import React from "react";
import { Helmet } from "react-helmet";
import { useStaticQuery, graphql } from "gatsby";

const SITE_URL = "{{site_url}}";

{% if multilang %}
function htmlLang(lang) {
  {% for lang in languages %}
  {% if lang.html_lang %}
  if (lang === "{{lang.code}}") return "{{lang.html_lang}}";
  {% endif %}
  {% endfor %}
  return lang;
}
{% endif %}

export default function SEO({
  title,
  description,
  image,
  url,
  {% if multilang %}lang = "{{primary_lang|default('en')}}",{% endif %}
  type = "website",
  article = null,
  alternateUrl = null,
  alternateLang = null,
  readingTime = null,
  children,
}) {
  const { site } = useStaticQuery(graphql`
    query SEOQuery {
      site {
        siteMetadata {
          title
          description
          siteUrl
        }
      }
    }
  `);

  const metaTitle = title
    ? `${title} -- ${site.siteMetadata.title}`
    : site.siteMetadata.title;
  const metaDescription = description || site.siteMetadata.description;
  const metaUrl = url || site.siteMetadata.siteUrl;
  const metaImage = image
    ? `${SITE_URL}${image}`
    : {% if default_og_image %}`${SITE_URL}{{default_og_image}}`{% else %}null{% endif %};
  const authorName = article?.author || "{{site_author|default(site_title)}}";

  // JSON-LD schema type based on article type
  const schemaType = article
    ? (article.type === "news" ? "NewsArticle" : "BlogPosting")
    : null;

  const wordCount = readingTime ? readingTime * 200 : undefined;

  return (
    <Helmet htmlAttributes={% raw %}{{ lang: {% endraw %}{% if multilang %}htmlLang(lang){% else %}"{{html_lang|default('en')}}"{% endif %} }}>
      <title>{metaTitle}</title>
      <meta name="description" content={metaDescription} />
      <link rel="canonical" href={metaUrl} />

      {/* Open Graph */}
      <meta property="og:site_name" content="{{site_title}}" />
      <meta property="og:title" content={title || site.siteMetadata.title} />
      <meta property="og:description" content={metaDescription} />
      {metaImage && <meta property="og:image" content={metaImage} />}
      {metaImage && <meta property="og:image:width" content="1200" />}
      {metaImage && <meta property="og:image:height" content="800" />}
      <meta property="og:url" content={metaUrl} />
      <meta property="og:type" content={type} />

      {/* Twitter Card */}
      <meta name="twitter:card" content={metaImage ? "summary_large_image" : "summary"} />
      <meta name="twitter:title" content={title || site.siteMetadata.title} />
      <meta name="twitter:description" content={metaDescription} />
      {metaImage && <meta name="twitter:image" content={metaImage} />}

      {/* Telegram Instant View hint */}
      <meta property="al:android:app_name" content="Medium" />

      {% if multilang %}
      {/* hreflang alternate links */}
      {alternateUrl && (
        <>
          <link rel="alternate" hreflang={htmlLang(lang)} href={metaUrl} />
          <link rel="alternate" hreflang={htmlLang(alternateLang)} href={`${SITE_URL}${alternateUrl}`} />
          <link rel="alternate" hreflang="x-default" href={lang === "{{primary_lang|default('en')}}" ? metaUrl : `${SITE_URL}${alternateUrl}`} />
        </>
      )}
      {% endif %}

      {/* Article-specific meta */}
      {article && (
        <>
          <meta property="article:published_time" content={`${article.date}T00:00:00Z`} />
          <meta property="article:author" content={authorName} />
        </>
      )}
      {article && article.tags && article.tags.map(tag => (
        <meta property="article:tag" content={tag} key={tag} />
      ))}

      {/* JSON-LD: Article schema */}
      {article && schemaType && (
        <script type="application/ld+json">
          {JSON.stringify({
            "@context": "https://schema.org",
            "@type": schemaType,
            headline: article.title,
            description: metaDescription,
            ...(metaImage && { image: metaImage }),
            url: metaUrl,
            datePublished: `${article.date}T00:00:00Z`,
            dateModified: `${article.date}T00:00:00Z`,
            {% if multilang %}inLanguage: htmlLang(lang),{% else %}inLanguage: "{{html_lang|default('en')}}",{% endif %}
            ...(wordCount && { wordCount }),
            ...(article.tags && { keywords: article.tags.join(", ") }),
            isAccessibleForFree: true,
            author: {
              "@type": "Person",
              name: authorName,
            },
            publisher: {
              "@type": "Organization",
              name: "{{site_title}}",
              url: SITE_URL,
              {% if logo_url %}
              logo: {
                "@type": "ImageObject",
                url: `${SITE_URL}{{logo_url}}`,
              },
              {% endif %}
            },
          })}
        </script>
      )}

      {/* JSON-LD: Breadcrumb */}
      {article && (
        <script type="application/ld+json">
          {JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            itemListElement: [
              {
                "@type": "ListItem",
                position: 1,
                name: "Home",
                item: {% if multilang %}`${SITE_URL}/${lang}/`{% else %}SITE_URL{% endif %},
              },
              {
                "@type": "ListItem",
                position: 2,
                name: article.title,
                item: metaUrl,
              },
            ],
          })}
        </script>
      )}

      {/* JSON-LD: WebSite (non-article pages) */}
      {!article && (
        <script type="application/ld+json">
          {JSON.stringify({
            "@context": "https://schema.org",
            "@type": "WebSite",
            name: "{{site_title}}",
            url: SITE_URL,
            description: site.siteMetadata.description,
            {% if multilang %}
            inLanguage: [{% for lang in languages %}"{{lang.html_lang|default(lang.code)}}"{% if not loop.last %}, {% endif %}{% endfor %}],
            {% else %}
            inLanguage: "{{html_lang|default('en')}}",
            {% endif %}
            publisher: {
              "@type": "Organization",
              name: "{{site_title}}",
              url: SITE_URL,
            },
          })}
        </script>
      )}

      {children}
    </Helmet>
  );
}
