"""Pipeline context: mutable state shared across all stages."""

from __future__ import annotations

from dataclasses import dataclass, field
from pathlib import Path


@dataclass
class PipelineContext:
    """Shared state flowing through pipeline stages."""

    # ---- Slot / scheduling ----
    slot_hour: int = 0
    slot_type: str = "news"  # news, material, guide, digest, etc.

    # ---- Editorial plan ----
    editorial_plan: dict | None = None  # topic, type, angle, sources_hint

    # ---- Collection ----
    news_items: list[dict] = field(default_factory=list)  # RSS headlines
    posted_slugs: list[str] = field(default_factory=list)  # already published

    # ---- Research ----
    research_text: str = ""

    # ---- Article ----
    title: str = ""
    slug: str = ""
    article_text: str = ""
    description: str = ""
    tags: list[str] = field(default_factory=list)
    hashtags: list[str] = field(default_factory=list)
    summary: str = ""  # for dedup in future planning

    # ---- Sources ----
    source_urls: list[str] = field(default_factory=list)
    source_names: list[str] = field(default_factory=list)

    # ---- Review ----
    review_approved: bool = False
    review_feedback: str = ""
    review_cycle: int = 0

    # ---- Telegram ----
    tg_post: str = ""
    tg_review_approved: bool = False

    # ---- Image ----
    image_prompt: str = ""
    image_path: Path | None = None

    # ---- Publishing ----
    article_url: str = ""
    msg_id: int | None = None
    site_ok: bool = False

{%- if languages | length > 1 %}

    # ---- Multi-language (optional) ----
    articles: dict[str, str] = field(default_factory=dict)  # {lang: text}
    tg_posts: dict[str, str] = field(default_factory=dict)
    titles: dict[str, str] = field(default_factory=dict)
    descriptions: dict[str, str] = field(default_factory=dict)
    msg_ids: dict[str, int] = field(default_factory=dict)
{%- endif %}
