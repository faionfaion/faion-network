{
  "type": "object",
  "required": ["articles"],
  "properties": {
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "type", "angle", "priority"],
        "properties": {
          "topic": {"type": "string", "description": "Specific article topic/headline"},
          "type": {"type": "string", "enum": ["news", "material", "guide", "utility", "digest"]},
          "angle": {"type": "string", "description": "Unique perspective or focus"},
          "sources_hint": {"type": "string", "description": "Where to research this topic"},
          "priority": {"type": "integer", "minimum": 1, "maximum": 3}
        }
      }
    }
  }
}
