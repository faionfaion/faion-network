<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="W3C Design Tokens Standard Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-platforms">target_platforms >= 2?</root-question>

    <branch when="single_platform == true">
      <conclusion ref="dtcg-keys-mandatory" verdict="skip-this-methodology — single-platform overhead unjustified"/>
    </branch>

    <branch when="single_platform == false">
      <question id="q-split">primitive/semantic split exists?</question>
      <branch when="split_exists == false">
        <conclusion ref="primitive-semantic-split" verdict="halt — fix split via token-organization first"/>
      </branch>
      <branch when="split_exists == true">
        <question id="q-alias-resolves">all aliases resolve?</question>
        <branch when="all_resolve == false">
          <conclusion ref="alias-resolves" verdict="fix unresolved aliases before publish"/>
        </branch>
        <branch when="all_resolve == true">
          <conclusion ref="contrast-on-color" verdict="run contrast check; publish if green"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="color-system-migration">
    single_platform=false → split_exists=true → all_resolve=true → conclusion contrast-on-color → publish tokens.json.
  </example>
</text>
