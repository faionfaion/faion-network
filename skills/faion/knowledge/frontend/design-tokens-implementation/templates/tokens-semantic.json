{
  "$schema": "https://tr.designtokens.org/format/",
  "comment": "Semantic token layer — W3C DTCG format ($value, $type). Aliases reference primitives.",

  "color": {
    "bg": {
      "primary": {
        "$value": "{color.gray.0}",
        "$type": "color",
        "$description": "Default page/surface background."
      },
      "secondary": {
        "$value": "{color.gray.50}",
        "$type": "color",
        "$description": "Subdued surface (cards, sidebars)."
      },
      "inverse": {
        "$value": "{color.gray.900}",
        "$type": "color",
        "$description": "Dark background for high-contrast sections."
      }
    },
    "text": {
      "primary": {
        "$value": "{color.gray.900}",
        "$type": "color",
        "$description": "Default body text."
      },
      "secondary": {
        "$value": "{color.gray.600}",
        "$type": "color",
        "$description": "Supporting / caption text."
      },
      "disabled": {
        "$value": "{color.gray.400}",
        "$type": "color"
      },
      "inverse": {
        "$value": "{color.gray.0}",
        "$type": "color",
        "$description": "Text on dark/colored backgrounds."
      }
    },
    "action": {
      "primary": {
        "$value": "{color.blue.600}",
        "$type": "color",
        "$description": "Primary CTA background."
      },
      "primary-hover": {
        "$value": "{color.blue.700}",
        "$type": "color"
      },
      "danger": {
        "$value": "{color.red.600}",
        "$type": "color"
      }
    },
    "border": {
      "default": {
        "$value": "{color.gray.200}",
        "$type": "color"
      },
      "strong": {
        "$value": "{color.gray.400}",
        "$type": "color"
      }
    }
  },

  "spacing": {
    "1":  { "$value": "0.25rem", "$type": "dimension" },
    "2":  { "$value": "0.5rem",  "$type": "dimension" },
    "4":  { "$value": "1rem",    "$type": "dimension" },
    "6":  { "$value": "1.5rem",  "$type": "dimension" },
    "8":  { "$value": "2rem",    "$type": "dimension" },
    "12": { "$value": "3rem",    "$type": "dimension" },
    "16": { "$value": "4rem",    "$type": "dimension" }
  },

  "radius": {
    "sm": { "$value": "0.25rem",  "$type": "dimension" },
    "md": { "$value": "0.375rem", "$type": "dimension" },
    "lg": { "$value": "0.5rem",   "$type": "dimension" },
    "xl": { "$value": "0.75rem",  "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  }
}
