<text id="02-output-contract" title="Paid Test-Task Scoring Rubric Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the rubric artefact this methodology produces. Validator script enforces required keys, field shapes, and forbidden patterns. Output that fails the schema is rejected.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/paid-test-task-scoring-rubric.json",
  "title": "Paid Test-Task Scoring Rubric",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artefact_id",
    "owner",
    "dimensions",
    "calibrated",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "dimensions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "name",
          "anchors",
          "weight"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "anchors": {
            "type": "array",
            "minItems": 5,
            "items": {
              "type": "string"
            }
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "calibrated": {
      "type": "boolean",
      "const": true
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "paid-test-task-scoring-rubric-rubric-v1",
  "owner": "ruslan@faion.net",
  "dimensions": [
    {
      "name": "scope",
      "anchors": [
        "minimal",
        "narrow",
        "balanced",
        "broad",
        "excessive"
      ],
      "weight": 0.4
    },
    {
      "name": "impact",
      "anchors": [
        "none",
        "low",
        "medium",
        "high",
        "critical"
      ],
      "weight": 0.4
    },
    {
      "name": "clarity",
      "anchors": [
        "unclear",
        "partial",
        "clear",
        "very-clear",
        "exemplary"
      ],
      "weight": 0.2
    }
  ],
  "calibrated": true,
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "BAD ID",
  "owner": "",
  "version": "draft"
}
]]></code>
    <note>artefact_id violates pattern; owner is empty; version not semver; required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>owner equals "team" / "we" / "us" / empty string</item>
      <item>rationale or evidence that does not cite at least one input artefact by name</item>
      <item>version frozen at 1.0.0 when decision content has changed</item>
      <item>artefact_id reuses an existing id within the same store</item>
    </list>
  </section>

  <reference path="scripts/validate-paid-test-task-scoring-rubric.py">Validator script (stdlib-only; --help + --self-test)</reference>
</text>
