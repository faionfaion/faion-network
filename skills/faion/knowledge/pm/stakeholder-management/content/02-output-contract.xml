<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Management Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the spec artefact this methodology produces, with valid and invalid examples plus forbidden patterns.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-management.json",
  "type": "object",
  "required": [
    "project_id",
    "stakeholders",
    "decision_rights",
    "escalation_triggers",
    "upward_comms_cadence"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "power",
          "interest",
          "attitude",
          "engagement"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "power": {
            "enum": [
              "high",
              "low"
            ]
          },
          "interest": {
            "enum": [
              "high",
              "low"
            ]
          },
          "attitude": {
            "enum": [
              "supporter",
              "neutral",
              "blocker"
            ]
          },
          "engagement": {
            "type": "object",
            "required": [
              "frequency",
              "channel",
              "content"
            ],
            "properties": {
              "frequency": {
                "type": "string"
              },
              "channel": {
                "type": "string"
              },
              "content": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "decision_rights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "decision_type",
          "rights"
        ],
        "properties": {
          "decision_type": {
            "type": "string"
          },
          "rights": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "stakeholder_id",
                "role"
              ],
              "properties": {
                "stakeholder_id": {
                  "type": "string"
                },
                "role": {
                  "enum": [
                    "D",
                    "I",
                    "V"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "escalation_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "trigger",
          "escalate_to"
        ]
      }
    },
    "upward_comms_cadence": {
      "type": "object",
      "required": [
        "weekly_status",
        "monthly_review"
      ],
      "properties": {
        "weekly_status": {
          "type": "string"
        },
        "monthly_review": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "acme-launch-2026q3",
  "stakeholders": [
    {
      "id": "s-cmo",
      "name": "Maria CMO",
      "power": "high",
      "interest": "high",
      "attitude": "supporter",
      "engagement": {
        "frequency": "weekly 30min",
        "channel": "slack-then-1on1",
        "content": "launch readiness matrix + risks"
      }
    },
    {
      "id": "s-legal",
      "name": "Frank Legal",
      "power": "high",
      "interest": "low",
      "attitude": "blocker",
      "engagement": {
        "frequency": "biweekly 15min",
        "channel": "doc-review",
        "content": "ToS + data residency questions"
      }
    }
  ],
  "decision_rights": [
    {
      "decision_type": "launch-go-no-go",
      "rights": [
        {
          "stakeholder_id": "s-cmo",
          "role": "D"
        },
        {
          "stakeholder_id": "s-legal",
          "role": "V"
        }
      ]
    }
  ],
  "escalation_triggers": [
    {
      "trigger": "legal raises Veto on ToS",
      "escalate_to": "Head of Product"
    }
  ],
  "upward_comms_cadence": {
    "weekly_status": "Friday 14:00 Slack",
    "monthly_review": "First Tuesday 30min"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "p1",
  "stakeholders": [
    {
      "id": "s1",
      "name": "x",
      "power": "very-high",
      "interest": "yes"
    }
  ],
  "decision_rights": [],
  "escalation_triggers": [],
  "upward_comms_cadence": {}
}
]]></code>
    <note>stakeholder missing attitude + engagement; power/interest enums invalid; decision_rights empty; escalation_triggers empty; upward_comms missing both cadence keys.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>stakeholder missing attitude axis (two-axis grid).</item>
      <item>stakeholder engagement missing frequency / channel / content (ad-hoc cadence).</item>
      <item>decision_rights empty (re-litigation risk).</item>
      <item>escalation_triggers empty (ad-hoc escalation).</item>
      <item>upward_comms_cadence missing weekly_status or monthly_review (silence risk).</item>
    </list>
  </section>

  <reference path="scripts/validate-stakeholder-management.py">Validator script enforcing this schema</reference>
</text>
