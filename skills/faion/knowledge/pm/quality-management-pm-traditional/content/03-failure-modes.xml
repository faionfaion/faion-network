<text id="03-failure-modes" title="Quality Management Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns observed in real deployments. Each pairs a symptom (observable signal) with root cause and concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="adjective-thresholds" severity="high">
      <symptom>Quality plan reads 'fast and reliable'.</symptom>
      <root-cause>no numeric thresholds</root-cause>
      <fix>Convert each adjective to metric × threshold.</fix>
    </antipattern>

    <antipattern id="judgement-gate" severity="high">
      <symptom>Quality gate is 'reviewer thinks it's fine'.</symptom>
      <root-cause>no scripted gate artefact</root-cause>
      <fix>Implement scripted gate with thresholds.</fix>
    </antipattern>

    <antipattern id="severity-priority-merged" severity="medium">
      <symptom>Single 'urgency' field replaces both severity and priority.</symptom>
      <root-cause>no separate severity + priority fields</root-cause>
      <fix>Restore both dimensions.</fix>
    </antipattern>

  </section>

  <see-also>
    <link path="content/01-core-rules.xml"/>
    <link path="content/06-decision-tree.xml"/>
  </see-also>
</text>
