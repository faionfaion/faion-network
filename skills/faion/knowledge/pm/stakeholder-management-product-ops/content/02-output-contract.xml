<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Management Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-register.json",
  "type": "object",
  "required": [
    "project",
    "stakeholders",
    "approval_gates"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "power",
          "interest",
          "attitude",
          "owner",
          "cadence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "power": {
            "enum": [
              "high",
              "low"
            ]
          },
          "interest": {
            "enum": [
              "high",
              "low"
            ]
          },
          "attitude": {
            "enum": [
              "supporter",
              "neutral",
              "resistor"
            ]
          },
          "owner": {
            "type": "string"
          },
          "cadence": {
            "enum": [
              "weekly",
              "biweekly",
              "monthly",
              "quarterly"
            ]
          },
          "last_contact": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "approval_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "transition",
          "approvers"
        ]
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project": "faion-launch",
  "stakeholders": [
    {
      "name": "VP Sales",
      "power": "high",
      "interest": "high",
      "attitude": "neutral",
      "owner": "ruslan",
      "cadence": "biweekly",
      "last_contact": "2026-05-18"
    }
  ],
  "approval_gates": [
    {
      "transition": "backlog\u2192todo",
      "approvers": [
        "ruslan"
      ]
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project": "x",
  "stakeholders": [
    {
      "name": "VP Sales",
      "power": "high"
    }
  ]
}
]]></code>
    <note>stakeholder missing attitude, owner, cadence; approval_gates missing.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">row without attitude</pattern>
    <pattern id="f2">row without owner+cadence</pattern>
    <pattern id="f3">approval gate without named approvers</pattern>
    <pattern id="f4">broadcast comms to mixed-attitude lists</pattern>
  </section>

  <reference path="scripts/validate-stakeholder-management.py">Validator script (stdlib-only).</reference>
</text>
