<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Trello Kanban Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/trello-kanban.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "board_url",
    "columns",
    "wip_limits",
    "labels",
    "powerups",
    "butler_rules",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "board_url": {
      "type": "string"
    },
    "columns": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5
    },
    "wip_limits": {
      "type": "object"
    },
    "labels": {
      "type": "array",
      "maxItems": 8
    },
    "powerups": {
      "type": "array",
      "maxItems": 2
    },
    "butler_rules": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">columns.length != 5 — violates r1</pattern>
      <pattern id="f2">wip_limits missing for In Progress OR Review — violates r2</pattern>
      <pattern id="f3">labels.length &gt; 8 — violates r3</pattern>
      <pattern id="f4">powerups.length &gt; 2 — violates r4</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "trello-kanban-ops-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "board_url": "https://trello.com/b/abc/ops",
  "columns": [
    "Backlog",
    "Ready",
    "In Progress",
    "Review",
    "Done"
  ],
  "wip_limits": {
    "Ready": 8,
    "In Progress": 6,
    "Review": 5
  },
  "labels": [
    "bug",
    "feat",
    "ops",
    "sales",
    "onboarding",
    "billing"
  ],
  "powerups": [
    "calendar",
    "github"
  ],
  "butler_rules": [
    {
      "name": "auto-archive-done-30d",
      "trigger": "card in Done >30d",
      "action": "archive"
    }
  ],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "board_url": "https://trello.com/b/x/y",
  "columns": [
    "A",
    "B",
    "C",
    "D",
    "E",
    "F",
    "G",
    "H"
  ],
  "wip_limits": {},
  "labels": [
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x",
    "x"
  ],
  "powerups": [
    "a",
    "b",
    "c",
    "d",
    "e"
  ],
  "butler_rules": [],
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-trello-kanban.py">Schema validator (stdlib only).</reference>
</text>
