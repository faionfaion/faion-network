<methodology slug="performance-domains-overview">
  <metadata>
    <tier>pro</tier>
    <group>pm</group>
    <domain>project-manager</domain>
    <summary>PMBoK 7 defines eight interconnected performance domains — Stakeholder, Team, Development Approach, Planning, Project Work, Delivery, Measurement, Uncertainty — enabling successful project delivery.</summary>
    <tags>
      <tag>pmbok7</tag>
      <tag>performance-domains</tag>
      <tag>project-assessment</tag>
      <tag>governance</tag>
      <tag>framework</tag>
