<text id="05-examples" title="Team Morale Pulse Survey Worked Example" version="1.1.0" est_tokens="500" depth="medium">
  <summary>One complete weekly cycle for a 6-person team where eNPS dropped and an alert fired.</summary>

  <section title="Worked example">

    <example type="good" title="Week with axis_median_low alert">
      <code lang="json"><![CDATA[
{
  "team_id": "checkout-squad",
  "sprint_id": "S14",
  "week_iso": "2026-W21",
  "responses_received": 5,
  "team_size": 6,
  "response_rate": 0.83,
  "anonymity_threshold_met": true,
  "scores": {
    "enps": {"value": -40, "promoter_pct": 20, "passive_pct": 20, "detractor_pct": 60},
    "workload": {"mean": 3.4, "median": 3},
    "autonomy": {"mean": 5.6, "median": 6},
    "clarity": {"mean": 4.2, "median": 4}
  },
  "trend_vs_prior_sprint": {
    "enps_delta": -28,
    "workload_median_delta": -2,
    "autonomy_median_delta": 0,
    "clarity_median_delta": -2
  },
  "alerts_triggered": [
    {
      "alert_id": "a-2026W21-1",
      "trigger": "enps_drop",
      "evidence": {"prior": -12, "current": -40, "delta": -28, "threshold": -20},
      "action_required": "one_on_ones_within_48h",
      "due_by": "2026-05-25T17:00:00Z",
      "responsible_pm": "pm-handle"
    },
    {
      "alert_id": "a-2026W21-2",
      "trigger": "axis_median_low",
      "evidence": {"axis": "workload", "median": 3, "threshold": 6},
      "action_required": "one_on_ones_within_48h",
      "due_by": "2026-05-25T17:00:00Z",
      "responsible_pm": "pm-handle"
    }
  ]
}
]]></code>
      <note>Both eNPS drop &gt; 20 AND axis median &lt; 6 trigger alerts; same `due_by`; PM owns 1:1s in 48h. Anonymity met (5 of 6, ≥ 60%).</note>
    </example>

  </section>
</text>
