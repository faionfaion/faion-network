<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Client Visibility vs Velocity Tradeoff Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/client-visibility-vs-velocity-tradeoff.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "clients",
    "cadence_policy",
    "visibility_budget_hours_per_week",
    "update_template_url",
    "next_tier_revisit",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "clients": {
      "type": "array",
      "minItems": 1
    },
    "cadence_policy": {
      "type": "object"
    },
    "visibility_budget_hours_per_week": {
      "type": "number"
    },
    "update_template_url": {
      "type": "string"
    },
    "next_tier_revisit": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">clients missing tier — violates r1</pattern>
      <pattern id="f2">cadence_policy missing tier-specific rules — violates r2</pattern>
      <pattern id="f3">visibility_budget &gt; 0.4 of weekly capacity hours — violates r3</pattern>
      <pattern id="f4">update_template_url empty — violates r4</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "client-visibility-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "clients": [
    {
      "name": "client-a",
      "tier": "HIGH",
      "contract_value": 35000
    },
    {
      "name": "client-b",
      "tier": "MID",
      "contract_value": 12000
    },
    {
      "name": "client-c",
      "tier": "LOW",
      "contract_value": 2500
    }
  ],
  "cadence_policy": {
    "HIGH": "weekly-call + daily-slack",
    "MID": "weekly-email + as-needed-slack",
    "LOW": "biweekly-email"
  },
  "visibility_budget_hours_per_week": 6,
  "update_template_url": "templates/status-update.md",
  "next_tier_revisit": "2026-08-15",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "clients": [
    {
      "name": "client-a"
    }
  ],
  "cadence_policy": {},
  "visibility_budget_hours_per_week": 18,
  "update_template_url": "",
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-client-visibility-vs-velocity-tradeoff.py">Schema validator (stdlib only).</reference>
</text>
