<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Steerco Meeting Playbook Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Steerco state at T-5 days?</root-question>
    <branch when="signal == asks_count_0">
      <conclusion ref="cancel-if-no-decisions" verdict="cancel + send written status memo"/>
    </branch>
    <branch when="signal == asks_count_ge_1_binary">
      <conclusion ref="ask-list-binary" verdict="proceed; ensure pre-read sent T-3"/>
    </branch>
    <branch when="signal == asks_present_but_vague">
      <conclusion ref="ask-list-binary" verdict="rewrite as binary approve/reject/defer; re-circulate"/>
    </branch>
    <root-question id="q-2">Meeting outcome?</root-question>
    <branch when="signal == decisions_made">
      <conclusion ref="decision-memo-48h" verdict="send memo within 48h with each ask + decision + rationale + owner"/>
    </branch>
    <branch when="signal == decisions_deferred">
      <conclusion ref="decision-memo-48h" verdict="memo captures defer + trigger to revisit"/>
    </branch>
  </decision-tree>
</text>
