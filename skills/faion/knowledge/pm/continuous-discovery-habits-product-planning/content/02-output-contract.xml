<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Continuous Discovery Habits Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/discovery-spec.json",
  "type": "object",
  "required": [
    "week",
    "trio",
    "touchpoints",
    "ost",
    "specs"
  ],
  "properties": {
    "week": {
      "type": "string"
    },
    "trio": {
      "type": "object",
      "required": [
        "pm",
        "design",
        "tech"
      ],
      "properties": {
        "pm": {
          "type": "string"
        },
        "design": {
          "type": "string"
        },
        "tech": {
          "type": "string"
        }
      }
    },
    "touchpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "date",
          "attendees",
          "customer"
        ]
      }
    },
    "ost": {
      "type": "object",
      "required": [
        "outcome",
        "opportunities"
      ],
      "properties": {
        "outcome": {
          "type": "string"
        },
        "opportunities": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "opportunity_id"
        ]
      }
    },
    "assumption_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "solution_id",
          "assumption",
          "test"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "week": "2026-W21",
  "trio": {
    "pm": "ruslan",
    "design": "lara",
    "tech": "kostya"
  },
  "touchpoints": [
    {
      "date": "2026-05-21",
      "attendees": [
        "ruslan",
        "lara",
        "kostya"
      ],
      "customer": "acme"
    }
  ],
  "ost": {
    "outcome": "raise activation 20%",
    "opportunities": [
      "new-user friction in step 2"
    ]
  },
  "specs": [
    {
      "id": "spec-onboard-v2",
      "opportunity_id": "opp-step2"
    }
  ],
  "assumption_tests": [
    {
      "solution_id": "sol-tooltip",
      "assumption": "tooltip clarifies step 2",
      "test": "fake-door 5%"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "week": "May",
  "trio": {
    "pm": "ruslan"
  }
}
]]></code>
    <note>Trio missing design + tech; touchpoints empty.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">PM-only touchpoint</pattern>
    <pattern id="f2">&lt;1 touchpoint per week</pattern>
    <pattern id="f3">spec without opportunity_id</pattern>
    <pattern id="f4">feature build before assumption test</pattern>
  </section>

  <reference path="scripts/validate-continuous-discovery-habits.py">Validator script (stdlib-only).</reference>
</text>
