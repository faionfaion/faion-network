<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Async Standup Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 for the daily standup post and the weekly digest. Validator rejects posts with empty blocker/owner inconsistencies or digests authored by the worker being summarised.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/async-standup-template.json",
  "oneOf": [
    {
      "type": "object",
      "required": ["kind", "author", "posted_at", "yesterday", "today", "blocker"],
      "properties": {
        "kind": {"const": "post"},
        "author": {"type": "string", "minLength": 1},
        "posted_at": {"type": "string", "format": "date-time"},
        "in_window": {"type": "boolean"},
        "yesterday": {"type": "string", "minLength": 1, "maxLength": 400},
        "today": {"type": "string", "minLength": 1, "maxLength": 400},
        "blocker": {"type": "string", "minLength": 1, "maxLength": 600},
        "blocker_owner": {"type": ["string", "null"]}
      }
    },
    {
      "type": "object",
      "required": ["kind", "author", "week_window", "shipped", "in_progress",
                   "unresolved_blockers", "missed_posters", "next_week_risk"],
      "properties": {
        "kind": {"const": "digest"},
        "author": {"type": "string"},
        "week_window": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}\\.\\.[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "shipped": {"type": "array", "items": {"type": "string"}, "maxItems": 7},
        "in_progress": {"type": "array", "items": {"type": "string"}, "maxItems": 7},
        "unresolved_blockers": {"type": "array", "items": {"type": "string"}},
        "missed_posters": {"type": "array", "items": {"type": "string"}},
        "next_week_risk": {"type": "string", "minLength": 1, "maxLength": 400}
      }
    }
  ]
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "kind": "post",
  "author": "U_ALICE",
  "posted_at": "2026-05-23T08:15:00+02:00",
  "in_window": true,
  "yesterday": "Shipped checkout flow v2 to staging; pair-debugged Klaviyo webhook with Maria.",
  "today": "Production rollout behind feature flag (10% canary), then monitor 4h before broadening.",
  "blocker": "Need DB migration window for canary promotion; proposing 14:00 UTC tomorrow.",
  "blocker_owner": "U_RAJ"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "kind": "post",
  "author": "U_ALICE",
  "posted_at": "2026-05-23T08:15:00+02:00",
  "yesterday": "Stuff.",
  "today": "Stuff.",
  "blocker": "Blocked by DB migration window",
  "blocker_owner": null
}
]]></code>
    <note>Blocker text present but blocker_owner null — violates rule r3-blocker-routing-and-sla. yesterday/today identical — violates rule r1-three-field-shape (copy-paste signal).</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>post.blocker non-"none" with blocker_owner null.</item>
      <item>post fields with literal placeholders (TBD, WIP, TODO).</item>
      <item>post total &gt; 250 words.</item>
      <item>digest authored by the same contributor whose work it summarises.</item>
      <item>digest entries not traceable to a daily post.</item>
      <item>post.yesterday == post.today (signal of copy-paste / disengagement).</item>
    </list>
  </section>

  <reference path="scripts/validate-async-standup-template.py">Validator script enforcing this schema</reference>
</text>
