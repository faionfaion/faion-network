<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Trello Kanban Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for trello-kanban.</summary>

  <decision-tree>
    <root-question id="q-root">Is Trello the right tool AND is the board within the methodology's caps?</root-question>

    <branch when="needs_code_traceability == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — use GitHub Projects"/>
    </branch>
    <branch when="lists_count &gt; 7 OR lists_count &lt; 5">
      <conclusion ref="r1-lists-7-max-wip-named" verdict="BLOCK — adjust list count"/>
    </branch>
    <branch when="labels_count &gt; 12">
      <conclusion ref="r2-labels-12-max-closed-list" verdict="BLOCK — trim labels"/>
    </branch>
    <branch when="data_in_card_titles == true">
      <conclusion ref="r3-custom-fields-not-titles" verdict="BLOCK — migrate to custom fields"/>
    </branch>
    <branch when="ids_cached == false">
      <conclusion ref="r5-cached-ids-no-name-lookup-per-write" verdict="BLOCK — cache IDs"/>
    </branch>
    <branch when="rate_limit_per_10s &gt; 100">
      <conclusion ref="r6-rate-limit-100-per-10s" verdict="BLOCK — cap to 100"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — agents may write to the board"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="trello-kanban-happy-path">
    Solo team + no code traceability need + 6 lists with WIP + 7 labels in taxonomy + custom fields enabled + ids_cached=true + rate_limit=80 → APPROVE.
  </example>
</text>
