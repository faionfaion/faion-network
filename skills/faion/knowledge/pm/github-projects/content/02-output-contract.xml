<text id="02-output-contract" title="GitHub Projects Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/github-projects.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "project_urls",
    "linked_repos",
    "custom_fields_count",
    "primary_axis",
    "automation_workflows",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "project_urls": {
      "type": "array",
      "maxItems": 2
    },
    "linked_repos": {
      "type": "array",
      "minItems": 1
    },
    "custom_fields_count": {
      "type": "integer",
      "maximum": 8
    },
    "primary_axis": {
      "type": "string",
      "enum": [
        "iteration",
        "status"
      ]
    },
    "automation_workflows": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">project_urls.length &gt; 2 — violates r1</pattern>
      <pattern id="f2">linked_repos empty — violates r2</pattern>
      <pattern id="f3">custom_fields_count &gt; 8 — violates r3</pattern>
      <pattern id="f4">primary_axis not in [&apos;iteration&apos;, &apos;status&apos;] — violates r4</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "github-projects-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "project_urls": [
    "https://github.com/orgs/faion/projects/1"
  ],
  "linked_repos": [
    "faionfaion/faion-cli",
    "faionfaion/faion-net"
  ],
  "custom_fields_count": 6,
  "primary_axis": "iteration",
  "automation_workflows": [
    ".github/workflows/project-automation.yml"
  ],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_urls": [
    "a",
    "b",
    "c",
    "d"
  ],
  "linked_repos": [],
  "custom_fields_count": 22,
  "primary_axis": "neither",
  "automation_workflows": [],
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-github-projects.py">Schema validator (stdlib only).</reference>
</text>
