<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Agency Pipeline Hygiene 15min Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>5-step procedure.</summary>

  <section title="Procedure">
    <step n="1" name="export">
      <input>CRM</input>
      <action>Export current pipeline + last-week closes.</action>
      <output>Raw export</output>
    </step>
    <step n="2" name="checklist">
      <input>Raw export + checklist template</input>
      <action>Walk 5 items; mark green/amber/red; name actions on amber.</action>
      <output>Checklist artefact</output>
      <decision-gate>Reject amber with empty action.</decision-gate>
    </step>
    <step n="3" name="fix-in-crm">
      <input>Action items</input>
      <action>Apply field updates, stage moves, tags in CRM.</action>
      <output>Cleaned CRM state</output>
    </step>
    <step n="4" name="ledger">
      <input>Cleaned CRM state</input>
      <action>Compute ledger metrics; append row to ledger CSV.</action>
      <output>Ledger row</output>
    </step>
    <step n="5" name="next-steps">
      <input>Hot-opp list</input>
      <action>Schedule next-steps for hot opps; send required follow-ups.</action>
      <output>Scheduled follow-ups</output>
    </step>
  </section>
</text>
