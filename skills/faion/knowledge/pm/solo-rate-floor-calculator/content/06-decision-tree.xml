<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Solo Rate Floor Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from 01-core-rules.xml for solo-rate-floor-calculator.</summary>

  <decision-tree>
    <root-question id="q-root">Is the operator full-time solo AND are inputs within the methodology's accepted bands?</root-question>

    <branch when="operator_has_w2 == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — side-income rate-floor logic does not apply"/>
    </branch>
    <branch when="engagement_hours_total &lt; 10">
      <conclusion ref="skip-this-methodology" verdict="SKIP — micro-engagement, fixed-price wins"/>
    </branch>
    <branch when="billable_pct &gt; 0.55 AND historical_data_cited == false">
      <conclusion ref="r1-honest-billable" verdict="BLOCK — cap to 0.55 or cite history"/>
    </branch>
    <branch when="tax_load_pct &lt; jurisdictional_floor">
      <conclusion ref="r2-all-in-tax" verdict="BLOCK — raise to jurisdictional default"/>
    </branch>
    <branch when="working_weeks &gt; 46">
      <conclusion ref="r3-downtime-load" verdict="BLOCK — cap to 46"/>
    </branch>
    <branch when="profit_margin_pct &lt; 0.15">
      <conclusion ref="r4-profit-margin" verdict="BLOCK — raise margin or accept wage outcome"/>
    </branch>
    <branch when="sensitivity_bands_count &lt; 3">
      <conclusion ref="r5-sensitivity-bands" verdict="BLOCK — emit 3 bands ±10pp"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — emit floor and quote"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="solo-rate-floor-calculator-happy-path">
    Full-time solo + 40h engagement + billable=0.55 + tax=0.34 (US default) + W=46 + margin=0.20 + 3 bands emitted → APPROVE → floor $235/hr.
  </example>
</text>
