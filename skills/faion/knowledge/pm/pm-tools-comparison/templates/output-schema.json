{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/pm-tools-comparison.json",
  "__faion_header__": {
    "purpose": "JSON Schema for the PM Tools Comparison artefact",
    "consumes": "see content/02-output-contract.xml inputs for pm-tools-comparison",
    "produces": "artefact conforming to content/02-output-contract.xml schema",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~200-1000 tokens when loaded as context"
  },
  "type": "object",
  "required": [
    "report_id",
    "tools",
    "criteria_weights",
    "scores",
    "tco",
    "recommendation",
    "decision_owner"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5
    },
    "criteria_weights": {
      "type": "object",
      "required": [
        "core_features",
        "usability",
        "integrations",
        "enterprise",
        "cost"
      ]
    },
    "scores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "core_features",
          "usability",
          "integrations",
          "enterprise",
          "cost",
          "evidence"
        ]
      }
    },
    "tco": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "year_1",
          "year_2",
          "year_3",
          "total"
        ]
      }
    },
    "recommendation": {
      "type": "object",
      "required": [
        "tool",
        "rationale"
      ]
    },
    "decision_owner": {
      "type": "string"
    },
    "dissents": {
      "type": "array"
    }
  }
}
