<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agile Ceremonies Setup Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the ceremonies config artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agile-ceremonies-setup.json",
  "type": "object",
  "required": [
    "team",
    "sprint_length_weeks",
    "ceremonies",
    "overhead_pct"
  ],
  "properties": {
    "team": {
      "type": "string"
    },
    "sprint_length_weeks": {
      "enum": [
        1,
        2,
        3
      ]
    },
    "ceremonies": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "name",
          "purpose",
          "timebox_minutes",
          "attendees_mandatory",
          "owner",
          "output"
        ],
        "properties": {
          "name": {
            "enum": [
              "sprint_planning",
              "daily_standup",
              "refinement",
              "review",
              "retro"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 12
          },
          "timebox_minutes": {
            "type": "integer",
            "minimum": 5
          },
          "attendees_mandatory": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "attendees_optional": {
            "type": "array"
          },
          "owner": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    },
    "overhead_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 0.1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "team": "platform",
  "sprint_length_weeks": 2,
  "ceremonies": [
    {
      "name": "sprint_planning",
      "purpose": "Commit to sprint goal + ordered backlog",
      "timebox_minutes": 120,
      "attendees_mandatory": [
        "team",
        "PO"
      ],
      "owner": "SM",
      "output": "sprint plan artefact"
    },
    {
      "name": "daily_standup",
      "purpose": "Surface blockers + alignment",
      "timebox_minutes": 15,
      "attendees_mandatory": [
        "team"
      ],
      "owner": "SM",
      "output": "blocker list"
    },
    {
      "name": "review",
      "purpose": "Inspect increment with stakeholders",
      "timebox_minutes": 60,
      "attendees_mandatory": [
        "team",
        "PO",
        "stakeholders"
      ],
      "owner": "PO",
      "output": "feedback log"
    },
    {
      "name": "retro",
      "purpose": "Adapt team process; produce action items",
      "timebox_minutes": 90,
      "attendees_mandatory": [
        "team",
        "SM"
      ],
      "owner": "SM",
      "output": "action items with owner+due"
    }
  ],
  "overhead_pct": 0.08
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "team": "x"
}
]]></code>
    <note>sprint_length_weeks missing; ceremonies array missing or wrong size; overhead_pct missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="no-purpose"><description>ceremony with purpose &lt; 12 chars</description><reason>Purpose-less ceremony degrades.</reason></forbidden-pattern>
    <forbidden-pattern id="no-timebox"><description>ceremony missing timebox_minutes</description><reason>Drift inevitable.</reason></forbidden-pattern>
    <forbidden-pattern id="over-10pct"><description>overhead_pct &gt; 0.10</description><reason>Ceremonies cost more than return.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-agile-ceremonies-setup.py">Validator script</reference>
</text>
