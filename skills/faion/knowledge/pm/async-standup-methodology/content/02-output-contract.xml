<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Async Standup Methodology Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/async-standup-methodology.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "channel",
    "post_window_local",
    "participants",
    "blocker_policy",
    "weekly_rollup_day",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "channel": {
      "type": "string"
    },
    "post_window_local": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "minItems": 2
    },
    "blocker_policy": {
      "type": "object"
    },
    "weekly_rollup_day": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">participants.length &lt; 2 — no audience, violates applies-if</pattern>
      <pattern id="f2">blocker_policy missing escalation owner + ETA — violates r3</pattern>
      <pattern id="f3">weekly_rollup_day missing — violates r4</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "async-standup-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "channel": "#daily-standup",
  "post_window_local": "by 11:00 local",
  "participants": [
    "@ruslan",
    "@contractor-1",
    "@contractor-2"
  ],
  "blocker_policy": {
    "escalation_owner": "@ruslan",
    "eta_hours": 24
  },
  "weekly_rollup_day": "Friday",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "channel": "#daily-standup",
  "participants": [
    "@ruslan"
  ],
  "blocker_policy": {},
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-async-standup-methodology.py">Schema validator (stdlib only).</reference>
</text>
