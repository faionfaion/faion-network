<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Schedule Development Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Path classification?</root-question>
    <branch when="signal == critical_float_0">
      <conclusion ref="track-near-critical-paths" verdict="manage actively; daily standup line item"/>
    </branch>
    <branch when="signal == near_critical_float_lt_2">
      <conclusion ref="track-near-critical-paths" verdict="report at every status review; one slip promotes it"/>
    </branch>
    <branch when="signal == non_critical_float_ge_2">
      <conclusion ref="fs-by-default" verdict="monitor; level overloads here first"/>
    </branch>
    <root-question id="q-2">Date math context?</root-question>
    <branch when="signal == agent_computation">
      <conclusion ref="business-calendar" verdict="use business_calendar lib; never raw date arithmetic"/>
    </branch>
    <branch when="signal == manual_review">
      <conclusion ref="business-calendar" verdict="verify holidays + half-days listed in calendar.yaml"/>
    </branch>
  </decision-tree>
</text>
