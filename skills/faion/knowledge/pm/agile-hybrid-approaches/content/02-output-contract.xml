<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agile Hybrid Approaches Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the mode-decision record.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agile-hybrid-decision.json",
  "type": "object",
  "required": [
    "programme",
    "decision_date",
    "sponsor",
    "dimensions",
    "recommendation",
    "named_hybrid_tilt",
    "reevaluation_triggers"
  ],
  "properties": {
    "programme": {
      "type": "string"
    },
    "decision_date": {
      "type": "string",
      "format": "date"
    },
    "sponsor": {
      "type": "string"
    },
    "dimensions": {
      "type": "object",
      "required": [
        "requirement_volatility",
        "team_skill_uniformity",
        "failure_cost_low",
        "team_size_small",
        "culture_fit_agile",
        "domain_uncertainty_high"
      ],
      "properties": {
        "requirement_volatility": {
          "type": "object",
          "required": [
            "score",
            "evidence"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "team_skill_uniformity": {
          "type": "object",
          "required": [
            "score",
            "evidence"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "failure_cost_low": {
          "type": "object",
          "required": [
            "score",
            "evidence"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "team_size_small": {
          "type": "object",
          "required": [
            "score",
            "evidence"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "culture_fit_agile": {
          "type": "object",
          "required": [
            "score",
            "evidence"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence": {
              "type": "string"
            }
          }
        },
        "domain_uncertainty_high": {
          "type": "object",
          "required": [
            "score",
            "evidence"
          ],
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "evidence": {
              "type": "string"
            }
          }
        }
      }
    },
    "recommendation": {
      "enum": [
        "predictive",
        "agile",
        "hybrid"
      ]
    },
    "named_hybrid_tilt": {
      "type": "string"
    },
    "reevaluation_triggers": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "programme": "regulated-claims-platform",
  "decision_date": "2026-05-22",
  "sponsor": "COO",
  "dimensions": {
    "requirement_volatility": {
      "score": 0.4,
      "evidence": "regulator change-log cadence"
    },
    "team_skill_uniformity": {
      "score": 0.6,
      "evidence": "skill-matrix Q2"
    },
    "failure_cost_low": {
      "score": 0.2,
      "evidence": "SLA fines $200k per outage"
    },
    "team_size_small": {
      "score": 0.5,
      "evidence": "8 FTE delivery team"
    },
    "culture_fit_agile": {
      "score": 0.7,
      "evidence": "team Scrum maturity score 4/5"
    },
    "domain_uncertainty_high": {
      "score": 0.5,
      "evidence": "BA discovery notes Q1"
    }
  },
  "recommendation": "hybrid",
  "named_hybrid_tilt": "predictive on regulatory milestones + audit gates; agile on UX + reporting layer",
  "reevaluation_triggers": [
    "velocity volatility > 30% over 3 sprints",
    "escalation rate > 1 per sprint for 2 sprints"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "programme": "x",
  "decision_date": "2026-05-22",
  "sponsor": "x"
}
]]></code>
    <note>dimensions/recommendation/named_hybrid_tilt/reevaluation_triggers missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="partial-score"><description>missing any of 6 dimensions</description><reason>Biases recommendation.</reason></forbidden-pattern>
    <forbidden-pattern id="no-evidence"><description>dimension score with empty evidence</description><reason>Drifts to comfort zone.</reason></forbidden-pattern>
    <forbidden-pattern id="unnamed-hybrid"><description>recommendation=hybrid with empty named_hybrid_tilt</description><reason>Best-of-both-worlds prose.</reason></forbidden-pattern>
    <forbidden-pattern id="few-triggers"><description>reevaluation_triggers length &lt; 2</description><reason>Mode drift not detected.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-agile-hybrid-approaches.py">Validator script</reference>
</text>
