<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Stakeholder Engagement Advanced Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns.</summary>

  <section title="Antipatterns">
    <antipattern id="theatre-indicators" severity="high">
      <symptom>Indicators are 'sentiment improves'; never measurable.</symptom>
      <root-cause source="OKR practice">Author avoided commitment to numbers.</root-cause>
      <fix>Force numeric or enum indicators with explicit baseline/target.</fix>
    </antipattern>
    <antipattern id="no-regression-escalation" severity="high">
      <symptom>Sponsor surprised by stakeholder veto at month 3.</symptom>
      <root-cause source="Internal — distressed-project case">Regression noticed but not escalated.</root-cause>
      <fix>Escalation on regress rule mandates sponsor notification in next status.</fix>
    </antipattern>
    <antipattern id="strategy-copy-paste" severity="medium">
      <symptom>Same strategy text across 5 stakeholders.</symptom>
      <root-cause source="Internal — register audit">Author copies first stakeholder's plan.</root-cause>
      <fix>Strategy must reference observable behaviour specific to the stakeholder.</fix>
    </antipattern>
    <antipattern id="no-diff-cycle" severity="medium">
      <symptom>Movement only reviewed at quarterly checkpoint.</symptom>
      <root-cause source="PMBoK 7">No weekly diff job.</root-cause>
      <fix>engagement_diff.py runs weekly; status blocked without diff output.</fix>
    </antipattern>
  </section>
</text>
