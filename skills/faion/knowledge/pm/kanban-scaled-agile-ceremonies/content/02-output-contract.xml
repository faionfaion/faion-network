<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Kanban and SAFe Ceremonies Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the Kanban and SAFe Ceremonies artefact. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <schema kind="json-schema">
      <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/kanban-scaled-agile-ceremonies.json",
  "type": "object",
  "required": [
    "program_id",
    "ceremony_set",
    "stages",
    "cadence",
    "flow_metrics"
  ],
  "properties": {
    "program_id": {
      "type": "string"
    },
    "ceremony_set": {
      "enum": [
        "kanban-lightweight",
        "kanban-cadenced",
        "safe-essential",
        "safe-full"
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "name",
          "wip_limit"
        ]
      }
    },
    "cadence": {
      "type": "object",
      "required": [
        "replenishment",
        "flow_review"
      ],
      "properties": {
        "replenishment": {
          "type": "string"
        },
        "flow_review": {
          "type": "string"
        },
        "pi_planning": {
          "type": "string"
        }
      }
    },
    "flow_metrics": {
      "type": "object",
      "required": [
        "lead_time_p50",
        "cycle_time_p50",
        "throughput",
        "wip"
      ]
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "program_id": "orion-platform",
  "ceremony_set": "safe-essential",
  "stages": [
    {
      "name": "Ready",
      "wip_limit": 20
    },
    {
      "name": "In Progress",
      "wip_limit": 8
    },
    {
      "name": "Review",
      "wip_limit": 4
    },
    {
      "name": "Done",
      "wip_limit": null
    }
  ],
  "cadence": {
    "replenishment": "weekly Mon 10:00",
    "flow_review": "biweekly Thu 14:00",
    "pi_planning": "every 10 weeks"
  },
  "flow_metrics": {
    "lead_time_p50": 6.5,
    "cycle_time_p50": 3.0,
    "throughput": 14,
    "wip": 7
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ceremony_set": "custom",
  "stages": [
    {
      "name": "Ready"
    }
  ],
  "cadence": {},
  "flow_metrics": {}
}
]]></code>
    <note>missing program_id; ceremony_set not in enum; stage missing wip_limit; cadence missing replenishment + flow_review; flow_metrics empty.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern id="f1"><description>Status set to an approved/sent state by the producing agent without a human reviewer entry.</description></antipattern>
    <antipattern id="f2"><description>Required field empty or replaced with a placeholder (n/a, unknown) without an anchored reason.</description></antipattern>
    <antipattern id="f3"><description>Prose paragraph stuffed into a field the schema declares as array or object.</description></antipattern>
  </section>

  <reference path="scripts/validate-kanban-scaled-agile-ceremonies.py">Validator script.</reference>
</text>
