<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitLab Issue Boards Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the GitLab Issue Boards artefact. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <schema kind="json-schema">
      <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/gitlab-boards.json",
  "type": "object",
  "required": [
    "project_id",
    "labels",
    "boards"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "required": [
        "workflow",
        "priority",
        "type"
      ],
      "properties": {
        "workflow": {
          "type": "array",
          "minItems": 3
        },
        "priority": {
          "type": "array",
          "minItems": 3
        },
        "type": {
          "type": "array",
          "minItems": 2
        }
      }
    },
    "boards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "columns"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "required": [
                "label",
                "wip_limit"
              ]
            }
          },
          "policy_url": {
            "type": "string"
          }
        }
      }
    },
    "issue_templates": {
      "type": "array",
      "minItems": 2
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "acme/platform",
  "labels": {
    "workflow": [
      "workflow::backlog",
      "workflow::ready",
      "workflow::in-progress",
      "workflow::review",
      "workflow::done"
    ],
    "priority": [
      "priority::critical",
      "priority::high",
      "priority::medium",
      "priority::low"
    ],
    "type": [
      "type::feature",
      "type::bug",
      "type::tech-debt",
      "type::docs"
    ]
  },
  "boards": [
    {
      "name": "Engineering Flow",
      "columns": [
        {
          "label": "workflow::ready",
          "wip_limit": null
        },
        {
          "label": "workflow::in-progress",
          "wip_limit": 5
        },
        {
          "label": "workflow::review",
          "wip_limit": 3
        },
        {
          "label": "workflow::done",
          "wip_limit": null
        }
      ],
      "policy_url": "docs/board-policy.md"
    }
  ],
  "issue_templates": [
    ".gitlab/issue_templates/Bug.md",
    ".gitlab/issue_templates/Feature.md"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "labels": {
    "workflow": [
      "todo",
      "doing"
    ],
    "priority": [],
    "type": []
  },
  "boards": [
    {
      "name": "main",
      "columns": [
        {
          "label": "doing"
        }
      ]
    }
  ]
}
]]></code>
    <note>missing project_id; workflow labels not scoped (no 'workflow::' prefix); priority + type empty; column missing wip_limit; no issue_templates.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern id="f1"><description>Status set to an approved/sent state by the producing agent without a human reviewer entry.</description></antipattern>
    <antipattern id="f2"><description>Required field empty or replaced with a placeholder (n/a, unknown) without an anchored reason.</description></antipattern>
    <antipattern id="f3"><description>Prose paragraph stuffed into a field the schema declares as array or object.</description></antipattern>
  </section>

  <reference path="scripts/validate-gitlab-boards.py">Validator script.</reference>
</text>
