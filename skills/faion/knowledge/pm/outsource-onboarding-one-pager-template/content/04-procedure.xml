<text id="04-procedure" title="Outsource Onboarding One-Pager Template Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Outsource Onboarding One-Pager Template end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="draft-scope">
      <input>Problem brief + success criteria</input>
      <action>Write ≤50-word scope; name success criteria.</action>
      <output>scope string.</output>
    </step>

    <step n="2" name="name-deliverables">
      <input>Scope</input>
      <action>Pick 1-3 deliverables; first one due ≤24 hrs.</action>
      <output>deliverables array.</output>
      <decision-gate>Reject if first due_in_hours &gt;48.</decision-gate>
    </step>

    <step n="3" name="set-cadence">
      <input>Engagement length + team comms style</input>
      <action>Pin daily-standup channel + weekly call slot.</action>
      <output>comms_cadence object.</output>
    </step>

    <step n="4" name="provision-access">
      <input>Tool stack</input>
      <action>List + provision access on day 0.</action>
      <output>access_list array.</output>
    </step>

    <step n="5" name="set-payment">
      <input>Rate + cycle</input>
      <action>Specify rate / currency / cycle / payment method.</action>
      <output>payment_terms object.</output>
    </step>

    <step n="6" name="name-kill-switch">
      <input>Trial criteria</input>
      <action>Pin trial_period_weeks + criterion + exit_pay_days.</action>
      <output>kill_switch object.</output>
    </step>

  </section>
</text>
