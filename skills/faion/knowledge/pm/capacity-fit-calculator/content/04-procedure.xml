<text id="04-procedure" title="Capacity Fit Calculator Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Capacity Fit Calculator end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="pull-baseline">
      <input>Last 4 sprints</input>
      <action>Compute median of last 4 sprints&apos; completed velocity.</action>
      <output>baseline_velocity number.</output>
    </step>

    <step n="2" name="set-focus-factor">
      <input>Team size + interruption profile</input>
      <action>Pick focus_factor in 0.60-0.80; default 0.75.</action>
      <output>focus_factor number.</output>
      <decision-gate>Reject &gt;0.85.</decision-gate>
    </step>

    <step n="3" name="list-reductions">
      <input>Team calendar</input>
      <action>Itemise PTO + holidays + ops days; convert to points.</action>
      <output>reductions array.</output>
    </step>

    <step n="4" name="compute-available">
      <input>baseline × focus × (1 - reductions)</input>
      <action>available_capacity = baseline_velocity × focus_factor − sum(reductions).</action>
      <output>available_capacity number.</output>
    </step>

    <step n="5" name="compare-scope">
      <input>proposed_scope + available_capacity</input>
      <action>Decide: fits / cut-required / expand-allowed.</action>
      <output>fit_decision string.</output>
      <decision-gate>Refuse &apos;fits&apos; if proposed &gt; available.</decision-gate>
    </step>

    <step n="6" name="commit">
      <input>fit_decision</input>
      <action>Cut or expand scope; archive spec; recompute next sprint.</action>
      <output>Final scope committed.</output>
    </step>

  </section>
</text>
