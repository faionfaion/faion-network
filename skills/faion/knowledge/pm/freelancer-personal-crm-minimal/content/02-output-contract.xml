<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Freelancer Personal CRM (Minimal) Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/freelancer-personal-crm-minimal.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "table_url",
    "field_count",
    "stages",
    "review_day",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "table_url": {
      "type": "string"
    },
    "field_count": {
      "type": "integer",
      "maximum": 12
    },
    "stages": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6
    },
    "review_day": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">stages.length != 6 — violates r1</pattern>
      <pattern id="f2">field_count &gt; 12 — violates r2</pattern>
      <pattern id="f3">review_day missing — violates r3</pattern>
      <pattern id="f4">table_url empty — violates r1</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "crm-minimal-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "table_url": "notion://workspace/crm",
  "field_count": 11,
  "stages": [
    "lead",
    "qualified",
    "proposal",
    "signed",
    "active",
    "churned"
  ],
  "review_day": "Friday",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "table_url": "",
  "field_count": 22,
  "stages": [
    "lead",
    "qualified",
    "proposal",
    "signed",
    "active"
  ],
  "review_day": "",
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-freelancer-personal-crm-minimal.py">Schema validator (stdlib only).</reference>
</text>
