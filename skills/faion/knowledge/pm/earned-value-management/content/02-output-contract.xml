<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Earned Value Management Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>JSON Schema draft-07 for the report artefact this methodology produces. Validator rejects artefacts that violate the schema or any forbidden pattern.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/earned-value-management.json",
  "type": "object",
  "required": [
    "project_id",
    "period",
    "pv",
    "ev",
    "ac",
    "cpi",
    "spi",
    "eac",
    "eac_method",
    "status_color"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}$"
    },
    "pv": {
      "type": "number",
      "minimum": 0
    },
    "ev": {
      "type": "number",
      "minimum": 0
    },
    "ac": {
      "type": "number",
      "minimum": 0
    },
    "cpi": {
      "type": "number"
    },
    "spi": {
      "type": "number"
    },
    "eac": {
      "type": "number"
    },
    "eac_method": {
      "enum": [
        "BAC_over_CPI",
        "AC_plus_ETC",
        "optimistic",
        "regression"
      ]
    },
    "status_color": {
      "enum": [
        "green",
        "amber",
        "red"
      ]
    },
    "corrective_action_plan": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "acme",
  "period": "2026-05",
  "pv": 100000,
  "ev": 95000,
  "ac": 105000,
  "cpi": 0.905,
  "spi": 0.95,
  "eac": 220000,
  "eac_method": "BAC_over_CPI",
  "status_color": "amber",
  "corrective_action_plan": {
    "actions": [
      "scope freeze",
      "vendor renegotiation"
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "x",
  "period": "May 2026",
  "pv": 100,
  "ev": 90,
  "ac": 110,
  "cpi": 0.82,
  "spi": 0.9,
  "eac": 250,
  "eac_method": "guess",
  "status_color": "yellow"
}
]]></code>
    <note>period pattern invalid; eac_method not in enum; status_color not in enum; cpi=0.82 should be 'red' not anything else.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>cpi or spi reported without status_color.</item>
      <item>status_color='green' when cpi &lt; 0.95 or spi &lt; 0.95.</item>
      <item>status_color='red' without corrective_action_plan.</item>
      <item>eac without eac_method.</item>
      <item>two periods with different baselines but no change-control reference.</item>
    </list>
  </section>

  <reference path="scripts/validate-earned-value-management.py">Validator script enforcing this schema</reference>
</text>
