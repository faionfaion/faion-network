<text id="02-output-contract" title="Linear Issue Tracking (PM Agile) Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/linear-issue-tracking.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "workspace_url",
    "cycle_length_days",
    "states",
    "labels",
    "integrations",
    "estimation_method",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "workspace_url": {
      "type": "string"
    },
    "cycle_length_days": {
      "type": "integer",
      "enum": [
        7,
        14
      ]
    },
    "states": {
      "type": "array",
      "minItems": 5,
      "maxItems": 7
    },
    "labels": {
      "type": "array",
      "maxItems": 15
    },
    "integrations": {
      "type": "object"
    },
    "estimation_method": {
      "type": "string",
      "enum": [
        "points",
        "tshirt",
        "hours"
      ]
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">cycle_length_days not in [7, 14] — violates r2</pattern>
      <pattern id="f2">states.length &gt; 7 — violates r3</pattern>
      <pattern id="f3">labels.length &gt; 15 — violates r4</pattern>
      <pattern id="f4">integrations missing &apos;github&apos; AND &apos;slack&apos; both — violates r5</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "linear-setup-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "workspace_url": "https://linear.app/faion",
  "cycle_length_days": 14,
  "states": [
    "Backlog",
    "Todo",
    "In Progress",
    "In Review",
    "Done",
    "Cancelled"
  ],
  "labels": [
    "bug",
    "feat",
    "chore",
    "spike",
    "docs",
    "infra"
  ],
  "integrations": {
    "github": true,
    "slack": true,
    "calendar": true
  },
  "estimation_method": "points",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

