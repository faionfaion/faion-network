<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Explainability Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/product-kb-config.json",
  "type": "object",
  "required": [
    "page",
    "schema_markup",
    "boundary_section",
    "owner",
    "review_cadence"
  ],
  "properties": {
    "page": {
      "type": "string"
    },
    "schema_markup": {
      "type": "object",
      "required": [
        "@type",
        "name",
        "description"
      ],
      "properties": {
        "@type": {
          "enum": [
            "Product",
            "SoftwareApplication"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "applicationCategory": {
          "type": "string"
        },
        "featureList": {
          "type": "array"
        }
      }
    },
    "boundary_section": {
      "type": "string",
      "minLength": 30
    },
    "owner": {
      "type": "string"
    },
    "review_cadence": {
      "enum": [
        "weekly",
        "monthly",
        "quarterly"
      ]
    },
    "flesch_kincaid_grade": {
      "type": "number",
      "maximum": 11
    },
    "machine_readable_changelog": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "page": "/product/faion",
  "schema_markup": {
    "@type": "SoftwareApplication",
    "name": "Faion",
    "description": "CLI methodology base for solopreneur developers.",
    "applicationCategory": "DeveloperTools",
    "featureList": [
      "search",
      "get-content"
    ]
  },
  "boundary_section": "Faion does NOT execute code or call paid LLMs on customer behalf.",
  "owner": "ruslan",
  "review_cadence": "quarterly",
  "flesch_kincaid_grade": 9.8,
  "machine_readable_changelog": "/changelog.json"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "page": "/x",
  "schema_markup": {
    "@type": "Thing",
    "name": "x"
  },
  "owner": "ruslan"
}
]]></code>
    <note>schema_markup @type must be Product or SoftwareApplication; boundary_section missing; review_cadence missing.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">capability-only page (no boundary)</pattern>
    <pattern id="f2">schema_markup @type not Product/SoftwareApplication</pattern>
    <pattern id="f3">review_cadence absent</pattern>
    <pattern id="f4">Flesch-Kincaid grade &gt; 11 on public page</pattern>
  </section>

  <reference path="scripts/validate-product-explainability.py">Validator script (stdlib-only).</reference>
</text>
