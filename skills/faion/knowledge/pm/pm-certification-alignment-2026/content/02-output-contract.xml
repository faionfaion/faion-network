<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="PM Certification Alignment 2026 Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>JSON Schema draft-07 for the rubric artefact this methodology produces. Validator rejects artefacts that violate the schema or any forbidden pattern.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pm-certification-alignment-2026.json",
  "type": "object",
  "required": [
    "analysis_date",
    "methodology_count",
    "coverage_by_domain",
    "coverage_gaps",
    "themes_covered"
  ],
  "properties": {
    "analysis_date": {
      "type": "string",
      "format": "date"
    },
    "methodology_count": {
      "type": "integer",
      "minimum": 1
    },
    "coverage_by_domain": {
      "type": "object",
      "required": [
        "People",
        "Process",
        "Business Environment"
      ],
      "properties": {
        "People": {
          "type": "object",
          "required": [
            "count",
            "weight_pct"
          ]
        },
        "Process": {
          "type": "object",
          "required": [
            "count",
            "weight_pct"
          ]
        },
        "Business Environment": {
          "type": "object",
          "required": [
            "count",
            "weight_pct"
          ]
        }
      }
    },
    "coverage_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "gap",
          "owner",
          "due_date"
        ]
      }
    },
    "themes_covered": {
      "type": "array",
      "items": {
        "enum": [
          "business-acumen",
          "data-driven",
          "strategic-alignment",
          "agile-hybrid",
          "leadership-skills"
        ]
      },
      "minItems": 1,
      "maxItems": 5
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "analysis_date": "2026-05-22",
  "methodology_count": 130,
  "coverage_by_domain": {
    "People": {
      "count": 35,
      "weight_pct": 33
    },
    "Process": {
      "count": 60,
      "weight_pct": 41
    },
    "Business Environment": {
      "count": 35,
      "weight_pct": 26
    }
  },
  "coverage_gaps": [
    {
      "gap": "stakeholder negotiation methodology missing",
      "owner": "U_CONTENT_LEAD",
      "due_date": "2026-09-30"
    }
  ],
  "themes_covered": [
    "business-acumen",
    "data-driven",
    "strategic-alignment",
    "agile-hybrid",
    "leadership-skills"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "analysis_date": "yesterday",
  "methodology_count": 0,
  "coverage_by_domain": {
    "People": {}
  },
  "coverage_gaps": [
    {
      "gap": "x"
    }
  ],
  "themes_covered": [
    "random"
  ]
}
]]></code>
    <note>analysis_date not ISO; methodology_count 0; coverage_by_domain incomplete; gap missing owner/due; theme not canonical.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>coverage_by_domain missing People / Process / Business Environment.</item>
      <item>coverage_gap without owner or due_date.</item>
      <item>theme not in {business-acumen, data-driven, strategic-alignment, agile-hybrid, leadership-skills}.</item>
      <item>weight_pct sum across domains != 100.</item>
      <item>methodology_count == 0 (cannot align an empty library).</item>
    </list>
  </section>

  <reference path="scripts/validate-pm-certification-alignment-2026.py">Validator script enforcing this schema</reference>
</text>
