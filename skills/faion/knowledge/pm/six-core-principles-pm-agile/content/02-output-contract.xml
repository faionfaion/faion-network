<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Six Core Principles (PMBOK 7) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the `rubric` artefact this methodology produces, plus one valid and one invalid example, and a forbidden-pattern list. Validator at `scripts/validate-six-core-principles.py` enforces required keys.</summary>

  <section title="Schema">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/six-core-principles.json",
  "title": "Six Core Principles (PMBOK 7)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "criteria",
    "overall"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "const": "six-core-principles"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "score",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "overall": {
      "enum": [
        "GREEN",
        "YELLOW",
        "RED"
      ]
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "six-core-principles",
  "criteria": [
    {
      "id": "principle-observable-required",
      "score": 3,
      "evidence": "decision log entry #142"
    }
  ],
  "overall": "GREEN"
}
]]></code>
    <note>Minimal example that passes the validator.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "six-core-principles",
  "criteria": [
    {
      "id": "x",
      "score": 9,
      "evidence": ""
    }
  ],
  "overall": "BLUE"
}
]]></code>
    <note>Fails: required fields missing or values outside their allowed range.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">TBD, TODO, FIXME, or placeholder text anywhere in the artefact body — strings are rejected by the validator.</pattern>
      <pattern id="f2">Slug mismatch — `slug` field does not equal the directory slug.</pattern>
      <pattern id="f3">Missing required field per schema — validator returns exit code 1 with the violating path.</pattern>
      <pattern id="f4">Non-deterministic timestamps in `approved_at` or equivalent fields — must be ISO-8601 UTC.</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-six-core-principles.py">Validator script (stdlib only; --help + --self-test).</reference>
</text>
