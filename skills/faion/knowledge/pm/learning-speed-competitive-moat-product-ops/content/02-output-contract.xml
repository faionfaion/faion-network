<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Learning Speed as Competitive Moat Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/learning-speed-report.json",
  "type": "object",
  "required": [
    "week",
    "beliefs",
    "decisions_logged",
    "outside_view_inputs"
  ],
  "properties": {
    "week": {
      "type": "string"
    },
    "beliefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "assumption",
          "confidence",
          "source",
          "last_updated"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "assumption": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source": {
            "type": "string"
          },
          "last_updated": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "decisions_logged": {
      "type": "integer",
      "minimum": 0
    },
    "outside_view_inputs": {
      "type": "integer",
      "minimum": 0
    },
    "kill_criteria_present": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "week": "2026-W21",
  "beliefs": [
    {
      "id": "b1",
      "assumption": "Mid-market buys plg if seat <$30",
      "confidence": 0.6,
      "source": "OpenView 2024",
      "last_updated": "2026-05-19"
    }
  ],
  "decisions_logged": 4,
  "outside_view_inputs": 3,
  "kill_criteria_present": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "week": "May",
  "beliefs": []
}
]]></code>
    <note>Empty beliefs + missing outside_view_inputs.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">belief older than 90d without update</pattern>
    <pattern id="f2">decision without outside-view input</pattern>
    <pattern id="f3">bet without kill criteria</pattern>
  </section>

  <reference path="scripts/validate-learning-speed-competitive-moat.py">Validator script (stdlib-only).</reference>
</text>
