<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Verbatim To Backlog Pattern Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/verbatim-to-backlog-pattern.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "card_id",
    "job_story",
    "verbatim_quotes",
    "rice_score",
    "source_cluster_id",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "card_id": {
      "type": "string"
    },
    "job_story": {
      "type": "string"
    },
    "verbatim_quotes": {
      "type": "array"
    },
    "rice_score": {
      "type": "number"
    },
    "source_cluster_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "verbatim-to-backlog-pattern-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "card_id": "card_id value",
  "job_story": "job_story value",
  "verbatim_quotes": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "rice_score": 1.0,
  "source_cluster_id": "source_cluster_id value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-verbatim-to-backlog-pattern.py">Schema validator (stdlib only).</reference>
</text>
