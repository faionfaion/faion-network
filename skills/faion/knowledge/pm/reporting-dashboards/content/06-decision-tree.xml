<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Reporting Dashboards Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for reporting-dashboards.</summary>

  <decision-tree>
    <root-question id="q-root">Is the team large enough to benefit from automation AND does the validation gate hold?</root-question>

    <branch when="team_size &lt; 4 AND manual_update_faster == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — manual update wins under N=3"/>
    </branch>
    <branch when="token_scope == write">
      <conclusion ref="r1-read-only-token" verdict="BLOCK — provision read-only token"/>
    </branch>
    <branch when="schema_in_repo == false">
      <conclusion ref="r2-schema-first" verdict="BLOCK — commit schema before running"/>
    </branch>
    <branch when="committed == 0 OR fetch_errors &gt; 0">
      <conclusion ref="r4-validate-before-send" verdict="BLOCK — emit error alert, do not deliver"/>
    </branch>
    <branch when="health_metric_count &lt; 3">
      <conclusion ref="r3-multi-metric-health" verdict="BLOCK — add scope_creep + blocked_count"/>
    </branch>
    <branch when="archive_url == empty">
      <conclusion ref="r5-archive-before-deliver" verdict="BLOCK — write archive before delivery"/>
    </branch>
    <branch when="generate_deliver_coupled == true">
      <conclusion ref="r6-separate-generate-deliver" verdict="BLOCK — split scripts"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — deliver"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="reporting-dashboards-happy-path">
    Team size 8 + read-only token + schema locked + fetch returns 24 issues + 3 metrics computed + archived to S3 + scripts separate → APPROVE → Slack post.
  </example>
</text>
