<text id="02-output-contract" title="Risk Management Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. The validator script enforces the schema.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/risk-management.json",
  "title": "Risk Management",
  "type": "object",
  "required": [
    "__faion_header__",
    "report_id",
    "data"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces",
        "rules_satisfied"
      ],
      "properties": {
        "methodology": {
          "const": "risk-management"
        },
        "version": {
          "const": "1.1.0"
        },
        "produces": {
          "const": "report"
        },
        "rules_satisfied": {
          "type": "array",
          "items": {
            "enum": [
              "track-opportunities-too",
              "named-owner-with-trigger",
              "contingency-for-accept",
              "source-quote-required",
              "weekly-15min-review",
              "convert-materialised-to-issue"
            ]
          },
          "minItems": 1
        }
      }
    },
    "report_id": {
      "type": "string"
    },
    "data": {
      "type": "object"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item>Missing __faion_header__ block — every artefact MUST carry methodology, version, produces, rules_satisfied.</item>
      <item>rules_satisfied containing IDs outside the risk-management rule set.</item>
      <item>Empty top-level body (no sections / data / entries / items / criteria) — the artefact must carry payload, not metadata only.</item>
      <item>Free-form prose substituted for the typed sub-fields the schema requires.</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "risk-management",
    "version": "1.1.0",
    "produces": "report",
    "rules_satisfied": [
      "track-opportunities-too",
      "named-owner-with-trigger",
      "contingency-for-accept"
    ]
  },
  "report_id": "risk-management-2026-05-23",
  "data": {
    "summary": "ok"
  }
}
]]></code>
    <note>Header carries methodology + version + produces + rules_satisfied; body matches the per-produces shape.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_path": "docs/risk-management.md"
}
]]></code>
    <note>Header missing → validator rejects; rules_satisfied not declared → no audit trail.</note>
  </example>

  <reference path="scripts/validate-risk-management.py">Validator script</reference>
</text>
