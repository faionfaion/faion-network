<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="PMBoK 8 Focus Areas Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>JSON Schema draft-07 for the rubric artefact this methodology produces. Validator rejects artefacts that violate the schema or any forbidden pattern.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pm-framework-focus-areas.json",
  "type": "object",
  "required": [
    "pmbok_version",
    "refresh_date",
    "matrix"
  ],
  "properties": {
    "pmbok_version": {
      "type": "string",
      "pattern": "^8\\.[0-9]+$"
    },
    "refresh_date": {
      "type": "string",
      "format": "date"
    },
    "matrix": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "focus_area",
          "domains"
        ],
        "properties": {
          "focus_area": {
            "enum": [
              "Initiating",
              "Planning",
              "Executing",
              "Monitoring and Controlling",
              "Closing"
            ]
          },
          "domains": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": [
                "status",
                "artefacts"
              ],
              "properties": {
                "status": {
                  "enum": [
                    "covered",
                    "NA"
                  ]
                },
                "artefacts": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "na_justification": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pmbok_version": "8.0",
  "refresh_date": "2026-05-22",
  "matrix": [
    {
      "focus_area": "Initiating",
      "domains": {
        "Stakeholder": {
          "status": "covered",
          "artefacts": [
            "stakeholder-register-template"
          ]
        }
      }
    },
    {
      "focus_area": "Planning",
      "domains": {
        "Planning": {
          "status": "covered",
          "artefacts": [
            "wbs-template",
            "cost-baseline-template"
          ]
        }
      }
    },
    {
      "focus_area": "Executing",
      "domains": {
        "Team": {
          "status": "covered",
          "artefacts": [
            "team-charter"
          ]
        }
      }
    },
    {
      "focus_area": "Monitoring and Controlling",
      "domains": {
        "Measurement": {
          "status": "covered",
          "artefacts": [
            "evm-report-template"
          ]
        }
      }
    },
    {
      "focus_area": "Closing",
      "domains": {
        "Delivery": {
          "status": "covered",
          "artefacts": [
            "lessons-learned-template"
          ]
        }
      }
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pmbok_version": "7",
  "refresh_date": "y",
  "matrix": [
    {
      "focus_area": "Initiating",
      "domains": {}
    }
  ]
}
]]></code>
    <note>version pattern wrong; refresh_date not ISO; matrix has only 1 of 5 focus areas.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>matrix with fewer than 5 focus areas.</item>
      <item>focus_area outside the canonical 5.</item>
      <item>cell with status='NA' but no na_justification.</item>
      <item>cell with status='covered' but artefacts empty.</item>
      <item>pmbok_version not matching 8.x pattern.</item>
    </list>
  </section>

  <reference path="scripts/validate-pm-framework-focus-areas.py">Validator script enforcing this schema</reference>
</text>
