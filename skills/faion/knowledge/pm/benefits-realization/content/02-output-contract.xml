<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Benefits Realization Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>JSON Schema draft-07 for the spec artefact this methodology produces. Validator rejects artefacts that violate the schema or any forbidden pattern.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/benefits-realization.json",
  "type": "object",
  "required": [
    "project_id",
    "benefits",
    "owner_of_register"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_of_register": {
      "type": "string",
      "minLength": 1
    },
    "benefits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "metric",
          "baseline_value",
          "baseline_date",
          "target_value",
          "target_date",
          "owner",
          "attribution_plan"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "metric": {
            "type": "string"
          },
          "baseline_value": {
            "type": "number"
          },
          "baseline_date": {
            "type": "string",
            "format": "date"
          },
          "target_value": {
            "type": "number"
          },
          "target_date": {
            "type": "string",
            "format": "date"
          },
          "owner": {
            "type": "string"
          },
          "attribution_plan": {
            "enum": [
              "control-cohort",
              "diff-in-diff",
              "synthetic-control",
              "uncontested"
            ]
          },
          "category": {
            "enum": [
              "revenue",
              "cost-reduction",
              "risk-reduction",
              "compliance",
              "engagement"
            ]
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "acme-crm-2026",
  "owner_of_register": "U_VP_SALES",
  "benefits": [
    {
      "id": "b1",
      "metric": "deals_closed_per_q",
      "baseline_value": 120,
      "baseline_date": "2026-01-01",
      "target_value": 144,
      "target_date": "2026-12-31",
      "owner": "U_VP_SALES",
      "attribution_plan": "diff-in-diff",
      "category": "revenue"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "x",
  "owner_of_register": "",
  "benefits": [
    {
      "id": "b1",
      "metric": "growth"
    }
  ]
}
]]></code>
    <note>owner_of_register empty; benefit missing baseline_value, baseline_date, target_*, owner, attribution_plan; metric vague.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>benefit without quantified baseline_value AND target_value.</item>
      <item>owner == project_manager (must be business stakeholder).</item>
      <item>attribution_plan absent AND category in {revenue, cost-reduction}.</item>
      <item>baseline_date later than project kick-off — baseline must be pre-launch.</item>
      <item>two concurrent benefits in the portfolio claiming the same metric without sign-off.</item>
    </list>
  </section>

  <reference path="scripts/validate-benefits-realization.py">Validator script enforcing this schema</reference>
</text>
