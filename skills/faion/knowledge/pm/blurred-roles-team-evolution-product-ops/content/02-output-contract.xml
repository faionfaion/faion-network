<text id="02-output-contract" title="Blurred Roles and Team Evolution Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/blurred-roles-report.json",
  "type": "object",
  "required": [
    "quarter",
    "overlap_zones",
    "specialists",
    "audit_source"
  ],
  "properties": {
    "quarter": {
      "type": "string",
      "pattern": "^\\d{4}-Q[1-4]$"
    },
    "overlap_zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "zone",
          "dri"
        ],
        "properties": {
          "zone": {
            "enum": [
              "PM\u2229Design",
              "Design\u2229Eng",
              "PM\u2229Eng",
              "PM\u2229Data"
            ]
          },
          "dri": {
            "type": "string"
          },
          "asymmetry_flag": {
            "type": "boolean"
          }
        }
      },
      "minItems": 1
    },
    "specialists": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "domain",
          "person"
        ],
        "properties": {
          "domain": {
            "type": "string"
          },
          "person": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "audit_source": {
      "enum": [
        "git-shortlog",
        "self-report+git-shortlog"
      ]
    },
    "pm_eng_ratio": {
      "type": "number",
      "minimum": 0
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "quarter": "2026-Q2",
  "overlap_zones": [
    {
      "zone": "PM\u2229Design",
      "dri": "lara"
    },
    {
      "zone": "Design\u2229Eng",
      "dri": "kostya"
    }
  ],
  "specialists": [
    {
      "domain": "security",
      "person": "olena"
    },
    {
      "domain": "ml-eval",
      "person": "vlad"
    }
  ],
  "audit_source": "git-shortlog",
  "pm_eng_ratio": 0.5
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "quarter": "Q2",
  "overlap_zones": [
    {
      "zone": "PM\u2229Design"
    }
  ],
  "audit_source": "self-report"
}
]]></code>
    <note>Quarter must be ISO; every zone needs DRI; self-report-only audit is forbidden.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">overlap zone without DRI</pattern>
    <pattern id="f2">specialists list empty in deep domains</pattern>
    <pattern id="f3">self-report-only audit</pattern>
    <pattern id="f4">asymmetric blur (PM→Design without Design→Metrics)</pattern>
  </section>

  <reference path="scripts/validate-blurred-roles-team-evolution.py">Validator script (stdlib-only).</reference>
</text>
