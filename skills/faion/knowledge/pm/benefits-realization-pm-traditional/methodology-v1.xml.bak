<methodology slug="benefits-realization">
  <metadata>
    <tier>pro</tier>
    <group>pm</group>
    <domain>pm-traditional</domain>
    <summary>Track business outcome realization post-delivery. Each benefit needs a named owner, pre-launch baseline, quantified target, metric source, and multi-period measurement curve to detect decay.</summary>
    <category>benefits</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-28</created>
    <tags>
      <tag>benefits</tag>
      <tag>outcomes</tag>
      <tag>measurement</tag>
      <tag>roi</tag>
      <tag>post-launch</tag>
    </tags>
