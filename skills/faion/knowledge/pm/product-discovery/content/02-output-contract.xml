<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Discovery Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/product-discovery.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "idea_brief",
    "risk_value",
    "risk_usability",
    "risk_feasibility",
    "risk_viability",
    "verdict",
    "evidence",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "idea_brief": {
      "type": "string"
    },
    "risk_value": {
      "type": "string"
    },
    "risk_usability": {
      "type": "string"
    },
    "risk_feasibility": {
      "type": "string"
    },
    "risk_viability": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "go",
        "hold",
        "no-op"
      ]
    },
    "evidence": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "product-discovery-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "idea_brief": "idea_brief value",
  "risk_value": "risk_value value",
  "risk_usability": "risk_usability value",
  "risk_feasibility": "risk_feasibility value",
  "risk_viability": "risk_viability value",
  "verdict": "go",
  "evidence": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-product-discovery.py">Schema validator (stdlib only).</reference>
</text>
