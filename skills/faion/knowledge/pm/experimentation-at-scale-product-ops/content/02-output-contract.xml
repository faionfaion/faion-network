<text id="02-output-contract" title="Experimentation at Scale Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/experiment-spec.json",
  "type": "object",
  "required": [
    "experiment_id",
    "hypothesis",
    "primary_metric",
    "mde",
    "sample_size",
    "guardrails",
    "pre_registered_at"
  ],
  "properties": {
    "experiment_id": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string",
      "minLength": 30
    },
    "primary_metric": {
      "type": "string"
    },
    "mde": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "sample_size": {
      "type": "integer",
      "minimum": 1
    },
    "guardrails": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "metric",
          "threshold"
        ]
      },
      "minItems": 1
    },
    "pre_registered_at": {
      "type": "string",
      "format": "date-time"
    },
    "srm_passed": {
      "type": "boolean"
    },
    "sequential_design": {
      "enum": [
        "none",
        "mSPRT",
        "group-sequential"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "experiment_id": "exp-2026-042",
  "hypothesis": "New onboarding cuts time-to-aha by 30%; this lifts day-1 activation.",
  "primary_metric": "day1_activation",
  "mde": 0.02,
  "sample_size": 12500,
  "guardrails": [
    {
      "metric": "p95_latency_ms",
      "threshold": 350
    },
    {
      "metric": "error_rate",
      "threshold": 0.01
    }
  ],
  "pre_registered_at": "2026-05-20T09:00:00Z",
  "srm_passed": true,
  "sequential_design": "none"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "experiment_id": "exp-x",
  "hypothesis": "lift",
  "primary_metric": "conversion"
}
]]></code>
    <note>Missing mde, sample_size, guardrails, pre_registered_at; hypothesis too short.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">post-hoc metric pick</pattern>
    <pattern id="f2">no SRM check</pattern>
    <pattern id="f3">no guardrails</pattern>
    <pattern id="f4">early-stop without sequential design</pattern>
  </section>

  <reference path="scripts/validate-experimentation-at-scale.py">Validator script (stdlib-only).</reference>
</text>
