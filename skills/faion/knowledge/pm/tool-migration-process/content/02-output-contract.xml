<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cross-Tool PM Migration — Process Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the `playbook-step` artefact this methodology produces, plus one valid and one invalid example, and a forbidden-pattern list. Validator at `scripts/validate-tool-migration-process.py` enforces required keys.</summary>

  <section title="Schema">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/tool-migration-process.json",
  "title": "Cross-Tool PM Migration \u2014 Process",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "steps"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "const": "tool-migration-process"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "n",
          "name",
          "action"
        ],
        "properties": {
          "n": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "decision_gate": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "tool-migration-process",
  "steps": [
    {
      "n": 1,
      "name": "prepare",
      "action": "Collect inputs",
      "decision_gate": "All inputs present"
    }
  ]
}
]]></code>
    <note>Minimal example that passes the validator.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "tool-migration-process",
  "steps": []
}
]]></code>
    <note>Fails: required fields missing or values outside their allowed range.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">TBD, TODO, FIXME, or placeholder text anywhere in the artefact body — strings are rejected by the validator.</pattern>
      <pattern id="f2">Slug mismatch — `slug` field does not equal the directory slug.</pattern>
      <pattern id="f3">Missing required field per schema — validator returns exit code 1 with the violating path.</pattern>
      <pattern id="f4">Non-deterministic timestamps in `approved_at` or equivalent fields — must be ISO-8601 UTC.</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-tool-migration-process.py">Validator script (stdlib only; --help + --self-test).</reference>
</text>
