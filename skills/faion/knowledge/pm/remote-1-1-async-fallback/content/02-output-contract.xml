<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Remote 1:1 Async Fallback Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for `Async11Note` — 3 named prompts + response window + escalation + named owner + evidence anchor.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/async-11-note.json",
  "type": "object",
  "required": ["pair_id", "cycle_iso", "header", "prompts", "ic_response", "pm_ack", "escalation"],
  "properties": {
    "pair_id": {"type": "string"},
    "cycle_iso": {"type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$"},
    "header": {
      "type": "object",
      "required": ["owner", "last_reviewed", "version", "response_window_business_hours"],
      "properties": {
        "owner": {"type": "object", "required": ["role", "person"], "properties": {"role": {"type": "string"}, "person": {"type": "string", "minLength": 2}}},
        "last_reviewed": {"type": "string", "format": "date"},
        "version": {"type": "string"},
        "response_window_business_hours": {"type": "integer", "minimum": 24, "maximum": 168}
      }
    },
    "prompts": {
      "type": "object",
      "required": ["blockers", "decisions_needed", "morale"],
      "properties": {
        "blockers": {"type": "string", "minLength": 10},
        "decisions_needed": {"type": "string", "minLength": 10},
        "morale": {"type": "string", "minLength": 10}
      }
    },
    "ic_response": {
      "type": "object",
      "required": ["received_at", "blockers", "decisions_needed", "morale"],
      "properties": {
        "received_at": {"type": ["string", "null"]},
        "blockers": {"type": "string"},
        "decisions_needed": {"type": "string"},
        "morale": {"type": "string"}
      }
    },
    "pm_ack": {
      "type": "object",
      "required": ["acked_at", "next_actions"],
      "properties": {
        "acked_at": {"type": ["string", "null"]},
        "next_actions": {"type": "array", "items": {"type": "object", "required": ["action", "owner_role", "deadline_sprint"]}}
      }
    },
    "escalation": {
      "type": "object",
      "required": ["unresponsive_count", "action"],
      "properties": {
        "unresponsive_count": {"type": "integer", "minimum": 0},
        "action": {"enum": ["none", "synchronous_reschedule", "escalate_to_manager"]}
      }
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item>Any `prompts.*` shorter than 10 chars or generic ("anything?") — violates `r2-bounded-output`.</item>
      <item>`ic_response.received_at` past response window AND `escalation.action == "none"` — violates `r1-explicit-trigger`.</item>
      <item>`pm_ack.next_actions` items missing `deadline_sprint` — violates `r4-named-owner`.</item>
      <item>`header.last_reviewed` &gt; 90 days — violates `r5-iteration-loop`.</item>
      <item>`unresponsive_count` &gt;= 2 with `action == "none"` — violates escalation policy.</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pair_id": "pm-handle--ic-handle",
  "cycle_iso": "2026-W21",
  "header": {"owner": {"role": "PM", "person": "pm-handle"}, "last_reviewed": "2026-05-10", "version": "1.4", "response_window_business_hours": 48},
  "prompts": {
    "blockers": "What is blocking your current sprint goals? Cite the WBS id and what is upstream.",
    "decisions_needed": "What decision are you waiting on, from whom, and by when?",
    "morale": "Workload 1-10, autonomy 1-10, clarity 1-10 — and anything else you want me to know."
  },
  "ic_response": {
    "received_at": "2026-05-22T09:30:00Z",
    "blockers": "PR review on 4.2 stalled 3 days",
    "decisions_needed": "Need security-lead sign-off on token TTL",
    "morale": "workload 7 autonomy 8 clarity 6"
  },
  "pm_ack": {
    "acked_at": "2026-05-22T17:00:00Z",
    "next_actions": [
      {"action": "Ping security-lead for token TTL decision", "owner_role": "PM", "deadline_sprint": "S14"}
    ]
  },
  "escalation": {"unresponsive_count": 0, "action": "none"}
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pair_id": "x", "cycle_iso": "2026-W21",
  "header": {"owner": {"role": "team", "person": ""}, "last_reviewed": "2024-01-01", "version": "0", "response_window_business_hours": 12},
  "prompts": {"blockers": "?", "decisions_needed": "?", "morale": "?"},
  "ic_response": {"received_at": null, "blockers": "", "decisions_needed": "", "morale": ""},
  "pm_ack": {"acked_at": null, "next_actions": []},
  "escalation": {"unresponsive_count": 3, "action": "none"}
}
]]></code>
    <note>Prompts too short; owner empty; response_window below minimum; 3 unresponsive cycles with action=none.</note>
  </example>

  <reference path="scripts/validate-remote-1-1-async-fallback.py">Validator script</reference>
</text>
