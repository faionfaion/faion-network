<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agency P&amp;L Tracker Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the agency-pnl-tracker-template artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agency-pnl.json",
  "type": "object",
  "required": [
    "agency",
    "month",
    "revenue",
    "cogs",
    "opex",
    "utilisation",
    "variance_vs_plan"
  ],
  "properties": {
    "agency": {
      "type": "string"
    },
    "month": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}$"
    },
    "revenue": {
      "type": "object",
      "required": [
        "project",
        "retainer",
        "productised"
      ],
      "properties": {
        "project": {
          "type": "number"
        },
        "retainer": {
          "type": "number"
        },
        "productised": {
          "type": "number"
        }
      }
    },
    "cogs": {
      "type": "object",
      "required": [
        "contractor_fees",
        "tooling_per_seat"
      ],
      "properties": {
        "contractor_fees": {
          "type": "number"
        },
        "tooling_per_seat": {
          "type": "number"
        }
      }
    },
    "opex": {
      "type": "object",
      "required": [
        "payroll",
        "fixed_costs",
        "marketing"
      ],
      "properties": {
        "payroll": {
          "type": "number"
        },
        "fixed_costs": {
          "type": "number"
        },
        "marketing": {
          "type": "number"
        }
      }
    },
    "utilisation": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "variance_vs_plan": {
      "type": "object",
      "required": [
        "revenue_variance",
        "reason"
      ],
      "properties": {
        "revenue_variance": {
          "type": "number"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "agency": "Acme Studio",
  "month": "2026-04",
  "revenue": {
    "project": 60000,
    "retainer": 30000,
    "productised": 5000
  },
  "cogs": {
    "contractor_fees": 18000,
    "tooling_per_seat": 1500
  },
  "opex": {
    "payroll": 35000,
    "fixed_costs": 6000,
    "marketing": 4000
  },
  "utilisation": 0.68,
  "variance_vs_plan": {
    "revenue_variance": -5000,
    "reason": "Q2 deal slipped to Q3"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "agency": "x",
  "month": "2026-04"
}
]]></code>
    <note>revenue/cogs/opex/utilisation/variance_vs_plan missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="aggregate-revenue"><description>revenue without 3-line split</description><reason>Hides mix shifts.</reason></forbidden-pattern>
    <forbidden-pattern id="contractor-as-opex"><description>contractor fees in opex.payroll</description><reason>Hides true gross margin.</reason></forbidden-pattern>
    <forbidden-pattern id="missing-utilisation"><description>utilisation field absent</description><reason>Hides profitability lever.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-agency-pnl-tracker-template.py">Validator script</reference>
</text>
