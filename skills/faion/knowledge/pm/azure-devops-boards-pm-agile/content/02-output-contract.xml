<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Azure DevOps Boards Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the Azure DevOps Boards artefact. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <schema kind="json-schema">
      <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/azure-devops-boards.json",
  "type": "object",
  "required": [
    "project_id",
    "process_template",
    "area_paths",
    "iteration_paths",
    "boards"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "process_template": {
      "enum": [
        "Basic",
        "Agile",
        "Scrum",
        "CMMI"
      ]
    },
    "area_paths": {
      "type": "array",
      "minItems": 1
    },
    "iteration_paths": {
      "type": "array",
      "minItems": 1
    },
    "boards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "team",
          "columns"
        ],
        "properties": {
          "team": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "name",
                "state"
              ]
            }
          },
          "swimlanes": {
            "type": "array"
          }
        }
      }
    },
    "shared_queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "wiql"
        ]
      }
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "Acme-Platform",
  "process_template": "Scrum",
  "area_paths": [
    "Acme-Platform\\Frontend",
    "Acme-Platform\\Backend",
    "Acme-Platform\\Infra"
  ],
  "iteration_paths": [
    "Acme-Platform\\2026\\Q2\\Sprint-21",
    "Acme-Platform\\2026\\Q2\\Sprint-22"
  ],
  "boards": [
    {
      "team": "Frontend",
      "columns": [
        {
          "name": "New",
          "state": "New"
        },
        {
          "name": "Approved",
          "state": "Approved"
        },
        {
          "name": "Committed",
          "state": "Committed"
        },
        {
          "name": "Done",
          "state": "Done"
        }
      ],
      "swimlanes": [
        "Customer-Reported",
        "Tech-Debt"
      ]
    }
  ],
  "shared_queries": [
    {
      "path": "/Shared Queries/v2/active-bugs-2026-Q2",
      "wiql": "SELECT [System.Id] FROM workitems WHERE [System.WorkItemType]='Bug' AND [System.State]<>'Done'"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "Acme",
  "process_template": "Custom",
  "area_paths": [],
  "boards": [
    {
      "team": "Frontend",
      "columns": [
        {
          "name": "Doing"
        }
      ]
    }
  ]
}
]]></code>
    <note>process_template not in enum; area_paths empty; column missing state; iteration_paths missing; shared_queries un-versioned.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern id="f1"><description>Status set to an approved/sent state by the producing agent without a human reviewer entry.</description></antipattern>
    <antipattern id="f2"><description>Required field empty or replaced with a placeholder (n/a, unknown) without an anchored reason.</description></antipattern>
    <antipattern id="f3"><description>Prose paragraph stuffed into a field the schema declares as array or object.</description></antipattern>
  </section>

  <reference path="scripts/validate-azure-devops-boards.py">Validator script.</reference>
</text>
