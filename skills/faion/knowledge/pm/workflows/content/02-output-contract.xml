<text id="02-output-contract" title="Product Manager Workflows Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pm-workflow-output.json",
  "type": "object",
  "required": [
    "pipeline",
    "phase",
    "artifacts",
    "approvals"
  ],
  "properties": {
    "pipeline": {
      "enum": [
        "bootstrap",
        "mlp",
        "sprint",
        "release"
      ]
    },
    "phase": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "kind"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "constitution",
              "roadmap",
              "spec",
              "task",
              "rice-table",
              "mlp-report",
              "release-notes"
            ]
          }
        }
      },
      "minItems": 1
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "who",
          "token",
          "timestamp"
        ]
      },
      "minItems": 1
    },
    "needs_human": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pipeline": "bootstrap",
  "phase": "5-backlog",
  "artifacts": [
    {
      "path": ".aidocs/features/backlog/01-auth/spec.md",
      "kind": "spec"
    }
  ],
  "approvals": [
    {
      "who": "ruslan",
      "token": "approve",
      "timestamp": "2026-05-23T10:00:00Z"
    }
  ],
  "needs_human": false
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pipeline": "bootstrap",
  "phase": "5",
  "artifacts": []
}
]]></code>
    <note>Missing approvals + empty artifacts; bootstrap MUST refuse with needs_human=true.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">artifacts kind not in enum</pattern>
    <pattern id="f2">approval without token</pattern>
    <pattern id="f3">phase 4 simulated without explicit user token</pattern>
    <pattern id="f4">feature created without RICE row</pattern>
  </section>

  <reference path="scripts/validate-workflows.py">Validator script (stdlib-only).</reference>
</text>
