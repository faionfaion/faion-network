<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Feature De Risking Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a AI Feature De Risking deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="eval_set_id" format="versioned_id" />
      <field name="n_examples" type="integer" min="20" />
      <field name="model_id_pinned" format="provider_model_version" />
      <field name="metric_values" type="object" schema="{mean,ci_low,ci_high}" />
      <field name="cost_per_run_usd" format="float" />
    </required>
    <forbidden>
      <pattern id="f1">naked metric without n and CI</pattern>
      <pattern id="f2">eval_set_id not frozen</pattern>
      <pattern id="f3">judge-LLM uncalibrated within 90 days</pattern>
      <pattern id="f4">eval cost unmeasured</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Downsample for cost only AFTER recording full-run baseline.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>n ≥ 20</item>
      <item>CI present</item>
      <item>Model + prompt pinned</item>
      <item>Cost reported</item>
    </list>
  </section>
</text>
