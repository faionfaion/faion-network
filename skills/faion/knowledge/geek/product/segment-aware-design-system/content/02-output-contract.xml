<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Segment-Aware Design System Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator enforces required fields + per-field constraints. Forbidden patterns listed at end.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/segment-aware-design-system.json",
  "type": "object",
  "required": [
    "segments",
    "tokens_path",
    "components_with_segment_prop",
    "i18n_namespace"
  ],
  "properties": {
    "segments": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "tone"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]+$"
          },
          "label": {
            "type": "string"
          },
          "tone": {
            "enum": [
              "neutral",
              "formal",
              "playful",
              "technical"
            ]
          }
        }
      }
    },
    "tokens_path": {
      "type": "string"
    },
    "components_with_segment_prop": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "i18n_namespace": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "segments": [
    {
      "id": "developer",
      "label": "Solo developer",
      "tone": "technical"
    },
    {
      "id": "exec",
      "label": "Engineering leader",
      "tone": "formal"
    }
  ],
  "tokens_path": "design-system/tokens/segments/",
  "components_with_segment_prop": [
    "Button",
    "Hero",
    "PricingCard"
  ],
  "i18n_namespace": "marketing"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "segments": [],
  "tokens_path": ""
}
]]></code>
    <note>segments empty (minItems=1); tokens_path empty; missing components_with_segment_prop, i18n_namespace.</note>
  </example>

  <forbidden>
    <pattern id="f1">segments.length &gt; 5</pattern>
    <pattern id="f2">tone outside enum</pattern>
    <pattern id="f3">components_with_segment_prop empty</pattern>
    <pattern id="f4">tokens_path missing or empty</pattern>
  </forbidden>

  <reference path="scripts/validate-segment-aware-design-system.py">Validator script (stdlib + jsonschema-style validation; --self-test included).</reference>
</text>
