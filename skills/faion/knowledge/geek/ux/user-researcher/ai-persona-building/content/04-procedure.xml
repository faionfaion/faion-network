<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AI Persona Building (Single-Pass) Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply ai-persona-building end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="collect-secondary">
      <input>Analytics + market reports</input>
      <action>Gather 5–10 secondary-source artefacts.</action>
      <output>Source bundle</output>
    </step>
    <step n="2" name="sonnet-pass">
      <input>Source bundle + industry context</input>
      <action>Sonnet generates 3–5 persona scaffolds.</action>
      <output>Scaffolds</output>
    </step>
    <step n="3" name="haiku-detail-pass">
      <input>Scaffolds</input>
      <action>Haiku adds goals + frustrations + behaviours per scaffold.</action>
      <output>Detailed personas</output>
    </step>
    <step n="4" name="label-not-validated">
      <input>Detailed personas</input>
      <action>Apply validated=false + validation_required + use_for=discovery.</action>
      <output>Labelled report</output>
    </step>
    <step n="5" name="emit-with-next-step">
      <input>Labelled report</input>
      <action>Add explicit upgrade path to two-pass methodology.</action>
      <output>personas.json</output>
    </step>
  </section>
</text>
