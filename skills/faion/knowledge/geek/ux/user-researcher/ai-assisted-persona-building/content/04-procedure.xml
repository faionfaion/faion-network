<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AI-Assisted Persona Building (Two-Pass) Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply ai-assisted-persona-building end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="ingest-sources">
      <input>Transcripts + surveys + analytics</input>
      <action>Normalise into snippet records with id + source + text.</action>
      <output>Snippet corpus</output>
    </step>
    <step n="2" name="broad-cluster">
      <input>Snippet corpus</input>
      <action>Sonnet pass clusters into broad segments.</action>
      <output>Cluster set</output>
    </step>
    <step n="3" name="refine-cluster">
      <input>Cluster set</input>
      <action>Haiku pass refines each cluster with quote grounding + goals.</action>
      <output>Refined personas</output>
    </step>
    <step n="4" name="collect-reviews">
      <input>Refined personas + reviewer list</input>
      <action>Route to ≥3 stakeholders; collect verdicts + comments.</action>
      <output>Review pack</output>
    </step>
    <step n="5" name="emit-report">
      <input>Refined personas + reviews + open Qs</input>
      <action>Compose final persona report.</action>
      <output>personas.json</output>
    </step>
  </section>
</text>
