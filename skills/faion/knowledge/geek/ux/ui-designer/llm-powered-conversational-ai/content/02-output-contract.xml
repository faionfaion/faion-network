<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM-Powered Conversational AI Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the spec artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/llm-powered-conversational-ai.json",
  "type": "object",
  "required": [
    "modality",
    "asr_provider",
    "llm_model",
    "latency_budget_ms",
    "safety_filters",
    "fallback_target",
    "audit_log_path"
  ],
  "properties": {
    "modality": {
      "type": "string",
      "enum": [
        "voice",
        "text",
        "voice+text"
      ]
    },
    "asr_provider": {
      "type": "string"
    },
    "llm_model": {
      "type": "string"
    },
    "tts_voice": {
      "type": "string"
    },
    "latency_budget_ms": {
      "type": "object",
      "required": [
        "asr",
        "llm",
        "tts"
      ]
    },
    "safety_filters": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "fallback_target": {
      "type": "string"
    },
    "history_max_turns": {
      "type": "integer",
      "maximum": 20
    },
    "audit_log_path": {
      "type": "string"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "modality": "voice",
  "asr_provider": "deepgram-nova-2",
  "llm_model": "claude-sonnet-4.7",
  "tts_voice": "elevenlabs:rachel",
  "latency_budget_ms": {
    "asr": 300,
    "llm": 1200,
    "tts": 600
  },
  "safety_filters": [
    "jailbreak-detector",
    "factual-grounding"
  ],
  "fallback_target": "human-queue-tier1",
  "history_max_turns": 12,
  "audit_log_path": "s3://audit/convo/{date}.jsonl"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "modality": "voice",
  "asr_provider": "x"
}
]]></code>
    <note>Missing latency budget + safety filters + fallback + audit log.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-llm-powered-conversational-ai.py">Validator script</reference>
</text>
