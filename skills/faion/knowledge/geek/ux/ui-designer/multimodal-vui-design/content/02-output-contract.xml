<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Multimodal VUI Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the spec artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/multimodal-vui-design.json",
  "type": "object",
  "required": [
    "feature_id",
    "pattern",
    "fallback_tiers",
    "timeout_ms",
    "error_state_ui",
    "statesync_test_path",
    "locales"
  ],
  "properties": {
    "feature_id": {
      "type": "string"
    },
    "pattern": {
      "type": "string",
      "enum": [
        "voice-init-screen-complete",
        "screen-init-voice-complete",
        "voice-visual-feedback",
        "voice-nav-visual-content"
      ]
    },
    "fallback_tiers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 30000
    },
    "error_state_ui": {
      "type": "string",
      "minLength": 20
    },
    "statesync_test_path": {
      "type": "string"
    },
    "locales": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "feature_id": "play-recipe-cards",
  "pattern": "voice-nav-visual-content",
  "fallback_tiers": [
    "voice",
    "touch",
    "keyboard"
  ],
  "timeout_ms": 8000,
  "error_state_ui": "Show 'Try saying next step' + tap-to-advance button.",
  "statesync_test_path": "tests/vui/recipe-cards-statesync.test.ts",
  "locales": [
    "en-US",
    "es-MX",
    "uk-UA"
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "feature_id": "x",
  "pattern": "voice",
  "fallback_tiers": [
    "voice"
  ]
}
]]></code>
    <note>Pattern not one of four; fallback has &lt;3 tiers; missing timeout + error + statesync + locales.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-multimodal-vui-design.py">Validator script</reference>
</text>
