<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Plugin Ecosystem (Figma REST) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the code artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-plugin-ecosystem.json",
  "type": "object",
  "required": [
    "operation",
    "file_key",
    "auth_type",
    "rate_limit_rpm",
    "output_uri"
  ],
  "properties": {
    "operation": {
      "type": "string",
      "enum": [
        "a11y-audit",
        "bulk-rename",
        "asset-export",
        "style-extract",
        "comment-batch"
      ]
    },
    "file_key": {
      "type": "string",
      "minLength": 16
    },
    "auth_type": {
      "type": "string",
      "enum": [
        "pat",
        "oauth"
      ]
    },
    "rate_limit_rpm": {
      "type": "integer",
      "maximum": 60
    },
    "audit_log_path": {
      "type": "string"
    },
    "output_uri": {
      "type": "string",
      "format": "uri"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "operation": "a11y-audit",
  "file_key": "AbCdEf1234567890",
  "auth_type": "pat",
  "rate_limit_rpm": 55,
  "audit_log_path": "s3://logs/figma/2026-05-22.jsonl",
  "output_uri": "s3://reports/a11y/AbCdEf-2026-05-22.json"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "operation": "delete-frame",
  "file_key": "x",
  "auth_type": "pat"
}
]]></code>
    <note>Operation not supported by REST; file_key too short; missing rate_limit + output_uri.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-ai-plugin-ecosystem.py">Validator script</reference>
</text>
