<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Generative UI Design Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply generative-ui-design end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="prepare-brief">
      <input>Feature brief + constraints</input>
      <action>Combine brief + brand tokens + must-not-have into a generator prompt.</action>
      <output>Generator prompt</output>
    </step>
    <step n="2" name="generate-variants">
      <input>Generator prompt + tools</input>
      <action>Run ≥5 generations across chosen generators.</action>
      <output>Variant set</output>
    </step>
    <step n="3" name="review-with-stakeholders">
      <input>Variant set + review channel</input>
      <action>Hold review; collect comments + selection vote.</action>
      <output>Stakeholder feedback</output>
    </step>
    <step n="4" name="select-and-rationalise">
      <input>Variant set + feedback</input>
      <action>Pick variant; write a ≥40-char rationale.</action>
      <output>Selected variant + rationale</output>
    </step>
    <step n="5" name="emit-handoff">
      <input>Selected variant + rationale + refinement list</input>
      <action>Emit JSON spec labelled ideation-only; hand off to design refinement.</action>
      <output>ideation-spec.json</output>
    </step>
  </section>
</text>
