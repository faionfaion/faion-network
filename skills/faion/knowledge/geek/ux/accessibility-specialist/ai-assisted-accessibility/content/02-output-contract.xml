<text id="02-output-contract" title="AI-Assisted Accessibility Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-ai-assisted-accessibility.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-assisted-accessibility.json",
  "title": "A11yAuditReport",
  "type": "object",
  "required": [
    "scope_pages_scanned",
    "tools_used",
    "haiku_filter_results_count",
    "sonnet_fixes_proposed_count",
    "expert_validated_count",
    "tickets_created_count",
    "wcag_citations_complete"
  ],
  "properties": {
    "scope_pages_scanned": {
      "type": "integer",
      "minimum": 1
    },
    "tools_used": {
      "type": "array",
      "items": {
        "enum": [
          "axe",
          "pa11y",
          "wave",
          "other"
        ]
      },
      "minItems": 1
    },
    "haiku_filter_results_count": {
      "type": "integer",
      "minimum": 0
    },
    "sonnet_fixes_proposed_count": {
      "type": "integer",
      "minimum": 0
    },
    "expert_validated_count": {
      "type": "integer",
      "minimum": 0
    },
    "tickets_created_count": {
      "type": "integer",
      "minimum": 0
    },
    "wcag_citations_complete": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "scope_pages_scanned": 48,
  "tools_used": [
    "axe",
    "pa11y"
  ],
  "haiku_filter_results_count": 134,
  "sonnet_fixes_proposed_count": 84,
  "expert_validated_count": 84,
  "tickets_created_count": 71,
  "wcag_citations_complete": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scope_pages_scanned": 48,
  "tools_used": [],
  "haiku_filter_results_count": 134,
  "sonnet_fixes_proposed_count": 84,
  "expert_validated_count": 0,
  "tickets_created_count": 84,
  "wcag_citations_complete": false
}
]]></code>
    <note>Tools list empty; nothing expert-validated; tickets created ahead of validation; WCAG citations missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">tools_used empty</pattern>
      <pattern id="f2">expert_validated_count &lt; sonnet_fixes_proposed_count when tickets_created_count &gt; 0</pattern>
      <pattern id="f3">wcag_citations_complete == false</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-ai-assisted-accessibility.py">Validator script enforcing this contract.</reference>
</text>
