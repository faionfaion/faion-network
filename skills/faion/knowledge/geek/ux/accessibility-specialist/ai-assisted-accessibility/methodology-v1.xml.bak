<?xml version="1.0" encoding="UTF-8"?>
<methodology slug="ai-assisted-accessibility">
  <metadata>
    <tier>geek</tier>
    <group>ux</group>
    <domain>accessibility-specialist</domain>
    <summary>AI accelerates WCAG auditing by automating scan execution, false-positive filtering, fix suggestion generation, and bulk alt text creation — reducing audit time by 60–75%.</summary>
    <tags>
      <tag>accessibility</tag>
      <tag>wcag</tag>
      <tag>ai-automation</tag>
      <tag>auditing</tag>
      <tag>testing</tag>
    </tags>
    <category>accessibility</category>
    <difficulty>advanced</difficulty>
    <created>2026-04-28</created>
  </metadata>
  <content>
    <title>AI-Assisted Accessibility</title>
    <summary>AI accelerates WCAG auditing by automating scan execution, false-positive filtering, fix suggestion generation, and bulk alt text creation — reducing audit time by 60–75%. A Haiku subagent runs axe-playwright or pa11y, filters noise, and ranks issues by impact. A Sonnet subagent generates code fixes per issue. Human experts validate all AI output before developer tickets are created.</summary>
    <why>
      <p>Manual accessibility audits take 20–40 hours and happen infrequently; AI-assisted workflows compress the same coverage to 5–10 hours and enable continuous monitoring on every deploy. AI reduces false positives from 30–40% to 10–15% and attaches code fix suggestions directly to issues, cutting developer context-switching.</p>
    </why>
    <when-to-use>
      <list>
        <item>Running automated WCAG audits as part of a CI/CD pipeline before each deployment</item>
        <item>Generating alt text suggestions at scale for image-heavy content pipelines</item>
        <item>Producing draft VPAT/accessibility conformance reports from scan results</item>
        <item>Triaging a large backlog of accessibility issues by AI-assisted priority ranking</item>
        <item>Generating auto-captions for video content as a first pass before human review</item>
      </list>
    </when-to-use>
    <when-not-to-use>
      <list>
        <item>Replacing real user testing with people who use assistive technology — AI cannot substitute</item>
        <item>Accepting AI overlay widgets as an accessibility solution — they do not fix underlying code</item>
        <item>Treating AI-generated alt text as final without editorial review for context and brand voice</item>
        <item>Using AI scan results alone as proof of WCAG compliance for legal or procurement purposes</item>
        <item>Cognitive accessibility evaluation — AI tools have poor coverage here even in 2026</item>
      </list>
    </when-not-to-use>
    <section name="Tool Landscape">
      <p>AI-powered accessibility tools by category, integration points across the development lifecycle, and capability comparison for 2026.</p>
      <section name="Enterprise Platforms">
        <list>
          <item>axe DevTools Pro — AI suggestions, issue prioritization, fix chatbot; $$$</item>
          <item>Deque axe Enterprise — intelligent false-positive reduction, AI fix recommendations; $$$</item>
          <item>Level Access — Ask Level AI chatbot for WCAG Q&amp;A; no programmatic scan API; $$$</item>
          <item>Evinced — AI-powered continuous testing; REST API for CI/CD integration; $$$</item>
          <item>Siteimprove — enterprise monitoring with AI trend analysis; REST API; $$$</item>
          <item>AudioEye — AI remediation with human oversight; not overlay-based; $$</item>
        </list>
      </section>
      <section name="Free and Low-Cost Tools">
        <list>
          <item>Accessibility Insights (Microsoft) — code fix recommendations, automated guidance; free</item>
          <item>WAVE — visual feedback with annotations; free browser extension</item>
          <item>Lighthouse — performance + a11y scoring with AI insights; free (Chrome DevTools)</item>
          <item>Stark — contrast checking, vision simulation, AI suggestions; free/$</item>
          <item>axe-playwright — headless WCAG scanning in CI; OSS</item>
          <item>pa11y-ci — batch URL scanning in CI pipelines; OSS</item>
          <item>jest-axe — unit-level accessibility assertions; OSS</item>
          <item>eslint-plugin-jsx-a11y — static JSX a11y linting; OSS</item>
        </list>
      </section>
      <section name="Integration Points">
        <list>
          <item>Design: Figma (Stark plugin), Adobe XD (built-in checker), Sketch (contrast plugins)</item>
          <item>Development: VS Code (axe Linter), JetBrains (inspections), ESLint (jsx-a11y), Storybook (a11y addon)</item>
          <item>Testing: Playwright (axe-playwright), Cypress (cypress-axe), Jest (jest-axe)</item>
          <item>CI/CD: GitHub Actions, GitLab CI (pa11y), Jenkins, CircleCI</item>
        </list>
      </section>
      <section name="AI New Capabilities (2026)">
        <list>
          <item>Issue-level AI: tools attached to individual audit issues; one-click fix suggestions without context switching</item>
          <item>VPAT generation: draft in seconds vs. hours of manual work</item>
          <item>False positive reduction: 30–40% down to 10–15%</item>
          <item>In-IDE hints: VS Code and JetBrains real-time a11y linting</item>
          <item>Alt text generators: Azure Computer Vision, Google Vision AI, OpenAI GPT-4V, Claude</item>
          <item>Caption tools: 3Play Media (AI + human, 99% accuracy), Rev.ai (80–90%)</item>
        </list>
      </section>
    </section>
    <section name="AI-Assisted Accessibility Workflow">
      <p>5-stage pipeline from automated scan to user validation, including the human-AI responsibility split and ROI data.</p>
      <section name="5-Stage Pipeline">
        <list>
          <item>1. Automated Scan: run axe, WAVE, Lighthouse; AI prioritizes findings; false positives filtered (10–15% remain)</item>
          <item>2. AI Suggestions: review AI-proposed code fixes; understand why issue matters; get multiple fix options ranked by best practice</item>
          <item>3. Manual Verification: test keyboard navigation; verify logical fix makes sense; check edge cases AI missed</item>
          <item>4. User Testing: test with people with disabilities using real assistive technology; validate AI assumptions</item>
          <item>5. Continuous Monitoring: AI scans on every deploy; track trends over time; alert on new critical issues</item>
        </list>
      </section>
      <section name="Human vs AI Responsibilities">
        <rule>
          <statement>AI handles repetitive scanning and report generation; humans handle all contextual decisions and user testing validation.</statement>
          <rationale>AI finds issues faster and more consistently; humans provide context, empathy, and judgment. Combining both produces 85–95% issue coverage vs 50–70% for manual alone.</rationale>
        </rule>
        <list>
          <item>AI: repetitive scanning, code extraction, report generation, WCAG Q&amp;A, draft alt text, priority ranking, regression testing</item>
          <item>Human: context and empathy in content decisions, complex judgment calls, user testing, strategic fix decisions, edge cases, final review, accessibility culture</item>
        </list>
      </section>
      <section name="ROI Benchmarks">
        <list>
          <item>Manual audit: 20–40 hours; $5,000–$20,000 per audit</item>
          <item>AI-assisted audit: 5–10 hours; 60–75% time reduction</item>
          <item>AI tools: $100–$2,000/month; break-even at 1–3 audits/year</item>
          <item>Manual only: 50–70% issue detection; AI + Manual: 85–95%</item>
          <item>Continuous AI: prevents 40% of issues before production</item>
        </list>
      </section>
      <rule>
        <statement>Scan new pages on every deployment, not just periodically — regressions appear silently.</statement>
        <rationale>New code regularly introduces accessibility regressions. One-time audits miss regressions introduced between audits. CI-integrated scanning catches them at the source.</rationale>
      </rule>
    </section>
    <section name="AI Accessibility Anti-Patterns">
      <p>Critical failure modes: AI overlays, alt text limitations, caption accuracy traps, automated compliance claims, and agent gotchas.</p>
      <antipattern>
        <description>Using AI overlay widgets (UserWay, accessiBe) as an accessibility compliance solution.</description>
        <reason>Overlays do not fix underlying code issues — they are band-aids that cannot fix semantic HTML, keyboard navigation, heading structure, or meaningful alt text. They may create new barriers for screen reader users and do not satisfy WCAG 2 compliance.</reason>
      </antipattern>
      <antipattern>
        <description>Accepting AI-generated alt text without editorial review for context, brand voice, and image purpose.</description>
        <reason>AI describes what is in the image; it cannot determine why the image matters to the user, what should be emphasized, or the appropriate level of detail for the context. Always include surrounding page context in the generation prompt.</reason>
      </antipattern>
      <antipattern>
        <description>Publishing video with AI-only captions without human review.</description>
        <reason>AI-only caption accuracy (80–90%) does not meet the 99% legal requirement. Always pair AI captioning with human review before publication. Legal requirement is non-negotiable.</reason>
      </antipattern>
      <antipattern>
        <description>Using AI scan results alone as proof of WCAG compliance for legal or procurement purposes.</description>
        <reason>Even AI-enhanced scanning covers only 30–50% of WCAG success criteria. The remaining criteria require human testing and judgment. Presenting automated results as compliance evidence is legally and ethically inaccurate.</reason>
      </antipattern>
      <antipattern>
        <description>Sending large axe JSON output (100+ issues) to LLM in a single prompt without chunking.</description>
        <reason>Large axe reports on poorly maintained pages exceed LLM context limits. Chunk by page or component before sending; aggregate results after.</reason>
      </antipattern>
      <antipattern>
        <description>Agent instructed to suggest overlays or widget-based fixes as remediation options.</description>
        <reason>Overlays are never an acceptable remediation. The agent must be explicitly instructed to skip overlay suggestions — without the constraint, it will recommend them as quick fixes.</reason>
      </antipattern>
    </section>
    <section name="Best Practices">
      <list>
        <item>Integrate axe-playwright or pa11y-ci into the CI pipeline as a blocking gate for critical violations only — warnings go to the issue tracker</item>
        <item>Use AI fix suggestions as a starting point; require developer to understand and confirm the fix, not just apply it blindly</item>
        <item>For alt text generation: always include surrounding page context and image purpose in the prompt, not just the image file</item>
        <item>Caption review is non-negotiable for legal compliance — never publish AI-only captions for video content</item>
        <item>Scan new pages on every deployment, not just periodically — regressions appear silently</item>
        <item>Document which AI suggestions were accepted or rejected and why — creates a learning corpus for future fine-tuning</item>
        <item>Pair automated scanning with quarterly manual audits using real assistive technology (VoiceOver, NVDA, JAWS)</item>
      </list>
    </section>
    <section name="AI-Agent Gotchas">
      <list>
        <item>Agent must be explicitly instructed to skip overlay/widget fix suggestions — they are never an acceptable remediation</item>
        <item>axe JSON output can be large (>100 issues on poorly maintained pages) — chunk before sending to LLM to avoid context overflow</item>
        <item>Alt text agents hallucinate confident descriptions for images with ambiguous content — require explicit uncertainty markers in output</item>
        <item>Fix suggestions for dynamic/AJAX content are often incorrect — flag these for manual review rather than automated fix</item>
        <item>VPAT generation agents produce legally significant documents; always require human legal/compliance sign-off before publication</item>
        <item>Human-in-loop checkpoint: before developer tickets are created from AI-ranked issues, a human accessibility expert must validate the priority ranking</item>
      </list>
    </section>
    <section name="CLI Tools">
      <list>
        <item>axe-playwright — Headless WCAG scanning in CI | npm install @axe-core/playwright / github.com/dequelabs/axe-core-npm</item>
        <item>pa11y — Lightweight CLI accessibility tester | npm install -g pa11y / pa11y.org</item>
        <item>pa11y-ci — CI-integrated batch page scanning | npm install -g pa11y-ci / github.com/pa11y/pa11y-ci</item>
        <item>lighthouse-ci — Performance + a11y scoring in CI | npm install -g @lhci/cli / github.com/GoogleChrome/lighthouse-ci</item>
        <item>jest-axe — Unit-level accessibility assertions | npm install jest-axe / github.com/nickcolley/jest-axe</item>
        <item>eslint-plugin-jsx-a11y — Static analysis for JSX accessibility | npm install eslint-plugin-jsx-a11y / github.com/jsx-eslint/eslint-plugin-jsx-a11y</item>
        <item>storybook-addon-a11y — Component-level a11y testing in Storybook | npm install @storybook/addon-a11y</item>
      </list>
    </section>
    <section name="Services and Apps">
      <p>AI accessibility SaaS platforms and their agent compatibility.</p>
      <list>
        <item>Deque axe DevTools Pro (SaaS, Partial) — AI fix suggestions per issue; requires license</item>
        <item>Evinced (SaaS, Yes) — AI-powered continuous scanning; REST API for issue data</item>
        <item>Siteimprove (SaaS, Yes) — Enterprise monitoring; AI trend analysis via API</item>
        <item>Level Access (SaaS, Partial) — Ask Level AI for WCAG Q&amp;A; no programmatic API</item>
        <item>3Play Media (SaaS, Yes) — AI + human caption review pipeline; media upload API</item>
        <item>Microsoft Azure Computer Vision (SaaS, Yes) — Alt text generation from image bytes</item>
        <item>Google Cloud Vision AI (SaaS, Yes) — Object/scene detection for alt text generation</item>
        <item>OpenAI GPT-4 Vision (SaaS, Yes) — Contextual image description for alt text drafts</item>
        <item>UserWay (SaaS, No) — Widget-based — not recommended for agent-driven fixes</item>
      </list>
    </section>
    <templates>
      <template path="templates/ci-a11y-gate.sh" purpose="pa11y-ci CI gate script with threshold configuration"/>
      <template path="templates/pa11yci.json" purpose="pa11y-ci config: WCAG2AA, axe + htmlcs runners, ignore list"/>
      <template path="templates/prompt-triage-issues.txt" purpose="Haiku prompt: axe JSON → ranked issue list with fix suggestions"/>
      <template path="templates/prompt-generate-fix.txt" purpose="Sonnet prompt: WCAG violation + code snippet → concrete code fix"/>
    </templates>
