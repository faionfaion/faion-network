<text id="02-output-contract" title="AI + Spatial Computing Accessibility Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the spec artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-spatial-computing.json",
  "type": "object",
  "required": [
    "hardware",
    "modalities",
    "fallback_tiers",
    "ondevice_p95_ms",
    "consent_screen",
    "human_signoff_recorded"
  ],
  "properties": {
    "hardware": {
      "type": "string"
    },
    "modalities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "fallback_tiers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "ondevice_p95_ms": {
      "type": "number",
      "maximum": 20
    },
    "consent_screen": {
      "type": "boolean",
      "const": true
    },
    "biometric_retention_days": {
      "type": "integer",
      "minimum": 0
    },
    "xaur_findings": {
      "type": "array"
    },
    "human_signoff_recorded": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "hardware": "Apple Vision Pro visionOS 2.1",
  "modalities": [
    "gaze",
    "voice",
    "hand"
  ],
  "fallback_tiers": [
    "gaze",
    "voice",
    "controller"
  ],
  "ondevice_p95_ms": 14.2,
  "consent_screen": true,
  "biometric_retention_days": 0,
  "xaur_findings": [
    {
      "clause": "3.6.1",
      "verdict": "pass",
      "confidence": "High"
    }
  ],
  "human_signoff_recorded": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "hardware": "Vision Pro",
  "modalities": [
    "gaze"
  ],
  "ondevice_p95_ms": 65,
  "consent_screen": false
}
]]></code>
    <note>Single-modality gaze-only; latency &gt;20 ms; consent missing.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-ai-spatial-computing.py">Validator script</reference>
</text>
