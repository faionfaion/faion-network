<text id="06-decision-tree" title="AI Accessibility Automation 2026 Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Does the product deploy ≥ weekly AND is a human a11y lead available?</root-question>

      <branch when="deploy_frequency &lt; weekly OR human_lead_available == false">
        <conclusion ref="skip-this-methodology" verdict="manual audit fits the cadence / no gate possible"/>
      </branch>
      <branch when="scan_per_deploy == false">
        <conclusion ref="scan-every-deploy" verdict="reject: missing per-deploy scan"/>
      </branch>
      <branch when="human_lead_gate == false">
        <conclusion ref="ai-rank-not-decide" verdict="reject: AI deciding backlog"/>
      </branch>
      <branch when="vpat_unsigned_shared == true">
        <conclusion ref="vpat-draft-human-signed" verdict="reject: unsigned VPAT released"/>
      </branch>
      <branch when="alt_text_confidence &lt; 0.8 AND auto_accepted == true">
        <conclusion ref="alt-text-confidence-gate" verdict="reject: low-confidence alt text shipped"/>
      </branch>
      <branch when="regulated_content_review_pct &lt; 100">
        <conclusion ref="caption-review-stratified" verdict="reject: regulated content unreviewed"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="caption-review-stratified" verdict="accept: a11y pipeline live"/>
      </branch>

  </decision-tree>

  <example trace="ai-accessibility-automation-2026-happy-path">
    Weekly deploy → axe scan 47 issues → AI ranks → lead approves 12 → VPAT section updated → signed → alt text on 200 product shots accepted at 0.86 confidence.
  </example>
</text>
