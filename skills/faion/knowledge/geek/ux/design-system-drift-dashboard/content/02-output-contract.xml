<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design System Drift Dashboard Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the report artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/design-system-drift-dashboard.json",
  "type": "object",
  "required": [
    "scan_date",
    "repos_scanned",
    "adoption_pct",
    "drift_count",
    "signoff_threshold_met"
  ],
  "properties": {
    "scan_date": {
      "type": "string",
      "format": "date"
    },
    "repos_scanned": {
      "type": "integer",
      "minimum": 1
    },
    "adoption_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "drift_count": {
      "type": "integer",
      "minimum": 0
    },
    "tokens_total": {
      "type": "integer",
      "minimum": 1
    },
    "tokens_v2": {
      "type": "integer",
      "minimum": 0
    },
    "hardcoded_findings": {
      "type": "array"
    },
    "signoff_threshold_met": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "scan_date": "2026-05-22",
  "repos_scanned": 14,
  "adoption_pct": 92.4,
  "drift_count": 1,
  "tokens_total": 480,
  "tokens_v2": 443,
  "hardcoded_findings": [
    {
      "file": "apps/web/Header.tsx",
      "line": 42,
      "value": "#0F62FE",
      "expected_token": "color-brand-primary"
    }
  ],
  "signoff_threshold_met": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scan_date": "2026-05-22",
  "adoption_pct": 110,
  "drift_count": -1
}
]]></code>
    <note>adoption_pct &gt; 100; drift_count negative; missing required fields.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-design-system-drift-dashboard.py">Validator script</reference>
</text>
