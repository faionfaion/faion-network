{
  "__faion_header__": {
    "purpose": "Pre-existing template carried into the multimodal-vui-design methodology",
    "consumes": "See content/02-output-contract.xml inputs",
    "produces": "artefact conforming to content/02-output-contract.xml for produces=spec",
    "depends-on": "content/01-core-rules.xml",
    "token-budget-impact": "~200-1000 tokens when loaded as context"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MultimodalDialogueTurn",
  "description": "Schema for a single turn in a multimodal voice + visual dialogue.",
  "type": "object",
  "required": [
    "turn_id",
    "voice_prompt",
    "visual_state",
    "user_actions",
    "fallback"
  ],
  "properties": {
    "turn_id": {
      "type": "integer",
      "description": "Sequential turn index starting at 0."
    },
    "voice_prompt": {
      "type": "string",
      "maxLength": 120,
      "description": "What the assistant says aloud. Max 15 words for smart displays."
    },
    "visual_state": {
      "type": "object",
      "required": [
        "component_type",
        "items"
      ],
      "properties": {
        "component_type": {
          "type": "string",
          "enum": [
            "card",
            "carousel",
            "list",
            "confirmation",
            "progress",
            "text",
            "form"
          ]
        },
        "items": {
          "type": "array",
          "maxItems": 5,
          "description": "Displayed items. Maximum 5 to prevent cognitive overload.",
          "items": {
            "type": "object"
          }
        },
        "title": {
          "type": "string"
        }
      }
    },
    "user_actions": {
      "type": "object",
      "required": [
        "voice",
        "touch"
      ],
      "description": "Both input modes must be defined \u2014 voice alone is not acceptable.",
      "properties": {
        "voice": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Accepted spoken commands for this state."
        },
        "touch": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tappable elements and their actions."
        }
      }
    },
    "fallback": {
      "type": "string",
      "description": "What happens after 5 seconds of silence."
    },
    "destructive": {
      "type": "boolean",
      "default": false,
      "description": "If true, confirmation_required must be true."
    },
    "confirmation_required": {
      "type": "boolean",
      "default": false
    }
  }
}
