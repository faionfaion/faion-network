<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Claude-Driven UX Methodology Bundle Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for CLAUDE-methodologies.</summary>

  <decision-tree>
      <root-question id="q-root">What is the primary UX task shape?</root-question>

      <branch when="task == review_ai_generated_mockup">
        <conclusion ref="r1" verdict="load ai-generated-layout-review-checklist"/>
      </branch>
      <branch when="task == build_generative_ui">
        <conclusion ref="r1" verdict="load generative-ui-design"/>
      </branch>
      <branch when="task == pick_figma_plugin">
        <conclusion ref="r1" verdict="load ai-plugin-ecosystem"/>
      </branch>
      <branch when="task == design_spatial_or_xr">
        <conclusion ref="r1" verdict="load ai-spatial-computing"/>
      </branch>
      <branch when="task == build_conversational_ui">
        <conclusion ref="r1" verdict="load llm-powered-conversational-ai or multimodal-vui-design"/>
      </branch>

      <branch when="preconditions_unmet == true">
        <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
      </branch>
    </decision-tree>

    <example trace="CLAUDE-methodologies-happy-path">
      preconditions met → first branch matches → conclusion ref resolves to a rule in 01-core-rules.xml.
    </example>
</text>
