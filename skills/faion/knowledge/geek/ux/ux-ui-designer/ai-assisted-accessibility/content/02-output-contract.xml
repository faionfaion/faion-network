<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Assisted Accessibility (WCAG 2.2 AA) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the report artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-assisted-accessibility.json",
  "type": "object",
  "required": [
    "site_id",
    "wcag_target",
    "automated_findings",
    "at_findings",
    "conformance_verdict",
    "signed_by",
    "next_audit_date"
  ],
  "properties": {
    "site_id": {
      "type": "string"
    },
    "wcag_target": {
      "type": "string",
      "enum": [
        "2.1-AA",
        "2.2-AA",
        "2.2-AAA"
      ]
    },
    "automated_findings": {
      "type": "array"
    },
    "at_findings": {
      "type": "array"
    },
    "conformance_verdict": {
      "type": "string",
      "enum": [
        "conforms",
        "partial",
        "non-conforms"
      ]
    },
    "signed_by": {
      "type": "string"
    },
    "next_audit_date": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "site_id": "faion.net",
  "wcag_target": "2.2-AA",
  "automated_findings": [
    {
      "id": "axe-color-contrast-1",
      "evidence": "scan:2026-05-22:run42"
    }
  ],
  "at_findings": [
    {
      "id": "at-nvda-headings",
      "evidence": "tester:viktoria:transcript-42"
    }
  ],
  "conformance_verdict": "partial",
  "signed_by": "a11y-lead@faion.net",
  "next_audit_date": "2027-05-22"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "site_id": "x",
  "wcag_target": "1.0",
  "automated_findings": []
}
]]></code>
    <note>Out-of-enum target; missing AT findings + verdict + signed_by + next_audit_date.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-ai-assisted-accessibility.py">Validator script</reference>
</text>
