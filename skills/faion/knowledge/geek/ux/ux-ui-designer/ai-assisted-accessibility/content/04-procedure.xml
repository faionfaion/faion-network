<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AI-Assisted Accessibility (WCAG 2.2 AA) Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply ai-assisted-accessibility end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="ingest-automation">
      <input>Automated scan output</input>
      <action>Load axe / Lighthouse JSON; map issues to WCAG criteria.</action>
      <output>Automated findings</output>
    </step>
    <step n="2" name="schedule-at-tests">
      <input>AT roster + criteria gap</input>
      <action>Schedule AT tests for criteria automation cannot evaluate.</action>
      <output>AT calendar</output>
    </step>
    <step n="3" name="run-at-tests">
      <input>AT calendar</input>
      <action>Conduct sessions; collect tester transcripts + evidence.</action>
      <output>AT findings</output>
    </step>
    <step n="4" name="compute-verdict">
      <input>Combined findings + target</input>
      <action>Compute conforms / partial / non-conforms.</action>
      <output>Verdict</output>
    </step>
    <step n="5" name="sign-and-publish">
      <input>Verdict + evidence</input>
      <action>Emit signed JSON + PDF; archive; schedule next audit.</action>
      <output>Signed report</output>
    </step>
  </section>
</text>
