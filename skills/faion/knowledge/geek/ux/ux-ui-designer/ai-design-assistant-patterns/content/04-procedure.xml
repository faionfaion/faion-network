<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AI Design Assistant Patterns (UX/UI) Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>6-step procedure to apply ai-design-assistant-patterns end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="inventory-triggers">
      <input>Workflow description</input>
      <action>List every trigger source per stage.</action>
      <output>Trigger inventory</output>
    </step>
    <step n="2" name="inventory-context">
      <input>Trigger inventory</input>
      <action>List data sources read per trigger; mark privacy-sensitive.</action>
      <output>Context inventory</output>
    </step>
    <step n="3" name="choose-pattern">
      <input>Inventory + budgets</input>
      <action>Score sidebar / modal / inline / review; pick one.</action>
      <output>Pattern decision</output>
    </step>
    <step n="4" name="define-fallbacks">
      <input>Pattern + outage scenarios</input>
      <action>Define UI for offline / rate-limited / low-confidence.</action>
      <output>Fallback spec</output>
    </step>
    <step n="5" name="place-checkpoints">
      <input>Workflow stages</input>
      <action>Define ≥1 human checkpoint per stage.</action>
      <output>Checkpoint list</output>
    </step>
    <step n="6" name="emit-decision-record">
      <input>All blocks</input>
      <action>Compose JSON decision record.</action>
      <output>decision-record.json</output>
    </step>
  </section>
</text>
