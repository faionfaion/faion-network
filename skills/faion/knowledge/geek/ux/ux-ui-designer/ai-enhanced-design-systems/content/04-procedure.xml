<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AI-Enhanced Design Systems (UX/UI) Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>6-step procedure to apply ai-enhanced-design-systems end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="verify-foundation">
      <input>DS root + tokens + stories</input>
      <action>Confirm tokens codified + naming consistent + stories ≥80 %.</action>
      <output>Foundation check</output>
    </step>
    <step n="2" name="wire-figma-diff">
      <input>Figma file_key + code source</input>
      <action>Wire diff pipeline; block merge on drift.</action>
      <output>Diff pipeline</output>
    </step>
    <step n="3" name="wire-doc-gen">
      <input>Source + stories + Figma metadata</input>
      <action>Auto-generate Markdown per component.</action>
      <output>Doc-gen pipeline</output>
    </step>
    <step n="4" name="wire-token-scanner">
      <input>Token map + scan globs</input>
      <action>Block merge on hardcoded values.</action>
      <output>Scanner pipeline</output>
    </step>
    <step n="5" name="wire-variant-gen">
      <input>Components + token axes</input>
      <action>Generate capped variants; route through visreg.</action>
      <output>Variant pipeline</output>
    </step>
    <step n="6" name="review-and-publish">
      <input>Generated docs</input>
      <action>Human review queue; publish on approval.</action>
      <output>Published docs</output>
    </step>
  </section>
</text>
