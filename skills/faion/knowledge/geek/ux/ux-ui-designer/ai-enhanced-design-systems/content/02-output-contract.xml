<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Enhanced Design Systems (UX/UI) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-enhanced-design-systems.json",
  "type": "object",
  "required": [
    "ds_root",
    "figma_file_key",
    "token_map",
    "doc_generator",
    "token_scanner",
    "figma_code_diff",
    "variant_generator",
    "human_review_required"
  ],
  "properties": {
    "ds_root": {
      "type": "string"
    },
    "figma_file_key": {
      "type": "string",
      "minLength": 16
    },
    "token_map": {
      "type": "string"
    },
    "doc_generator": {
      "type": "object",
      "required": [
        "source",
        "story_root",
        "figma_metadata",
        "output"
      ]
    },
    "token_scanner": {
      "type": "object",
      "required": [
        "block_on_violation"
      ]
    },
    "figma_code_diff": {
      "type": "object",
      "required": [
        "block_on_drift"
      ]
    },
    "variant_generator": {
      "type": "object",
      "required": [
        "visreg_provider"
      ]
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "ds_root": "packages/ds",
  "figma_file_key": "AbCdEf1234567890",
  "token_map": "packages/ds/tokens.json",
  "doc_generator": {
    "source": "packages/ds/src",
    "story_root": "packages/ds/stories",
    "figma_metadata": "true",
    "output": "packages/ds/docs"
  },
  "token_scanner": {
    "block_on_violation": true
  },
  "figma_code_diff": {
    "block_on_drift": true
  },
  "variant_generator": {
    "visreg_provider": "chromatic"
  },
  "human_review_required": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ds_root": "packages/ds",
  "token_scanner": {
    "block_on_violation": false
  },
  "human_review_required": false
}
]]></code>
    <note>Scanner non-blocking; review disabled; missing figma_code_diff + token_map + doc_generator + variant_generator.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-ai-enhanced-design-systems.py">Validator script</reference>
</text>
