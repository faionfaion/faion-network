<text id="06-decision-tree" title="AI-Enhanced Design Systems (UX/UI) Decision Tree" version="1.1.0" est_tokens="600">
  <decision-tree>
    <root-question id="q-preconditions">Do all four `Applies If` preconditions hold for the current task?</root-question>
    <branch when="preconditions.all_hold == true">
      <question id="q-skip-disqualifiers">Does ANY `Skip If` disqualifier hold?</question>
      <branch when="skip.any_hold == true">
        <conclusion ref="skip-this-methodology" verdict="exit without producing the artefact; document why"/>
      </branch>
      <branch when="skip.any_hold == false">
        <question id="q-primary-rule">Does the primary constraint (foundation-prerequisite) hold?</question>
        <branch when="primary_rule.holds == true">
          <conclusion ref="foundation-prerequisite" verdict="run the full procedure; emit the artefact"/>
        </branch>
        <branch when="primary_rule.holds == false">
          <conclusion ref="figma-to-code-diff-required" verdict="fix the primary constraint first; do not produce a degraded artefact"/>
        </branch>
      </branch>
    </branch>
    <branch when="preconditions.all_hold == false">
      <conclusion ref="skip-this-methodology" verdict="preconditions unmet; do not run"/>
    </branch>
    <example trace="precondition checks pass → skip disqualifiers fail → primary constraint holds → run-the-checklist → emit config"/>
  </decision-tree>
</text>
