<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AI Accessibility Automation 2026 Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply ai-accessibility-automation-2026 end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="wire-scanners">
      <input>URL inventory + CI env</input>
      <action>Install axe + Lighthouse in CI; baseline scan.</action>
      <output>Scanner jobs</output>
    </step>
    <step n="2" name="wire-ai-triage">
      <input>Scanner output + model</input>
      <action>Route raw findings to AI triage prompt; classify severity + false-positive.</action>
      <output>Triage jobs</output>
    </step>
    <step n="3" name="set-ci-fail-policy">
      <input>Triage verdict</input>
      <action>Configure CI fail-on-critical; report non-critical.</action>
      <output>CI config</output>
    </step>
    <step n="4" name="schedule-at-testing">
      <input>AT roster + cadence</input>
      <action>Add monthly AT testing event for issues scanners cannot evaluate.</action>
      <output>Calendar</output>
    </step>
    <step n="5" name="persist-audit-trail">
      <input>All run outputs</input>
      <action>Persist scan + triage + verdict ≥90 days.</action>
      <output>Audit store</output>
    </step>
  </section>
</text>
