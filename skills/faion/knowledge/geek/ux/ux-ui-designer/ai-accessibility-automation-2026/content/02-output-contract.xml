<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Accessibility Automation 2026 Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-accessibility-automation-2026.json",
  "type": "object",
  "required": [
    "ci_config_path",
    "scanners",
    "triage_model",
    "wcag_target",
    "at_testing_cadence",
    "ci_fail_on_severity"
  ],
  "properties": {
    "ci_config_path": {
      "type": "string"
    },
    "scanners": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2
    },
    "triage_model": {
      "type": "string"
    },
    "wcag_target": {
      "type": "string",
      "enum": [
        "2.1-AA",
        "2.2-AA",
        "2.2-AAA"
      ]
    },
    "at_testing_cadence": {
      "type": "string"
    },
    "ci_fail_on_severity": {
      "type": "string",
      "enum": [
        "critical",
        "major",
        "any"
      ]
    },
    "audit_retention_days": {
      "type": "integer",
      "minimum": 90
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "ci_config_path": ".github/workflows/a11y.yml",
  "scanners": [
    "axe-core@4.10",
    "lighthouse@12.x"
  ],
  "triage_model": "claude-sonnet-4.7",
  "wcag_target": "2.2-AA",
  "at_testing_cadence": "monthly",
  "ci_fail_on_severity": "critical",
  "audit_retention_days": 120
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ci_config_path": "x",
  "scanners": [],
  "wcag_target": "1.0"
}
]]></code>
    <note>Empty scanners; out-of-enum WCAG target; missing triage_model + AT cadence + CI fail policy.</note>
  </example>
  <forbidden>
    <pattern id="placeholder-strings">Output MUST NOT contain placeholder values listed in the validator script PLACEHOLDERS set. Reject any field whose value matches case-insensitively.</pattern>
  </forbidden>
  <reference path="scripts/validate-ai-accessibility-automation-2026.py">Validator script</reference>
</text>
