<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Research Tools Selection Map Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact this methodology produces. Validator enforces required fields + per-field constraints. Forbidden patterns listed at end.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-research-tools.json",
  "type": "object",
  "required": [
    "research_question",
    "evidence_type",
    "tool_choice",
    "tool_alternatives_considered",
    "citations"
  ],
  "properties": {
    "research_question": {
      "type": "string",
      "minLength": 10
    },
    "evidence_type": {
      "enum": [
        "market_data",
        "scientific_claim",
        "opinion",
        "summary",
        "meta_analysis"
      ]
    },
    "tool_choice": {
      "enum": [
        "perplexity",
        "elicit",
        "consensus",
        "scite",
        "notebooklm"
      ]
    },
    "tool_alternatives_considered": {
      "type": "array",
      "minItems": 1
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "url",
          "claim"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "claim": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "research_question": "What is TAM for AI research tools 2026?",
  "evidence_type": "market_data",
  "tool_choice": "perplexity",
  "tool_alternatives_considered": [
    "consensus"
  ],
  "citations": [
    {
      "url": "https://example.com/report",
      "claim": "TAM = $X by 2026"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "research_question": "?",
  "evidence_type": "vibes"
}
]]></code>
    <note>research_question too short; evidence_type outside enum; missing tool_choice + alternatives + citations.</note>
  </example>

  <forbidden>
    <pattern id="f1">tool_choice outside the enum</pattern>
    <pattern id="f2">citations empty</pattern>
    <pattern id="f3">research_question &lt; 10 chars</pattern>
    <pattern id="f4">tool_alternatives_considered empty</pattern>
  </forbidden>

  <reference path="scripts/validate-ai-research-tools.py">Validator script (stdlib + jsonschema-style validation; --self-test included).</reference>
</text>
