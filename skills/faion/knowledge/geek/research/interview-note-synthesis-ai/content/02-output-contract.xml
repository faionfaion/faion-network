<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Assisted Interview Note Synthesis Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. Validator enforces required fields + per-field constraints. Forbidden patterns listed at end.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/interview-note-synthesis-ai.json",
  "type": "object",
  "required": [
    "research_question",
    "interview_count",
    "themes",
    "verified_by"
  ],
  "properties": {
    "research_question": {
      "type": "string",
      "minLength": 10
    },
    "interview_count": {
      "type": "integer",
      "minimum": 3
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "theme_id",
          "label",
          "confidence",
          "supporting_interviews",
          "quotes"
        ],
        "properties": {
          "theme_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "confidence": {
            "enum": [
              "H",
              "M",
              "L"
            ]
          },
          "supporting_interviews": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "quotes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "interview_id",
                "line_range",
                "text"
              ],
              "properties": {
                "interview_id": {
                  "type": "string"
                },
                "line_range": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "verified_by": {
      "type": "string",
      "minLength": 2
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "research_question": "Why do solo developers churn from faion in week 2?",
  "interview_count": 8,
  "themes": [
    {
      "theme_id": "t1",
      "label": "Auth flow friction",
      "confidence": "H",
      "supporting_interviews": [
        "i01",
        "i03",
        "i04",
        "i07"
      ],
      "quotes": [
        {
          "interview_id": "i01",
          "line_range": "L42-L48",
          "text": "I gave up after the third login redirect"
        }
      ]
    }
  ],
  "verified_by": "ruslan@faion.net"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "themes": []
}
]]></code>
    <note>Empty themes; missing research_question, interview_count, verified_by; no quote attribution.</note>
  </example>

  <forbidden>
    <pattern id="f1">themes with supporting_interviews count &lt; 1</pattern>
    <pattern id="f2">quote missing interview_id or line_range</pattern>
    <pattern id="f3">confidence outside H/M/L</pattern>
    <pattern id="f4">verified_by empty (skipping human review gate)</pattern>
  </forbidden>

  <reference path="scripts/validate-interview-note-synthesis-ai.py">Validator script (stdlib + jsonschema-style validation; --self-test included).</reference>
</text>
