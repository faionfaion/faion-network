<text id="02-output-contract" title="AI-Assisted Coding Protocol for Qualitative Data Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the playbook-step artefact this methodology produces. Validator enforces required fields + per-field constraints. Forbidden patterns listed at end.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-coding-of-qualitative-data-protocol.json",
  "type": "object",
  "required": [
    "codebook_version",
    "coded_segments",
    "kappa",
    "coders"
  ],
  "properties": {
    "codebook_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "coded_segments": {
      "type": "array",
      "minItems": 20,
      "items": {
        "type": "object",
        "required": [
          "segment_id",
          "code_ids",
          "coder",
          "timestamp"
        ],
        "properties": {
          "segment_id": {
            "type": "string"
          },
          "code_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "coder": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "kappa": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "coders": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>

