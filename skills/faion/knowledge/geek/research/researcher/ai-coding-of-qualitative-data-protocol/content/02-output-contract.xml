  <example valid="false">
    <code lang="json"><![CDATA[
{
  "codebook_version": "1",
  "coded_segments": []
}
]]></code>
    <note>codebook_version not semver; coded_segments empty (minItems=20); missing kappa, coders.</note>
  </example>

  <forbidden>
    <pattern id="f1">coded_segments.length &lt; 20</pattern>
    <pattern id="f2">kappa &lt; 0.7 reported as final</pattern>
    <pattern id="f3">coders.length &lt; 2</pattern>
    <pattern id="f4">code_ids empty per segment</pattern>
  </forbidden>

