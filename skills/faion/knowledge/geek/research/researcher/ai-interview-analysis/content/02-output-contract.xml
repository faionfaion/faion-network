<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Assisted Single-Interview Analysis Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. Validator enforces required fields + per-field constraints. Forbidden patterns listed at end.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-interview-analysis.json",
  "type": "object",
  "required": [
    "interview_id",
    "highlights",
    "codes",
    "contradictions",
    "follow_up_questions",
    "verified_by"
  ],
  "properties": {
    "interview_id": {
      "type": "string"
    },
    "highlights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "text",
          "line_range_start",
          "line_range_end"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "line_range_start": {
            "type": "integer",
            "minimum": 1
          },
          "line_range_end": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradictions": {
      "type": "array"
    },
    "follow_up_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question",
          "reason"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "verified_by": {
      "type": "string",
      "minLength": 2
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "interview_id": "i07",
  "highlights": [
    {
      "text": "I gave up after the third login redirect",
      "line_range_start": 42,
      "line_range_end": 48
    }
  ],
  "codes": [
    "pain.auth"
  ],
  "contradictions": [
    {
      "a_range": "L20-L25",
      "b_range": "L150-L155",
      "note": "Initially said auth was fine, later said it killed onboarding."
    }
  ],
  "follow_up_questions": [
    {
      "question": "What changed your mind about auth between minute 5 and minute 45?",
      "reason": "Probes L20-L25 vs L150-L155 contradiction."
    }
  ],
  "verified_by": "ruslan@faion.net"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "interview_id": "x"
}
]]></code>
    <note>Missing highlights/codes/contradictions/follow_up_questions/verified_by.</note>
  </example>

  <forbidden>
    <pattern id="f1">highlights with line_range_start &gt; line_range_end</pattern>
    <pattern id="f2">follow_up_questions without reason</pattern>
    <pattern id="f3">contradictions present but unrelated to interview lines</pattern>
    <pattern id="f4">verified_by empty</pattern>
  </forbidden>

  <reference path="scripts/validate-ai-interview-analysis.py">Validator script (stdlib + jsonschema-style validation; --self-test included).</reference>
</text>
