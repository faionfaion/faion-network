<text id="02-output-contract" title="Ev For Fixed Bid Outsource — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of the artefact produced by ev-for-fixed-bid-outsource. Subagent must satisfy this contract before returning.</summary>
  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://ev-for-fixed-bid-outsource/output.schema.json",
  "type": "object",
  "required": ["header", "body", "evidence", "decisions"],
  "properties": {
    "header": {
      "type": "object",
      "required": ["version", "owner", "last_reviewed"],
      "properties": {
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "owner": {"type": "string", "minLength": 3},
        "last_reviewed": {"type": "string", "format": "date"}
      }
    },
    "body": {"type": "object", "minProperties": 1},
    "evidence": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "decisions": {
      "type": "object",
      "required": ["next_actions", "next_review"],
      "properties": {
        "next_actions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "next_review": {"type": "string", "format": "date"}
      }
    }
  }
}
]]></code>
  </section>
  <section title="Required fields">
    <list>
      <item>header.version (semver)</item>
      <item>header.owner (named person, not team)</item>
      <item>header.last_reviewed (ISO date, ≤6 months stale)</item>
      <item>body filled with methodology-specific structured output</item>
      <item>evidence ≥1 link, ticket, or measurement id</item>
      <item>decisions.next_actions ≥1 + decisions.next_review ISO date</item>
    </list>
  </section>
  <section title="Forbidden patterns">
    <antipattern>
      <description>artefact produced without evidence or owner</description>
      <reason>Anonymous artefacts decay into folklore.</reason>
    </antipattern>
    <antipattern>
      <description>body free-form prose without the methodology-specific structured fields</description>
      <reason>Free-form output cannot be validated or diffed across cycles.</reason>
    </antipattern>
    <antipattern>
      <description>decisions block omitted or empty</description>
      <reason>Artefacts without next-actions are reading material, not operating tools.</reason>
    </antipattern>
  </section>
  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "header": {"version": "1.0.0", "owner": "pm:alice", "last_reviewed": "2026-05-22"},
  "body": {"status": "complete", "metrics": {"score": 4}},
  "evidence": ["https://tracker.example.com/issue/123"],
  "decisions": {"next_actions": ["ship change"], "next_review": "2026-11-22"}
}
]]></code>
    </example>
  </section>
  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"header": {"owner": "team"}, "body": {}, "evidence": [], "decisions": {}}
]]></code>
      <note>Invalid: missing version/last_reviewed; owner is a team; body empty; evidence empty; decisions empty.</note>
    </example>
  </section>
  <section title="Self-check checklist">
    <list>
      <item>header carries version + owner + last_reviewed</item>
      <item>body has the methodology-specific structured fields filled</item>
      <item>evidence ≥1 link or ticket id</item>
      <item>decisions block with next_actions + next_review</item>
      <item>artefact validates against the JSON Schema above</item>
    </list>
  </section>
</text>
