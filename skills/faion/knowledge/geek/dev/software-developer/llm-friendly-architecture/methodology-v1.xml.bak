<methodology slug="llm-friendly-architecture">
  <metadata>
    <tier>geek</tier>
    <group>dev</group>
    <domain>software-developer</domain>
    <summary>Architecture patterns keeping source files 100-300 lines, flat structure, self-documenting names, explicit imports — designed to reduce LLM edit errors from large files and hidden imports.</summary>
    <tags>
