{
    "hooks": {
        "PostToolUse": [
            {
                "type": "command",
                "command": "bash ~/.claude/hooks/post-edit-format.sh",
                "matcher": "Edit",
                "timeout": 10000
            },
            {
                "type": "command",
                "command": "bash ~/.claude/hooks/post-edit-format.sh",
                "matcher": "Write",
                "timeout": 10000
            }
        ],
        "PreToolUse": [
            {
                "type": "command",
                "command": "bash ~/.claude/hooks/pre-bash-safety.sh",
                "matcher": "Bash",
                "timeout": 5000
            }
        ],
        "UserPromptSubmit": [
            {
                "type": "command",
                "command": "bash ~/.claude/hooks/tmux-save.sh",
                "timeout": 5000
            }
        ],
        "SubagentStart": [
            {
                "type": "command",
                "command": "bash ~/.claude/hooks/tmux-save.sh",
                "timeout": 5000
            }
        ]
    }
}
