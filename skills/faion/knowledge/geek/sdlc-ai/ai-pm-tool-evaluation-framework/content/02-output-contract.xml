<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI PM Tool Evaluation Framework Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for ai-pm-tool-evaluation-framework output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-pm-tool-evaluation-framework.json",
  "type": "object",
  "required": [
    "vendor",
    "scores",
    "weighted_total",
    "threshold_failures",
    "verdict"
  ],
  "properties": {
    "vendor": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 5
      }
    },
    "weighted_total": {
      "type": "number"
    },
    "threshold_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "enum": [
        "recommended",
        "conditional",
        "rejected",
        "skipped"
      ]
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "vendor": "AcmePM AI",
  "scores": {
    "data_residency": 5,
    "hallucination_rate": 4,
    "tracker_fidelity": 5,
    "cost": 3,
    "export_rights": 4,
    "prompt_injection": 4,
    "audit_log": 5,
    "integration_depth": 3
  },
  "weighted_total": 4.0,
  "threshold_failures": [],
  "verdict": "recommended"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "vendor": "AcmePM AI",
  "verdict": "good"
}
    ]]></code>
    <note>Missing required `scores`, `weighted_total`, `threshold_failures`; `verdict` value `good` not in enum.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-ai-pm-tool-evaluation-framework.py">Validator script</reference>
</text>
