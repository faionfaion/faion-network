<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Auto-Draft Postmortem, No Auto-Publish Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>6-step procedure to apply inc-postmortem-auto-draft-no-publish end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="collect-artifacts">
      <input>PD + Slack + dashboards + PRs</input>
      <action>Pull incident channel archive, PD timeline, dashboards URLs, related PRs.</action>
      <output>Artifact bundle</output>
    </step>
    <step n="2" name="synthesise-timeline">
      <input>Bundle</input>
      <action>Build chronological timeline with evidence URLs.</action>
      <output>Timeline</output>
    </step>
    <step n="3" name="propose-factors">
      <input>Timeline + service catalog</input>
      <action>Generate ≥3 candidate contributing factors with confidence scores.</action>
      <output>Candidate list</output>
    </step>
    <step n="4" name="propose-actions">
      <input>Factors</input>
      <action>Generate ≥1 action item placeholder per factor (no owner).</action>
      <output>Placeholders</output>
    </step>
    <step n="5" name="language-scan">
      <input>Draft</input>
      <action>Flag blame-language candidates without rewriting.</action>
      <output>Flag list</output>
    </step>
    <step n="6" name="emit-draft">
      <input>All sections</input>
      <action>Write to `docs/postmortems/inc-...-draft.md`; emit JSON metadata.</action>
      <output>Draft + JSON</output>
    </step>
  </section>
</text>
