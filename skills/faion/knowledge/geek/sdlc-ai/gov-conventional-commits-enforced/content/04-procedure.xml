<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Conventional Commits Enforced at the Hook Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>5-step procedure to apply gov-conventional-commits-enforced end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="install-hook">
      <input>Hook tool of choice</input>
      <action>Add lefthook/husky/pre-commit config running `commitlint --edit $1`.</action>
      <output>Hook installed</output>
    </step>
    <step n="2" name="pin-types">
      <input>commitlint config</input>
      <action>Configure type-enum + subject rules per spec.</action>
      <output>commitlint.config.cjs</output>
    </step>
    <step n="3" name="install-ci-check">
      <input>GitHub Actions / GitLab CI</input>
      <action>Add PR-title commitlint job.</action>
      <output>CI job</output>
    </step>
    <step n="4" name="wire-release-tool">
      <input>release-please / semantic-release / changesets</input>
      <action>Configure tool to read Conventional Commits and derive bumps.</action>
      <output>Release config</output>
    </step>
    <step n="5" name="validate">
      <input>Test PR</input>
      <action>Open PR with bad subject; confirm hook + CI both reject.</action>
      <output>Pass/fail</output>
    </step>
  </section>
</text>
