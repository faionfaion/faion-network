<text id="06-decision-tree" title="TypeScript Strict + isolatedDeclarations + Project References Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the project TypeScript AND does AI generate code that lands in the repo?</root-question>

      <branch when="project_is_typescript == false">
        <conclusion ref="skip-this-methodology" verdict="not TypeScript"/>
      </branch>
      <branch when="strict == false">
        <conclusion ref="strict-true-required" verdict="reject: strict disabled"/>
      </branch>
      <branch when="noUncheckedIndexedAccess == false">
        <conclusion ref="no-unchecked-index" verdict="reject: unchecked indexing allowed"/>
      </branch>
      <branch when="exactOptionalPropertyTypes == false">
        <conclusion ref="exact-optional-property-types" verdict="reject: optional/undefined ambiguous"/>
      </branch>
      <branch when="is_library AND isolatedDeclarations == false">
        <conclusion ref="isolated-declarations-libs" verdict="reject: lib without isolated declarations"/>
      </branch>
      <branch when="is_monorepo AND composite_or_refs_missing == true">
        <conclusion ref="composite-and-refs" verdict="reject: missing project references"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="composite-and-refs" verdict="accept: tsconfig family valid"/>
      </branch>

  </decision-tree>

  <example trace="ts-strict-isolated-happy-path">
    Monorepo @acme/* → tsconfig.base.json strict+unchecked+exact → @acme/web extends base + composite + refs [&apos;../core&apos;] → Biome emits .d.ts.
  </example>
</text>
