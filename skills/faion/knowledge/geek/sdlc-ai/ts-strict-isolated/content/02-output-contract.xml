<text id="02-output-contract" title="TypeScript Strict + isolatedDeclarations + Project References Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-ts-strict-isolated.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ts-strict-isolated.json",
  "title": "TSConfigFamily",
  "type": "object",
  "required": [
    "base_path",
    "strict",
    "no_unchecked_indexed_access",
    "exact_optional_property_types",
    "libraries"
  ],
  "properties": {
    "base_path": {
      "type": "string"
    },
    "strict": {
      "type": "boolean",
      "const": true
    },
    "no_unchecked_indexed_access": {
      "type": "boolean",
      "const": true
    },
    "exact_optional_property_types": {
      "type": "boolean",
      "const": true
    },
    "libraries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "isolated_declarations",
          "composite"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "isolated_declarations": {
            "type": "boolean",
            "const": true
          },
          "composite": {
            "type": "boolean",
            "const": true
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "base_path": "tsconfig.base.json",
  "strict": true,
  "no_unchecked_indexed_access": true,
  "exact_optional_property_types": true,
  "libraries": [
    {
      "path": "packages/core/tsconfig.json",
      "isolated_declarations": true,
      "composite": true,
      "references": []
    },
    {
      "path": "packages/web/tsconfig.json",
      "isolated_declarations": true,
      "composite": true,
      "references": [
        "../core"
      ]
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "base_path": "tsconfig.json",
  "strict": false,
  "no_unchecked_indexed_access": false,
  "exact_optional_property_types": false,
  "libraries": [
    {
      "path": "packages/web/tsconfig.json",
      "isolated_declarations": false,
      "composite": false
    }
  ]
}
]]></code>
    <note>Strict flags off; libs missing isolatedDeclarations + composite.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">strict == false</pattern>
      <pattern id="f2">noUncheckedIndexedAccess == false</pattern>
      <pattern id="f3">exactOptionalPropertyTypes == false</pattern>
      <pattern id="f4">library composite == false (in monorepo)</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-ts-strict-isolated.py">Validator script enforcing this contract.</reference>
</text>
