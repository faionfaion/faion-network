<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Linear Agent as First-Class Assignee Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-tracker-linear-agent-as-assignee.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/tracker-linear-agent-as-assignee.json",
  "title": "LinearAgentDelegation",
  "type": "object",
  "required": [
    "agent_identity",
    "vendor",
    "issue_id",
    "human_owner",
    "task_list_comment_id",
    "checkpoint_interval_minutes",
    "transitioned_to"
  ],
  "properties": {
    "agent_identity": {
      "type": "string",
      "pattern": "^agent-[a-z0-9-]+$"
    },
    "vendor": {
      "enum": [
        "cursor",
        "devin",
        "claude-code",
        "copilot",
        "other"
      ]
    },
    "issue_id": {
      "type": "string"
    },
    "human_owner": {
      "type": "string"
    },
    "task_list_comment_id": {
      "type": "string"
    },
    "checkpoint_interval_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 30
    },
    "final_pr_link": {
      "type": "string",
      "format": "uri"
    },
    "transitioned_to": {
      "enum": [
        "In Progress",
        "In Review"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "agent_identity": "agent-cursor",
  "vendor": "cursor",
  "issue_id": "ENG-4521",
  "human_owner": "alice",
  "task_list_comment_id": "cmt-99",
  "checkpoint_interval_minutes": 15,
  "final_pr_link": "https://github.com/org/repo/pull/4530",
  "transitioned_to": "In Review"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "agent_identity": "bot",
  "vendor": "cursor",
  "issue_id": "ENG-4521",
  "human_owner": "alice",
  "task_list_comment_id": "",
  "checkpoint_interval_minutes": 90,
  "transitioned_to": "Done"
}
]]></code>
    <note>Shared `bot` identity; missing task list comment; checkpoint interval too long; agent transitioned to Done (human&apos;s slot).</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">agent_identity == bot (shared account)</pattern>
      <pattern id="f2">transitioned_to == Done (agent owns up to In Review only)</pattern>
      <pattern id="f3">checkpoint_interval_minutes &gt; 30</pattern>
      <pattern id="f4">task_list_comment_id empty for assigned issue</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-tracker-linear-agent-as-assignee.py">Validator script enforcing this contract.</reference>
</text>
