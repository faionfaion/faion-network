<text id="06-decision-tree" title="Golden-Master Corpus for AI-Driven Legacy Rewrites Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the legacy module ≥ 500 LoC AND does production traffic or fixtures exist?</root-question>

      <branch when="loc &lt; 500 OR no_traffic_source == true">
        <conclusion ref="skip-this-methodology" verdict="module too small or no inputs to capture"/>
      </branch>
      <branch when="pair_count &lt; 10">
        <conclusion ref="sampling-from-production" verdict="reject: corpus too thin"/>
      </branch>
      <branch when="non_determinism_present AND canonicalize_fn_missing == true">
        <conclusion ref="canonicalize-non-determinism" verdict="reject: unhandled non-determinism"/>
      </branch>
      <branch when="pass_criterion == fuzzy_or_soft">
        <conclusion ref="byte-for-byte-default" verdict="reject: soft equality"/>
      </branch>
      <branch when="diff_approval_in_bulk == true">
        <conclusion ref="diff-row-approval" verdict="reject: row-by-row approval missing"/>
      </branch>
      <branch when="corpus_in_git == false">
        <conclusion ref="corpus-committed" verdict="reject: corpus uncommitted"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="byte-for-byte-default" verdict="accept: rewrite gated by corpus"/>
      </branch>

  </decision-tree>

  <example trace="test-golden-master-legacy-rewrite-happy-path">
    5000-LoC `pricing.py` → 1200-pair corpus → agent rewrite → 3 diffs flagged → 3 rows approved → CI green.
  </example>
</text>
