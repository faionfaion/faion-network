{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodeChunk",
  "description": "One symbol-boundary chunk for codebase RAG.",
  "type": "object",
  "required": ["path", "symbol", "kind", "signature", "start_line", "end_line", "sha", "body"],
  "additionalProperties": false,
  "properties": {
    "path": {
      "type": "string",
      "description": "Repo-root-relative file path."
    },
    "symbol": {
      "type": "string",
      "description": "Fully-qualified symbol name (Class.method, module.function)."
    },
    "kind": {
      "type": "string",
      "enum": ["function", "method", "class", "interface", "type_alias", "constant"]
    },
    "signature": {
      "type": "string",
      "description": "Single-line declaration (def..., class..., interface...)."
    },
    "start_line": { "type": "integer", "minimum": 1 },
    "end_line":   { "type": "integer", "minimum": 1 },
    "sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{12,64}$",
      "description": "sha256 of the symbol body; dedupe and re-embed key."
    },
    "body": {
      "type": "string",
      "description": "Verbatim source plus path/signature/doc-comment padding."
    },
    "language": {
      "type": "string",
      "description": "tree-sitter language id (python, typescript, go, ...)."
    }
  }
}
