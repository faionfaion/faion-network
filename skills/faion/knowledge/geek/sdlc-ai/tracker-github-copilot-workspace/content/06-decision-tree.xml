<text id="06-decision-tree" title="GitHub Copilot Workspace Four-Gate Pipeline Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the repo on GitHub with Copilot Workspace enabled AND is the change non-trivial (&gt; 1 file OR &gt; 50 LoC)?</root-question>

      <branch when="github_workspace_available == false">
        <conclusion ref="skip-this-methodology" verdict="wrong runtime for this methodology"/>
      </branch>
      <branch when="loc_changed &lt;= 50 AND files_changed &lt;= 1 AND pr_prefix == trivial">
        <conclusion ref="workspace-only-for-non-trivial" verdict="trivial path — bypass allowed"/>
      </branch>
      <branch when="gates_passed missing spec/plan/diff/pr">
        <conclusion ref="four-gates-required" verdict="reject: skipped gate"/>
      </branch>
      <branch when="human_edited_at empty">
        <conclusion ref="human-edit-each-gate" verdict="reject: rubber-stamp pipeline"/>
      </branch>
      <branch when="snapshot_url missing">
        <conclusion ref="snapshot-link-in-pr" verdict="reject: review artifacts missing"/>
      </branch>
      <branch when="agent_pr_without_workspace_metadata == true">
        <conclusion ref="issue-to-diff-aborts" verdict="reject: bypassed Workspace"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="snapshot-link-in-pr" verdict="accept: Workspace pipeline complete"/>
      </branch>

  </decision-tree>

  <example trace="tracker-github-copilot-workspace-happy-path">
    Issue #4521 → spec edited → plan edited → diff reviewed → PR #4530 with Workspace snapshot link.
  </example>
</text>
