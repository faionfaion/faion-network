<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitHub Copilot Workspace Four-Gate Pipeline Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the playbook-step artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-tracker-github-copilot-workspace.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/tracker-github-copilot-workspace.json",
  "title": "WorkspacePRArtifacts",
  "type": "object",
  "required": [
    "issue_url",
    "spec_snapshot_url",
    "plan_snapshot_url",
    "diff_url",
    "pr_url",
    "gates_passed",
    "human_edited_at"
  ],
  "properties": {
    "issue_url": {
      "type": "string",
      "format": "uri"
    },
    "spec_snapshot_url": {
      "type": "string",
      "format": "uri"
    },
    "plan_snapshot_url": {
      "type": "string",
      "format": "uri"
    },
    "diff_url": {
      "type": "string",
      "format": "uri"
    },
    "pr_url": {
      "type": "string",
      "format": "uri"
    },
    "gates_passed": {
      "type": "array",
      "items": {
        "enum": [
          "spec",
          "plan",
          "diff",
          "pr"
        ]
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "human_edited_at": {
      "type": "array",
      "items": {
        "enum": [
          "spec",
          "plan",
          "diff"
        ]
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "issue_url": "https://github.com/org/repo/issues/4521",
  "spec_snapshot_url": "https://github.com/copilot/workspaces/abc#spec",
  "plan_snapshot_url": "https://github.com/copilot/workspaces/abc#plan",
  "diff_url": "https://github.com/copilot/workspaces/abc#diff",
  "pr_url": "https://github.com/org/repo/pull/4530",
  "gates_passed": [
    "spec",
    "plan",
    "diff",
    "pr"
  ],
  "human_edited_at": [
    "spec",
    "plan"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "issue_url": "https://github.com/org/repo/issues/4521",
  "pr_url": "https://github.com/org/repo/pull/4530",
  "gates_passed": [
    "diff"
  ],
  "human_edited_at": []
}
]]></code>
    <note>Missing spec/plan/diff snapshots; gates_passed incomplete; no human edits recorded.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">gates_passed missing any of {spec, plan, diff, pr}</pattern>
      <pattern id="f2">snapshot_url missing while pr_url present</pattern>
      <pattern id="f3">human_edited_at empty (rubber-stamp pipeline)</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-tracker-github-copilot-workspace.py">Validator script enforcing this contract.</reference>
</text>
