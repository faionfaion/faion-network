<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Jira via Atlassian Rovo MCP, Permission-Inheriting Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-tracker-jira-rovo-mcp-agents.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/tracker-jira-rovo-mcp-agents.json",
  "title": "RovoMCPConfig",
  "type": "object",
  "required": [
    "rovo_mcp_url",
    "ai_clients",
    "permission_inheritance",
    "native_audit_log",
    "single_installation",
    "scope_projects"
  ],
  "properties": {
    "rovo_mcp_url": {
      "type": "string",
      "format": "uri"
    },
    "ai_clients": {
      "type": "array",
      "items": {
        "enum": [
          "claude-code",
          "cursor",
          "codex",
          "claude-desktop",
          "other"
        ]
      },
      "minItems": 1
    },
    "permission_inheritance": {
      "type": "boolean",
      "const": true
    },
    "native_audit_log": {
      "type": "boolean",
      "const": true
    },
    "single_installation": {
      "type": "boolean",
      "const": true
    },
    "scope_projects": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "rovo_mcp_url": "https://acme.atlassian.net/rovo/mcp",
  "ai_clients": [
    "claude-code",
    "cursor"
  ],
  "permission_inheritance": true,
  "native_audit_log": true,
  "single_installation": true,
  "scope_projects": [
    "PROJ",
    "DEVOPS"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "rovo_mcp_url": "https://acme.atlassian.net/rovo/mcp",
  "ai_clients": [],
  "permission_inheritance": false,
  "native_audit_log": false,
  "single_installation": false,
  "scope_projects": []
}
]]></code>
    <note>Empty ai_clients; inheritance off; audit log off; multiple installations; empty project scope.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">permission_inheritance == false</pattern>
      <pattern id="f2">native_audit_log == false</pattern>
      <pattern id="f3">single_installation == false</pattern>
      <pattern id="f4">scope_projects empty</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-tracker-jira-rovo-mcp-agents.py">Validator script enforcing this contract.</reference>
</text>
