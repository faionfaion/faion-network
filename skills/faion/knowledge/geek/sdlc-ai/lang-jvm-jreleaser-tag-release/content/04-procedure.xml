<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="JVM One-Tag Release via JReleaser Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="author-jreleaser-yml">
      <input>Distribution list</input>
      <action>Author jreleaser.yml with maven-central + github + signing.</action>
      <output>config committed</output>
    </step>
    <step n="2" name="configure-ci-secrets">
      <input>CI vault</input>
      <action>Add JRELEASER_GPG_PASSPHRASE, JRELEASER_MAVENCENTRAL_USERNAME / PASSWORD, JRELEASER_GITHUB_TOKEN.</action>
      <output>secrets ready</output>
    </step>
    <step n="3" name="wire-tag-workflow">
      <input>GH Actions</input>
      <action>Add tag-triggered workflow that runs `jreleaser full-release`.</action>
      <output>workflow live</output>
    </step>
    <step n="4" name="dry-run">
      <input>Tag candidate</input>
      <action>Run `jreleaser config --output yaml` then `jreleaser release --dry-run`.</action>
      <output>dry-run green; ready to tag</output>
    </step>

  </section>
</text>
