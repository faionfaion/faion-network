<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MegaLinter as the Polyglot Quality Umbrella in CI Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lint-megalinter-polyglot.json",
  "type": "object",
  "required": [
    "mega_linter_yml",
    "flavour",
    "image_sha",
    "sarif_upload",
    "languages_count"
  ],
  "properties": {
    "mega_linter_yml": {
      "type": "string"
    },
    "flavour": {
      "enum": [
        "all",
        "ci_light",
        "cupcake",
        "documentation",
        "dotnet",
        "go",
        "java",
        "javascript",
        "python",
        "ruby",
        "rust",
        "salesforce",
        "security",
        "swift",
        "terraform"
      ]
    },
    "image_sha": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sarif_upload": {
      "const": true
    },
    "languages_count": {
      "type": "integer",
      "minimum": 3
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "mega_linter_yml": ".mega-linter.yml",
  "flavour": "all",
  "image_sha": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
  "sarif_upload": true,
  "languages_count": 5
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "mega_linter_yml": ".mega-linter.yml",
  "flavour": "ci_light",
  "image_sha": "latest",
  "sarif_upload": false,
  "languages_count": 1
}
]]></code>
    <note>image_sha must be sha256:; sarif_upload must be True; languages_count &lt; 3.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">image_sha not pinned (using :latest)</pattern>
    <pattern id="f2">sarif_upload == false</pattern>
    <pattern id="f3">Per-language linter job NOT removed when MegaLinter adopted (duplication)</pattern>
  </section>

  <reference path="scripts/validate-megalinter-polyglot.py">Validator script</reference>
</text>
