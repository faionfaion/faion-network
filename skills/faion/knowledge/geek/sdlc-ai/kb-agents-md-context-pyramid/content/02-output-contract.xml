<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AGENTS.md Context Pyramid Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for kb-agents-md-context-pyramid output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/kb-agents-md-context-pyramid.json",
  "type": "object",
  "required": [
    "repo_root",
    "root_agents_md_line_count",
    "per_directory_coverage_pct",
    "violations",
    "audit_passed"
  ],
  "properties": {
    "repo_root": {
      "type": "string"
    },
    "root_agents_md_line_count": {
      "type": "integer",
      "maximum": 80
    },
    "per_directory_coverage_pct": {
      "type": "number",
      "minimum": 95
    },
    "violations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/violation"
      }
    },
    "audit_passed": {
      "type": "boolean"
    }
  },
  "$defs": {
    "violation": {
      "type": "object",
      "required": [
        "path",
        "category"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "category": {
          "enum": [
            "missing-agents-md",
            "too-long",
            "contains-tbd",
            "broken-link",
            "missing-claude-md"
          ]
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "repo_root": ".",
  "root_agents_md_line_count": 67,
  "per_directory_coverage_pct": 98,
  "violations": [
    {"path": "src/legacy/", "category": "missing-agents-md", "detail": "Add AGENTS.md or mark dir as empty"}
  ],
  "audit_passed": false
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "root_agents_md_line_count": 250,
  "per_directory_coverage_pct": 40
}
    ]]></code>
    <note>root file too long; coverage below 95%; required repo_root, violations, audit_passed missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-kb-agents-md-context-pyramid.py">Validator script</reference>
</text>
