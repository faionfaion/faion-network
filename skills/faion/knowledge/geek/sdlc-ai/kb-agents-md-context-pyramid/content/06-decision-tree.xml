<text id="06-decision-tree" title="AGENTS.md Context Pyramid Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml for kb-agents-md-context-pyramid.</summary>
  <decision-tree>
    <root-question id="q-root">Is the project multi-directory and used by AI agents?</root-question>
    <branch when="single_dir == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="different_convention_in_use == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="root_agents_md_over_80 == true">
      <conclusion ref="root-agents-md-short"/>
    </branch>
    <branch when="per_dir_coverage_below_95 == true">
      <conclusion ref="per-directory-agents-md"/>
    </branch>
    <branch when="claude_md_has_content == true">
      <conclusion ref="claude-md-points-to-agents-md"/>
    </branch>
    <branch when="deep_docs_in_agents_md == true">
      <conclusion ref="agents-dot-dir-on-demand"/>
    </branch>
    <branch when="sdd_docs_in_agents_md == true">
      <conclusion ref="aidocs-for-sdd-lifecycle"/>
    </branch>
    <branch when="audit_script_missing == true">
      <conclusion ref="audit-script-pre-commit"/>
    </branch>
  </decision-tree>
  <example trace="Audit run on monorepo → root AGENTS.md 67 lines (ok) → per-dir coverage 98% (ok) → src/legacy/ missing AGENTS.md → violation logged → engineer adds skeleton → re-audit passes."/>
</text>
