<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="AGENTS.md Context Pyramid Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>6-step procedure to apply kb-agents-md-context-pyramid end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="inventory-dirs">
      <input>Repo file tree</input>
      <action>List directories with source code.</action>
      <output>Directory list</output>
    </step>
    <step n="2" name="scaffold-agents-md">
      <input>Template + dir list</input>
      <action>Generate AGENTS.md skeleton per directory.</action>
      <output>Skeletons</output>
    </step>
    <step n="3" name="write-content">
      <input>Skeletons + domain knowledge</input>
      <action>Fill each AGENTS.md with what-this-dir-is + file table + key types.</action>
      <output>Filled files</output>
    </step>
    <step n="4" name="link-claude-md">
      <input>Per directory</input>
      <action>Add `CLAUDE.md` containing only `@AGENTS.md`.</action>
      <output>CLAUDE.md per dir</output>
    </step>
    <step n="5" name="audit">
      <input>Audit script</input>
      <action>Run audit; fix violations.</action>
      <output>Audit report</output>
    </step>
    <step n="6" name="install-pre-commit">
      <input>Hook config</input>
      <action>Wire audit script as pre-commit; block commits with violations.</action>
      <output>Hook config</output>
    </step>
  </section>
</text>
