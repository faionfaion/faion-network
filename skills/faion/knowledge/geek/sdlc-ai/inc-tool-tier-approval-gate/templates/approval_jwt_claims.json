{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentApprovalJWT",
  "description": "Canonical claim set for an SRE-agent destructive-action approval token.",
  "type": "object",
  "required": ["sub", "tool", "target", "incident_id", "iat", "exp", "jti"],
  "additionalProperties": false,
  "properties": {
    "sub":         { "type": "string", "format": "email" },
    "tool":        { "type": "string", "minLength": 1 },
    "target":      { "type": "string", "minLength": 1 },
    "incident_id": { "type": "string", "pattern": "^INC-[0-9]{4}-[0-9]{4}-[0-9]{3}$" },
    "iat":         { "type": "integer" },
    "exp":         { "type": "integer" },
    "jti":         { "type": "string", "minLength": 16 },
    "iss":         { "type": "string", "format": "uri" },
    "aud":         { "type": "string", "minLength": 1 }
  }
}
