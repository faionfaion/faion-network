<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Alert Triage Decision Tree Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for alert-triage-decision-tree output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/alert-triage-decision-tree.json",
  "type": "object",
  "required": [
    "alert_id",
    "severity",
    "blast_radius",
    "route",
    "owner",
    "sla_minutes",
    "audit_reason"
  ],
  "properties": {
    "alert_id": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "p0",
        "p1",
        "p2",
        "p3"
      ]
    },
    "blast_radius": {
      "enum": [
        "single-user",
        "single-tenant",
        "cohort",
        "global"
      ]
    },
    "route": {
      "enum": [
        "page",
        "async-ticket",
        "auto-suppress"
      ]
    },
    "owner": {
      "type": "string"
    },
    "sla_minutes": {
      "type": "integer",
      "minimum": 0
    },
    "audit_reason": {
      "type": "string"
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "alert_id": "alm-2026-05-22-0001",
  "severity": "p1",
  "blast_radius": "cohort",
  "route": "page",
  "owner": "payments-oncall",
  "sla_minutes": 15,
  "audit_reason": "error_rate=4.2% > threshold 1% across 12% of tenants for >5 min"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "alert_id": "alm-2026-05-22-0001",
  "severity": "high"
}
    ]]></code>
    <note>`severity` value `high` not in enum (use p0-p3); required `blast_radius`, `route`, `owner`, `sla_minutes`, `audit_reason` missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-alert-triage-decision-tree.py">Validator script</reference>
</text>
