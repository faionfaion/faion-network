<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Team Mode CLI Flag (`--team-config` Overlay) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-team-mode-cli-flag.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/team-mode-cli-flag.json",
  "title": "TeamConfigOverlay",
  "type": "object",
  "required": [
    "version",
    "last_reviewed",
    "signed_by",
    "signature",
    "overrides"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "signed_by": {
      "type": "string"
    },
    "signature": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/=]{40,}$"
    },
    "overrides": {
      "type": "object",
      "minProperties": 1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "version": "1.2.0",
  "last_reviewed": "2026-05-10",
  "signed_by": "ops@acme.com",
  "signature": "MEUCIQDxAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
  "overrides": {
    "model_whitelist": [
      "claude-opus",
      "claude-sonnet"
    ],
    "mcp_allowlist": [
      "pact",
      "github"
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "1.2",
  "signed_by": "we",
  "overrides": {}
}
]]></code>
    <note>Version not semver; signed_by is plural; signature missing; overrides empty; last_reviewed missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">signed_by ∈ {team, we, all, anyone}</pattern>
      <pattern id="f2">signature absent or shorter than 40 chars</pattern>
      <pattern id="f3">overrides empty (overlay with no overrides is meaningless)</pattern>
      <pattern id="f4">last_reviewed older than 90 days without explicit acknowledgement</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-team-mode-cli-flag.py">Validator script enforcing this contract.</reference>
</text>
