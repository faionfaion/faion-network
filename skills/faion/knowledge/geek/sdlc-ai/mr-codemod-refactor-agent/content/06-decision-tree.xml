<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Codemod-First Refactor Agent Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">sites_touched?</root-question>

    <branch when="sites &lt; 5">
      <conclusion ref="skip-this-methodology" verdict="hand-edit"/>
    </branch>
    <branch when="sites &gt;= 5">
      <question id="q-2">ast_tool_available?</question>
        <branch when="ast_available == false">
          <conclusion ref="skip-this-methodology" verdict="hand-edit + PR template"/>
        </branch>
        <branch when="ast_available == true">
          <question id="q-4">semantic_judgement_required_per_site?</question>
            <branch when="semantic == true">
              <conclusion ref="skip-this-methodology" verdict="hand-edit"/>
            </branch>
            <branch when="semantic == false">
              <conclusion ref="codemod-first" verdict="codemod + 2-agent"/>
            </branch>
        </branch>
    </branch>

  </decision-tree>

  <example trace="sites=142 → ast_available=true (jscodeshift) → semantic=false → codemod-first → batched + reviewed">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
