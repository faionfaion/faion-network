<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Role Cheatsheet Generator Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema (draft-07) for the generated cheatsheet artefact, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/role-cheatsheet-generator.json",
  "type": "object",
  "required": ["corpus_version", "role", "tier", "top_n", "entries", "overrides_merged"],
  "properties": {
    "corpus_version": {"type": "string"},
    "role": {"type": "string"},
    "tier": {"enum": ["free", "solo", "pro", "geek"]},
    "top_n": {"type": "integer", "minimum": 1, "maximum": 10},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["rank", "slug", "tier", "priority_signal"],
        "properties": {
          "rank": {"type": "integer", "minimum": 1, "maximum": 10},
          "slug": {"type": "string"},
          "tier": {"enum": ["free", "solo", "pro", "geek"]},
          "priority_signal": {"type": "number"}
        }
      }
    },
    "overrides_merged": {"type": "integer", "minimum": 0, "maximum": 5}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "corpus_version": "2026-05-23",
  "role": "software-architect",
  "tier": "pro",
  "top_n": 10,
  "entries": [
    {"rank": 1, "slug": "pro/infra/greenfield-infra-decision-matrix", "tier": "pro", "priority_signal": 42},
    {"rank": 2, "slug": "pro/infra/capacity-planning-at-design-time", "tier": "pro", "priority_signal": 38}
  ],
  "overrides_merged": 2
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "corpus_version": "2026-05-23",
  "role": "software-architect",
  "tier": "pro",
  "top_n": 30,
  "entries": [
    {"rank": 1, "slug": "geek/ai/foo", "tier": "geek", "priority_signal": 99}
  ]
}
]]></code>
    <note>top_n &gt; 10; entry tier=geek above org tier=pro (tier-gate violation); missing overrides_merged.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">top_n &gt; 10</pattern>
    <pattern id="f2">entry.tier above org tier (tier-gate breach)</pattern>
    <pattern id="f3">missing corpus_version (cheatsheet not reproducible)</pattern>
  </section>

  <reference path="scripts/validate-role-cheatsheet-generator.py">Validator script</reference>
</text>
