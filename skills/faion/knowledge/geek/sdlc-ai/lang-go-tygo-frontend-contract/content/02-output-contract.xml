<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Go → TypeScript DTO Contract via tygo Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lang-go-tygo-frontend-contract.json",
  "type": "object",
  "required": [
    "tygo_yaml_path",
    "output_dir",
    "packages",
    "ci_diff_gate",
    "type_mappings"
  ],
  "properties": {
    "tygo_yaml_path": {
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "ci_diff_gate": {
      "const": true
    },
    "type_mappings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tygo_yaml_path": "tygo.yaml",
  "output_dir": "frontend/src/api-types/",
  "packages": [
    "github.com/acme/api/internal/dto"
  ],
  "ci_diff_gate": true,
  "type_mappings": {
    "time.Time": "string",
    "decimal.Decimal": "string",
    "json.RawMessage": "unknown"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tygo_yaml_path": "tygo.yaml",
  "packages": [],
  "ci_diff_gate": false,
  "type_mappings": {}
}
]]></code>
    <note>packages empty; ci_diff_gate must be True; type_mappings must be non-empty.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">ci_diff_gate == false</pattern>
    <pattern id="f2">type_mappings empty when non-primitives present in DTOs</pattern>
    <pattern id="f3">Hand-edited file inside output_dir</pattern>
  </section>

  <reference path="scripts/validate-go-tygo-frontend-contract.py">Validator script</reference>
</text>
