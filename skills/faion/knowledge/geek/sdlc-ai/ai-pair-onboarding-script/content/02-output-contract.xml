<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Pair Onboarding Script Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for ai-pair-onboarding-script output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-pair-onboarding-script.json",
  "type": "object",
  "required": [
    "agent_versions",
    "agents_md_checksum",
    "allowed_tools",
    "smoke_task_passed",
    "ready_to_pair"
  ],
  "properties": {
    "agent_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "agents_md_checksum": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "smoke_task_passed": {
      "type": "boolean"
    },
    "ready_to_pair": {
      "type": "boolean"
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "agent_versions": {"claude": "1.2.4"},
  "agents_md_checksum": "f3a4b9c0d1e2f3a4b9c0d1e2f3a4b9c0d1e2f3a4b9c0d1e2f3a4b9c0d1e2f3a4",
  "allowed_tools": ["Read", "Grep", "Glob", "Bash"],
  "smoke_task_passed": true,
  "ready_to_pair": true
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ready_to_pair": true
}
    ]]></code>
    <note>Missing every other required field; `ready_to_pair` cannot be true without supporting evidence.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-ai-pair-onboarding-script.py">Validator script</reference>
</text>
