<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pre-Commit Hooks as the Non-Negotiable Merge Floor Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lint-precommit-floor.json",
  "type": "object",
  "required": [
    "framework",
    "config_path",
    "hook_categories",
    "setup_command",
    "ci_mirror"
  ],
  "properties": {
    "framework": {
      "enum": [
        "pre-commit",
        "lefthook",
        "husky+lint-staged"
      ]
    },
    "config_path": {
      "type": "string"
    },
    "hook_categories": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": [
          "format",
          "lint",
          "secret-scan",
          "type-check",
          "iac-lint"
        ]
      },
      "contains": {
        "enum": [
          "secret-scan"
        ]
      }
    },
    "setup_command": {
      "type": "string"
    },
    "ci_mirror": {
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "framework": "pre-commit",
  "config_path": ".pre-commit-config.yaml",
  "hook_categories": [
    "format",
    "lint",
    "secret-scan",
    "type-check"
  ],
  "setup_command": "make hooks",
  "ci_mirror": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "framework": "manual",
  "config_path": "hooks.txt",
  "hook_categories": [
    "lint"
  ],
  "ci_mirror": false
}
]]></code>
    <note>framework not in enum; hook_categories &lt; 4 and missing secret-scan; ci_mirror must be True.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">framework not in {pre-commit, lefthook, husky+lint-staged}</pattern>
    <pattern id="f2">hook_categories missing &apos;secret-scan&apos;</pattern>
    <pattern id="f3">ci_mirror == false</pattern>
  </section>

  <reference path="scripts/validate-precommit-floor.py">Validator script</reference>
</text>
