<text id="06-decision-tree" title="Renovate Auto-Merge + AI Handoff Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping bump kind + version-prefix + alert source to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">repo_uses_package_manager_and_has_ci?</root-question>

    <branch when="usable == false">
      <conclusion ref="skip-this-methodology" verdict="skip — no Renovate role"/>
    </branch>
    <branch when="usable == true">
      <question id="q-2">bump_kind?</question>
        <branch when="bump_kind == security">
          <conclusion ref="vulnerability-alerts-to-agent" verdict="label agent-fixable; do not auto-merge"/>
        </branch>
        <branch when="bump_kind == major">
          <conclusion ref="never-auto-merge-major" verdict="label agent-fixable; do not auto-merge"/>
        </branch>
        <branch when="bump_kind == minor_or_patch">
          <question id="q-3">current_version_starts_with_zero?</question>
            <branch when="zero_prefix == true">
              <conclusion ref="zero-prefix-treated-as-major" verdict="treat as breaking; label agent-fixable"/>
            </branch>
            <branch when="zero_prefix == false">
              <conclusion ref="merge-confidence-gate" verdict="auto-merge if Merge-Confidence high and CI green"/>
            </branch>
        </branch>
    </branch>

  </decision-tree>

  <example trace="usable=true → bump_kind=minor_or_patch → zero_prefix=false → merge-confidence-gate → platformAutomerge waits for CI then merges">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
