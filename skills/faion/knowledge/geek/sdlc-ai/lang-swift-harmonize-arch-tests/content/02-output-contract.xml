<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Swift Architecture as Tests via Harmonize + Swift Testing Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lang-swift-harmonize-arch-tests.json",
  "type": "object",
  "required": [
    "harmonize_dep_pinned",
    "ci_runs_swift_test",
    "arch_test_files",
    "swiftlint_present"
  ],
  "properties": {
    "harmonize_dep_pinned": {
      "const": true
    },
    "ci_runs_swift_test": {
      "const": true
    },
    "arch_test_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "swiftlint_present": {
      "const": true
    },
    "swift_version": {
      "type": "string",
      "pattern": "^[5-9]\\."
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "harmonize_dep_pinned": true,
  "ci_runs_swift_test": true,
  "arch_test_files": [
    "Tests/ArchTests/LayerBoundariesTests.swift",
    "Tests/ArchTests/NamingTests.swift"
  ],
  "swiftlint_present": true,
  "swift_version": "5.9"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "harmonize_dep_pinned": false,
  "ci_runs_swift_test": false,
  "arch_test_files": []
}
]]></code>
    <note>all four required flags must be True; arch_test_files must be non-empty.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">ci_runs_swift_test == false</pattern>
    <pattern id="f2">harmonize_dep_pinned == false (drift risk)</pattern>
    <pattern id="f3">arch test file without doc comment / ADR reference</pattern>
  </section>

  <reference path="scripts/validate-swift-harmonize-arch-tests.py">Validator script</reference>
</text>
