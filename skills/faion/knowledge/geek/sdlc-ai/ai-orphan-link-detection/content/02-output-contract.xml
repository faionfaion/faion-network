<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Orphan Link Detection Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a AI Orphan Link Detection deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="detector_id" format="stable_id" />
      <field name="signal_definition" type="string" />
      <field name="threshold" type="string" />
      <field name="remediation_runbook" format="url_or_path" />
      <field name="false_positive_target" format="float_0_to_1" />
    </required>
    <forbidden>
      <pattern id="f1">detector without remediation_runbook</pattern>
      <pattern id="f2">threshold expressed in vague language</pattern>
      <pattern id="f3">false_positive_target unset</pattern>
      <pattern id="f4">detector with no last_review_date</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Adjust threshold only with reason and review-date update.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Signal + threshold concrete</item>
      <item>Remediation link reachable</item>
      <item>FP target set</item>
      <item>Last review ≤90d</item>
    </list>
  </section>
</text>
