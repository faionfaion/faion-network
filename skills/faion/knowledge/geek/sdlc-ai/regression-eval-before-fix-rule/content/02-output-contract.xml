<text id="02-output-contract" title="Regression Eval Before Fix Rule — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>A decision-rule artefact: named inputs, published thresholds, a default branch, and a per-invocation log.</summary>

  <section title="Required fields">
    <list>
      <item>rule.inputs (name + source per input)</item>
      <item>rule.thresholds (numeric or boolean)</item>
      <item>rule.default_branch (the unhappy-path action)</item>
      <item>invocation.log (timestamp + inputs + branch + decider)</item>
      <item>owner + version + last_reviewed</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>input named &apos;judgment&apos;</description>
      <reason>Unnamed inputs let bias dominate.</reason>
    </antipattern>
    <antipattern>
      <description>thresholds without numbers</description>
      <reason>Not reproducible.</reason>
    </antipattern>
    <antipattern>
      <description>no default branch</description>
      <reason>Edge cases collapse the rule.</reason>
    </antipattern>
    <antipattern>
      <description>invocations not logged</description>
      <reason>Rule cannot be reviewed against outcomes.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Inputs named with source.</item>
      <item>Thresholds carry numbers.</item>
      <item>Default branch documented.</item>
      <item>Each invocation logged with branch and decider.</item>
      <item>Owner + last_reviewed populated.</item>
    </list>
  </section>
</text>
