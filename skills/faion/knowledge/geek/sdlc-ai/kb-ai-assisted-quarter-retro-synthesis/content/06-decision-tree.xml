<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI-Assisted Multi-Squad Quarter Retro Synthesis Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">squads_count?</root-question>

    <branch when="squads_count &lt; 3">
      <conclusion ref="skip-this-methodology" verdict="skip"/>
    </branch>
    <branch when="squads_count &gt;= 3">
      <question id="q-2">dora_instrumented?</question>
        <branch when="dora_instrumented == false">
          <conclusion ref="skip-this-methodology" verdict="instrument DORA first"/>
        </branch>
        <branch when="dora_instrumented == true">
          <question id="q-4">hr_or_secret_incidents_present?</question>
            <branch when="hr_or_secret == true">
              <conclusion ref="skip-this-methodology" verdict="exclude or skip"/>
            </branch>
            <branch when="hr_or_secret == false">
              <conclusion ref="redact-before-ingest" verdict="redact, then run pipeline"/>
            </branch>
        </branch>
    </branch>

  </decision-tree>

  <example trace="squads_count=4 → dora_instrumented=true → hr=false → redact-before-ingest → run pipeline">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
