<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="TDD with Red and Green in Separate Agents Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-test-tdd-red-green-split-agents.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/test-tdd-red-green-split-agents.json",
  "title": "RedGreenSplitConfig",
  "type": "object",
  "required": [
    "red_skill_path",
    "green_skill_path",
    "red_tools_allowed",
    "green_tools_allowed",
    "tools_disjoint",
    "orchestrator_records_transition"
  ],
  "properties": {
    "red_skill_path": {
      "type": "string",
      "pattern": "\\.skill\\.md$"
    },
    "green_skill_path": {
      "type": "string",
      "pattern": "\\.skill\\.md$"
    },
    "red_tools_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "green_tools_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "tools_disjoint": {
      "type": "boolean",
      "const": true
    },
    "orchestrator_records_transition": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "red_skill_path": ".claude/skills/tdd-red.skill.md",
  "green_skill_path": ".claude/skills/tdd-green.skill.md",
  "red_tools_allowed": [
    "Read(src/)",
    "Write(tests/)",
    "Bash(pytest -q)"
  ],
  "green_tools_allowed": [
    "Read(tests/)",
    "Edit(src/)",
    "Bash(pytest -q)"
  ],
  "tools_disjoint": true,
  "orchestrator_records_transition": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "red_skill_path": "red.md",
  "green_skill_path": "green.md",
  "red_tools_allowed": [
    "Edit(src/)",
    "Write(tests/)"
  ],
  "green_tools_allowed": [
    "Edit(src/)",
    "Write(tests/)"
  ],
  "tools_disjoint": false,
  "orchestrator_records_transition": false
}
]]></code>
    <note>Tool sets overlap on Write(tests/) + Edit(src/); tools_disjoint=false; orchestrator transition not recorded.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">RED tool set contains Edit(src/) or Write(src/)</pattern>
      <pattern id="f2">GREEN tool set contains Write(tests/)</pattern>
      <pattern id="f3">tools_disjoint == false</pattern>
      <pattern id="f4">merge without orchestrator-recorded RED→GREEN transition</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-test-tdd-red-green-split-agents.py">Validator script enforcing this contract.</reference>
</text>
