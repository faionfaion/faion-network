<text id="02-output-contract" title="uv as the Python Lockfile Floor Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-uv-lockfile-floor.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/uv-lockfile-floor.json",
  "title": "UVProjectFloor",
  "type": "object",
  "required": [
    "pyproject_path",
    "requires_python",
    "uv_lock_present",
    "agents_md_snippet_present",
    "other_resolvers_absent"
  ],
  "properties": {
    "pyproject_path": {
      "type": "string",
      "pattern": "pyproject\\.toml$"
    },
    "requires_python": {
      "type": "string",
      "pattern": "^[<>=~,.\\d ]+$"
    },
    "uv_lock_present": {
      "type": "boolean",
      "const": true
    },
    "agents_md_snippet_present": {
      "type": "boolean",
      "const": true
    },
    "other_resolvers_absent": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pyproject_path": "pyproject.toml",
  "requires_python": ">=3.12,<3.13",
  "uv_lock_present": true,
  "agents_md_snippet_present": true,
  "other_resolvers_absent": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pyproject_path": "pyproject.toml",
  "requires_python": ">=3.10",
  "uv_lock_present": false,
  "agents_md_snippet_present": false,
  "other_resolvers_absent": false
}
]]></code>
    <note>Python version constraint floating; no uv.lock; no AGENTS.md snippet; other resolvers present.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">Poetry.lock / pipfile.lock / requirements.txt present beside uv.lock</pattern>
      <pattern id="f2">requires_python with only a lower bound</pattern>
      <pattern id="f3">uv.lock missing</pattern>
      <pattern id="f4">AGENTS.md missing the uv-run snippet</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-uv-lockfile-floor.py">Validator script enforcing this contract.</reference>
</text>
