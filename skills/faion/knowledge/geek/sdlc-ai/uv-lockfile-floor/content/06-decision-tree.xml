<text id="06-decision-tree" title="uv as the Python Lockfile Floor Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the project Python AND do AI agents run shell commands against it?</root-question>

      <branch when="project_python == false">
        <conclusion ref="skip-this-methodology" verdict="not Python"/>
      </branch>
      <branch when="other_resolvers_present == true">
        <conclusion ref="uv-is-the-resolver" verdict="reject: dual-resolver state"/>
      </branch>
      <branch when="uv_lock_present == false">
        <conclusion ref="lockfile-committed" verdict="reject: missing committed lockfile"/>
      </branch>
      <branch when="requires_python_floating == true">
        <conclusion ref="python-version-pinned" verdict="reject: unpinned Python version"/>
      </branch>
      <branch when="agents_md_snippet_missing == true">
        <conclusion ref="agents-md-snippet" verdict="reject: agent context missing"/>
      </branch>
      <branch when="prompt_contains_bare_pytest_or_python == true">
        <conclusion ref="uv-run-for-tools" verdict="reject: bare invocation"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="uv-run-for-tools" verdict="accept: uv floor valid"/>
      </branch>

  </decision-tree>

  <example trace="uv-lockfile-floor-happy-path">
    Python repo → uv installed → pyproject pinned to 3.12 → uv.lock committed → AGENTS.md snippet present → `uv run pytest` green.
  </example>
</text>
