<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Ruby Sorbet Strict Floor with Tapioca RBI Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lang-ruby-sorbet-strict-floor.json",
  "type": "object",
  "required": [
    "sorbet_config",
    "tapioca_rbis_committed",
    "ci_runs_srb_tc",
    "ci_runs_check_shims",
    "min_sigil_level"
  ],
  "properties": {
    "sorbet_config": {
      "type": "string"
    },
    "tapioca_rbis_committed": {
      "const": true
    },
    "ci_runs_srb_tc": {
      "const": true
    },
    "ci_runs_check_shims": {
      "const": true
    },
    "min_sigil_level": {
      "enum": [
        "true",
        "strict",
        "strong"
      ]
    },
    "untyped_justification_required": {
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "sorbet_config": "sorbet/config",
  "tapioca_rbis_committed": true,
  "ci_runs_srb_tc": true,
  "ci_runs_check_shims": true,
  "min_sigil_level": "true",
  "untyped_justification_required": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "sorbet_config": "sorbet/config",
  "tapioca_rbis_committed": false,
  "ci_runs_srb_tc": false,
  "min_sigil_level": "false"
}
]]></code>
    <note>tapioca_rbis_committed must be True; min_sigil_level not in enum; ci checks required.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">tapioca_rbis_committed == false</pattern>
    <pattern id="f2">ci_runs_check_shims == false</pattern>
    <pattern id="f3">min_sigil_level == &apos;false&apos; or &apos;ignore&apos;</pattern>
  </section>

  <reference path="scripts/validate-ruby-sorbet-strict-floor.py">Validator script</reference>
</text>
