<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Triage, Classify, and Route Inbound Issues Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-tracker-ai-triage-classify-route.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/tracker-ai-triage-classify-route.json",
  "title": "TriageDecision",
  "type": "object",
  "required": [
    "issue_id",
    "type",
    "severity",
    "labels",
    "route_team",
    "assignee",
    "audit_comment_url"
  ],
  "properties": {
    "issue_id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "bug",
        "story",
        "epic",
        "task",
        "spike"
      ]
    },
    "severity": {
      "enum": [
        "blocker",
        "critical",
        "major",
        "minor"
      ]
    },
    "duplicate_of": {
      "type": [
        "string",
        "null"
      ]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "route_team": {
      "type": "string"
    },
    "assignee": {
      "type": "string"
    },
    "audit_comment_url": {
      "type": "string",
      "format": "uri"
    },
    "blocker_confirmed_by": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "issue_id": "PROJ-4521",
  "type": "bug",
  "severity": "major",
  "duplicate_of": null,
  "labels": [
    "/area/checkout",
    "/component/payments",
    "/lang/python"
  ],
  "route_team": "@org/payments",
  "assignee": "alice",
  "audit_comment_url": "https://github.com/org/repo/issues/4521#issuecomment-99",
  "blocker_confirmed_by": null
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "issue_id": "PROJ-4521",
  "type": "bug",
  "severity": "blocker",
  "labels": [],
  "route_team": "guessed-team",
  "assignee": "alice",
  "blocker_confirmed_by": null
}
]]></code>
    <note>Blocker severity without on-call confirmation; labels empty; route_team not from CODEOWNERS; audit_comment_url missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">severity == blocker AND blocker_confirmed_by == null</pattern>
      <pattern id="f2">duplicate auto-closed (only auto-linked allowed)</pattern>
      <pattern id="f3">labels empty</pattern>
      <pattern id="f4">audit_comment_url missing</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-tracker-ai-triage-classify-route.py">Validator script enforcing this contract.</reference>
</text>
