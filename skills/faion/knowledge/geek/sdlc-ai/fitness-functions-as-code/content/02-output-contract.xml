<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fitness Functions as Code Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for fitness-functions-as-code output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/fitness-functions-as-code.json",
  "type": "object",
  "required": [
    "functions",
    "verdict",
    "adr_index_path"
  ],
  "properties": {
    "functions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/function"
      },
      "minItems": 1
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "skipped"
      ]
    },
    "adr_index_path": {
      "type": "string"
    }
  },
  "$defs": {
    "function": {
      "type": "object",
      "required": [
        "axis",
        "test_file",
        "adr",
        "result"
      ],
      "properties": {
        "axis": {
          "enum": [
            "modularity",
            "latency",
            "security",
            "coupling",
            "throughput"
          ]
        },
        "test_file": {
          "type": "string"
        },
        "adr": {
          "type": "string"
        },
        "result": {
          "enum": [
            "pass",
            "fail",
            "skip"
          ]
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "functions": [
    {"axis": "modularity", "test_file": "tests/fitness/test_no_domain_to_infra_imports.py", "adr": "docs/adr/0007-layered-arch.md", "result": "pass"},
    {"axis": "latency", "test_file": "tests/fitness/test_checkout_p95_under_500ms.py", "adr": "docs/adr/0012-sla.md", "result": "pass"}
  ],
  "verdict": "pass",
  "adr_index_path": "docs/adr/INDEX.md"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "functions": [],
  "verdict": "pass"
}
    ]]></code>
    <note>`functions` must have ≥1 entry; `adr_index_path` required; verdict=pass with empty functions is meaningless.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-fitness-functions-as-code.py">Validator script</reference>
</text>
