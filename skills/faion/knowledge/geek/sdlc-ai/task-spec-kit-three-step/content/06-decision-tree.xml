<text id="06-decision-tree" title="Spec-Kit Three-Step Pipeline (specify → plan → tasks) Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the pipeline running artifacts in the order spec.md → plan.md → tasks.md?</root-question>

      <branch when="artifact_order != [spec, plan, tasks]">
        <conclusion ref="artifact-order-fixed" verdict="reject: out-of-order pipeline"/>
      </branch>
      <branch when="spec_md.clarifications_resolved == false">
        <conclusion ref="clarification-markers-honored" verdict="reject: unresolved [NEEDS CLARIFICATION]"/>
      </branch>
      <branch when="plan_md.constitution_gate_cited == false">
        <conclusion ref="constitution-gate-evidence" verdict="reject: plan without cited standards"/>
      </branch>
      <branch when="agent_prompt_includes_spec_or_plan == true">
        <conclusion ref="tasks-drive-agent-only" verdict="reject: layering violation"/>
      </branch>
      <branch when="parallel_tasks_share_files == true">
        <conclusion ref="parallel-tag-meaning" verdict="reject: false [P] tagging"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="parallel-tag-meaning" verdict="accept: pipeline valid"/>
      </branch>

  </decision-tree>

  <example trace="task-spec-kit-three-step-happy-path">
    `user-export` feature: specify runs first, plan cites `/docs/constitution.md#data-export`, tasks T01/T02 marked [P] with proof — agent starts.
  </example>
</text>
