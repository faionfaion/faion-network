<text id="04-procedure" title="C# Roslyn Analyzers as Compile Errors + Public API Lock Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="audit-current">
      <input>Repo</input>
      <action>Count current warnings per analyzer ID; pick top-N to escalate.</action>
      <output>audit report</output>
    </step>
    <step n="2" name="write-editorconfig">
      <input>Audit + this schema</input>
      <action>Commit .editorconfig with escalations + Directory.Build.props.</action>
      <output>configs committed</output>
    </step>
    <step n="3" name="add-public-api-analyzer">
      <input>Library list</input>
      <action>Add Microsoft.CodeAnalysis.PublicApiAnalyzers; generate baselines.</action>
      <output>baselines committed</output>
    </step>
    <step n="4" name="wire-ci">
      <input>CI workflow</input>
      <action>Add `dotnet build -c Release` step that fails on errors.</action>
      <output>CI gate live</output>
    </step>

  </section>
</text>
