<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="C# Roslyn Analyzers as Compile Errors + Public API Lock Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">dotnet_version?</root-question>

    <branch when="dotnet_version &lt; 4.7.2">
      <conclusion ref="skip-this-methodology" verdict="skip — analyzer support poor"/>
    </branch>
    <branch when="dotnet_version &gt;= 6.0">
      <question id="q-2">is_library_publisher?</question>
        <branch when="is_library == true">
          <conclusion ref="public-api-analyzer-lock" verdict="add PublicApiAnalyzers + standard escalations"/>
        </branch>
        <branch when="is_library == false">
          <conclusion ref="editorconfig-escalations" verdict="escalations + TreatWarningsAsErrors"/>
        </branch>
    </branch>

  </decision-tree>

  <example trace="dotnet=8.0 → is_library=true → public-api-analyzer-lock → commit .editorconfig + ShippedAPI.txt">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
