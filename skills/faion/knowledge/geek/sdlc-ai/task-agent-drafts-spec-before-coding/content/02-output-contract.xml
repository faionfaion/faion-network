<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agent Drafts Spec Before Coding Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact (ticket → spec comment → approval event → PR), with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/task-agent-drafts-spec-before-coding.json",
  "type": "object",
  "required": ["ticket_id", "spec_comment_url", "approval_event_url", "pr_url", "approval_mode"],
  "properties": {
    "ticket_id": {"type": "string"},
    "spec_comment_url": {"type": "string", "minLength": 10},
    "approval_event_url": {"type": "string", "minLength": 10},
    "pr_url": {"type": "string", "minLength": 10},
    "approval_mode": {"enum": ["linear_thumbs_up", "jira_slash_approve", "github_label_transition", "gitlab_label_transition", "auto_approve_label"]},
    "auto_approve_label": {"type": "boolean"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "ticket_id": "LIN-321",
  "spec_comment_url": "https://linear.app/org/issue/LIN-321/comment-12345",
  "approval_event_url": "https://linear.app/org/issue/LIN-321/reaction-67890",
  "pr_url": "https://github.com/org/repo/pull/482",
  "approval_mode": "linear_thumbs_up",
  "auto_approve_label": false
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ticket_id": "LIN-321",
  "spec_comment_url": "",
  "approval_event_url": "",
  "pr_url": "https://github.com/org/repo/pull/482",
  "approval_mode": "silence"
}
]]></code>
    <note>spec_comment_url + approval_event_url empty (rule violated); approval_mode not in enum (silence is not approval).</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">spec_comment_url empty — spec gate skipped</pattern>
    <pattern id="f2">approval_event_url empty — implicit silence treated as approval</pattern>
    <pattern id="f3">approval_mode not in enum</pattern>
  </section>

  <reference path="scripts/validate-task-agent-drafts-spec-before-coding.py">Validator script</reference>
</text>
