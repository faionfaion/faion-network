<text id="06-decision-tree" title="Autofix-vs-Flag Decision Rule for Coding Agents Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">tests_present?</root-question>

    <branch when="tests == false">
      <conclusion ref="skip-this-methodology" verdict="flag-only"/>
    </branch>
    <branch when="tests == true">
      <question id="q-2">syntactic_only AND explicit_fix_flag?</question>
        <branch when="syntactic_and_explicit == false">
          <conclusion ref="syntactic-only" verdict="flag-only"/>
        </branch>
        <branch when="syntactic_and_explicit == true">
          <question id="q-4">diff_lines &lt; 50 OR single_rule_id?</question>
            <branch when="diff_or_rule == false">
              <conclusion ref="diff-bound" verdict="flag-only; refactor scope"/>
            </branch>
            <branch when="diff_or_rule == true">
              <conclusion ref="tests-pass-after-fix" verdict="autofix + run tests"/>
            </branch>
        </branch>
    </branch>

  </decision-tree>

  <example trace="tests=true → syntactic=true (ruff I001 sort imports) → explicit_fix=true → diff=12 → tests-pass-after-fix → autofix">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
