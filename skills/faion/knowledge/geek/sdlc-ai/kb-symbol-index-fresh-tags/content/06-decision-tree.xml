<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Symbol Index as Always-Fresh LSP/ctags Artifact Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">repo_size_KLOC?</root-question>

    <branch when="repo_size_KLOC &lt; 5">
      <conclusion ref="skip-this-methodology" verdict="grep suffices"/>
    </branch>
    <branch when="repo_size_KLOC &gt;= 5">
      <question id="q-2">lsp_available?</question>
        <branch when="lsp_available == true">
          <conclusion ref="lsp-or-ctags-only" verdict="use LSP/SCIP"/>
        </branch>
        <branch when="lsp_available == false">
          <question id="q-4">ctags_available?</question>
            <branch when="ctags_available == true">
              <conclusion ref="lsp-or-ctags-only" verdict="use ctags"/>
            </branch>
            <branch when="ctags_available == false">
              <conclusion ref="skip-this-methodology" verdict="skip"/>
            </branch>
        </branch>
    </branch>

  </decision-tree>

  <example trace="repo=80 KLOC → lsp_available=true (gopls + tsserver) → lsp-or-ctags-only → Serena + JSON CLI">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
