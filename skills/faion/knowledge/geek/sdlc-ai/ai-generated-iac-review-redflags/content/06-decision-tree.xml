<text id="06-decision-tree" title="AI-Generated IaC Review Red-Flags Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml for ai-generated-iac-review-redflags.</summary>
  <decision-tree>
    <root-question id="q-root">Does the plan include resource changes in a production-blast environment?</root-question>
    <branch when="plan_diff_empty == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="env == 'sandbox-personal'">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="hardcoded_credential_found == true">
      <conclusion ref="no-hardcoded-creds"/>
    </branch>
    <branch when="open_ingress_found == true">
      <conclusion ref="no-open-ingress"/>
    </branch>
    <branch when="public_bucket_found == true">
      <conclusion ref="no-public-bucket"/>
    </branch>
    <branch when="state_lock_missing == true">
      <conclusion ref="state-lock-enabled"/>
    </branch>
    <branch when="wildcard_iam_found == true">
      <conclusion ref="no-wildcard-iam"/>
    </branch>
    <branch when="all_checks_pass == true">
      <conclusion ref="mandatory-tags"/>
    </branch>
  </decision-tree>
  <example trace="PR adds `aws_security_group_rule` with cidr 0.0.0.0/0 on port 22 → finding no-open-ingress (high) → verdict=fail."/>
</text>
