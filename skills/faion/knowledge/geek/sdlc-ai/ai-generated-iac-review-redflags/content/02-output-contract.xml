<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Generated IaC Review Red-Flags Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for ai-generated-iac-review-redflags output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-generated-iac-review-redflags.json",
  "type": "object",
  "required": [
    "plan_path",
    "findings",
    "verdict"
  ],
  "properties": {
    "plan_path": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "skipped"
      ]
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "rule_id",
        "severity",
        "resource_address",
        "remediation"
      ],
      "properties": {
        "rule_id": {
          "enum": [
            "no-hardcoded-creds",
            "no-open-ingress",
            "no-public-bucket",
            "state-lock-enabled",
            "mandatory-tags",
            "no-wildcard-iam",
            "encryption-at-rest"
          ]
        },
        "severity": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "resource_address": {
          "type": "string"
        },
        "remediation": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "plan_path": "ci/plan.json",
  "findings": [
    {"rule_id": "no-open-ingress", "severity": "high", "resource_address": "aws_security_group.api[0]", "remediation": "Restrict ingress to corp CIDR or load balancer SG"}
  ],
  "verdict": "fail"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": "none"
}
    ]]></code>
    <note>`findings` must be array; required `plan_path` and `verdict` missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-ai-generated-iac-review-redflags.py">Validator script</reference>
</text>
