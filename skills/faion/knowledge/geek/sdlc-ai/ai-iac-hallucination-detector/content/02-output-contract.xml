<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI IaC Hallucination Detector Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for ai-iac-hallucination-detector output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-iac-hallucination-detector.json",
  "type": "object",
  "required": [
    "scanned_files",
    "hallucinations",
    "verdict"
  ],
  "properties": {
    "scanned_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hallucinations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hallucination"
      }
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "skipped"
      ]
    }
  },
  "$defs": {
    "hallucination": {
      "type": "object",
      "required": [
        "category",
        "file",
        "line",
        "fabricated_name",
        "suggestion"
      ],
      "properties": {
        "category": {
          "enum": [
            "resource-type",
            "attribute-name",
            "module-source",
            "data-source",
            "deprecated-resource"
          ]
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "fabricated_name": {
          "type": "string"
        },
        "suggestion": {
          "type": "string"
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "scanned_files": ["main.tf"],
  "hallucinations": [
    {"category": "resource-type", "file": "main.tf", "line": 12, "fabricated_name": "aws_dynamodb_globaltable", "suggestion": "Did you mean aws_dynamodb_global_table?"}
  ],
  "verdict": "fail"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "hallucinations": [
    {"category": "typo"}
  ]
}
    ]]></code>
    <note>Missing `scanned_files` and `verdict`; `category` value `typo` not in enum; required fields missing from hallucination.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-ai-iac-hallucination-detector.py">Validator script</reference>
</text>
