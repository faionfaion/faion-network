<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI-Assisted Lessons-Learned Synthesis Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">retros_ingested_count?</root-question>

    <branch when="retros_ingested_count &lt; 5">
      <conclusion ref="skip-this-methodology" verdict="skip — sample too small"/>
    </branch>
    <branch when="retros_ingested_count &gt;= 5">
      <question id="q-2">retros_contain_hr_or_pii?</question>
        <branch when="hr_or_pii == true">
          <conclusion ref="skip-this-methodology" verdict="manual synthesis only"/>
        </branch>
        <branch when="hr_or_pii == false">
          <question id="q-4">human_editor_assigned?</question>
            <branch when="human_editor == null">
              <conclusion ref="human-edit-pass-mandatory" verdict="assign human editor before starting"/>
            </branch>
            <branch when="human_editor != null">
              <conclusion ref="verbatim-citations-required" verdict="run full pipeline"/>
            </branch>
        </branch>
    </branch>

  </decision-tree>

  <example trace="retros=8 → hr_or_pii=false → human_editor=&apos;Jane Doe&apos; → verbatim-citations-required → run pipeline">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
