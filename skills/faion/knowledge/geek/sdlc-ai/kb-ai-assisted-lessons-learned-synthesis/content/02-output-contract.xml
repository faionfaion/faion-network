<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Assisted Lessons-Learned Synthesis Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Defines the synthesis doc, themed appendix, and action-item table.</summary>

  <output-contract>
    <required>
      <field name="synthesis_metadata">
        <subfield name="window_start" type="iso_date"/>
        <subfield name="window_end" type="iso_date"/>
        <subfield name="retros_ingested_count" type="integer" min="5"/>
        <subfield name="model" type="string"/>
        <subfield name="model_run_temperature" type="number" max="0.2"/>
        <subfield name="human_editor" type="string"/>
        <subfield name="finalized_at" type="iso_datetime"/>
      </field>
      <field name="themes" format="list" min_items="3" max_items="12">
        <subfield name="themes[].theme_id" type="string"/>
        <subfield name="themes[].title" type="string"/>
        <subfield name="themes[].description" type="string" max_words="60"/>
        <subfield name="themes[].severity" enum="0,1,2,3"/>
        <subfield name="themes[].recurrence_count" type="integer" min="2"/>
        <subfield name="themes[].evidence_quotes" min_items="2"/>
        <subfield name="themes[].evidence_quotes[].verbatim_text" type="string"/>
        <subfield name="themes[].evidence_quotes[].source_doc" type="string"/>
        <subfield name="themes[].evidence_quotes[].line_range" type="string"/>
      </field>
      <field name="action_items" min_items="5" max_items="10">
        <subfield name="action_items[].title" type="string"/>
        <subfield name="action_items[].owner_role" type="string"/>
        <subfield name="action_items[].deadline" type="iso_date"/>
        <subfield name="action_items[].success_criteria" type="string"/>
        <subfield name="action_items[].related_theme_ids" min_items="1"/>
      </field>
      <field name="long_tail_observations" format="list"/>
      <field name="human_edit_pass">
        <subfield name="citation_check_passed" type="boolean"/>
        <subfield name="citations_verified_count" type="integer"/>
        <subfield name="edits_made_log" type="string"/>
      </field>
    </required>

    <forbidden>
      <pattern id="f1">theme with recurrence_count &lt; 2 in main themes list</pattern>
      <pattern id="f2">theme with evidence_quotes count &lt; 2</pattern>
      <pattern id="f3">evidence_quotes[].verbatim_text that does not appear in the cited source_doc at the cited line_range</pattern>
      <pattern id="f4">action_item with owner_role == "team" / "everyone" / generic</pattern>
      <pattern id="f5">action_item with deadline &gt; 1 quarter from finalized_at</pattern>
      <pattern id="f6">finalized_at present but human_edit_pass.citation_check_passed == false</pattern>
      <pattern id="f7">vague theme titles like "communication", "process", "collaboration" without a specific qualifier</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Single-mention insights move to long_tail_observations; do NOT promote them to themes without 2+ sources.</transformation>
      <transformation>Verbatim quotes may be trimmed for length while preserving specifics (project names anonymized to roles where retros require confidentiality).</transformation>
      <transformation>Theme description may add 1-2 sentences of synthesis interpretation, but evidence stays verbatim.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/synthesis-doc.md"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>≥ 5 retros ingested, sources listed</item>
      <item>every theme has ≥ 2 verbatim quotes from ≥ 2 source retros</item>
      <item>citations validated against source docs (script + human pass)</item>
      <item>severity × recurrence score computed</item>
      <item>5-10 action items, each with owner role + deadline + success criteria</item>
      <item>human_edit_pass.citation_check_passed == true before finalize</item>
      <item>no filler themes (communication / process / collaboration alone)</item>
    </list>
  </section>
</text>
