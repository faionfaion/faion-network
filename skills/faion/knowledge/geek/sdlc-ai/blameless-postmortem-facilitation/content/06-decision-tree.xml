<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Blameless Postmortem Facilitation Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml for blameless-postmortem-facilitation.</summary>
  <decision-tree>
    <root-question id="q-root">Does the incident warrant a full postmortem?</root-question>
    <branch when="is_drill == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="severity == 'sev4-self-healing'">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="facilitator == on_call_responder">
      <conclusion ref="facilitator-not-responder"/>
    </branch>
    <branch when="timeline_evidence_missing == true">
      <conclusion ref="timeline-from-evidence-only"/>
    </branch>
    <branch when="contributing_factors_count &lt; 3">
      <conclusion ref="contributing-factors-not-root-cause"/>
    </branch>
    <branch when="language_lint_passed == false">
      <conclusion ref="language-lint-pass"/>
    </branch>
    <branch when="action_items_missing_owner == true">
      <conclusion ref="action-items-owned-and-deadlined"/>
    </branch>
    <branch when="days_since_incident &gt; 7">
      <conclusion ref="publish-internal-with-redaction"/>
    </branch>
  </decision-tree>
  <example trace="SEV2 incident → facilitator scheduled (independent) → 5-event timeline reconstructed → 3 factors identified → 2 action items with owner+deadline+verifier → language lint pass → published day 6."/>
</text>
