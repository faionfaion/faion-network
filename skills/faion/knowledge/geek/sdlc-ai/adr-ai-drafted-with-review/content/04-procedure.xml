<text id="04-procedure" title="ADR AI-Drafted With Review Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>5-step procedure that walks an operator from trigger to validated artefact. Each step names its input, action, output, and (where applicable) a decision gate that stops the flow on policy violation.</summary>

  <section title="Procedure">

<step n="1" name="assemble-context">
  <input>Related ADRs + code refs</input>
  <action>Build bundle within token budget.</action>
  <output>Context bundle</output>
  <decision-gate>Reject over-budget bundle.</decision-gate>
</step>
<step n="2" name="draft-via-llm">
  <input>Bundle + ADR template</input>
  <action>LLM drafts ADR.</action>
  <output>AI draft</output>
</step>
<step n="3" name="flag-attribution">
  <input>AI draft</input>
  <action>Set `ai_drafted: true` + `model_id` + author = LLM.</action>
  <output>Flagged draft</output>
</step>
<step n="4" name="route-to-approver">
  <input>Flagged draft</input>
  <action>Send to named approver; capture sign-off timestamp.</action>
  <output>Approved ADR</output>
  <decision-gate>Block until timestamp present.</decision-gate>
</step>
<step n="5" name="validate-and-commit">
  <input>Approved ADR</input>
  <action>Run validate-adr-ai-drafted-with-review.py; commit.</action>
  <output>Committed ADR</output>
</step>
  </section>
</text>
