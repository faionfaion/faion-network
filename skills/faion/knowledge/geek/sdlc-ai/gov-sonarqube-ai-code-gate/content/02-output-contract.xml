<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="SonarQube AI-Code Gate Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for gov-sonarqube-ai-code-gate output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gov-sonarqube-ai-code-gate.json",
  "type": "object",
  "required": [
    "sonar_url",
    "project_key",
    "ai_quality_gate_id",
    "thresholds",
    "merge_gate_enforced"
  ],
  "properties": {
    "sonar_url": {
      "type": "string",
      "format": "uri"
    },
    "project_key": {
      "type": "string"
    },
    "ai_quality_gate_id": {
      "type": "string"
    },
    "thresholds": {
      "$ref": "#/$defs/thresholds"
    },
    "merge_gate_enforced": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "thresholds": {
      "type": "object",
      "required": [
        "coverage_new_code",
        "duplication_pct",
        "security_hotspots",
        "major_smells"
      ],
      "properties": {
        "coverage_new_code": {
          "type": "number",
          "minimum": 85
        },
        "duplication_pct": {
          "type": "number",
          "maximum": 2
        },
        "security_hotspots": {
          "type": "integer",
          "const": 0
        },
        "major_smells": {
          "type": "integer",
          "const": 0
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "sonar_url": "https://sonar.faion.net",
  "project_key": "payments-service",
  "ai_quality_gate_id": "ai-strict-v1",
  "thresholds": {"coverage_new_code": 85, "duplication_pct": 2, "security_hotspots": 0, "major_smells": 0},
  "merge_gate_enforced": true
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "sonar_url": "https://sonar.faion.net",
  "thresholds": {"coverage_new_code": 60},
  "merge_gate_enforced": false
}
    ]]></code>
    <note>coverage below 85; missing duplication/hotspots/smells; merge_gate_enforced false; required project_key + ai_quality_gate_id missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-gov-sonarqube-ai-code-gate.py">Validator script</reference>
</text>
