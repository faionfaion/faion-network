<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="PHP Dual Gate: PHPStan Level 9 + Psalm Taint Analysis Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lang-php-phpstan9-psalm-taint.json",
  "type": "object",
  "required": [
    "phpstan_level",
    "psalm_taint_enabled",
    "ci_runs_both",
    "baselines_committed",
    "suppression_justification_required"
  ],
  "properties": {
    "phpstan_level": {
      "type": "integer",
      "minimum": 9,
      "maximum": 10
    },
    "psalm_taint_enabled": {
      "const": true
    },
    "ci_runs_both": {
      "const": true
    },
    "baselines_committed": {
      "const": true
    },
    "suppression_justification_required": {
      "const": true
    },
    "php_version": {
      "type": "string",
      "pattern": "^[78]\\.[0-9]+"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "phpstan_level": 9,
  "psalm_taint_enabled": true,
  "ci_runs_both": true,
  "baselines_committed": true,
  "suppression_justification_required": true,
  "php_version": "8.2"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "phpstan_level": 5,
  "psalm_taint_enabled": false,
  "ci_runs_both": false
}
]]></code>
    <note>phpstan_level &lt; 9; psalm_taint_enabled must be True; ci_runs_both must be True.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">phpstan_level &lt; 9</pattern>
    <pattern id="f2">psalm_taint_enabled == false on repos with user input</pattern>
    <pattern id="f3">ci_runs_both == false</pattern>
  </section>

  <reference path="scripts/validate-php-phpstan9-psalm-taint.py">Validator script</reference>
</text>
