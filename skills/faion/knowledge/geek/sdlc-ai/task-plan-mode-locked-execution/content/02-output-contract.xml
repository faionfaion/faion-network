<text id="02-output-contract" title="Plan Mode Then Locked Execution Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the spec artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-task-plan-mode-locked-execution.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/task-plan-mode-locked-execution.json",
  "title": "LockedExecutionPlan",
  "type": "object",
  "required": [
    "plan_id",
    "plan_hash_sha256",
    "steps",
    "out_of_scope",
    "risks",
    "approver",
    "approved_at"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "plan_hash_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "n",
          "action",
          "verify"
        ],
        "properties": {
          "n": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string",
            "minLength": 5
          },
          "verify": {
            "type": "string"
          }
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "approver": {
      "type": "string"
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "plan_id": "PL-2026-0521-001",
  "plan_hash_sha256": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
  "steps": [
    {
      "n": 1,
      "action": "Rename module foo \u2192 bar in src/foo.py",
      "verify": "pytest tests/test_foo.py"
    }
  ],
  "out_of_scope": [
    "unrelated lint fixes",
    "changes to CI"
  ],
  "risks": [
    "import paths in 3 downstream modules"
  ],
  "approver": "alice@team",
  "approved_at": "2026-05-21T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "plan_id": "PL-2026-0521-002",
  "steps": [],
  "approver": "alice"
}
]]></code>
    <note>Missing plan_hash; empty steps; missing out_of_scope/risks; missing approved_at; approver not a handle.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">steps array empty</pattern>
      <pattern id="f2">out_of_scope missing or empty</pattern>
      <pattern id="f3">plan_hash_sha256 absent or wrong length</pattern>
      <pattern id="f4">approved_at missing while execution proceeds</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-task-plan-mode-locked-execution.py">Validator script enforcing this contract.</reference>
</text>
