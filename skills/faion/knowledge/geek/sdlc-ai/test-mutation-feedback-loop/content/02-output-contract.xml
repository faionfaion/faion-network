<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mutation Testing as the Agent Feedback Signal Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-test-mutation-feedback-loop.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/test-mutation-feedback-loop.json",
  "title": "MutationFeedbackConfig",
  "type": "object",
  "required": [
    "tool",
    "scope",
    "break_threshold_pct",
    "high_threshold_pct",
    "feedback_to_agent",
    "equivalent_review_required",
    "baseline_ratchet_pct"
  ],
  "properties": {
    "tool": {
      "enum": [
        "stryker",
        "mutmut",
        "pit",
        "mutmut-rust",
        "other"
      ]
    },
    "scope": {
      "enum": [
        "diff",
        "whole-codebase"
      ]
    },
    "break_threshold_pct": {
      "type": "integer",
      "minimum": 30,
      "maximum": 95
    },
    "high_threshold_pct": {
      "type": "integer",
      "minimum": 30,
      "maximum": 100
    },
    "feedback_to_agent": {
      "type": "boolean",
      "const": true
    },
    "equivalent_review_required": {
      "type": "boolean",
      "const": true
    },
    "baseline_ratchet_pct": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tool": "stryker",
  "scope": "diff",
  "break_threshold_pct": 70,
  "high_threshold_pct": 80,
  "feedback_to_agent": true,
  "equivalent_review_required": true,
  "baseline_ratchet_pct": 1
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tool": "stryker",
  "scope": "whole-codebase",
  "break_threshold_pct": 10,
  "high_threshold_pct": 5,
  "feedback_to_agent": false,
  "equivalent_review_required": false,
  "baseline_ratchet_pct": 0
}
]]></code>
    <note>Whole-codebase scope per PR; high&lt;break; feedback disabled; equivalence unreviewed; baseline ratchet disabled.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">high_threshold_pct &lt; break_threshold_pct</pattern>
      <pattern id="f2">scope == whole-codebase on every PR</pattern>
      <pattern id="f3">feedback_to_agent == false</pattern>
      <pattern id="f4">equivalent_review_required == false</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-test-mutation-feedback-loop.py">Validator script enforcing this contract.</reference>
</text>
