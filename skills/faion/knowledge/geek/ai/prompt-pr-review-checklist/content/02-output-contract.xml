<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Prompt PR Review Checklist — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>A pause-point structured checklist (5–9 items per pause-point), each item with named executor and completion artefact, owned and quarterly-reviewed.</summary>

  <section title="Required fields">
    <list>
      <item>header.owner</item>
      <item>header.mode (READ-DO or DO-CONFIRM per pause-point)</item>
      <item>header.last_reviewed (≤ 90 days)</item>
      <item>item.executor (role)</item>
      <item>item.artefact (link / screenshot / sign-off id)</item>
      <item>item.killer_anchor (incident_id / policy / postmortem) for every item</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>items without a killer-anchor</description>
      <reason>Decorative items rot the checklist.</reason>
    </antipattern>
    <antipattern>
      <description>pause-point &gt; 9 items</description>
      <reason>Working memory cap exceeded; items get skipped.</reason>
    </antipattern>
    <antipattern>
      <description>anonymous items</description>
      <reason>Owner-less items become &apos;somebody else&apos;s job&apos;.</reason>
    </antipattern>
    <antipattern>
      <description>missing or stale last_reviewed</description>
      <reason>Drift from operating reality.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Mode (READ-DO / DO-CONFIRM) named at header.</item>
      <item>Each pause-point sized 5–9 items.</item>
      <item>Every item ties to an executor + artefact + killer-anchor.</item>
      <item>Owner + last_reviewed populated and current.</item>
      <item>Quarterly review scheduled.</item>
    </list>
  </section>
</text>
