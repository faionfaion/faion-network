<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Creating or Updating Claude Code Commands Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-size">Estimated line count?</root-question>

      <branch when="lines &gt; 250">
        <conclusion ref="line-count-cap" verdict="not a command — split into a Skill"/>
      </branch>

      <branch when="lines &lt;= 250">
        <question id="q-trigger">Should it auto-run (no /invoke)?</question>
        <branch when="auto_run == true">
          <conclusion ref="line-count-cap" verdict="not a command — use a Hook"/>
        </branch>
        <branch when="auto_run == false">
          <question id="q-arguments">Does it take typed arguments?</question>
          <branch when="has_arguments == true">
            <conclusion ref="explicit-argument-syntax" verdict="command with arguments block declared"/>
          </branch>
          <branch when="has_arguments == false">
            <conclusion ref="tool-whitelist-required" verdict="argument-less command; still whitelist tools"/>
          </branch>
        </branch>
      </branch>
    </decision-tree>

    <example trace="deploy-cmd">
      lines=87 → q-trigger: /invoke → q-arguments: env arg → command with arguments block + Bash+Read whitelist.
    </example>
</text>
