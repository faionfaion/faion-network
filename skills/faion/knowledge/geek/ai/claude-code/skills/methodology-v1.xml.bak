    <domain>claude-code</domain>
    <summary>Guide to creating and updating Claude Code skills. Covers SKILL.md structure, frontmatter, tool permissions, and best practices for global and project-specific skills.</summary>
    <tags>
      <tag>skills</tag>
      <tag>claude-code</tag>
      <tag>workflow</tag>
      <tag>automation</tag>
