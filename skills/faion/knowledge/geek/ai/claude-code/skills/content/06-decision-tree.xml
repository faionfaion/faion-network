<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Creating or Updating Claude Code Skills Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-workflow-shape">Workflow shape?</root-question>

      <branch when="shape == one_shot">
        <conclusion ref="skill-md-required-fields" verdict="use a plain prompt; do not create a Skill"/>
      </branch>

      <branch when="shape == reusable_discoverable">
        <question id="q-scope">Shared across &gt; 1 project?</question>
        <branch when="cross_project == true">
          <conclusion ref="global-vs-project-decision" verdict="global Skill in faion-network/skills/"/>
        </branch>
        <branch when="cross_project == false">
          <conclusion ref="global-vs-project-decision" verdict="project-local Skill in project repo (gitignored)"/>
        </branch>
      </branch>

      <branch when="shape == isolated_async">
        <conclusion ref="skill-md-required-fields" verdict="use an Agent (apply `agents` methodology) instead"/>
      </branch>
    </decision-tree>

    <example trace="code-review">
      shape=reusable_discoverable → cross_project=true → global Skill in faion-network/skills/code-review/.
    </example>
</text>
