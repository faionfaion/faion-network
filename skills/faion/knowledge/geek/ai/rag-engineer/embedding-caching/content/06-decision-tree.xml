<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Embedding Caching Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes repeated-text rate + backend availability to cache vs no-cache.</summary>

  <decision-tree>
    <root-question id="q-repeat-rate">Estimated repeated-text rate &gt;5% over 30 days?</root-question>
    <branch when="repeat_rate &lt; 0.05">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="repeat_rate &gt;= 0.05">
      <question id="q-backend">Cache backend (Redis/Valkey/Dynamo) available?</question>
      <branch when="backend_available == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="backend_available == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="multi-tenant-refresh-2026">
    repeat_rate=0.18 → backend_available=true → run-the-checklist.
  </example>
</text>
