<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agentic RAG Iterative Retrieval Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes question class + latency budget + trust to iterative vs single-pass.</summary>

  <decision-tree>
    <root-question id="q-question-class">Multi-hop / synthesis question class with single-pass RAG failure rate &gt;20%?</root-question>
    <branch when="multi_hop == false OR single_pass_failure_rate &lt; 0.2">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="multi_hop == true AND single_pass_failure_rate &gt;= 0.2">
      <question id="q-latency">Latency SLA ≥3s allowed?</question>
      <branch when="latency_sla_ms &lt; 3000">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="latency_sla_ms &gt;= 3000">
        <question id="q-trust">Corpus trusted OR sanitisation pipeline present?</question>
        <branch when="corpus_trusted == false AND sanitise == false">
          <conclusion ref="skip-this-methodology"/>
        </branch>
        <branch when="corpus_trusted == true OR sanitise == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="research-assistant-q2-2026">
    multi_hop=true → failure_rate=0.34 → latency=8000 → sanitise=true → run-the-checklist.
  </example>
</text>
