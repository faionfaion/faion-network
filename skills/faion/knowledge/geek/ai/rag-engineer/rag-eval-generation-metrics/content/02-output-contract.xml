<text id="02-output-contract" title="rag-eval-generation-metrics Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one rag-eval-generation-metrics output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rag-generation-metrics-record",
  "type": "object",
  "required": ["query_id", "judge_model", "faithfulness", "answer_relevance", "context_relevance"],
  "properties": {
    "query_id": {"type": "string"},
    "judge_model": {"type": "string"},
    "faithfulness": {"type": "number", "minimum": 0, "maximum": 1},
    "answer_relevance": {"type": "number", "minimum": 0, "maximum": 1},
    "context_relevance": {"type": "number", "minimum": 0, "maximum": 1},
    "notes": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "query_id": "q-001",
  "judge_model": "gpt-4o",
  "faithfulness": 0.93,
  "answer_relevance": 0.87,
  "context_relevance": 0.78
}
    ]]></code>
    <note>Valid: all three metrics present, judge_model recorded.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{
  "query_id": "q-001",
  "faithfulness": 0.93
}
    ]]></code>
    <note>Invalid: missing judge_model, answer_relevance, context_relevance.</note>
  </example>

  <reference path="scripts/validate-rag-eval-generation-metrics.py">Validates an output file against this schema.</reference>
</text>
