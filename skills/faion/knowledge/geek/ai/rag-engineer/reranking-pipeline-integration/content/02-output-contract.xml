<text id="02-output-contract" title="reranking-pipeline-integration Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one reranking-pipeline-integration output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reranking-rag-result",
  "type": "object",
  "required": ["query", "results", "latency", "degraded"],
  "properties": {
    "query": {"type": "string"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "score", "source"]
      }
    },
    "latency": {"type": "object", "required": ["retrieval_ms", "rerank_ms"]},
    "degraded": {"type": "boolean"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "query": "refresh tokens",
  "results": [{"id": "c-007", "score": 0.91, "source": "rerank"}],
  "latency": {"retrieval_ms": 35, "rerank_ms": 90},
  "degraded": false
}
    ]]></code>
    <note>Valid: uniform result shape; stage-split latency; degraded flag.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"query": "q", "results": []}
    ]]></code>
    <note>Invalid: missing latency, degraded.</note>
  </example>

  <reference path="scripts/validate-reranking-pipeline-integration.py">Validates an output file against this schema.</reference>
</text>
