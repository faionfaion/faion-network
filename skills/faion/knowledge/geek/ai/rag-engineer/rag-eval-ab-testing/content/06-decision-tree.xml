<text id="06-decision-tree" title="rag-eval-ab-testing Decision Tree" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Tree picking promote / keep / run-more.</summary>

  <decision-tree>
    <root-question>Is the paired-test p-value &lt; 0.05 on the chosen quality metric?</root-question>
    <branch when="p_value &lt; 0.05 AND b_latency_p95_ms &lt;= a_latency_p95_ms * 1.2 AND b_mean &gt; a_mean">
      <conclusion ref="r5-quality-over-latency">Promote B.</conclusion>
    </branch>
    <branch when="p_value &gt;= 0.05 AND n_questions &lt; 100">
      <conclusion ref="r3-min-20-questions">Run more trials until N reaches 100 or signal emerges.</conclusion>
    </branch>
    <branch when="p_value &lt; 0.05 AND b_mean &lt; a_mean">
      <conclusion ref="r5-quality-over-latency">Keep A (B is significantly worse).</conclusion>
    </branch>
    <branch when="b_latency_p95_ms &gt; a_latency_p95_ms * 1.2">
      <conclusion ref="r5-quality-over-latency">Keep A (latency regression too large even if quality wins).</conclusion>
    </branch>
    <example trace="root → first branch → r5-quality-over-latency">
      <description>p=0.012 with +0.09 faithfulness and +14% latency → promote-b.</description>
    </example>
  </decision-tree>

