<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="reranking-models Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one reranking-models output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reranker-choice-record",
  "type": "object",
  "required": ["choice", "model", "version", "bench", "fallback"],
  "properties": {
    "choice": {"type": "string", "enum": ["cross-encoder-local", "cohere", "mixedbread", "llm-as-judge"]},
    "model": {"type": "string"},
    "version": {"type": "string"},
    "bench": {"type": "object", "required": ["latency_p95_ms", "ndcg_at_10", "cost_per_query_usd"]},
    "fallback": {"type": "string", "enum": ["ann-top-k", "none"]}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "choice": "cross-encoder-local",
  "model": "BAAI/bge-reranker-v2-m3",
  "version": "revision:abc123",
  "bench": {"latency_p95_ms": 120, "ndcg_at_10": 0.78, "cost_per_query_usd": 0.0002},
  "fallback": "ann-top-k"
}
    ]]></code>
    <note>Valid: choice + pinned version + benchmark evidence + fallback declared.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"choice": "cohere"}
    ]]></code>
    <note>Invalid: missing model, version, bench, fallback.</note>
  </example>

  <reference path="scripts/validate-reranking-models.py">Validates an output file against this schema.</reference>
</text>
