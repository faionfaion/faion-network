<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Embedding Generation Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the embedder-config artefact + valid/invalid examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/embedding-generation.json",
  "type": "object",
  "required": ["model_name", "model_version", "provider", "batch_size", "normalize", "cache_hash_algo", "max_input_tokens", "input_type_index", "input_type_query"],
  "properties": {
    "model_name": {"type": "string", "minLength": 2},
    "model_version": {"type": "string", "minLength": 1},
    "provider": {"enum": ["openai", "cohere", "voyage", "google", "azure", "local"]},
    "batch_size": {"type": "integer", "minimum": 8, "maximum": 2048},
    "normalize": {"type": "boolean", "const": true},
    "cache_hash_algo": {"const": "sha256"},
    "max_input_tokens": {"type": "integer", "minimum": 1, "maximum": 32768},
    "input_type_index": {"type": "string"},
    "input_type_query": {"type": "string"}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">batch_size violates provider cap (rule r2)</item>
      <item id="f2">cache_hash_algo != 'sha256' (rule r3)</item>
      <item id="f3">normalize=false with cosine usage (rule r4)</item>
      <item id="f4">Cohere provider without input_type_index/query (rule r6)</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "model_name": "text-embedding-3-large",
  "model_version": "2026-04",
  "provider": "openai",
  "batch_size": 512,
  "normalize": true,
  "cache_hash_algo": "sha256",
  "max_input_tokens": 8191,
  "input_type_index": "n/a",
  "input_type_query": "n/a"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "model_name": "x",
  "model_version": "",
  "provider": "cohere",
  "batch_size": 5000,
  "normalize": false,
  "cache_hash_algo": "md5",
  "max_input_tokens": 100000,
  "input_type_index": "",
  "input_type_query": ""
}
]]></code>
    <note>batch_size &gt;cap (f1); md5 (f2); normalize=false (f3); Cohere missing input_type (f4); max_input_tokens out of range.</note>
  </example>

  <reference path="scripts/validate-embedding-generation.py">Validator script</reference>
</text>
