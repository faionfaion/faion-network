<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="vector-database-setup Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one vector-database-setup output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vector-db-decision-record",
  "type": "object",
  "required": ["choice", "index", "dim", "distance", "deployment", "bench"],
  "properties": {
    "choice": {"type": "string", "enum": ["pinecone", "weaviate", "chroma", "qdrant", "milvus", "pgvector"]},
    "index": {"type": "string", "enum": ["flat", "ivf", "hnsw"]},
    "dim": {"type": "integer"},
    "distance": {"type": "string", "enum": ["cosine", "dot", "l2"]},
    "deployment": {"type": "string", "enum": ["managed", "self-host"]},
    "bench": {"type": "object", "required": ["recall_at_10", "latency_p95_ms", "qps"]}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "choice": "qdrant",
  "index": "hnsw",
  "dim": 3072,
  "distance": "cosine",
  "deployment": "self-host",
  "bench": {"recall_at_10": 0.96, "latency_p95_ms": 18, "qps": 240}
}
    ]]></code>
    <note>Valid: choice + index + dim/distance match embedder; bench evidence.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"choice": "qdrant"}
    ]]></code>
    <note>Invalid: missing index, dim, distance, deployment, bench.</note>
  </example>

  <reference path="scripts/validate-vector-database-setup.py">Validates an output file against this schema.</reference>
</text>
