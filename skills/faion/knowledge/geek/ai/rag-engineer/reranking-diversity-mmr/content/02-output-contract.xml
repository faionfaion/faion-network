<text id="02-output-contract" title="reranking-diversity-mmr Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one reranking-diversity-mmr output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mmr-rerank-result",
  "type": "object",
  "required": ["lambda", "pool_n", "top_k", "results"],
  "properties": {
    "lambda": {"type": "number", "minimum": 0, "maximum": 1},
    "pool_n": {"type": "integer"},
    "top_k": {"type": "integer"},
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "relevance", "diversity_penalty", "mmr_score"]
      }
    }
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "lambda": 0.5,
  "pool_n": 20,
  "top_k": 5,
  "results": [
    {"id": "c-007", "relevance": 0.91, "diversity_penalty": 0.0, "mmr_score": 0.455},
    {"id": "c-013", "relevance": 0.86, "diversity_penalty": 0.22, "mmr_score": 0.32}
  ]
}
    ]]></code>
    <note>Valid: λ explicit, pool size >= 2K, per-doc score breakdown.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"top_k": 5, "results": []}
    ]]></code>
    <note>Invalid: missing lambda, pool_n, per-doc breakdown.</note>
  </example>

  <reference path="scripts/validate-reranking-diversity-mmr.py">Validates an output file against this schema.</reference>
</text>
