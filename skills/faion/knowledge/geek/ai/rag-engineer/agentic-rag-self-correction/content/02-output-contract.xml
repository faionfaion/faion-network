<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agentic RAG Self-Correction Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the self-correction-config artefact + examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agentic-rag-self-correction.json",
  "type": "object",
  "required": ["max_corrections", "generator_model", "verifier_model", "max_ungrounded_claims", "audit_trace"],
  "properties": {
    "max_corrections": {"type": "integer", "minimum": 1, "maximum": 3},
    "generator_model": {"type": "string", "minLength": 2},
    "verifier_model": {"type": "string", "minLength": 2},
    "max_ungrounded_claims": {"type": "integer", "minimum": 0, "maximum": 5},
    "audit_trace": {"type": "boolean", "const": true}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">verifier_model == generator_model (rule r1)</item>
      <item id="f2">max_corrections &gt;3 (rule r2)</item>
      <item id="f3">audit_trace=false (rule r2)</item>
      <item id="f4">max_ungrounded_claims &gt;5 (defeats verifier)</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "max_corrections": 2,
  "generator_model": "opus",
  "verifier_model": "sonnet",
  "max_ungrounded_claims": 2,
  "audit_trace": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "max_corrections": 10,
  "generator_model": "opus",
  "verifier_model": "opus",
  "max_ungrounded_claims": 99,
  "audit_trace": false
}
]]></code>
    <note>max_corrections &gt;3 (f2); verifier==generator (f1); ungrounded threshold &gt;5 (f4); audit_trace=false (f3).</note>
  </example>

  <reference path="scripts/validate-agentic-rag-self-correction.py">Validator script</reference>
</text>
