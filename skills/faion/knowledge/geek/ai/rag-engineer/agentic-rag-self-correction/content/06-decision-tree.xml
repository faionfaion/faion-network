<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agentic RAG Self-Correction Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes hallucination rate + verifier availability to self-correct vs vanilla.</summary>

  <decision-tree>
    <root-question id="q-hallucination-rate">Baseline hallucination rate &gt;3% on eval set?</root-question>
    <branch when="hallucination_rate &lt; 0.01">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="hallucination_rate &gt;= 0.03">
      <question id="q-distinct-verifier">Distinct verifier model available?</question>
      <branch when="distinct_verifier == false">
        <conclusion ref="r1-different-verifier"/>
      </branch>
      <branch when="distinct_verifier == true">
        <question id="q-latency">Latency budget allows 1–3s overhead?</question>
        <branch when="latency_budget_ms &lt; 2000">
          <conclusion ref="skip-this-methodology"/>
        </branch>
        <branch when="latency_budget_ms &gt;= 2000">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-bot-q2-2026">
    hallucination_rate=0.05 → distinct_verifier=true → latency_budget=4000 → run-the-checklist.
  </example>
</text>
