<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agentic RAG Query Decomposition Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes question intent count + parallel infra to decomposition vs atomic.</summary>

  <decision-tree>
    <root-question id="q-multi-intent">Question contains ≥2 distinct intents (compound class)?</root-question>
    <branch when="multi_intent == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="multi_intent == true">
      <question id="q-parallel">Parallel retrieval infrastructure available (asyncio / thread pool)?</question>
      <branch when="parallel_available == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="parallel_available == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="compound-query-q2-2026">
    multi_intent=true → parallel_available=true → run-the-checklist (decomposer wired).
  </example>
</text>
