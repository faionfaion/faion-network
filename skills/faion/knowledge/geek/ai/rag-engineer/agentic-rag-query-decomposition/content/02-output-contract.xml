<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agentic RAG Query Decomposition Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the decomposer-config artefact + examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agentic-rag-query-decomposition.json",
  "type": "object",
  "required": ["min_sub_queries", "max_sub_queries", "planner_model", "parallel", "confidence_threshold", "coverage_required"],
  "properties": {
    "min_sub_queries": {"type": "integer", "minimum": 2, "maximum": 2},
    "max_sub_queries": {"type": "integer", "minimum": 2, "maximum": 4},
    "planner_model": {"type": "string", "minLength": 2},
    "parallel": {"type": "boolean", "const": true},
    "confidence_threshold": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "coverage_required": {"type": "boolean", "const": true}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">max_sub_queries &gt;4 (rule r1)</item>
      <item id="f2">parallel=false (rule r2)</item>
      <item id="f3">coverage_required=false (rule r3)</item>
      <item id="f4">confidence_threshold &lt;= 0 (no signal)</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "min_sub_queries": 2,
  "max_sub_queries": 4,
  "planner_model": "sonnet",
  "parallel": true,
  "confidence_threshold": 0.6,
  "coverage_required": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "min_sub_queries": 1,
  "max_sub_queries": 12,
  "planner_model": "x",
  "parallel": false,
  "confidence_threshold": 0.0,
  "coverage_required": false
}
]]></code>
    <note>max_sub_queries&gt;4 (f1); parallel=false (f2); coverage_required=false (f3); threshold=0 (f4).</note>
  </example>

  <reference path="scripts/validate-agentic-rag-query-decomposition.py">Validator script</reference>
</text>
