<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="reranking-two-stage Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one reranking-two-stage output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "two-stage-design",
  "type": "object",
  "required": ["stage1", "stage2", "bench", "fallback"],
  "properties": {
    "stage1": {"type": "object", "required": ["type", "pool_size"]},
    "stage2": {"type": "object", "required": ["type", "top_k"]},
    "bench": {"type": "object", "required": ["recall_at_pool", "precision_at_topk", "latency_p95_ms"]},
    "fallback": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "stage1": {"type": "ann", "pool_size": 50},
  "stage2": {"type": "cross-encoder", "top_k": 5},
  "bench": {"recall_at_pool": 0.92, "precision_at_topk": 0.76, "latency_p95_ms": 240},
  "fallback": "stage1-topk"
}
    ]]></code>
    <note>Valid: stage shapes, bench evidence, fallback declared.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"stage2": {"type": "bi-encoder"}}
    ]]></code>
    <note>Invalid: stage1 missing, stage2.type wrong, no bench, no fallback.</note>
  </example>

  <reference path="scripts/validate-reranking-two-stage.py">Validates an output file against this schema.</reference>
</text>
