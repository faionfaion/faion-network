<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Embedding Chunking Strategies Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes corpus class + bench availability to strategy.</summary>

  <decision-tree>
    <root-question id="q-bench-available">Domain bench set ≥50 pairs available?</root-question>
    <branch when="bench_pairs &lt; 50">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="bench_pairs &gt;= 50">
      <question id="q-class">Dominant corpus class?</question>
      <branch when="corpus_class == code">
        <conclusion ref="r3-strategy-per-corpus-class"/>
      </branch>
      <branch when="corpus_class == structured">
        <conclusion ref="r3-strategy-per-corpus-class"/>
      </branch>
      <branch when="corpus_class == prose OR corpus_class == mixed">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="kb-corpus-q2-2026">
    bench_pairs=120 → corpus_class=prose → run-the-checklist (recursive strategy).
  </example>
</text>
