<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Fine-tuning with LoRA (PEFT + TRL) Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the target attention layer set defined?</root-question>
    <branch when="target_modules covers q/k/v/o">
      <conclusion ref="target-attention-projections" verdict="apply rule target-attention-projections"/>
    </branch>
    <branch when="rank not yet picked">
      <conclusion ref="rank-8-to-64" verdict="apply rule rank-8-to-64"/>
    </branch>
    <branch when="eval-best wired == false">
      <conclusion ref="checkpoint-best-eval" verdict="apply rule checkpoint-best-eval"/>
    </branch>
    <branch when="else (config complete)">
      <conclusion ref="save-adapter-not-merged" verdict="apply rule save-adapter-not-merged"/>
    </branch>
  </decision-tree>
</text>
