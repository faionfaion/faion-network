<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fine-tuning Basics — Techniques and Frameworks Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the finetuning-basics artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/finetuning-basics.json",
  "type": "object",
  "required": [
    "decision_id",
    "base_model",
    "technique",
    "framework",
    "dataset_size",
    "gpu_floor_gb"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "base_model": {
      "type": "string"
    },
    "technique": {
      "type": "string"
    },
    "framework": {
      "type": "string"
    },
    "dataset_size": {
      "type": "integer"
    },
    "gpu_floor_gb": {
      "type": "number"
    },
    "estimated_gpu_hours": {
      "type": "number"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "decision_id": "example-decision_id",
  "base_model": "example-base_model",
  "technique": "example-technique",
  "framework": "example-framework",
  "dataset_size": 1,
  "gpu_floor_gb": 1.0,
  "estimated_gpu_hours": 1.0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "decision_id": 123
}
]]></code>
    <note>field "decision_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-finetuning-basics.py">schema validator</reference>
</text>
