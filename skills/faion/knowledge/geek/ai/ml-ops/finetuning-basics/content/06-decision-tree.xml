<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Fine-tuning Basics — Techniques and Frameworks Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Does available GPU VRAM cover base model + LoRA adapters?</root-question>
    <branch when="vram_gb &gt;= base_model_gb + 4">
      <conclusion ref="lora-default" verdict="apply rule lora-default"/>
    </branch>
    <branch when="vram_gb &lt; base_model_gb + 4 AND vram_gb &gt;= base_model_gb / 2">
      <conclusion ref="qlora-when-low-vram" verdict="apply rule qlora-when-low-vram"/>
    </branch>
    <branch when="measured_quality_gap &gt; 5pp despite LoRA + dataset growth">
      <conclusion ref="full-ft-only-when-justified" verdict="apply rule full-ft-only-when-justified"/>
    </branch>
    <branch when="team_new_to_finetuning == true">
      <conclusion ref="framework-by-skill" verdict="apply rule framework-by-skill"/>
    </branch>
  </decision-tree>
</text>
