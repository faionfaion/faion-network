<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Fine-tuning OpenAI — Basics (Dataset Preparation) Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Does the dataset have ≥50 examples?</root-question>
    <branch when="example_count &lt; 50">
      <conclusion ref="min-50-examples" verdict="apply rule min-50-examples"/>
    </branch>
    <branch when="token_count not measured">
      <conclusion ref="token-budget-computed" verdict="apply rule token-budget-computed"/>
    </branch>
    <branch when="role_alternation_violated == true">
      <conclusion ref="role-alternation" verdict="apply rule role-alternation"/>
    </branch>
    <branch when="else">
      <conclusion ref="validation-split-10pct" verdict="apply rule validation-split-10pct"/>
    </branch>
  </decision-tree>
</text>
