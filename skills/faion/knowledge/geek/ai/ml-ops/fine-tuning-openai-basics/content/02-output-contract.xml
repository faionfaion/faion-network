<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fine-tuning OpenAI — Basics (Dataset Preparation) Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the fine-tuning-openai-basics artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/fine-tuning-openai-basics.json",
  "type": "object",
  "required": [
    "job_id",
    "file_id",
    "example_count",
    "token_count",
    "estimated_usd",
    "validation_split_count"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "file_id": {
      "type": "string"
    },
    "example_count": {
      "type": "integer"
    },
    "token_count": {
      "type": "integer"
    },
    "estimated_usd": {
      "type": "number"
    },
    "validation_split_count": {
      "type": "integer"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "job_id": "example-job_id",
  "file_id": "example-file_id",
  "example_count": 1,
  "token_count": 1,
  "estimated_usd": 1.0,
  "validation_split_count": 1
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "job_id": 123
}
]]></code>
    <note>field "job_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-fine-tuning-openai-basics.py">schema validator</reference>
</text>
