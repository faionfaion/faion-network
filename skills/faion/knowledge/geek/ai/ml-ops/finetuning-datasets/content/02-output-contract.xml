<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fine-tuning Datasets — Preparation, Training, Deployment Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the finetuning-datasets artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/finetuning-datasets.json",
  "type": "object",
  "required": [
    "dataset_id",
    "raw_count",
    "clean_count",
    "duplicate_rate",
    "format",
    "test_split_hash"
  ],
  "properties": {
    "dataset_id": {
      "type": "string"
    },
    "raw_count": {
      "type": "integer"
    },
    "clean_count": {
      "type": "integer"
    },
    "duplicate_rate": {
      "type": "number"
    },
    "format": {
      "type": "string"
    },
    "test_split_hash": {
      "type": "string"
    },
    "eval_results": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "dataset_id": "example-dataset_id",
  "raw_count": 1,
  "clean_count": 1,
  "duplicate_rate": 1.0,
  "format": "example-format",
  "test_split_hash": "example-test_split_hash",
  "eval_results": {
    "k": "v"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dataset_id": 123
}
]]></code>
    <note>field "dataset_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-finetuning-datasets.py">schema validator</reference>
</text>
