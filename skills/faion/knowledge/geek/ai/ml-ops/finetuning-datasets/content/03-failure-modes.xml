<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Fine-tuning Datasets — Preparation, Training, Deployment Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for finetuning-datasets.</summary>

  <section title="Antipatterns">

    <antipattern id="exact-dedupe-only" severity="medium">
      <symptom>Dedupe step uses exact-match.</symptom>
      <root-cause source="v1-methodology + 2026 production review">MinHash setup deferred.</root-cause>
      <fix>Add MinHash with 0.85 threshold; record dropped-duplicate count.</fix>
    </antipattern>
    <antipattern id="mixed-format" severity="medium">
      <symptom>Some examples Alpaca, some ShareGPT.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Multi-vendor merge without normalisation.</root-cause>
      <fix>Normalise to one format first; record the conversion script.</fix>
    </antipattern>
    <antipattern id="no-general-eval" severity="medium">
      <symptom>Only the niche task is evaluated.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Catastrophic forgetting not budgeted.</root-cause>
      <fix>Add LM-Eval-Harness MMLU + ARC; treat regression as a block.</fix>
    </antipattern>

  </section>
</text>
