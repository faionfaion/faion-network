<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Fine-tuning Datasets — Preparation, Training, Deployment Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the dataset already deduped and split?</root-question>
    <branch when="deduped == false">
      <conclusion ref="dedupe-minhash" verdict="apply rule dedupe-minhash"/>
    </branch>
    <branch when="test_split_locked == false">
      <conclusion ref="test-split-frozen" verdict="apply rule test-split-frozen"/>
    </branch>
    <branch when="format_mixed == true">
      <conclusion ref="format-single-target" verdict="apply rule format-single-target"/>
    </branch>
    <branch when="else (ready to train)">
      <conclusion ref="eval-harness-required" verdict="apply rule eval-harness-required"/>
    </branch>
  </decision-tree>
</text>
