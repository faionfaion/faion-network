<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Evaluation Metrics for LLMs Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the evaluation-metrics artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/evaluation-metrics.json",
  "type": "object",
  "required": [
    "task_id",
    "metric_card_version",
    "safety_floor",
    "reliability_floor"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": true
    },
    "metric_card_version": {
      "type": "string"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": true
    },
    "safety_floor": {
      "type": "number"
    },
    "reliability_floor": {
      "type": "number"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "task_id": "example-task_id",
  "dimensions": {
    "k": "v"
  },
  "metric_card_version": "example-metric_card_version",
  "thresholds": {
    "k": "v"
  },
  "safety_floor": 1.0,
  "reliability_floor": 1.0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "task_id": 123
}
]]></code>
    <note>field "task_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-evaluation-metrics.py">schema validator</reference>
</text>
