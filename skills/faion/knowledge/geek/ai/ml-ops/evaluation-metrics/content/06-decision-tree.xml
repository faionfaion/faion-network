<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Evaluation Metrics for LLMs Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the task&apos;s quality dimension quantifiable by exact-match or F1?</root-question>
    <branch when="exact_match_applicable == true">
      <conclusion ref="metric-per-dim-or-na" verdict="apply rule metric-per-dim-or-na"/>
    </branch>
    <branch when="requires_rubric_judge == true">
      <conclusion ref="anchored-rubric" verdict="apply rule anchored-rubric"/>
    </branch>
    <branch when="safety_critical == true OR reliability_critical == true">
      <conclusion ref="safety-and-reliability-floor" verdict="apply rule safety-and-reliability-floor"/>
    </branch>
    <branch when="else">
      <conclusion ref="six-dimensions" verdict="apply rule six-dimensions"/>
    </branch>
  </decision-tree>
</text>
