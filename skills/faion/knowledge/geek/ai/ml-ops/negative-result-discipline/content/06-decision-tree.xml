<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Negative Result Discipline for ML Spikes Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Did the spike cost more than $200 in engineer-time + GPU?</root-question>
    <branch when="cost_usd &gt;= 200 AND outcome == no">
      <conclusion ref="three-lines-mandatory" verdict="apply rule three-lines-mandatory"/>
    </branch>
    <branch when="cost_usd &gt;= 200 AND outcome == blocked">
      <conclusion ref="retry-condition-concrete" verdict="apply rule retry-condition-concrete"/>
    </branch>
    <branch when="artefact exists but not tagged">
      <conclusion ref="tagged-and-indexed" verdict="apply rule tagged-and-indexed"/>
    </branch>
    <branch when="else (pre-spike planning)">
      <conclusion ref="pre-spike-search-required" verdict="apply rule pre-spike-search-required"/>
    </branch>
  </decision-tree>
</text>
