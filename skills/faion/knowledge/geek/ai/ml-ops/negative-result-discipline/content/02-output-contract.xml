<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Negative Result Discipline for ML Spikes Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the negative-result-discipline artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/negative-result-discipline.json",
  "type": "object",
  "required": [
    "spike_id",
    "hypothesis",
    "outcome",
    "retry_condition",
    "cost_usd",
    "indexed_at"
  ],
  "properties": {
    "spike_id": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "outcome": {
      "type": "string"
    },
    "retry_condition": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cost_usd": {
      "type": "number"
    },
    "indexed_at": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spike_id": "example-spike_id",
  "hypothesis": "example-hypothesis",
  "outcome": "example-outcome",
  "retry_condition": "example-retry_condition",
  "tags": [
    "a",
    "b"
  ],
  "cost_usd": 1.0,
  "indexed_at": "example-indexed_at"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "spike_id": 123
}
]]></code>
    <note>field "spike_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-negative-result-discipline.py">schema validator</reference>
</text>
