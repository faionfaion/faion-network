<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM Observability Stack (2026) Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the llm-observability-stack-2026 artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/llm-observability-stack-2026.json",
  "type": "object",
  "required": [
    "config_id",
    "otel_endpoint",
    "self_host",
    "pii_redaction_at_edge",
    "trace_budget_mb_per_min"
  ],
  "properties": {
    "config_id": {
      "type": "string"
    },
    "tools_wired": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "otel_endpoint": {
      "type": "string"
    },
    "self_host": {
      "type": "boolean"
    },
    "pii_redaction_at_edge": {
      "type": "boolean"
    },
    "trace_budget_mb_per_min": {
      "type": "number"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "config_id": "example-config_id",
  "tools_wired": [
    "a",
    "b"
  ],
  "otel_endpoint": "example-otel_endpoint",
  "self_host": true,
  "pii_redaction_at_edge": true,
  "trace_budget_mb_per_min": 1.0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "config_id": 123
}
]]></code>
    <note>field "config_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-llm-observability-stack-2026.py">schema validator</reference>
</text>
