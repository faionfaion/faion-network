<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM Cost Reduction Strategies Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the cost-reduction-strategies artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/cost-reduction-strategies.json",
  "type": "object",
  "required": [
    "report_id",
    "baseline_usd_month",
    "post_usd_month",
    "quality_delta",
    "latency_delta_ms"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "baseline_usd_month": {
      "type": "number"
    },
    "post_usd_month": {
      "type": "number"
    },
    "levers": {
      "type": "object",
      "additionalProperties": true
    },
    "quality_delta": {
      "type": "number"
    },
    "latency_delta_ms": {
      "type": "number"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "report_id": "example-report_id",
  "baseline_usd_month": 1.0,
  "post_usd_month": 1.0,
  "levers": {
    "k": "v"
  },
  "quality_delta": 1.0,
  "latency_delta_ms": 1.0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "report_id": 123
}
]]></code>
    <note>field "report_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-cost-reduction-strategies.py">schema validator</reference>
</text>
