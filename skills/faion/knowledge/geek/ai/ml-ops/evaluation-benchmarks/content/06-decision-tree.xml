<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Evaluation Benchmarks — Multi-Model + Continuous Production Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is this an offline model-swap decision?</root-question>
    <branch when="intent == model_swap">
      <conclusion ref="held-out-fresh" verdict="apply rule held-out-fresh"/>
    </branch>
    <branch when="intent == continuous_monitoring">
      <conclusion ref="prod-sampling-1-5pct" verdict="apply rule prod-sampling-1-5pct"/>
    </branch>
    <branch when="intent == prompt_rewrite">
      <conclusion ref="baseline-versioned" verdict="apply rule baseline-versioned"/>
    </branch>
    <branch when="else (ad-hoc)">
      <conclusion ref="judge-with-rubric" verdict="apply rule judge-with-rubric"/>
    </branch>
  </decision-tree>
</text>
