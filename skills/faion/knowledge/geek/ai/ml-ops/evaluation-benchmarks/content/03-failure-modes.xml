<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Evaluation Benchmarks — Multi-Model + Continuous Production Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for evaluation-benchmarks.</summary>

  <section title="Antipatterns">

    <antipattern id="leaderboard-without-baseline" severity="medium">
      <symptom>Leaderboard reports absolute scores only.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Baseline forgotten.</root-cause>
      <fix>Always report delta vs baseline + 95% CI.</fix>
    </antipattern>
    <antipattern id="100pct-sampling" severity="medium">
      <symptom>Every prod call re-scored.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Cost forgotten.</root-cause>
      <fix>Cap sampling at 5%; weight by traffic class.</fix>
    </antipattern>
    <antipattern id="free-form-judge" severity="medium">
      <symptom>Judge prompt has no rubric.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Author skipped rubric authoring.</root-cause>
      <fix>Write a rubric with 3-5 dimensions and 1-5 anchored scores per dimension.</fix>
    </antipattern>

  </section>
</text>
