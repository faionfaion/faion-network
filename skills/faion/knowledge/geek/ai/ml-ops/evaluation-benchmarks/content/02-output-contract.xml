<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Evaluation Benchmarks — Multi-Model + Continuous Production Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the evaluation-benchmarks artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/evaluation-benchmarks.json",
  "type": "object",
  "required": [
    "benchmark_id",
    "baseline_model_id",
    "contender_model_id",
    "win_rate",
    "drift_alert"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string"
    },
    "baseline_model_id": {
      "type": "string"
    },
    "contender_model_id": {
      "type": "string"
    },
    "win_rate": {
      "type": "number"
    },
    "ci_95": {
      "type": "object",
      "additionalProperties": true
    },
    "drift_alert": {
      "type": "boolean"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "benchmark_id": "example-benchmark_id",
  "baseline_model_id": "example-baseline_model_id",
  "contender_model_id": "example-contender_model_id",
  "win_rate": 1.0,
  "ci_95": {
    "k": "v"
  },
  "drift_alert": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "benchmark_id": 123
}
]]></code>
    <note>field "benchmark_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-evaluation-benchmarks.py">schema validator</reference>
</text>
