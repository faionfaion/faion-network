<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fine-tuning OpenAI — Production Pipeline Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the fine-tuning-openai-production artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/fine-tuning-openai-production.json",
  "type": "object",
  "required": [
    "registry_id",
    "model_id",
    "base_model",
    "dataset_hash",
    "eval_score",
    "status"
  ],
  "properties": {
    "registry_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "base_model": {
      "type": "string"
    },
    "dataset_hash": {
      "type": "string"
    },
    "eval_score": {
      "type": "number"
    },
    "status": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "registry_id": "example-registry_id",
  "model_id": "example-model_id",
  "base_model": "example-base_model",
  "dataset_hash": "example-dataset_hash",
  "eval_score": 1.0,
  "status": "example-status",
  "created_at": "example-created_at"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "registry_id": 123
}
]]></code>
    <note>field "registry_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-fine-tuning-openai-production.py">schema validator</reference>
</text>
