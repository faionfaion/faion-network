<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Fine-tuning OpenAI — Production Pipeline Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for fine-tuning-openai-production.</summary>

  <section title="Antipatterns">

    <antipattern id="default-hyperparams" severity="medium">
      <symptom>Job submitted with no hyperparameters.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Author trusted defaults.</root-cause>
      <fix>Set n_epochs / batch_size / lr_multiplier explicitly; record in registry.</fix>
    </antipattern>
    <antipattern id="no-registry" severity="medium">
      <symptom>Model ID stored in a Notion page.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Registry deferred.</root-cause>
      <fix>Add a small SQLite / git-tag registry with required fields.</fix>
    </antipattern>
    <antipattern id="tight-polling" severity="medium">
      <symptom>Polling loop hits API every 5s.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Backoff deferred.</root-cause>
      <fix>Move to exponential backoff (30s → 5min cap).</fix>
    </antipattern>

  </section>
</text>
