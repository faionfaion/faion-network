<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Fine-tuning OpenAI — Production Pipeline Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Has the file been uploaded?</root-question>
    <branch when="file_uploaded == false">
      <conclusion ref="idempotent-resume" verdict="apply rule idempotent-resume"/>
    </branch>
    <branch when="hyperparameters_unset == true">
      <conclusion ref="hyperparameter-explicit" verdict="apply rule hyperparameter-explicit"/>
    </branch>
    <branch when="eval_pending == true">
      <conclusion ref="eval-on-held-out" verdict="apply rule eval-on-held-out"/>
    </branch>
    <branch when="eval_regression &gt; 5pp">
      <conclusion ref="rollback-on-regression" verdict="apply rule rollback-on-regression"/>
    </branch>
  </decision-tree>
</text>
