<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="LLM Cost Basics — Pricing, Usage Tracking, Baseline Optimisation Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for llm-cost-basics.</summary>

  <section title="Antipatterns">

    <antipattern id="no-per-call-log" severity="medium">
      <symptom>Per-call cost cannot be reconstructed.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Logging deferred.</root-cause>
      <fix>Add input_tokens/output_tokens/model_id to log emitter.</fix>
    </antipattern>
    <antipattern id="hardcoded-prices" severity="medium">
      <symptom>Cost calc hard-codes $0.01/1k input.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Provider price updates ignored.</root-cause>
      <fix>Move to a versioned price table; reload on month boundary.</fix>
    </antipattern>
    <antipattern id="default-opus" severity="medium">
      <symptom>Multi-model setup defaults to opus.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Cheap model not trusted.</root-cause>
      <fix>Default to haiku / sonnet; escalate on confidence-gate fail.</fix>
    </antipattern>

  </section>
</text>
