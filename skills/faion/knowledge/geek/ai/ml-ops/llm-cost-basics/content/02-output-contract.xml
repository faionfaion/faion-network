<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM Cost Basics — Pricing, Usage Tracking, Baseline Optimisation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the llm-cost-basics artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/llm-cost-basics.json",
  "type": "object",
  "required": [
    "month",
    "total_usd"
  ],
  "properties": {
    "month": {
      "type": "string"
    },
    "total_usd": {
      "type": "number"
    },
    "by_feature": {
      "type": "object",
      "additionalProperties": true
    },
    "by_tenant": {
      "type": "object",
      "additionalProperties": true
    },
    "by_model": {
      "type": "object",
      "additionalProperties": true
    },
    "baseline_applied": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "month": "example-month",
  "total_usd": 1.0,
  "by_feature": {
    "k": "v"
  },
  "by_tenant": {
    "k": "v"
  },
  "by_model": {
    "k": "v"
  },
  "baseline_applied": {
    "k": "v"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "month": 123
}
]]></code>
    <note>field "month" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-llm-cost-basics.py">schema validator</reference>
</text>
