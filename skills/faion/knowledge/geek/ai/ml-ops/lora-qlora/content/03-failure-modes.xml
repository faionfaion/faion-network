<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="LoRA and QLoRA — Low-Rank Adaptation Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for lora-qlora.</summary>

  <section title="Antipatterns">

    <antipattern id="fp16-on-ampere" severity="medium">
      <symptom>Team forces fp16 on an Ampere GPU.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Cargo-culted from older docs.</root-cause>
      <fix>Switch to bf16; observe drop in NaN crash rate.</fix>
    </antipattern>
    <antipattern id="int8-instead-nf4" severity="medium">
      <symptom>QLoRA uses int8 to &apos;save more VRAM&apos;.</symptom>
      <root-cause source="v1-methodology + 2026 production review">QLoRA paper not read.</root-cause>
      <fix>Use nf4 + bf16 compute; int8 loses quality without VRAM win.</fix>
    </antipattern>
    <antipattern id="skip-smoke" severity="medium">
      <symptom>Multi-hour job launched without smoke.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Author wanted to ship.</root-cause>
      <fix>Run 5-step smoke; bail on failure.</fix>
    </antipattern>

  </section>
</text>
