<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LoRA and QLoRA — Low-Rank Adaptation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the lora-qlora artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/lora-qlora.json",
  "type": "object",
  "required": [
    "run_id",
    "technique",
    "rank",
    "alpha",
    "compute_dtype",
    "base_dtype"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "technique": {
      "type": "string"
    },
    "rank": {
      "type": "integer"
    },
    "alpha": {
      "type": "integer"
    },
    "compute_dtype": {
      "type": "string"
    },
    "base_dtype": {
      "type": "string"
    },
    "vram_peak_gb": {
      "type": "number"
    },
    "smoke_passed": {
      "type": "boolean"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "run_id": "example-run_id",
  "technique": "example-technique",
  "rank": 1,
  "alpha": 1,
  "compute_dtype": "example-compute_dtype",
  "base_dtype": "example-base_dtype",
  "vram_peak_gb": 1.0,
  "smoke_passed": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "run_id": 123
}
]]></code>
    <note>field "run_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-lora-qlora.py">schema validator</reference>
</text>
