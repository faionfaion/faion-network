<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="LoRA and QLoRA — Low-Rank Adaptation Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the available GPU Ampere or newer?</root-question>
    <branch when="gpu_ampere_or_newer == true">
      <conclusion ref="bf16-on-ampere" verdict="apply rule bf16-on-ampere"/>
    </branch>
    <branch when="technique == qlora">
      <conclusion ref="nf4-for-qlora" verdict="apply rule nf4-for-qlora"/>
    </branch>
    <branch when="vram_headroom_gb &lt; 4">
      <conclusion ref="grad-checkpointing-on" verdict="apply rule grad-checkpointing-on"/>
    </branch>
    <branch when="else (config ready)">
      <conclusion ref="smoke-test-5-steps" verdict="apply rule smoke-test-5-steps"/>
    </branch>
  </decision-tree>
</text>
