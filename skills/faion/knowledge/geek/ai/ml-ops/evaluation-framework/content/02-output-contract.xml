<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Evaluation Framework — Offline Harness + LLM-as-Judge + Production Sampling Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the evaluation-framework artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/evaluation-framework.json",
  "type": "object",
  "required": [
    "evaluation_id",
    "dataset_id",
    "model_id",
    "win_rate",
    "judge_model_id"
  ],
  "properties": {
    "evaluation_id": {
      "type": "string"
    },
    "dataset_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "win_rate": {
      "type": "number"
    },
    "ci_95": {
      "type": "object",
      "additionalProperties": true
    },
    "judge_model_id": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "evaluation_id": "example-evaluation_id",
  "dataset_id": "example-dataset_id",
  "model_id": "example-model_id",
  "scores": [
    "a",
    "b"
  ],
  "win_rate": 1.0,
  "ci_95": {
    "k": "v"
  },
  "judge_model_id": "example-judge_model_id"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "evaluation_id": 123
}
]]></code>
    <note>field "evaluation_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-evaluation-framework.py">schema validator</reference>
</text>
