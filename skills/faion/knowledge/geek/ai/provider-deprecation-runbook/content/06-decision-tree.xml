<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Provider Deprecation Runbook Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes deprecation state + portability lock to run / skip + phase transitions.</summary>

  <decision-tree>
    <root-question id="q-deprecation-pending">Provider deprecation notice received OR quarterly drill due?</root-question>
    <branch when="deprecation_pending == false AND drill_due == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="deprecation_pending == true OR drill_due == true">
      <question id="q-portability-locked">Portability spec already locks ≥2 providers?</question>
      <branch when="portability_locked == true AND drill_due == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="portability_locked == false OR drill_due == true">
        <question id="q-owner-oncall">Owner + on-call named?</question>
        <branch when="owner_oncall == false">
          <conclusion ref="r5-owner-and-oncall"/>
        </branch>
        <branch when="owner_oncall == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="opus-3x-deprecation-2026">
    deprecation_pending=true → portability_locked=true → drill_due=false → skip-this-methodology (rely on portability spec).
  </example>
</text>
