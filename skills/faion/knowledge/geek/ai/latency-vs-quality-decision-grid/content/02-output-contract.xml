<text id="02-output-contract" title="Latency vs Quality Decision Grid Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>JSON Schema for grid.json: per-call-site row with SLO + model + tactic + cost + owner.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/latency-vs-quality-decision-grid",
  "type": "object",
  "required": ["app", "sites", "rollback_minutes_max"],
  "properties": {
    "app": {"type": "string"},
    "rollback_minutes_max": {"type": "integer", "maximum": 5},
    "sites": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "latency_p50_ms", "latency_p95_ms", "quality_floor", "model", "tactic", "cost_per_call_usd", "owner", "last_reviewed"],
        "properties": {
          "id": {"type": "string"},
          "latency_p50_ms": {"type": "integer", "minimum": 1},
          "latency_p95_ms": {"type": "integer", "minimum": 1},
          "quality_floor": {"type": "number", "minimum": 0, "maximum": 1},
          "model": {"type": "string"},
          "tactic": {"type": "string"},
          "cost_per_call_usd": {"type": "number", "minimum": 0},
          "owner": {"type": "string"},
          "last_reviewed": {"type": "string"}
        }
      }
    }
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "app": "support-app",
  "rollback_minutes_max": 5,
  "sites": [
    {"id": "autocomplete", "latency_p50_ms": 200, "latency_p95_ms": 400, "quality_floor": 0.75, "model": "haiku", "tactic": "prompt-cache + tight max_tokens", "cost_per_call_usd": 0.0005, "owner": "fe-team", "last_reviewed": "2026-05-22"},
    {"id": "chat", "latency_p50_ms": 1500, "latency_p95_ms": 3000, "quality_floor": 0.88, "model": "sonnet", "tactic": "stream + tools", "cost_per_call_usd": 0.012, "owner": "chat-team", "last_reviewed": "2026-05-22"},
    {"id": "audit-summary", "latency_p50_ms": 12000, "latency_p95_ms": 30000, "quality_floor": 0.95, "model": "opus", "tactic": "structured-output + 2-pass", "cost_per_call_usd": 0.18, "owner": "ops-team", "last_reviewed": "2026-05-22"}
  ]
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"app": "x", "rollback_minutes_max": 30, "sites": [{"id": "one", "model": "sonnet"}]}]]></code>
      <note>Fails: rollback &gt;5 min, only 1 site, missing SLO + quality_floor + owner fields.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>sites array length ≥ 3.</item>
      <item>Every row has the 9 required columns populated.</item>
      <item>rollback_minutes_max ≤ 5.</item>
      <item>quality_floor ∈ [0, 1].</item>
      <item>owner is a named entity (not "team", "us").</item>
      <item>last_reviewed within 90 days.</item>
    </list>
  </section>
</text>
