<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI Governance and Compliance — Decision Tree" version="1.1.0" est_tokens="400">
  <decision-tree>
    <root-question id="q-root">What is the EU AI Act risk tier?</root-question>
    <branch when="risk_tier == &apos;unacceptable&apos;">
      <conclusion ref="r1-risk-tier-first">Abort deployment — system forbidden.</conclusion>
    </branch>
    <branch when="risk_tier == &apos;high&apos;">
      <conclusion ref="r4-fairness-explainability">All seven artefacts mandatory; do not ship without them.</conclusion>
    </branch>
    <branch when="risk_tier == &apos;limited&apos;">
      <conclusion ref="r2-named-dri">Only transparency disclosure required; named DRI still mandatory.</conclusion>
    </branch>
    <branch when="risk_tier == &apos;minimal&apos;">
      <conclusion ref="r3-audit-trail-immutable">Log + skip the heavy gates.</conclusion>
    </branch>
    <example trace="risk_tier == &apos;unacceptable&apos;">
      <p>Abort deployment — system forbidden.</p>
    </example>
  </decision-tree>
</text>
