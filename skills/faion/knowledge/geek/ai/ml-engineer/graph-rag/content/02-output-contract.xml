<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GraphRAG — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `graph-rag`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://graph-rag/output.schema.json",
  "type": "object",
  "required": ["pipeline_name", "entity_schema_path", "extraction_prompt_path", "community_algorithm", "summary_levels", "router_path"],
  "properties": {
    "pipeline_name": {"type": "string"},
    "entity_schema_path": {"type": "string"},
    "extraction_prompt_path": {"type": "string"},
    "community_algorithm": {"enum": ["leiden", "louvain"]},
    "summary_levels": {"type": "integer", "minimum": 2},
    "router_path": {"type": "string"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "pipeline_name": "legal-graphrag-v1",
  "entity_schema_path": "schemas/legal_entities.py",
  "extraction_prompt_path": "prompts/legal_extraction.txt",
  "community_algorithm": "leiden",
  "summary_levels": 2,
  "router_path": "routers/legal_query_classifier.py"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "pipeline_name": "",
  "entity_schema_path": "",
  "extraction_prompt_path": "",
  "community_algorithm": "naive",
  "summary_levels": 1,
  "router_path": ""
}
]]></code>
      <note>Invalid: empty paths; bogus algorithm; summary_levels&lt;2; no router.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-graph-rag.py --self-test exits 0.</item>
    </list>
  </section>
</text>
