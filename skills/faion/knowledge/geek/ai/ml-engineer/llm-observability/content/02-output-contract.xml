<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM Observability and Monitoring — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `llm-observability`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://llm-observability/output.schema.json",
  "type": "object",
  "required": ["spec_name", "vendor", "trace_coverage_pct", "eval_cadence", "cost_alert", "pii_redaction"],
  "properties": {
    "spec_name": {"type": "string"},
    "vendor": {"enum": ["langfuse_self", "langfuse_cloud", "langsmith", "phoenix", "native_otel"]},
    "trace_coverage_pct": {"type": "number", "minimum": 50, "maximum": 100},
    "eval_cadence": {"enum": ["hourly", "daily", "weekly"]},
    "cost_alert": {"type": "object", "required": ["daily_multiplier", "single_call_multiplier"]},
    "pii_redaction": {"type": "boolean"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "spec_name": "agent-obs-v1",
  "vendor": "langfuse_self",
  "trace_coverage_pct": 100,
  "eval_cadence": "daily",
  "cost_alert": {
    "daily_multiplier": 2.0,
    "single_call_multiplier": 100
  },
  "pii_redaction": true
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "spec_name": "",
  "vendor": "x",
  "trace_coverage_pct": 10,
  "eval_cadence": "monthly",
  "cost_alert": {},
  "pii_redaction": false
}
]]></code>
      <note>Invalid: bogus vendor; coverage &lt;50; eval cadence too slow; no alert; PII not redacted.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-llm-observability.py --self-test exits 0.</item>
    </list>
  </section>
</text>
