<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Voice Agents Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the deployment phone-based?</root-question>
    <branch when="channel == phone AND self_host == false">
      <conclusion ref="latency-budget-800" verdict="apply rule latency-budget-800"/>
    </branch>
    <branch when="channel == phone AND outbound == true">
      <conclusion ref="tcpa-gdpr-consent" verdict="apply rule tcpa-gdpr-consent"/>
    </branch>
    <branch when="channel == web AND tool_calls_per_turn &gt; 0">
      <conclusion ref="filler-phrase-on-tool" verdict="apply rule filler-phrase-on-tool"/>
    </branch>
    <branch when="channel == web AND tool_calls_per_turn == 0">
      <conclusion ref="responses-1-3-sentences" verdict="apply rule responses-1-3-sentences"/>
    </branch>
  </decision-tree>
</text>
