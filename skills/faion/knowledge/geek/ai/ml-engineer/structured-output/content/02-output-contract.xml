<text id="02-output-contract" title="Structured Output — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins `StructuredCallResult` shape returned by the safe-parse wrapper and the structured-output config block.</summary>

  <output-contract>
    <required>
      <field name="provider" type="enum" values="openai|anthropic|gemini|mistral|cohere"/>
      <field name="mode" type="enum" values="response_format|tool_use_json|schema_response|function_call"/>
      <field name="model_name" type="string"/>
      <field name="schema_ref" type="string"/>
      <field name="repair_strategy" type="enum" values="once|none"/>
      <field name="log_raw_on_failure" type="boolean"/>
    </required>

    <forbidden>
      <pattern id="f1">provider supports structured-output AND mode == "manual_prompt" (r1-provider-native-first)</pattern>
      <pattern id="f2">repair_strategy == "infinite" or count &gt; 1 (r3-repair-once)</pattern>
      <pattern id="f3">log_raw_on_failure == false (r4-log-raw-on-failure)</pattern>
      <pattern id="f4">schema contains recursive type reference (r5-no-recursive-schemas)</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add typed field to schema (minor bump if backward compatible).</transformation>
      <transformation>Tighten constraint (regex, enum) is minor.</transformation>
      <transformation>Switch provider is major bump (capability differences).</transformation>
    </allowed-transformations>

    <schema-reference path="templates/structured-output.schema.yaml"/>
  </output-contract>

  <section title="StructuredCallResult JSON shape">
    <code lang="json"><![CDATA[
{
  "value": { /* parsed Pydantic / JSON Schema instance */ },
  "repair_attempts": 0,
  "raw": "<set only when parse failed twice>",
  "provider": "openai",
  "model": "gpt-4o-2024-08-06"
}
]]></code>
  </section>
</text>
