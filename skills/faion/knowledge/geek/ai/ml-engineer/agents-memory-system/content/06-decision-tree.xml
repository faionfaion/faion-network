<text id="06-decision-tree" title="Agents Memory System — Decision Tree" version="1.1.0" est_tokens="400">
  <decision-tree>
    <root-question id="q-root">How long do agent sessions typically run?</root-question>
    <branch when="session_length_turns &gt;= 50 or session_length_hours &gt;= 1">
      <question id="q-sub-0">Does session continuity matter (user returns expecting recall)?</question>
      <branch when="session_continuity_matters == true">
        <conclusion ref="r1-three-tiers">Adopt three-tier memory with summariser + hybrid recall + eviction.</conclusion>
      </branch>
      <branch when="session_continuity_matters == false">
        <conclusion ref="r2-bounded-short-term">Adopt short-term + episodic; skip long-term store.</conclusion>
      </branch>
      <branch when="session_length_turns &lt; 50 and session_length_hours &lt; 1">
        <conclusion ref="r2-bounded-short-term">Skip — bounded buffer is enough at this scale.</conclusion>
      </branch>
    </branch>
    <example trace="session_length_turns &gt;= 50 or session_length_hours &gt;= 1">
      <p>see first branch</p>
    </example>
  </decision-tree>
</text>
