<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM Observability Stack — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `llm-observability-stack`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://llm-observability-stack/output.schema.json",
  "type": "object",
  "required": ["stack_name", "topology", "components", "pricing_path", "alert_rules_path", "pii_at_collector"],
  "properties": {
    "stack_name": {"type": "string"},
    "topology": {"enum": ["docker_compose", "k8s", "managed"]},
    "components": {"type": "array", "minItems": 3, "items": {"type": "object", "required": ["name", "version"]}},
    "pricing_path": {"type": "string"},
    "alert_rules_path": {"type": "string"},
    "pii_at_collector": {"type": "boolean"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "stack_name": "agent-obs-eu",
  "topology": "k8s",
  "components": [
    {
      "name": "langfuse",
      "version": "3.18.0"
    },
    {
      "name": "otel-collector",
      "version": "0.95.0"
    },
    {
      "name": "prometheus",
      "version": "2.55.0"
    },
    {
      "name": "grafana",
      "version": "11.2.0"
    }
  ],
  "pricing_path": "config/pricing.yaml",
  "alert_rules_path": "config/alert-rules.yaml",
  "pii_at_collector": true
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "stack_name": "",
  "topology": "x",
  "components": [
    {
      "name": "langfuse",
      "version": "latest"
    }
  ],
  "pricing_path": "",
  "alert_rules_path": "",
  "pii_at_collector": false
}
]]></code>
      <note>Invalid: empty name; bogus topology; &lt;3 components; floating @latest version; missing paths; PII not at collector.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-llm-observability-stack.py --self-test exits 0.</item>
    </list>
  </section>
</text>
