    <?xml version="1.0" encoding="UTF-8"?>
    <text id="06-decision-tree" title="Embeddings Provider APIs — Decision Tree" version="1.1.0" est_tokens="400">
      <decision-tree>
        <root-question id="q-root">How many embedding providers will you use in production?</root-question>
        <branch when="provider_count == 1 and no_switch_planned == true">
  <conclusion ref="r1-unified-client">Skip — direct SDK use is OK at this scale.</conclusion>
</branch>
<branch when="provider_count == 1 and no_switch_planned == false">
  <conclusion ref="r1-unified-client">Build the unified client now to make future switch cheap.</conclusion>
</branch>
<branch when="provider_count &gt;= 2">
  <conclusion ref="r5-fallback-chain">Build unified client + fallback chain.</conclusion>
</branch>
        <example trace="provider_count == 1 and no_switch_planned == true">
          <p>Skip — direct SDK use is OK at this scale.</p>
        </example>
      </decision-tree>
    </text>
