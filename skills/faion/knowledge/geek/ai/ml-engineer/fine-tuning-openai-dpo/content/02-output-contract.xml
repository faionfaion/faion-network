<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OpenAI Direct Preference Optimization (DPO) — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `fine-tuning-openai-dpo`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://fine-tuning-openai-dpo/output.schema.json",
  "type": "object",
  "required": ["sft_base_model_id", "pair_count", "beta", "epochs", "inter_rater_agreement", "preference_eval_gate_passed"],
  "properties": {
    "sft_base_model_id": {"type": "string", "pattern": "^ft:"},
    "pair_count": {"type": "integer", "minimum": 500},
    "beta": {"type": "number", "minimum": 0.01, "maximum": 0.5},
    "epochs": {"type": "integer", "minimum": 1, "maximum": 5},
    "inter_rater_agreement": {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "preference_eval_gate_passed": {"type": "boolean"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "sft_base_model_id": "ft:gpt-4o-mini-2024-07-18:org::sft_v1",
  "pair_count": 1850,
  "beta": 0.1,
  "epochs": 2,
  "inter_rater_agreement": 0.72,
  "preference_eval_gate_passed": true
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "sft_base_model_id": "",
  "pair_count": 80,
  "beta": 5.0,
  "epochs": 0,
  "inter_rater_agreement": 0.2,
  "preference_eval_gate_passed": false
}
]]></code>
      <note>Invalid: base not SFT (no ft: prefix); pair_count &lt; 500; beta &gt; 0.5; epochs &lt; 1; low agreement; eval not passed.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-fine-tuning-openai-dpo.py --self-test exits 0.</item>
    </list>
  </section>
</text>
