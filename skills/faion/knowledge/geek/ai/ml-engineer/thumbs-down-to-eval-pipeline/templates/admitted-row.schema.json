{
  "_header": [
    "purpose: eval-suite row schema (final admitted form)",
    "consumes: EvalCandidate (admit_decision=ADMIT)",
    "produces: validation schema for eval-suite PR contents",
    "depends-on: jsonschema",
    "token-budget-impact: 0 at runtime"
  ],
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "input", "expected", "rubric_ref", "source", "admitted_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^er-[a-z0-9-]+$"},
    "input": {"type": "string"},
    "expected": {"type": "string"},
    "rubric_ref": {"type": "string"},
    "source": {
      "type": "object",
      "required": ["type", "candidate_id"],
      "properties": {
        "type": {"type": "string", "enum": ["thumbs-down", "report", "manual"]},
        "candidate_id": {"type": "string"}
      }
    },
    "admitted_at": {"type": "string", "format": "date"},
    "tags": {"type": "array", "items": {"type": "string"}}
  }
}
