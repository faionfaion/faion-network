<text id="02-output-contract" title="Reranking — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the YAML shape of `reranker.yaml` — a sub-block of rag-pipeline.yaml consumed by the orchestrator.</summary>

  <output-contract>
    <required>
      <field name="provider" type="enum" values="cohere|voyage|jina|bge|flashrank|none"/>
      <field name="model" type="string"/>
      <field name="top_n_input" type="integer" min="10" max="1000"/>
      <field name="top_k_output" type="integer" min="1" max="20"/>
      <field name="latency_budget_ms" type="integer" min="50" max="2000"/>
      <field name="fallback" type="object" required_keys="strategy"/>
      <field name="eval_evidence" type="object" required_keys="set_path,precision_lift,sample_size"/>
    </required>

    <forbidden>
      <pattern id="f1">top_n_input &lt; top_k_output (no reordering room)</pattern>
      <pattern id="f2">provider == "cohere" AND top_n_input &gt; 1000 (cap violation, r2-top-n-capacity)</pattern>
      <pattern id="f3">eval_evidence.sample_size &lt; 50 OR precision_lift &lt; 0.10 (r4-eval-before-adopt)</pattern>
      <pattern id="f4">fallback.strategy == "hard-fail" (r5-fallback-on-outage)</pattern>
      <pattern id="f5">latency_budget_ms &lt; 50 (impossible budget; reranker requires ≥100ms)</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Swap provider with new eval_evidence record (major bump).</transformation>
      <transformation>Tune top_n / top_k within band (patch bump if eval gate passes).</transformation>
    </allowed-transformations>

    <schema-reference path="templates/reranker.schema.yaml"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>provider, model, top_n_input, top_k_output declared</item>
      <item>top_n_input within provider cap</item>
      <item>top_n_input &gt;= 2 × top_k_output (reordering needs room)</item>
      <item>fallback.strategy is one of {local-bge, return-first-stage-degraded}</item>
      <item>eval_evidence.sample_size ≥ 50 AND precision_lift ≥ 0.10</item>
      <item>latency_budget_ms agreed with product SLO</item>
    </list>
  </section>
</text>
