<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MCP Security — Consent, Injection Defenses, Access Controls — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `mcp-security`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://mcp-security/output.schema.json",
  "type": "object",
  "required": ["rubric_name", "scope", "consent_grade", "auth_grade", "injection_grade", "audit_grade", "overall_pass"],
  "properties": {
    "rubric_name": {"type": "string"},
    "scope": {"enum": ["local_desktop", "remote_single_tenant", "remote_multi_tenant"]},
    "consent_grade": {"enum": ["fails", "meets", "exceeds"]},
    "auth_grade": {"enum": ["fails", "meets", "exceeds"]},
    "injection_grade": {"enum": ["fails", "meets", "exceeds"]},
    "audit_grade": {"enum": ["fails", "meets", "exceeds"]},
    "overall_pass": {"type": "boolean"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "rubric_name": "support-agent-mcp-sec-v1",
  "scope": "remote_multi_tenant",
  "consent_grade": "meets",
  "auth_grade": "meets",
  "injection_grade": "meets",
  "audit_grade": "exceeds",
  "overall_pass": true
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "rubric_name": "",
  "scope": "x",
  "consent_grade": "yolo",
  "auth_grade": "fails",
  "injection_grade": "fails",
  "audit_grade": "fails",
  "overall_pass": true
}
]]></code>
      <note>Invalid: bogus scope/grades; overall_pass true while individual grades fail (contradiction).</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-mcp-security.py --self-test exits 0.</item>
    </list>
  </section>
</text>
