<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LlamaIndex — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `llamaindex`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://llamaindex/output.schema.json",
  "type": "object",
  "required": ["pipeline_name", "index_kind", "embed_model", "chunk_size", "top_k", "rerank_enabled", "citation_required"],
  "properties": {
    "pipeline_name": {"type": "string"},
    "index_kind": {"enum": ["vector", "property-graph", "hybrid"]},
    "embed_model": {"type": "string"},
    "chunk_size": {"type": "integer", "minimum": 128, "maximum": 4096},
    "top_k": {"type": "integer", "minimum": 1, "maximum": 100},
    "rerank_enabled": {"type": "boolean"},
    "citation_required": {"type": "boolean"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "pipeline_name": "docs-qa",
  "index_kind": "vector",
  "embed_model": "text-embedding-3-small",
  "chunk_size": 512,
  "top_k": 10,
  "rerank_enabled": true,
  "citation_required": true
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "pipeline_name": "",
  "index_kind": "ai",
  "embed_model": "",
  "chunk_size": 5,
  "top_k": 0,
  "rerank_enabled": false,
  "citation_required": false
}
]]></code>
      <note>Invalid: empty fields; bogus index_kind; chunk_size too small; top_k=0; citation off.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-llamaindex.py --self-test exits 0.</item>
    </list>
  </section>
</text>
