<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gemini API Integration — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `gemini-api`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://gemini-api/output.schema.json",
  "type": "object",
  "required": ["model", "safety_settings", "retry_config", "structured_output", "cache_ttl_s"],
  "properties": {
    "model": {"type": "string", "pattern": "^gemini-"},
    "safety_settings": {"type": "object"},
    "retry_config": {"type": "object", "required": ["max_retries", "backoff_base_s"]},
    "structured_output": {"type": "boolean"},
    "cache_ttl_s": {"type": "integer", "minimum": 0}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "model": "gemini-3-flash-001",
  "safety_settings": {
    "HARM_CATEGORY_HARASSMENT": "BLOCK_MEDIUM_AND_ABOVE"
  },
  "retry_config": {
    "max_retries": 5,
    "backoff_base_s": 5
  },
  "structured_output": true,
  "cache_ttl_s": 3600
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "model": "latest",
  "safety_settings": {},
  "retry_config": {},
  "structured_output": false,
  "cache_ttl_s": -1
}
]]></code>
      <note>Invalid: 'latest' model tag; no safety_settings; no retry_config; negative cache TTL.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-gemini-api.py --self-test exits 0.</item>
    </list>
  </section>
</text>
