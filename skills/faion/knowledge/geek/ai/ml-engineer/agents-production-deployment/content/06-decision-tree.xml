<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agents Production Deployment — Decision Tree" version="1.1.0" est_tokens="400">
  <decision-tree>
    <root-question id="q-root">Is the agent within 2 weeks of customer traffic?</root-question>
    <branch when="customer_traffic_imminent == true and all_5_gates_pass == true">
      <conclusion ref="r5-eval-harness">Proceed to production rollout; track SLOs.</conclusion>
    </branch>
    <branch when="customer_traffic_imminent == true and all_5_gates_pass == false">
      <question id="q-sub-1">Which gate is failing?</question>
      <branch when="gate_failing == &apos;typed-tools&apos;">
        <conclusion ref="r1-typed-tools">Refactor tools to typed base; re-audit.</conclusion>
      </branch>
      <branch when="gate_failing == &apos;config&apos;">
        <conclusion ref="r2-config-via-yaml">Centralise into YAML + Config class.</conclusion>
      </branch>
      <branch when="gate_failing == &apos;logs&apos;">
        <conclusion ref="r3-structured-logs">Switch to structured JSON logs.</conclusion>
      </branch>
      <branch when="gate_failing == &apos;retry-circuit&apos;">
        <conclusion ref="r4-retry-circuit">Add tenacity + circuit breaker.</conclusion>
      </branch>
      <branch when="gate_failing == &apos;eval&apos;">
        <conclusion ref="r5-eval-harness">Build eval harness + CI gate.</conclusion>
      </branch>
      <branch when="customer_traffic_imminent == false">
        <conclusion ref="r5-eval-harness">Skip — these gates are overkill pre-customer.</conclusion>
      </branch>
    </branch>
    <example trace="customer_traffic_imminent == true and all_5_gates_pass == true">
      <p>Proceed to production rollout; track SLOs.</p>
    </example>
  </decision-tree>
</text>
