<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI Agent Patterns — Decision Tree" version="1.1.0" est_tokens="400">
  <decision-tree>
    <root-question id="q-root">How deep is the loop and how many distinct roles?</root-question>
    <branch when="loop_depth &lt;= 5 and roles == 1">
      <conclusion ref="r2-default-react">Use ReAct.</conclusion>
    </branch>
    <branch when="loop_depth &gt; 5 and roles == 1">
      <conclusion ref="r3-plan-execute-when-long">Use Plan-Execute.</conclusion>
    </branch>
    <branch when="roles &gt;= 2 and self_correction_needed == true">
      <conclusion ref="r5-multi-agent-when-roles">Use multi-agent with Reflection step.</conclusion>
    </branch>
    <branch when="roles &gt;= 2 and self_correction_needed == false">
      <conclusion ref="r5-multi-agent-when-roles">Use sequential or supervisor multi-agent.</conclusion>
    </branch>
    <example trace="loop_depth &lt;= 5 and roles == 1">
      <p>Use ReAct.</p>
    </example>
  </decision-tree>
</text>
