<text id="02-output-contract" title="Ollama Production Deployment — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the `config` artefact this methodology produces, with one valid and one invalid worked example.</summary>

  <section title="Schema">
    <reference path="scripts/validate-ollama-deployment.py">Mechanical validator wired to this schema.</reference>
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ollama-deployment.json",
  "type": "object",
  "required": [
    "slug",
    "version",
    "date",
    "produces",
    "signature",
    "payload",
    "forbidden_seen"
  ],
  "properties": {
    "slug": {
      "const": "ollama-deployment"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "produces": {
      "const": "config"
    },
    "signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "payload": {
      "type": "object",
      "required": [
        "env",
        "keys"
      ],
      "properties": {
        "env": {
          "type": "string",
          "enum": [
            "dev",
            "staging",
            "prod"
          ]
        },
        "keys": {
          "type": "object"
        }
      }
    },
    "forbidden_seen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "slug": "ollama-deployment",
  "version": "1.0.0",
  "date": "2026-05-22",
  "produces": "config",
  "signature": "94c78c7fd9f816c5",
  "payload": {
    "env": "prod",
    "keys": {
      "timeout": 30
    }
  },
  "forbidden_seen": []
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "slug": "ollama-deployment",
  "version": "v1",
  "date": "today",
  "produces": "config",
  "signature": "tooshort",
  "payload": {
    "TBD": true
  },
  "forbidden_seen": [
    "empty_intent"
  ]
}
]]></code>
      <note>Fails validation: missing required fields and contains forbidden patterns.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Required keys present and typed correctly.</item>
      <item>`forbidden_seen` array empty.</item>
      <item>`signature` matches sha1(slug + version + ISO date)[:16].</item>
      <item>`date` is ISO 8601 (YYYY-MM-DD).</item>
    </list>
  </section>
</text>
