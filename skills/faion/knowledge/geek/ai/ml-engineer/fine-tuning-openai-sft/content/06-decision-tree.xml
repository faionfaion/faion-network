<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="OpenAI Supervised Fine-Tuning (SFT) — Decision Tree" version="1.1.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root">Are both training_file_id and validation_file_id validated and present?</root-question>
    <branch when="training_present == true AND validation_present == true">
      <question id="q-sub">How many training examples?</question>
        <branch when="train_count &lt; 300">
          <conclusion ref="r3-epochs-by-size">n_epochs=5; lr_multiplier=1.0. Small data needs more passes.</conclusion>
        </branch>
        <branch when="train_count between 300 and 10000">
          <conclusion ref="r3-epochs-by-size">n_epochs=3; lr_multiplier=1.0. Default.</conclusion>
        </branch>
        <branch when="train_count &gt; 10000">
          <conclusion ref="r3-epochs-by-size">n_epochs=2; lr_multiplier=1.0. Large data converges fast.</conclusion>
        </branch>
    </branch>
    <branch when="validation_present == false">
      <conclusion ref="r2-validation-file-required">Create a validation split first (per data-prep).</conclusion>
    </branch>
    <example trace="worked-example">
      <p>4200 training rows + 836 val on gpt-4o-mini → 300-10000 branch → n_epochs=3, lr=1.0.</p>
    </example>
  </decision-tree>
</text>
