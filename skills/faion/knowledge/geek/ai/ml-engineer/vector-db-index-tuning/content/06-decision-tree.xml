<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Index Tuning — Decision Tree" version="1.0.0" est_tokens="400" depth="essential">
  <summary>Routes by workload + memory + recall floor to HNSW + quantization combo.</summary>

  <decision-tree>
    <root-question id="q-baseline">Does baseline bench already meet SLA?</root-question>
    <branch when="baseline_meets_sla == true">
      <conclusion ref="r1-bench-before-tune" verdict="STOP — no tuning needed; archive baseline as record"/>
    </branch>
    <branch when="baseline_meets_sla == false">
      <question id="q-workload">Workload class?</question>
      <branch when="workload == 'read-heavy'">
        <conclusion ref="r3-workload-driven-m" verdict="M=32-64, ef_construct=200, sweep ef_search ∈ {64,128,200}"/>
      </branch>
      <branch when="workload == 'balanced'">
        <conclusion ref="r3-workload-driven-m" verdict="M=16-32, ef_construct=128, sweep ef_search ∈ {32,64,128}"/>
      </branch>
      <branch when="workload == 'write-heavy'">
        <conclusion ref="r3-workload-driven-m" verdict="M=16, ef_construct=64, lower-end ef_search"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="baseline fails + read-heavy → tune M=32 + ef_search sweep">
    <code lang="text"><![CDATA[
baseline_meets_sla=false → workload=read-heavy → r3-workload-driven-m verdict applied
]]></code>
  </example>
</text>
