<text id="02-output-contract" title="Embedding Batch+Cache Config Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the batch+cache config artefact. Locks in batch size, parallelism, cache backend + key scheme + TTL, retry, and dedup flag.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/embedding-batch-cache.json",
  "type": "object",
  "required": ["artefact_id", "provider", "batch", "cache", "dedup", "retry", "preserve_order", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^ebc-[a-z0-9-]{6,}$"},
    "provider":    {"enum": ["openai", "voyage", "cohere", "mistral", "local-sentence-transformers"]},
    "model_id":    {"type": "string"},
    "dimension":   {"type": "integer", "minimum": 64, "maximum": 8192},
    "batch": {
      "type": "object",
      "required": ["size", "concurrency"],
      "properties": {
        "size":        {"type": "integer", "minimum": 1, "maximum": 4096},
        "concurrency": {"type": "integer", "minimum": 1, "maximum": 64}
      }
    },
    "cache": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled":     {"type": "boolean"},
        "backend":     {"enum": ["redis", "sqlite", "memory", "none"]},
        "key_scheme":  {"enum": ["sha256-text-model-dim"]},
        "ttl_seconds": {"type": "integer", "minimum": 60, "maximum": 31536000}
      }
    },
    "dedup":           {"type": "boolean"},
    "preserve_order":  {"type": "boolean"},
    "retry": {
      "type": "object",
      "required": ["enabled", "max_attempts", "strategy"],
      "properties": {
        "enabled":      {"type": "boolean"},
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 10},
        "strategy":     {"enum": ["exponential-jitter", "linear", "none"]}
      }
    },
    "rate_budget": {
      "type": "object",
      "properties": {
        "rpm": {"type": "integer", "minimum": 1},
        "tpm": {"type": "integer", "minimum": 1}
      }
    },
    "version":       {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ebc-news-archive",
  "provider": "openai",
  "model_id": "text-embedding-3-small",
  "dimension": 1536,
  "batch": {"size": 2048, "concurrency": 4},
  "cache": {"enabled": true, "backend": "redis", "key_scheme": "sha256-text-model-dim", "ttl_seconds": 2592000},
  "dedup": true,
  "preserve_order": true,
  "retry": {"enabled": true, "max_attempts": 5, "strategy": "exponential-jitter"},
  "rate_budget": {"rpm": 5000, "tpm": 1000000},
  "version": "1.1.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "provider": "openai",
  "batch": {"size": 5000, "concurrency": 0},
  "cache": {"enabled": true, "backend": "redis", "key_scheme": "sha256-text"},
  "dedup": false,
  "preserve_order": false,
  "retry": {"enabled": false, "max_attempts": 0, "strategy": "none"}
}
]]></code>
    <note>batch.size 5000 exceeds OpenAI 2048 limit; concurrency 0 invalid; key_scheme not in enum (rule content-hash-cache-key); dedup=false; preserve_order=false (rule preserve-input-order); retry disabled; missing version + last_reviewed.</note>
  </example>

  <reference path="scripts/validate-embeddings-batch-and-cache.py">Validator enforces this contract.</reference>

</text>
