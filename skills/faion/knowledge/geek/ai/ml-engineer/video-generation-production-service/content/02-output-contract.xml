<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Video Gen Service — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Pins service-config.yaml shape.</summary>

  <output-contract>
    <required>
      <field name="queue" type="object" required_keys="kind,connection"/>
      <field name="workers" type="object" required_keys="count,concurrency"/>
      <field name="providers" type="array" min="2"/>
      <field name="ffmpeg" type="object" required_keys="enabled,operations"/>
      <field name="tenant_quotas" type="object" required_keys="default_monthly_jobs,default_monthly_usd"/>
      <field name="cost_cap" type="object" required_keys="global_monthly_usd,reject_at_pct"/>
      <field name="idempotency" type="object" required_keys="window_hours"/>
    </required>

    <forbidden>
      <pattern id="f1">queue.kind == "in-memory" (r1-persistent-queue)</pattern>
      <pattern id="f2">tenant_quotas.default_monthly_jobs &lt;= 0 (r2-per-tenant-quota)</pattern>
      <pattern id="f3">ffmpeg.enabled == false BUT pipeline declares concat/overlay operations (r3-ffmpeg-post-processing-declared)</pattern>
      <pattern id="f4">cost_cap.reject_at_pct &gt; 100 (r4-cost-cap-pre-submit)</pattern>
      <pattern id="f5">idempotency.window_hours &lt; 1 (r5-idempotent-by-design)</pattern>
      <pattern id="f6">providers length &lt; 2 (no fallback)</pattern>
    </forbidden>

    <schema-reference path="templates/service-config.schema.yaml"/>
  </output-contract>
</text>
