<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vector DB Prod Setup — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Pins prod-deploy.yaml shape.</summary>

  <output-contract>
    <required>
      <field name="deploy_mode" type="enum" values="docker-compose|k8s-statefulset|managed"/>
      <field name="storage" type="object" required_keys="class,size_gb,durable"/>
      <field name="resources" type="object" required_keys="cpu_request,cpu_limit,memory_request_gb,memory_limit_gb"/>
      <field name="ha" type="object" required_keys="strategy,replicas"/>
      <field name="backup" type="object" required_keys="schedule_cron,retention_days,destination,last_restore_drill"/>
      <field name="checklist" type="object" required_keys="pre_deploy_passed,post_deploy_passed"/>
    </required>

    <forbidden>
      <pattern id="f1">storage.durable == false (r1-durable-persistence)</pattern>
      <pattern id="f2">resources.cpu_limit missing OR memory_limit_gb missing (r2-resource-limits)</pattern>
      <pattern id="f3">ha.strategy mismatched with DB class (r3-ha-per-db-class)</pattern>
      <pattern id="f4">backup.last_restore_drill older than 120 days (r4-backup-and-restore-drilled)</pattern>
      <pattern id="f5">checklist.pre_deploy_passed == false (r5-pre-post-deploy-checklist)</pattern>
    </forbidden>

    <schema-reference path="templates/prod-deploy.schema.yaml"/>
  </output-contract>
</text>
