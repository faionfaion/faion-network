<methodology slug="vector-db-setup-prod">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>ml-engineer</domain>
    <summary>Deploy vector databases to production: Docker Compose, Kubernetes StatefulSets, Helm, Terraform, managed services, deployment checklists, HA, and disaster recovery.</summary>
