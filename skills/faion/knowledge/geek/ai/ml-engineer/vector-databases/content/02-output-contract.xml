<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vector Databases — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins vector-db.yaml shape consumed by the connection layer.</summary>

  <output-contract>
    <required>
      <field name="kind" type="enum" values="qdrant|weaviate|milvus|pgvector|pinecone|chroma"/>
      <field name="connection" type="object" required_keys="host"/>
      <field name="collection" type="object" required_keys="name,dim,metric,embedding_model"/>
      <field name="multi_tenant" type="object" required_keys="enabled,filter_field"/>
      <field name="hybrid_search" type="object" required_keys="enabled"/>
    </required>

    <forbidden>
      <pattern id="f1">kind=="chroma" AND serve_mode=="multi-process" (Chroma dev-only)</pattern>
      <pattern id="f2">multi_tenant.enabled=true AND filter_field missing (r3-tenant-filter-required)</pattern>
      <pattern id="f3">collection.metric not in supported set for embedding_model (r5-metric-matches-embedding)</pattern>
      <pattern id="f4">embedding_model missing version pin (r2-pin-embedding-model)</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add new collection — minor bump.</transformation>
      <transformation>Switching embedding model is major bump; forces re-index.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/vector-db.schema.yaml"/>
  </output-contract>
</text>
