    <text id="06-decision-tree" title="Chain of Thought — Decision Tree" version="1.1.0" est_tokens="400">
      <decision-tree>
        <root-question id="q-root">Does the task require multi-step reasoning?</root-question>
        <branch when="multi_step == true and stakes == &apos;high&apos;">
  <conclusion ref="r3-self-consistency-for-stakes">Use extended-thinking + self-consistency N=3-5.</conclusion>
</branch>
<branch when="multi_step == true and stakes == &apos;medium&apos;">
  <conclusion ref="r1-hide-cot">Use zero-shot or few-shot CoT with bounded thinking.</conclusion>
</branch>
<branch when="multi_step == false">
  <conclusion ref="r5-prompt-versioned">Skip CoT; single-shot is enough.</conclusion>
</branch>
        <example trace="multi_step == true and stakes == &apos;high&apos;">
          <p>Use extended-thinking + self-consistency N=3-5.</p>
        </example>
      </decision-tree>
    </text>
