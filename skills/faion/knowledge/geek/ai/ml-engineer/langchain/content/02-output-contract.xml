<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LangChain and LangGraph: Building Production AI Agents — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `langchain`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://langchain/output.schema.json",
  "type": "object",
  "required": ["graph_name", "framework", "state_schema_path", "checkpointer", "nodes", "recursion_limit"],
  "properties": {
    "graph_name": {"type": "string"},
    "framework": {"enum": ["lcel", "langgraph"]},
    "state_schema_path": {"type": "string"},
    "checkpointer": {"enum": ["postgres", "redis", "sqlite", "memory"]},
    "nodes": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "kind"]}},
    "recursion_limit": {"type": "integer", "minimum": 1, "maximum": 100}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "graph_name": "support-triage",
  "framework": "langgraph",
  "state_schema_path": "state/support.py",
  "checkpointer": "postgres",
  "nodes": [
    {
      "name": "classifier",
      "kind": "llm"
    },
    {
      "name": "tool_caller",
      "kind": "tool"
    },
    {
      "name": "human_approval",
      "kind": "interrupt"
    }
  ],
  "recursion_limit": 25
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "graph_name": "",
  "framework": "lcel",
  "state_schema_path": "",
  "checkpointer": "memory",
  "nodes": [],
  "recursion_limit": 0
}
]]></code>
      <note>Invalid: LCEL chosen for a stateful flow; no state schema; memory checkpointer in production; no nodes; recursion_limit &lt; 1.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-langchain.py --self-test exits 0.</item>
    </list>
  </section>
</text>
