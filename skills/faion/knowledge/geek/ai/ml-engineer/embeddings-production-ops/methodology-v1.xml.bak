<methodology slug="embeddings-production-ops">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>ml-engineer</domain>
    <summary>Production operations for embedding systems: latency SLOs, scalability patterns, monitoring, debugging poor retrieval and dimension mismatches, cost analysis, and model migration.</summary>
    <tags>
      <tag>embeddings</tag>
      <tag>production</tag>
      <tag>monitoring</tag>
      <tag>debugging</tag>
      <tag>cost-optimization</tag>
    </tags>
    <category>embeddings</category>
    <difficulty>advanced</difficulty>
    <created>2026-04-27</created>
    <languages>
      <language>python</language>
    </languages>
