<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vector DB Monitoring — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins `monitoring.yaml` shape consumed by Prometheus / Grafana / on-call infra.</summary>

  <output-contract>
    <required>
      <field name="metrics" type="array" min="4"/>
      <field name="metrics[].name" type="string"/>
      <field name="metrics[].pillar" type="enum" values="latency|error|memory|disk"/>
      <field name="metrics[].slo" type="object" required_keys="target"/>
      <field name="alerts" type="array" min="1"/>
      <field name="alerts[].severity" type="enum" values="page|ticket"/>
      <field name="alerts[].runbook_url" type="string"/>
      <field name="capacity" type="object" required_keys="forecast_window_days,alert_when_lt_days"/>
      <field name="dashboard" type="object" required_keys="slo_overlay"/>
    </required>

    <forbidden>
      <pattern id="f1">missing any of the 4 pillar metrics (r1-four-pillar-coverage)</pattern>
      <pattern id="f2">alerts[].runbook_url missing (r5-runbook-link-required)</pattern>
      <pattern id="f3">dashboard.slo_overlay==false (r4-slo-panel-on-dashboard)</pattern>
      <pattern id="f4">capacity.alert_when_lt_days &lt; 14 (insufficient lead time, r3-capacity-baseline)</pattern>
    </forbidden>

    <schema-reference path="templates/monitoring.schema.yaml"/>
  </output-contract>
</text>
