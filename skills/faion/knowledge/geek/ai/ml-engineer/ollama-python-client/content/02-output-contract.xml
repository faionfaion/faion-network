<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Ollama Python Client Patterns — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the `code` artefact this methodology produces, with one valid and one invalid worked example.</summary>

  <section title="Schema">
    <reference path="scripts/validate-ollama-python-client.py">Mechanical validator wired to this schema.</reference>
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ollama-python-client.json",
  "type": "object",
  "required": [
    "slug",
    "version",
    "date",
    "produces",
    "signature",
    "payload",
    "forbidden_seen"
  ],
  "properties": {
    "slug": {
      "const": "ollama-python-client"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "produces": {
      "const": "code"
    },
    "signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "payload": {
      "type": "object",
      "required": [
        "language",
        "entry_point",
        "files"
      ],
      "properties": {
        "language": {
          "type": "string"
        },
        "entry_point": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "purpose"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "purpose": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "forbidden_seen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "slug": "ollama-python-client",
  "version": "1.0.0",
  "date": "2026-05-22",
  "produces": "code",
  "signature": "46f2d7aa252cec9c",
  "payload": {
    "language": "python",
    "entry_point": "skeleton.py",
    "files": [
      {
        "path": "skeleton.py",
        "purpose": "main module"
      }
    ]
  },
  "forbidden_seen": []
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "slug": "ollama-python-client",
  "version": "v1",
  "date": "today",
  "produces": "code",
  "signature": "tooshort",
  "payload": {
    "TBD": true
  },
  "forbidden_seen": [
    "empty_intent"
  ]
}
]]></code>
      <note>Fails validation: missing required fields and contains forbidden patterns.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Required keys present and typed correctly.</item>
      <item>`forbidden_seen` array empty.</item>
      <item>`signature` matches sha1(slug + version + ISO date)[:16].</item>
      <item>`date` is ISO 8601 (YYYY-MM-DD).</item>
    </list>
  </section>
</text>
