<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MCP Development Prompts — Server, Debug, Architecture, Testing — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `mcp-dev-prompts`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://mcp-dev-prompts/output.schema.json",
  "type": "object",
  "required": ["library_name", "prompts", "versioning_policy", "storage_path"],
  "properties": {
    "library_name": {"type": "string"},
    "prompts": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "version", "purpose", "model"]}},
    "versioning_policy": {"enum": ["semver", "date_stamped"]},
    "storage_path": {"type": "string"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "library_name": "mcp-dev-prompts-v1",
  "prompts": [
    {
      "id": "server.create",
      "version": "1.0.0",
      "purpose": "scaffold MCP server",
      "model": "sonnet"
    },
    {
      "id": "debug.connection",
      "version": "1.0.0",
      "purpose": "diagnose connect failure",
      "model": "opus"
    }
  ],
  "versioning_policy": "semver",
  "storage_path": "prompts/mcp/"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "library_name": "",
  "prompts": [],
  "versioning_policy": "yolo",
  "storage_path": ""
}
]]></code>
      <note>Invalid: empty fields; no prompts; bogus versioning policy; no storage path.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-mcp-dev-prompts.py --self-test exits 0.</item>
    </list>
  </section>
</text>
