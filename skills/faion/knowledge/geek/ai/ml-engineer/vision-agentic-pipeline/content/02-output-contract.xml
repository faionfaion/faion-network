<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vision Agentic Pipeline — Production Architecture Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the vision-agentic-pipeline artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/vision-agentic-pipeline.json",
  "type": "object",
  "required": [
    "pipeline_id",
    "image_hash",
    "doc_type",
    "validation_status"
  ],
  "properties": {
    "pipeline_id": {
      "type": "string"
    },
    "image_hash": {
      "type": "string"
    },
    "doc_type": {
      "type": "string"
    },
    "extracted": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_status": {
      "type": "string"
    },
    "validator_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pipeline_id": "example-pipeline_id",
  "image_hash": "example-image_hash",
  "doc_type": "example-doc_type",
  "extracted": {
    "k": "v"
  },
  "validation_status": "example-validation_status",
  "validator_errors": [
    "a",
    "b"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pipeline_id": 123
}
]]></code>
    <note>field "pipeline_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-vision-agentic-pipeline.py">schema validator</reference>
</text>
