<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="LLM Decision Framework — Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure for applying `llm-decision-framework`. Each step lists input artifact, action, output artifact. Decision gates live in content/06-decision-tree.xml.</summary>

  <section title="Procedure">
    <step n="1" name="gather-constraints">
      <input>Stakeholders + ops.</input>
      <action>Document accuracy/freshness/budget/latency/team in constraints.yaml.</action>
      <output>Constraints sheet.</output>
    </step>

    <step n="2" name="score-prompting">
      <input>Sample queries + best-effort prompt.</input>
      <action>Run baseline on Sonnet/Haiku; record metric.</action>
      <output>scores.prompt.</output>
    </step>

    <step n="3" name="score-rag">
      <input>Same queries + cheap RAG stub.</input>
      <action>Run; record metric.</action>
      <output>scores.rag.</output>
    </step>

    <step n="4" name="score-ft">
      <input>Estimate or run thin FT.</input>
      <action>Estimate from r4-technique-by-budget; record metric.</action>
      <output>scores.fine_tune.</output>
    </step>

    <step n="5" name="pick-and-write-adr">
      <input>All scores + constraints.</input>
      <action>Walk decision tree; write ADR with chosen + alternatives + rationale.</action>
      <output>ADR-NNN.md.</output>
    </step>
  </section>
</text>
