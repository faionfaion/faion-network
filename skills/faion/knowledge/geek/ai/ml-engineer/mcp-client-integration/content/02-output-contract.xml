<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MCP Client Integration — Agents, Claude Code, Host Configuration — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `mcp-client-integration`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://mcp-client-integration/output.schema.json",
  "type": "object",
  "required": ["client_name", "host_type", "servers", "consent_policy", "audit_log_path"],
  "properties": {
    "client_name": {"type": "string"},
    "host_type": {"enum": ["claude_desktop", "vscode", "claude_sdk_custom"]},
    "servers": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name", "transport"]}},
    "consent_policy": {"enum": ["per_call", "per_session", "always_allow_listed_only"]},
    "audit_log_path": {"type": "string"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "client_name": "support-agent-mcp",
  "host_type": "claude_sdk_custom",
  "servers": [
    {
      "name": "filesystem",
      "transport": "stdio"
    },
    {
      "name": "github",
      "transport": "stdio"
    }
  ],
  "consent_policy": "per_session",
  "audit_log_path": "logs/mcp-audit.jsonl"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "client_name": "",
  "host_type": "x",
  "servers": [],
  "consent_policy": "always_allow_anything",
  "audit_log_path": ""
}
]]></code>
      <note>Invalid: empty name; bogus host; no servers; unsafe consent policy; no audit log.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-mcp-client-integration.py --self-test exits 0.</item>
    </list>
  </section>
</text>
