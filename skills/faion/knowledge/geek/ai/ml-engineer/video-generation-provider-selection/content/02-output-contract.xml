<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Video Generation Provider Selection Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the video-generation-provider-selection artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/video-generation-provider-selection.json",
  "type": "object",
  "required": [
    "decision_id",
    "selected_provider",
    "budget_usd_month",
    "fallback_provider",
    "expected_volume"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "selected_provider": {
      "type": "string"
    },
    "required_capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budget_usd_month": {
      "type": "number"
    },
    "fallback_provider": {
      "type": "string"
    },
    "expected_volume": {
      "type": "integer"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "decision_id": "example-decision_id",
  "selected_provider": "example-selected_provider",
  "required_capabilities": [
    "a",
    "b"
  ],
  "budget_usd_month": 1.0,
  "fallback_provider": "example-fallback_provider",
  "expected_volume": 1
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "decision_id": 123
}
]]></code>
    <note>field "decision_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-video-generation-provider-selection.py">schema validator</reference>
</text>
