<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Text-to-Speech — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins `tts-config.yaml` shape consumed by the TTS service module.</summary>

  <output-contract>
    <required>
      <field name="provider" type="enum" values="openai|elevenlabs|google|azure|deepgram|local-coqui"/>
      <field name="model" type="string"/>
      <field name="voice" type="object" required_keys="id,clone_consent"/>
      <field name="cache" type="object" required_keys="enabled"/>
      <field name="fallback" type="object" required_keys="provider"/>
    </required>

    <forbidden>
      <pattern id="f1">voice.clone_consent==false for any custom-cloned voice id (r2-voice-cloning-consent)</pattern>
      <pattern id="f2">cache.enabled==false in production (r3-cache-by-text-hash)</pattern>
      <pattern id="f3">fallback.provider == provider (r5-fallback-mandatory)</pattern>
      <pattern id="f4">use_case=="real-time" AND streaming=false (r4-streaming-for-real-time)</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Switch voice id is patch bump if same provider and consent recorded.</transformation>
      <transformation>Switch provider is major bump (latency / quality may shift).</transformation>
    </allowed-transformations>

    <schema-reference path="templates/tts-config.schema.yaml"/>
  </output-contract>
</text>
