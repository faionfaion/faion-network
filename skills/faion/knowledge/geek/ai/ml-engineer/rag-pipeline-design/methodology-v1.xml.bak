<methodology slug="rag-pipeline-design">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>ml-engineer</domain>
    <summary>Production RAG architecture: hybrid search, reranking, chunking strategy matrix, agentic retrieval loops. Four tiers: Naive, Advanced, Modular, Agentic.</summary>
    <tags>
      <tag>rag</tag>
      <tag>pipeline</tag>
      <tag>architecture</tag>
