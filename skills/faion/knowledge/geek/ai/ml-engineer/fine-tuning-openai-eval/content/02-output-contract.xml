<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OpenAI Fine-Tuning Evaluation — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `fine-tuning-openai-eval`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://fine-tuning-openai-eval/output.schema.json",
  "type": "object",
  "required": ["ft_model_id", "base_model_id", "eval_set_path", "eval_count", "metrics", "gate_decision"],
  "properties": {
    "ft_model_id": {"type": "string", "pattern": "^ft:"},
    "base_model_id": {"type": "string"},
    "eval_set_path": {"type": "string"},
    "eval_count": {"type": "integer", "minimum": 200},
    "metrics": {"type": "array", "minItems": 2, "items": {"type": "object", "required": ["name", "ft_score", "base_score", "delta", "ci", "passed"]}},
    "gate_decision": {"enum": ["pass", "fail", "hold"]}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "ft_model_id": "ft:gpt-4o-mini:org::abc",
  "base_model_id": "gpt-4o-mini",
  "eval_set_path": "data/eval.jsonl",
  "eval_count": 300,
  "metrics": [
    {
      "name": "accuracy",
      "ft_score": 0.88,
      "base_score": 0.68,
      "delta": 0.2,
      "ci": "\u00b10.04",
      "passed": true
    },
    {
      "name": "format_compliance",
      "ft_score": 0.99,
      "base_score": 0.84,
      "delta": 0.15,
      "ci": "\u00b10.02",
      "passed": true
    }
  ],
  "gate_decision": "pass"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "ft_model_id": "gpt-4o-mini",
  "base_model_id": "",
  "eval_set_path": "",
  "eval_count": 50,
  "metrics": [],
  "gate_decision": "yolo"
}
]]></code>
      <note>Invalid: ft_model_id missing ft: prefix; eval_count &lt; 200; no metrics; bogus gate.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-fine-tuning-openai-eval.py --self-test exits 0.</item>
    </list>
  </section>
</text>
