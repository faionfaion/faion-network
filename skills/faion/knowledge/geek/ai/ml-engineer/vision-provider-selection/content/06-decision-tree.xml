<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Vision Language Model Provider Selection Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Does the task require &gt;200K-token context (long video, multi-doc) ?</root-question>
    <branch when="context_tokens &gt; 200000">
      <conclusion ref="gemini-when" verdict="apply rule gemini-when"/>
    </branch>
    <branch when="structured_output_required == true AND tool_use_required == true">
      <conclusion ref="gpt4o-when" verdict="apply rule gpt4o-when"/>
    </branch>
    <branch when="long_pdf_ocr_priority == true">
      <conclusion ref="claude-when" verdict="apply rule claude-when"/>
    </branch>
    <branch when="self_host_required == true OR fine_tune_required == true">
      <conclusion ref="open-vlm-when" verdict="apply rule open-vlm-when"/>
    </branch>
  </decision-tree>
</text>
