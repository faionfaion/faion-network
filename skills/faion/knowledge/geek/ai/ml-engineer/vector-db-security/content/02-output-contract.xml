<text id="02-output-contract" title="Vector DB Security — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins security-config.yaml shape.</summary>

  <output-contract>
    <required>
      <field name="auth" type="object" required_keys="method,enabled"/>
      <field name="tls" type="object" required_keys="enabled,min_version"/>
      <field name="network" type="object" required_keys="binding,public_internet_exposed"/>
      <field name="encryption_at_rest" type="object" required_keys="enabled"/>
      <field name="audit" type="object" required_keys="enabled,sink"/>
      <field name="pii" type="object" required_keys="detection,redaction,retention_days,erasure_sla_hours"/>
    </required>

    <forbidden>
      <pattern id="f1">auth.enabled==false (r1-no-anonymous)</pattern>
      <pattern id="f2">tls.enabled==false OR tls.min_version &lt; "1.2" (r2-tls-everywhere)</pattern>
      <pattern id="f3">network.public_internet_exposed==true (r3-private-network-only)</pattern>
      <pattern id="f4">audit.enabled==false (r4-audit-every-admin-call)</pattern>
      <pattern id="f5">pii.erasure_sla_hours &gt; 720 (GDPR Art 17 imposes &lt;30d)</pattern>
    </forbidden>

    <schema-reference path="templates/security-config.schema.yaml"/>
  </output-contract>
</text>
