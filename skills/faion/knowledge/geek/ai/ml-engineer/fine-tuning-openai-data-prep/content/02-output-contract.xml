<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OpenAI Fine-Tuning Data Preparation — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `fine-tuning-openai-data-prep`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://fine-tuning-openai-data-prep/output.schema.json",
  "type": "object",
  "required": ["dataset_name", "format", "train_path", "val_path", "train_count", "val_count", "token_budget", "pii_scrubbed"],
  "properties": {
    "dataset_name": {"type": "string", "minLength": 3},
    "format": {"enum": ["chat", "completion", "dpo"]},
    "train_path": {"type": "string", "pattern": "\\.jsonl$"},
    "val_path": {"type": "string", "pattern": "\\.jsonl$"},
    "train_count": {"type": "integer", "minimum": 10},
    "val_count": {"type": "integer", "minimum": 5},
    "token_budget": {"type": "object", "required": ["total_tokens", "estimated_usd"]},
    "pii_scrubbed": {"type": "boolean"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "dataset_name": "support-tone-v1",
  "format": "chat",
  "train_path": "data/train.jsonl",
  "val_path": "data/val.jsonl",
  "train_count": 3360,
  "val_count": 840,
  "token_budget": {
    "total_tokens": 540000,
    "estimated_usd": 12.5
  },
  "pii_scrubbed": true
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "dataset_name": "",
  "format": "yolo",
  "train_path": "x",
  "val_path": "x",
  "train_count": 5,
  "val_count": 0,
  "token_budget": {},
  "pii_scrubbed": false
}
]]></code>
      <note>Invalid: empty name, bogus format, paths not .jsonl, counts below floors, empty token_budget, PII not scrubbed.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-fine-tuning-openai-data-prep.py --self-test exits 0.</item>
    </list>
  </section>
</text>
