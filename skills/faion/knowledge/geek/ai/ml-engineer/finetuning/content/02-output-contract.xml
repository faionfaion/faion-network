<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LLM Fine-tuning (General Guide) — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `finetuning`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://finetuning/output.schema.json",
  "type": "object",
  "required": ["model_target", "technique", "framework", "data_volume", "baseline_scores", "eval_gate_passed", "rollback_owner"],
  "properties": {
    "model_target": {"type": "string"},
    "technique": {"enum": ["full-ft", "lora", "qlora", "dora", "api-sft", "api-dpo"]},
    "framework": {"enum": ["trl", "axolotl", "llama-factory", "unsloth", "torchtune", "openai-api"]},
    "data_volume": {"type": "integer", "minimum": 100},
    "baseline_scores": {"type": "object"},
    "eval_gate_passed": {"type": "boolean"},
    "rollback_owner": {"type": "string", "minLength": 3}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "model_target": "mistral-7b-tone",
  "technique": "qlora",
  "framework": "axolotl",
  "data_volume": 4200,
  "baseline_scores": {
    "prompt_only": 0.61,
    "rag": 0.68
  },
  "eval_gate_passed": true,
  "rollback_owner": "ml-lead:bob"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "model_target": "",
  "technique": "magic",
  "framework": "?",
  "data_volume": 12,
  "baseline_scores": {},
  "eval_gate_passed": false,
  "rollback_owner": "team"
}
]]></code>
      <note>Invalid: bogus technique/framework; data_volume below floor; empty model_target; rollback_owner is team.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No TBD / placeholder strings in any required field.</item>
      <item>scripts/validate-finetuning.py --self-test exits 0.</item>
    </list>
  </section>
</text>
