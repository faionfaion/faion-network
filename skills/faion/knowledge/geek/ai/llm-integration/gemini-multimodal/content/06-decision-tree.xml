<text id="06-decision-tree" title="Gemini Multimodal Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Does the input contain any non-text modality (image / audio / video / PDF)?</root-question>
    <branch when="modality.is_multimodal == true AND vendor == 'gemini'">
      <question>Is the total non-text payload ≤ 4 MB AND only images?</question>
      <branch when="size.under_4mb == true AND modality == 'image'">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="size.under_4mb == false OR modality != 'image'">
        <conclusion ref="r1"/>
      </branch>
    </branch>
    <branch when="modality.is_multimodal == false OR vendor != 'gemini'">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="MP4 video, 80MB → r1 (Files API path)"/>
  </decision-tree>
</text>
