<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gemini Multimodal Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>JSON Schema for multimodal-config.json.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/gemini-multimodal-config",
  "type": "object",
  "required": ["inline_limit_mb", "files_api", "modality"],
  "properties": {
    "inline_limit_mb": {"type": "number", "minimum": 0, "maximum": 4},
    "modality": {"enum": ["image", "audio", "video", "pdf", "mixed"]},
    "files_api": {
      "type": "object",
      "required": ["enabled", "poll_timeout_s", "ttl_hours"],
      "properties": {
        "enabled": {"type": "boolean"},
        "poll_timeout_s": {"type": "integer", "minimum": 1, "maximum": 600},
        "ttl_hours": {"type": "integer", "minimum": 1, "maximum": 48}
      }
    },
    "context_cache": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "min_tokens": {"type": "integer", "minimum": 32768},
        "ttl_hours": {"type": "integer", "minimum": 1}
      }
    }
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "inline_limit_mb": 4,
  "modality": "video",
  "files_api": {"enabled": true, "poll_timeout_s": 300, "ttl_hours": 48},
  "context_cache": {"enabled": true, "min_tokens": 32768, "ttl_hours": 24}
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"inline_limit_mb": 50, "modality": "video", "files_api": {"enabled": false}}]]></code>
      <note>Fails: inline_limit_mb &gt;4 (use Files API for video), missing required fields, files_api disabled for video.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>inline_limit_mb ≤ 4.</item>
      <item>files_api.enabled = true when modality ∈ {audio, video, pdf} or size &gt;4MB.</item>
      <item>poll_timeout_s reasonable for media size (≥60 for video).</item>
      <item>ttl_hours ≤ 48 (vendor limit).</item>
      <item>context_cache.min_tokens ≥ 32768 when enabled.</item>
    </list>
  </section>
</text>
