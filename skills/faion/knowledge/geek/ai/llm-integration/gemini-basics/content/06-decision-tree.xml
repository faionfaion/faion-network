<text id="06-decision-tree" title="Gemini Basics Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is this a starter Gemini integration (no function calling, no multimodal, no Vertex enterprise)?</root-question>
    <branch when="features.needed == 'starter-only'">
      <conclusion ref="run-the-checklist"/>
    </branch>
    <branch when="features.needed.includes('function-calling')">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="features.needed.includes('multimodal')">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="features.needed.includes('vertex-enterprise')">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new project doing text classification with Gemini → run-the-checklist"/>
  </decision-tree>
</text>
