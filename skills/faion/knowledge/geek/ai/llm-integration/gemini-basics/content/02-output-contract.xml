<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gemini Basics Output Contract" version="1.0.0" est_tokens="500" depth="essential">
  <summary>JSON Schema for the starter gemini-config-basic.json.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/gemini-config-basic",
  "type": "object",
  "required": ["model", "temperature", "max_output_tokens"],
  "properties": {
    "model": {"type": "string", "pattern": "^gemini-.+-\\d+|^gemini-\\d+\\.\\d+"},
    "temperature": {"type": "number", "minimum": 0, "maximum": 2},
    "max_output_tokens": {"type": "integer", "minimum": 1, "maximum": 65536},
    "response_mime_type": {"enum": ["text/plain", "application/json"]},
    "streaming": {"type": "boolean"}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "model": "gemini-2.5-flash",
  "temperature": 0.3,
  "max_output_tokens": 1024,
  "response_mime_type": "text/plain",
  "streaming": false
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"model": "gemini-pro", "temperature": 3, "max_output_tokens": 100000}]]></code>
      <note>Fails: unversioned model alias, temperature out of range, max_output_tokens beyond limit.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Model includes version/date suffix.</item>
      <item>Temperature ∈ [0, 2].</item>
      <item>max_output_tokens within Gemini limit.</item>
      <item>response_mime_type set when JSON output expected.</item>
    </list>
  </section>
</text>
