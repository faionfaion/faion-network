<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Failure Mode Taxonomy Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a AI Failure Mode Taxonomy deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="version" format="semver" />
      <field name="labels" type="list" min="3" schema="{name,definition,detector,remediation,examples}" />
      <field name="instances_classified" type="list" schema="{instance_id,primary_label,secondary_tags,evidence}" />
    </required>
    <forbidden>
      <pattern id="f1">multi-primary labels</pattern>
      <pattern id="f2">ad-hoc labels not in the versioned set</pattern>
      <pattern id="f3">label without remediation lane</pattern>
      <pattern id="f4">destructive re-tagging (overwrite without history)</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Append new labels only after ≥3 justifying instances.</transformation>
      <transformation>Re-classify with prior_label preserved.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Single primary label per instance</item>
      <item>Every label has remediation</item>
      <item>Re-classifications append, not overwrite</item>
      <item>Version stamped</item>
    </list>
  </section>
</text>
