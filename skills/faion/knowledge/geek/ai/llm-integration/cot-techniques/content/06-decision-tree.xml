<text id="06-decision-tree" title="CoT Techniques Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is zero-shot CoT failure rate &gt; 10% AND budget supports an Nx-cost technique?</root-question>
    <branch when="baseline_failure_rate &gt; 0.10 AND budget.allows_nx == true">
      <question>What is the dominant failure shape?</question>
      <branch when="failure.shape == 'noisy-random'">
        <conclusion ref="r5"/>
      </branch>
      <branch when="failure.shape == 'sequential-dependency'">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="failure.shape == 'branching-design'">
        <conclusion ref="r6"/>
      </branch>
      <branch when="failure.shape == 'format-issues'">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
    <branch when="baseline_failure_rate &lt;= 0.10 OR budget.allows_nx == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="math benchmark, baseline 65% acc, budget allows 5x → self-consistency"/>
  </decision-tree>
</text>
