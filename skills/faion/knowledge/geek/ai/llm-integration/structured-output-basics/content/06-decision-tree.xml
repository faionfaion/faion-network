    <?xml version="1.0" encoding="UTF-8"?>
    <text id="06-decision-tree" title="Structured Output Basics — Decision Tree" version="1.1.0" est_tokens="400">
      <decision-tree>
        <root-question id="q-root">Does the provider support response_format=json_schema or tool-as-schema?</root-question>
        <branch when="provider_supports_native_schema == true and stakes == &apos;high&apos;">
  <conclusion ref="r5-strict-when-stakes-high">Use strict=true + Pydantic validation + 1-shot retry.</conclusion>
</branch>
<branch when="provider_supports_native_schema == true and stakes == &apos;low&apos;">
  <conclusion ref="r2-provider-native">Use json_schema mode without strict + 1-shot retry.</conclusion>
</branch>
<branch when="provider_supports_native_schema == false">
  <conclusion ref="r3-validate-on-receipt">Use JSON mode + Pydantic validation + 1-shot retry-with-error.</conclusion>
</branch>
        <example trace="provider_supports_native_schema == true and stakes == &apos;high&apos;">
          <p>Use strict=true + Pydantic validation + 1-shot retry.</p>
        </example>
      </decision-tree>
    </text>
