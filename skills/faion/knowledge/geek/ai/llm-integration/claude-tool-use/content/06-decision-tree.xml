<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Claude Tool Use Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is the target model from the Claude family (Anthropic) AND does the task require ≥1 external function call?</root-question>
    <branch when="model.family == 'claude' AND tools.needed &gt;= 1">
      <question>Is the number of distinct tools ≤ 20 AND is non-streaming response acceptable?</question>
      <branch when="tools.count &lt;= 20 AND streaming.required == false">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="tools.count &gt; 20">
        <conclusion ref="r1"/>
      </branch>
      <branch when="streaming.required == true">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="model.family != 'claude' OR tools.needed == 0">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="Claude sonnet + 5 tools + non-streaming → run-the-checklist"/>
  </decision-tree>
</text>
