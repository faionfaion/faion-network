    <text id="06-decision-tree" title="Structured Output Patterns — Decision Tree" version="1.1.0" est_tokens="400">
      <decision-tree>
        <root-question id="q-root">How many structured-output endpoints are in production?</root-question>
        <branch when="endpoint_count &gt;= 3 and need_metrics == true">
  <conclusion ref="r1-service-abstraction">Centralise into StructuredOutputService.</conclusion>
</branch>
<branch when="endpoint_count &gt;= 3 and need_metrics == false">
  <conclusion ref="r2-metrics-required">Add metrics first; then centralise.</conclusion>
</branch>
<branch when="endpoint_count &lt; 3">
  <conclusion ref="r1-service-abstraction">Skip this methodology — use structured-output-basics until endpoint count grows.</conclusion>
</branch>
        <example trace="endpoint_count &gt;= 3 and need_metrics == true">
          <p>Centralise into StructuredOutputService.</p>
        </example>
      </decision-tree>
    </text>
