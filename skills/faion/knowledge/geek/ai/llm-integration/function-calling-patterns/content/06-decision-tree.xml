<text id="06-decision-tree" title="Function Calling Patterns Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Which LLM vendor and is ≥1 function call required?</root-question>
    <branch when="vendor == 'anthropic' AND tools.count &gt;= 1">
      <conclusion ref="r6"/>
    </branch>
    <branch when="vendor == 'openai' AND tools.count &gt;= 1">
      <conclusion ref="run-the-checklist"/>
    </branch>
    <branch when="vendor == 'gemini' AND tools.count &gt;= 1">
      <conclusion ref="r6"/>
    </branch>
    <branch when="tools.count == 0">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="OpenAI + 8 tools → run-the-checklist"/>
  </decision-tree>
</text>
