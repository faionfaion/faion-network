<text id="06-decision-tree" title="Local LLM Ollama Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Does privacy OR per-token cost dominate the decision?</root-question>
    <branch when="constraint.privacy_or_cost_dominant == true">
      <question>Does the host have RAM ≥ floor(model_size)?</question>
      <branch when="host.ram_gb &gt;= model.ram_floor_gb">
        <question>Does the local model clear the gold-eval bar?</question>
        <branch when="eval.local_passes_bar == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="eval.local_passes_bar == false">
          <conclusion ref="skip-this-methodology"/>
        </branch>
      </branch>
      <branch when="host.ram_gb &lt; model.ram_floor_gb">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="constraint.privacy_or_cost_dominant == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="privacy-sensitive classifier + 16GB host + llama3.1:8b passes eval → run-the-checklist"/>
  </decision-tree>
</text>
