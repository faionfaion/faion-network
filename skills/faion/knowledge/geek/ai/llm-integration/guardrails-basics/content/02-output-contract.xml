<text id="02-output-contract" title="Guardrails Basics Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>JSON Schema for guardrails-spec.json.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/guardrails-basic-spec",
  "type": "object",
  "required": ["layers", "fail_closed", "latency_budget_ms"],
  "properties": {
    "layers": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["type", "kind", "order"],
        "properties": {
          "type": {"enum": ["regex_filter", "length_cap", "output_schema", "llm_classifier"]},
          "kind": {"enum": ["input", "output", "both"]},
          "order": {"type": "integer", "minimum": 1}
        }
      }
    },
    "fail_closed": {"type": "boolean", "const": true},
    "latency_budget_ms": {"type": "integer", "minimum": 50, "maximum": 2000}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "layers": [
    {"type": "regex_filter", "kind": "input", "order": 1},
    {"type": "length_cap", "kind": "both", "order": 2},
    {"type": "output_schema", "kind": "output", "order": 3},
    {"type": "llm_classifier", "kind": "both", "order": 4}
  ],
  "fail_closed": true,
  "latency_budget_ms": 900
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"layers": [{"type":"llm_classifier","kind":"both","order":1}], "fail_closed": false, "latency_budget_ms": 5000}]]></code>
      <note>Fails: &lt;4 layers, classifier first (order 1), fail_closed false, latency budget &gt;2000.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>≥4 layers.</item>
      <item>order values strictly increasing.</item>
      <item>llm_classifier has the highest order.</item>
      <item>fail_closed = true.</item>
      <item>latency_budget_ms ≤ 2000.</item>
    </list>
  </section>
</text>
