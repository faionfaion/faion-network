<text id="06-decision-tree" title="Guardrails Implementation Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is the app public-facing AND latency_budget_ms &gt;= 500?</root-question>
    <branch when="exposure.public_output == true AND latency.budget_ms &gt;= 500">
      <question>Are independent checks present (PII, injection, moderation)?</question>
      <branch when="checks.count &gt;= 2">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="checks.count &lt; 2">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="exposure.public_output == false OR latency.budget_ms &lt; 500">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="public chatbot with 800ms budget + 3 independent checks → run-the-checklist (with async fan-out)"/>
  </decision-tree>
</text>
