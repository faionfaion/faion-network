{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/llm-classifier-config",
  "title": "llm-classifier-config",
  "_purpose": "Schema for a llm-classifier-config JSON; ensures forced tool, byte-stable prefix, batch caps.",
  "_consumes": "classifier-config.json from caller",
  "_produces": "validation report for validate-llm-classifier-design.py",
  "_depends_on": "content/01-core-rules.xml r2-r6",
  "_token_budget_impact": "0 — schema-only file",
  "type": "object",
  "required": ["model", "tool_name", "tool_choice", "system_prompt", "batch_size", "max_turns"],
  "properties": {
    "model": {"type": "string"},
    "tool_name": {"type": "string", "minLength": 1},
    "tool_choice": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {"const": "tool"},
        "name": {"type": "string"}
      }
    },
    "system_prompt": {"type": "string", "minLength": 10},
    "setting_sources": {"type": "array", "maxItems": 0},
    "allowed_tools": {"type": "array", "minItems": 1, "maxItems": 1},
    "batch_size": {"type": "integer", "minimum": 1, "maximum": 15},
    "max_turns": {"type": "integer", "minimum": 2}
  }
}
