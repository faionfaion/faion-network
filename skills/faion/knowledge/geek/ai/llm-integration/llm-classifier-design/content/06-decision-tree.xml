<text id="06-decision-tree" title="LLM Classifier Design Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Is the answer a fixed shape (boolean / enum ≤10 / fixed-keys object)?</root-question>
    <branch when="answer_shape.is_fixed == true">
      <question>Does the eval bar require multi-step reasoning?</question>
      <branch when="reasoning.multi_step_required == true">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="reasoning.multi_step_required == false">
        <question>Will N items per run &gt;= 50 (batching worthwhile)?</question>
        <branch when="run_size.items &gt;= 50">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="run_size.items &lt; 50">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
    <branch when="answer_shape.is_fixed == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="binary spam triage on 5000 items → run-the-checklist (Haiku, batch=10, forced tool)"/>
  </decision-tree>
</text>
