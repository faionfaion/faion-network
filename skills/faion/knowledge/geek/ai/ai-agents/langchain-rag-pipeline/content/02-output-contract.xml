<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="langchain-rag-pipeline Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for langchain-rag-pipeline. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "langchain-rag-pipeline"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["loader", "splitter", "chunk_size", "embedding_model", "vectorstore", "retriever_k", "prompt_template"],
      "properties": {
        "loader": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "splitter": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "chunk_size": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "embedding_model": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "vectorstore": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "retriever_k": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "prompt_template": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["doc_count", "avg_doc_chars", "query_pattern", "latency_budget_ms"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "langchain-rag-pipeline",
  "version": "2.0.0",
  "decision": {"loader": "TODO", "splitter": "TODO", "chunk_size": "TODO", "embedding_model": "TODO", "vectorstore": "TODO", "retriever_k": "TODO", "prompt_template": "TODO"},
  "drivers": {"doc_count": "val", "avg_doc_chars": "val", "query_pattern": "val", "latency_budget_ms": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "langchain-rag-pipeline",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "loader", "splitter", "chunk_size", "embedding_model", "vectorstore", "retriever_k", "prompt_template".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
