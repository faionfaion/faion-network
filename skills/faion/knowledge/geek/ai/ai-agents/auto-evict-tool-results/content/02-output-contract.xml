<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Auto-Evict Tool Results Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Two contracts pinned: (1) the eviction config; (2) the evicted-pointer shape the LLM sees.</summary>

  <output-contract>
    <required>
      <field name="threshold_n_tokens" type="integer" required="true">≥1; default 20000</field>
      <field name="scratch_path" type="string" required="true">URL or local path</field>
      <field name="preview_chars" type="integer" required="true">size of preview kept inline</field>
      <field name="read_tool_name" type="string" required="true">name of the paired read tool</field>
      <field name="evicted_pointer_schema" type="object" required="true">must include {path, preview, total_tokens, evicted: true}</field>
    </required>
    <forbidden>
      <pattern id="f1">threshold_n_tokens missing</pattern>
      <pattern id="f2">preview_chars &gt; threshold_n_tokens / 10 (negates the saving)</pattern>
      <pattern id="f3">read_tool_name not exposed to the agent</pattern>
      <pattern id="f4">evicted_pointer_schema lacks evicted:true flag</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Round threshold to nearest 1000.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>

  <section title="Evicted pointer example">
    <example type="good">
      <code lang="json"><![CDATA[{"path":"/scratch/tc-2026-05-22-001/result.txt",
 "preview":"First 500 chars of the result here...",
 "total_tokens":42700,
 "evicted":true}]]></code>
    </example>
  </section>
</text>
