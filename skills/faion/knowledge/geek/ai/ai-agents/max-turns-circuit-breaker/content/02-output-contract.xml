<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="max-turns-circuit-breaker Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for max-turns-circuit-breaker. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "max-turns-circuit-breaker"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["max_turns", "recovery_model", "fallback_message_template", "log_partial_trajectory"],
      "properties": {
        "max_turns": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "recovery_model": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "fallback_message_template": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "log_partial_trajectory": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["agent_kind", "per_turn_cost_usd"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "max-turns-circuit-breaker",
  "version": "2.0.0",
  "decision": {"max_turns": "TODO", "recovery_model": "TODO", "fallback_message_template": "TODO", "log_partial_trajectory": "TODO"},
  "drivers": {"agent_kind": "val", "per_turn_cost_usd": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "max-turns-circuit-breaker",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "max_turns", "recovery_model", "fallback_message_template", "log_partial_trajectory".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
