<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Bundle vs Split Tools Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Bundle/split decision record schema.</summary>

  <output-contract>
    <required>
      <field name="decision_id" type="string" required="true"/>
      <field name="tool_count_before" type="integer" required="true"/>
      <field name="tool_count_after" type="integer" required="true"/>
      <field name="action" type="enum" required="true">bundle | split | refactor | no-action</field>
      <field name="bundle_groups" type="list" required="false">list of {bundle_name, modes:[], member_tools:[]}</field>
      <field name="eval_set_version" type="string" required="true"/>
      <field name="eval_quality_delta" type="number" required="true">e.g. -0.008 means 0.8% quality drop</field>
      <field name="owner" type="string" required="true"/>
      <field name="version" type="string" required="true">semver</field>
      <field name="produced_at" type="datetime" required="true"/>
    </required>
    <forbidden>
      <pattern id="f1">action=bundle AND eval_quality_delta &lt; -0.02 (worse than 2% drop)</pattern>
      <pattern id="f2">bundle_groups[].modes uses free-string instead of enum</pattern>
      <pattern id="f3">tool_count_after &gt; tool_count_before for action=bundle</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Round eval_quality_delta to 3 decimals.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>
</text>
