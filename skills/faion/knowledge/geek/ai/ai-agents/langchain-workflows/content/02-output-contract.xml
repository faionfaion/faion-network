<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="langchain-workflows Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for langchain-workflows. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "langchain-workflows"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["state_schema", "nodes", "edges", "interrupt_before", "checkpointer", "subgraphs"],
      "properties": {
        "state_schema": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "nodes": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "edges": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "interrupt_before": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "checkpointer": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "subgraphs": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["steps", "branches", "hitl_points", "parallel_branches", "persistence_target"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "langchain-workflows",
  "version": "2.0.0",
  "decision": {"state_schema": "TODO", "nodes": "TODO", "edges": "TODO", "interrupt_before": "TODO", "checkpointer": "TODO", "subgraphs": "TODO"},
  "drivers": {"steps": "val", "branches": "val", "hitl_points": "val", "parallel_branches": "val", "persistence_target": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "langchain-workflows",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "state_schema", "nodes", "edges", "interrupt_before", "checkpointer", "subgraphs".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
