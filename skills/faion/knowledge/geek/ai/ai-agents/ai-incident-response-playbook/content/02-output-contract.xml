<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Incident Response Playbook Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a AI Incident Response Playbook deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="steps" type="list" min="3" schema="{id,precondition,action,postcondition,time_budget}" />
      <field name="decision_branches" type="list" schema="{step_id,signal,threshold,route}" />
      <field name="escalation_path" type="list" min="1" />
      <field name="last_drilled_date" format="iso_date" />
    </required>
    <forbidden>
      <pattern id="f1">vague verbs ('investigate', 'check', 'look at')</pattern>
      <pattern id="f2">decision branch without numeric threshold</pattern>
      <pattern id="f3">escalation path buried below step 5</pattern>
      <pattern id="f4">runbook with last_drilled_date &gt;90 days old</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Restructure steps as long as pre/postconditions chain correctly.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>No vague verbs</item>
      <item>Branches have numeric thresholds</item>
      <item>Escalation at top</item>
      <item>Drill ≤90d</item>
    </list>
  </section>
</text>
