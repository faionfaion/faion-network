<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Role-Specialized Models Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the role-specialized-models spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "role-specialized-models"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "role_map",
        "fallback_chain",
        "eval_schedule_cron"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "role_count",
        "monthly_cost_target",
        "quality_floor"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "role-specialized-models",
  "version": "2.0.0",
  "decision": {
    "role_map": "value",
    "fallback_chain": "value",
    "eval_schedule_cron": "value"
  },
  "drivers": {
    "role_count": "v",
    "monthly_cost_target": "v",
    "quality_floor": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-competence-floor"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "role-specialized-models",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: role_map, fallback_chain, eval_schedule_cron.</violation>
      <violation>drivers missing required keys: role_count, monthly_cost_target, quality_floor.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-role-specialized-models.py">Schema validator.</reference>
</text>
