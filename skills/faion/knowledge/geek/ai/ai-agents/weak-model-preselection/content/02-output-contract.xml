<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Weak-Model Preselection Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/weak-model-preselection.json",
  "type": "object",
  "required": ["variant", "weak_model", "strong_model", "filter_eval", "cost_savings_ratio"],
  "properties": {
    "variant": {"enum": ["filter-then-reason", "reference-extract-then-load", "classify-then-route", "rank-then-rerank"]},
    "weak_model": {"type": "string"},
    "strong_model": {"type": "string"},
    "filter_eval": {"type": "object", "required": ["recall", "precision", "n"], "properties": {"recall": {"type": "number", "minimum": 0.95, "maximum": 1.0}, "precision": {"type": "number", "minimum": 0, "maximum": 1.0}, "n": {"type": "integer", "minimum": 100}}},
    "cost_savings_ratio": {"type": "number", "minimum": 3.0},
    "escape_to_full_context": {"type": "boolean", "const": true},
    "high_stakes": {"type": "boolean"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "variant": "filter-then-reason",
  "weak_model": "claude-haiku-4-7",
  "strong_model": "claude-opus-4-7",
  "filter_eval": {
    "recall": 0.97,
    "precision": 0.82,
    "n": 200
  },
  "cost_savings_ratio": 7.4,
  "escape_to_full_context": true,
  "high_stakes": false
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "variant": "filter-then-reason",
  "weak_model": "haiku"
}
]]></code>
    <note>Missing strong_model, filter_eval, cost_savings_ratio, escape_to_full_context.</note>
  </example>

  <reference path="scripts/validate-weak-model-preselection.py">Validator script</reference>
</text>
