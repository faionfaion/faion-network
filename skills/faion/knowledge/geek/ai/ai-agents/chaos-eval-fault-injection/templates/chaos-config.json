{
  "_header": "purpose=chaos-eval config; consumes=tool inventory + production fault rates; produces=fault injection plan; depends-on=content/01-core-rules.xml; token-budget-impact=none (offline)",
  "name": "agent-chaos-config",
  "version": 1,
  "seed": 42,
  "scope": {
    "include_tools": ["*"],
    "exclude_tools": ["log", "metric"],
    "include_llm_calls": true
  },
  "faults": [
    {"type": "tool_timeout",       "p": 0.10, "deadline_ms": 5000},
    {"type": "tool_error",         "p": 0.05, "code": 500, "message": "internal server error"},
    {"type": "llm_rate_limit",     "p": 0.02, "retry_after_s": 30},
    {"type": "tool_mutate",        "p": 0.03, "strategy": "drop_field"},
    {"type": "service_disconnect", "p": 0.01, "midstream": true}
  ],
  "deterministic_injections": {
    "step_4": "tool_timeout",
    "step_7": "tool_mutate"
  },
  "grading": {
    "outcomes": ["recovered", "retried_intelligently", "escalated_correctly", "wrong_confident"],
    "thresholds": {
      "wrong_confident_max": 0.0,
      "recovered_or_retried_min": 0.7,
      "escalated_correctly_min": 0.1
    }
  },
  "report": {
    "per_fault_breakdown": true,
    "per_tool_breakdown": true,
    "save_traces_for": ["wrong_confident"]
  }
}
