<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Chaos-Eval Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Chaos-eval report schema.</summary>

  <output-contract>
    <required>
      <field name="report_id" type="string" required="true"/>
      <field name="agent_version" type="string" required="true"/>
      <field name="eval_set_version" type="string" required="true"/>
      <field name="seed" type="integer" required="true">deterministic seed for reproducibility</field>
      <field name="baseline_pass_rate" type="number" required="true">no-fault baseline</field>
      <field name="chaos_pass_rate" type="number" required="true">with faults injected</field>
      <field name="recovery_score" type="number" required="true">mean of 0..3 rubric over fault occurrences</field>
      <field name="per_fault_class" type="object" required="true">{timeout, http_5xx, rate_limit, corrupted_return, disconnect} → {n_occurrences, mean_score, confidently_wrong_count}</field>
      <field name="owner" type="string" required="true"/>
      <field name="version" type="string" required="true">semver</field>
      <field name="produced_at" type="datetime" required="true"/>
    </required>
    <forbidden>
      <pattern id="f1">baseline_pass_rate missing OR chaos_pass_rate &gt; baseline_pass_rate (implausible)</pattern>
      <pattern id="f2">per_fault_class has confidently_wrong_count &gt; 0 with no flag in recommendation</pattern>
      <pattern id="f3">seed missing (non-reproducible)</pattern>
      <pattern id="f4">recovery_score outside [0, 3]</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Aggregate similar fault classes (e.g. http_5xx and timeout) only when sample sizes too small to report separately.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>
</text>
