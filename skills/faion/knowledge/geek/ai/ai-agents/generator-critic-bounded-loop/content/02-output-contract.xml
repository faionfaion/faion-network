<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="generator-critic-bounded-loop Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>Critic output schema + loop trace schema.</summary>

  <section title="Critic output schema">
    <code lang="json"><![CDATA[
{
  "$id": "generator-critic-bounded-loop/critic-output",
  "type": "object",
  "required": ["score", "should_continue", "feedback"],
  "additionalProperties": false,
  "properties": {
    "score":           {"type": "number", "minimum": 0.0, "maximum": 1.0},
    "should_continue": {"type": "boolean"},
    "feedback":        {"type": "string", "maxLength": 1500}
  }
}
    ]]></code>
  </section>

  <section title="Loop trace schema">
    <code lang="json"><![CDATA[
{
  "$id": "generator-critic-bounded-loop/trace",
  "type": "object",
  "required": ["iterations", "exit_reason", "final_score"],
  "additionalProperties": false,
  "properties": {
    "iterations":  {"type": "integer", "minimum": 1, "maximum": 5},
    "exit_reason": {"enum": ["critic_veto", "plateau", "cap"]},
    "final_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
  }
}
    ]]></code>
  </section>

  <section title="Good example (critic output)">
    <example type="good">
      <code lang="json"><![CDATA[
{"score": 0.78, "should_continue": true, "feedback": "Missing the requested concrete example in the second section; please add one."}
      ]]></code>
      <note>Score in range, structured boolean, concrete feedback.</note>
    </example>
  </section>

  <section title="Bad example (no should_continue)">
    <example type="bad">
      <code lang="json"><![CDATA[
{"score": 0.6, "feedback": "Needs improvement."}
      ]]></code>
      <note>Missing `should_continue`; caller would have to derive from score. Validator rejects.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Critic output has `score`, `should_continue`, `feedback`.</item>
      <item>Loop trace records `exit_reason` from the canonical enum.</item>
      <item>`iterations` is between 1 and 5.</item>
    </list>
  </section>
</text>
