<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="mcp-gateway-composition Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for mcp-gateway-composition. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "mcp-gateway-composition"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["pattern", "exposed_tools", "auth_scheme", "rate_limit_rps", "namespace_prefix_strategy"],
      "properties": {
        "pattern": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "exposed_tools": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "auth_scheme": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "rate_limit_rps": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "namespace_prefix_strategy": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["servers_count", "tools_total", "agent_clients_count", "shared_concerns"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "mcp-gateway-composition",
  "version": "2.0.0",
  "decision": {"pattern": "TODO", "exposed_tools": "TODO", "auth_scheme": "TODO", "rate_limit_rps": "TODO", "namespace_prefix_strategy": "TODO"},
  "drivers": {"servers_count": "val", "tools_total": "val", "agent_clients_count": "val", "shared_concerns": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "mcp-gateway-composition",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "pattern", "exposed_tools", "auth_scheme", "rate_limit_rps", "namespace_prefix_strategy".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
