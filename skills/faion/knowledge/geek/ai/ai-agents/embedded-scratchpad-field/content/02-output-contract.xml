<text id="02-output-contract" title="embedded-scratchpad-field Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>Five canonical schema variants, each with the scratchpad declared before the answer.</summary>

  <section title="Variant 1 — reasoning before verdict (decisions)">
    <code lang="json"><![CDATA[
{
  "type": "object",
  "required": ["reasoning", "confidence", "decision"],
  "additionalProperties": false,
  "properties": {
    "reasoning":  {"type": "string", "minLength": 4, "maxLength": 2000},
    "confidence": {"enum": ["low", "medium", "high"]},
    "decision":   {"enum": ["approve", "reject"]}
  }
}
    ]]></code>
  </section>

  <section title="Variant 2 — plan_steps before final action (multi-step)">
    <code lang="json"><![CDATA[
{
  "type": "object",
  "required": ["plan_steps", "next_action"],
  "additionalProperties": false,
  "properties": {
    "plan_steps":  {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 10},
    "next_action": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <section title="Variant 3 — evidence before classification">
    <code lang="json"><![CDATA[
{
  "type": "object",
  "required": ["evidence", "category"],
  "additionalProperties": false,
  "properties": {
    "evidence": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 5},
    "category": {"enum": ["bug", "feature_request", "question", "spam"]}
  }
}
    ]]></code>
  </section>

  <section title="Variant 4 — free-form scratchpad before summary+action">
    <code lang="json"><![CDATA[
{
  "type": "object",
  "required": ["scratchpad", "summary", "next_action"],
  "additionalProperties": false,
  "properties": {
    "scratchpad":  {"type": "string"},
    "summary":     {"type": "string"},
    "next_action": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <section title="Variant 5 — tab_cot for math/derivation">
    <code lang="json"><![CDATA[
{
  "type": "object",
  "required": ["steps", "final_answer"],
  "additionalProperties": false,
  "properties": {
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["operation", "intermediate"],
        "additionalProperties": false,
        "properties": {
          "operation":    {"type": "string"},
          "intermediate": {"type": "string"}
        }
      }
    },
    "final_answer": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <section title="Good example (verdict)">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "reasoning": "Three of the four acceptance criteria are clearly met; the fourth needs investigation but the evidence so far supports approval.",
  "confidence": "medium",
  "decision": "approve"
}
      ]]></code>
      <note>Reasoning is concrete, references the criteria, and is generated before confidence and decision.</note>
    </example>
  </section>

  <section title="Bad example (anti-pattern)">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "decision": "approve",
  "reasoning": "Three of the four criteria are met."
}
      ]]></code>
      <note>Reasoning placed AFTER decision — post-hoc rationalisation, not CoT. Validator rejects.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Schema has exactly one scratchpad field.</item>
      <item>Scratchpad field is declared BEFORE every answer-shaped field.</item>
      <item>Scratchpad field has a non-trivial `description`.</item>
      <item>The chosen variant matches the task type.</item>
    </list>
  </section>
</text>
