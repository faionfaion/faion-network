<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llamaindex-hybrid-retrieval Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llamaindex-hybrid-retrieval. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llamaindex-hybrid-retrieval"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["retrievers", "fusion_top_k", "rerank_model", "rerank_top_n", "similarity_cutoff"],
      "properties": {
        "retrievers": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "fusion_top_k": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "rerank_model": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "rerank_top_n": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "similarity_cutoff": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["corpus_heterogeneity", "latency_target_ms", "rerank_budget_usd"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llamaindex-hybrid-retrieval",
  "version": "2.0.0",
  "decision": {"retrievers": "TODO", "fusion_top_k": "TODO", "rerank_model": "TODO", "rerank_top_n": "TODO", "similarity_cutoff": "TODO"},
  "drivers": {"corpus_heterogeneity": "val", "latency_target_ms": "val", "rerank_budget_usd": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llamaindex-hybrid-retrieval",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "retrievers", "fusion_top_k", "rerank_model", "rerank_top_n", "similarity_cutoff".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
