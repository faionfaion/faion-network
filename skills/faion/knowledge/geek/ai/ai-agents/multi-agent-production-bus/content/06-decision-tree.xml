<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Multi-Agent Production Bus Decision Tree" version="2.0.0" est_tokens="600">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (subtasks_independent, chain_shape, agent_count, audit_required)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-indep" text="Are subtasks independent (no data dependency)?">
          <branch when="subtasks_independent == true">
            <conclusion ref="r-parallel">Pick parallel (asyncio.gather + per-task timeout).</conclusion>
          </branch>
          <branch when="subtasks_independent == false">
            <question id="q-shape" text="Is chain_shape linear?">
              <branch when="chain_shape == 'linear'">
                <conclusion ref="r-sequential">Pick sequential — cheapest, most predictable.</conclusion>
              </branch>
              <branch when="chain_shape == 'dependent_dag' or chain_shape == 'unknown'">
                <conclusion ref="r-hierarchical">Pick hierarchical — planner + workers + synthesizer with traceable assignments.</conclusion>
              </branch>
            </question>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true, subtasks_independent=false, chain_shape=dependent_dag">
      q-root yes → q-indep no → q-shape dag → r-hierarchical
    </example>
  </decision-tree>
</text>
