<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="PostTool Hook Self-Correction Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (language, runtime_per_file, validators_available)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-rt" text="Is runtime_per_file &gt;= 5 seconds?">
          <branch when="runtime_per_file &gt;= 5">
            <conclusion ref="r-defer-slow">Defer validation to a commit-time gate; don't run as PostToolUse hook.</conclusion>
          </branch>
          <branch when="runtime_per_file &lt; 5">
            <question id="q-lang" text="What is language?">
              <branch when="language == 'python'">
                <conclusion ref="r-python-ruff">Pick ruff (check + format) scoped per file.</conclusion>
              </branch>
              <branch when="language == 'typescript' or language == 'javascript'">
                <conclusion ref="r-typescript-tsc-eslint">Pick tsc --noEmit then eslint --max-warnings 0 per file.</conclusion>
              </branch>
            </question>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="language=python, runtime_per_file=1">
      q-root yes → q-rt &lt;5 → q-lang python → r-python-ruff
    </example>
  </decision-tree>
</text>
