<text id="06-decision-tree" title="Refusal Field Strict Schema Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (api_flavor, production_refusal_rate, downstream_consumer_count)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="api_flavor == &apos;openai-responses&apos;">
            <conclusion ref="r2-strict-mode">Use strict mode + top-level refusal.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="r1-top-level-refusal">Add top-level refusal field; branch in caller.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → r1-top-level-refusal
    </example>
  </decision-tree>
</text>
