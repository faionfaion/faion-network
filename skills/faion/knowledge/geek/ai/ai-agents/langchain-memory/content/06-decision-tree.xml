<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="langchain-memory Decision Tree" version="2.0.0" est_tokens="700">
  <decision-tree>
    <root-question id="q-root" text="Does the conversation profile meet the prerequisites (expected_turns set, recall_pattern in {recency,semantic,mixed}, store_backend present)?">
      <branch when="profile.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return error, do not guess.</conclusion>
      </branch>
      <branch when="profile.valid == true">
        <question id="q-turns" text="expected_turns &lt; 10?">
          <branch when="expected_turns &lt; 10">
            <question id="q-entity-short" text="entity_focus == true?">
              <branch when="entity_focus == true">
                <conclusion ref="r4">Entity Memory — short but entity-centric.</conclusion>
              </branch>
              <branch when="entity_focus == false">
                <conclusion ref="r1">Buffer Memory — short conversation, no extraction overhead.</conclusion>
              </branch>
            </question>
          </branch>
          <branch when="expected_turns &gt;= 10">
            <question id="q-recall" text="recall_pattern == semantic?">
              <branch when="recall_pattern == semantic">
                <conclusion ref="r3">Vector Memory — semantic retrieval over many turns.</conclusion>
              </branch>
              <branch when="recall_pattern != semantic">
                <question id="q-long" text="expected_turns &gt; 50?">
                  <branch when="expected_turns &gt; 50">
                    <conclusion ref="r3">Vector Memory — too long for summary, switch to retrieval.</conclusion>
                  </branch>
                  <branch when="expected_turns &lt;= 50">
                    <conclusion ref="r2">Summary Memory — 10-50 turns sequential.</conclusion>
                  </branch>
                </question>
              </branch>
            </question>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="expected_turns=6, recall_pattern=recency, entity_focus=false">
      q-root yes → q-turns yes (&lt;10) → q-entity-short no → conclusion r1 (buffer)
    </example>
  </decision-tree>
</text>
