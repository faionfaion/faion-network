<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Batch + Cache Stack Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Batch+cache pipeline config schema.</summary>

  <output-contract>
    <required>
      <field name="pipeline_id" type="string" required="true"/>
      <field name="provider" type="enum" required="true">anthropic | openai</field>
      <field name="endpoint" type="enum" required="true">batch | sync (must be batch for this methodology)</field>
      <field name="prefix_hash" type="string" required="true">sha256 of the byte-identical prefix</field>
      <field name="cache_control_position" type="string" required="true">e.g. "after-system-prompt", "after-tools"</field>
      <field name="target_hit_rate" type="number" required="true">0..1; default 0.9</field>
      <field name="batch_size" type="integer" required="true">≥50</field>
    </required>
    <forbidden>
      <pattern id="f1">endpoint != batch</pattern>
      <pattern id="f2">batch_size &lt; 50</pattern>
      <pattern id="f3">prefix_hash differs across items in the same batch run</pattern>
      <pattern id="f4">cache_control_position empty</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Increase batch_size up to provider max (10k items typically).</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>
</text>
