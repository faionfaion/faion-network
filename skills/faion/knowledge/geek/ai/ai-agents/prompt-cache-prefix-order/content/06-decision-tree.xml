<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Prompt Cache Prefix Order Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (stable_prefix_tokens, calls_per_day, system_prompt_changes_per_day)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="stable_prefix_tokens &lt; 1024">
            <conclusion ref="skip-this-methodology">Below minimum; cache_control will be ignored.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="r1-stable-first">Order: system → tools → static context → RAG/dynamic → user input; breakpoint at boundary.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → r1-stable-first
    </example>
  </decision-tree>
</text>
