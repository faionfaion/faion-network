<text id="05-examples" title="Prompt Cache Prefix Order Worked Example" version="2.0.0" est_tokens="600" depth="recommended">
  <summary>Canonical happy-path spec emitted from the smoke-test input.</summary>

  <example type="good">
    <note>Smoke-test driver values flow through the decision tree to the default leaf (r1-stable-first). The emitted JSON satisfies the schema in 02-output-contract.xml.</note>
    <code lang="json"><![CDATA[
{
  "slug": "prompt-cache-prefix-order",
  "version": "2.0.0",
  "decision": {
    "section_order": "value",
    "breakpoint_position_tokens": "value",
    "stable_token_count": "value",
    "cache_hit_target": "value"
  },
  "drivers": {
    "stable_prefix_tokens": "v",
    "calls_per_day": "v",
    "system_prompt_changes_per_day": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-stable-first"
    ]
  }
}
]]></code>
  </example>

