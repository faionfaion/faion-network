<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Prompt Cache Prefix Order Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the prompt-cache-prefix-order spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "prompt-cache-prefix-order"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "section_order",
        "breakpoint_position_tokens",
        "stable_token_count",
        "cache_hit_target"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "stable_prefix_tokens",
        "calls_per_day",
        "system_prompt_changes_per_day"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "prompt-cache-prefix-order",
  "version": "2.0.0",
  "decision": {
    "section_order": "value",
    "breakpoint_position_tokens": "value",
    "stable_token_count": "value",
    "cache_hit_target": "value"
  },
  "drivers": {
    "stable_prefix_tokens": "v",
    "calls_per_day": "v",
    "system_prompt_changes_per_day": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-stable-first"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "prompt-cache-prefix-order",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: section_order, breakpoint_position_tokens, stable_token_count, cache_hit_target.</violation>
      <violation>drivers missing required keys: stable_prefix_tokens, calls_per_day, system_prompt_changes_per_day.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-prompt-cache-prefix-order.py">Schema validator.</reference>
</text>
