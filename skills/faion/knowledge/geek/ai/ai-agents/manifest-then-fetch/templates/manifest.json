{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolResultManifest",
  "type": "object",
  "required": ["execution_id", "preview", "size_tokens", "storage_uri"],
  "properties": {
    "execution_id": {
      "type": "string",
      "description": "Opaque ID; passed back to get_full_result to load body."
    },
    "preview": {
      "description": "Small, structured-per-tool snapshot. ≤200 tokens. Never the answer.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {"const": "sql"},
            "row_count": {"type": "integer"},
            "columns": {"type": "array", "items": {"type": "string"}}
          }
        },
        {
          "type": "object",
          "properties": {
            "kind": {"const": "http_response"},
            "status": {"type": "integer"},
            "content_type": {"type": "string"},
            "first_chars": {"type": "string", "maxLength": 400}
          }
        },
        {
          "type": "object",
          "properties": {
            "kind": {"const": "log"},
            "line_count": {"type": "integer"},
            "head": {"type": "array", "items": {"type": "string"}, "maxItems": 5},
            "tail": {"type": "array", "items": {"type": "string"}, "maxItems": 5}
          }
        }
      ]
    },
    "size_tokens": {"type": "integer", "minimum": 0},
    "storage_uri": {
      "type": "string",
      "description": "Where the full body lives. Resolvable by get_full_result."
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional. After this, get_full_result returns expired error."
    }
  }
}
