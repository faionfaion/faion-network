<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llamaindex-production-gotchas Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llamaindex-production-gotchas. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llamaindex-production-gotchas"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["async_fixes", "concurrency_caps", "agent_wraps", "eval_sampling", "callback_handlers"],
      "properties": {
        "async_fixes": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "concurrency_caps": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "agent_wraps": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "eval_sampling": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "callback_handlers": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["async", "components_used", "cost_cap_per_turn_usd"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llamaindex-production-gotchas",
  "version": "2.0.0",
  "decision": {"async_fixes": "TODO", "concurrency_caps": "TODO", "agent_wraps": "TODO", "eval_sampling": "TODO", "callback_handlers": "TODO"},
  "drivers": {"async": "val", "components_used": "val", "cost_cap_per_turn_usd": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llamaindex-production-gotchas",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "async_fixes", "concurrency_caps", "agent_wraps", "eval_sampling", "callback_handlers".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
