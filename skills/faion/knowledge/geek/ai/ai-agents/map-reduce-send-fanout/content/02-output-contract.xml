<text id="02-output-contract" title="map-reduce-send-fanout Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for map-reduce-send-fanout. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "map-reduce-send-fanout"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["framework", "concurrency_cap", "reducer", "idempotency_guarantee", "max_attempts"],
      "properties": {
        "framework": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "concurrency_cap": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "reducer": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "idempotency_guarantee": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "max_attempts": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["item_count", "mutates_shared_state", "idempotent", "framework"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "map-reduce-send-fanout",
  "version": "2.0.0",
  "decision": {"framework": "TODO", "concurrency_cap": "TODO", "reducer": "TODO", "idempotency_guarantee": "TODO", "max_attempts": "TODO"},
  "drivers": {"item_count": "val", "mutates_shared_state": "val", "idempotent": "val", "framework": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "map-reduce-send-fanout",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "framework", "concurrency_cap", "reducer", "idempotency_guarantee", "max_attempts".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
