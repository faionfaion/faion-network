<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Schema Field Order Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the schema-field-order spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "schema-field-order"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "field_order",
        "reasoning_field_name",
        "schema_strict"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "answer_quality_floor",
        "latency_budget_ms",
        "schema_modifiable"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "schema-field-order",
  "version": "2.0.0",
  "decision": {
    "field_order": "value",
    "reasoning_field_name": "value",
    "schema_strict": "value"
  },
  "drivers": {
    "answer_quality_floor": "v",
    "latency_budget_ms": "v",
    "schema_modifiable": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-reasoning-first"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "schema-field-order",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: field_order, reasoning_field_name, schema_strict.</violation>
      <violation>drivers missing required keys: answer_quality_floor, latency_budget_ms, schema_modifiable.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-schema-field-order.py">Schema validator.</reference>
</text>
