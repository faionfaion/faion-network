<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agent Kill Switch Design Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a Agent Kill Switch Design deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="control_id" format="stable_id" />
      <field name="scope" type="string" schema="tenant_or_global" />
      <field name="activation_criteria" type="string" />
      <field name="reversal_path" type="string" />
      <field name="audit_log_endpoint" format="url" />
      <field name="last_drilled_date" format="iso_date" />
    </required>
    <forbidden>
      <pattern id="f1">control without reversal_path</pattern>
      <pattern id="f2">global default without explicit approval step</pattern>
      <pattern id="f3">control with last_drilled_date &gt;90 days old</pattern>
      <pattern id="f4">audit log missing required fields (invoker, reason, timestamp, outcome)</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Narrow scope (global → tenant) is always allowed; widening requires approval.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Reversal path documented</item>
      <item>Per-tenant default</item>
      <item>Audit fields complete</item>
      <item>Drill ≤90d</item>
    </list>
  </section>
</text>
