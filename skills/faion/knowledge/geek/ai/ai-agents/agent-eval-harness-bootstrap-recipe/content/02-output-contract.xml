<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agent Eval Harness Bootstrap Recipe Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a Agent Eval Harness Bootstrap Recipe deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="dimensions" type="list" min="3" schema="{name,anchors_1_3_5,weight}" />
      <field name="instance_scores" type="list" min="1" schema="{instance_id,dimension_scores,evidence_refs}" />
      <field name="rater_count" type="integer" min="1" />
      <field name="weighted_total" format="float" />
    </required>
    <forbidden>
      <pattern id="f1">scores without evidence_refs</pattern>
      <pattern id="f2">post-hoc weight changes after scoring</pattern>
      <pattern id="f3">missing anchors_1_3_5 for any dimension</pattern>
      <pattern id="f4">single-rater scores on decisions ≥$10k</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Average scores across raters only after reconciliation when divergence &gt;1.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Every score cites evidence</item>
      <item>Weights frozen pre-scoring</item>
      <item>Anchors present 1/3/5</item>
      <item>Reconciliation step recorded when needed</item>
    </list>
  </section>
</text>
