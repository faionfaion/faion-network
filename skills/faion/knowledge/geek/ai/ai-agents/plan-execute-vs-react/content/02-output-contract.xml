<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Plan-Execute vs ReAct Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the agent-loop spec.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "plan-execute-vs-react"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["loop_type", "max_turns", "plan_model", "execute_model", "replan_on_failure"],
      "properties": {
        "loop_type": {"enum": ["plan-execute", "react", "hybrid"]},
        "max_turns": {"type": "integer", "minimum": 1},
        "plan_model": {"type": "string"},
        "execute_model": {"type": "string"},
        "replan_on_failure": {"type": "boolean"}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["known_substeps", "horizon", "adaptability_needed", "audit_required", "mixed_predictability"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Hybrid 15-step research"><![CDATA[
{
  "slug": "plan-execute-vs-react",
  "version": "2.0.0",
  "decision": {"loop_type": "hybrid", "max_turns": 5, "plan_model": "opus", "execute_model": "sonnet", "replan_on_failure": true},
  "drivers": {"known_substeps": "unknown", "horizon": 15, "adaptability_needed": true, "audit_required": true, "mixed_predictability": true},
  "audit": {"rule_refs": ["r3-hybrid-long-horizon", "r4-max-turns-mandatory", "r6-slim-state-doc"]}
}
]]></example>

    <example valid="false" title="ReAct without max_turns + empty audit"><![CDATA[
{
  "slug": "plan-execute-vs-react",
  "version": "2.0.0",
  "decision": {"loop_type": "react", "max_turns": 0, "plan_model": "opus", "execute_model": "sonnet", "replan_on_failure": false},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>max_turns must be &gt;= 1.</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>decision.loop_type matches the decision-tree branch.</item>
      <item>If loop_type in (react, hybrid), max_turns &gt;= 1.</item>
      <item>audit.rule_refs cites the rule that drove the leaf.</item>
    </list>
  </section>

  <reference path="templates/agent-loop-spec.md">Markdown wrapper.</reference>
  <reference path="scripts/validate-plan-execute-vs-react.py">Validator.</reference>
</text>
