<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Plan-Execute vs ReAct Decision Tree" version="2.0.0" est_tokens="600">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (known_substeps, horizon, adaptability_needed, audit_required, mixed_predictability)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-adapt" text="Is adaptability_needed true OR known_substeps == 'unknown'?">
          <branch when="adaptability_needed == true">
            <question id="q-horizon" text="Is horizon &gt; 10 AND mixed_predictability == true?">
              <branch when="horizon &gt; 10 and mixed_predictability == true">
                <conclusion ref="r3-hybrid-long-horizon">Pick Hybrid: top-level plan + per-step ReAct with max_turns=5.</conclusion>
              </branch>
              <branch when="horizon &lt;= 10 or mixed_predictability == false">
                <conclusion ref="r2-react-when-exploratory">Pick ReAct with max_turns cap.</conclusion>
              </branch>
            </question>
          </branch>
          <branch when="adaptability_needed == false">
            <conclusion ref="r1-plan-when-predictable">Pick Plan-Execute — auditable, parallelisable, cheap.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="adaptability_needed=true, horizon=15, mixed_predictability=true">
      q-root yes → q-adapt yes → q-horizon both true → r3-hybrid-long-horizon
    </example>
  </decision-tree>
</text>
