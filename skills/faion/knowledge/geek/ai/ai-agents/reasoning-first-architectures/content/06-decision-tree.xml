<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Reasoning-First Architectures Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (task_complexity, branching, error_recovery_needed, horizon)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="branching == true">
            <conclusion ref="r2-tot-when-branching">Pick Tree-of-Thought.</conclusion>
          </branch>
          <branch when="error_recovery_needed == true">
            <conclusion ref="r3-reflexion-when-recovery">Pick Reflexion.</conclusion>
          </branch>
          <branch when="horizon &gt; 20">
            <conclusion ref="r4-planning-loop-long-horizon">Pick Planning Loop.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="r1-thought-before-action">Pick ReAct with extended_thinking.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → r1-thought-before-action
    </example>
  </decision-tree>
</text>
