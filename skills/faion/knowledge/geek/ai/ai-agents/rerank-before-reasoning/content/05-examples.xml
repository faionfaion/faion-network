<text id="05-examples" title="Rerank Before Reasoning Worked Example" version="2.0.0" est_tokens="600" depth="recommended">
  <summary>Canonical happy-path spec emitted from the smoke-test input.</summary>

  <example type="good">
    <note>Smoke-test driver values flow through the decision tree to the default leaf (r1-rerank-required). The emitted JSON satisfies the schema in 02-output-contract.xml.</note>
    <code lang="json"><![CDATA[
{
  "slug": "rerank-before-reasoning",
  "version": "2.0.0",
  "decision": {
    "reranker_model": "value",
    "k_retrieved": "value",
    "k_final": "value",
    "timeout_ms": "value",
    "fallback_mode": "value"
  },
  "drivers": {
    "top_1_miss_rate": "v",
    "latency_budget_ms": "v",
    "context_budget_tokens": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-rerank-required"
    ]
  }
}
]]></code>
  </example>

  <example type="bad">
    <note>Bad — empty decision and audit; validator fails fast.</note>
    <code lang="json"><![CDATA[
{
  "slug": "rerank-before-reasoning",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></code>
  </example>
</text>
