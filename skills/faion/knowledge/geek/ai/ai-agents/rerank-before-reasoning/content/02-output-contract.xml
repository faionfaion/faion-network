<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rerank Before Reasoning Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the rerank-before-reasoning spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "rerank-before-reasoning"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "reranker_model",
        "k_retrieved",
        "k_final",
        "timeout_ms",
        "fallback_mode"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "top_1_miss_rate",
        "latency_budget_ms",
        "context_budget_tokens"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "rerank-before-reasoning",
  "version": "2.0.0",
  "decision": {
    "reranker_model": "value",
    "k_retrieved": "value",
    "k_final": "value",
    "timeout_ms": "value",
    "fallback_mode": "value"
  },
  "drivers": {
    "top_1_miss_rate": "v",
    "latency_budget_ms": "v",
    "context_budget_tokens": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-rerank-required"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "rerank-before-reasoning",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: reranker_model, k_retrieved, k_final, timeout_ms, fallback_mode.</violation>
      <violation>drivers missing required keys: top_1_miss_rate, latency_budget_ms, context_budget_tokens.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-rerank-before-reasoning.py">Schema validator.</reference>
</text>
