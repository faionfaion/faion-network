<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Record-Replay Debugging Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the record-replay-debugging config artefact.</summary>

  <output-contract produces="config">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "record-replay-debugging"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "record_mode",
        "replay_mode",
        "redaction_policy",
        "ci_recordings"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "failure_reproduction_difficulty",
        "production_failures_per_month",
        "tool_count"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "record-replay-debugging",
  "version": "2.0.0",
  "decision": {
    "record_mode": "value",
    "replay_mode": "value",
    "redaction_policy": "value",
    "ci_recordings": "value"
  },
  "drivers": {
    "failure_reproduction_difficulty": "v",
    "production_failures_per_month": "v",
    "tool_count": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-record-all-calls"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "record-replay-debugging",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: record_mode, replay_mode, redaction_policy, ci_recordings.</violation>
      <violation>drivers missing required keys: failure_reproduction_difficulty, production_failures_per_month, tool_count.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-record-replay-debugging.py">Schema validator.</reference>
</text>
