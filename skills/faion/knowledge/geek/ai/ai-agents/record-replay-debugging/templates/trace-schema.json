{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent-run-trace",
  "type": "object",
  "required": ["run_id", "agent_version", "started_at", "events"],
  "properties": {
    "run_id": {"type": "string"},
    "agent_version": {"type": "string"},
    "model_version": {"type": "string"},
    "prompt_hash": {"type": "string"},
    "started_at": {"type": "string", "format": "date-time"},
    "ended_at": {"type": "string", "format": "date-time"},
    "events": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "ts", "request", "response"],
            "properties": {
              "type": {"const": "llm_call"},
              "ts": {"type": "string", "format": "date-time"},
              "request": {"type": "object"},
              "response": {"type": "object"},
              "usage": {"type": "object"}
            }
          },
          {
            "type": "object",
            "required": ["type", "ts", "tool", "args", "result"],
            "properties": {
              "type": {"const": "tool_call"},
              "ts": {"type": "string", "format": "date-time"},
              "tool": {"type": "string"},
              "args": {"type": "object"},
              "result": {},
              "error": {"type": "string"},
              "side_effect": {"type": "boolean", "default": false}
            }
          },
          {
            "type": "object",
            "required": ["type", "ts", "value"],
            "properties": {
              "type": {"enum": ["clock_read", "rng_draw", "uuid_gen", "env_read"]},
              "ts": {"type": "string", "format": "date-time"},
              "value": {}
            }
          }
        ]
      }
    }
  }
}
