<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="previous_response_id Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (api_flavor, multi_turn, reasoning_model_used)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-flavor" text="Is api_flavor 'responses' AND multi_turn true?">
          <branch when="api_flavor == 'responses' and multi_turn == true">
            <conclusion ref="r-use-previous-id">Use previous_response_id with session store + 404 fallback + per-turn logging.</conclusion>
          </branch>
          <branch when="api_flavor == 'chat' or multi_turn == false">
            <conclusion ref="r-message-array-fallback">Use Chat Completions message array; previous_response_id incompatible.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="api_flavor=responses, multi_turn=true">
      q-root yes → q-flavor both true → r-use-previous-id
    </example>
  </decision-tree>
</text>
