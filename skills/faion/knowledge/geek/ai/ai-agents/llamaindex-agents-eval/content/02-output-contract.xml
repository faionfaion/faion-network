<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llamaindex-agents-eval Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llamaindex-agents-eval. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llamaindex-agents-eval"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["agent_class", "tools", "eval_metrics", "sample_count", "streaming", "cache"],
      "properties": {
        "agent_class": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "tools": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "eval_metrics": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "sample_count": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "streaming": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "cache": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["reasoning_style", "tools_count", "eval_budget_usd", "latency_target_ms"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llamaindex-agents-eval",
  "version": "2.0.0",
  "decision": {"agent_class": "TODO", "tools": "TODO", "eval_metrics": "TODO", "sample_count": "TODO", "streaming": "TODO", "cache": "TODO"},
  "drivers": {"reasoning_style": "val", "tools_count": "val", "eval_budget_usd": "val", "latency_target_ms": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llamaindex-agents-eval",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "agent_class", "tools", "eval_metrics", "sample_count", "streaming", "cache".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
