<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llm-judge-rubric-evidence-first Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llm-judge-rubric-evidence-first. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llm-judge-rubric-evidence-first"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["criteria", "judge_model", "evidence_first", "json_output", "bias_mitigations", "sample_count"],
      "properties": {
        "criteria": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "judge_model": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "evidence_first": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "json_output": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "bias_mitigations": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "sample_count": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["criteria_count", "bias_targets", "judge_model"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llm-judge-rubric-evidence-first",
  "version": "2.0.0",
  "decision": {"criteria": "TODO", "judge_model": "TODO", "evidence_first": "TODO", "json_output": "TODO", "bias_mitigations": "TODO", "sample_count": "TODO"},
  "drivers": {"criteria_count": "val", "bias_targets": "val", "judge_model": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llm-judge-rubric-evidence-first",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "criteria", "judge_model", "evidence_first", "json_output", "bias_mitigations", "sample_count".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
