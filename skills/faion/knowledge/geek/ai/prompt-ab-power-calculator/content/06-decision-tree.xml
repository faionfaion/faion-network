<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Prompt A/B Power Calculator Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes traffic volume + MDE to feasibility outcome.</summary>

  <decision-tree>
    <root-question id="q-inputs-pinned">Are baseline_rate, mde, traffic_per_day pinned with source citations?</root-question>
    <branch when="inputs_pinned == false">
      <conclusion ref="r3-evidence-anchored"/>
    </branch>
    <branch when="inputs_pinned == true">
      <question id="q-feasible">days_required ≤ cadence_window?</question>
      <branch when="days_required &gt; cadence_window">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="days_required &lt;= cadence_window">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="greeting-variant-q2-2026">
    inputs_pinned=true → days_required=4 → cadence_window=7 → run-the-checklist.
  </example>
</text>
