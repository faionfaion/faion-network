<text id="02-output-contract" title="Prompt Portability Audit — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>An audit report: bounded scope, criterion-tagged findings, severity + owner + deadline per finding, and a reproducible evidence package.</summary>

  <section title="Required fields">
    <list>
      <item>scope.artefact_set (paths / repos / ids)</item>
      <item>finding.criterion (rule_id / policy_line)</item>
      <item>finding.severity (low|medium|high)</item>
      <item>finding.owner + finding.deadline</item>
      <item>finding.evidence (query / screenshot / link)</item>
      <item>report.followup_backlog_link</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>findings without criterion</description>
      <reason>Devolves into debate.</reason>
    </antipattern>
    <antipattern>
      <description>owner / deadline missing</description>
      <reason>Becomes organisational debt.</reason>
    </antipattern>
    <antipattern>
      <description>evidence not reproducible</description>
      <reason>Cannot be verified at remediation.</reason>
    </antipattern>
    <antipattern>
      <description>self-attested closure without auditor verification</description>
      <reason>Findings reopen later.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Scope frozen before audit start.</item>
      <item>Every finding cites a criterion.</item>
      <item>Severity + owner + deadline on every finding.</item>
      <item>Evidence reproducible by second auditor.</item>
      <item>Follow-up backlog linked.</item>
    </list>
  </section>
</text>
