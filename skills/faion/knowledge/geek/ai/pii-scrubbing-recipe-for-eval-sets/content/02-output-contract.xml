<text id="02-output-contract" title="PII Scrubbing Recipe Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the pii-scrub-spec artefact + worked valid/invalid examples + forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pii-scrubbing-recipe-for-eval-sets.json",
  "type": "object",
  "required": ["artefact_id", "owner", "scrub_strategy", "consent_label_field", "retention_days", "inputs_used", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]{3,64}$"},
    "owner": {"type": "string", "minLength": 3, "not": {"enum": ["team", "we", "us", "engineering"]}},
    "scrub_strategy": {
      "type": "object",
      "required": ["mode", "rules"],
      "properties": {
        "mode": {"enum": ["regex_only", "regex_plus_ml", "ml_plus_human_review"]},
        "rules": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    },
    "consent_label_field": {"type": "string", "minLength": 1},
    "retention_days": {"type": "integer", "minimum": 1, "maximum": 3650},
    "inputs_used": {
      "type": "array",
      "items": {"type": "object", "required": ["name", "source"], "properties": {"name": {"type": "string"}, "source": {"type": "string"}}},
      "minItems": 1
    },
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "last_reviewed": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">owner == 'team' / 'we' / 'us' / 'engineering' / empty</item>
      <item id="f2">inputs_used == [] AND scrub_strategy.mode != 'no-op'</item>
      <item id="f3">retention_days &gt; legal max for the row class</item>
      <item id="f4">duplicate artefact_id within the same store</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "eval-set-prod-2026q2",
  "owner": "ruslan@faion.net",
  "scrub_strategy": {
    "mode": "regex_plus_ml",
    "rules": ["email", "phone", "credit_card", "ml-ner-person"]
  },
  "consent_label_field": "user.consent.eval_v1",
  "retention_days": 365,
  "inputs_used": [
    {"name": "traffic_sample", "source": "warehouse://prod.traffic_2026q2"},
    {"name": "consent_dict", "source": "git://faion/consent.yaml"}
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "scrub_strategy": {"mode": "regex_only", "rules": []},
  "retention_days": 99999,
  "inputs_used": [],
  "version": "v1",
  "last_reviewed": "yesterday"
}
]]></code>
    <note>owner=team (f1); rules empty; retention out of range; inputs empty (f2); version not semver; last_reviewed not ISO date.</note>
  </example>

  <reference path="scripts/validate-pii-scrubbing-recipe-for-eval-sets.py">Validator script</reference>
</text>
