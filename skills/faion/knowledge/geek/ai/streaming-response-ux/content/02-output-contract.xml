<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Streaming Response Ux Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a valid Streaming Response Ux output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="surface_name" type="string" required="true">chat / inline-AI / copilot / sidebar / autocomplete</field>
      <field name="wire_protocol" type="enum" required="true">sse / websocket / http-chunked</field>
      <field name="ttft_p95_target_ms" type="integer" required="true">&lt; 1500</field>
      <field name="cancel_supported" type="boolean" required="true">MUST be true</field>
      <field name="partial_copy_supported" type="boolean" required="true">MUST be true</field>
      <field name="edit_during_stream_strategy" type="enum" required="true">block / abort-and-replay / branch</field>
      <field name="error_recovery_pattern" type="string" required="true">named pattern: retry-from-last-token / restart-clean / preserve-partial</field>
      <field name="telemetry_events" type="list" required="true">ttft, first_token, token_rate, abort, error, complete</field>
    </required>

    <forbidden>
      <pattern id="f1">cancel_supported = false (no exceptions for &apos;short&apos; streams)</pattern>
      <pattern id="f2">ttft_p95_target_ms &gt; 2500</pattern>
      <pattern id="f3">edit_during_stream_strategy = &apos;block&apos; on a chat surface (users expect to edit prior turns)</pattern>
      <pattern id="f4">telemetry_events missing &apos;abort&apos;</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Trim long prose fields to fit limits while preserving numeric claims, named tools, and citations.</transformation>
      <transformation>Promote a 'no decision yet' state to status='pending' rather than fabricating a decision.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/streaming-response-ux.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/streaming-response-ux.json</item>
    </list>
  </section>
</text>
