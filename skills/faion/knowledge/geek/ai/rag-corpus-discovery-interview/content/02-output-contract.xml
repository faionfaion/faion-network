<text id="02-output-contract" title="RAG Corpus Discovery Interview — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>A structured-interview artefact bundle: written guide (≤ 2 pp), recordings + transcripts (≥ 5), and a tagged-evidence summary.</summary>

  <section title="Required fields">
    <list>
      <item>guide.prompts (5–9 past-behaviour anchored)</item>
      <item>interview.recording_url + interview.transcript_id</item>
      <item>interview.consent_recorded</item>
      <item>synthesis.interview_count ≥ 5</item>
      <item>evidence.quotes (verbatim, attributed to transcript_id)</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>synthesis claims on &lt; 5 interviews</description>
      <reason>Patterns not yet detectable.</reason>
    </antipattern>
    <antipattern>
      <description>leading prompts (&apos;would you pay…&apos;)</description>
      <reason>Contaminates the data.</reason>
    </antipattern>
    <antipattern>
      <description>notes-only (no transcript)</description>
      <reason>Memory of interviews decays sharply.</reason>
    </antipattern>
    <antipattern>
      <description>single-interview opinions labelled &apos;finding&apos;</description>
      <reason>Hypothesis presented as evidence.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Guide reviewed for non-leading phrasing before the call.</item>
      <item>Recording + transcript per interview.</item>
      <item>≥ 5 interviews before any synthesis claim.</item>
      <item>Quotes attributed to transcript_id.</item>
      <item>Insights tagged hypothesis vs finding.</item>
    </list>
  </section>
</text>
