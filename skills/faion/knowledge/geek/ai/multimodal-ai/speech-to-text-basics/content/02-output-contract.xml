<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Speech-to-Text Basics Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>JSON Schema for stt-config.json.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/stt-basics-config",
  "type": "object",
  "required": ["provider", "language", "response_format", "timestamp_granularities"],
  "properties": {
    "provider": {"enum": ["openai-whisper-api", "faster-whisper-local"]},
    "language": {"type": "string", "minLength": 2},
    "response_format": {"enum": ["verbose_json", "json", "text", "srt", "vtt"]},
    "timestamp_granularities": {"type": "array", "items": {"enum": ["segment", "word"]}, "minItems": 1},
    "max_file_mb": {"type": "integer", "maximum": 25},
    "split_on_silence": {"type": "boolean"}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "provider": "openai-whisper-api",
  "language": "uk",
  "response_format": "verbose_json",
  "timestamp_granularities": ["segment"],
  "max_file_mb": 25,
  "split_on_silence": true
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"provider": "openai-whisper-api", "response_format": "text", "max_file_mb": 100}]]></code>
      <note>Fails: missing language pin, response_format != verbose_json, max_file_mb &gt; 25.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>language pinned (rule r1).</item>
      <item>response_format = verbose_json (rule r2).</item>
      <item>timestamp_granularities non-empty.</item>
      <item>max_file_mb ≤ 25.</item>
    </list>
  </section>
</text>
