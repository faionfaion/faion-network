<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Image Generation Tools Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Does the pipeline run ≥2 use cases or ≥2 providers?</root-question>
    <branch when="pipeline.use_case_count &gt;= 2 OR pipeline.provider_count &gt;= 2">
      <question>Is an S3-compatible cache available AND per-tenant attribution required?</question>
      <branch when="cache.available == true AND attribution.required == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="cache.available == false OR attribution.required == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="pipeline.use_case_count &lt; 2 AND pipeline.provider_count &lt; 2">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="article-header + social-card + 3-provider rotation + S3 cache + per-tenant attribution → run-the-checklist"/>
  </decision-tree>
</text>
