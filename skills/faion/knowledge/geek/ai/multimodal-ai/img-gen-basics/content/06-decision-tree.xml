<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Image Generation Basics Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is task = image generation from text prompt AND output requires human review acceptable?</root-question>
    <branch when="task.is_text_to_image == true AND review.acceptable == true">
      <question>Is cost-per-image &lt;= $0.005 required (very high volume)?</question>
      <branch when="cost.per_image_cap_usd &lt;= 0.005">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="cost.per_image_cap_usd &gt; 0.005">
        <question>Need maximum photorealism AND brand can tolerate prompt rewriting?</question>
        <branch when="quality.photoreal_required == true AND brand.tolerates_revision == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="quality.photoreal_required == false OR brand.tolerates_revision == false">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
    <branch when="task.is_text_to_image == false OR review.acceptable == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="article headers + budget $0.05/img + brand tolerates revision → DALL-E 3 path"/>
  </decision-tree>
</text>
