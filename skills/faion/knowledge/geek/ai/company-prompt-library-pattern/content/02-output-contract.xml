<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Company Prompt Library Pattern Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a valid company prompt-library spec. Subagent must satisfy this contract before returning to caller.</summary>

  <output-contract>
    <required>
      <field name="spec_id" type="string" required="true">kebab-case slug identifying this spec</field>
      <field name="owner" type="string" required="true">single named accountable owner of the library overall</field>
      <field name="namespace_map" type="object" required="true">map of namespace path → consumer role/task</field>
      <field name="override_layers" type="list" required="true">ordered list of exactly 4: faion-defaults, role-pack, company-override, repo-override</field>
      <field name="eval_gate" type="object" required="true">CI gate config: scorer list + thresholds + block-on-fail</field>
      <field name="role_packs" type="list" required="true">list of role-packs with per-pack owner + count</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO-8601 date</field>
    </required>

    <forbidden>
      <pattern id="f1">owner = 'team' / 'we' / 'us' / empty</pattern>
      <pattern id="f2">override_layers count not equal to 4 OR wrong order</pattern>
      <pattern id="f3">eval_gate.block_on_fail = false (gate must block)</pattern>
      <pattern id="f4">namespace_map has files outside any namespace</pattern>
      <pattern id="f5">role_packs entry without owner</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Collapse role-packs with fewer than 3 prompts into the company-override layer.</transformation>
      <transformation>Auto-generate spec_id from `&lt;org-slug&gt;-prompt-library` when caller omits it.</transformation>
    </allowed-transformations>

    <schema>
      <schema-reference path="templates/company-prompt-library-pattern.json"/>
    </schema>

    <example valid="true"><![CDATA[
{
  "spec_id": "acme-prompt-library",
  "owner": "alex@acme.com",
  "namespace_map": {
    "prompts/role/pm/": "PM agents",
    "prompts/role/dev/": "dev agents",
    "prompts/task/code-review/": "code-review agents"
  },
  "override_layers": ["faion-defaults", "role-pack", "company-override", "repo-override"],
  "eval_gate": {"scorers": ["rubric-judge", "json-schema"], "threshold": 0.85, "block_on_fail": true},
  "role_packs": [{"name": "pm", "owner": "alex@acme.com", "count": 12}, {"name": "dev", "owner": "kim@acme.com", "count": 18}],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

    <example valid="false"><![CDATA[
{
  "spec_id": "lib",
  "owner": "team",
  "namespace_map": {},
  "override_layers": ["faion-defaults", "repo-override"],
  "eval_gate": {"block_on_fail": false},
  "role_packs": [],
  "version": "v1",
  "last_reviewed": "soon"
}
]]></example>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>override_layers is exactly faion-defaults / role-pack / company-override / repo-override in that order</item>
      <item>Output validates against templates/company-prompt-library-pattern.json</item>
    </list>
  </section>
</text>
