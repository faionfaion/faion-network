<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Champion Challenger Pattern for RAG Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/champion-challenger-pattern-rag.json",
  "type": "object",
  "required": ["bench_id", "cycle", "arms", "judge", "promotion_criteria", "audit_log_uri"],
  "properties": {
    "bench_id": {"type": "string"},
    "cycle": {"type": "object", "required": ["start_date", "days"], "properties": {"start_date": {"type": "string", "format": "date"}, "days": {"type": "integer", "const": 7}}},
    "arms": {"type": "object", "required": ["champion", "challenger"], "properties": {"champion": {"type": "object", "required": ["id", "config_uri", "traffic_pct"], "properties": {"id": {"type": "string"}, "config_uri": {"type": "string"}, "traffic_pct": {"type": "number", "const": 100}}}, "challenger": {"type": "object", "required": ["id", "config_uri", "mode"], "properties": {"id": {"type": "string"}, "config_uri": {"type": "string"}, "mode": {"const": "shadow"}}}}},
    "judge": {"type": "object", "required": ["kind", "model_or_rule"]},
    "promotion_criteria": {"type": "object", "required": ["min_delta_pp", "min_n", "safety_regressions_max"], "properties": {"min_delta_pp": {"type": "number", "minimum": 1}, "min_n": {"type": "integer", "minimum": 100}, "safety_regressions_max": {"type": "integer", "const": 0}}},
    "audit_log_uri": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "bench_id": "rag-chunking-bench-w22",
  "cycle": {
    "start_date": "2026-05-19",
    "days": 7
  },
  "arms": {
    "champion": {
      "id": "chunk-256-overlap-32",
      "config_uri": "configs/champ.yml",
      "traffic_pct": 100
    },
    "challenger": {
      "id": "chunk-384-overlap-64",
      "config_uri": "configs/chall.yml",
      "mode": "shadow"
    }
  },
  "judge": {
    "kind": "llm-as-judge",
    "model_or_rule": "claude-sonnet-4-7"
  },
  "promotion_criteria": {
    "min_delta_pp": 3,
    "min_n": 1000,
    "safety_regressions_max": 0
  },
  "audit_log_uri": "s3://faion-net/rag-bench-audit/"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "bench_id": "x"
}
]]></code>
    <note>Missing cycle, arms, judge, promotion_criteria, audit_log_uri.</note>
  </example>

  <reference path="scripts/validate-champion-challenger-pattern-rag.py">Validator script</reference>
</text>
