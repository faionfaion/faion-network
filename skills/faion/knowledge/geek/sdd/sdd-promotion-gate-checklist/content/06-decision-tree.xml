<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="SDD Promotion Gate Checklist Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf either applies a concrete rule or routes to `skip-this-methodology`.</summary>

  <decision-tree>
    <root-question id="q-root">Is the feature in `backlog/` ready for `todo/`?</root-question>

      <branch when="canonical_files_missing &gt; 0"><conclusion ref="required-files-present" verdict="block — author missing files first"/></branch>
<branch when="canonical_files_missing == 0">
  <question id="q-sub">Are open blockers empty?</question>
    <branch when="open_blockers == 0"><conclusion ref="binary-criteria-only" verdict="promote — checklist passes binary criteria"/></branch>
    <branch when="open_blockers &gt; 0"><conclusion ref="blocker-list" verdict="block — resolve blockers before retry"/></branch>
</branch>
  </decision-tree>

  <example trace="input matches `canonical_files_missing &gt; 0` → conclusion ref=`required-files-present`."/>
</text>
