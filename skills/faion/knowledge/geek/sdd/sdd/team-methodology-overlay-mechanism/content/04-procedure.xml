<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Team Methodology Overlay Mechanism Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>5-step procedure that walks an operator from trigger to validated artefact. Each step names its input, action, output, and (where applicable) a decision gate that stops the flow on policy violation.</summary>

  <section title="Procedure">

<step n="1" name="inventory-deviations">
  <input>Override candidates inventory</input>
  <action>List concrete methodologies needing override.</action>
  <output>Deviation list</output>
</step>
<step n="2" name="pick-scope">
  <input>Deviation list</input>
  <action>Decide per-repo vs per-user per item.</action>
  <output>Scope assignment</output>
</step>
<step n="3" name="author-overlays">
  <input>Scope assignment + base methodology</input>
  <action>Drop overlay files into named paths.</action>
  <output>Overlay files</output>
</step>
<step n="4" name="log-conflicts">
  <input>Overlay files</input>
  <action>Add entries to `.faion/overlays/conflict.log`.</action>
  <output>Conflict log updated</output>
  <decision-gate>Reject overlay without log entry.</decision-gate>
</step>
<step n="5" name="validate-precedence">
  <input>Full overlay manifest</input>
  <action>Run validate-team-methodology-overlay-mechanism.py; confirm chain.</action>
  <output>Validated overlay</output>
</step>
  </section>
</text>
