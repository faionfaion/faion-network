<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Launch Tier Decision Frame Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Launch Tier Decision Frame output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="launch_name" type="string" required="true">named launch</field>
      <field name="funnel_goal" type="string" required="true">enum (signups | paid | waitlist | press | qualitative)</field>
      <field name="selected_tier" type="integer" required="true">1-4 (soft / friend / ph-day / blitz)</field>
      <field name="readiness_score" type="object" required="true">capacity + support + rollback subscores</field>
      <field name="retreat_cost" type="string" required="true">concrete units</field>
      <field name="rationale" type="string" required="true">≥200 chars</field>
      <field name="owner" type="string" required="true">named human owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">selected_tier outside 1-4</pattern>
      <pattern id="f2">rationale length &lt; 200</pattern>
      <pattern id="f3">funnel_goal empty</pattern>
      <pattern id="f4">readiness_score missing capacity / support / rollback</pattern>
      <pattern id="f5">retreat_cost generic ('low' / 'small')</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to downgrade tier post-decision (tier-4 → tier-2) with logged rationale; upgrade requires new decision record.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/launch-tier-decision-frame.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "launch_name": "sample-launch_name",
  "funnel_goal": "sample-funnel_goal",
  "selected_tier": 1,
  "readiness_score": {
    "k": "v"
  },
  "retreat_cost": "sample-retreat_cost",
  "rationale": "sample-rationale",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/launch-tier-decision-frame.json</item>
    </list>
  </section>
</text>
