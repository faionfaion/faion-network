<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Launch Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/product-launch.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "launch_id",
    "audience_segments",
    "stage_gates",
    "success_metrics",
    "rollback_plan",
    "post_launch_review_date",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "launch_id": { "type": "string" },
    "audience_segments": { "type": "array" },
    "stage_gates": { "type": "array" },
    "success_metrics": { "type": "array" },
    "rollback_plan": { "type": "string" },
    "post_launch_review_date": { "type": "string", "format": "date" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-stage-gates</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "product-launch-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "launch_id": "launch_id value",
  "audience_segments": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "stage_gates": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "success_metrics": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "rollback_plan": "rollback_plan value",
  "post_launch_review_date": "2026-05-23",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-product-launch.py">Schema validator (stdlib only).</reference>
</text>
