<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Metric Deviation Hypothesis Framework Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Metric Deviation Hypothesis Framework output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="metric_name" type="string" required="true">named metric</field>
      <field name="baseline" type="object" required="true">baseline value + window</field>
      <field name="deviation_magnitude" type="string" required="true">σ or % vs baseline</field>
      <field name="time_window" type="object" required="true">ISO start/end</field>
      <field name="hypotheses" type="array" required="true">≥3 ranked causal hypotheses with detector + probability</field>
      <field name="next_checks" type="array" required="true">ranked check list with P(falsify) and cost</field>
      <field name="owner" type="string" required="true">named human owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">hypotheses count &lt; 3</pattern>
      <pattern id="f2">any hypothesis missing detector</pattern>
      <pattern id="f3">deviation_magnitude non-numeric</pattern>
      <pattern id="f4">next_checks unranked</pattern>
      <pattern id="f5">probability not in {high, medium, low}</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to consolidate two near-duplicate hypotheses into one with a logged merge note.</transformation>
      <transformation>Allowed to mark a hypothesis 'falsified' mid-investigation; record observed signal that falsified it.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/metric-deviation-hypothesis-framework.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "metric_name": "sample-metric_name",
  "baseline": {
    "k": "v"
  },
  "deviation_magnitude": "sample-deviation_magnitude",
  "time_window": {
    "k": "v"
  },
  "hypotheses": [
    {
      "k": "v"
    }
  ],
  "next_checks": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/metric-deviation-hypothesis-framework.json</item>
    </list>
  </section>
</text>
