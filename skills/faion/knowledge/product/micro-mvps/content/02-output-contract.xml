<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Micro MVPs Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Micro MVPs output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="hypothesis" type="string" required="true">single falsifiable claim with numeric prediction</field>
      <field name="gate_event" type="string" required="true">named gate</field>
      <field name="gate_threshold" type="number" required="true">numeric gate</field>
      <field name="build_window" type="object" required="true">ISO start/end ≤7 days</field>
      <field name="manual_backend_plan" type="string" required="true">explicit description of manual back-end</field>
      <field name="decision_at" type="string" required="true">ISO datetime ≤ window_close + 7 days</field>
      <field name="decision" type="string" required="true">go | kill | iterate</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">build_window &gt; 7 days</pattern>
      <pattern id="f2">hypothesis missing numeric prediction</pattern>
      <pattern id="f3">gate_threshold non-numeric</pattern>
      <pattern id="f4">decision not in {go, kill, iterate}</pattern>
      <pattern id="f5">manual_backend_plan empty AND build_includes_back_end_code == false</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to extend build window by 2 days ONCE with logged rationale (max 9 days total).</transformation>
      <transformation>Allowed to upgrade manual back-end to automated post-decision-go.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/micro-mvps.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "hypothesis": "sample-hypothesis",
  "gate_event": "sample-gate_event",
  "gate_threshold": 1,
  "build_window": {
    "k": "v"
  },
  "manual_backend_plan": "sample-manual_backend_plan",
  "decision_at": "sample-decision_at",
  "decision": "sample-decision",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/micro-mvps.json</item>
    </list>
  </section>
</text>
