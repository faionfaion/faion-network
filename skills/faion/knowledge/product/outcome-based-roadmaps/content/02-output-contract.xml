<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Outcome Based Roadmaps Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Outcome Based Roadmaps output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="quarter" type="string" required="true">yyyy-Qn</field>
      <field name="outcomes" type="array" required="true">≤3 outcome objects with target metrics + opportunities[]</field>
      <field name="solutions" type="array" required="true">linked to opportunities with confidence + delivery_window_month_range</field>
      <field name="public_url" type="string" required="true">stakeholder-facing URL</field>
      <field name="quarter_review" type="object" required="true">shipped/slipped lists + adjustments</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">outcomes count &gt; 3</pattern>
      <pattern id="f2">any row title is a feature verb</pattern>
      <pattern id="f3">any solution with exact-date promise</pattern>
      <pattern id="f4">any solution with empty confidence</pattern>
      <pattern id="f5">quarter_review missing on closed quarter</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to flex delivery window by ±1 month with logged rationale.</transformation>
      <transformation>Allowed to retire an outcome mid-quarter with logged rationale.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/outcome-based-roadmaps.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "quarter": "sample-quarter",
  "outcomes": [
    {
      "k": "v"
    }
  ],
  "solutions": [
    {
      "k": "v"
    }
  ],
  "public_url": "sample-public_url",
  "quarter_review": {
    "k": "v"
  },
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/outcome-based-roadmaps.json</item>
    </list>
  </section>
</text>
