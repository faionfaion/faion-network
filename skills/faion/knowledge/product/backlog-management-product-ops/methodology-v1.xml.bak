<methodology slug="backlog-management">
  <metadata>
    <tier>solo</tier>
    <group>product</group>
    <domain>product-operations</domain>
    <summary>Maintain a prioritized, healthy backlog using DEEP and INVEST principles. Weekly grooming and clear "ready" definition prevent backlogs from becoming dumping grounds.</summary>
    <tags>
