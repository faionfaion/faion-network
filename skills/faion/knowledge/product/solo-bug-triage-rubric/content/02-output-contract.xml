<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solo Bug Triage Rubric Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/solo-bug-triage-rubric.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "bug_id",
    "severity",
    "scope",
    "frequency",
    "reachable",
    "workaround",
    "queue",
    "owner",
    "retest_threshold"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "bug_id": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "p0",
        "p1",
        "p2",
        "p3"
      ]
    },
    "scope": {
      "type": "string"
    },
    "frequency": {
      "type": "string"
    },
    "reachable": {
      "type": "boolean"
    },
    "workaround": {
      "type": "string"
    },
    "queue": {
      "enum": [
        "drop-everything",
        "next-sprint",
        "accept"
      ]
    },
    "owner": {
      "type": "string"
    },
    "retest_threshold": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "solo-bug-triage-rubric-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "bug_id": "bug_id value",
  "severity": "p0",
  "scope": "scope value",
  "frequency": "frequency value",
  "reachable": true,
  "workaround": "workaround value",
  "queue": "drop-everything",
  "owner": "@solo-founder",
  "retest_threshold": "retest_threshold value"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-solo-bug-triage-rubric.py">Schema validator (stdlib only).</reference>
</text>
