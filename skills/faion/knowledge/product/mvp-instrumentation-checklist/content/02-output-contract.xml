<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MVP Instrumentation Checklist Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid MVP Instrumentation Checklist output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="product_name" type="string" required="true">named product</field>
      <field name="acquire" type="object" required="true">event_name + dashboard_segment</field>
      <field name="activate" type="object" required="true">event_name + dashboard_segment</field>
      <field name="retain" type="object" required="true">event_name + dashboard_segment</field>
      <field name="revenue" type="object" required="true">event_name + dashboard_segment</field>
      <field name="dashboard_url" type="string" required="true">public URL</field>
      <field name="launch_gated" type="boolean" required="true">true means checklist gates launch event</field>
      <field name="owner" type="string" required="true">named human owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">any of {acquire, activate, retain, revenue}.event_name empty</pattern>
      <pattern id="f2">activate.event_name == acquire.event_name</pattern>
      <pattern id="f3">dashboard_url empty or localhost</pattern>
      <pattern id="f4">launch_gated != true</pattern>
      <pattern id="f5">owner is collapsed plural</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to merge two near-duplicate events (e.g. 'signup' and 'register') into one; record merge in version log.</transformation>
      <transformation>Allowed to swap analytics tool mid-life with logged rationale and re-emit checklist.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/mvp-instrumentation-checklist.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "product_name": "sample-product_name",
  "acquire": {
    "k": "v"
  },
  "activate": {
    "k": "v"
  },
  "retain": {
    "k": "v"
  },
  "revenue": {
    "k": "v"
  },
  "dashboard_url": "sample-dashboard_url",
  "launch_gated": true,
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/mvp-instrumentation-checklist.json</item>
    </list>
  </section>
</text>
