{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeeklySynthesisOutput",
  "description": "Output schema for the weekly discovery synthesis agent.",
  "type": "object",
  "required": ["week", "themes", "interview_questions", "decision_required"],
  "properties": {
    "week": {
      "type": "string",
      "description": "ISO week identifier, e.g. 2026-W18"
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "evidence_count", "verbatim_samples", "suggested_opportunity"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable ID from controlled vocabulary, e.g. T-onboarding-friction"
          },
          "name": {"type": "string"},
          "evidence_count": {
            "type": "integer",
            "minimum": 3,
            "description": "Must be >= 3 before theme is promoted"
          },
          "verbatim_samples": {
            "type": "array",
            "maxItems": 5,
            "items": {"type": "string"}
          },
          "segments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "suggested_opportunity": {"type": "string"},
          "candidate_solutions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "roadmap_link": {
            "type": ["string", "null"],
            "description": "Existing initiative ID or null if no roadmap item yet"
          }
        }
      }
    },
    "interview_questions": {
      "type": "array",
      "description": "Question scripts for next week's interviews",
      "items": {"type": "string"}
    },
    "decision_required": {
      "type": "array",
      "description": "Items requiring human decision this week. Empty array is acceptable but must be deliberate.",
      "items": {"type": "string"}
    }
  }
}
