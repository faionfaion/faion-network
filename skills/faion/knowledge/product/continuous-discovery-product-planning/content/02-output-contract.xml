<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Continuous Discovery Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/continuous-discovery.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "weekly_touch_count",
    "assumption_tree_url",
    "touch_types",
    "cadence_slot",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "weekly_touch_count": { "type": "integer" },
    "assumption_tree_url": { "type": "string" },
    "touch_types": { "type": "array" },
    "cadence_slot": { "type": "object" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-weekly-touch</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "continuous-discovery-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "weekly_touch_count": 3,
  "assumption_tree_url": "notion://workspace/assumption_tree_url",
  "touch_types": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "cadence_slot": {
    "key": "value"
  },
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-continuous-discovery.py">Schema validator (stdlib only).</reference>
</text>
