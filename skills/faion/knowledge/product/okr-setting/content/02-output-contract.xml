<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OKR Setting Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid OKR Setting output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="quarter" type="string" required="true">yyyy-Qn</field>
      <field name="quarter_dates" type="object" required="true">ISO start/end</field>
      <field name="objectives" type="array" required="true">≤3 objects each with title + owner + KRs[]</field>
      <field name="biweekly_checkin" type="object" required="true">day_of_week + time + recurrence</field>
      <field name="owner" type="string" required="true">named owner (overall)</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">objectives count &gt; 3</pattern>
      <pattern id="f2">any objective with KRs count &lt; 2 OR &gt; 4</pattern>
      <pattern id="f3">any KR with non-numeric target</pattern>
      <pattern id="f4">biweekly_checkin empty</pattern>
      <pattern id="f5">any objective with empty owner OR owner in collapsed-plural set</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to retire one KR mid-quarter with logged rationale (e.g. metric proven irrelevant).</transformation>
      <transformation>Allowed to merge two objectives mid-quarter with logged rationale; archive originals in version log.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/okr-setting.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "quarter": "sample-quarter",
  "quarter_dates": {
    "k": "v"
  },
  "objectives": [
    {
      "k": "v"
    }
  ],
  "biweekly_checkin": {
    "k": "v"
  },
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/okr-setting.json</item>
    </list>
  </section>
</text>
