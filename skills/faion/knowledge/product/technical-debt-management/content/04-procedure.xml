<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Technical Debt Management Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Technical Debt Management end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Codebase + team knowledge</input>
      <action>Capture all known debt in register; rate interest.</action>
      <output>Debt register</output>
    </step>
    <step n="2" name="budget">
      <input>Sprint capacity</input>
      <action>Allocate 10-20% per sprint.</action>
      <output>Budget policy</output>
    </step>
    <step n="3" name="prioritise">
      <input>Debt register + budget</input>
      <action>Top-interest items into current sprint.</action>
      <output>Sprint debt items</output>
    </step>
    <step n="4" name="review">
      <input>Sprint outcomes</input>
      <action>Quarterly: register hygiene + budget compliance.</action>
      <output>Quarterly snapshot</output>
    </step>

  </section>
</text>
