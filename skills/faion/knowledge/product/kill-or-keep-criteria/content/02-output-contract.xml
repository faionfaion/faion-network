<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Kill Or Keep Criteria Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Kill Or Keep Criteria output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="project_name" type="string" required="true">named side-project</field>
      <field name="mrr_snapshot" type="number" required="true">current MRR in USD</field>
      <field name="traffic_snapshot" type="number" required="true">current monthly visits</field>
      <field name="joy_score" type="integer" required="true">1-10 last-7-days self-rating</field>
      <field name="opportunity_cost_candidate" type="string" required="true">named alternative bet</field>
      <field name="evidence_links" type="object" required="true">URL/ticket per floor</field>
      <field name="verdict" type="string" required="true">kill | keep (binary)</field>
      <field name="next_action" type="string" required="true">concrete action attached to verdict</field>
      <field name="template_version" type="string" required="true">kill-criteria-template version pinned</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">verdict not in {kill, keep}</pattern>
      <pattern id="f2">evidence_links missing for any floor</pattern>
      <pattern id="f3">opportunity_cost_candidate empty OR generic ('something else')</pattern>
      <pattern id="f4">joy_score outside 1-10 range</pattern>
      <pattern id="f5">next_action empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to mark a floor 'N/A' with a logged reason (e.g. pre-revenue project has no MRR floor).</transformation>
      <transformation>Allowed to defer verdict ONCE by 7 days if evidence is missing; second defer = auto-kill.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/kill-or-keep-criteria.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "project_name": "sample-project_name",
  "mrr_snapshot": 1,
  "traffic_snapshot": 1,
  "joy_score": 1,
  "opportunity_cost_candidate": "sample-opportunity_cost_candidate",
  "evidence_links": {
    "k": "v"
  },
  "verdict": "sample-verdict",
  "next_action": "sample-next_action",
  "template_version": "sample-template_version",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/kill-or-keep-criteria.json</item>
    </list>
  </section>
</text>
