<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Prioritization MoSCoW Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Feature Prioritization MoSCoW output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="cycle_id" type="string" required="true">sprint / release id</field>
      <field name="capacity" type="number" required="true">story points or hours</field>
      <field name="buckets" type="object" required="true">must / should / could / wont arrays</field>
      <field name="tiebreaker_rule" type="string" required="true">named rule</field>
      <field name="must_cap_pct" type="number" required="true">0-60</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">Must items consume &gt; 60% of capacity</pattern>
      <pattern id="f2">buckets count != 4</pattern>
      <pattern id="f3">tiebreaker_rule empty</pattern>
      <pattern id="f4">wont_items count == 0</pattern>
      <pattern id="f5">any Must item without dod</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to flex Must cap to 70% once per quarter with logged justification + retro.</transformation>
      <transformation>Allowed to merge Could / Won't into 'parked' for tracking only, not for decision.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/feature-prioritization-moscow.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "cycle_id": "sample-cycle_id",
  "capacity": 1,
  "buckets": {
    "k": "v"
  },
  "tiebreaker_rule": "sample-tiebreaker_rule",
  "must_cap_pct": 1,
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/feature-prioritization-moscow.json</item>
    </list>
  </section>
</text>
