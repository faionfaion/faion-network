<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="MVP Scoping Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply MVP Scoping end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="name-risk">
      <input>Discovery output</input>
      <action>One-sentence riskiest assumption.</action>
      <output>Risk statement</output>
    </step>
    <step n="2" name="draw-journey">
      <input>Risk statement</input>
      <action>Minimum end-to-end journey that tests it.</action>
      <output>Journey map</output>
    </step>
    <step n="3" name="cut">
      <input>Journey map + ideas list</input>
      <action>Apply Now/Not-Now policy.</action>
      <output>Scope-in / scope-out</output>
    </step>
    <step n="4" name="commit">
      <input>Scope-in</input>
      <action>Lock thresholds + ship date.</action>
      <output>MVP spec</output>
    </step>

  </section>
</text>
