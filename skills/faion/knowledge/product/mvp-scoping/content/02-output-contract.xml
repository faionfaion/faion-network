<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MVP Scoping Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid MVP Scoping output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="product_name" type="string" required="true">named product</field>
      <field name="aha_moment" type="string" required="true">single moment statement</field>
      <field name="must_have_journey" type="array" required="true">ordered step list</field>
      <field name="build_window" type="object" required="true">ISO start/end ≤4 weeks</field>
      <field name="cut_list" type="array" required="true">≥3 items each with rationale</field>
      <field name="readiness_checklist" type="object" required="true">instrumentation + billing + support + docs booleans</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">build_window &gt; 4 weeks</pattern>
      <pattern id="f2">aha_moment empty</pattern>
      <pattern id="f3">cut_list count &lt; 3</pattern>
      <pattern id="f4">must_have_journey count != 1</pattern>
      <pattern id="f5">any readiness_checklist subcomponent false at launch_at</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to flex build window by +1 week ONCE with logged rationale.</transformation>
      <transformation>Allowed to promote a cut item to must-have post-launch with logged rationale.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/mvp-scoping.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "product_name": "sample-product_name",
  "aha_moment": "sample-aha_moment",
  "must_have_journey": [
    {
      "k": "v"
    }
  ],
  "build_window": {
    "k": "v"
  },
  "cut_list": [
    {
      "k": "v"
    }
  ],
  "readiness_checklist": {
    "k": "v"
  },
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/mvp-scoping.json</item>
    </list>
  </section>
</text>
