<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Backlog Management Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Backlog Management output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="backlog_url" type="string" required="true">tracker URL</field>
      <field name="buckets" type="object" required="true">ready/upcoming/backlog/icebox counts</field>
      <field name="ready_items" type="array" required="true">items in Ready bucket with type, story, AC, estimate, source</field>
      <field name="type_distribution" type="object" required="true">feature/bug/tech_debt/research counts</field>
      <field name="grooming_cadence" type="object" required="true">day_of_week + duration_hours</field>
      <field name="prioritisation_method" type="string" required="true">RICE | MoSCoW | stack</field>
      <field name="archive_proposal_count" type="integer" required="true">items proposed for archive this grooming</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">any Ready item with empty acceptance_criteria</pattern>
      <pattern id="f2">buckets count != 4</pattern>
      <pattern id="f3">any item without type tag</pattern>
      <pattern id="f4">grooming_cadence empty</pattern>
      <pattern id="f5">ready bucket count &gt; 25</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to bulk-archive items with logged reason at grooming; PR-linked items still require human approval.</transformation>
      <transformation>Allowed to merge items with title-similarity &gt; 0.85 after human review.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/backlog-management.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "backlog_url": "sample-backlog_url",
  "buckets": {
    "k": "v"
  },
  "ready_items": [
    {
      "k": "v"
    }
  ],
  "type_distribution": {
    "k": "v"
  },
  "grooming_cadence": {
    "k": "v"
  },
  "prioritisation_method": "sample-prioritisation_method",
  "archive_proposal_count": 1,
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/backlog-management.json</item>
    </list>
  </section>
</text>
