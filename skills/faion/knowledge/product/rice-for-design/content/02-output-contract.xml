<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rice For Design Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rice-for-design.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "backlog_item_id",
    "reach",
    "impact",
    "confidence",
    "effort_design_days",
    "effort_dev_days",
    "rice_score",
    "friction_ref",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "backlog_item_id": {
      "type": "string"
    },
    "reach": {
      "type": "integer"
    },
    "impact": {
      "type": "number"
    },
    "confidence": {
      "type": "number"
    },
    "effort_design_days": {
      "type": "number"
    },
    "effort_dev_days": {
      "type": "number"
    },
    "rice_score": {
      "type": "number"
    },
    "friction_ref": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "rice-for-design-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "backlog_item_id": "backlog_item_id value",
  "reach": 1,
  "impact": 1.0,
  "confidence": 1.0,
  "effort_design_days": 1.0,
  "effort_dev_days": 1.0,
  "rice_score": 1.0,
  "friction_ref": "friction_ref value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-rice-for-design.py">Schema validator (stdlib only).</reference>
</text>
