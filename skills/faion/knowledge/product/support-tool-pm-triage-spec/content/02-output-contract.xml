<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Support Tool Pm Triage Spec Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/support-tool-pm-triage-spec.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "tool",
    "tag_taxonomy",
    "escalation_rules",
    "digest_schedule",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "tool": {
      "type": "string"
    },
    "tag_taxonomy": {
      "type": "array"
    },
    "escalation_rules": {
      "type": "array"
    },
    "digest_schedule": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "support-tool-pm-triage-spec-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "tool": "tool value",
  "tag_taxonomy": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "escalation_rules": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "digest_schedule": "digest_schedule value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-support-tool-pm-triage-spec.py">Schema validator (stdlib only).</reference>
</text>
