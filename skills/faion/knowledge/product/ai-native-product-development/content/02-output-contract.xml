<text id="02-output-contract" title="AI-Native Product Development — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of an AI-native roadmap line: layer + AI component + pinned model + risk tier + build-or-buy decision + inference cost + human-refines UX.</summary>

  <section title="Required fields (JSON Schema)">
    <schema lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["product", "owner", "version", "components"],
  "properties": {
    "product": {"type": "string"},
    "owner": {"type": "string", "pattern": "^[a-zA-Z0-9._-]+:[a-zA-Z0-9._-]+$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["layer", "name", "model_id", "risk_tier", "build_or_buy", "inference_cost_per_active_user_usd_day", "human_refines_ux"],
        "properties": {
          "layer": {"enum": ["research", "design", "development", "testing", "analytics", "support"]},
          "name": {"type": "string"},
          "model_id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]+@[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "risk_tier": {"enum": ["prohibited", "high-risk", "limited", "minimal"]},
          "build_or_buy": {"enum": ["build", "buy"]},
          "build_rationale": {
            "type": "object",
            "properties": {
              "core_differentiator": {"type": "boolean"},
              "unique_data_advantage": {"type": "boolean"},
              "revisit_date": {"type": "string", "format": "date"}
            }
          },
          "inference_cost_per_active_user_usd_day": {"type": "number", "minimum": 0},
          "human_refines_ux": {
            "type": "object",
            "required": ["surface", "telemetry_event"],
            "properties": {
              "surface": {"type": "string"},
              "telemetry_event": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
    ]]></schema>
  </section>

  <section title="Examples">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "product": "design-suite",
  "owner": "ai-pm:alice",
  "version": "1.0.0",
  "components": [
    {
      "layer": "design",
      "name": "prototype-generator",
      "model_id": "claude-opus-4.6@2026-04-01",
      "risk_tier": "limited",
      "build_or_buy": "build",
      "build_rationale": {
        "core_differentiator": true,
        "unique_data_advantage": true,
        "revisit_date": "2027-04-01"
      },
      "inference_cost_per_active_user_usd_day": 0.12,
      "human_refines_ux": {
        "surface": "inline-refine-pill",
        "telemetry_event": "design.refine.applied"
      }
    }
  ]
}
      ]]></code>
    </example>
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "product": "design-suite",
  "components": [
    {"layer": "design", "name": "x", "model_id": "latest"}
  ]
}
      ]]></code>
      <note>"latest" not allowed; risk_tier missing; build_or_buy missing; inference cost missing.</note>
    </example>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>model_id == "latest" or "best available"</description>
      <reason>Silent vendor updates change behaviour.</reason>
    </antipattern>
    <antipattern>
      <description>component without risk_tier classification</description>
      <reason>Compliance debt that compounds.</reason>
    </antipattern>
    <antipattern>
      <description>build decision without core_differentiator AND unique_data_advantage</description>
      <reason>Building commodity capability — pay rent instead.</reason>
    </antipattern>
    <antipattern>
      <description>human_refines_ux missing</description>
      <reason>Wasting the most valuable training signal in the system.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every component carries a pinned model_id (model-name@YYYY-MM-DD).</item>
      <item>Every component has a risk_tier classification.</item>
      <item>Every build decision is justified by core_differentiator AND unique_data_advantage.</item>
      <item>Inference cost is set on every component.</item>
      <item>human_refines_ux is wired with a telemetry event.</item>
    </list>
  </section>
</text>
