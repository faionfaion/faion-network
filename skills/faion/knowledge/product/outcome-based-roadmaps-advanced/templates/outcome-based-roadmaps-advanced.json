{
  "__faion_header__": {
    "purpose": "JSON Schema for the Outcome Based Roadmaps Advanced output contract",
    "consumes": "subagent-produced artefact JSON",
    "produces": "validation verdict (pass/fail with violations)",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "~300 tokens"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.network/schema/outcome-based-roadmaps-advanced.json",
  "title": "Outcome Based Roadmaps Advanced Output Contract",
  "type": "object",
  "required": [
    "horizon",
    "swim_lanes",
    "outcomes_by_quarter",
    "dependency_edges",
    "confidence_decay_applied",
    "quarter_reviews",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "horizon": {
      "type": "object",
      "description": "ISO start/end across ≥2 quarters"
    },
    "swim_lanes": {
      "type": "array",
      "description": "per-product lanes ≥2",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "outcomes_by_quarter": {
      "type": "object",
      "description": "quarter → outcomes[]"
    },
    "dependency_edges": {
      "type": "array",
      "description": "from/to/type/rationale objects",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "confidence_decay_applied": {
      "type": "boolean",
      "description": "true means decay applied unless cited"
    },
    "quarter_reviews": {
      "type": "array",
      "description": "per closed quarter review entry",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "owner": {
      "type": "string",
      "description": "named owner"
    },
    "version": {
      "type": "string",
      "description": "semver"
    },
    "last_reviewed": {
      "type": "string",
      "description": "ISO date",
      "format": "date"
    }
  },
  "additionalProperties": true
}
