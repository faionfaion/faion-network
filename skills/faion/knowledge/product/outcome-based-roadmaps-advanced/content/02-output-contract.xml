<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Outcome Based Roadmaps Advanced Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Outcome Based Roadmaps Advanced output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="horizon" type="object" required="true">ISO start/end across ≥2 quarters</field>
      <field name="swim_lanes" type="array" required="true">per-product lanes ≥2</field>
      <field name="outcomes_by_quarter" type="object" required="true">quarter → outcomes[]</field>
      <field name="dependency_edges" type="array" required="true">from/to/type/rationale objects</field>
      <field name="confidence_decay_applied" type="boolean" required="true">true means decay applied unless cited</field>
      <field name="quarter_reviews" type="array" required="true">per closed quarter review entry</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">swim_lanes count &lt; 2</pattern>
      <pattern id="f2">any dependency edge with type empty</pattern>
      <pattern id="f3">any Q+3 solution with confidence=high AND no cited evidence</pattern>
      <pattern id="f4">outcomes_by_quarter covers only 1 quarter</pattern>
      <pattern id="f5">quarter_reviews missing on closed quarter</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to relax decay (Q+2 high) for solutions with cited multi-data-point evidence.</transformation>
      <transformation>Allowed to merge two swim lanes mid-horizon with logged rationale (e.g. products sunset or merged).</transformation>
    </allowed-transformations>

    <schema-reference path="templates/outcome-based-roadmaps-advanced.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "horizon": {
    "k": "v"
  },
  "swim_lanes": [
    {
      "k": "v"
    }
  ],
  "outcomes_by_quarter": {
    "k": "v"
  },
  "dependency_edges": [
    {
      "k": "v"
    }
  ],
  "confidence_decay_applied": true,
  "quarter_reviews": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/outcome-based-roadmaps-advanced.json</item>
    </list>
  </section>
</text>
