<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mutation Testing Bootstrap Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/mutation-testing-bootstrap.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "language",
    "tool",
    "scope",
    "survivor_gate_pct",
    "ci_budget_minutes"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "language": {
      "enum": [
        "python",
        "javascript",
        "typescript",
        "php",
        "java"
      ]
    },
    "tool": {
      "enum": [
        "mutmut",
        "stryker",
        "infection",
        "pitest"
      ]
    },
    "scope": {
      "enum": [
        "pr-changed-files",
        "full-repo-nightly",
        "module"
      ]
    },
    "survivor_gate_pct": {
      "type": "integer"
    },
    "ci_budget_minutes": {
      "type": "integer"
    },
    "flake_rate_baseline": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">tool not from the canonical list.</pattern>
      <pattern id="f2">scope == &apos;full-repo&apos; on PR job (must be nightly).</pattern>
      <pattern id="f3">survivor_gate_pct &gt; 25 on first bootstrap.</pattern>
      <pattern id="f4">ci_budget_minutes &gt; 10 for PR scope.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "mut-2026-0007",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "language": "python",
  "tool": "mutmut",
  "scope": "pr-changed-files",
  "survivor_gate_pct": 20,
  "ci_budget_minutes": 8,
  "flake_rate_baseline": "0%"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "language": "ruby",
  "tool": "mutant",
  "scope": "full-repo",
  "survivor_gate_pct": 40,
  "ci_budget_minutes": 60
}
]]></code>
    <note>language not in enum; tool not canonical; PR scope with full-repo; survivor gate too lax; budget too high; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-mutation-testing-bootstrap.py">Schema validator (stdlib only).</reference>
</text>
