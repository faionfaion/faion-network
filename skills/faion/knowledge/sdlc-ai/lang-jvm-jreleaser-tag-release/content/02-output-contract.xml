<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="JVM One-Tag Release via JReleaser Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lang-jvm-jreleaser-tag-release.json",
  "type": "object",
  "required": [
    "jreleaser_yml",
    "tag_pattern",
    "signing_enabled",
    "conventional_commits_enforced",
    "github_release_enabled"
  ],
  "properties": {
    "jreleaser_yml": {
      "type": "string"
    },
    "tag_pattern": {
      "const": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "signing_enabled": {
      "const": true
    },
    "conventional_commits_enforced": {
      "const": true
    },
    "github_release_enabled": {
      "const": true
    },
    "distribution_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "maven-central",
          "github-packages",
          "sonatype-snapshots"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "jreleaser_yml": "jreleaser.yml",
  "tag_pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
  "signing_enabled": true,
  "conventional_commits_enforced": true,
  "github_release_enabled": true,
  "distribution_targets": [
    "maven-central",
    "github-packages"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "jreleaser_yml": "release.yml",
  "signing_enabled": false
}
]]></code>
    <note>signing must be True; tag_pattern wrong; conventional commits required.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">signing_enabled == false</pattern>
    <pattern id="f2">tag_pattern doesn&apos;t match SemVer</pattern>
    <pattern id="f3">secrets hard-coded in jreleaser.yml</pattern>
  </section>

  <reference path="scripts/validate-jvm-jreleaser-tag-release.py">Validator script</reference>
</text>
