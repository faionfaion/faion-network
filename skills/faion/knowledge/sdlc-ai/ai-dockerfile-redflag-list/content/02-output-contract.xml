<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI-Generated Dockerfile Red-Flag List Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for ai-dockerfile-redflag-list output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-dockerfile-redflag-list.json",
  "type": "object",
  "required": [
    "dockerfile_path",
    "findings",
    "verdict"
  ],
  "properties": {
    "dockerfile_path": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      },
      "minItems": 0
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "skipped"
      ]
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "rule_id",
        "severity",
        "line",
        "remediation"
      ],
      "properties": {
        "rule_id": {
          "enum": [
            "no-floating-tag",
            "no-root-runtime",
            "no-curl-pipe-shell",
            "no-arg-secret",
            "healthcheck-present",
            "multi-stage-build"
          ]
        },
        "severity": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "dockerfile_path": "services/api/Dockerfile",
  "findings": [
    {"rule_id": "no-floating-tag", "severity": "high", "line": 1, "remediation": "Pin python:3.12 to python:3.12.4-slim-bookworm@sha256:..."},
    {"rule_id": "no-root-runtime", "severity": "high", "line": 18, "remediation": "Add USER app before CMD"}
  ],
  "verdict": "fail"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dockerfile_path": "services/api/Dockerfile",
  "verdict": "ok"
}
    ]]></code>
    <note>`verdict` value `ok` not in enum; `findings` missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-ai-dockerfile-redflag-list.py">Validator script</reference>
</text>
