<text id="06-decision-tree" title="AI-Generated Dockerfile Red-Flag List Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml for ai-dockerfile-redflag-list.</summary>
  <decision-tree>
    <root-question id="q-root">Is the Dockerfile AI-authored and pushed to a multi-tenant registry?</root-question>
    <branch when="ai_authored == false &amp;&amp; senior_review == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="build_once_throwaway == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="ai_authored == true &amp;&amp; contains_floating_tag == true">
      <conclusion ref="no-floating-tag"/>
    </branch>
    <branch when="ai_authored == true &amp;&amp; runs_as_root == true">
      <conclusion ref="no-root-runtime"/>
    </branch>
    <branch when="ai_authored == true &amp;&amp; contains_curl_pipe == true">
      <conclusion ref="no-curl-pipe-shell"/>
    </branch>
    <branch when="ai_authored == true &amp;&amp; contains_arg_secret == true">
      <conclusion ref="no-arg-secret"/>
    </branch>
    <branch when="ai_authored == true &amp;&amp; healthcheck_absent == true">
      <conclusion ref="healthcheck-present"/>
    </branch>
    <branch when="ai_authored == true &amp;&amp; all_checks_pass == true">
      <conclusion ref="multi-stage-build"/>
    </branch>
  </decision-tree>
  <example trace="Dockerfile uses `FROM node:latest` and runs as root → findings include `no-floating-tag` (high) and `no-root-runtime` (high) → verdict=fail → PR blocked."/>
</text>
