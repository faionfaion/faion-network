<text id="04-procedure" title="ADR Decay Detector Agent Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>6-step procedure to apply kb-adr-decay-detector-agent end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="list-adrs">
      <input>ADR root</input>
      <action>Enumerate every `.md` under ADR root.</action>
      <output>ADR list</output>
    </step>
    <step n="2" name="parse-metadata">
      <input>ADR files</input>
      <action>Parse frontmatter (status, supersedes, supersededBy, references).</action>
      <output>Metadata map</output>
    </step>
    <step n="3" name="check-contradictions">
      <input>Code + ADR claims</input>
      <action>Compare ADR claims to current code (imports, configs).</action>
      <output>Contradictions</output>
    </step>
    <step n="4" name="check-references">
      <input>Metadata + repo files</input>
      <action>Check every referenced artifact still exists.</action>
      <output>Missing-artifact list</output>
    </step>
    <step n="5" name="check-supersession">
      <input>Metadata + ADR graph</input>
      <action>Validate supersession is bidirectional + linked.</action>
      <output>Orphan list</output>
    </step>
    <step n="6" name="emit-report">
      <input>All findings</input>
      <action>Write JSON + open review-queue issues.</action>
      <output>Report + issues</output>
    </step>
  </section>
</text>
