<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="CI Evaluation Gate Config Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for ci-eval-gate-config output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ci-eval-gate-config.json",
  "type": "object",
  "required": [
    "fixture_corpus_sha",
    "metrics",
    "baseline_commit",
    "verdict",
    "artifact_url"
  ],
  "properties": {
    "fixture_corpus_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/metric"
      }
    },
    "baseline_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,40}$"
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "skipped"
      ]
    },
    "artifact_url": {
      "type": "string",
      "format": "uri"
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": [
        "name",
        "score",
        "threshold",
        "tolerance",
        "gated"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "threshold": {
          "type": "number"
        },
        "tolerance": {
          "type": "number"
        },
        "gated": {
          "type": "boolean"
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "fixture_corpus_sha": "0000000000000000000000000000000000000000",
  "metrics": {
    "faithfulness": {"name": "faithfulness", "score": 0.91, "threshold": 0.88, "tolerance": 0.02, "gated": true},
    "safety_pii": {"name": "safety_pii", "score": 0.99, "threshold": 0.99, "tolerance": 0.0, "gated": true},
    "latency_p95_ms": {"name": "latency_p95_ms", "score": 1850, "threshold": 2000, "tolerance": 200, "gated": true}
  },
  "baseline_commit": "abc1234",
  "verdict": "pass",
  "artifact_url": "https://ci/runs/42/artifact.json"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "metrics": {"faithfulness": 0.91},
  "verdict": "ok"
}
    ]]></code>
    <note>`metrics` value must be metric object, not bare number; `verdict` not in enum; required fields missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-ci-eval-gate-config.py">Validator script</reference>
</text>
