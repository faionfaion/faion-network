<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Infrastructure-as-Code Lint Floor (shellcheck, hadolint, yamllint, actionlint, tflint) Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="inventory-iac">
      <input>Repo</input>
      <action>Find .sh, Dockerfile, *.yml, .github/workflows/, *.tf files.</action>
      <output>file inventory</output>
    </step>
    <step n="2" name="install-linters">
      <input>Inventory</input>
      <action>Install one linter per format present.</action>
      <output>linters on PATH</output>
    </step>
    <step n="3" name="commit-rc-files">
      <input>Per-tool config</input>
      <action>Author + commit .shellcheckrc / .hadolint.yaml / .yamllint / .tflint.hcl.</action>
      <output>rc files committed</output>
    </step>
    <step n="4" name="wire-hooks-and-ci">
      <input>pre-commit + CI</input>
      <action>Add per-linter hook + CI job.</action>
      <output>gates live</output>
    </step>

  </section>
</text>
