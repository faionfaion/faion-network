<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Linear Agent as First-Class Assignee Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the tracker Linear AND is the MCP server available?</root-question>

      <branch when="tracker_is_linear == false">
        <conclusion ref="skip-this-methodology" verdict="wrong tracker"/>
      </branch>
      <branch when="mcp_available == false">
        <conclusion ref="skip-this-methodology" verdict="no integration"/>
      </branch>
      <branch when="agent_identity == shared_bot">
        <conclusion ref="distinct-agent-identity" verdict="reject: shared bot account"/>
      </branch>
      <branch when="task_list_comment_missing_after_60s == true">
        <conclusion ref="delegation-contract-on-assign" verdict="reject: silent agent"/>
      </branch>
      <branch when="checkpoint_interval &gt; 30 min">
        <conclusion ref="checkpoint-cadence" verdict="reject: cadence too long"/>
      </branch>
      <branch when="agent_transitions_to == Done">
        <conclusion ref="pr-link-final-comment" verdict="reject: agent owns closure"/>
      </branch>
      <branch when="silent_side_effect_detected == true">
        <conclusion ref="no-silent-side-effects" verdict="reject: invisible mutation"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="no-silent-side-effects" verdict="accept: delegation contract complete"/>
      </branch>

  </decision-tree>

  <example trace="tracker-linear-agent-as-assignee-happy-path">
    ENG-4521 assigned to agent-cursor → task list posted 15s later → 4 checkpoints over 50 min → PR linked → In Review.
  </example>
</text>
