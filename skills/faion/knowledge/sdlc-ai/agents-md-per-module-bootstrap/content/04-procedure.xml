<text id="04-procedure" title="AGENTS.md Per-Module Bootstrap Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply AGENTS.md Per-Module Bootstrap end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Repo root</input>
      <action>List all source-containing dirs.</action>
      <output>Dir list</output>
    </step>

    <step n="2" name="draft">
      <input>Dir list</input>
      <action>For each, draft AGENTS.md with required sections.</action>
      <output>Drafts</output>
    </step>

    <step n="3" name="size-check">
      <input>Drafts</input>
      <action>Trim to 20–80 lines; overflow to .agents/.</action>
      <output>Sized drafts</output>
    </step>

    <step n="4" name="symlink-claude">
      <input>Sized drafts</input>
      <action>Add CLAUDE.md with `@AGENTS.md` only.</action>
      <output>Paired pair files</output>
    </step>

    <step n="5" name="validate">
      <input>Paired files</input>
      <action>Run scripts/validate-agents-md-per-module-bootstrap.py.</action>
      <output>Validated coverage</output>
    </step>

  </section>
</text>
