<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AGENTS.md Per-Module Bootstrap Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agents-md-per-module-bootstrap.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "feature_id",
    "summary",
    "items",
    "out_of_scope"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "feature_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "items": {
      "type": "array"
    },
    "out_of_scope": {
      "type": "array"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "agents-md-per-module-bootstrap-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "owner": "@solo-founder",
  "feature_id": "F-example",
  "summary": "One-paragraph problem + outcome statement.",
  "items": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "out_of_scope": [
    "item-x",
    "item-y"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-agents-md-per-module-bootstrap.py">Schema validator (stdlib only).</reference>
</text>
