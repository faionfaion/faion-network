<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="GitLab Duo Agent Platform Developer Flow Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is GitLab version ≥ 18.8 AND is Duo Agent Platform licensed?</root-question>

      <branch when="gitlab_version &lt; 18.8">
        <conclusion ref="min-gitlab-18-8" verdict="reject: locking bug + feature-flag issues"/>
      </branch>
      <branch when="duo_license == false">
        <conclusion ref="skip-this-methodology" verdict="platform not available"/>
      </branch>
      <branch when="trigger_kind == raw_api">
        <conclusion ref="label-triggered-only" verdict="reject: API trigger bypass"/>
      </branch>
      <branch when="approval_rules_respected == false">
        <conclusion ref="approval-rules-preserved" verdict="reject: bypass tokens"/>
      </branch>
      <branch when="task_type_misrouted == true">
        <conclusion ref="flow-per-task-type" verdict="reject: wrong named-flow"/>
      </branch>
      <branch when="audit_log_emitted == false">
        <conclusion ref="audit-trail-via-flow-log" verdict="reject: no audit trail"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="audit-trail-via-flow-log" verdict="accept: Duo flows configured"/>
      </branch>

  </decision-tree>

  <example trace="tracker-gitlab-duo-developer-flow-happy-path">
    GitLab 18.9 + Duo licensed → `agent:implement` triggers Developer Flow → MR opens → approval rule fires → human merges.
  </example>
</text>
