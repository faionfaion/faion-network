<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="MegaLinter as the Polyglot Quality Umbrella in CI Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="audit-languages">
      <input>Repo</input>
      <action>Count languages with &gt; 100 LOC.</action>
      <output>language list</output>
      <decision-gate>If &lt; 3, STOP.</decision-gate>
    </step>
    <step n="2" name="pick-flavour">
      <input>Language list</input>
      <action>Pick MegaLinter flavour: all / per-language combination.</action>
      <output>flavour decision</output>
    </step>
    <step n="3" name="author-config">
      <input>Flavour + exclusions</input>
      <action>Author .mega-linter.yml; explicit linter list.</action>
      <output>config committed</output>
    </step>
    <step n="4" name="wire-ci">
      <input>GH Actions / GitLab CI</input>
      <action>Add MegaLinter job pinned to SHA; upload SARIF.</action>
      <output>CI live</output>
    </step>

  </section>
</text>
