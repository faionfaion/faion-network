<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Tool-Tier Approval Gate Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for inc-tool-tier-approval-gate output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/inc-tool-tier-approval-gate.json",
  "type": "object",
  "required": [
    "tools",
    "default_tier",
    "gates"
  ],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      },
      "minItems": 5
    },
    "default_tier": {
      "const": "T3"
    },
    "gates": {
      "$ref": "#/$defs/gates"
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "required": [
        "name",
        "tier"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "tier": {
          "enum": [
            "T0",
            "T1",
            "T2",
            "T3"
          ]
        },
        "action_class": {
          "type": "string"
        }
      }
    },
    "gates": {
      "type": "object",
      "required": [
        "T0",
        "T1",
        "T2",
        "T3"
      ],
      "properties": {
        "T0": {
          "const": "audit"
        },
        "T1": {
          "const": "audit"
        },
        "T2": {
          "const": "signed-token"
        },
        "T3": {
          "const": "two-person-cooling"
        }
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tools": [
    {"name": "grep", "tier": "T0"},
    {"name": "kubectl-logs", "tier": "T0"},
    {"name": "agent-self-restart", "tier": "T1"},
    {"name": "rollback-service", "tier": "T2", "action_class": "rollback:payments-service"},
    {"name": "cluster-drain", "tier": "T3", "action_class": "drain:prod-cluster-us-east-1"}
  ],
  "default_tier": "T3",
  "gates": {"T0": "audit", "T1": "audit", "T2": "signed-token", "T3": "two-person-cooling"}
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tools": [{"name": "grep", "tier": "T9"}]
}
    ]]></code>
    <note>Tier `T9` not in enum; required `default_tier` and `gates` missing; tool count &lt; 5.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-inc-tool-tier-approval-gate.py">Validator script</reference>
</text>
