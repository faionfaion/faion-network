<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Symbol Index as Always-Fresh LSP/ctags Artifact Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="pick-tool">
      <input>language list</input>
      <action>Pick LSP/SCIP for modern languages; ctags as fallback.</action>
      <output>tool decision</output>
    </step>
    <step n="2" name="init-index">
      <input>tool + repo</input>
      <action>Build initial index; commit to .symbol-index/.</action>
      <output>committed index</output>
    </step>
    <step n="3" name="wire-precommit">
      <input>hook config</input>
      <action>Add incremental-update hook entry.</action>
      <output>hook live</output>
    </step>
    <step n="4" name="wire-ci">
      <input>CI pipeline</input>
      <action>Add gate: regenerate, diff, fail on mismatch.</action>
      <output>CI gate live</output>
    </step>

  </section>
</text>
