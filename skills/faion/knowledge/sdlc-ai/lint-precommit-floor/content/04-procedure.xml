<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Pre-Commit Hooks as the Non-Negotiable Merge Floor Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="pick-framework">
      <input>Team prefs</input>
      <action>Pick one of pre-commit / lefthook / husky+lint-staged.</action>
      <output>framework decided</output>
    </step>
    <step n="2" name="author-config">
      <input>Framework + language list</input>
      <action>Author config with 4+ hook categories.</action>
      <output>config committed</output>
    </step>
    <step n="3" name="wire-setup-command">
      <input>Makefile / scripts/</input>
      <action>Add `make hooks` target.</action>
      <output>one-command setup live</output>
    </step>
    <step n="4" name="wire-ci-mirror">
      <input>CI</input>
      <action>Add CI job running same checks.</action>
      <output>CI mirror live</output>
    </step>

  </section>
</text>
