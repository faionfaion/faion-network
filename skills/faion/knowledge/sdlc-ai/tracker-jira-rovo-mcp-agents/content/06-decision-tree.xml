<text id="06-decision-tree" title="Jira via Atlassian Rovo MCP, Permission-Inheriting Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is Atlassian Cloud in use AND is Rovo MCP licensed?</root-question>

      <branch when="atlassian_cloud == false OR rovo_license == false">
        <conclusion ref="skip-this-methodology" verdict="wrong runtime / no license"/>
      </branch>
      <branch when="ai_clients_use_direct_rest == true">
        <conclusion ref="rovo-mcp-only-bridge" verdict="reject: direct REST bypass"/>
      </branch>
      <branch when="permission_inheritance == false">
        <conclusion ref="permission-inheritance-mandatory" verdict="reject: scope-exceeding service account"/>
      </branch>
      <branch when="native_audit_log == false">
        <conclusion ref="audit-trail-native" verdict="reject: audit trail not native"/>
      </branch>
      <branch when="multiple_mcp_installations == true">
        <conclusion ref="single-mcp-installation" verdict="reject: fragmented audit"/>
      </branch>
      <branch when="scope_projects empty OR cross_project_query == true">
        <conclusion ref="no-cross-project-bleed" verdict="reject: scope leak"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="single-mcp-installation" verdict="accept: Rovo bridge live"/>
      </branch>

  </decision-tree>

  <example trace="tracker-jira-rovo-mcp-agents-happy-path">
    ACME Cloud + Rovo → Claude registered via OAuth → scope=PROJ,DEVOPS → action logged as alice@acme on PROJ-4521.
  </example>
</text>
