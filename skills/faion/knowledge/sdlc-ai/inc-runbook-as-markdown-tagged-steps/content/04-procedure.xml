<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Runbook as Markdown with Tagged Steps Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>5-step procedure to apply inc-runbook-as-markdown-tagged-steps end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="define-tags">
      <input>Tag spec</input>
      <action>Document `[read]`, `[write]`, `[approval-required]`, `[verify]`, `[wait]` semantics.</action>
      <output>TAG-SPEC.md</output>
    </step>
    <step n="2" name="annotate-runbooks">
      <input>Existing markdown</input>
      <action>Add tags + stable ids to every actionable step.</action>
      <output>Annotated runbooks</output>
    </step>
    <step n="3" name="write-parser">
      <input>Parser script</input>
      <action>Parse markdown into step list; emit JSON.</action>
      <output>Parser + JSON</output>
    </step>
    <step n="4" name="wire-executor">
      <input>Executor script</input>
      <action>Execute steps; gate writes on token; emit audit entries.</action>
      <output>Executor</output>
    </step>
    <step n="5" name="test-dry-run">
      <input>Sample runbook</input>
      <action>Run --dry-run; review plan; iterate.</action>
      <output>Dry-run report</output>
    </step>
  </section>
</text>
