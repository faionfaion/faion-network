<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Approval Token as Signed JWT Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for gov-approval-token-signed-jwt output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gov-approval-token-signed-jwt.json",
  "type": "object",
  "required": [
    "issuer_key_id",
    "audience",
    "scope",
    "exp_seconds",
    "nonce_store",
    "hsm_rooted"
  ],
  "properties": {
    "issuer_key_id": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "pattern": "^[a-z]+:[a-z0-9-]+$"
    },
    "exp_seconds": {
      "type": "integer",
      "maximum": 900
    },
    "nonce_store": {
      "type": "string"
    },
    "hsm_rooted": {
      "type": "boolean",
      "const": true
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "issuer_key_id": "kms://arn:aws:kms:eu-west-1:123:key/abc",
  "audience": "prod-cluster-us-east-1",
  "scope": "deploy:payments-service",
  "exp_seconds": 600,
  "nonce_store": "redis://nonce.svc:6379/0",
  "hsm_rooted": true
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "issuer_key_id": "kms://...",
  "audience": "*",
  "scope": "*",
  "exp_seconds": 86400,
  "hsm_rooted": false
}
    ]]></code>
    <note>Wildcard `audience` + `scope`; expiry exceeds 900s; HSM-rooted=false; `nonce_store` missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-gov-approval-token-signed-jwt.py">Validator script</reference>
</text>
