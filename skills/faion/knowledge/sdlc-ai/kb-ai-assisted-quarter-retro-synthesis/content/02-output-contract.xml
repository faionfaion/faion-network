{
  "quarter_metadata": {
    "quarter": "Q1",
    "squads_count": 2
  },
  "dora_deltas": {
    "lead_time": "improved"
  },
  "themes": [],
  "action_items": [
    {
      "title": "Do stuff",
      "owner_role": "team",
      "deadline": "2030-01-01",
      "success_criteria": "x"
    }
  ]
}
]]></code>
    <note>quarter pattern invalid; squads_count&lt;3; DORA lead_time not structured; themes empty; action owner_role generic.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">dora_deltas without source_row pointer</pattern>
    <pattern id="f2">themes with &lt; 2 evidence quotes</pattern>
    <pattern id="f3">action_items with owner_role generic</pattern>
    <pattern id="f4">human_edit_pass.citation_check_passed != true at finalize</pattern>
    <pattern id="f5">ingested raw chat text without redaction step</pattern>
  </section>

  <reference path="scripts/validate-quarter-retro-synthesis.py">Validator script</reference>
</text>
