<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Methodology Versioning and CHANGELOG Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the decision-record artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/methodology-versioning-and-changelog.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "slug",
    "previous_version",
    "bump",
    "changelog_entry",
    "content_id"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "slug": {
      "type": "string"
    },
    "previous_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "bump": {
      "enum": [
        "MAJOR",
        "MINOR",
        "PATCH"
      ]
    },
    "changelog_entry": {
      "type": "string"
    },
    "migration_plan_url": {
      "type": "string"
    },
    "content_id": {
      "type": "string"
    },
    "removed_rule_ids": {
      "type": "array"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">MAJOR bump without migration_plan_url.</pattern>
      <pattern id="f2">Removed rule id with bump != MAJOR.</pattern>
      <pattern id="f3">Stale content_id (does not match sha1(slug+version)[:16]).</pattern>
      <pattern id="f4">Empty changelog_entry.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ver-2026-0014",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "slug": "code-review",
  "previous_version": "1.0.0",
  "bump": "MINOR",
  "changelog_entry": "Added rule no-sole-approver-agent; no schema change.",
  "content_id": "ee8a70147c263798",
  "removed_rule_ids": []
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "2",
  "slug": "code-review",
  "bump": "major",
  "removed_rule_ids": [
    "old-rule"
  ]
}
]]></code>
    <note>Version not semver; bump enum is upper-case; removed_rule_ids non-empty but no migration_plan_url; missing artefact_id, last_reviewed, previous_version, changelog_entry, content_id.</note>
  </example>

  <reference path="scripts/validate-methodology-versioning-and-changelog.py">Schema validator (stdlib only).</reference>
</text>
