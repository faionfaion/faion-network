<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="`agent-fixable` Triage Gate (Humans Pick, Agents Work) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the config artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-task-agent-fixable-triage-gate.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/task-agent-fixable-triage-gate.json",
  "title": "AgentFixableTriagePolicy",
  "type": "object",
  "required": [
    "label",
    "trigger_event",
    "triage_actors_allowed",
    "self_labelling_forbidden",
    "merge_rate_threshold_pct"
  ],
  "properties": {
    "label": {
      "type": "string",
      "const": "agent-fixable"
    },
    "trigger_event": {
      "type": "string",
      "const": "issues.labeled"
    },
    "triage_actors_allowed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "self_labelling_forbidden": {
      "type": "boolean",
      "const": true
    },
    "vendor_labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "merge_rate_threshold_pct": {
      "type": "integer",
      "minimum": 30,
      "maximum": 95
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "label": "agent-fixable",
  "trigger_event": "issues.labeled",
  "triage_actors_allowed": [
    "maintainers",
    "triage-bot-ro"
  ],
  "self_labelling_forbidden": true,
  "vendor_labels": [
    "agent:devin",
    "agent:copilot"
  ],
  "merge_rate_threshold_pct": 60
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "label": "needs-fix",
  "trigger_event": "issues.opened",
  "triage_actors_allowed": [],
  "self_labelling_forbidden": false,
  "merge_rate_threshold_pct": 10
}
]]></code>
    <note>Wrong label; agent dispatches on issues.opened; empty triage allowlist; self-labelling allowed; threshold below floor.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">trigger_event in {issues.opened, issues.reopened, issues.edited}</pattern>
      <pattern id="f2">triage actors include any account matching `*-bot$` or `agent-*` that also has code-write tools</pattern>
      <pattern id="f3">vendor label applied by human triage (must come from router post-pickup)</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-task-agent-fixable-triage-gate.py">Validator script enforcing this contract.</reference>
</text>
