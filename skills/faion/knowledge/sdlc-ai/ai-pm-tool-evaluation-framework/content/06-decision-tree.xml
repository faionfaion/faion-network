<text id="06-decision-tree" title="AI PM Tool Evaluation Framework Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml for ai-pm-tool-evaluation-framework.</summary>
  <decision-tree>
    <root-question id="q-root">Does the team have a real choice between AI-PM vendors?</root-question>
    <branch when="single_dev_trial == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="vendor_mandated == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="data_residency_undisclosed == true">
      <conclusion ref="data-residency-stated"/>
    </branch>
    <branch when="hallucination_rate_unmeasured == true">
      <conclusion ref="hallucination-rate-measured"/>
    </branch>
    <branch when="tracker_fidelity_lossy == true">
      <conclusion ref="tracker-fidelity-preserved"/>
    </branch>
    <branch when="cost_bundled == true">
      <conclusion ref="cost-bounded-per-axis"/>
    </branch>
    <branch when="export_rights_missing == true">
      <conclusion ref="export-rights-explicit"/>
    </branch>
    <branch when="audit_log_partial == true">
      <conclusion ref="audit-log-complete"/>
    </branch>
  </decision-tree>
  <example trace="Vendor AcmePM AI scored on 50-issue fixture → hallucination rate 3% (pass), residency EU-only (pass), cost itemised (pass), weighted_total=4.0 → verdict=recommended."/>
</text>
