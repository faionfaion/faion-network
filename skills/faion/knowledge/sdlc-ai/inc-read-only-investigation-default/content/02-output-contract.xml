<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Read-Only Investigation by Default Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for inc-read-only-investigation-default output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/inc-read-only-investigation-default.json",
  "type": "object",
  "required": [
    "agent_id",
    "default_policy",
    "read_allowlist",
    "write_allowlist",
    "token_verifier",
    "revert_after_incident"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "default_policy": {
      "const": "deny"
    },
    "read_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "write_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "token_verifier": {
      "type": "string"
    },
    "revert_after_incident": {
      "type": "boolean",
      "const": true
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "agent_id": "sre-agent-prod-01",
  "default_policy": "deny",
  "read_allowlist": ["logs:search", "dashboards:read", "code:search", "runbooks:read", "pagerduty:read"],
  "write_allowlist": ["rollback:payments-service", "flag-toggle:checkout-feature"],
  "token_verifier": "https://approvals.internal/verify",
  "revert_after_incident": true
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "agent_id": "sre-agent",
  "default_policy": "allow",
  "write_allowlist": ["*"]
}
    ]]></code>
    <note>`default_policy` must be deny; `write_allowlist` cannot contain wildcard; required fields missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-inc-read-only-investigation-default.py">Validator script</reference>
</text>
