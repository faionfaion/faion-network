<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Faion CLI Agent Adapter Pattern Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid code artefact. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/faion-cli-agent-adapter-pattern.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "inputs_used",
    "modules"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100
    },
    "owner": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "inputs_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source"
        ]
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "language"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "language": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "faion-cli-agent-adapter-pattern-adapter-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "inputs_used": [
    {
      "name": "feed-schema",
      "source": "templates/feed-schema.json"
    }
  ],
  "modules": [
    {
      "name": "anthropic-adapter",
      "path": "templates/anthropic-adapter.py",
      "language": "python"
    },
    {
      "name": "langchain-adapter",
      "path": "templates/langchain-adapter.py",
      "language": "python"
    },
    {
      "name": "openai-adapter",
      "path": "templates/openai-adapter.py",
      "language": "python"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "modules": []
}
]]></code>
    <note>Owner is plural pronoun (or generic group); required fields empty or missing.</note>
  </example>

  <forbidden>
    <pattern id="owner-plural">`owner` is a plural pronoun (`team`, `we`, `us`, `everyone`, `engineering`) or empty string</pattern>
    <pattern id="inputs-empty">`inputs_used` is empty</pattern>
    <pattern id="version-not-semver">`version` does not match `^[0-9]+\.[0-9]+\.[0-9]+$`</pattern>
  </forbidden>

  <reference path="scripts/validate-faion-cli-agent-adapter-pattern.py">Stdlib-only validator implementing this schema.</reference>
</text>
