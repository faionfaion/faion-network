<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="PR Time + Cost Diff Tool Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact the checker posts on the PR, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pr-time-cost-diff-tool.json",
  "type": "object",
  "required": ["pr_number", "base_sha", "head_sha", "eval_set_hash", "cost_table_version", "deltas", "verdict"],
  "properties": {
    "pr_number": {"type": "integer"},
    "base_sha": {"type": "string", "minLength": 7},
    "head_sha": {"type": "string", "minLength": 7},
    "eval_set_hash": {"type": "string", "minLength": 7},
    "cost_table_version": {"type": "string"},
    "deltas": {
      "type": "object",
      "required": ["median_latency_ms", "p95_latency_ms", "usd_per_req_cents", "eval_pass_rate_pct"],
      "properties": {
        "median_latency_ms": {"type": "number"},
        "p95_latency_ms": {"type": "number"},
        "usd_per_req_cents": {"type": "number"},
        "eval_pass_rate_pct": {"type": "number"}
      }
    },
    "verdict": {"enum": ["pass", "fail", "warn"]},
    "budget_breach_reasons": {"type": "array", "items": {"type": "string"}}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pr_number": 482,
  "base_sha": "a1b2c3d",
  "head_sha": "e4f5a6b",
  "eval_set_hash": "1234567",
  "cost_table_version": "2026.05.20",
  "deltas": {"median_latency_ms": 12, "p95_latency_ms": 80, "usd_per_req_cents": 0.3, "eval_pass_rate_pct": -0.5},
  "verdict": "pass",
  "budget_breach_reasons": []
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pr_number": 482,
  "deltas": {"usd_per_req_cents": 0.3},
  "verdict": "ok"
}
]]></code>
    <note>missing base_sha, head_sha, eval_set_hash, cost_table_version; deltas missing three fields; verdict not in enum.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">deltas missing any of {median_latency_ms, p95_latency_ms, usd_per_req_cents, eval_pass_rate_pct}</pattern>
    <pattern id="f2">verdict not in {pass, fail, warn}</pattern>
    <pattern id="f3">cost_table_version absent — vendor drift blends into code diff</pattern>
  </section>

  <reference path="scripts/validate-pr-time-cost-diff-tool.py">Validator script</reference>
</text>
