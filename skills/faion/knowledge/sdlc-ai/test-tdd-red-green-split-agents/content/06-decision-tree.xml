<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="TDD with Red and Green in Separate Agents Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is sub-agent infra available AND are test/source paths cleanly separable?</root-question>

      <branch when="sub_agent_infra == false">
        <conclusion ref="skip-this-methodology" verdict="single-agent only — split is unenforceable"/>
      </branch>
      <branch when="test_source_intermixed == true">
        <conclusion ref="skip-this-methodology" verdict="doctests / inline tests block the split"/>
      </branch>
      <branch when="red_tools_include_src_write == true OR green_tools_include_tests_write == true">
        <conclusion ref="disjoint-tool-permissions" verdict="reject: tools overlap"/>
      </branch>
      <branch when="red_prompt_includes_impl_hints == true">
        <conclusion ref="ac-only-to-red" verdict="reject: RED contaminated"/>
      </branch>
      <branch when="green_prompt_includes_spec == true">
        <conclusion ref="failure-only-to-green" verdict="reject: GREEN contaminated"/>
      </branch>
      <branch when="transition_not_recorded == true">
        <conclusion ref="orchestrator-verifies-transition" verdict="reject: no audit trail"/>
      </branch>
      <branch when="merge_without_recorded_transition == true">
        <conclusion ref="merge-only-on-green" verdict="reject: merge gate bypassed"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="merge-only-on-green" verdict="accept: split-TDD complete"/>
      </branch>

  </decision-tree>

  <example trace="test-tdd-red-green-split-agents-happy-path">
    AC `signup rejects empty email` → RED writes `test_signup_empty_email_rejected` (red) → GREEN edits `signup.py` → suite green → merge.
  </example>
</text>
