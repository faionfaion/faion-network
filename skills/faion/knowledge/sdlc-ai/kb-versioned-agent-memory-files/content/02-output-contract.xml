<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Versioned Agent-Memory Files (decisions / patterns / mistakes) Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/kb-versioned-agent-memory-files.json",
  "type": "object",
  "required": [
    "bundle_path",
    "files",
    "load_on_start",
    "secret_scan_hook"
  ],
  "properties": {
    "bundle_path": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "enum": [
          "decisions.md",
          "patterns.md",
          "mistakes.md",
          "session.md"
        ]
      },
      "uniqueItems": true
    },
    "load_on_start": {
      "const": true
    },
    "secret_scan_hook": {
      "const": true
    },
    "prune_strategy": {
      "enum": [
        "quarterly",
        "size-cap",
        "never"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "bundle_path": ".aidocs/memory/",
  "files": [
    "decisions.md",
    "patterns.md",
    "mistakes.md",
    "session.md"
  ],
  "load_on_start": true,
  "secret_scan_hook": true,
  "prune_strategy": "quarterly"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "bundle_path": ".memory/",
  "files": [
    "notes.md"
  ],
  "load_on_start": false,
  "secret_scan_hook": false
}
]]></code>
    <note>files must be the canonical 4; load_on_start required true; secret_scan_hook required true.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">files != exactly the canonical 4</pattern>
    <pattern id="f2">load_on_start == false</pattern>
    <pattern id="f3">secret_scan_hook == false on memory dir</pattern>
  </section>

  <reference path="scripts/validate-versioned-agent-memory-files.py">Validator script</reference>
</text>
