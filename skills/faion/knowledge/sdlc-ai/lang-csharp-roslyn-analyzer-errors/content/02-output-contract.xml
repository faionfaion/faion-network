<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="C# Roslyn Analyzers as Compile Errors + Public API Lock Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lang-csharp-roslyn-analyzer-errors.json",
  "type": "object",
  "required": [
    "editorconfig_present",
    "escalated_ids",
    "treat_warnings_as_errors",
    "public_api_analyzer_libs",
    "ci_blocks_on_build"
  ],
  "properties": {
    "editorconfig_present": {
      "const": true
    },
    "escalated_ids": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^(CS|CA|VSTHRD|RS)[0-9]+$"
      },
      "contains": {
        "const": "CS8602"
      }
    },
    "treat_warnings_as_errors": {
      "const": true
    },
    "public_api_analyzer_libs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ci_blocks_on_build": {
      "const": true
    },
    "pragma_justification_required": {
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "editorconfig_present": true,
  "escalated_ids": [
    "CS8602",
    "CS8618",
    "CS8625",
    "CA2007",
    "VSTHRD100",
    "VSTHRD002",
    "CA2016",
    "RS0016",
    "RS0017"
  ],
  "treat_warnings_as_errors": true,
  "public_api_analyzer_libs": [
    "src/Foo.Lib",
    "src/Bar.Lib"
  ],
  "ci_blocks_on_build": true,
  "pragma_justification_required": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "editorconfig_present": false,
  "escalated_ids": [
    "CS001"
  ],
  "treat_warnings_as_errors": false
}
]]></code>
    <note>editorconfig_present must be True; escalated_ids must include CS8602 + ≥ 5 entries; treat_warnings_as_errors must be True.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">TreatWarningsAsErrors == false in Release</pattern>
    <pattern id="f2">escalated_ids missing CS8602 or &lt; 5 entries</pattern>
    <pattern id="f3">#pragma warning disable without justification comment</pattern>
  </section>

  <reference path="scripts/validate-csharp-roslyn-analyzer-errors.py">Validator script</reference>
</text>
