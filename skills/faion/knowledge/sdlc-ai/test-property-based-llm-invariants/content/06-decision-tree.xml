<text id="06-decision-tree" title="Property-Based Tests From LLM-Inferred Invariants Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is the function pure AND does grounding source (docstring / types / example) exist?</root-question>

      <branch when="function_pure == false">
        <conclusion ref="pure-functions-only" verdict="reject: impure target"/>
      </branch>
      <branch when="docstring_or_types_or_example == false">
        <conclusion ref="skip-this-methodology" verdict="no grounding source to anchor invariants"/>
      </branch>
      <branch when="invariant_source_citation_empty == true">
        <conclusion ref="invariant-must-be-grounded" verdict="reject: ungrounded invariant"/>
      </branch>
      <branch when="five_families_not_swept == true">
        <conclusion ref="five-property-families" verdict="reject: missed family coverage"/>
      </branch>
      <branch when="example_tests_before_property == true">
        <conclusion ref="property-before-example" verdict="reorder: properties first"/>
      </branch>
      <branch when="seed_floating == true">
        <conclusion ref="seed-pinned" verdict="reject: irreproducible failures"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="seed-pinned" verdict="accept: property suite ready"/>
      </branch>

  </decision-tree>

  <example trace="test-property-based-llm-invariants-happy-path">
    `rle_encode` pure → docstring line 3 grounds round-trip → Hypothesis test pinned seed 42 → suite green.
  </example>
</text>
