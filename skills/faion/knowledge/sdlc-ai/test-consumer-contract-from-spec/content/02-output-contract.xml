<text id="02-output-contract" title="Consumer Contract Tests Generated from OpenAPI / Traffic Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the code artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-test-consumer-contract-from-spec.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/test-consumer-contract-from-spec.json",
  "title": "ConsumerContractGenConfig",
  "type": "object",
  "required": [
    "source_kind",
    "source_uri",
    "source_hash",
    "pact_output_path",
    "client_test_path",
    "broker_url",
    "can_i_deploy_required"
  ],
  "properties": {
    "source_kind": {
      "enum": [
        "openapi",
        "grpc-proto",
        "http-traffic",
        "typed-client"
      ]
    },
    "source_uri": {
      "type": "string"
    },
    "source_hash": {
      "type": "string",
      "minLength": 7
    },
    "pact_output_path": {
      "type": "string",
      "pattern": "\\.json$"
    },
    "client_test_path": {
      "type": "string"
    },
    "broker_url": {
      "type": "string",
      "format": "uri"
    },
    "can_i_deploy_required": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "source_kind": "openapi",
  "source_uri": "git+https://github.com/acme/api@abc1234:openapi.yaml",
  "source_hash": "abc1234def",
  "pact_output_path": "pacts/consumer-acme-web.json",
  "client_test_path": "tests/pact/test_acme_web.py",
  "broker_url": "https://pact.acme.io",
  "can_i_deploy_required": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "source_kind": "openapi",
  "pact_output_path": "pacts/foo.json",
  "can_i_deploy_required": false
}
]]></code>
    <note>Missing source_uri/source_hash/client_test_path/broker_url; can_i_deploy not required.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">source_uri pointing to `latest` or a branch tip without a commit hash</pattern>
      <pattern id="f2">pact_output_path edited manually after generation (git history shows non-generator commits)</pattern>
      <pattern id="f3">client_test_path missing while pact_output_path present</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-test-consumer-contract-from-spec.py">Validator script enforcing this contract.</reference>
</text>
