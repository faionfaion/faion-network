<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pre-Commit Linters MUST Run on Staged Files Only Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lint-staged-only-not-whole-tree.json",
  "type": "object",
  "required": [
    "framework",
    "staged_filter_native",
    "whole_tree_ci_job"
  ],
  "properties": {
    "framework": {
      "enum": [
        "pre-commit",
        "lefthook",
        "husky+lint-staged"
      ]
    },
    "staged_filter_native": {
      "const": true
    },
    "whole_tree_ci_job": {
      "const": true
    },
    "linters_accept_paths": {
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "framework": "lefthook",
  "staged_filter_native": true,
  "whole_tree_ci_job": true,
  "linters_accept_paths": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "framework": "custom-shell-script",
  "staged_filter_native": false,
  "whole_tree_ci_job": false
}
]]></code>
    <note>framework must be one of supported; staged_filter_native must be True; whole_tree_ci_job required.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">framework not in supported list</pattern>
    <pattern id="f2">staged_filter_native == false (custom shell loop)</pattern>
    <pattern id="f3">whole_tree_ci_job == false</pattern>
  </section>

  <reference path="scripts/validate-staged-only-not-whole-tree.py">Validator script</reference>
</text>
