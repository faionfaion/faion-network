<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="License Compliance Scan Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml for gov-license-compliance-scan.</summary>
  <decision-tree>
    <root-question id="q-root">Is the product externally distributed with non-trivial dependencies?</root-question>
    <branch when="internal_only == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="transitive_deps_count &lt; 30 &amp;&amp; license_diversity == 'mit-only'">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="scanner_version_pinned == false">
      <conclusion ref="scanner-pinned"/>
    </branch>
    <branch when="allowlist_missing == true">
      <conclusion ref="allowlist-explicit"/>
    </branch>
    <branch when="denylist_missing_copyleft == true">
      <conclusion ref="denylist-includes-copyleft"/>
    </branch>
    <branch when="direct_only_scan == true">
      <conclusion ref="transitive-deps-included"/>
    </branch>
    <branch when="denied_dep_introduced == true">
      <conclusion ref="new-deps-block-on-deny"/>
    </branch>
    <branch when="sbom_unpublished == true">
      <conclusion ref="sbom-published"/>
    </branch>
  </decision-tree>
  <example trace="PR adds `ghostscript@10.0.0` → syft scan reports AGPL-3.0-or-later → denylist hit → verdict=fail → PR blocked → engineer swaps to mupdf → re-scan → verdict=pass."/>
</text>
