<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Codemod-First Refactor Agent Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the playbook-step artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mr-codemod-refactor-agent.json",
  "type": "object",
  "required": [
    "refactor_id",
    "ast_tool",
    "sites_touched",
    "tests_after_batch",
    "reviewer_agent_separate"
  ],
  "properties": {
    "refactor_id": {
      "type": "string"
    },
    "ast_tool": {
      "enum": [
        "jscodeshift",
        "ts-morph",
        "ast-grep",
        "comby",
        "roslyn"
      ]
    },
    "sites_touched": {
      "type": "integer",
      "minimum": 20
    },
    "tests_after_batch": {
      "const": true
    },
    "reviewer_agent_separate": {
      "const": true
    },
    "pr_documents_transform": {
      "const": true
    },
    "codemod_path": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "refactor_id": "rename-user-id-to-uid",
  "ast_tool": "jscodeshift",
  "sites_touched": 142,
  "tests_after_batch": true,
  "reviewer_agent_separate": true,
  "pr_documents_transform": true,
  "codemod_path": "scripts/codemods/rename-user-id.ts"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "refactor_id": "x",
  "ast_tool": "sed",
  "sites_touched": 3,
  "tests_after_batch": false,
  "reviewer_agent_separate": false
}
]]></code>
    <note>ast_tool must be one of supported; sites_touched &lt; 20; tests_after_batch and reviewer_agent_separate required.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">ast_tool == &apos;sed&apos; or &apos;regex&apos;</pattern>
    <pattern id="f2">tests_after_batch == false</pattern>
    <pattern id="f3">reviewer_agent_separate == false</pattern>
  </section>

  <reference path="scripts/validate-codemod-refactor-agent.py">Validator script</reference>
</text>
