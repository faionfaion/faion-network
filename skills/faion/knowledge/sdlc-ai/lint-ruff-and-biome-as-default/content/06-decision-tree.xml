<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Ruff for Python and Biome for JS/TS as the Sole Linter+Formatter Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable preconditions to a rule from 01-core-rules.xml. Every leaf is a conclusion ref bound to a rule id.</summary>

  <decision-tree>
    <root-question id="q-root">project_phase?</root-question>

    <branch when="phase == new">
      <conclusion ref="ruff-sole-python" verdict="ruff + biome from day 1"/>
    </branch>
    <branch when="phase == legacy">
      <question id="q-2">eslint_custom_rules_count?</question>
        <branch when="custom_rules &gt; 10">
          <conclusion ref="skip-this-methodology" verdict="migration cost too high"/>
        </branch>
        <branch when="custom_rules &lt;= 10">
          <conclusion ref="biome-sole-js" verdict="migrate biome; keep ruff"/>
        </branch>
    </branch>

  </decision-tree>

  <example trace="phase=new (greenfield) → ruff-sole-python → pyproject.toml [tool.ruff] + biome.json">
    Canonical traversal from root question through branches to a single conclusion.
  </example>
</text>
