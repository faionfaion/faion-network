<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Conventional Commits Enforced at the Hook Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for gov-conventional-commits-enforced output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gov-conventional-commits-enforced.json",
  "type": "object",
  "required": [
    "hook_tool",
    "allowed_types",
    "subject_max_length",
    "ci_pr_title_check",
    "release_tool"
  ],
  "properties": {
    "hook_tool": {
      "enum": [
        "lefthook",
        "husky",
        "pre-commit"
      ]
    },
    "allowed_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 11
    },
    "subject_max_length": {
      "type": "integer",
      "const": 72
    },
    "ci_pr_title_check": {
      "type": "boolean",
      "const": true
    },
    "release_tool": {
      "enum": [
        "release-please",
        "semantic-release",
        "changesets"
      ]
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "hook_tool": "lefthook",
  "allowed_types": ["feat", "fix", "chore", "refactor", "docs", "test", "perf", "build", "ci", "style", "revert"],
  "subject_max_length": 72,
  "ci_pr_title_check": true,
  "release_tool": "release-please"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "hook_tool": "homebrew",
  "allowed_types": ["foo", "bar"]
}
    ]]></code>
    <note>`hook_tool` not in enum; types list incomplete; required `subject_max_length`, `ci_pr_title_check`, `release_tool` missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard values where enum is required</item>
      <item>values outside enum / pattern / numeric bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-gov-conventional-commits-enforced.py">Validator script</reference>
</text>
