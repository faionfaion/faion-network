<text id="02-output-contract" title="Spec-Kit Three-Step Pipeline (specify → plan → tasks) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the spec artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-task-spec-kit-three-step.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/task-spec-kit-three-step.json",
  "title": "SpecKitArtifacts",
  "type": "object",
  "required": [
    "spec_md",
    "plan_md",
    "tasks_md",
    "produced_order"
  ],
  "properties": {
    "spec_md": {
      "type": "object",
      "required": [
        "path",
        "clarifications_resolved"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "spec\\.md$"
        },
        "clarifications_resolved": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "plan_md": {
      "type": "object",
      "required": [
        "path",
        "constitution_gate_cited"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "plan\\.md$"
        },
        "constitution_gate_cited": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "tasks_md": {
      "type": "object",
      "required": [
        "path",
        "tasks"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "tasks\\.md$"
        },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "parallel_safe"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "parallel_safe": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "produced_order": {
      "type": "array",
      "items": {
        "enum": [
          "spec.md",
          "plan.md",
          "tasks.md"
        ]
      },
      "const": [
        "spec.md",
        "plan.md",
        "tasks.md"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spec_md": {
    "path": ".speckit/spec.md",
    "clarifications_resolved": true
  },
  "plan_md": {
    "path": ".speckit/plan.md",
    "constitution_gate_cited": true
  },
  "tasks_md": {
    "path": ".speckit/tasks.md",
    "tasks": [
      {
        "id": "T01",
        "parallel_safe": false
      },
      {
        "id": "T02",
        "parallel_safe": true
      }
    ]
  },
  "produced_order": [
    "spec.md",
    "plan.md",
    "tasks.md"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "plan_md": {
    "path": "plan.md",
    "constitution_gate_cited": false
  },
  "tasks_md": {
    "path": "tasks.md",
    "tasks": []
  },
  "produced_order": [
    "plan.md",
    "spec.md"
  ]
}
]]></code>
    <note>Missing spec.md; constitution gate not cited; tasks empty; produced_order violates fixed sequence.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">any artifact created before its predecessor</pattern>
      <pattern id="f2">unresolved [NEEDS CLARIFICATION] markers in spec.md</pattern>
      <pattern id="f3">tasks.md with no [P] reasoning attached when [P] is used</pattern>
      <pattern id="f4">agent prompt set to spec.md or plan.md content</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-task-spec-kit-three-step.py">Validator script enforcing this contract.</reference>
</text>
