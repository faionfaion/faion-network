<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Analysis — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-analysis.json",
  "type": "object",
  "required": [
    "register",
    "raci",
    "comms_plan",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "register": {
      "type": "string"
    },
    "raci": {
      "type": "string"
    },
    "comms_plan": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "register": "sample-register",
  "raci": "sample-raci",
  "comms_plan": "sample-comms_plan",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="register"/>
      <field name="raci"/>
      <field name="comms_plan"/>
      <field name="owner"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">stakeholder name matches r'^(the .* team|.* department|we|us|engineering)$'</pattern>
      <pattern id="f2">raci row missing R or A</pattern>
      <pattern id="f3">comms_plan entry missing cadence OR channel OR owner</pattern>
      <pattern id="f4">register without power_interest quadrant per row</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-stakeholder language preference for multilingual programs.</transformation>
      <transformation>Promote a 'monitor' stakeholder to 'keep informed' on material project changes.</transformation>
      <transformation>Add per-stakeholder dissent-history field for re-engagement projects.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-stakeholder-analysis.py"/>
  </output-contract>
</text>
