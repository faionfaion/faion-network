<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solution Assessment — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/solution-assessment.json",
  "type": "object",
  "required": [
    "assessment_id",
    "baseline_version",
    "stage",
    "compliance_table",
    "business_value_rows",
    "recommendation",
    "remediation_backlog"
  ],
  "properties": {
    "assessment_id": {
      "type": "string"
    },
    "baseline_version": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "compliance_table": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "business_value_rows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendation": {
      "type": "string"
    },
    "remediation_backlog": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "assessment_id": "sample-assessment_id",
  "baseline_version": "sample-baseline_version",
  "stage": "sample-stage",
  "compliance_table": [
    {
      "id": "x1"
    }
  ],
  "business_value_rows": [
    {
      "id": "x1"
    }
  ],
  "recommendation": "sample-recommendation",
  "remediation_backlog": [
    {
      "id": "x1"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="assessment_id"/>
      <field name="baseline_version"/>
      <field name="stage"/>
      <field name="compliance_table"/>
      <field name="business_value_rows"/>
      <field name="recommendation"/>
      <field name="remediation_backlog"/>
    </required>

    <forbidden>
      <pattern id="f1">compliance_table without per-row evidence_url</pattern>
      <pattern id="f2">business_value_row without sample_size</pattern>
      <pattern id="f3">business_value_row with only one source</pattern>
      <pattern id="f4">requirement marked 'Not Met' when business need has changed (should be 'Deprecated')</pattern>
      <pattern id="f5">assessment without baseline_version field</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-segment slicing (geography, customer tier) without removing the overall view.</transformation>
      <transformation>Promote 'Partially Met' to 'Met' only when sample size + triangulation upgrade.</transformation>
      <transformation>Tighten variance bands as data quality improves.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-solution-assessment.py"/>
  </output-contract>
</text>
