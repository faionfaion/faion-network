<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Solution Assessment Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply this methodology end-to-end. Each step names inputs, actions, outputs, and optional decision-gates.</summary>
  <section title="Procedure">
    <step n="1" name="define-assessment-window">
      <input>Launch date + scope</input>
      <action>Choose data window post-launch (e.g. 4-12 weeks).</action>
      <output>Window decision</output>
    </step>
    <step n="2" name="pull-actuals">
      <input>Window + sources</input>
      <action>Pull KPI + usage + support data.</action>
      <output>Actuals dataset</output>
    </step>
    <step n="3" name="compute-deltas">
      <input>Actuals + baselines</input>
      <action>delta_pct per KPI; tag met vs missed.</action>
      <output>Delta table</output>
    </step>
    <step n="4" name="write-pir">
      <input>Delta table + stakeholder feedback</input>
      <action>Assemble PIR with recommendations.</action>
      <output>PIR draft</output>
    </step>
    <step n="5" name="present-and-archive">
      <input>PIR draft + stakeholders</input>
      <action>Walk through findings; archive in engagement repo.</action>
      <output>Final PIR</output>
    </step>
  </section>
</text>
