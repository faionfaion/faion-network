<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Use Case Modeling — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/use-case-modeling.json",
  "type": "object",
  "required": [
    "use_case_id",
    "actor",
    "goal",
    "preconditions",
    "main_scenario",
    "alternate_flows",
    "exception_flows",
    "postconditions",
    "frequency",
    "owner"
  ],
  "properties": {
    "use_case_id": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "main_scenario": {
      "type": "string"
    },
    "alternate_flows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "exception_flows": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "postconditions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "frequency": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "use_case_id": "sample-use_case_id",
  "actor": "sample-actor",
  "goal": "sample-goal",
  "preconditions": [
    {
      "id": "x1"
    }
  ],
  "main_scenario": "sample-main_scenario",
  "alternate_flows": [
    {
      "id": "x1"
    }
  ],
  "exception_flows": [
    {
      "id": "x1"
    }
  ],
  "postconditions": [
    {
      "id": "x1"
    }
  ],
  "frequency": "sample-frequency",
  "owner": "ruslan@faion.net"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="use_case_id"/>
      <field name="actor"/>
      <field name="goal"/>
      <field name="preconditions"/>
      <field name="main_scenario"/>
      <field name="alternate_flows"/>
      <field name="exception_flows"/>
      <field name="postconditions"/>
      <field name="frequency"/>
      <field name="owner"/>
    </required>

    <forbidden>
      <pattern id="f1">actor == 'system' OR actor missing</pattern>
      <pattern id="f2">main_scenario prose instead of numbered steps</pattern>
      <pattern id="f3">alternate_flows count &lt; 1</pattern>
      <pattern id="f4">exception_flows count &lt; 1</pattern>
      <pattern id="f5">frequency missing</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-locale variants for multi-region products.</transformation>
      <transformation>Tighten preconditions as integration discovery matures.</transformation>
      <transformation>Add per-step actor-response time SLA for performance-sensitive flows.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-use-case-modeling.py"/>
  </output-contract>
</text>
