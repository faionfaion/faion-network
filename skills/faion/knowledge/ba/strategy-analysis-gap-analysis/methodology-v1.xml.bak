<methodology slug="strategy-analysis-gap-analysis">
  <metadata>
    <tier>pro</tier>
    <group>ba</group>
    <domain>business-analyst</domain>
    <summary>Identify and measure what must change: each gap row carries area, current metric, future metric, numeric delta, unit, priority H/M/L, evidence URL, and a dependency DAG.</summary>
    <tags>
      <tag>strategy-analysis</tag>
      <tag>gap-analysis</tag>
      <tag>babok</tag>
      <tag>prioritization</tag>
      <tag>measurement</tag>
