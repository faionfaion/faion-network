<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Strategy Analysis — Gap Analysis — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/strategy-analysis-gap-analysis.json",
  "type": "object",
  "required": [
    "gaps",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "gaps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "gaps": [
    {
      "id": "x1"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="gaps"/>
      <field name="owner"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">gap without type</pattern>
      <pattern id="f2">gap without severity OR rationale</pattern>
      <pattern id="f3">gap without owner</pattern>
      <pattern id="f4">gap without current_state_row_id AND future_state_row_id</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-region gap slicing for multi-geography programs.</transformation>
      <transformation>Tighten severity rubric thresholds with portfolio data.</transformation>
      <transformation>Add per-gap remediation-cost estimate for prioritisation.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-strategy-analysis-gap-analysis.py"/>
  </output-contract>
</text>
