<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Strategy Analysis — Gap Analysis — Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to produce the artefact end-to-end.</summary>

  <section title="Procedure">
    <step n="1" name="align-rows">
      <input>current-state + future-state specs</input>
      <action>Match current-state rows to future-state rows.</action>
      <output>alignment map</output>
    </step>
    <step n="2" name="identify-deltas">
      <input>alignment map</input>
      <action>Per matched pair: identify the delta (gap).</action>
      <output>gap candidates</output>
    </step>
    <step n="3" name="score-severity">
      <input>gap candidates + rubric</input>
      <action>Apply rubric; produce severity + rationale.</action>
      <output>scored gaps</output>
    </step>
    <step n="4" name="assign-owners">
      <input>scored gaps + org chart</input>
      <action>Per gap: name remediation owner.</action>
      <output>owned gap list</output>
    </step>
  </section>
</text>
