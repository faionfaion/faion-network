<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Prioritization Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-requirements-prioritization.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-prioritization.json",
  "type": "object",
  "required": [
    "method",
    "ranked",
    "weights"
  ],
  "properties": {
    "method": {
      "enum": [
        "MoSCoW",
        "RICE",
        "WSJF",
        "Hybrid"
      ]
    },
    "ranked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "req_id",
          "score",
          "bucket"
        ]
      }
    },
    "weights": {
      "type": "object"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "method": "RICE",
  "ranked": [
    {
      "req_id": "REQ-001",
      "score": 142.5,
      "bucket": "Must"
    },
    {
      "req_id": "REQ-002",
      "score": 88.0,
      "bucket": "Should"
    }
  ],
  "weights": {
    "reach": 1.0,
    "impact": 1.0,
    "confidence": 1.0,
    "effort": 1.0
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "method": "Best"
}
]]></code>
    <note>method not in enum; ranked + weights missing.</note>
  </example>

  <forbidden>
    <pattern id="everything-must" severity="high">MoSCoW partition has 90% items in 'Must'.</pattern>
    <pattern id="phantom-confidence" severity="medium">RICE confidence = 100% for every requirement.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-prioritization.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
