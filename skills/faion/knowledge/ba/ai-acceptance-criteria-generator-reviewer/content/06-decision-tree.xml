<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI Acceptance Criteria Generator Reviewer Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable rubric signals to a rule from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="q-anchors-present">All dimensions have anchors_1_3_5 written?</root-question>
    <branch when="anchors_1_3_5 == false">
      <conclusion ref="r1" verdict="reject rubric; rewrite anchors before scoring"/>
    </branch>
    <branch when="anchors_1_3_5 == true">
      <question id="q-evidence">Every dimension_score has evidence_refs non-empty?</question>
      <branch when="evidence_refs.length == 0">
        <conclusion ref="r2" verdict="reject score; require evidence before reconciliation"/>
      </branch>
      <branch when="evidence_refs.length &gt;= 1">
        <question id="q-stakes">decision_value_usd &gt;= 10000?</question>
        <branch when="decision_value_usd &gt;= 10000 AND rater_count &lt; 2">
          <conclusion ref="r3" verdict="add second rater + reconciliation before composite"/>
        </branch>
        <branch when="decision_value_usd &lt; 10000 OR rater_count &gt;= 2">
          <question id="q-weights">weights_locked_at recorded BEFORE first score?</question>
          <branch when="weights_locked_at &gt; first_score_timestamp">
            <conclusion ref="r4" verdict="reset run; re-lock weights before scoring"/>
          </branch>
          <branch when="weights_locked_at &lt;= first_score_timestamp">
            <conclusion ref="r1" verdict="accept rubric; compute weighted_total"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="standard-pass">
    anchors_1_3_5=true → evidence_refs=[draft.md#L12] → decision_value_usd=5000 → weights_locked_at=2026-05-23T09:00:00Z &lt; first_score → accept rubric (r1).
  </example>
</text>
