<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Interface Analysis Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/interface-analysis.json",
  "title": "interface-specification",
  "type": "object",
  "required": [
    "interface_id",
    "name",
    "type",
    "data_elements",
    "protocol",
    "frequency",
    "volume",
    "security",
    "error_handling",
    "owner"
  ],
  "properties": {
    "interface_id": {
      "type": "string",
      "pattern": "^IF-[0-9]{4}$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "enum": [
        "system",
        "user",
        "hardware",
        "communication"
      ]
    },
    "data_elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "direction"
        ]
      }
    },
    "protocol": {
      "type": "object",
      "required": [
        "name",
        "version"
      ]
    },
    "frequency": {
      "type": "string"
    },
    "volume": {
      "type": "object",
      "required": [
        "records_per_day",
        "peak_per_minute"
      ]
    },
    "security": {
      "type": "object",
      "required": [
        "authn",
        "authz",
        "encryption_in_transit",
        "encryption_at_rest",
        "data_classification"
      ]
    },
    "error_handling": {
      "type": "object",
      "required": [
        "retry",
        "dlq",
        "alerting"
      ]
    },
    "owner": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "interface_id": "IF-0012",
  "name": "Order events to billing",
  "type": "system",
  "data_elements": [
    {
      "name": "order_id",
      "type": "string",
      "direction": "out"
    }
  ],
  "protocol": {
    "name": "kafka",
    "version": "3.6"
  },
  "frequency": "continuous",
  "volume": {
    "records_per_day": 250000,
    "peak_per_minute": 600
  },
  "security": {
    "authn": "mTLS",
    "authz": "RBAC",
    "encryption_in_transit": "TLS1.3",
    "encryption_at_rest": "AES-256",
    "data_classification": "PII"
  },
  "error_handling": {
    "retry": "exp-backoff",
    "dlq": "kafka:billing.dlq",
    "alerting": "pagerduty:billing-on-call"
  },
  "owner": "Order Platform"
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "interface_id": "IF1",
  "name": "events"
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-interface-analysis.py">Validates an artefact against this schema.</reference>
</text>
