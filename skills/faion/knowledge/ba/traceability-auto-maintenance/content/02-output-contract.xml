<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Traceability Auto-Maintenance — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/traceability-auto-maintenance.json",
  "type": "object",
  "required": [
    "graph_id",
    "schema_version",
    "refresh_at",
    "owner",
    "nodes",
    "edges",
    "diff_log",
    "alerts"
  ],
  "properties": {
    "graph_id": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "refresh_at": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "diff_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "graph_id": "sample-graph_id",
  "schema_version": "sample-schema_version",
  "refresh_at": "sample-refresh_at",
  "owner": "ruslan@faion.net",
  "nodes": [
    {
      "id": "x1"
    }
  ],
  "edges": [
    {
      "id": "x1"
    }
  ],
  "diff_log": [
    {
      "id": "x1"
    }
  ],
  "alerts": [
    {
      "id": "x1"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="graph_id"/>
      <field name="schema_version"/>
      <field name="refresh_at"/>
      <field name="owner"/>
      <field name="nodes"/>
      <field name="edges"/>
      <field name="diff_log"/>
      <field name="alerts"/>
    </required>

    <forbidden>
      <pattern id="f1">refresh_at older than 24h</pattern>
      <pattern id="f2">alert without owner</pattern>
      <pattern id="f3">graph derived from a copy (not SoR)</pattern>
      <pattern id="f4">connector failure with no 'stale' flag</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-team alert routing for large engagements.</transformation>
      <transformation>Tighten link-decay thresholds as conventions mature.</transformation>
      <transformation>Add per-edge confidence tier for inferred links.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-traceability-auto-maintenance.py"/>
  </output-contract>
</text>
