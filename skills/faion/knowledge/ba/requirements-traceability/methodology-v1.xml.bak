<methodology slug="requirements-traceability">
  <metadata>
    <tier>pro</tier>
    <group>ba</group>
    <domain>business-analyst</domain>
    <summary>Bidirectional traceability links artifacts to origins and dependents, enabling coverage and justification analysis. RTM is generated from frontmatter links, never hand-edited.</summary>
    <tags>
      <tag>traceability</tag>
      <tag>requirements</tag>
      <tag>rtm</tag>
      <tag>coverage</tag>
      <tag>impact-analysis</tag>
    </tags>
    <category>requirements</category>
    <difficulty>advanced</difficulty>
