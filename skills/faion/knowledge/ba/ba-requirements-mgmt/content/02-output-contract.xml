<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="BA Requirements Management Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-ba-requirements-mgmt.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ba-requirements-mgmt.json",
  "type": "object",
  "required": [
    "register",
    "change_requests",
    "approval_thresholds"
  ],
  "properties": {
    "register": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "req_id",
          "current_version",
          "status"
        ]
      }
    },
    "change_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cr_id",
          "req_id",
          "classification",
          "impact",
          "approver",
          "decision"
        ]
      }
    },
    "approval_thresholds": {
      "type": "object",
      "required": [
        "scope_change",
        "clarification"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "register": [
    {
      "req_id": "REQ-001",
      "current_version": "1.2.0",
      "status": "approved"
    }
  ],
  "change_requests": [
    {
      "cr_id": "CR-014",
      "req_id": "REQ-001",
      "classification": "scope",
      "impact": "medium",
      "approver": "amaia@acme.com",
      "decision": "approved"
    }
  ],
  "approval_thresholds": {
    "scope_change": "VP+",
    "clarification": "BA"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "register": []
}
]]></code>
    <note>register is empty (min 1); change_requests + approval_thresholds missing entirely.</note>
  </example>

  <forbidden>
    <pattern id="unversioned-changes" severity="high">Requirements are edited in-place; no version history exists.</pattern>
    <pattern id="rubber-stamp-approval" severity="medium">Every CR is approved by default; the threshold is decorative.</pattern>
  </forbidden>

  <reference path="scripts/validate-ba-requirements-mgmt.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
