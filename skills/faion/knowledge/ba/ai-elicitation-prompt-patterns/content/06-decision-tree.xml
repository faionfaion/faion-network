<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI Elicitation Prompt Patterns Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from elicitation-phase signal to the matching pattern + rule from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="q-session-goal">Session goal?</root-question>
    <branch when="session_goal == prep_questions_from_brief">
      <question id="q-versioned-1">Pattern stored in git with semver tag?</question>
      <branch when="versioned == false">
        <conclusion ref="r1" verdict="commit pattern to repo with semver tag before use"/>
      </branch>
      <branch when="versioned == true">
        <conclusion ref="r2" verdict="use interview-prep pattern; ensure eval set linked"/>
      </branch>
    </branch>
    <branch when="session_goal == probe_followup_from_answers">
      <conclusion ref="r4" verdict="use follow-up pattern with structured output schema"/>
    </branch>
    <branch when="session_goal == confirm_understanding">
      <conclusion ref="r4" verdict="use paraphrase-back pattern; output is structured pairs (original, paraphrase)"/>
    </branch>
    <branch when="session_goal == probe_from_persona">
      <question id="q-budget">budget.tokens_out declared?</question>
      <branch when="budget.tokens_out == null">
        <conclusion ref="r3" verdict="declare cost budget before deploying"/>
      </branch>
      <branch when="budget.tokens_out &gt; 0">
        <conclusion ref="r4" verdict="use persona-probe pattern with persona slot"/>
      </branch>
    </branch>
  </decision-tree>
  <example trace="prep">
    session_goal=prep_questions_from_brief → versioned=true → use interview-prep pattern (r2).
  </example>
</text>
