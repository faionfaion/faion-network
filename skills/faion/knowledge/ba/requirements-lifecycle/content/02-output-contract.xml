<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Lifecycle Management Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-lifecycle.json",
  "title": "requirement-lifecycle-record",
  "type": "object",
  "required": [
    "req_id",
    "current_state",
    "transitions",
    "change_log"
  ],
  "properties": {
    "req_id": {
      "type": "string"
    },
    "current_state": {
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "implemented",
        "verified",
        "deferred",
        "rejected"
      ]
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "by",
          "at",
          "evidence"
        ]
      }
    },
    "change_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "change_id",
          "change_type",
          "impact",
          "approvers",
          "approved_at"
        ]
      }
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "req_id": "SR-0042",
  "current_state": "verified",
  "transitions": [
    {
      "from": "draft",
      "to": "reviewed",
      "by": "BA Lead",
      "at": "2026-05-12",
      "evidence": "review-pack-v1"
    },
    {
      "from": "reviewed",
      "to": "approved",
      "by": "Sponsor",
      "at": "2026-05-14",
      "evidence": "signed-ac-form"
    }
  ],
  "change_log": []
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "req_id": "SR-0042",
  "current_state": "draft",
  "transitions": [
    {
      "from": "verified",
      "to": "draft"
    }
  ]
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-lifecycle.py">Validates an artefact against this schema.</reference>
</text>
