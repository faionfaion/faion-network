<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="BA Methodologies Detail Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/methodologies-detail.json",
  "title": "ba-framework-selection",
  "type": "object",
  "required": [
    "record_id",
    "ka",
    "frameworks",
    "deliverables"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^FRS-[0-9]{4}$"
    },
    "ka": {
      "enum": [
        "KA-1",
        "KA-2",
        "KA-3",
        "KA-4",
        "KA-5",
        "KA-6"
      ]
    },
    "frameworks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "governance",
          "communication-plan",
          "elicitation-prep",
          "requirements-maintenance",
          "change-impact",
          "current-state",
          "future-state",
          "risk-analysis",
          "change-strategy",
          "requirements-architecture",
          "solution-options",
          "solution-limitations"
        ]
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "framework",
          "template",
          "owner"
        ]
      }
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "record_id": "FRS-0003",
  "ka": "KA-4",
  "frameworks": [
    "current-state",
    "future-state",
    "risk-analysis"
  ],
  "deliverables": [
    {
      "framework": "current-state",
      "template": "templates/current-state.md",
      "owner": "BA Lead"
    }
  ]
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "record_id": "x",
  "frameworks": []
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-methodologies-detail.py">Validates an artefact against this schema.</reference>
</text>
