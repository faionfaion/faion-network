<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Validation and Sign-Off Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-validation.json",
  "title": "validation-pack",
  "type": "object",
  "required": [
    "pack_id",
    "scores",
    "review_sessions",
    "sign_off",
    "dissent"
  ],
  "properties": {
    "pack_id": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "description": "req_id -> { attribute -> 1..5 }"
    },
    "review_sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "session_id",
          "scope",
          "technique",
          "attendees"
        ]
      }
    },
    "sign_off": {
      "type": "object",
      "required": [
        "status",
        "signed_at",
        "signed_by"
      ]
    },
    "dissent": {
      "type": "array"
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pack_id": "VP-2026Q2",
  "scores": {
    "SR-0042": {
      "atomic": 5,
      "complete": 5,
      "consistent": 4,
      "correct": 5,
      "feasible": 4,
      "modifiable": 4,
      "prioritized": 5,
      "testable": 5,
      "traceable": 5,
      "unambiguous": 5
    }
  },
  "review_sessions": [
    {
      "session_id": "RS-0007",
      "scope": "Finance Ops",
      "technique": "inspection",
      "attendees": [
        "BA",
        "Sponsor",
        "QA Lead"
      ]
    }
  ],
  "sign_off": {
    "status": "approved",
    "signed_at": "2026-05-22",
    "signed_by": "Sponsor"
  },
  "dissent": []
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pack_id": "VP-x"
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-validation.py">Validates an artefact against this schema.</reference>
</text>
