<methodology slug="knowledge-areas-detail">
  <metadata>
    <tier>pro</tier>
    <group>ba</group>
    <domain>business-analyst</domain>
    <summary>Detailed reference for all six BABOK Knowledge Areas with per-KA task tables, key outputs, linked methodologies, and canonical workflow sequences for greenfield engagements and change requests.</summary>
