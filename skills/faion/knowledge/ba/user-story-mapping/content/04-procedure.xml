<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="User Story Mapping — Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to produce the artefact end-to-end.</summary>

  <section title="Procedure">
    <step n="1" name="lay-journey">
      <input>use cases or journey definition</input>
      <action>Lay user-journey steps horizontally.</action>
      <output>journey backbone</output>
    </step>
    <step n="2" name="draft-slices">
      <input>journey backbone</input>
      <action>Identify viable release slices vertically.</action>
      <output>slices</output>
    </step>
    <step n="3" name="name-walking-skeleton-mvp">
      <input>slices</input>
      <action>Name walking-skeleton + MVP releases.</action>
      <output>release names</output>
    </step>
    <step n="4" name="write-ac">
      <input>stories</input>
      <action>Author ≥3 AC per story; link to use case or journey step.</action>
      <output>story rows + AC</output>
    </step>
    <step n="5" name="review-with-po">
      <input>draft map + PO</input>
      <action>Walkthrough; capture corrections; bump last_reviewed.</action>
      <output>signed map</output>
    </step>
  </section>
</text>
