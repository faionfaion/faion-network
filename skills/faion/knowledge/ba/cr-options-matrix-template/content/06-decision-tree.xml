<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="CR Options Matrix Template — Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the CR bin L (major) AND can ≥2 viable options be enumerated?</root-question>
      <branch when="bin != 'L'">
        <conclusion ref="r5-no-straw-men" verdict="skip — use cr-impact-memo-template instead"/>
      </branch>
      <branch when="bin == 'L' AND options_viable &lt; 2">
        <conclusion ref="r1-two-or-more-options" verdict="block — enumerate genuine options"/>
      </branch>
      <branch when="bin == 'L' AND options_viable &gt;= 2 AND approver_missing">
        <conclusion ref="r3-named-approver" verdict="block — identify approver"/>
      </branch>
      <branch when="bin == 'L' AND options_viable &gt;= 2 AND approver_named">
        <conclusion ref="r2-scored-on-cost-value-risk" verdict="score options and recommend"/>
      </branch>
  </decision-tree>
  <example trace="CR-202 → bin=L → 3 viable options → approver=steering → matrix built"/>
</text>
