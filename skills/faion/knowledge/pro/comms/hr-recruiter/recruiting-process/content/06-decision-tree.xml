<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Recruiting Process (Full-Cycle) Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from `content/01-core-rules.xml`. Every leaf names either a concrete rule id or `skip-this-methodology` when the case is out of scope. Max depth = 2.</summary>

  <decision-tree>
    <root-question id="q-root">Is this a new requisition or an audit of an existing stage?</root-question>
      <branch when="requisition_type == new">
        <conclusion ref="r7" verdict="apply rule r7 from content/01-core-rules.xml"/>
      </branch>
      <branch when="requisition_type == audit AND failing_stage == sourcing">
        <conclusion ref="r1" verdict="apply rule r1 from content/01-core-rules.xml"/>
      </branch>
      <branch when="requisition_type == audit AND failing_stage == screening">
        <conclusion ref="r6" verdict="apply rule r6 from content/01-core-rules.xml"/>
      </branch>
      <branch when="requisition_type == audit AND failing_stage == offer">
        <conclusion ref="r11" verdict="apply rule r11 from content/01-core-rules.xml"/>
      </branch>
      <branch when="requisition_type == executive_search_retained">
        <conclusion ref="skip-this-methodology" verdict="skip-this-methodology: this case is out of scope for this methodology"/>
      </branch>
  </decision-tree>

  <example trace="primary-path">
    Observable: requisition_type == new → conclusion: r7.
  </example>
</text>
