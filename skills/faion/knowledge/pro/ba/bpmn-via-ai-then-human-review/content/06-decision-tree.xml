<text id="06-decision-tree" title="BPMN via AI then Human Review Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from artefact-state signal to the active rule.</summary>
  <decision-tree>
    <root-question id="q-bpmn-via-ai-then-human-review-root">BPMN XML validates against schema?</root-question>
    <branch when="validation_status != 'passed'">
      <conclusion ref="r2-typed-input" verdict="fix BPMN; rerun pm4py validate"/>
    </branch>
    <branch when="validation_status == 'passed'">
      <conclusion ref="r3-named-owner" verdict="advance to SME review"/>
    </branch>
  </decision-tree>
  <example trace="bpmn-via-ai-then-human-review-pass">
    All required fields populated → named owner ≥2 tokens → version_tag semver → publish (r4).
  </example>
</text>
