<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Contractor Brief Template (Self-Contained) — Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the deliverable shape well-defined enough to write AC?</root-question>
      <branch when="deliverable_definite == false">
        <conclusion ref="r2-ac-three-plus" verdict="skip — switch to discovery-sprint brief"/>
      </branch>
      <branch when="deliverable_definite AND escalation_owner_missing">
        <conclusion ref="r4-named-escalation-owner" verdict="block — assign escalation owner"/>
      </branch>
      <branch when="deliverable_definite AND escalation_owner_named AND terms_undecided">
        <conclusion ref="r5-terms-inline" verdict="block — finalise rate + terms"/>
      </branch>
      <branch when="all_prereqs_met">
        <conclusion ref="r1-self-contained" verdict="draft the self-contained brief"/>
      </branch>
  </decision-tree>
  <example trace="GIG-23 → deliverable definite → owner=ruslan → rate $X → draft brief"/>
</text>
