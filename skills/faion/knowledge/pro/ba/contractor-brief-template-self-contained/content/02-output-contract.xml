<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Contractor Brief Template (Self-Contained) — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/contractor-brief-template-self-contained.json",
  "type": "object",
  "required": [
    "brief_id",
    "owner",
    "context",
    "deliverable",
    "acceptance_criteria",
    "evidence_checkpoints",
    "rate",
    "payment_terms",
    "escalation_owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "brief_id": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string"
    },
    "deliverable": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "string"
    },
    "evidence_checkpoints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "rate": {
      "type": "string"
    },
    "payment_terms": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "escalation_owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "brief_id": "sample-brief_id",
  "owner": "ruslan@faion.net",
  "context": "sample-context",
  "deliverable": "sample-deliverable",
  "acceptance_criteria": "sample-acceptance_criteria",
  "evidence_checkpoints": [
    {
      "id": "x1"
    }
  ],
  "rate": "sample-rate",
  "payment_terms": [
    {
      "id": "x1"
    }
  ],
  "escalation_owner": "sample-escalation_owner",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="brief_id"/>
      <field name="owner"/>
      <field name="context"/>
      <field name="deliverable"/>
      <field name="acceptance_criteria"/>
      <field name="evidence_checkpoints"/>
      <field name="rate"/>
      <field name="payment_terms"/>
      <field name="escalation_owner"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">owner = 'team' / 'we' / 'us' / empty string</pattern>
      <pattern id="f2">rationale that does not reference any input by name</pattern>
      <pattern id="f3">inputs_used is empty AND decision is not 'no-op'</pattern>
      <pattern id="f4">duplicate artefact_id within the same store</pattern>
      <pattern id="f5">brief contains link to gated doc</pattern>
      <pattern id="f6">acceptance_criteria count &lt; 3</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Trim rationale to ≤500 chars, preserving numeric claims and named tools.</transformation>
      <transformation>Promote a 'no decision yet' state to status='pending' rather than fabricating a decision.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-contractor-brief-template-self-contained.py"/>
  </output-contract>
</text>
