<text id="04-procedure" title="Requirements Validation and Sign-Off Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply the requirements-validation methodology end-to-end.</summary>

  <section title="Procedure">
    <step n="1" name="score-attributes">
      <input>Pack</input>
      <action>Score each requirement on 10 attributes.</action>
      <output>Score sheet</output>
    </step>
    <step n="2" name="match-technique">
      <input>Pack + types</input>
      <action>Pick walkthrough/inspection/prototype.</action>
      <output>Technique map</output>
    </step>
    <step n="3" name="run-segmented-review">
      <input>Pack + technique map</input>
      <action>≤200 reqs per session; capture dissent.</action>
      <output>Session log</output>
    </step>
    <step n="4" name="sign-off-gate">
      <input>Score + dissent + session log</input>
      <action>Sponsor sign-off; gate to baseline.</action>
      <output>Sign-off pack</output>
      <decision-gate>Validate against the output contract before declaring done; if invalid, loop back to the failing step.</decision-gate>
    </step>
  </section>
</text>
