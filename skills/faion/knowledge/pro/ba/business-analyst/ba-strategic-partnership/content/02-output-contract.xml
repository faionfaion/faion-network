<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="BA Strategic Partnership Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the BA Strategic Partnership artefact shape.</summary>
  <section title="JSON Schema (draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ba-strategic-partnership.json",
  "type": "object",
  "required": [
    "ba_name",
    "period",
    "sponsor_name",
    "version_tag",
    "okrs_coowned",
    "business_cases_authored",
    "sponsor_syncs"
  ],
  "properties": {
    "ba_name": {
      "type": "string",
      "minLength": 2
    },
    "period": {
      "type": "string",
      "pattern": "^\\d{4}Q[1-4]$"
    },
    "sponsor_name": {
      "type": "string",
      "minLength": 2
    },
    "version_tag": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "okrs_coowned": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "objective",
          "ba_role"
        ]
      }
    },
    "business_cases_authored": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "primary_author"
        ]
      }
    },
    "sponsor_syncs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "date",
          "minutes_path"
        ]
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>
  <section title="Examples">
    <example type="good" title="Valid artefact">
      <code lang="json"><![CDATA[
{
  "ba_name": "Maria Lopes",
  "period": "2026Q2",
  "sponsor_name": "Pedro Silva",
  "version_tag": "v1.0.0",
  "okrs_coowned": [
    {
      "id": "okr-rev-1",
      "objective": "Reduce AP cycle time 40%",
      "ba_role": "co-owner: process redesign + AC"
    }
  ],
  "business_cases_authored": [
    {
      "id": "bc-01",
      "title": "Invoice automation",
      "primary_author": "Maria Lopes"
    }
  ],
  "sponsor_syncs": [
    {
      "date": "2026-04-15",
      "minutes_path": "syncs/2026-04-15.md"
    }
  ]
}
]]></code>
      <note>All required fields populated; rule constraints satisfied.</note>
    </example>
    <example type="bad" title="Invalid artefact">
      <code lang="json"><![CDATA[
{
  "ba_name": "x",
  "period": "x",
  "sponsor_name": "team",
  "version_tag": "latest",
  "okrs_coowned": [],
  "business_cases_authored": [],
  "sponsor_syncs": []
}
]]></code>
      <note>Missing required fields or violating rule constraints.</note>
    </example>
  </section>
  <section title="Forbidden patterns">
    <list>
      <item>missing any required field</item>
      <item>field value outside declared enum</item>
      <item>anonymous owner / reviewer / approver</item>
      <item>version_tag missing semver pattern</item>
    </list>
  </section>
  <reference path="templates/ba-strategic-partnership.json"/>
  <reference path="scripts/validate-ba-strategic-partnership.py"/>
</text>
