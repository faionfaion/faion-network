<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agile BA Frameworks Mapping Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the Agile BA Frameworks Mapping artefact shape.</summary>
  <section title="JSON Schema (draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/agile-ba-frameworks-mapping.json",
  "type": "object",
  "required": [
    "framework",
    "version_tag",
    "ceremonies"
  ],
  "properties": {
    "framework": {
      "type": "string",
      "enum": [
        "scrum",
        "safe-team",
        "safe-program",
        "safe-solution",
        "safe-portfolio"
      ]
    },
    "version_tag": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "ceremonies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "activities"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "activities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type",
                "description",
                "owner"
              ],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "elicit",
                    "refine",
                    "validate",
                    "trace",
                    "review",
                    "document",
                    "not_ba"
                  ]
                },
                "description": {
                  "type": "string"
                },
                "owner": {
                  "type": "string",
                  "minLength": 2
                }
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>
  <section title="Examples">
    <example type="good" title="Valid artefact">
      <code lang="json"><![CDATA[
{
  "framework": "scrum",
  "version_tag": "v1.0.0",
  "ceremonies": [
    {
      "name": "refinement",
      "activities": [
        {
          "type": "refine",
          "description": "Refine AC + stories",
          "owner": "Maria Lopes"
        }
      ]
    },
    {
      "name": "review",
      "activities": [
        {
          "type": "validate",
          "description": "Run UAT vs AC",
          "owner": "Maria Lopes"
        }
      ]
    }
  ]
}
]]></code>
      <note>All required fields populated; rule constraints satisfied.</note>
    </example>
    <example type="bad" title="Invalid artefact">
      <code lang="json"><![CDATA[
{
  "framework": "agile",
  "version_tag": "latest",
  "ceremonies": []
}
]]></code>
      <note>Missing required fields or violating rule constraints.</note>
    </example>
  </section>
  <section title="Forbidden patterns">
    <list>
      <item>missing any required field</item>
      <item>field value outside declared enum</item>
      <item>anonymous owner / reviewer / approver</item>
      <item>version_tag missing semver pattern</item>
    </list>
  </section>
  <reference path="templates/agile-ba-frameworks-mapping.json"/>
  <reference path="scripts/validate-agile-ba-frameworks-mapping.py"/>
</text>
