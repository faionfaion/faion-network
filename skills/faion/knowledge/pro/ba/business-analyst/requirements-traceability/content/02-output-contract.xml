<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Traceability Matrix (RTM) Generation and Maintenance Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-traceability.json",
  "title": "rtm-record",
  "type": "object",
  "required": [
    "rtm_id",
    "role_vocabulary_version",
    "edges",
    "coverage",
    "orphans"
  ],
  "properties": {
    "rtm_id": {
      "type": "string"
    },
    "role_vocabulary_version": {
      "type": "string"
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "from_role",
          "to_role"
        ]
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "needs_with_tests_pct",
        "tests_with_needs_pct"
      ]
    },
    "orphans": {
      "type": "object",
      "required": [
        "needs_without_tests",
        "tests_without_needs"
      ]
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "rtm_id": "RTM-2026Q2",
  "role_vocabulary_version": "v1.2",
  "edges": [
    {
      "from": "BR-0019",
      "to": "SR-0042",
      "from_role": "business_requirement",
      "to_role": "solution_requirement"
    },
    {
      "from": "SR-0042",
      "to": "TC-0103",
      "from_role": "solution_requirement",
      "to_role": "test_case"
    }
  ],
  "coverage": {
    "needs_with_tests_pct": 0.98,
    "tests_with_needs_pct": 0.95
  },
  "orphans": {
    "needs_without_tests": [
      "NFR-0007"
    ],
    "tests_without_needs": [
      "TC-0210"
    ]
  }
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "rtm_id": "x",
  "edges": []
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-traceability.py">Validates an artefact against this schema.</reference>
</text>
