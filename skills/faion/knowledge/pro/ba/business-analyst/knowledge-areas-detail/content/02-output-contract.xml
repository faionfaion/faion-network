<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="BA Knowledge Areas Detail Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/knowledge-areas-detail.json",
  "title": "ka-routing-record",
  "type": "object",
  "required": [
    "record_id",
    "engagement_type",
    "ka_sequence",
    "methodologies",
    "deliverables"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^KAR-[0-9]{4}$"
    },
    "engagement_type": {
      "enum": [
        "greenfield",
        "change_request",
        "transformation",
        "audit",
        "onboarding"
      ]
    },
    "ka_sequence": {
      "type": "array",
      "items": {
        "enum": [
          "KA-1",
          "KA-2",
          "KA-3",
          "KA-4",
          "KA-5",
          "KA-6"
        ]
      },
      "minItems": 1
    },
    "methodologies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ka",
          "name",
          "owner"
        ]
      }
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "record_id": "KAR-0001",
  "engagement_type": "greenfield",
  "ka_sequence": [
    "KA-1",
    "KA-4",
    "KA-2",
    "KA-5",
    "KA-3",
    "KA-6"
  ],
  "methodologies": [
    "ba-planning",
    "strategy-analysis-current-state",
    "elicitation-techniques",
    "requirements-documentation",
    "requirements-lifecycle",
    "solution-assessment"
  ],
  "deliverables": [
    {
      "ka": "KA-1",
      "name": "BA Plan",
      "owner": "BA Lead"
    }
  ]
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "record_id": "x",
  "engagement_type": "n/a"
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-knowledge-areas-detail.py">Validates an artefact against this schema.</reference>
</text>
