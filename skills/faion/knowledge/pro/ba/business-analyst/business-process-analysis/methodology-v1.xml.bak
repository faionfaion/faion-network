<methodology slug="business-process-analysis">
  <metadata>
    <tier>pro</tier>
    <group>ba</group>
    <domain>business-analyst</domain>
    <summary>Five-stage BPA with portfolio orchestration for M&amp;A, ERP, and digital transformation programs.</summary>
    <tags>
