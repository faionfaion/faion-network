<text id="02-output-contract" title="Strategy Analysis — Current State — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/strategy-analysis-current-state.json",
  "type": "object",
  "required": [
    "processes",
    "systems",
    "capabilities",
    "pain_points",
    "constraints",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "processes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "pain_points": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "processes": [
    {
      "id": "x1"
    }
  ],
  "systems": [
    {
      "id": "x1"
    }
  ],
  "capabilities": [
    {
      "id": "x1"
    }
  ],
  "pain_points": [
    {
      "id": "x1"
    }
  ],
  "constraints": [
    {
      "id": "x1"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="processes"/>
      <field name="systems"/>
      <field name="capabilities"/>
      <field name="pain_points"/>
      <field name="constraints"/>
      <field name="owner"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">process / system / capability row without owner</pattern>
      <pattern id="f2">pain_point row without frequency OR impact score</pattern>
      <pattern id="f3">constraint without category</pattern>
      <pattern id="f4">process depth &gt; 3</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-segment process variation rows for multi-tenant programs.</transformation>
      <transformation>Tighten pain rubric thresholds after a quarter of data.</transformation>
      <transformation>Add per-system data-classification field for compliance overlay.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-strategy-analysis-current-state.py"/>
  </output-contract>
</text>
