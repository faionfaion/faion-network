<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Strategy Analysis — Change Strategy — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/strategy-analysis-change-strategy.json",
  "type": "object",
  "required": [
    "options",
    "transition_states",
    "readiness_gaps",
    "trade_offs",
    "recommendation",
    "decision_maker",
    "decision_by",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "options": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "transition_states": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "readiness_gaps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "trade_offs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendation": {
      "type": "string"
    },
    "decision_maker": {
      "type": "string",
      "minLength": 1
    },
    "decision_by": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "options": [
    {
      "id": "x1"
    }
  ],
  "transition_states": [
    {
      "id": "x1"
    }
  ],
  "readiness_gaps": [
    {
      "id": "x1"
    }
  ],
  "trade_offs": [
    {
      "id": "x1"
    }
  ],
  "recommendation": "sample-recommendation",
  "decision_maker": "Olena Kovalenko (COO)",
  "decision_by": "2026-06-30",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="options"/>
      <field name="transition_states"/>
      <field name="readiness_gaps"/>
      <field name="trade_offs"/>
      <field name="recommendation"/>
      <field name="decision_maker"/>
      <field name="decision_by"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">options[] length &lt; 2</pattern>
      <pattern id="f2">option without transition_states list</pattern>
      <pattern id="f3">option without readiness_gap field</pattern>
      <pattern id="f4">trade_off without cost OR risk OR time score</pattern>
      <pattern id="f5">decision_maker missing OR decision_by missing</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-region trade-off slicing for multi-geography programs.</transformation>
      <transformation>Tighten cost-risk-time rubric as benchmarks mature.</transformation>
      <transformation>Add post-decision feedback loop to refresh rubric weights.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-strategy-analysis-change-strategy.py"/>
  </output-contract>
</text>
