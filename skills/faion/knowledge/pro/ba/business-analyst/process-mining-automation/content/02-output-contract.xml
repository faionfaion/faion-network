<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Process Mining and Intelligent Automation Analysis Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/process-mining-automation.json",
  "title": "automation-candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "process_name",
    "score",
    "verdict",
    "evidence",
    "roi_estimate"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^AC-[0-9]{4}$"
    },
    "process_name": {
      "type": "string"
    },
    "score": {
      "type": "object",
      "required": [
        "volume",
        "frequency",
        "variance",
        "rule_density",
        "total"
      ]
    },
    "verdict": {
      "enum": [
        "rpa",
        "idp",
        "orchestration",
        "ai_assist",
        "none"
      ]
    },
    "evidence": {
      "type": "object",
      "required": [
        "log_source",
        "as_is_bpmn",
        "conformance_fitness"
      ]
    },
    "roi_estimate": {
      "type": "object",
      "required": [
        "annual_savings",
        "implementation_cost",
        "payback_months"
      ]
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "candidate_id": "AC-0017",
  "process_name": "Invoice 3-way match",
  "score": {
    "volume": 5,
    "frequency": 5,
    "variance": 2,
    "rule_density": 4,
    "total": 16
  },
  "verdict": "rpa",
  "evidence": {
    "log_source": "celonis://erp/ap",
    "as_is_bpmn": "ap-3wm.bpmn",
    "conformance_fitness": 0.92
  },
  "roi_estimate": {
    "annual_savings": 220000,
    "implementation_cost": 80000,
    "payback_months": 5
  }
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "candidate_id": "AC1"
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-process-mining-automation.py">Validates an artefact against this schema.</reference>
</text>
