<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Data Analysis — Requirements Discovery and Quality Assessment Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/data-analysis.json",
  "title": "data-element",
  "type": "object",
  "required": [
    "name",
    "type",
    "source",
    "scope",
    "quality",
    "owner"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "enum": [
        "string",
        "integer",
        "number",
        "boolean",
        "date",
        "datetime",
        "enum",
        "json"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "system",
        "table",
        "column"
      ]
    },
    "scope": {
      "type": "string",
      "description": "bounded context"
    },
    "quality": {
      "type": "object",
      "required": [
        "accuracy",
        "completeness",
        "consistency",
        "timeliness",
        "validity",
        "uniqueness"
      ]
    },
    "owner": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule_type",
          "expression"
        ]
      }
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "active_customer",
  "type": "boolean",
  "source": {
    "system": "billing",
    "table": "customer",
    "column": "is_active"
  },
  "scope": "billing",
  "quality": {
    "accuracy": 0.99,
    "completeness": 1.0,
    "consistency": 0.98,
    "timeliness": 0.95,
    "validity": 1.0,
    "uniqueness": 1.0
  },
  "owner": "Finance Ops",
  "rules": [
    {
      "rule_type": "validation",
      "expression": "is_active IN (true,false)"
    }
  ]
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": "active customer",
  "source": "billing.customer"
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-data-analysis.py">Validates an artefact against this schema.</reference>
</text>
