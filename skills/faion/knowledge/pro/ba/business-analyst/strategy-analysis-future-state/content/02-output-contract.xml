<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Strategy Analysis — Future State — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/strategy-analysis-future-state.json",
  "type": "object",
  "required": [
    "processes",
    "systems",
    "capabilities",
    "outcomes",
    "constraints",
    "approver",
    "approval_by",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "processes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "approver": {
      "type": "string",
      "minLength": 1
    },
    "approval_by": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "processes": [
    {
      "id": "x1"
    }
  ],
  "systems": [
    {
      "id": "x1"
    }
  ],
  "capabilities": [
    {
      "id": "x1"
    }
  ],
  "outcomes": [
    {
      "id": "x1"
    }
  ],
  "constraints": [
    {
      "id": "x1"
    }
  ],
  "approver": "Olena Kovalenko (COO)",
  "approval_by": "2026-06-30",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="processes"/>
      <field name="systems"/>
      <field name="capabilities"/>
      <field name="outcomes"/>
      <field name="constraints"/>
      <field name="approver"/>
      <field name="approval_by"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">outcome without target value + unit + measurement source</pattern>
      <pattern id="f2">outcome without trace back to a business-need metric</pattern>
      <pattern id="f3">system or capability row contains vendor/product name</pattern>
      <pattern id="f4">approver missing OR approval_by missing</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-region outcome targets for multi-geography programs.</transformation>
      <transformation>Tighten outcome targets as baseline data improves.</transformation>
      <transformation>Add per-outcome confidence tier (high / medium / low).</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-strategy-analysis-future-state.py"/>
  </output-contract>
</text>
