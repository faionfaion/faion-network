<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Prioritization Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact produced by this methodology, paired with a valid + invalid example.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-prioritization.json",
  "title": "prioritization-record",
  "type": "object",
  "required": [
    "record_id",
    "method",
    "method_version",
    "items"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "pattern": "^PR-[0-9]{4}$"
    },
    "method": {
      "enum": [
        "moscow",
        "rice",
        "kano",
        "wsjf"
      ]
    },
    "method_version": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "req_id",
          "rank",
          "score",
          "rationale"
        ]
      }
    },
    "distribution_check": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
    ]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "record_id": "PR-0011",
  "method": "moscow",
  "method_version": "v1.0",
  "items": [
    {
      "req_id": "SR-0042",
      "rank": 1,
      "score": "Must",
      "rationale": "Compliance gate; auditable."
    }
  ],
  "distribution_check": {
    "must_pct": 0.55,
    "should_pct": 0.25,
    "could_pct": 0.15,
    "wont_pct": 0.05
  }
}
    ]]></code>
    <note>Conforms to the schema; required fields present, enums respected.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "record_id": "PR-1",
  "method": "vibes"
}
    ]]></code>
    <note>Missing required fields and / or violates pattern constraints.</note>
  </example>

  <forbidden>
    <pattern id="f1">Top-level object missing any of the required fields.</pattern>
    <pattern id="f2">Free-form additional properties not listed in the schema.</pattern>
    <pattern id="f3">Enum field value outside the declared set.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-prioritization.py">Validates an artefact against this schema.</reference>
</text>
