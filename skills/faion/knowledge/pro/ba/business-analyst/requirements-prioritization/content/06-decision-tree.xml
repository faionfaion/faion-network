<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Requirements Prioritization Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml or to the universal skip-this-methodology conclusion.</summary>

  <decision-tree>
    <root-question id="q-root">Which prioritization method is right?</root-question>
    <branch when="backlog_size &gt; 50 AND quantified_metrics == true">
      <conclusion ref="r3" verdict="RICE with cost-coupled effort."/>
    </branch>
    <branch when="backlog_size &lt;= 50 AND release_planning == true">
      <conclusion ref="r1" verdict="MoSCoW with non-flat distribution check."/>
    </branch>
    <branch when="kano_signals_present == true">
      <conclusion ref="r4" verdict="Kano: classify must / performance / delighter."/>
    </branch>
    <branch when="safe_scaled_agile == true">
      <conclusion ref="r5" verdict="WSJF (Cost of Delay / job size)."/>
    </branch>
    <branch when="default">
      <conclusion ref="skip-this-methodology" verdict="Method unclear; gather more inputs before scoring."/>
    </branch>
    <example trace="default path">
      <description>When the situation matches the leading branch, apply the referenced rule; otherwise traverse to the next condition until the default branch is reached.</description>
    </example>
  </decision-tree>

  <see-also>
    <link path="content/01-core-rules.xml"/>
  </see-also>
</text>
