<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Strategy Analysis — Business Need — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/strategy-analysis-business-need.json",
  "type": "object",
  "required": [
    "problem_statement",
    "affected_stakeholders",
    "evidence",
    "success_metric",
    "do_nothing_baseline",
    "sponsor",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "problem_statement": {
      "type": "string"
    },
    "affected_stakeholders": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "success_metric": {
      "type": "string"
    },
    "do_nothing_baseline": {
      "type": "string"
    },
    "sponsor": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "problem_statement": "sample-problem_statement",
  "affected_stakeholders": [
    {
      "id": "x1"
    }
  ],
  "evidence": [
    {
      "id": "x1"
    }
  ],
  "success_metric": "sample-success_metric",
  "do_nothing_baseline": "sample-do_nothing_baseline",
  "sponsor": "Olena Kovalenko (COO)",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="problem_statement"/>
      <field name="affected_stakeholders"/>
      <field name="evidence"/>
      <field name="success_metric"/>
      <field name="do_nothing_baseline"/>
      <field name="sponsor"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">problem_statement contains vendor or product name</pattern>
      <pattern id="f2">success_metric is qualitative (no number)</pattern>
      <pattern id="f3">evidence list empty</pattern>
      <pattern id="f4">sponsor missing</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-segment evidence slicing.</transformation>
      <transformation>Tighten the success metric range as data quality improves.</transformation>
      <transformation>Update do-nothing baseline annually.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-strategy-analysis-business-need.py"/>
  </output-contract>
</text>
