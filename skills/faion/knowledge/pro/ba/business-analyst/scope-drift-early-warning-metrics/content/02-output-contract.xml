<text id="02-output-contract" title="Scope Drift Early-Warning Metrics — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/scope-drift-early-warning-metrics.json",
  "type": "object",
  "required": [
    "dashboard",
    "metrics",
    "trigger_log",
    "metric_definitions"
  ],
  "properties": {
    "dashboard": {
      "type": "string"
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "trigger_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "metric_definitions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "dashboard": "sample-dashboard",
  "metrics": [
    {
      "id": "x1"
    }
  ],
  "trigger_log": [
    {
      "id": "x1"
    }
  ],
  "metric_definitions": [
    {
      "id": "x1"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="dashboard"/>
      <field name="metrics"/>
      <field name="trigger_log"/>
      <field name="metric_definitions"/>
    </required>

    <forbidden>
      <pattern id="f1">metrics map missing any of the five named metrics</pattern>
      <pattern id="f2">threshold values absolute (count-based) instead of baseline-relative ratios</pattern>
      <pattern id="f3">refresh_at older than 24h</pattern>
      <pattern id="f4">trigger entry without owner or sla_hours</pattern>
      <pattern id="f5">red trigger open &gt; sla_hours without escalation per risk-threshold-policy</pattern>
      <pattern id="f6">dashboard.owner is a team name instead of a named individual</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Tighten thresholds after ≥4 weeks with ≤1 false amber per metric.</transformation>
      <transformation>Add per-workstream slicing without removing the overall view.</transformation>
      <transformation>Define engagement-specific exceptions in metric-definitions.md.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-scope-drift-early-warning-metrics.py"/>
  </output-contract>
</text>
