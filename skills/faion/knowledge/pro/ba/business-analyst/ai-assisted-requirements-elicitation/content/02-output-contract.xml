<text id="02-output-contract" title="AI-Assisted Requirements Elicitation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the AI-Assisted Requirements Elicitation artefact shape.</summary>
  <section title="JSON Schema (draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-assisted-requirements-elicitation.json",
  "type": "object",
  "required": [
    "elicitation_id",
    "version_tag",
    "ba_reviewer",
    "stories"
  ],
  "properties": {
    "elicitation_id": {
      "type": "string"
    },
    "version_tag": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+\\.\\d+$"
    },
    "ba_reviewer": {
      "type": "string",
      "minLength": 2
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "story_id",
          "title",
          "source_refs",
          "ac_count"
        ],
        "properties": {
          "story_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "ac_count": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>
  <section title="Examples">
    <example type="good" title="Valid artefact">
      <code lang="json"><![CDATA[
{
  "elicitation_id": "kyc-2026",
  "version_tag": "v1.0.0",
  "ba_reviewer": "Ana Rodrigues",
  "stories": [
    {
      "story_id": "STORY-101",
      "title": "ID verification step",
      "source_refs": [
        "interview-ana#08:14",
        "compliance-doc.md#L40"
      ],
      "ac_count": 5
    }
  ]
}
]]></code>
      <note>All required fields populated; rule constraints satisfied.</note>
    </example>
    <example type="bad" title="Invalid artefact">
      <code lang="json"><![CDATA[
{
  "elicitation_id": "x",
  "version_tag": "latest",
  "ba_reviewer": "team",
  "stories": [
    {
      "story_id": "x",
      "title": "x",
      "source_refs": [],
      "ac_count": 0
    }
  ]
}
]]></code>
      <note>Missing required fields or violating rule constraints.</note>
    </example>
  </section>
  <section title="Forbidden patterns">
    <list>
      <item>missing any required field</item>
      <item>field value outside declared enum</item>
      <item>anonymous owner / reviewer / approver</item>
      <item>version_tag missing semver pattern</item>
    </list>
  </section>
  <reference path="templates/ai-assisted-requirements-elicitation.json"/>
  <reference path="scripts/validate-ai-assisted-requirements-elicitation.py"/>
</text>
