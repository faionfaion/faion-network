<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="User Story Mapping — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/user-story-mapping.json",
  "type": "object",
  "required": [
    "journey",
    "slices",
    "stories",
    "walking_skeleton_id",
    "mvp_id",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "journey": {
      "type": "string"
    },
    "slices": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "stories": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "walking_skeleton_id": {
      "type": "string"
    },
    "mvp_id": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "journey": "sample-journey",
  "slices": [
    {
      "id": "x1"
    }
  ],
  "stories": [
    {
      "id": "x1"
    }
  ],
  "walking_skeleton_id": "sample-walking_skeleton_id",
  "mvp_id": "sample-mvp_id",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="journey"/>
      <field name="slices"/>
      <field name="stories"/>
      <field name="walking_skeleton_id"/>
      <field name="mvp_id"/>
      <field name="owner"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">story without acceptance criteria</pattern>
      <pattern id="f2">map without walking_skeleton_id</pattern>
      <pattern id="f3">map without mvp_id</pattern>
      <pattern id="f4">story without use_case_id OR journey_step_id</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Add per-persona swim-lane for multi-persona products.</transformation>
      <transformation>Promote a story from MVP to walking-skeleton when discovery exposes new integration risk.</transformation>
      <transformation>Add per-slice release-date target as planning matures.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-user-story-mapping.py"/>
  </output-contract>
</text>
