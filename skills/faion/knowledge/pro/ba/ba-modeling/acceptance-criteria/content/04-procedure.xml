<text id="04-procedure" title="Acceptance Criteria Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply this methodology end-to-end. Each step names inputs, actions, outputs, and optional decision-gates.</summary>
  <section title="Procedure">
    <step n="1" name="pick-shape">
      <input>Story / requirement</input>
      <action>Classify behaviour AC → BDD, constraint AC → rule.</action>
      <output>Shape decision</output>
    </step>
    <step n="2" name="draft-ac">
      <input>Story + shape</input>
      <action>Write 3-7 AC with stable IDs.</action>
      <output>AC draft</output>
      <decision-gate>Reject when count &gt; 7 — slice story.</decision-gate>
    </step>
    <step n="3" name="review-quality">
      <input>AC draft</input>
      <action>Audit independent + atomic + testable.</action>
      <output>Reviewed AC</output>
    </step>
    <step n="4" name="wire-trace">
      <input>Reviewed AC + spec.md + test file</input>
      <action>Add trace.spec_ref + trace.test_ref.</action>
      <output>Traced AC</output>
    </step>
  </section>
</text>
