<text id="02-output-contract" title="Data Analysis Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>Pins the data-dictionary deliverable. Subagent must satisfy this before returning.</summary>
  <section title="JSON Schema (draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/data-analysis-dictionary.json",
  "type": "object",
  "required": ["dictionary_id", "version_tag", "entities", "business_rules"],
  "properties": {
    "dictionary_id": {"type": "string", "minLength": 2},
    "version_tag": {"type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+$"},
    "entities": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "owner_name", "owner_role", "fields", "dq_baseline"],
        "properties": {
          "name": {"type": "string"},
          "owner_name": {"type": "string", "minLength": 2},
          "owner_role": {"type": "string", "minLength": 2},
          "fields": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "type", "source_system", "source_ref", "nullable"],
              "properties": {
                "name": {"type": "string"},
                "type": {"type": "string", "enum": ["string", "int", "float", "bool", "date", "datetime", "uuid", "json", "blob"]},
                "source_system": {"type": "string"},
                "source_ref": {"type": "string", "minLength": 2},
                "nullable": {"type": "boolean"},
                "pii": {"type": "boolean"}
              }
            }
          },
          "dq_baseline": {
            "type": "object",
            "required": ["accuracy", "completeness", "consistency", "timeliness", "validity", "uniqueness"],
            "properties": {
              "accuracy": {"type": "number", "minimum": 0, "maximum": 100},
              "completeness": {"type": "number", "minimum": 0, "maximum": 100},
              "consistency": {"type": "number", "minimum": 0, "maximum": 100},
              "timeliness": {"type": "number", "minimum": 0, "maximum": 100},
              "validity": {"type": "number", "minimum": 0, "maximum": 100},
              "uniqueness": {"type": "number", "minimum": 0, "maximum": 100}
            }
          }
        }
      }
    },
    "business_rules": {
      "type": "array", "minItems": 0,
      "items": {
        "type": "object",
        "required": ["id", "entity", "predicate", "severity"],
        "properties": {
          "id": {"type": "string"},
          "entity": {"type": "string"},
          "predicate": {"type": "string", "minLength": 4},
          "severity": {"type": "string", "enum": ["block", "warn", "info"]}
        }
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>
  <section title="Examples">
    <example type="good" title="Valid customer-entity dictionary">
      <code lang="json"><![CDATA[
{
  "dictionary_id": "core-customer",
  "version_tag": "v1.0.0",
  "entities": [{
    "name": "customer",
    "owner_name": "Maria Lopes",
    "owner_role": "Data Steward",
    "fields": [
      {"name": "customer_id", "type": "uuid", "source_system": "crm", "source_ref": "crm.customers.id", "nullable": false, "pii": false},
      {"name": "email", "type": "string", "source_system": "crm", "source_ref": "crm.customers.email", "nullable": false, "pii": true}
    ],
    "dq_baseline": {"accuracy": 92, "completeness": 88, "consistency": 75, "timeliness": 95, "validity": 91, "uniqueness": 99}
  }],
  "business_rules": [
    {"id": "br-01", "entity": "customer", "predicate": "regex(email, '^[^@]+@[^@]+$')", "severity": "block"}
  ]
}
]]></code>
      <note>Typed, sourced, six DQ dimensions, named owner, predicate rule.</note>
    </example>
    <example type="bad" title="Invalid — missing DQ dimensions">
      <code lang="json"><![CDATA[
{
  "dictionary_id": "x", "version_tag": "v1.0.0",
  "entities": [{"name": "x", "owner_name": "Data Team", "owner_role": "?", "fields": [],
    "dq_baseline": {"accuracy": 90}}],
  "business_rules": []
}
]]></code>
      <note>Anonymous owner; only 1 DQ dimension; empty fields.</note>
    </example>
  </section>
  <section title="Forbidden patterns">
    <list>
      <item>fields with non-canonical type (rule r1)</item>
      <item>entities without all six DQ dimensions scored (rule r2)</item>
      <item>business_rules with prose-only predicate (rule r3)</item>
      <item>entities with anonymous owner_name (rule r4)</item>
      <item>version_tag missing semver pattern (rule r5)</item>
    </list>
  </section>
  <section title="Allowed transformations">
    <list>
      <item>Aliases (synonyms) may be added per field, but canonical name remains stable.</item>
    </list>
  </section>
  <reference path="templates/data-dictionary.md"/>
  <reference path="scripts/validate-data-analysis.py"/>
</text>
