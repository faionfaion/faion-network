<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Use Case Modeling Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from use-case-state signal to the active rule.</summary>
  <decision-tree>
    <root-question id="q-actor">primary_actor names a specific role with scope?</root-question>
    <branch when="primary_actor == 'User' OR primary_actor.token_count &lt; 2">
      <conclusion ref="r1-named-actors" verdict="resolve actor with role+scope from glossary"/>
    </branch>
    <branch when="primary_actor.token_count &gt;= 2">
      <question id="q-goal">goal is single-sentence single-goal?</question>
      <branch when="goal.contains(' AND ') OR main_success_scenario.length &gt; 10">
        <conclusion ref="r4-single-goal" verdict="split use case into multiple goals"/>
      </branch>
      <branch when="goal_single == true">
        <question id="q-conditions">preconditions + postconditions are predicates?</question>
        <branch when="prose_condition_count &gt; 0">
          <conclusion ref="r3-pre-postconditions" verdict="rewrite conditions as boolean predicates"/>
        </branch>
        <branch when="prose_condition_count == 0">
          <question id="q-flows">alternative_flows ≥ 1 AND exception_flows ≥ 1?</question>
          <branch when="alt_count == 0 OR exception_count == 0">
            <conclusion ref="r2-flows-triple" verdict="add alternative + exception flows"/>
          </branch>
          <branch when="alt_count &gt;= 1 AND exception_count &gt;= 1">
            <question id="q-trace">trace_id non-empty?</question>
            <branch when="trace_id_empty == true">
              <conclusion ref="r5-trace-id" verdict="link trace_id to backlog item"/>
            </branch>
            <branch when="trace_id_empty == false">
              <conclusion ref="r5-trace-id" verdict="validate set + hand off to AC team"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="book-appointment">
    Authenticated Patient → single goal → predicate conditions → alt+exception both ≥1 → trace_id=PROD-432 → hand off (r5).
  </example>
</text>
