<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Business Process Analysis Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from cycle-state signal to the active rule from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="q-evidence">Process evidence collected and cited?</root-question>
    <branch when="steps_without_source &gt; 0">
      <conclusion ref="r1-source-citation" verdict="remove uncited steps before advancing"/>
    </branch>
    <branch when="steps_without_source == 0">
      <question id="q-lanes">All lanes have a named owner (full name + role)?</question>
      <branch when="anonymous_lane_count &gt; 0">
        <conclusion ref="r2-named-lane-owner" verdict="BLOCK cycle; resolve named owner per anonymous lane"/>
      </branch>
      <branch when="anonymous_lane_count == 0">
        <question id="q-analysis">analysis[] populated with value_add + cycle_time + cost for every step?</question>
        <branch when="analysis.length &lt; steps.length">
          <conclusion ref="r3-value-time-cost-table" verdict="finish analysis table before future-state"/>
        </branch>
        <branch when="analysis.length == steps.length">
          <question id="q-future">future_state expressed as diff with step_id refs?</question>
          <branch when="prose_future_state == true">
            <conclusion ref="r4-future-state-as-diff" verdict="rewrite future-state as diff table"/>
          </branch>
          <branch when="prose_future_state == false">
            <conclusion ref="r5-stakeholder-signoff" verdict="collect per-lane signoff; ship report"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="invoice-approval">
    steps_without_source=0 → anonymous_lane_count=0 → analysis.length=6=steps.length → prose_future_state=false → collect signoff (r5) → ship.
  </example>
</text>
