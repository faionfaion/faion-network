<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Decision Analysis Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from record-state signal to the active rule from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="q-baseline">options[] includes is_baseline=true entry?</root-question>
    <branch when="is_baseline_count == 0">
      <conclusion ref="r3-do-nothing-included" verdict="add do-nothing baseline before scoring"/>
    </branch>
    <branch when="is_baseline_count &gt;= 1">
      <question id="q-weights">weights_locked_at recorded before first_score_ts?</question>
      <branch when="weights_locked_at &gt; first_score_ts">
        <conclusion ref="r1-weights-locked-pre-scoring" verdict="reset run; lock weights before scoring"/>
      </branch>
      <branch when="weights_locked_at &lt;= first_score_ts">
        <question id="q-evidence">Every score has evidence ≥ 4 chars?</question>
        <branch when="evidence_missing_count &gt; 0">
          <conclusion ref="r2-evidence-per-cell" verdict="add evidence URL per missing cell"/>
        </branch>
        <branch when="evidence_missing_count == 0">
          <question id="q-sensitivity">sensitivity.rank_flip_rate &lt;= 0.15?</question>
          <branch when="rank_flip_rate &gt; 0.15 AND unstable_pairs.length == 0">
            <conclusion ref="r4-sensitivity-20pct" verdict="surface unstable_pairs and route back to stakeholder"/>
          </branch>
          <branch when="rank_flip_rate &lt;= 0.15 OR unstable_pairs.length &gt; 0">
            <conclusion ref="r5-signed-rationale" verdict="collect approver signoff and publish"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="vendor-pick">
    baseline=true → weights locked early → evidence per cell → flip_rate=0.18 with unstable_pairs flagged → approver signs (r5).
  </example>
</text>
