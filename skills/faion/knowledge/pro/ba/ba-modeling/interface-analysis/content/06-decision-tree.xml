<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Interface Analysis Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from interface-state signal to the active rule.</summary>
  <decision-tree>
    <root-question id="q-contract">contract.type within enum AND contract.ref points to real file?</root-question>
    <branch when="contract.type == 'n/a' OR contract.ref.exists == false">
      <conclusion ref="r1-typed-contract" verdict="author OpenAPI/AsyncAPI before continuing"/>
    </branch>
    <branch when="contract.type valid AND ref exists">
      <question id="q-owners">Both owners.producer.name and owners.consumer.name named (≥2 tokens)?</question>
      <branch when="anonymous_owner_count &gt; 0">
        <conclusion ref="r2-named-owner" verdict="resolve named producer + consumer owner"/>
      </branch>
      <branch when="anonymous_owner_count == 0">
        <question id="q-errors">error_codes[] non-empty?</question>
        <branch when="error_codes.length == 0">
          <conclusion ref="r3-error-contract" verdict="declare error codes with retry semantics"/>
        </branch>
        <branch when="error_codes.length &gt;= 1">
          <question id="q-sla">All four SLA fields declared?</question>
          <branch when="sla_missing_fields &gt; 0">
            <conclusion ref="r4-sla-declared" verdict="escalate to SRE for missing SLA fields"/>
          </branch>
          <branch when="sla_missing_fields == 0">
            <conclusion ref="r5-version-and-fixtures" verdict="link fixtures + bump semver + publish"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="payment-webhook">
    contract=openapi-3.1 ref exists → owners named both sides → 3 error codes → SLA all 4 fields → fixtures linked → publish v1.0.0 (r5).
  </example>
</text>
