<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Elicitation Prompt Patterns Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a AI Elicitation Prompt Patterns deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="prompt_path" format="git_path_with_sha" />
      <field name="model_id" format="provider_model_version" />
      <field name="budget" type="object" schema="{tokens_in,tokens_out,cost_usd}" />
      <field name="eval_reference" format="test_file_or_id" />
      <field name="output_schema" format="json_schema_path_or_inline" />
    </required>
    <forbidden>
      <pattern id="f1">untracked prompt edits (chat-tab only)</pattern>
      <pattern id="f2">free-text output where downstream parses</pattern>
      <pattern id="f3">missing eval_reference</pattern>
      <pattern id="f4">budget unset</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Pin to provider quirk only when documented in metadata.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Prompt versioned</item>
      <item>Eval linked</item>
      <item>Budget set</item>
      <item>Schema present</item>
    </list>
  </section>
</text>
