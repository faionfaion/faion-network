<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Definition of Done Library — Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Does the BA / PO own ≥2 engagements where DoD reuse pays off?</root-question>
      <branch when="engagements_count &lt; 2">
        <conclusion ref="r4-named-owner" verdict="skip — single-engagement overhead &gt; value"/>
      </branch>
      <branch when="engagements_count &gt;= 2 AND owner_missing">
        <conclusion ref="r4-named-owner" verdict="block — assign library owner"/>
      </branch>
      <branch when="engagements_count &gt;= 2 AND owner_named AND existing_library_current">
        <conclusion ref="r5-quarterly-review" verdict="refresh selectively"/>
      </branch>
      <branch when="engagements_count &gt;= 2 AND owner_named AND no_existing_library">
        <conclusion ref="r1-by-type-indexed" verdict="produce new typed DoD library"/>
      </branch>
  </decision-tree>
  <example trace="Portfolio of 5 engagements → owner=Maria → new library with 4 types"/>
</text>
