<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Decision Options Memo Template — Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Are ≥2 viable options available AND is the decision-maker identifiable?</root-question>
      <branch when="decision_maker_missing == true">
        <conclusion ref="r3-named-decision-maker" verdict="escalate to identify decision-maker"/>
      </branch>
      <branch when="decision_maker_named AND options_viable &lt; 2">
        <conclusion ref="r1-two-or-more-options" verdict="expand or escalate as 'no-option' memo"/>
      </branch>
      <branch when="decision_maker_named AND options_viable &gt;= 2 AND deadline_missing">
        <conclusion ref="r4-decision-by-date" verdict="set a near-term deadline"/>
      </branch>
      <branch when="all_prereqs_met">
        <conclusion ref="r5-dissent-acknowledged" verdict="draft memo with dissent acknowledged"/>
      </branch>
  </decision-tree>
  <example trace="DEC-15 → decision-maker=CTO → 3 options → deadline 2026-06-30 → memo drafted with dissent"/>
</text>
