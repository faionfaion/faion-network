<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Client Control ID Mapping — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/client-control-id-mapping.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "decision",
    "rationale",
    "inputs_used",
    "version",
    "last_reviewed",
    "control_id",
    "internal_ids",
    "evidence_urls"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "inputs_used": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    },
    "control_id": {
      "type": "string"
    },
    "internal_ids": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence_urls": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "artefact_id": "sample-artefact_id",
  "owner": "ruslan@faion.net",
  "decision": "sample-decision",
  "rationale": "sample-rationale",
  "inputs_used": "sample-inputs_used",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "control_id": "sample-control_id",
  "internal_ids": [
    {
      "id": "x1"
    }
  ],
  "evidence_urls": [
    {
      "id": "x1"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="artefact_id"/>
      <field name="owner"/>
      <field name="decision"/>
      <field name="rationale"/>
      <field name="inputs_used"/>
      <field name="version"/>
      <field name="last_reviewed"/>
      <field name="control_id"/>
      <field name="internal_ids"/>
      <field name="evidence_urls"/>
    </required>

    <forbidden>
      <pattern id="f1">owner = 'team' / 'we' / 'us' / empty string</pattern>
      <pattern id="f2">rationale that does not reference any input by name</pattern>
      <pattern id="f3">inputs_used is empty AND decision is not 'no-op'</pattern>
      <pattern id="f4">duplicate artefact_id within the same store</pattern>
      <pattern id="f5">control_id without ≥1 internal_id</pattern>
      <pattern id="f6">internal_id without evidence_url</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Trim rationale to ≤500 chars, preserving numeric claims and named tools.</transformation>
      <transformation>Promote a 'no decision yet' state to status='pending' rather than fabricating a decision.</transformation>
      <transformation>Add per-tenant overlay for multi-tenant SaaS compliance.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-client-control-id-mapping.py"/>
  </output-contract>
</text>
