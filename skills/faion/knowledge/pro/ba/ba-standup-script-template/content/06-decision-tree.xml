<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="BA Standup Script Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes the BA from script-state signal to the active rule.</summary>
  <decision-tree>
    <root-question id="q-blockers">blockers[] all have named owner (≥2 tokens)?</root-question>
    <branch when="anonymous_blocker_owner_count &gt; 0">
      <conclusion ref="r3-named-owner" verdict="resolve named owner per anonymous blocker before posting"/>
    </branch>
    <branch when="anonymous_blocker_owner_count == 0">
      <question id="q-clarifications">clarifications_needed[] each have story_id + stakeholder?</question>
      <branch when="incomplete_clarification_count &gt; 0">
        <conclusion ref="r2-typed-input" verdict="add story_id + stakeholder to each clarification"/>
      </branch>
      <branch when="incomplete_clarification_count == 0">
        <question id="q-date">date in ISO 8601?</question>
        <branch when="date_iso == false">
          <conclusion ref="r4-versioned" verdict="format date as ISO 8601"/>
        </branch>
        <branch when="date_iso == true">
          <conclusion ref="r1-bound-scope" verdict="post to standup channel"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="2026-05-23">
    blocker owner "Ana Rodrigues" → clarification has story_id+stakeholder → date=2026-05-23 → post (r1).
  </example>
</text>
