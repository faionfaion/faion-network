<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Process Mining &amp; Automation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-process-mining-automation.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/process-mining-automation.json",
  "type": "object",
  "required": [
    "variants",
    "candidates",
    "data_window"
  ],
  "properties": {
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "variant_id",
          "frequency",
          "cost",
          "variance_score"
        ]
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "variant_id",
          "feasibility",
          "expected_savings"
        ],
        "properties": {
          "feasibility": {
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "data_window": {
      "type": "object",
      "required": [
        "from",
        "to"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "variants": [
    {
      "variant_id": "V001",
      "frequency": 12450,
      "cost": 89000,
      "variance_score": 0.72
    }
  ],
  "candidates": [
    {
      "candidate_id": "AUT-001",
      "variant_id": "V001",
      "feasibility": "high",
      "expected_savings": 65000
    }
  ],
  "data_window": {
    "from": "2025-10-01",
    "to": "2026-04-30"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "variants": [],
  "candidates": []
}
]]></code>
    <note>variants + candidates empty; data_window missing.</note>
  </example>

  <forbidden>
    <pattern id="happy-path-only" severity="high">Discovery output shows only the most frequent variant; long-tail variance is hidden.</pattern>
    <pattern id="automation-without-feasibility" severity="high">Candidates are listed without feasibility scores or owners.</pattern>
  </forbidden>

  <reference path="scripts/validate-process-mining-automation.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
