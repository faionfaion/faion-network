<text id="04-procedure" title="Stakeholder Analysis Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply this methodology end-to-end. Each step names inputs, actions, outputs, and optional decision-gates.</summary>
  <section title="Procedure">
    <step n="1" name="extract-stakeholders">
      <input>Org chart + scope</input>
      <action>List candidate stakeholders; tag category.</action>
      <output>Draft register</output>
    </step>
    <step n="2" name="verify-against-org-chart">
      <input>Draft register + org chart</input>
      <action>Cross-check each entry; reject unverified.</action>
      <output>Verified register</output>
    </step>
    <step n="3" name="score-power-interest">
      <input>Verified register</input>
      <action>Map onto 2x2 grid (manage closely / keep satisfied / keep informed / monitor).</action>
      <output>Power/interest map</output>
    </step>
    <step n="4" name="build-raci">
      <input>Verified register + artefact list</input>
      <action>Assign R/A/C/I per artefact.</action>
      <output>RACI matrix</output>
      <decision-gate>Reject rows with multiple A's.</decision-gate>
    </step>
    <step n="5" name="publish-and-monitor">
      <input>Register + RACI</input>
      <action>Commit to engagement repo; refresh per cycle.</action>
      <output>Live register</output>
    </step>
  </section>
</text>
