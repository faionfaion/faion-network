<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Analysis Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-stakeholder-analysis.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-analysis.json",
  "type": "object",
  "required": [
    "register",
    "raci"
  ],
  "properties": {
    "register": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "category",
          "power",
          "interest"
        ],
        "properties": {
          "category": {
            "enum": [
              "sponsor",
              "user",
              "implementer",
              "regulator",
              "support"
            ]
          }
        }
      }
    },
    "raci": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artefact",
          "responsible",
          "accountable",
          "consulted",
          "informed"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "register": [
    {
      "name": "Amaia Ruiz",
      "role": "VP Product",
      "category": "sponsor",
      "power": "high",
      "interest": "high"
    }
  ],
  "raci": [
    {
      "artefact": "spec.md",
      "responsible": "ba@acme.com",
      "accountable": "amaia@acme.com",
      "consulted": [
        "eng-lead@acme.com"
      ],
      "informed": [
        "ops@acme.com"
      ]
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "register": []
}
]]></code>
    <note>register empty (min 1); raci missing.</note>
  </example>

  <forbidden>
    <pattern id="invented-roles" severity="high">Register contains plausible-sounding roles never verified against org chart.</pattern>
    <pattern id="multi-accountable" severity="high">RACI rows have multiple A's.</pattern>
  </forbidden>

  <reference path="scripts/validate-stakeholder-analysis.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
