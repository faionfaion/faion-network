<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Traceability Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-requirements-traceability.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-traceability.json",
  "type": "object",
  "required": [
    "rtm",
    "orphans",
    "coverage_pct"
  ],
  "properties": {
    "rtm": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "req_id",
          "source_ref",
          "design_ref",
          "code_ref",
          "test_ref"
        ]
      }
    },
    "orphans": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverage_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "rtm": [
    {
      "req_id": "REQ-001",
      "source_ref": "elicit/session-2026-04-12.md",
      "design_ref": "design.md#auth",
      "code_ref": "src/auth/oauth.ts",
      "test_ref": "tests/auth.spec.ts"
    }
  ],
  "orphans": [],
  "coverage_pct": 100
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "rtm": [
    {
      "req_id": "REQ-001"
    }
  ]
}
]]></code>
    <note>rtm entry missing source/design/code/test refs; orphans + coverage_pct missing.</note>
  </example>

  <forbidden>
    <pattern id="forward-only-traceability" severity="high">RTM links requirement → code but not back to source elicitation.</pattern>
    <pattern id="phantom-links" severity="medium">RTM cites code paths that no longer exist after refactor.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-traceability.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
