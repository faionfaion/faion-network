<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Elicitation Techniques Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-elicitation-techniques.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/elicitation-techniques.json",
  "type": "object",
  "required": [
    "sessions",
    "rationale_map"
  ],
  "properties": {
    "sessions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "technique",
          "participants",
          "info_type",
          "duration_min"
        ],
        "properties": {
          "technique": {
            "enum": [
              "interview",
              "workshop",
              "survey",
              "observation",
              "document-analysis"
            ]
          }
        }
      }
    },
    "rationale_map": {
      "type": "object"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "sessions": [
    {
      "technique": "interview",
      "participants": [
        "amaia@acme.com"
      ],
      "info_type": "sme-deep",
      "duration_min": 60
    },
    {
      "technique": "workshop",
      "participants": [
        "amaia@acme.com",
        "bruno@acme.com",
        "carla@acme.com"
      ],
      "info_type": "consensus-needs",
      "duration_min": 120
    },
    {
      "technique": "survey",
      "participants": [
        "100-user-cohort"
      ],
      "info_type": "broad-preference",
      "duration_min": 0
    }
  ],
  "rationale_map": {
    "sme-deep": "interview",
    "consensus-needs": "workshop",
    "broad-preference": "survey"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "sessions": []
}
]]></code>
    <note>sessions empty (min 1); rationale_map missing.</note>
  </example>

  <forbidden>
    <pattern id="interview-everything" severity="medium">Every session is a 1:1 interview regardless of info type.</pattern>
    <pattern id="ghost-participants" severity="high">Sessions list participants who never confirmed availability.</pattern>
  </forbidden>

  <reference path="scripts/validate-elicitation-techniques.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
