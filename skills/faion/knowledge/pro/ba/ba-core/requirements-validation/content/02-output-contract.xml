<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Validation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-requirements-validation.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-validation.json",
  "type": "object",
  "required": [
    "requirements_reviewed",
    "blocking_issues",
    "sign_off"
  ],
  "properties": {
    "requirements_reviewed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "req_id",
          "verdict",
          "reviewer",
          "reviewed_at"
        ],
        "properties": {
          "verdict": {
            "enum": [
              "pass",
              "fail",
              "conditional"
            ]
          }
        }
      }
    },
    "blocking_issues": {
      "type": "array"
    },
    "sign_off": {
      "type": "object",
      "required": [
        "approver",
        "approved_at"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "requirements_reviewed": [
    {
      "req_id": "REQ-001",
      "verdict": "pass",
      "reviewer": "carla@acme.com",
      "reviewed_at": "2026-05-20"
    }
  ],
  "blocking_issues": [],
  "sign_off": {
    "approver": "amaia@acme.com",
    "approved_at": "2026-05-22"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "requirements_reviewed": []
}
]]></code>
    <note>requirements_reviewed empty (min 1); blocking_issues + sign_off missing.</note>
  </example>

  <forbidden>
    <pattern id="rubber-stamp-review" severity="high">Every requirement is verdict=pass with no annotations.</pattern>
    <pattern id="missing-feasibility" severity="medium">Requirements pass validation without engineering feasibility input.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-validation.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
