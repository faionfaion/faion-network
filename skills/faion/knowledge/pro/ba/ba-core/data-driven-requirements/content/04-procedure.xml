<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Data-Driven Requirements Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply this methodology end-to-end. Each step names inputs, actions, outputs, and optional decision-gates.</summary>
  <section title="Procedure">
    <step n="1" name="connect-sources">
      <input>Source list</input>
      <action>Configure analytics + telemetry + support exports.</action>
      <output>Data pipeline ready</output>
    </step>
    <step n="2" name="pull-window">
      <input>Pipeline</input>
      <action>Pull a relevant window (last 4-12 weeks).</action>
      <output>Raw signal dump</output>
    </step>
    <step n="3" name="cluster-signals">
      <input>Raw dump</input>
      <action>Group by theme; tag with metric + sample size.</action>
      <output>Signal clusters</output>
    </step>
    <step n="4" name="draft-requirements">
      <input>Clusters</input>
      <action>Convert each high-signal cluster into a requirement; attach evidence trail + baseline + target.</action>
      <output>Requirements bundle</output>
      <decision-gate>Reject anecdote-only evidence.</decision-gate>
    </step>
    <step n="5" name="validate">
      <input>Requirements bundle</input>
      <action>Run scripts/validate-data-driven-requirements.py.</action>
      <output>Validated bundle</output>
    </step>
  </section>
</text>
