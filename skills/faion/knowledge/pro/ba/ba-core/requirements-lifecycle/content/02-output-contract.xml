<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Requirements Lifecycle Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 the produced artefact must satisfy. Validator (scripts/validate-requirements-lifecycle.py) enforces required keys + per-field constraints. Forbidden patterns are explicit anti-shapes the validator rejects.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/requirements-lifecycle.json",
  "type": "object",
  "required": [
    "states",
    "transitions",
    "exceptions"
  ],
  "properties": {
    "states": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string"
      }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "trigger",
          "owner",
          "sla_days"
        ]
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "states": [
    "draft",
    "reviewed",
    "approved",
    "implemented",
    "verified",
    "retired"
  ],
  "transitions": [
    {
      "from": "draft",
      "to": "reviewed",
      "trigger": "BA submits for review",
      "owner": "ba@acme.com",
      "sla_days": 5
    },
    {
      "from": "reviewed",
      "to": "approved",
      "trigger": "Sponsor signoff",
      "owner": "amaia@acme.com",
      "sla_days": 7
    }
  ],
  "exceptions": []
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "states": [
    "new",
    "done"
  ]
}
]]></code>
    <note>states too short (min 5); transitions + exceptions missing.</note>
  </example>

  <forbidden>
    <pattern id="happy-path-only" severity="medium">Lifecycle policy lacks 'rejected' or 'retired' transitions.</pattern>
    <pattern id="ownerless-transitions" severity="high">Transitions have no named owner.</pattern>
  </forbidden>

  <reference path="scripts/validate-requirements-lifecycle.py">Validator script (stdlib-only; --help + --self-test).</reference>
</text>
