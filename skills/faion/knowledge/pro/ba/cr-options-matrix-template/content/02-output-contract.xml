<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="CR Options Matrix Template — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cr-options-matrix-template.json",
  "type": "object",
  "required": [
    "matrix_id",
    "options",
    "scores",
    "recommendation",
    "rationale",
    "approver",
    "decision_by",
    "version",
    "last_reviewed",
    "owner"
  ],
  "properties": {
    "matrix_id": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "recommendation": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "approver": {
      "type": "string",
      "minLength": 1
    },
    "decision_by": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "matrix_id": "sample-matrix_id",
  "options": [
    {
      "id": "x1"
    }
  ],
  "scores": [
    {
      "id": "x1"
    }
  ],
  "recommendation": "sample-recommendation",
  "rationale": "sample-rationale",
  "approver": "Olena Kovalenko (COO)",
  "decision_by": "2026-06-30",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "ruslan@faion.net"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="matrix_id"/>
      <field name="options"/>
      <field name="scores"/>
      <field name="recommendation"/>
      <field name="rationale"/>
      <field name="approver"/>
      <field name="decision_by"/>
      <field name="version"/>
      <field name="last_reviewed"/>
      <field name="owner"/>
    </required>

    <forbidden>
      <pattern id="f1">owner = 'team' / 'we' / 'us' / empty string</pattern>
      <pattern id="f2">rationale that does not reference any input by name</pattern>
      <pattern id="f3">inputs_used is empty AND decision is not 'no-op'</pattern>
      <pattern id="f4">duplicate artefact_id within the same store</pattern>
      <pattern id="f5">options count &lt; 2</pattern>
      <pattern id="f6">recommendation without rationale referencing scores</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Trim rationale to ≤500 chars, preserving numeric claims and named tools.</transformation>
      <transformation>Promote a 'no decision yet' state to status='pending' rather than fabricating a decision.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-cr-options-matrix-template.py"/>
  </output-contract>
</text>
