<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Compliance Checklist by Domain — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/compliance-checklist-by-domain.json",
  "type": "object",
  "required": [
    "domain",
    "items",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "domain": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": "valid example",
  "domain": "sample-domain",
  "items": [
    {
      "id": "x1"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner = 'team' violates rule r3.</note>
  </example>

  <output-contract>
    <required>
      <field name="domain"/>
      <field name="items"/>
      <field name="owner"/>
      <field name="version"/>
      <field name="last_reviewed"/>
    </required>

    <forbidden>
      <pattern id="f1">owner = 'team' / 'we' / 'us' / empty string</pattern>
      <pattern id="f2">rationale that does not reference any input by name</pattern>
      <pattern id="f3">inputs_used is empty AND decision is not 'no-op'</pattern>
      <pattern id="f4">duplicate artefact_id within the same store</pattern>
      <pattern id="f5">item without source_clause OR evidence_required</pattern>
      <pattern id="f6">items count &gt; 50 per domain pass</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Trim rationale to ≤500 chars, preserving numeric claims and named tools.</transformation>
      <transformation>Promote a 'no decision yet' state to status='pending' rather than fabricating a decision.</transformation>
    </allowed-transformations>

    <schema-reference path="scripts/validate-compliance-checklist-by-domain.py"/>
  </output-contract>
</text>
