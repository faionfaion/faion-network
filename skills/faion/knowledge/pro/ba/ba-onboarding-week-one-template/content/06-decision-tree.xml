<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="BA Week-One Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routes the BA from pack-state signal to the active rule.</summary>
  <decision-tree>
    <root-question id="q-inventory">inventory.md row_count &gt;= 5 OR project &lt; 6 months old?</root-question>
    <branch when="inventory_row_count &lt; 5 AND project_age_months &gt;= 6">
      <conclusion ref="r1-artefact-first" verdict="STOP; escalate access; run artefact pull"/>
    </branch>
    <branch when="inventory_complete == true">
      <question id="q-stakeholders">stakeholders.md.approve_authority_count &gt;= 1?</question>
      <branch when="approve_authority_count == 0">
        <conclusion ref="r2-named-stakeholders" verdict="identify Approve-authority stakeholder; do not advance"/>
      </branch>
      <branch when="approve_authority_count &gt;= 1">
        <question id="q-glossary">glossary_md.term_count &gt;= 15?</question>
        <branch when="term_count &lt; 15">
          <conclusion ref="r3-glossary-written-down" verdict="harvest more terms from inventory + interviews"/>
        </branch>
        <branch when="term_count &gt;= 15">
          <question id="q-process">processes_md has ≥1 diagram file (PNG/SVG)?</question>
          <branch when="diagram_files.length == 0">
            <conclusion ref="r4-process-baseline-diagram" verdict="commit at least one baseline diagram before Day 5"/>
          </branch>
          <branch when="diagram_files.length &gt;= 1">
            <question id="q-signoff">signoff.engagement_manager_name non-empty?</question>
            <branch when="signoff_empty == true">
              <conclusion ref="r5-gap-memo" verdict="request engagement-manager signoff in writing"/>
            </branch>
            <branch when="signoff_empty == false">
              <conclusion ref="r5-gap-memo" verdict="pack accepted; ready to start requirements"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="acme-week-one">
    inventory=47 → approve_authority=2 → glossary=22 → 1 diagram → PM signoff at 2026-05-22T17:00Z → pack accepted (r5).
  </example>
</text>
