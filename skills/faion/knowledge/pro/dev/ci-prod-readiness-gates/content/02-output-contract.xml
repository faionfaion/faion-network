<text id="02-output-contract" title="ci-prod-readiness-gates Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ci-prod-readiness-gates.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "workflow_file",
    "budget_file",
    "gates",
    "shadow_mode_days",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "pattern": "^(?!team$|we$|us$|engineering$).+",
      "minLength": 2
    },
    "workflow_file": {
      "type": "string",
      "pattern": "^\\.github/workflows/.*\\.ya?ml$|^\\.gitlab-ci\\.yml$"
    },
    "budget_file": {
      "type": "string",
      "minLength": 3
    },
    "gates": {
      "type": "array",
      "items": {
        "enum": [
          "lint",
          "perf_budget",
          "a11y",
          "slo_instrumentation",
          "dep_vuln",
          "license"
        ]
      },
      "minItems": 4
    },
    "shadow_mode_days": {
      "type": "integer",
      "minimum": 14,
      "maximum": 60
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "exception_label": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ci-prod-readiness-2026-05-23",
  "owner": "@ruslan",
  "workflow_file": ".github/workflows/prod-readiness.yml",
  "budget_file": "prod-readiness.yaml",
  "gates": [
    "lint",
    "perf_budget",
    "a11y",
    "dep_vuln",
    "license",
    "slo_instrumentation"
  ],
  "shadow_mode_days": 14,
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "exception_label": "gate-exception"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "workflow_file": "ci.yml",
  "budget_file": "",
  "gates": [
    "lint"
  ],
  "shadow_mode_days": 0,
  "version": "v1",
  "last_reviewed": "soon"
}
]]></code>
    <note>owner=&apos;team&apos;; workflow_file not under .github/workflows/; gates count below 4; shadow_mode_days below 14.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">owner = &apos;team&apos; / &apos;we&apos; / empty.</forbidden>
    <forbidden id="f2">Magic numbers in workflow YAML instead of budget file references.</forbidden>
    <forbidden id="f3">Blocking-gate flip without 14-day shadow period.</forbidden>
    <forbidden id="f4">Silent exception without a labeled PR + audit log.</forbidden>
  </section>

  <reference path="scripts/validate-ci-prod-readiness-gates.py">Validator script.</reference>
</text>
