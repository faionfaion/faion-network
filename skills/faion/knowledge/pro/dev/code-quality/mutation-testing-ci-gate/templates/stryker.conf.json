{
  "__faion_header__": {
    "purpose": "Stryker config with incremental + dashboard reporter.",
    "consumes": "see content/02-output-contract.xml inputs",
    "produces": "artefact conforming to content/02-output-contract.xml (mutation-testing-ci-gate)",
    "depends_on": "content/01-core-rules.xml",
    "token_budget_impact": "small (template is loaded only when an artefact is being authored)"
  },
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts"
  ],
  "testRunner": "jest",
  "reporters": [
    "html",
    "clear-text",
    "dashboard"
  ],
  "incremental": true,
  "incrementalFile": ".stryker-tmp/incremental.json",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "timeoutMS": 60000
}
