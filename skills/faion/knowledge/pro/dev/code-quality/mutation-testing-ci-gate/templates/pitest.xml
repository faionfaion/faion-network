<!-- purpose: Pitest profile for incremental mutation. | consumes: see content/02-output-contract.xml inputs | produces: artefact conforming to content/02-output-contract.xml (mutation-testing-ci-gate) | depends-on: content/01-core-rules.xml | token-budget-impact: small (template is loaded only when an artefact is being authored) -->
<configuration>
  <build>
    <plugins>
      <plugin>
        <groupId>org.pitest</groupId>
        <artifactId>pitest-maven</artifactId>
        <configuration>
          <historyInputFile>target/pitest/history.bin</historyInputFile>
          <historyOutputFile>target/pitest/history.bin</historyOutputFile>
          <mutationThreshold>60</mutationThreshold>
          <failWhenNoMutations>false</failWhenNoMutations>
          <withHistory>true</withHistory>
        </configuration>
      </plugin>
    </plugins>
  </build>
</configuration>
