<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="mutation-testing-ci-gate Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mutation-testing-ci-gate.json",
  "type": "object",
  "required": [
    "tool",
    "config_path",
    "incremental_only",
    "shadow_mode_days",
    "module_floors",
    "exception_label"
  ],
  "properties": {
    "tool": {
      "enum": [
        "stryker",
        "stryker-net",
        "mutmut",
        "pitest",
        "infection",
        "cosmic-ray"
      ]
    },
    "config_path": {
      "type": "string",
      "minLength": 3
    },
    "incremental_only": {
      "const": true
    },
    "shadow_mode_days": {
      "type": "integer",
      "minimum": 14,
      "maximum": 60
    },
    "module_floors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "module",
          "floor_pct"
        ],
        "properties": {
          "module": {
            "type": "string"
          },
          "floor_pct": {
            "type": "integer",
            "minimum": 20,
            "maximum": 90
          }
        }
      },
      "minItems": 1
    },
    "exception_label": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tool": "stryker",
  "config_path": "stryker.conf.json",
  "incremental_only": true,
  "shadow_mode_days": 21,
  "module_floors": [
    {
      "module": "src/billing",
      "floor_pct": 65
    },
    {
      "module": "src/auth",
      "floor_pct": 70
    }
  ],
  "exception_label": "mutation-exception"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tool": "stryker",
  "config_path": "",
  "incremental_only": false,
  "shadow_mode_days": 1,
  "module_floors": []
}
]]></code>
    <note>config_path empty; full-repo mutation; shadow_mode_days below 14; no floors documented.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">Full-repo mutation on every PR.</forbidden>
    <forbidden id="f2">Flipping to blocking mode without &gt;= 14 days of shadow telemetry.</forbidden>
    <forbidden id="f3">Single global mutation floor instead of per-module floors.</forbidden>
    <forbidden id="f4">Hidden bypass without a labeled PR + audit log.</forbidden>
  </section>

  <reference path="scripts/validate-mutation-testing-ci-gate.py">Validator script.</reference>
</text>
