<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="cqrs-pattern Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cqrs-pattern.json",
  "type": "object",
  "required": [
    "module_root",
    "command_handlers",
    "query_handlers",
    "mediator_path",
    "no_mixed_handlers"
  ],
  "properties": {
    "module_root": {
      "type": "string",
      "minLength": 1
    },
    "command_handlers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "query_handlers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "mediator_path": {
      "type": "string",
      "minLength": 3
    },
    "no_mixed_handlers": {
      "const": true
    },
    "documented_projection_lag_ms_p95": {
      "type": "integer"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "module_root": "myapp",
  "command_handlers": [
    "myapp.commands.PlaceOrderHandler"
  ],
  "query_handlers": [
    "myapp.queries.GetOrderHandler"
  ],
  "mediator_path": "myapp.mediator.Mediator",
  "no_mixed_handlers": true,
  "documented_projection_lag_ms_p95": 250
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "module_root": "myapp",
  "command_handlers": [],
  "query_handlers": [],
  "mediator_path": "",
  "no_mixed_handlers": false
}
]]></code>
    <note>No handlers; mediator empty; handlers mixing query+command shapes.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">QueryHandler that mutates state.</forbidden>
    <forbidden id="f2">CommandHandler that returns a rich read model (return None or an ID only).</forbidden>
    <forbidden id="f3">Cross-handler imports without going through the mediator.</forbidden>
    <forbidden id="f4">Unmeasured projection lag.</forbidden>
  </section>

  <reference path="scripts/validate-cqrs-pattern.py">Validator script.</reference>
</text>
