<text id="02-output-contract" title="clean-architecture Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/clean-architecture.json",
  "type": "object",
  "required": [
    "module_root",
    "layers_present",
    "import_linter_contract_path",
    "all_inward_imports"
  ],
  "properties": {
    "module_root": {
      "type": "string",
      "minLength": 1
    },
    "layers_present": {
      "type": "array",
      "items": {
        "enum": [
          "domain",
          "application",
          "presentation",
          "infrastructure"
        ]
      },
      "minItems": 4,
      "maxItems": 4
    },
    "import_linter_contract_path": {
      "type": "string",
      "pattern": ".+\\.(ini|toml)$"
    },
    "all_inward_imports": {
      "const": true
    },
    "framework_imports_in_domain": {
      "const": 0
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "module_root": "myapp",
  "layers_present": [
    "domain",
    "application",
    "presentation",
    "infrastructure"
  ],
  "import_linter_contract_path": "pyproject.toml",
  "all_inward_imports": true,
  "framework_imports_in_domain": 0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "module_root": "myapp",
  "layers_present": [
    "domain",
    "application"
  ],
  "import_linter_contract_path": "",
  "all_inward_imports": false,
  "framework_imports_in_domain": 3
}
]]></code>
    <note>Only 2 of 4 layers; contract path empty; outward imports present; framework imports in domain.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">Importing ORM/HTTP from the domain layer.</forbidden>
    <forbidden id="f2">Business logic inside controllers / interface adapters.</forbidden>
    <forbidden id="f3">Shipping the layer skeleton without an import-linter / ArchUnit contract.</forbidden>
    <forbidden id="f4">Use cases that directly construct framework objects (SQLAlchemy session etc.).</forbidden>
  </section>

  <reference path="scripts/validate-clean-architecture.py">Validator script.</reference>
</text>
