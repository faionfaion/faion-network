<text id="06-decision-tree" title="PHPUnit Testing Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping test smell to a PHPUnit rule.</summary>

  <decision-tree>
      <root-question id="q-test-smell">Test smell?</root-question>

        <branch when="smell == flaky_order_dependent">
          <conclusion ref="no-test-order-dependence" verdict="switch to per-test factories + DatabaseTransactions trait"/>
        </branch>
        <branch when="smell == copy_paste_cases">
          <conclusion ref="data-provider-table-tests" verdict="extract to #[DataProvider]"/>
        </branch>
        <branch when="smell == facade_fake_in_unit">
          <conclusion ref="mocks-via-di" verdict="replace facade fake with constructor-injected mock"/>
        </branch>
        <branch when="smell == shared_setup_state">
          <conclusion ref="factory-no-shared-state" verdict="move state into per-test factory call"/>
        </branch>
        <branch when="smell == aaa_violation">
          <conclusion ref="aaa-structure" verdict="refactor into Arrange / Act / Assert blocks"/>
        </branch>
    </decision-tree>

    <example trace="OrderServiceTest">
      smell=copy_paste_cases → #[DataProvider].
    </example>
</text>
