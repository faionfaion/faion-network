<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Laravel Layered Patterns (Controller → Service → Resource) Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping audit signal to a layering rule.</summary>

  <decision-tree>
      <root-question id="q-audit">Audit result?</root-question>

        <branch when="fat_controller_count &gt; 0">
          <conclusion ref="controller-thin" verdict="extract logic to a service per concern"/>
        </branch>
        <branch when="inline_validation_count &gt; 0">
          <conclusion ref="form-request-required" verdict="extract to Form Request class"/>
        </branch>
        <branch when="raw_model_response_count &gt; 0">
          <conclusion ref="resource-required" verdict="wrap in JsonResource with explicit fields"/>
        </branch>
        <branch when="tx_in_controller_count &gt; 0">
          <conclusion ref="service-owns-tx" verdict="move DB::transaction into a service method"/>
        </branch>
        <branch when="inline_auth_count &gt; 0">
          <conclusion ref="policy-required" verdict="create Policy + register + authorizeResource"/>
        </branch>
    </decision-tree>

    <example trace="OrderController">
      fat_controller_count=8 → extract OrderService.
    </example>
</text>
