<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Ruby on Rails Framework Fundamentals Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one Rails module convention-conformance artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ruby-rails.json",
  "type": "object",
  "required": [
    "module",
    "uses_restful_resources",
    "strong_params_used",
    "secrets_in_credentials",
    "callbacks_for_side_effects_count",
    "concerns_for_duplication"
  ],
  "properties": {
    "module": {
      "type": "string"
    },
    "uses_restful_resources": {
      "type": "boolean",
      "const": true
    },
    "strong_params_used": {
      "type": "boolean",
      "const": true
    },
    "secrets_in_credentials": {
      "type": "boolean",
      "const": true
    },
    "callbacks_for_side_effects_count": {
      "type": "integer",
      "maximum": 0
    },
    "concerns_for_duplication": {
      "type": "boolean",
      "const": true
    },
    "ad_hoc_routes_count": {
      "type": "integer",
      "maximum": 3
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "module": "orders",
  "uses_restful_resources": true,
  "strong_params_used": true,
  "secrets_in_credentials": true,
  "callbacks_for_side_effects_count": 0,
  "concerns_for_duplication": true,
  "ad_hoc_routes_count": 1
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "module": "orders",
  "uses_restful_resources": false,
  "strong_params_used": false,
  "secrets_in_credentials": false,
  "callbacks_for_side_effects_count": 5,
  "concerns_for_duplication": false,
  "ad_hoc_routes_count": 12
}
]]></code>
    <note>No resources; no strong params; secrets in ENV; 5 callbacks doing side effects; no concerns; 12 ad-hoc routes.</note>
  </example>
  <forbidden>
      <pattern id="no-strong-params">`Model.create(params[:resource])` without `.permit(...)`.</pattern>
      <pattern id="after-save-send-mail">`after_save :send_confirmation` triggering external email.</pattern>
      <pattern id="secrets-in-env">Secret credentials (API keys, OAuth client_secret) read from ENV in production.</pattern>
  </forbidden>

  <reference path="scripts/validate-ruby-rails.py">Validator script</reference>
</text>
