<text id="06-decision-tree" title="Ruby on Rails Framework Fundamentals Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping convention smell to a rule.</summary>

  <decision-tree>
      <root-question id="q-smell">Convention smell?</root-question>

        <branch when="smell == ad_hoc_routes">
          <conclusion ref="restful-resources" verdict="refactor to resources block"/>
        </branch>
        <branch when="smell == no_strong_params">
          <conclusion ref="strong-parameters" verdict="add params.require(...).permit(...) per controller"/>
        </branch>
        <branch when="smell == secrets_in_env">
          <conclusion ref="credentials-not-env" verdict="migrate to credentials.yml.enc"/>
        </branch>
        <branch when="smell == callback_side_effect">
          <conclusion ref="callback-only-for-invariants" verdict="move side effect to service; keep callback for invariants only"/>
        </branch>
        <branch when="smell == duplicated_model_method">
          <conclusion ref="concern-for-shared-multi-model" verdict="extract into app/models/concerns/Name.rb"/>
        </branch>
    </decision-tree>

    <example trace="Orders hardening">
      smell=ad_hoc_routes → refactor to resources block.
    </example>
</text>
