<text id="02-output-contract" title="Spring Boot Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing the pattern application artefact (properties class + advice + profiles).</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/java-spring-boot-patterns.json",
  "type": "object",
  "required": [
    "properties_classes",
    "controller_advice_present",
    "profiles",
    "system_getenv_count"
  ],
  "properties": {
    "properties_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Za-z0-9]+Properties$"
      }
    },
    "controller_advice_present": {
      "type": "boolean",
      "const": true
    },
    "profiles": {
      "type": "array",
      "items": {
        "enum": [
          "dev",
          "staging",
          "prod",
          "test",
          "local"
        ]
      },
      "minItems": 2
    },
    "system_getenv_count": {
      "type": "integer",
      "maximum": 0
    },
    "validated_properties": {
      "type": "boolean",
      "const": true
    },
    "value_annotation_count_per_bean": {
      "type": "integer",
      "maximum": 3
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "properties_classes": [
    "MailProperties",
    "AuthProperties"
  ],
  "controller_advice_present": true,
  "profiles": [
    "dev",
    "staging",
    "prod"
  ],
  "system_getenv_count": 0,
  "validated_properties": true,
  "value_annotation_count_per_bean": 2
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "properties_classes": [],
  "controller_advice_present": false,
  "profiles": [
    "dev"
  ],
  "system_getenv_count": 5,
  "validated_properties": false,
  "value_annotation_count_per_bean": 12
}
]]></code>
    <note>No @ConfigurationProperties classes; no @ControllerAdvice; only one profile; raw System.getenv() usages; no @Validated; 12 @Value annotations in one bean.</note>
  </example>
  <forbidden>
      <pattern id="system-getenv">`System.getenv(...)` or `System.getProperty(...)` inside a bean.</pattern>
      <pattern id="value-blast">More than 3 `@Value` annotations on a single bean.</pattern>
      <pattern id="if-env">`if (env.equals(&quot;prod&quot;))` runtime branches instead of `@Profile`.</pattern>
  </forbidden>

  <reference path="scripts/validate-java-spring-boot-patterns.py">Validator script</reference>
</text>
