<text id="06-decision-tree" title="JUnit 5 + Spring Boot Test Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping test target to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-target">What is being tested?</root-question>

    <branch when="target == controller">
      <conclusion ref="webmvctest-for-controllers" verdict="@WebMvcTest + @MockBean for services + MockMvc"/>
    </branch>

    <branch when="target == service">
      <conclusion ref="mockitoextension-for-services" verdict="@ExtendWith(MockitoExtension.class) + @Mock + @InjectMocks; no Spring context"/>
    </branch>

    <branch when="target == repository">
      <question id="q-dialect">Does the code rely on Postgres-specific features (JSONB, sequences, FK enforcement)?</question>
      <branch when="needs_dialect == true">
        <conclusion ref="testcontainers-for-integration" verdict="@DataJpaTest + Testcontainers Postgres; H2 forbidden"/>
      </branch>
      <branch when="needs_dialect == false">
        <conclusion ref="datajpatest-for-repo-slices" verdict="@DataJpaTest with H2 acceptable for trivial cases"/>
      </branch>
    </branch>

    <branch when="target == multi_layer_end_to_end">
      <conclusion ref="testcontainers-for-integration" verdict="@SpringBootTest(webEnvironment=RANDOM_PORT) + @Testcontainers + @Container Postgres"/>
    </branch>
  </decision-tree>

  <example trace="orders-controller">
    target=controller → @WebMvcTest(OrdersController.class) + @MockBean OrderService + MockMvc.perform(...).andExpect(...).
  </example>
</text>
