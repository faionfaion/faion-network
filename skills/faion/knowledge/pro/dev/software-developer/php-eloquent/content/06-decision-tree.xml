<text id="06-decision-tree" title="PHP Eloquent ORM Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping Eloquent usage smell to a rule.</summary>

  <decision-tree>
      <root-question id="q-smell">Which Eloquent smell is present?</root-question>

        <branch when="smell == mass_assign_unguarded">
          <conclusion ref="fillable-or-guarded-required" verdict="declare $fillable whitelist"/>
        </branch>
        <branch when="smell == lazy_in_loop">
          <conclusion ref="eager-load-in-services" verdict="add -&gt;with(...) at query origin"/>
        </branch>
        <branch when="smell == raw_string_attr">
          <conclusion ref="casts-for-typed-attrs" verdict="declare $casts for the attribute"/>
        </branch>
        <branch when="smell == repeated_where">
          <conclusion ref="scope-for-reused-where" verdict="extract to scopeXxx method"/>
        </branch>
        <branch when="smell == multi_write_no_tx">
          <conclusion ref="tx-for-multi-write" verdict="wrap in DB::transaction"/>
        </branch>
    </decision-tree>

    <example trace="Order::create + Inventory::decrement">
      smell=multi_write_no_tx → wrap in DB::transaction.
    </example>
</text>
