<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="DDD Value Objects Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for a value-object spec — immutability, validation, identity-absence.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ddd-value-objects.json",
  "type": "object",
  "required": ["class_name", "immutable", "constructor_validation", "value_equality", "has_identity_field"],
  "properties": {
    "class_name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"},
    "immutable": {"type": "boolean", "const": true},
    "constructor_validation": {"type": "boolean", "const": true},
    "value_equality": {"type": "boolean", "const": true},
    "has_identity_field": {"type": "boolean", "const": false},
    "language": {"enum": ["python", "csharp", "java", "kotlin", "typescript"]},
    "ops": {
      "type": "array",
      "items": {"type": "object", "required": ["name", "returns_new_instance"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"},
          "returns_new_instance": {"type": "boolean", "const": true}
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "class_name": "Money",
  "immutable": true,
  "constructor_validation": true,
  "value_equality": true,
  "has_identity_field": false,
  "language": "python",
  "ops": [
    {"name": "add", "returns_new_instance": true},
    {"name": "subtract", "returns_new_instance": true}
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "class_name": "money",
  "immutable": false,
  "constructor_validation": false,
  "value_equality": false,
  "has_identity_field": true,
  "language": "python",
  "ops": [{"name": "Add", "returns_new_instance": false}]
}
]]></code>
    <note>name lower-case; mutable; no validation; identity-based equality; has UUID field; operation mutates.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>`immutable == false`.</description>
      <reason>Violates `immutability` rule.</reason>
    </antipattern>
    <antipattern>
      <description>`has_identity_field == true`.</description>
      <reason>Violates `no-identity` rule — this is an Entity, not a VO.</reason>
    </antipattern>
    <antipattern>
      <description>Any operation with `returns_new_instance == false`.</description>
      <reason>Violates `ops-return-new` rule.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-ddd-value-objects.py">Validator script</reference>
</text>
