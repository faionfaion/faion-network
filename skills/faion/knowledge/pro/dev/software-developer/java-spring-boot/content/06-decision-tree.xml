<text id="06-decision-tree" title="Spring Boot Layered Architecture Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping API endpoint shape to a Spring Boot layering rule.</summary>

  <decision-tree>
      <root-question id="q-endpoint-shape">Endpoint shape?</root-question>

        <branch when="shape == reactive_streaming">
          <conclusion ref="service-layer-transactions" verdict="use WebFlux + R2DBC instead — different methodology"/>
        </branch>
        <branch when="shape == sync_rest_with_db">
          <question id="q-dto">Returning entity directly?</question>
          <branch when="returns_entity == true">
            <conclusion ref="dto-not-entity" verdict="wrap entity in DTO/record inside @Transactional service method"/>
          </branch>
          <branch when="returns_entity == false">
            <question id="q-tx">@Transactional on controller?</question>
            <branch when="tx_on_controller == true">
              <conclusion ref="service-layer-transactions" verdict="move @Transactional to @Service method"/>
            </branch>
            <branch when="tx_on_controller == false">
              <conclusion ref="actuator-health-required" verdict="ship + enable Actuator health/prometheus + Bean Validation"/>
            </branch>
          </branch>
        </branch>
    </decision-tree>

    <example trace="place-order">
      shape=sync_rest_with_db → returns_entity=false (DTO) → tx_on_controller=false → ship + Actuator.
    </example>
</text>
