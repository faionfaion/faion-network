<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Laravel Queues Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one queue job artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/php-laravel-queues.json",
  "type": "object",
  "required": [
    "job_class",
    "constructor_payload_primitive_only",
    "tries",
    "timeout_s",
    "queue_name",
    "failed_method_implemented",
    "idempotent"
  ],
  "properties": {
    "job_class": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]+Job$"
    },
    "constructor_payload_primitive_only": {
      "type": "boolean",
      "const": true
    },
    "tries": {
      "type": "integer",
      "minimum": 2,
      "maximum": 10
    },
    "timeout_s": {
      "type": "integer",
      "minimum": 5,
      "maximum": 600
    },
    "backoff_seconds": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "minItems": 1
    },
    "queue_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "failed_method_implemented": {
      "type": "boolean",
      "const": true
    },
    "idempotent": {
      "type": "boolean",
      "const": true
    },
    "without_overlapping": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "job_class": "SendOrderConfirmationJob",
  "constructor_payload_primitive_only": true,
  "tries": 5,
  "timeout_s": 30,
  "backoff_seconds": [
    10,
    30,
    60,
    120,
    240
  ],
  "queue_name": "mail",
  "failed_method_implemented": true,
  "idempotent": true,
  "without_overlapping": false
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "job_class": "send_confirmation",
  "constructor_payload_primitive_only": false,
  "tries": 1,
  "timeout_s": 0,
  "queue_name": "default",
  "failed_method_implemented": false,
  "idempotent": false
}
]]></code>
    <note>Job class naming; passes Eloquent model; only 1 try; no timeout; default queue; no failed(); not idempotent.</note>
  </example>
  <forbidden>
      <pattern id="model-in-job">Job constructor accepts an Eloquent model parameter.</pattern>
      <pattern id="default-queue-everywhere">All dispatched jobs land in 'default' queue (no priority split).</pattern>
      <pattern id="no-failed-method">Job class without `public function failed(Throwable $e)`.</pattern>
  </forbidden>

  <reference path="scripts/validate-php-laravel-queues.py">Validator script</reference>
</text>
