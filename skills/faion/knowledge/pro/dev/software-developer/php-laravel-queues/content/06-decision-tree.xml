<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Laravel Queues Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping job characteristic to a queue rule.</summary>

  <decision-tree>
      <root-question id="q-job-shape">What's the job's risk profile?</root-question>

        <branch when="passes_model == true">
          <conclusion ref="primitive-ids-only" verdict="refactor to primitive ID + reload inside handle()"/>
        </branch>
        <branch when="side_effect_external == true">
          <conclusion ref="idempotent-handle" verdict="add idempotency check + WithoutOverlapping middleware"/>
        </branch>
        <branch when="downstream_unreliable == true">
          <conclusion ref="timeout-retries-backoff" verdict="set $tries=5 + $timeout + backoff with jitter"/>
        </branch>
        <branch when="no_failed_handler == true">
          <conclusion ref="failed-method" verdict="implement failed() that logs + alerts"/>
        </branch>
        <branch when="mixed_priority_queue == true">
          <conclusion ref="named-queue-per-priority" verdict="route to named queue + separate worker pool"/>
        </branch>
    </decision-tree>

    <example trace="SendOrderConfirmation">
      side_effect_external=true + downstream_unreliable=true → idempotent + tries+timeout+backoff + failed().
    </example>
</text>
