<text id="02-output-contract" title="CQRS Pattern Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces, plus valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "models_separate",
    "command_returns",
    "queries_pure",
    "projection_from_events",
    "read_models_per_access_pattern"
  ],
  "properties": {
    "models_separate": {
      "const": true
    },
    "command_returns": {
      "enum": [
        "void",
        "id"
      ]
    },
    "queries_pure": {
      "const": true
    },
    "projection_from_events": {
      "const": true
    },
    "read_models_per_access_pattern": {
      "type": "integer",
      "minimum": 1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "models_separate": true,
  "command_returns": "id",
  "queries_pure": true,
  "projection_from_events": true,
  "read_models_per_access_pattern": 3
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "models_separate": false,
  "command_returns": "entity",
  "queries_pure": false,
  "projection_from_events": false,
  "read_models_per_access_pattern": 1
}
]]></code>
    <note>Shared model (r1); command returns entity (r2); query side-effects (r3); hand-maintained read model (r4).</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">models_separate is false (r1)</pattern>
      <pattern id="f2">command_returns is `entity` (r2)</pattern>
      <pattern id="f3">queries_pure is false (r3)</pattern>
      <pattern id="f4">projection_from_events is false (r4)</pattern>
      <pattern id="f5">read_models_per_access_pattern &lt;1 when multiple access patterns exist (r5)</pattern>
    </forbidden>
  </output-contract>

  <reference path="scripts/validate-cqrs-pattern.py">Validator script</reference>
</text>
