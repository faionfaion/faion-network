<text id="06-decision-tree" title="Ruby on Rails Service Objects Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping service-pattern decision to a rule.</summary>

  <decision-tree>
      <root-question id="q-shape">Service shape?</root-question>

        <branch when="shape == multi_action_class">
          <conclusion ref="one-action-per-service" verdict="split into one service per action"/>
        </branch>
        <branch when="shape == raises_for_business_fail">
          <conclusion ref="service-result-explicit" verdict="return ServiceResult.failure(error:) instead"/>
        </branch>
        <branch when="shape == called_from_callback">
          <conclusion ref="no-callbacks-call-services" verdict="remove callback; call service from controller/job"/>
        </branch>
        <branch when="shape == no_isolation_test">
          <conclusion ref="service-tested-in-isolation" verdict="add spec/services/... spec without rails_helper"/>
        </branch>
        <branch when="shape == clean">
          <conclusion ref="service-owns-tx" verdict="ensure transaction wraps multi-write; ship"/>
        </branch>
    </decision-tree>

    <example trace="PlaceOrderService">
      shape=clean → ensure transaction + ship.
    </example>
</text>
