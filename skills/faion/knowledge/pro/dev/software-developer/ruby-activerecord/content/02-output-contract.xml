<text id="02-output-contract" title="Ruby ActiveRecord Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one ActiveRecord model artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ruby-activerecord.json",
  "type": "object",
  "required": [
    "model_class",
    "scopes_count",
    "n_plus_one_sites",
    "transaction_wrapped",
    "enum_for_status",
    "time_now_count"
  ],
  "properties": {
    "model_class": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]+$"
    },
    "scopes_count": {
      "type": "integer",
      "minimum": 0
    },
    "n_plus_one_sites": {
      "type": "integer",
      "maximum": 0
    },
    "transaction_wrapped": {
      "type": "boolean",
      "const": true
    },
    "enum_for_status": {
      "type": "boolean"
    },
    "time_now_count": {
      "type": "integer",
      "maximum": 0
    },
    "update_all_business_count": {
      "type": "integer",
      "maximum": 0
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "model_class": "Order",
  "scopes_count": 4,
  "n_plus_one_sites": 0,
  "transaction_wrapped": true,
  "enum_for_status": true,
  "time_now_count": 0,
  "update_all_business_count": 0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "model_class": "order",
  "scopes_count": 0,
  "n_plus_one_sites": 7,
  "transaction_wrapped": false,
  "enum_for_status": false,
  "time_now_count": 12,
  "update_all_business_count": 3
}
]]></code>
    <note>Model class lowercase; no scopes; 7 N+1; no transactions; magic status strings; 12 Time.now calls; 3 update_all skipping callbacks.</note>
  </example>
  <forbidden>
      <pattern id="lazy-in-each">`.each { |x| x.assoc }` without prior `.includes(:assoc)`.</pattern>
      <pattern id="time-now">`Time.now` / `Date.today` outside framework internals.</pattern>
      <pattern id="update-all-business">`Model.update_all(status: 'X')` in business code (bypasses callbacks, validations, audit log).</pattern>
  </forbidden>

  <reference path="scripts/validate-ruby-activerecord.py">Validator script</reference>
</text>
