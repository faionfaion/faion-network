<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Ruby ActiveRecord Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping AR smell to a rule.</summary>

  <decision-tree>
      <root-question id="q-smell">AR smell?</root-question>

        <branch when="smell == lazy_in_iteration">
          <conclusion ref="includes-no-n-plus-one" verdict="add includes/preload at query origin"/>
        </branch>
        <branch when="smell == repeated_where">
          <conclusion ref="scopes-for-reused-where" verdict="extract to named scope"/>
        </branch>
        <branch when="smell == magic_status">
          <conclusion ref="enum-for-status" verdict="declare enum + migrate column type"/>
        </branch>
        <branch when="smell == multi_write_no_tx">
          <conclusion ref="transaction-block-multi-write" verdict="wrap in ActiveRecord::Base.transaction"/>
        </branch>
        <branch when="smell == time_now">
          <conclusion ref="no-time-now" verdict="replace Time.now → Time.current"/>
        </branch>
    </decision-tree>

    <example trace="Order hardening">
      smell=lazy_in_iteration → add includes.
    </example>
</text>
