<text id="02-output-contract" title="RSpec Testing Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one spec file artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ruby-rspec-testing.json",
  "type": "object",
  "required": [
    "spec_file",
    "uses_describe_context_it",
    "uses_build_stubbed_when_possible",
    "isolated_when_unit",
    "no_unused_let_bang"
  ],
  "properties": {
    "spec_file": {
      "type": "string",
      "pattern": ".*_spec\\\\.rb$"
    },
    "uses_describe_context_it": {
      "type": "boolean",
      "const": true
    },
    "uses_build_stubbed_when_possible": {
      "type": "boolean",
      "const": true
    },
    "isolated_when_unit": {
      "type": "boolean",
      "const": true
    },
    "uses_shared_examples_for_invariants": {
      "type": "boolean"
    },
    "no_unused_let_bang": {
      "type": "boolean",
      "const": true
    },
    "lines": {
      "type": "integer",
      "maximum": 300
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spec_file": "spec/services/orders/place_order_service_spec.rb",
  "uses_describe_context_it": true,
  "uses_build_stubbed_when_possible": true,
  "isolated_when_unit": true,
  "uses_shared_examples_for_invariants": true,
  "no_unused_let_bang": true,
  "lines": 120
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "spec_file": "test_orders.rb",
  "uses_describe_context_it": false,
  "uses_build_stubbed_when_possible": false,
  "isolated_when_unit": false,
  "uses_shared_examples_for_invariants": false,
  "no_unused_let_bang": false,
  "lines": 600
}
]]></code>
    <note>Naming wrong; no describe/context/it; uses create everywhere; not isolated; no shared examples; unused let!; 600 LoC.</note>
  </example>
  <forbidden>
      <pattern id="bare-it">`it 'does X' do ... end` at top level without `describe ... do`.</pattern>
      <pattern id="create-overuse">`create(:order)` in a spec that doesn't touch DB.</pattern>
      <pattern id="unit-spec-needs-rails">Service spec that `require 'rails_helper'` despite testing pure Ruby logic.</pattern>
  </forbidden>

  <reference path="scripts/validate-ruby-rspec-testing.py">Validator script</reference>
</text>
