<text id="06-decision-tree" title="RSpec Testing Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping spec smell to a rule.</summary>

  <decision-tree>
      <root-question id="q-smell">RSpec smell?</root-question>

        <branch when="smell == flat_it_list">
          <conclusion ref="describe-context-it" verdict="wrap variants in context blocks"/>
        </branch>
        <branch when="smell == create_overuse">
          <conclusion ref="factory-bot-build-stubbed-default" verdict="switch to build_stubbed where DB not asserted"/>
        </branch>
        <branch when="smell == rails_helper_in_unit">
          <conclusion ref="isolated-service-specs" verdict="switch to spec_helper + inject mocks"/>
        </branch>
        <branch when="smell == duplicate_invariant_check">
          <conclusion ref="shared-examples-for-invariants" verdict="extract to shared_examples_for"/>
        </branch>
        <branch when="smell == let_bang_overuse">
          <conclusion ref="no-let-bang-when-not-needed" verdict="downgrade to lazy let where side effect not required"/>
        </branch>
    </decision-tree>

    <example trace="PlaceOrderService spec">
      smell=rails_helper_in_unit → spec_helper + mocks.
    </example>
</text>
