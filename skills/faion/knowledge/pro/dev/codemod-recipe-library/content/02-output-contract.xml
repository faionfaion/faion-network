<text id="02-output-contract" title="codemod-recipe-library Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/codemod-recipe-library.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "tool",
    "target_framework",
    "recipes",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "pattern": "^(?!team$|we$|us$|engineering$).+",
      "minLength": 2
    },
    "tool": {
      "enum": [
        "jscodeshift",
        "ts-morph",
        "ast-grep",
        "libcst",
        "Bowler",
        "comby"
      ]
    },
    "target_framework": {
      "type": "string",
      "minLength": 3
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "fixture_before",
          "fixture_after"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]+$"
          },
          "fixture_before": {
            "type": "string"
          },
          "fixture_after": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "codemod-react-18-2026-05-23",
  "owner": "@ruslan",
  "tool": "jscodeshift",
  "target_framework": "react@18",
  "recipes": [
    {
      "name": "render-to-create-root",
      "fixture_before": "fixtures/render.before.js",
      "fixture_after": "fixtures/render.after.js"
    }
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "tool": "regex",
  "target_framework": "",
  "recipes": [],
  "version": "v1",
  "last_reviewed": "soon"
}
]]></code>
    <note>owner=&apos;team&apos;; tool=&apos;regex&apos; (not in enum); recipes empty; version not semver.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">Regex-based codemods that touch source instead of AST.</forbidden>
    <forbidden id="f2">Recipes without paired before/after fixtures.</forbidden>
    <forbidden id="f3">Recipes without a CI smoke test.</forbidden>
    <forbidden id="f4">owner = &apos;team&apos; / &apos;we&apos; / empty.</forbidden>
  </section>

  <reference path="scripts/validate-codemod-recipe-library.py">Validator script.</reference>
</text>
