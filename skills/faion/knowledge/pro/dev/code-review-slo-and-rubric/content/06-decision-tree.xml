<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="code-review-slo-and-rubric Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-root">Is current PR throughput data available for the last 30 days?</root-question>
      <branch when="throughput_data_available == false">
        <conclusion ref="r2" verdict="STOP — collect throughput data before authoring the SLO"/>
      </branch>
      <branch when="throughput_data_available == true">
        <question id="q-next">ai_pre_review_tool_approved == true?</question>
        <branch when="ai_pre_review_tool_approved == true">
          <conclusion ref="r5" verdict="two-pass: AI mechanical + human judgment"/>
        </branch>
        <branch when="ai_pre_review_tool_approved == false">
          <conclusion ref="r4" verdict="single human pass with rubric"/>
        </branch>
      </branch>
  </decision-tree>
</text>
