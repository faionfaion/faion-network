<text id="02-output-contract" title="code-review-slo-and-rubric Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/code-review-slo-and-rubric.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "first_response_business_hours",
    "merge_business_hours",
    "reviewer_open_pr_cap",
    "rotation_algorithm",
    "blockers",
    "nits",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "pattern": "^(?!team$|we$|us$|engineering$).+",
      "minLength": 2
    },
    "first_response_business_hours": {
      "type": "integer",
      "minimum": 1,
      "maximum": 72
    },
    "merge_business_hours": {
      "type": "integer",
      "minimum": 1,
      "maximum": 168
    },
    "reviewer_open_pr_cap": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "rotation_algorithm": {
      "enum": [
        "round-robin",
        "load-balanced",
        "explicit-pair",
        "code-owners"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "nits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ai_pre_review_tool": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "crs-2026-05-23",
  "owner": "@ruslan",
  "first_response_business_hours": 24,
  "merge_business_hours": 48,
  "reviewer_open_pr_cap": 5,
  "rotation_algorithm": "round-robin",
  "blockers": [
    "correctness regression",
    "security defect",
    "public-API breaking without versioning",
    "missing test for new behaviour"
  ],
  "nits": [
    "naming preference",
    "formatting",
    "unrelated refactor request"
  ],
  "ai_pre_review_tool": "claude",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "first_response_business_hours": 0,
  "merge_business_hours": 0,
  "reviewer_open_pr_cap": 100,
  "rotation_algorithm": "ad-hoc",
  "blockers": [],
  "nits": [],
  "version": "v1",
  "last_reviewed": "soon"
}
]]></code>
    <note>owner=&apos;team&apos;; SLO values out of range; rotation_algorithm not in enum; blockers empty.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">owner = &apos;team&apos; / &apos;we&apos; / empty.</forbidden>
    <forbidden id="f2">SLO values that are aspirational without source dataset.</forbidden>
    <forbidden id="f3">Subjective blockers (e.g., &apos;I prefer this style&apos;).</forbidden>
    <forbidden id="f4">Single-pass review without AI pre-review when AI tool is available + team approved.</forbidden>
  </section>

  <reference path="scripts/validate-code-review-slo-and-rubric.py">Validator script.</reference>
</text>
