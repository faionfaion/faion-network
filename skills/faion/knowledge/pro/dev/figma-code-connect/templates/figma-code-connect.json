{
  "__faion_header__": {
    "purpose": "JSON Schema for figma-code-connect output contract",
    "consumes": "see content/02-output-contract.xml",
    "produces": "config artefact validated by scripts/validate-figma-code-connect.py",
    "depends_on": "content/01-core-rules.xml, content/02-output-contract.xml",
    "token_budget_impact": "~200 tokens when loaded as context"
  },
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/figma-code-connect.json",
  "type": "object",
  "required": ["artefact_id", "owner", "decision", "rationale", "inputs_used", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
    "owner": {"type": "string", "minLength": 3},
    "decision": {"type": "string", "minLength": 4},
    "rationale": {"type": "string", "minLength": 30},
    "inputs_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {"type": "string"},
          "source": {"type": "string"}
        }
      }
    },
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "produces": {"const": "config"}
  },
  "additionalProperties": true
}
