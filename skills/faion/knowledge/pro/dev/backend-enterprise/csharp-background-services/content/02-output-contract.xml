<text id="02-output-contract" title="C# Background Services Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces. Validator script enforces required keys, field shapes, and forbidden patterns. Output that fails the schema is rejected.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/csharp-background-services.json",
  "title": "C# Background Services",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artefact_id",
    "owner",
    "file_path",
    "language",
    "build_passes",
    "tests_passing",
    "rules_checked",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "file_path": {
      "type": "string"
    },
    "language": {
      "enum": [
        "csharp",
        "java",
        "kotlin",
        "swift",
        "python",
        "typescript",
        "go",
        "bash"
      ]
    },
    "build_passes": {
      "type": "boolean",
      "const": true
    },
    "tests_passing": {
      "type": "integer",
      "minimum": 1
    },
    "rules_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "csharp-background-services-impl-v1",
  "owner": "ruslan@faion.net",
  "file_path": "src/Features/Users/UsersController.cs",
  "language": "csharp",
  "build_passes": true,
  "tests_passing": 12,
  "rules_checked": [
    "r1",
    "r2",
    "r3"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "BAD ID",
  "owner": "",
  "version": "draft"
}
]]></code>
    <note>artefact_id violates pattern; owner is empty; version not semver; required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>owner equals "team" / "we" / "us" / empty string</item>
      <item>rationale or evidence that does not cite at least one input artefact by name</item>
      <item>version frozen at 1.0.0 when decision content has changed</item>
      <item>artefact_id reuses an existing id within the same store</item>
    </list>
  </section>

  <reference path="scripts/validate-csharp-background-services.py">Validator script (stdlib-only; --help + --self-test)</reference>
</text>
