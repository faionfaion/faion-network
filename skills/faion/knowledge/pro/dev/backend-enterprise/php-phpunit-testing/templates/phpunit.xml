<?xml version="1.0" encoding="UTF-8"?>
<!-- purpose: phpunit.xml configuration with coverage + Unit/Feature suite split -->
<!-- consumes: project root + tests/ directory layout -->
<!-- produces: phpunit config conforming to feature-vs-unit-boundary + coverage-gate-in-ci -->
<!-- depends-on: content/01-core-rules.xml rules feature-vs-unit-boundary, coverage-gate-in-ci -->
<!-- token-budget-impact: ~250 tokens when loaded as context -->
<phpunit
    colors="true"
    stopOnFailure="false"
    cacheDirectory=".phpunit.cache"
    executionOrder="random"
    beStrictAboutTestsThatDoNotTestAnything="true"
    beStrictAboutOutputDuringTests="true"
    failOnRisky="true"
    failOnWarning="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <php>
        <env name="APP_ENV"         value="testing"/>
        <env name="DB_CONNECTION"   value="sqlite"/>
        <env name="DB_DATABASE"     value=":memory:"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="CACHE_STORE"     value="array"/>
        <env name="MAIL_MAILER"     value="array"/>
        <env name="SESSION_DRIVER"  value="array"/>
        <env name="BCRYPT_ROUNDS"   value="4"/>
    </php>
</phpunit>
