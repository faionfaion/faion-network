    <summary>Spring Boot enterprise patterns: BaseEntity, JpaSpecificationExecutor, @Transactional defaults, records, MapStruct, ProblemDetail errors, N+1 prevention.</summary>
    <tags>
      <tag>java</tag>
      <tag>spring-boot</tag>
      <tag>enterprise</tag>
      <tag>jpa</tag>
      <tag>patterns</tag>
    </tags>
    <category>patterns</category>
    <difficulty>intermediate</difficulty>
