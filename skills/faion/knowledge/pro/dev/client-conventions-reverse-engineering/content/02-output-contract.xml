<text id="02-output-contract" title="client-conventions-reverse-engineering Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/client-conventions-reverse-engineering.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "client_repo",
    "lint_tool",
    "lint_config_path",
    "naming",
    "branching_model",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "pattern": "^(?!team$|we$|us$|engineering$).+",
      "minLength": 2
    },
    "client_repo": {
      "type": "string",
      "minLength": 5
    },
    "lint_tool": {
      "type": "string",
      "minLength": 2
    },
    "lint_config_path": {
      "type": "string",
      "minLength": 3
    },
    "naming": {
      "type": "object",
      "required": [
        "files",
        "classes",
        "functions"
      ]
    },
    "branching_model": {
      "enum": [
        "trunk",
        "github-flow",
        "gitflow",
        "release-flow"
      ]
    },
    "commit_format": {
      "type": "string"
    },
    "layering_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "rrev-2026-05-23",
  "owner": "@ruslan",
  "client_repo": "github.com/acme/web",
  "lint_tool": "eslint",
  "lint_config_path": ".eslintrc.json",
  "naming": {
    "files": "kebab-case",
    "classes": "PascalCase",
    "functions": "camelCase"
  },
  "branching_model": "github-flow",
  "commit_format": "conventional",
  "layering_rules": [
    "no DB calls from controllers"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "client_repo": "",
  "lint_tool": "",
  "lint_config_path": "",
  "naming": {},
  "branching_model": "ad-hoc",
  "version": "v1",
  "last_reviewed": "soon"
}
]]></code>
    <note>owner=&apos;team&apos;; lint metadata empty; naming missing required keys; branching_model not in enum.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">owner = &apos;team&apos; / &apos;we&apos; / empty.</forbidden>
    <forbidden id="f2">Rule entries without a source path or PR/commit citation.</forbidden>
    <forbidden id="f3">Multiple convention files instead of a single guardrail.</forbidden>
    <forbidden id="f4">Inferring implicit conventions from &lt; 20 PRs.</forbidden>
  </section>

  <reference path="scripts/validate-client-conventions-reverse-engineering.py">Validator script.</reference>
</text>
