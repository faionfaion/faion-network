<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Message Queue Patterns Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for mq-patterns.</summary>
  <decision-tree>
    <root-question id="q-root">How many consumers see each message?</root-question>
    <branch when="consumers == zero_or_pure_sync"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="consumers == one_of_n_workers"><conclusion ref="topology-by-consumer-shape"/></branch>
    <branch when="consumers == every_subscriber"><conclusion ref="topology-by-consumer-shape"/></branch>
    <branch when="consumers == one_expecting_reply"><conclusion ref="topology-by-consumer-shape"/></branch>
    <branch when="contract_missing == true"><conclusion ref="contract-first"/></branch>
    <branch when="dlq_missing == true"><conclusion ref="dlq-with-alert"/></branch>
    <branch when="metrics_missing == true"><conclusion ref="queue-metrics-required"/></branch>
    <branch when="non_idempotent_consumer == true"><conclusion ref="idempotent-consumers-by-default"/></branch>
  </decision-tree>
</text>
