<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Redis Data Structure Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for nosql-redis-patterns output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nosql-redis-patterns.json",
  "type": "object",
  "required": [
    "keys",
    "ttl_policy"
  ],
  "properties": {
    "keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pattern",
          "type",
          "ttl_seconds"
        ]
      },
      "minItems": 1
    },
    "ttl_policy": {
      "enum": [
        "per-key",
        "namespace-sweep",
        "mixed"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "keys": [
    {
      "pattern": "session:{user_id}",
      "type": "hash",
      "ttl_seconds": 1800
    }
  ],
  "ttl_policy": "per-key"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "keys": [
    {
      "pattern": "rate:{ip}",
      "type": "string"
    }
  ]
}
]]></code>
    <note>ttl_seconds missing on key entry; ttl_policy missing entirely; sliding-window not modelled as sorted set.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-nosql-redis-patterns.py">Validator script (--help, --self-test)</reference>
</text>
