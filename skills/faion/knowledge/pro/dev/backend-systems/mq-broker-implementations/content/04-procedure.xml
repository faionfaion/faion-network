<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Message Broker Implementations Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply mq-broker-implementations end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="pick-broker">
      <input>Constraints (throughput, AWS, retry primitives)</input>
      <action>Apply decision tree → broker choice.</action>
      <output>Broker decision</output>
    </step>
    <step n="2" name="declare-topology">
      <input>Broker decision + topology spec</input>
      <action>Declare queue + DLQ + bindings idempotently.</action>
      <output>Topology live</output>
    </step>
    <step n="3" name="wire-publisher">
      <input>Topology + DB layer</input>
      <action>Publish with confirms / acks=all; use outbox if atomic with DB.</action>
      <output>Publisher live</output>
    </step>
    <step n="4" name="wire-consumer">
      <input>Topology + business handler</input>
      <action>Consume with explicit ack-after-commit; route to DLQ on poison.</action>
      <output>Consumer live</output>
    </step>
    <step n="5" name="validate-and-alert">
      <input>All artefacts</input>
      <action>Run validator; install DLQ-depth alert.</action>
      <output>Production-ready</output>
    </step>
  </section>
</text>
