<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Message Queue Reliability Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for mq-reliability output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mq-reliability.json",
  "type": "object",
  "required": [
    "publisher_confirms",
    "dlq",
    "retry_policy",
    "prefetch_count",
    "queue_length_limit",
    "schema_registry"
  ],
  "properties": {
    "publisher_confirms": {
      "type": "boolean",
      "const": true
    },
    "dlq": {
      "type": "object",
      "required": [
        "queue",
        "alert_threshold"
      ]
    },
    "retry_policy": {
      "type": "object",
      "required": [
        "max_retries",
        "backoff",
        "jitter_pct"
      ]
    },
    "prefetch_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200
    },
    "queue_length_limit": {
      "type": "integer",
      "minimum": 1
    },
    "schema_registry": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "publisher_confirms": true,
  "dlq": {
    "queue": "orders.v1.dlq",
    "alert_threshold": 1
  },
  "retry_policy": {
    "max_retries": 5,
    "backoff": "exponential",
    "jitter_pct": 30
  },
  "prefetch_count": 10,
  "queue_length_limit": 100000,
  "schema_registry": "https://schema.acme.net"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "publisher_confirms": false,
  "prefetch_count": 0
}
]]></code>
    <note>publisher_confirms false; required dlq/retry_policy/queue_length_limit/schema_registry missing; prefetch_count below minimum.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-mq-reliability.py">Validator script (--help, --self-test)</reference>
</text>
