<text id="06-decision-tree" title="Neo4j Graph Database Patterns Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for nosql-neo4j-patterns.</summary>
  <decision-tree>
    <root-question id="q-root">Is the workload graph-shaped?</root-question>
    <branch when="workload == relational_joins_only"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="connection_data_on_node == true"><conclusion ref="relationships-first-class"/></branch>
    <branch when="unbounded_traversal == true"><conclusion ref="bounded-traversal-with-profile"/></branch>
    <branch when="missing_property_index == true"><conclusion ref="indexes-on-filtered-properties"/></branch>
  </decision-tree>
</text>
