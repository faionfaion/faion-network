<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Neo4j Graph Database Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for nosql-neo4j-patterns output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nosql-neo4j-patterns.json",
  "type": "object",
  "required": [
    "node_labels",
    "relationship_types",
    "indexes",
    "traversal_queries"
  ],
  "properties": {
    "node_labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "relationship_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "indexes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "property"
        ]
      },
      "minItems": 1
    },
    "traversal_queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "cypher",
          "max_hops"
        ]
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "node_labels": [
    "User",
    "Product"
  ],
  "relationship_types": [
    "PURCHASED"
  ],
  "indexes": [
    {
      "label": "User",
      "property": "user_id"
    }
  ],
  "traversal_queries": [
    {
      "cypher": "MATCH (u:User {user_id:$id})-[:PURCHASED*..3]->(p:Product) RETURN p LIMIT 50",
      "max_hops": 3
    }
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "node_labels": [],
  "traversal_queries": [
    {
      "cypher": "MATCH (u:User)-[:FRIEND*]->(f) RETURN f"
    }
  ]
}
]]></code>
    <note>node_labels empty; relationship_types/indexes missing; traversal_queries lack max_hops and LIMIT.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-nosql-neo4j-patterns.py">Validator script (--help, --self-test)</reference>
</text>
