<text id="02-output-contract" title="rust-testing-property Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-testing-property.json",
  "type": "object",
  "required": [
    "test_file",
    "invariant_name",
    "cases",
    "persists_seeds",
    "uses_prop_assert"
  ],
  "properties": {
    "test_file": {
      "type": "string",
      "pattern": "\\.rs$"
    },
    "invariant_name": {
      "type": "string",
      "minLength": 3
    },
    "cases": {
      "type": "integer",
      "minimum": 16,
      "maximum": 100000
    },
    "persists_seeds": {
      "const": true
    },
    "uses_prop_assert": {
      "const": true
    },
    "approx_for_floats": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_file": "src/codec.rs",
  "invariant_name": "decode_encode_roundtrip",
  "cases": 256,
  "persists_seeds": true,
  "uses_prop_assert": true,
  "approx_for_floats": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "test_file": "src/codec.rs",
  "invariant_name": "x",
  "cases": 10,
  "persists_seeds": false,
  "uses_prop_assert": false,
  "approx_for_floats": false
}
]]></code>
    <note>invariant_name too short; cases below 16; seeds not persisted; uses bare assert! instead of prop_assert!.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">assert_eq! on f64/f32 values.</forbidden>
    <forbidden id="f2">Unbounded cases without a CI-side cap.</forbidden>
    <forbidden id="f3">Bare assert! inside a proptest! block.</forbidden>
    <forbidden id="f4">Discarding failing seeds instead of committing the regression file.</forbidden>
  </section>

  <reference path="scripts/validate-rust-testing-property.py">Validator script.</reference>
</text>
