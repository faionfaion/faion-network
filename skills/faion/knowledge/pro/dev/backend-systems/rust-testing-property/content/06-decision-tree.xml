<text id="06-decision-tree" title="rust-testing-property Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-root">Is the SUT a pure function with a declared invariant?</root-question>
      <branch when="fn_is_pure == false">
        <conclusion ref="skip-this-methodology" verdict="skip — use rust-testing-integration"/>
      </branch>
      <branch when="fn_is_pure == true">
        <question id="q-next">has_invariant == true?</question>
        <branch when="has_invariant == false">
          <conclusion ref="skip-this-methodology" verdict="skip — author specific example tests"/>
        </branch>
        <branch when="has_invariant == true">
          <question id="q-next">returns_float == true?</question>
          <branch when="returns_float == true">
            <conclusion ref="r3" verdict="proptest + approx::assert_relative_eq!"/>
          </branch>
          <branch when="returns_float == false">
            <conclusion ref="r1" verdict="proptest! { prop_assert_eq!(...) }"/>
          </branch>
        </branch>
      </branch>
  </decision-tree>
