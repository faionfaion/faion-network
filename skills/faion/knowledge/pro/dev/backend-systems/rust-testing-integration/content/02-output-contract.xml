<text id="02-output-contract" title="rust-testing-integration Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-testing-integration.json",
  "type": "object",
  "required": [
    "test_file",
    "uses_oneshot",
    "uses_testcontainers",
    "migrations_run_in_setup",
    "tokio_flavor"
  ],
  "properties": {
    "test_file": {
      "type": "string",
      "pattern": "^tests/.*\\.rs$"
    },
    "uses_oneshot": {
      "const": true
    },
    "uses_testcontainers": {
      "type": "boolean"
    },
    "migrations_run_in_setup": {
      "type": "boolean"
    },
    "tokio_flavor": {
      "enum": [
        "multi_thread",
        "current_thread"
      ]
    },
    "snapshot_lib": {
      "enum": [
        "insta",
        "expect-test",
        "none"
      ]
    },
    "schema_isolation": {
      "enum": [
        "per-test-schema",
        "transaction-rollback",
        "shared"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_file": "tests/users_integration.rs",
  "uses_oneshot": true,
  "uses_testcontainers": true,
  "migrations_run_in_setup": true,
  "tokio_flavor": "multi_thread",
  "snapshot_lib": "insta",
  "schema_isolation": "per-test-schema"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "test_file": "src/main.rs",
  "uses_oneshot": false,
  "uses_testcontainers": true,
  "migrations_run_in_setup": false,
  "tokio_flavor": "current_thread",
  "snapshot_lib": "none",
  "schema_isolation": "shared"
}
]]></code>
    <note>Test file outside tests/; uses_oneshot=false; migrations not run; shared schema; current_thread flavor for an HTTP test.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">Hardcoded listener port (127.0.0.1:8080) for integration tests.</forbidden>
    <forbidden id="f2">Shared dev/staging database as the integration backend.</forbidden>
    <forbidden id="f3">Multi-line assert_eq! of JSON or HTML instead of insta snapshot.</forbidden>
    <forbidden id="f4">Default tokio runtime flavor for HTTP handler tests.</forbidden>
  </section>

  <reference path="scripts/validate-rust-testing-integration.py">Validator script.</reference>
</text>
