<text id="06-decision-tree" title="Rust Ownership Model Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for rust-ownership.</summary>
  <decision-tree>
    <root-question id="q-root">Does the code allocate on every call or share state across tasks?</root-question>
    <branch when="workload == embedded_no_heap"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="gratuitous_clone_present == true"><conclusion ref="no-clone-as-shortcut"/></branch>
    <branch when="rc_refcell_in_tokio_task == true"><conclusion ref="arc-mutex-across-threads"/></branch>
    <branch when="missing_lifetime_param == true"><conclusion ref="explicit-lifetimes-for-returned-refs"/></branch>
  </decision-tree>
</text>
