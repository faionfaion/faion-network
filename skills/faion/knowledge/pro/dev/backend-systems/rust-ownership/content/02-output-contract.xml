<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rust Ownership Model Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for rust-ownership output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-ownership.json",
  "type": "object",
  "required": [
    "audited",
    "clone_count",
    "rc_refcell_in_multi_thread"
  ],
  "properties": {
    "audited": {
      "type": "boolean",
      "const": true
    },
    "clone_count": {
      "type": "integer",
      "minimum": 0
    },
    "rc_refcell_in_multi_thread": {
      "type": "boolean",
      "const": false
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "audited": true,
  "clone_count": 14,
  "rc_refcell_in_multi_thread": false
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "audited": false,
  "rc_refcell_in_multi_thread": true
}
]]></code>
    <note>audited false; rc_refcell_in_multi_thread true; clone_count missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-rust-ownership.py">Validator script (--help, --self-test)</reference>
</text>
