<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rust Backend (Axum) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for rust-backend output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-backend.json",
  "type": "object",
  "required": [
    "crate_name",
    "modules",
    "app_error_present",
    "vertical_slice"
  ],
  "properties": {
    "crate_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "app_error_present": {
      "type": "boolean",
      "const": true
    },
    "vertical_slice": {
      "type": "object",
      "required": [
        "resource",
        "layers"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "crate_name": "payments-api",
  "modules": [
    "routes",
    "handlers",
    "services",
    "models",
    "db",
    "error"
  ],
  "app_error_present": true,
  "vertical_slice": {
    "resource": "users",
    "layers": [
      "model",
      "db",
      "service",
      "handler",
      "route",
      "tests"
    ]
  }
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "crate_name": "Payments API",
  "modules": [
    "src"
  ],
  "app_error_present": false
}
]]></code>
    <note>crate_name not kebab-case; modules too few; app_error_present false; vertical_slice missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-rust-backend.py">Validator script (--help, --self-test)</reference>
</text>
