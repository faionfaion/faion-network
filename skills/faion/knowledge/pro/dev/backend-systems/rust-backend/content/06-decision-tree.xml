<text id="06-decision-tree" title="Rust Backend (Axum) Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for rust-backend.</summary>
  <decision-tree>
    <root-question id="q-root">Is the service HTTP / Axum?</root-question>
    <branch when="service_kind == library_only"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="service_kind == grpc_only"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="service_kind == http_axum"><conclusion ref="vertical-slice-first"/></branch>
  </decision-tree>
</text>
