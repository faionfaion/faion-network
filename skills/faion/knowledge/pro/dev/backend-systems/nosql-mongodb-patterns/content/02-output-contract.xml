<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MongoDB Document Design Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for nosql-mongodb-patterns output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nosql-mongodb-patterns.json",
  "type": "object",
  "required": [
    "collections",
    "access_patterns",
    "indexes",
    "schema_version_field"
  ],
  "properties": {
    "collections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "embed_or_ref"
        ]
      },
      "minItems": 1
    },
    "access_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "indexes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "collection",
          "keys"
        ]
      },
      "minItems": 1
    },
    "schema_version_field": {
      "type": "string",
      "const": "schemaVersion"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "collections": [
    {
      "name": "users",
      "embed_or_ref": "embed_profile"
    }
  ],
  "access_patterns": [
    "find user by id with profile"
  ],
  "indexes": [
    {
      "collection": "users",
      "keys": {
        "_id": 1
      }
    }
  ],
  "schema_version_field": "schemaVersion"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "collections": [
    {
      "name": "users"
    }
  ],
  "schema_version_field": "version"
}
]]></code>
    <note>embed_or_ref missing per collection; access_patterns/indexes missing; schema_version_field not the canonical 'schemaVersion'.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-nosql-mongodb-patterns.py">Validator script (--help, --self-test)</reference>
</text>
