{
  "__faion_header__": {
    "purpose": "smoke skeleton for nosql-mongodb-patterns",
    "consumes": "spec from AGENTS.md",
    "produces": "artefact validated by scripts/validate-nosql-mongodb-patterns.py",
    "depends-on": "content/01-core-rules.xml",
    "token-budget-impact": "~200 tokens"
  },
  "collections": [
    {
      "name": "users",
      "embed_or_ref": "embed_profile"
    }
  ],
  "access_patterns": [
    "find user by id with profile"
  ],
  "indexes": [
    {
      "collection": "users",
      "keys": {
        "_id": 1
      }
    },
    {
      "collection": "users",
      "keys": {
        "email": 1
      },
      "unique": true
    }
  ],
  "schema_version_field": "schemaVersion"
}
