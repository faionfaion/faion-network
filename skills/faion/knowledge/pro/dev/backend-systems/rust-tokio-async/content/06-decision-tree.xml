<text id="06-decision-tree" title="rust-tokio-async Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-root">Is the workload CPU-heavy?</root-question>
      <branch when="is_cpu_heavy == true">
        <conclusion ref="r3" verdict="tokio::task::spawn_blocking + .await??"/>
      </branch>
      <branch when="is_cpu_heavy == false">
        <question id="q-next">n_known_at_compile_time == true?</question>
        <branch when="n_known_at_compile_time == true">
          <question id="q-next">n &lt;= 20?</question>
          <branch when="n &lt;= 20">
            <conclusion ref="r2" verdict="tokio::try_join!"/>
          </branch>
          <branch when="n &gt; 20">
            <conclusion ref="r4" verdict="buffer_unordered + Semaphore"/>
          </branch>
        </branch>
        <branch when="n_known_at_compile_time == false">
          <question id="q-next">tasks_added_dynamically == true?</question>
          <branch when="tasks_added_dynamically == true">
            <conclusion ref="r5" verdict="tokio::task::JoinSet"/>
          </branch>
          <branch when="tasks_added_dynamically == false">
            <conclusion ref="r4" verdict="buffer_unordered + Semaphore"/>
          </branch>
        </branch>
      </branch>
  </decision-tree>
</text>
