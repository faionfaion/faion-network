<methodology slug="rust-http-handlers">
  <metadata>
    <tier>pro</tier>
    <group>dev</group>
    <domain>backend-systems</domain>
    <summary>Axum handler pattern: typed DTOs, AppState in Arc, AppError with IntoResponse, extractor ordering (State first, body last).</summary>
    <tags>
      <tag>rust</tag>
      <tag>axum</tag>
      <tag>http-handlers</tag>
      <tag>web</tag>
    </tags>
    <category>handlers</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-26</created>
    <languages>
      <language>rust</language>
    </languages>
