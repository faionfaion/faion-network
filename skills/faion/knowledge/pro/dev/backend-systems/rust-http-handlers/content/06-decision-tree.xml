<text id="06-decision-tree" title="Rust HTTP Handlers (Axum) Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for rust-http-handlers.</summary>
  <decision-tree>
    <root-question id="q-root">Is the framework Axum or Actix-web?</root-question>
    <branch when="framework == tonic_grpc"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="framework == lambda"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="framework == axum_or_actix"><conclusion ref="typed-dto-required"/></branch>
    <branch when="untyped_handler_present == true"><conclusion ref="typed-dto-required"/></branch>
    <branch when="missing_tracing_instrument == true"><conclusion ref="tracing-instrument-required"/></branch>
  </decision-tree>
</text>
