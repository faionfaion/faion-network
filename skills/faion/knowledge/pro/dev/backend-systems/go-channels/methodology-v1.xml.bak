<methodology slug="go-channels">
  <metadata>
    <tier>pro</tier>
    <group>dev</group>
    <domain>backend-systems</domain>
    <summary>Channels are Go's primary mechanism for communication between goroutines. This methodology covers channel patterns, pipelines, and select operations for building concurrent data processing systems.</summary>
    <category>backend</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-29</created>
    <tags>
      <tag>go</tag>
      <tag>concurrency</tag>
