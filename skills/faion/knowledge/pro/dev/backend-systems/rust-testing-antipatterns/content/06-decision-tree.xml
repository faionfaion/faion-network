<text id="06-decision-tree" title="Rust Testing Anti-Patterns and Agent Gotchas Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for rust-testing-antipatterns.</summary>
  <decision-tree>
    <root-question id="q-root">Are test flakes timing- or state-related?</root-question>
    <branch when="test_suite_tiny == true"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="sleep_in_test_present == true"><conclusion ref="no-sleep-in-async-tests"/></branch>
    <branch when="utc_now_in_assertion == true"><conclusion ref="deterministic-now-via-injection"/></branch>
    <branch when="static_mut_present == true"><conclusion ref="no-static-mut-across-tests"/></branch>
    <branch when="hardcoded_port_present == true"><conclusion ref="no-hardcoded-ports-in-integration"/></branch>
  </decision-tree>
