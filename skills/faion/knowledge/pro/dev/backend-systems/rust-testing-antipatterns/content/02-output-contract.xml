<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rust Testing Anti-Patterns and Agent Gotchas Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for rust-testing-antipatterns output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-testing-antipatterns.json",
  "type": "object",
  "required": [
    "denies_active",
    "sleep_replaced_with_pause",
    "no_static_mut",
    "deterministic_now"
  ],
  "properties": {
    "denies_active": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "sleep_replaced_with_pause": {
      "type": "boolean",
      "const": true
    },
    "no_static_mut": {
      "type": "boolean",
      "const": true
    },
    "deterministic_now": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "denies_active": [
    "clippy::needless_return",
    "clippy::unwrap_used"
  ],
  "sleep_replaced_with_pause": true,
  "no_static_mut": true,
  "deterministic_now": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "denies_active": [],
  "sleep_replaced_with_pause": false
}
]]></code>
    <note>denies_active empty; sleep_replaced_with_pause false; no_static_mut + deterministic_now missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-rust-testing-antipatterns.py">Validator script (--help, --self-test)</reference>
</text>
