<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Go Project Structure Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for go-project-structure output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/go-project-structure.json",
  "type": "object",
  "required": [
    "module_path",
    "binaries",
    "internal_packages",
    "vertical_slices"
  ],
  "properties": {
    "module_path": {
      "type": "string",
      "pattern": "^[a-z0-9./_-]+$"
    },
    "binaries": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "internal_packages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 3
    },
    "vertical_slices": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "module_path": "github.com/acme/payments",
  "binaries": [
    "api",
    "worker"
  ],
  "internal_packages": [
    "handler",
    "service",
    "repository",
    "model",
    "config"
  ],
  "vertical_slices": [
    "users"
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "module_path": "",
  "binaries": [],
  "internal_packages": [
    "pkg"
  ]
}
]]></code>
    <note>module_path empty; binaries empty; internal_packages misuses pkg/ at top level; vertical_slices missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-go-project-structure.py">Validator script (--help, --self-test)</reference>
</text>
