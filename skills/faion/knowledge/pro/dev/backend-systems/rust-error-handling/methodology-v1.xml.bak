<methodology slug="rust-error-handling">
  <metadata>
    <tier>pro</tier>
    <group>dev</group>
    <domain>backend-systems</domain>
    <summary>Use thiserror for typed error enums, anyhow at binary boundaries. Never use Box&lt;dyn Error&gt; in public APIs. Map domain errors to HTTP responses via IntoResponse.</summary>
    <tags>
      <tag>rust</tag>
      <tag>error-handling</tag>
      <tag>result-type</tag>
      <tag>async</tag>
    </tags>
    <category>error-handling</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-26</created>
    <languages>
