    <root-question id="q-root">Library crate, binary crate, or both?</root-question>
    <branch when="scope == script_only"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="scope == library_crate"><conclusion ref="thiserror-at-crate-boundaries"/></branch>
    <branch when="scope == binary_crate"><conclusion ref="anyhow-at-binary-boundaries"/></branch>
    <branch when="scope == mixed"><conclusion ref="one-app-error-per-service"/></branch>
  </decision-tree>
