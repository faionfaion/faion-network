<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Rust Project Structure (Axum/Actix) Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply rust-project-structure end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="create-cargo-skeleton">
      <input>Crate name + deps</input>
      <action>cargo new + populate Cargo.toml.</action>
      <output>Skeleton</output>
    </step>
    <step n="2" name="add-canonical-modules">
      <input>Module list</input>
      <action>Create src/{config,error,routes,handlers,services,models,db,middleware}/.</action>
      <output>Modules</output>
    </step>
    <step n="3" name="write-main-rs">
      <input>AppState + router</input>
      <action>main.rs ≤80 lines; everything else delegated.</action>
      <output>main.rs lean</output>
    </step>
    <step n="4" name="install-scaffold-script">
      <input>Resource list</input>
      <action>new_module.sh creates a 5-file slice per entity.</action>
      <output>Scaffold ready</output>
    </step>
    <step n="5" name="validate">
      <input>All artefacts</input>
      <action>Run validate-rust-project-structure.py.</action>
      <output>Validated</output>
    </step>
  </section>
</text>
