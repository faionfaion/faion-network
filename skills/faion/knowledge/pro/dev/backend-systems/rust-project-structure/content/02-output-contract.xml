<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rust Project Structure (Axum/Actix) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for rust-project-structure output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-project-structure.json",
  "type": "object",
  "required": [
    "crate_name",
    "modules",
    "main_loc_under_100",
    "app_state_arc"
  ],
  "properties": {
    "crate_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "main_loc_under_100": {
      "type": "boolean",
      "const": true
    },
    "app_state_arc": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "crate_name": "orders-api",
  "modules": [
    "config",
    "error",
    "routes",
    "handlers",
    "services",
    "models",
    "db",
    "middleware"
  ],
  "main_loc_under_100": true,
  "app_state_arc": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "crate_name": "OrdersAPI",
  "modules": [
    "src"
  ]
}
]]></code>
    <note>crate_name not kebab-case; modules too few; main_loc_under_100 missing; app_state_arc missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-rust-project-structure.py">Validator script (--help, --self-test)</reference>
</text>
