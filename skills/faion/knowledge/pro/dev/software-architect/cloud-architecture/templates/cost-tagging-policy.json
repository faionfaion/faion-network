{
  "Comment": "AWS Tag Policy: enforce mandatory cost allocation tags on all resources.",
  "Version": "2012-10-17",
  "Statement": {
    "tags": {
      "Environment": {
        "tag_key": {
          "@@assign": "Environment"
        },
        "tag_value": {
          "@@assign": ["prod", "staging", "dev", "sandbox"]
        },
        "enforced_for": {
          "@@assign": [
            "ec2:instance",
            "ec2:volume",
            "rds:db",
            "rds:cluster",
            "s3:bucket",
            "elasticloadbalancing:loadbalancer",
            "lambda:function",
            "eks:cluster"
          ]
        }
      },
      "Team": {
        "tag_key": {
          "@@assign": "Team"
        },
        "tag_value": {
          "@@assign": ["platform", "data", "ml", "backend", "frontend", "security"]
        },
        "enforced_for": {
          "@@assign": [
            "ec2:instance",
            "ec2:volume",
            "rds:db",
            "rds:cluster",
            "s3:bucket",
            "lambda:function"
          ]
        }
      },
      "CostCenter": {
        "tag_key": {
          "@@assign": "CostCenter"
        },
        "enforced_for": {
          "@@assign": [
            "ec2:instance",
            "rds:db",
            "rds:cluster"
          ]
        }
      },
      "Owner": {
        "tag_key": {
          "@@assign": "Owner"
        },
        "enforced_for": {
          "@@assign": [
            "ec2:instance",
            "rds:db",
            "lambda:function"
          ]
        }
      },
      "Lifecycle": {
        "tag_key": {
          "@@assign": "Lifecycle"
        },
        "tag_value": {
          "@@assign": ["permanent", "temporary", "experimental"]
        },
        "enforced_for": {
          "@@assign": [
            "ec2:instance",
            "ec2:volume",
            "rds:db"
          ]
        }
      }
    }
  }
}
