{
  "__faion_header__": {
    "purpose": "config artefact skeleton for Service Mesh",
    "consumes": "see content/02-output-contract.xml inputs",
    "produces": "artefact conforming to content/02-output-contract.xml",
    "depends_on": "content/01-core-rules.xml",
    "token_budget_impact": "~200-800 tokens when loaded as context"
  },
  "mesh": "istio-ambient",
  "architecture": "sidecarless-ambient",
  "mtls": {
    "mode": "strict",
    "ca_kind": "vault-pki",
    "cert_ttl_seconds": 86400
  },
  "outlier_detection": {
    "enabled": true,
    "ejection_seconds": 30
  },
  "traffic_management": {
    "canary_steps": [
      1,
      10,
      50,
      100
    ],
    "rollback_strategy": "weight-revert"
  },
  "gitops": {
    "managed_by": "argo-cd"
  }
}
