<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Freelance Tax Cashflow Basics Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the checklist this methodology produces. Validator enforces the rule-set constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["checklist_id", "checks", "computed_at", "owner"],
  "properties": {
    "checklist_id": {"type": "string"},
    "checks": {
      "type": "object",
      "required": ["estimated_tax", "vat_reverse_charge", "entity_threshold", "separate_account", "runway_months"],
      "properties": {
        "estimated_tax": {"type": "object", "required": ["quarter", "paid", "amount_usd"], "properties": {"quarter": {"type": "string"}, "paid": {"type": "boolean"}, "amount_usd": {"type": "number"}}},
        "vat_reverse_charge": {"type": "object", "required": ["b2b_eu_invoices_count", "all_carry_notation"], "properties": {"b2b_eu_invoices_count": {"type": "integer", "minimum": 0}, "all_carry_notation": {"type": "boolean"}}},
        "entity_threshold": {"type": "object", "required": ["annual_revenue_usd", "entity"], "properties": {"annual_revenue_usd": {"type": "number"}, "entity": {"enum": ["sole_trader", "llc", "ltd", "other"]}}},
        "separate_account": {"type": "boolean"},
        "runway_months": {"type": "number"}
      }
    },
    "computed_at": {"type": "string", "format": "date"},
    "owner": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "checklist_id": "ftc-2026q2",
  "checks": {
    "estimated_tax": {"quarter": "2026-Q2", "paid": true, "amount_usd": 4200},
    "vat_reverse_charge": {"b2b_eu_invoices_count": 3, "all_carry_notation": true},
    "entity_threshold": {"annual_revenue_usd": 62000, "entity": "llc"},
    "separate_account": true,
    "runway_months": 7.5
  },
  "computed_at": "2026-05-23",
  "owner": "@ruslan"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"checklist_id": "x", "checks": {"estimated_tax": {"quarter": "Q2", "paid": false}, "separate_account": false, "runway_months": 1, "vat_reverse_charge": {}, "entity_threshold": {}}, "owner": "team", "computed_at": "2026-05-23"}
]]></code>
    <note>Violates one or more of the forbidden patterns listed below.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>estimated_tax.paid == false for current quarter past deadline (rule quarterly-estimated-tax).</item>
      <item>vat_reverse_charge.all_carry_notation == false with b2b_eu_invoices_count &gt; 0 (rule eu-reverse-charge-b2b).</item>
      <item>entity_threshold.annual_revenue_usd &gt; 50000 with entity == sole_trader and no doc decision (rule entity-threshold-decision).</item>
      <item>separate_account == false (rule separate-business-account).</item>
      <item>runway_months &lt; 6 with pending change (rule six-month-personal-runway).</item>
    </list>
  </section>

  <reference path="scripts/validate-freelance-tax-cashflow-basics.py">Validator script</reference>
</text>
