<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelance Tax Cashflow Basics Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-quarterly">Current quarter estimated tax paid?</root-question>

    <branch when="paid == false AND past_deadline == true">
      <conclusion ref="quarterly-estimated-tax" verdict="escalate to accountant; pay + accept penalty"/>
    </branch>

    <branch when="paid == true OR not past_deadline">
      <question id="q-vat">EU B2B invoices carry reverse-charge?</question>
      <branch when="all_carry == false">
        <conclusion ref="eu-reverse-charge-b2b" verdict="fix invoices + amend any sent without notation"/>
      </branch>
      <branch when="all_carry == true">
        <question id="q-entity">annual_revenue &gt; $50k AND sole_trader?</question>
        <branch when="threshold_crossed == true">
          <conclusion ref="entity-threshold-decision" verdict="schedule entity-conversion review with accountant"/>
        </branch>
        <branch when="threshold_crossed == false">
          <question id="q-runway">runway_months ≥6?</question>
          <branch when="runway &lt; 6">
            <conclusion ref="six-month-personal-runway" verdict="block strategic moves until runway ≥6"/>
          </branch>
          <branch when="runway &gt;= 6">
            <conclusion ref="separate-business-account" verdict="checklist green; proceed"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="green checklist">
    paid=true → all_carry=true → threshold_crossed=false → runway=7.5 → separate-business-account → green.
  </example>
</text>
