<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Founder Led Qualification Rubric Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the rubric this methodology produces. Validator enforces the rule-set constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["prospect_id", "checks", "verdict", "owner", "evaluated_at"],
  "properties": {
    "prospect_id": {"type": "string"},
    "checks": {
      "type": "object",
      "required": ["budget", "authority", "need", "timeline", "fit"],
      "properties": {
        "budget": {"type": "object", "required": ["yes", "evidence"], "properties": {"yes": {"type": "boolean"}, "evidence": {"type": "string"}}},
        "authority": {"type": "object", "required": ["yes", "evidence"], "properties": {"yes": {"type": "boolean"}, "evidence": {"type": "string"}}},
        "need": {"type": "object", "required": ["yes", "evidence"], "properties": {"yes": {"type": "boolean"}, "evidence": {"type": "string"}}},
        "timeline": {"type": "object", "required": ["yes", "evidence"], "properties": {"yes": {"type": "boolean"}, "evidence": {"type": "string"}}},
        "fit": {"type": "object", "required": ["yes", "evidence"], "properties": {"yes": {"type": "boolean"}, "evidence": {"type": "string"}}}
      }
    },
    "verdict": {"enum": ["qualified", "disqualified", "borderline"]},
    "owner": {"type": "string"},
    "evaluated_at": {"type": "string", "format": "date"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "prospect_id": "p-101",
  "checks": {
    "budget": {"yes": true, "evidence": "Discovery transcript: '$50k allocated for Q3'"},
    "authority": {"yes": true, "evidence": "Decision-maker @vp-growth confirmed in 2nd call"},
    "need": {"yes": true, "evidence": "Specific pain: conversion plateau at 4.2%"},
    "timeline": {"yes": false, "evidence": "Start date 5 months out — outside 90d window"},
    "fit": {"yes": true, "evidence": "B2B SaaS, 30 employees — matches ICP"}
  },
  "verdict": "borderline",
  "owner": "@ruslan",
  "evaluated_at": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"prospect_id": "p-1", "checks": {"budget": {"yes": true}}, "verdict": "looks promising"}
]]></code>
    <note>Violates one or more of the forbidden patterns listed below.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>Any check without `evidence` (rule evidence-per-check).</item>
      <item>Verdict outside {qualified, disqualified, borderline} (rule five-binary-checks).</item>
      <item>'maybe' or 'kind of' values for yes (rule five-binary-checks).</item>
      <item>Less than 5 checks (rule five-binary-checks).</item>
    </list>
  </section>

  <reference path="scripts/validate-founder-led-qualification-rubric.py">Validator script</reference>
</text>
