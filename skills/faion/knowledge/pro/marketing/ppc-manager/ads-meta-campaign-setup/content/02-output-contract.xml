<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Meta Ads Campaign Setup Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by ads-meta-campaign-setup. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ads-meta-campaign-setup.json",
  "type": "object",
  "required": [
    "objective",
    "budget_model",
    "ad_sets",
    "placements",
    "naming",
    "conversion_event"
  ],
  "properties": {
    "objective": {
      "enum": [
        "awareness",
        "traffic",
        "engagement",
        "leads",
        "app_promotion",
        "sales"
      ]
    },
    "budget_model": {
      "enum": [
        "cbo",
        "abo"
      ]
    },
    "ad_sets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "name",
          "audience",
          "daily_budget"
        ]
      }
    },
    "placements": {
      "enum": [
        "advantage_plus",
        "manual"
      ]
    },
    "naming": {
      "type": "string",
      "pattern": "^[a-z0-9]+_[a-z0-9-]+_[a-z0-9-]+_[a-z0-9-]+_[0-9]{8}$"
    },
    "conversion_event": {
      "type": "string",
      "minLength": 3
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "objective": "sales",
  "budget_model": "abo",
  "ad_sets": [
    {
      "name": "mofu_pro_director_video_20260523",
      "audience": "lal_top10_purchasers",
      "daily_budget": 80
    }
  ],
  "placements": "advantage_plus",
  "naming": "mofu_pro_director_video_20260523",
  "conversion_event": "Purchase"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "objective": "reach",
  "ad_sets": [
    {
      "name": "test1"
    },
    {
      "name": "test2"
    },
    {
      "name": "t3"
    },
    {
      "name": "t4"
    },
    {
      "name": "t5"
    },
    {
      "name": "t6"
    }
  ],
  "placements": "manual"
}
    ]]></code>
    <note>Wrong objective name ('reach' not in enum), too many ad sets (6 &gt; 5 cap), naming free-form, missing budget_model + conversion_event.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-over-5-adsets" severity="medium">
      <description>ad_sets array has more than 5 items.</description>
      <reason>Violates ad-set-cap-5 rule.</reason>
    </antipattern>
    <antipattern id="f-bad-naming" severity="medium">
      <description>naming does not match [stage]_[product]_[audience]_[creative]_[yyyymmdd].</description>
      <reason>Violates naming-convention rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-ads-meta-campaign-setup.py">Validator script enforcing this schema</reference>
</text>
