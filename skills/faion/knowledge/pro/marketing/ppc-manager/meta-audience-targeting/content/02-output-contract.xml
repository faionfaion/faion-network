<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Meta Audience Targeting (Granular) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by meta-audience-targeting. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/meta-audience-targeting.json",
  "type": "object",
  "required": [
    "interest_stacks",
    "behavioral_filters",
    "advantage_plus",
    "exclusion_matrix",
    "dynamic_creative"
  ],
  "properties": {
    "interest_stacks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "mode",
          "themes"
        ],
        "properties": {
          "mode": {
            "enum": [
              "or"
            ]
          },
          "themes": {
            "type": "array",
            "minItems": 2,
            "maxItems": 3
          }
        }
      }
    },
    "behavioral_filters": {
      "type": "array",
      "items": {
        "enum": [
          "engaged_shoppers",
          "returned_travelers",
          "frequent_travelers",
          "small_business_owners",
          "tech_early_adopters"
        ]
      }
    },
    "advantage_plus": {
      "type": "object",
      "required": [
        "enabled",
        "rationale"
      ]
    },
    "exclusion_matrix": {
      "type": "object",
      "required": [
        "tofu",
        "mofu",
        "bofu"
      ],
      "properties": {
        "tofu": {
          "type": "array",
          "minItems": 1
        },
        "mofu": {
          "type": "array",
          "minItems": 1
        },
        "bofu": {
          "type": "array",
          "minItems": 1
        }
      }
    },
    "dynamic_creative": {
      "type": "object",
      "required": [
        "enabled",
        "audience_breadth"
      ]
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "interest_stacks": [
    {
      "mode": "or",
      "themes": [
        "SaaS",
        "Developer Tools",
        "DevOps"
      ]
    }
  ],
  "behavioral_filters": [
    "tech_early_adopters",
    "engaged_shoppers"
  ],
  "advantage_plus": {
    "enabled": false,
    "rationale": "niche B2B product"
  },
  "exclusion_matrix": {
    "tofu": [
      "current_customers",
      "recent_converters"
    ],
    "mofu": [
      "purchasers_30d"
    ],
    "bofu": [
      "converters_7d"
    ]
  },
  "dynamic_creative": {
    "enabled": false,
    "audience_breadth": "manual_tier_2"
  }
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "interest_stacks": [
    {
      "mode": "and",
      "themes": [
        "A",
        "B",
        "C",
        "D",
        "E"
      ]
    }
  ],
  "behavioral_filters": [
    "page_visited_7d"
  ],
  "advantage_plus": {
    "enabled": true
  },
  "exclusion_matrix": {},
  "dynamic_creative": {
    "enabled": true,
    "audience_breadth": "narrow"
  }
}
    ]]></code>
    <note>AND mode + 5 themes; volatile filter; missing exclusion_matrix; dynamic_creative on narrow audience.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-and-stack" severity="medium">
      <description>interest_stacks[*].mode == 'and'.</description>
      <reason>Violates interest-stacks-broad rule.</reason>
    </antipattern>
    <antipattern id="f-no-exclusion-matrix" severity="medium">
      <description>exclusion_matrix missing any of tofu / mofu / bofu.</description>
      <reason>Violates exclusion-matrix-per-stage rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-meta-audience-targeting.py">Validator script enforcing this schema</reference>
</text>
