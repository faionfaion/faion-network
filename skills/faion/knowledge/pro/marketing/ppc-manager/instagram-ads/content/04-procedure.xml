<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Instagram Ads Playbook Procedure" version="1.1.0" est_tokens="950" depth="essential">
  <summary>5-step procedure to apply this methodology end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="verify-audience-fit">
      <input>ICP</input>
      <action>Confirm B2C / lifestyle / DTC.</action>
      <output>Audience-fit verdict.</output>
      <decision-gate>If B2B Director+, route to LinkedIn.</decision-gate>
    </step>
    <step n="2" name="allocate-placements">
      <input>Budget</input>
      <action>Reels ≥60% + Stories + Feed.</action>
      <output>Placement %.</output>
    </step>
    <step n="3" name="pick-creative-strategy">
      <input>Funnel stage + content inventory</input>
      <action>Cold = UGC/creator; retarget = brand-polished allowed.</action>
      <output>Creative strategy.</output>
    </step>
    <step n="4" name="set-frequency-caps">
      <input>Funnel stage</input>
      <action>Cold ≤3/wk; retarget ≤5/wk.</action>
      <output>Frequency caps.</output>
    </step>
    <step n="5" name="wire-shopping-tags">
      <input>Product feed (ecom)</input>
      <action>Enable Shopping tags per product ad.</action>
      <output>Shopping tags state.</output>
    </step>
  </section>
</text>
