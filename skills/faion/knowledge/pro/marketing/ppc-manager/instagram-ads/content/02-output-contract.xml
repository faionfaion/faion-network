<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Instagram Ads Playbook Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by instagram-ads. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/instagram-ads.json",
  "type": "object",
  "required": [
    "placements",
    "creative_strategy",
    "frequency_caps",
    "shopping_tags"
  ],
  "properties": {
    "placements": {
      "type": "object",
      "required": [
        "reels_pct",
        "stories_pct",
        "feed_pct"
      ],
      "properties": {
        "reels_pct": {
          "type": "integer",
          "minimum": 60,
          "maximum": 100
        }
      }
    },
    "creative_strategy": {
      "type": "object",
      "required": [
        "primary_format",
        "cold_content_type"
      ],
      "properties": {
        "primary_format": {
          "enum": [
            "9:16",
            "4:5",
            "1:1"
          ]
        },
        "cold_content_type": {
          "enum": [
            "ugc",
            "creator",
            "polished_brand"
          ]
        }
      }
    },
    "frequency_caps": {
      "type": "object",
      "required": [
        "cold_per_week",
        "retarget_per_week"
      ],
      "properties": {
        "cold_per_week": {
          "type": "integer",
          "maximum": 3
        },
        "retarget_per_week": {
          "type": "integer",
          "maximum": 5
        }
      }
    },
    "shopping_tags": {
      "type": "object",
      "required": [
        "enabled"
      ]
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "placements": {
    "reels_pct": 60,
    "stories_pct": 20,
    "feed_pct": 20
  },
  "creative_strategy": {
    "primary_format": "9:16",
    "cold_content_type": "ugc"
  },
  "frequency_caps": {
    "cold_per_week": 3,
    "retarget_per_week": 5
  },
  "shopping_tags": {
    "enabled": true
  }
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "placements": {
    "reels_pct": 10,
    "feed_pct": 90,
    "stories_pct": 0
  },
  "creative_strategy": {
    "primary_format": "1:1",
    "cold_content_type": "polished_brand"
  },
  "frequency_caps": {
    "cold_per_week": 10,
    "retarget_per_week": 20
  },
  "shopping_tags": {}
}
    ]]></code>
    <note>Reels share below 60 floor; primary format 1:1 (forfeits Reels); polished_brand on cold; frequency caps too high; missing shopping_tags.enabled.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-reels-under-60" severity="medium">
      <description>placements.reels_pct &lt; 60.</description>
      <reason>Violates reels-first rule.</reason>
    </antipattern>
    <antipattern id="f-polished-cold" severity="medium">
      <description>creative_strategy.cold_content_type == 'polished_brand'.</description>
      <reason>Violates ugc-or-creator-cold rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-instagram-ads.py">Validator script enforcing this schema</reference>
</text>
