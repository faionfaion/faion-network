<text id="05-examples" title="Retargeting / Remarketing Worked Example" version="1.1.0" est_tokens="800" depth="medium">
  <summary>One end-to-end worked example showing the methodology applied to a realistic scenario, including the produced artefact.</summary>
  <example type="good">
    <description>Faion checkout-recovery: 5-tier ladder with 25% of $20k/mo spend. Cart abandoners 7d gets urgency creative + 7/wk cap.</description>
    <code lang="json"><![CDATA[
{
  "segments": [
    {
      "name": "visitors_30d",
      "intent_depth": 1,
      "frequency_cap_wk": 3,
      "message_stage": "reminder"
    },
    {
      "name": "blog_readers_30d",
      "intent_depth": 2,
      "frequency_cap_wk": 4,
      "message_stage": "educate"
    },
    {
      "name": "product_viewers_30d",
      "intent_depth": 3,
      "frequency_cap_wk": 5,
      "message_stage": "benefits"
    },
    {
      "name": "pricing_viewers_14d",
      "intent_depth": 4,
      "frequency_cap_wk": 6,
      "message_stage": "social_proof"
    },
    {
      "name": "cart_abandoners_7d",
      "intent_depth": 5,
      "frequency_cap_wk": 7,
      "message_stage": "urgency"
    }
  ],
  "spend_share_pct": 25,
  "exclusions": [
    "purchasers_90d",
    "subscribers"
  ]
}
    ]]></code>
    <note>Five-tier ladder, per-stage caps, 25% spend share, exclusions seeded.</note>
  </example>
</text>
