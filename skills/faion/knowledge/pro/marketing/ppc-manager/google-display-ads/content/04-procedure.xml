<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Google Display Network Strategy Procedure" version="1.1.0" est_tokens="950" depth="essential">
  <summary>5-step procedure to apply this methodology end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="qualify-campaign">
      <input>Goal + budget</input>
      <action>Confirm awareness / upper-funnel goal + budget ≥ $1k/mo.</action>
      <output>Qualified.</output>
      <decision-gate>If goal is direct-response only, route to Search/Shopping.</decision-gate>
    </step>
    <step n="2" name="layer-audiences">
      <input>ICP + remarketing lists</input>
      <action>Stack 3+ audience tiers.</action>
      <output>Audience set.</output>
    </step>
    <step n="3" name="apply-exclusions">
      <input>Standard list</input>
      <action>Exclude mobile apps + low-quality sites.</action>
      <output>Exclusion config.</output>
    </step>
    <step n="4" name="assemble-creative-set">
      <input>Brand library</input>
      <action>Responsive + native + image (≥3 sizes).</action>
      <output>Creative set.</output>
    </step>
    <step n="5" name="set-frequency-and-kpi">
      <input>KPI targets</input>
      <action>5/day, 15/week cap; track CPA ceiling + CPM floor.</action>
      <output>Final spec.</output>
    </step>
  </section>
</text>
