<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Google Display Network Strategy Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by google-display-ads. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/google-display-ads.json",
  "type": "object",
  "required": [
    "audiences",
    "placement_exclusions",
    "creative_set",
    "frequency_cap",
    "kpi"
  ],
  "properties": {
    "audiences": {
      "type": "array",
      "minItems": 3,
      "items": {
        "enum": [
          "in_market",
          "affinity",
          "custom_intent",
          "remarketing",
          "similar"
        ]
      }
    },
    "placement_exclusions": {
      "type": "object",
      "required": [
        "mobile_apps_excluded",
        "low_quality_list_applied"
      ]
    },
    "creative_set": {
      "type": "array",
      "minItems": 3,
      "items": {
        "enum": [
          "responsive_display",
          "native",
          "image_300x250",
          "image_728x90",
          "image_320x50",
          "html5"
        ]
      }
    },
    "frequency_cap": {
      "type": "object",
      "required": [
        "per_day",
        "per_week"
      ],
      "properties": {
        "per_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "per_week": {
          "type": "integer",
          "minimum": 5,
          "maximum": 30
        }
      }
    },
    "kpi": {
      "type": "object",
      "required": [
        "cpa_ceiling",
        "cpm_floor"
      ]
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "audiences": [
    "in_market",
    "affinity",
    "remarketing"
  ],
  "placement_exclusions": {
    "mobile_apps_excluded": true,
    "low_quality_list_applied": true
  },
  "creative_set": [
    "responsive_display",
    "native",
    "image_300x250",
    "image_728x90"
  ],
  "frequency_cap": {
    "per_day": 5,
    "per_week": 15
  },
  "kpi": {
    "cpa_ceiling": 50,
    "cpm_floor": 4
  }
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "audiences": [
    "in_market"
  ],
  "placement_exclusions": {
    "mobile_apps_excluded": false,
    "low_quality_list_applied": false
  },
  "creative_set": [
    "responsive_display"
  ],
  "frequency_cap": {
    "per_day": 50
  },
  "kpi": {}
}
    ]]></code>
    <note>Single audience; no exclusions; only 1 creative; frequency cap too high; missing kpi fields.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-single-audience" severity="medium">
      <description>audiences length &lt; 3.</description>
      <reason>Violates audience-layering-4 rule.</reason>
    </antipattern>
    <antipattern id="f-no-exclusions" severity="medium">
      <description>mobile_apps_excluded != true OR low_quality_list_applied != true.</description>
      <reason>Violates placement-exclusions rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-google-display-ads.py">Validator script enforcing this schema</reference>
</text>
