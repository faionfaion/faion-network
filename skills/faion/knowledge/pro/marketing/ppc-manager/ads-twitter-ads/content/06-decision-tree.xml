<text id="06-decision-tree" title="X / Twitter Ads Strategy Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree on observable signals. Every leaf <conclusion ref="..."/> points to a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="q-root">Is vertical B2B/tech/crypto/media AND brand-safety list available?</root-question>
    <branch when="any precondition false">
      <conclusion ref="x-audience-fit" verdict="skip-this-methodology; defer until preconditions met"/>
    </branch>
    <branch when="vertical_match AND safety_list_ready">
      <question id="q-source">Is follower-LAL source ≥1000 available?</question>
      <branch when="answer == yes">
        <conclusion ref="follower-lal-or-keyword" verdict="run follower-LAL targeting"/>
      </branch>
      <branch when="answer == no">
        <conclusion ref="follower-lal-or-keyword" verdict="run keyword / conversation targeting"/>
      </branch>
    </branch>
  </decision-tree>
  <example trace="saas-tech-x">
    vertical=B2B SaaS, safety list ready, LAL source 3.5k → follower-LAL targeting.
  </example>
</text>
