<text id="05-examples" title="Google Ads Reporting Dashboards Worked Example" version="1.1.0" est_tokens="800" depth="medium">
  <summary>One end-to-end worked example showing the methodology applied to a realistic scenario, including the produced artefact.</summary>
  <example type="good">
    <description>Faion SaaS dashboard: 12-column preset, 3 views, 4 alerts, 5 segments. Q2 weekly report flags CPA breach on mobile + negative-sweep action queue.</description>
    <code lang="json"><![CDATA[
{
  "columns": [
    "Impressions",
    "Clicks",
    "CTR",
    "Avg CPC",
    "Cost",
    "Conversions",
    "Conv rate",
    "CPA",
    "Conv value",
    "ROAS",
    "Impression share",
    "Quality Score"
  ],
  "views": [
    "operator_weekly",
    "executive_monthly",
    "stakeholder_summary"
  ],
  "alerts": [
    {
      "metric": "CPA",
      "operator": ">",
      "threshold": "target +20%"
    },
    {
      "metric": "IS",
      "operator": "<",
      "threshold": "70%"
    },
    {
      "metric": "conv_rate",
      "operator": "<",
      "threshold": "target -15%"
    },
    {
      "metric": "daily_spend",
      "operator": ">",
      "threshold": "forecast +25%"
    }
  ],
  "segments": [
    "device",
    "network",
    "location",
    "time",
    "audience"
  ],
  "action_queue": [
    {
      "priority": 1,
      "lever": "mobile_bid_-15pct",
      "expected_impact": "CPA -10%",
      "owner": "ops"
    },
    {
      "priority": 2,
      "lever": "negative_sweep",
      "expected_impact": "CPA -8%",
      "owner": "ops"
    }
  ]
}
    ]]></code>
    <note>All five rules satisfied; alerts wired; actions ranked and owned.</note>
  </example>
</text>
