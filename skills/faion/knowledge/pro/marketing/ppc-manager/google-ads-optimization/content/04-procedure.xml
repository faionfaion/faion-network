<text id="04-procedure" title="Google Ads Optimization Cycle Procedure" version="1.1.0" est_tokens="950" depth="essential">
  <summary>5-step procedure to apply this methodology end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="audit-history">
      <input>Conversion history + last change log</input>
      <action>Confirm ≥30 days history AND ≥14 days since last learning-phase reset.</action>
      <output>History-OK.</output>
      <decision-gate>If history insufficient, STOP.</decision-gate>
    </step>
    <step n="2" name="pick-bidding-strategy">
      <input>Monthly conv volume</input>
      <action>&lt;30 → manual CPC; 30-100 → maximize-conversions; ≥100 → target-CPA / target-ROAS.</action>
      <output>Strategy.</output>
    </step>
    <step n="3" name="schedule-weekly-actions">
      <input>Weekly cadence</input>
      <action>Negative-keyword sweep + QS-&lt;5 remediation queue.</action>
      <output>Weekly action list.</output>
    </step>
    <step n="4" name="plan-monthly-rebalance">
      <input>Campaign ROAS quartiles</input>
      <action>Top quartile +20%, mid hold, bottom -20% or pause.</action>
      <output>Monthly action list.</output>
    </step>
    <step n="5" name="log-every-change">
      <input>Every change</input>
      <action>Append timestamp + change + rationale + owner to change-log.</action>
      <output>Updated change log.</output>
    </step>
  </section>
</text>
