<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Google Ads Optimization Cycle Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by google-ads-optimization. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/google-ads-optimization.json",
  "type": "object",
  "required": [
    "bidding_strategy",
    "weekly_actions",
    "monthly_actions",
    "change_log"
  ],
  "properties": {
    "bidding_strategy": {
      "enum": [
        "manual_cpc",
        "maximize_conversions",
        "target_cpa",
        "target_roas",
        "maximize_conversion_value"
      ]
    },
    "weekly_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lever",
          "trigger",
          "owner"
        ]
      }
    },
    "monthly_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lever",
          "trigger",
          "owner"
        ]
      }
    },
    "change_log": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "timestamp",
          "change",
          "rationale",
          "owner"
        ]
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "bidding_strategy": "target_cpa",
  "weekly_actions": [
    {
      "lever": "negative_sweep",
      "trigger": "search_term_cost_gt_5",
      "owner": "ops"
    }
  ],
  "monthly_actions": [
    {
      "lever": "budget_rebalance_quartile",
      "trigger": "roas_quartile_delta_gt_20pct",
      "owner": "ops"
    }
  ],
  "change_log": [
    {
      "timestamp": "2026-05-23T10:00Z",
      "change": "negative_added: 'free crack'",
      "rationale": "$30 wasted last 7d",
      "owner": "ops"
    }
  ]
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "bidding_strategy": "target_cpa",
  "weekly_actions": [],
  "monthly_actions": [],
  "change_log": []
}
    ]]></code>
    <note>Empty weekly/monthly action arrays violate minItems=1.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-empty-weekly" severity="medium">
      <description>weekly_actions array empty.</description>
      <reason>Violates weekly-negative-sweep rule.</reason>
    </antipattern>
    <antipattern id="f-no-change-log" severity="medium">
      <description>change_log array missing.</description>
      <reason>Violates change-log rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-google-ads-optimization.py">Validator script enforcing this schema</reference>
</text>
