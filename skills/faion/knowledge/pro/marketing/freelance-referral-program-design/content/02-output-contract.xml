<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Freelance Referral Program Design Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the spec this methodology produces. Validator enforces the rule-set constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["program_id", "incentive", "attribution_window_days", "referrers", "partners", "testimonial_framing", "owner"],
  "properties": {
    "program_id": {"type": "string"},
    "incentive": {"type": "object", "required": ["type", "amount_usd"], "properties": {"type": {"enum": ["flat_cash", "credit"]}, "amount_usd": {"type": "number", "minimum": 0}}},
    "attribution_window_days": {"type": "integer", "minimum": 1, "maximum": 90},
    "referrers": {"type": "array", "items": {"type": "object", "required": ["handle", "written_terms_date"], "properties": {"handle": {"type": "string"}, "written_terms_date": {"type": "string", "format": "date"}}}},
    "partners": {"type": "array", "items": {"type": "object", "required": ["handle", "swap_opt_in_date"], "properties": {"handle": {"type": "string"}, "swap_opt_in_date": {"type": "string", "format": "date"}}}},
    "testimonial_framing": {"type": "object", "required": ["template", "approved_by_customers"], "properties": {"template": {"type": "string"}, "approved_by_customers": {"type": "array", "items": {"type": "string"}}}},
    "owner": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "program_id": "frp-2026q2",
  "incentive": {"type": "flat_cash", "amount_usd": 500},
  "attribution_window_days": 90,
  "referrers": [{"handle": "@past-client-acme", "written_terms_date": "2026-05-10"}],
  "partners": [{"handle": "@peer-marina", "swap_opt_in_date": "2026-05-12"}],
  "testimonial_framing": {"template": "Acme used <NICHE> to ship in 2 weeks vs 3 months estimated.", "approved_by_customers": ["Acme"]},
  "owner": "@ruslan"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"program_id": "x", "incentive": {"type": "percent", "amount_usd": 10}, "attribution_window_days": 365, "referrers": [{"handle": "@x"}], "owner": "team", "partners": [{"handle": "@y"}], "testimonial_framing": {}}
]]></code>
    <note>Violates one or more of the forbidden patterns listed below.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>incentive.type != 'flat_cash' / 'credit' (rule flat-incentive-not-percent).</item>
      <item>Any referrer without written_terms_date (rule written-incentive-per-referrer).</item>
      <item>attribution_window_days &gt; 90 (rule attribution-window-90-days).</item>
      <item>Any partner without swap_opt_in_date (rule partner-swap-opted-in).</item>
      <item>testimonial_framing missing template / approved_by_customers (rule nda-safe-testimonial-framing).</item>
    </list>
  </section>

  <reference path="scripts/validate-freelance-referral-program-design.py">Validator script</reference>
</text>
