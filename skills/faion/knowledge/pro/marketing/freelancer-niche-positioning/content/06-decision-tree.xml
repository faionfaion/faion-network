<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelancer Niche Positioning Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-format">Format 'I do X for Y so they Z' filled with measurable Z?</root-question>

    <branch when="format == false">
      <conclusion ref="format-x-y-z" verdict="STOP — redraft to fill X / Y / Z explicitly"/>
    </branch>

    <branch when="format == true">
      <question id="q-z-numeric">Is Z measurable (unit + direction + magnitude)?</question>
      <branch when="numeric == false">
        <conclusion ref="numeric-outcome" verdict="STOP — rewrite Z with unit + direction"/>
      </branch>
      <branch when="numeric == true">
        <question id="q-validations">All 3 validation signals passed?</question>
        <branch when="signals_passed &lt; 3">
          <conclusion ref="search-find-test" verdict="positioning not yet live; complete missing signal(s) within 30 days"/>
        </branch>
        <branch when="signals_passed == 3">
          <conclusion ref="buyer-paraphrase-test" verdict="positioning validated; monthly re-check scheduled"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="fully validated positioning">
    format=true → numeric=true → signals=3 → buyer-paraphrase-test → validated.
  </example>
</text>
