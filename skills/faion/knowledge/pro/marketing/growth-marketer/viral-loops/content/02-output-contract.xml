<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Viral Loops and Types Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/viral-loops.json",
  "type": "object",
  "required": [
    "primary_archetype",
    "secondary_archetype",
    "k_factor_target",
    "k_factor_actual",
    "retention_d30",
    "incentive_cost_pct_cac",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "primary_archetype": "inherent",
  "secondary_archetype": "content",
  "k_factor_target": 0.45,
  "k_factor_actual": 0.38,
  "retention_d30": 0.42,
  "incentive_cost_pct_cac": 0.3,
  "owner": {
    "name": "Olha Riznyk",
    "role": "head of growth"
  },
  "produced_at": "2026-05-23T11:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "primary_archetype": [
    "wom",
    "incentivized"
  ],
  "k_factor_target": 2.0
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-viral-loops.py">Validator script</reference>
</text>
