<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Statistical Significance: Application Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/statistics-application.json",
  "type": "object",
  "required": [
    "test_id",
    "n1",
    "x1",
    "n2",
    "x2",
    "mde_declared",
    "sample_size_pre_committed",
    "p_value",
    "confidence_interval",
    "verdict",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_id": "headline-2026-04",
  "n1": 4200,
  "x1": 412,
  "n2": 4180,
  "x2": 489,
  "mde_declared": 0.015,
  "sample_size_pre_committed": true,
  "p_value": 0.018,
  "confidence_interval": [
    0.004,
    0.034
  ],
  "verdict": "significant_ship",
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "test_id": "x",
  "verdict": "looks good"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-statistics-application.py">Validator script</reference>
</text>
