<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Privacy-Compliant Analytics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/privacy-compliance.json",
  "type": "object",
  "required": [
    "cmp",
    "default_state",
    "consent_mode_version",
    "gpc_handler",
    "ip_policy",
    "tag_audit",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "cmp": "cookiebot",
  "default_state": "deny",
  "consent_mode_version": "v2",
  "gpc_handler": {
    "detected_in": "server_middleware",
    "treats_as": "ccpa_opt_out"
  },
  "ip_policy": "anonymized_pre_storage",
  "tag_audit": [
    {
      "tag": "ga4",
      "category": "analytics",
      "fires_when": "analytics_storage=granted"
    }
  ],
  "produced_at": "2026-05-23T11:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "default_state": "allow",
  "consent_mode_version": "v1"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-privacy-compliance.py">Validator script</reference>
</text>
