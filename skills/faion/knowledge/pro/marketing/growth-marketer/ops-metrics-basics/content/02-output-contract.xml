<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Ops Metrics Basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-metrics-basics.json",
  "type": "object",
  "required": [
    "metrics",
    "cadence",
    "owners_per_metric",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "metrics": [
    {
      "id": "mrr",
      "formula_ref": "sql/mrr.sql",
      "target": 50000,
      "alert_below": 45000,
      "owner": "Olha Riznyk"
    }
  ],
  "cadence": {
    "daily": [
      "signups",
      "errors"
    ],
    "weekly": [
      "mrr",
      "churn",
      "arr_growth"
    ],
    "monthly": [
      "cohort_retention",
      "ltv_cac"
    ]
  },
  "owners_per_metric": {
    "mrr": "Olha Riznyk",
    "churn": "Tetiana Lytvyn"
  },
  "produced_at": "2026-05-23T09:30:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "metrics": [],
  "cadence": "weekly"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-ops-metrics-basics.py">Validator script</reference>
</text>
