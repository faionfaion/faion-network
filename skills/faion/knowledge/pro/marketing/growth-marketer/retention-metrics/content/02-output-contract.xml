<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Retention Metrics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/retention-metrics.json",
  "type": "object",
  "required": [
    "metrics",
    "sql_refs",
    "cadence",
    "segments",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "metrics": [
    "d1_retention",
    "d7_retention",
    "d30_retention",
    "dau_mau",
    "monthly_churn",
    "churn_risk_score"
  ],
  "sql_refs": {
    "d1_retention": "sql/d1_retention.sql",
    "monthly_churn": "sql/monthly_churn.sql"
  },
  "cadence": {
    "default": "monthly",
    "deep_dive": "quarterly"
  },
  "segments": [
    "plan_tier",
    "acquisition_cohort"
  ],
  "owner": {
    "name": "Tetiana Lytvyn",
    "role": "head of product"
  },
  "produced_at": "2026-05-23T09:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "metrics": [
    "dau_only"
  ],
  "cadence": "quarterly"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-retention-metrics.py">Validator script</reference>
</text>
