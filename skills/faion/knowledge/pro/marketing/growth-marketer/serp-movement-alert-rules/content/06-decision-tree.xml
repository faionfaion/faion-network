<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="SERP Movement Alert Rules Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="do not run this methodology; document skip rationale"/>
    </branch>

    <branch when="preconditions == true">
      <question id="q-readiness">Are all readiness gates green?</question>
      <branch when="baseline_data_sufficient == false">
        <conclusion ref="skip-this-methodology" verdict="wait for &gt;= 90 days history"/>
      </branch>
      <branch when="impressions_alert_set == false">
        <conclusion ref="impressions-wow-30pct-alert" verdict="configure 30% WoW impressions drop alert"/>
      </branch>
      <branch when="position_alert_set == false">
        <conclusion ref="position-delta-3-rank-alert" verdict="configure 3-rank degradation alert"/>
      </branch>
      <branch when="ai_overview_monitor == false">
        <conclusion ref="ai-overview-appearance-alert" verdict="subscribe to AI Overview SERP-feature flag"/>
      </branch>
      <branch when="ctr_alert_set == false">
        <conclusion ref="ctr-collapse-50pct-alert" verdict="configure CTR collapse alert (stable-impressions filter)"/>
      </branch>
      <branch when="sla_and_owners_set == false">
        <conclusion ref="48-hour-review-sla" verdict="assign owners + 48h SLA per alert category"/>
      </branch>
      <branch when="all_checks_pass == true">
        <conclusion ref="48-hour-review-sla" verdict="ship alert config; monthly noise audit"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="happy-path">preconditions=true → readiness gates evaluated → all_checks_pass==true → conclusion ref=48-hour-review-sla</example>
</text>
