<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Retention Strategies Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the playbook-step artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/retention-strategies.json",
  "type": "object",
  "required": [
    "primary_loop",
    "secondary_loop",
    "mechanics",
    "re_engagement_windows",
    "ab_test_status",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "primary_loop": "content_publishing",
  "secondary_loop": "workflow_habit",
  "mechanics": [
    {
      "name": "streaks",
      "schedule": "variable",
      "ab_status": "validated_2026-Q1"
    }
  ],
  "re_engagement_windows": [
    30,
    60,
    90
  ],
  "ab_test_status": "passed",
  "owner": {
    "name": "Olha Riznyk",
    "role": "head of product"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "primary_loop": [
    "content",
    "viral",
    "social",
    "workflow"
  ],
  "ab_test_status": "skipped"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-retention-strategies.py">Validator script</reference>
</text>
