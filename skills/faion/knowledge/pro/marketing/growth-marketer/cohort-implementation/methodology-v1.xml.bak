<methodology slug="cohort-implementation">
  <metadata>
    <tier>pro</tier>
    <group>marketing</group>
    <domain>growth-marketer</domain>
    <summary>Cohort implementation moves cohort analysis from ad-hoc analytics-tool reports to warehouse-native dbt models that refresh daily, survive schema changes, and feed BI dashboards.</summary>
    <tags>
      <tag>cohort-analysis</tag>
      <tag>retention</tag>
      <tag>dbt</tag>
      <tag>warehouse</tag>
      <tag>analytics</tag>
    </tags>
