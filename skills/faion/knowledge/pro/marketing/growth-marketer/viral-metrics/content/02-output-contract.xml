<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Viral Metrics and K-factor Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/viral-metrics.json",
  "type": "object",
  "required": [
    "metrics",
    "sql_refs",
    "cadence",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "metrics": [
    "invites_per_user_i",
    "invite_conversion_c",
    "k_factor",
    "viral_cycle_time_days",
    "k_effective"
  ],
  "sql_refs": {
    "k_factor": "sql/k_factor.sql",
    "k_effective": "sql/k_effective.sql"
  },
  "cadence": {
    "default": "weekly",
    "deep_dive": "monthly"
  },
  "owner": {
    "name": "Olha Riznyk",
    "role": "head of growth"
  },
  "produced_at": "2026-05-23T12:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "metrics": [
    "k_total"
  ],
  "cadence": "quarterly"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-viral-metrics.py">Validator script</reference>
</text>
