<text id="06-decision-tree" title="A/B Testing Basics Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-pre-reg">Pre-registration exists with hypothesis + primary + MDE + sample size + close date?</root-question>

    <branch when="pre_reg == false">
      <conclusion ref="pre-registration-required" verdict="STOP — write pre-reg before launch"/>
    </branch>

    <branch when="pre_reg == true">
      <question id="q-split">50/50 split OR justified deviation?</question>
      <branch when="split_ok == false">
        <conclusion ref="fifty-fifty-split-or-justify" verdict="default to 50/50 OR pin power-adjustment record"/>
      </branch>
      <branch when="split_ok == true">
        <question id="q-running">Test currently running?</question>
        <branch when="running == true">
          <conclusion ref="no-peeking" verdict="hold; no decision before closes_at + sample_size"/>
        </branch>
        <branch when="running == false">
          <question id="q-srm">SRM check passed at close?</question>
          <branch when="srm_pass == false">
            <conclusion ref="srm-check-on-close" verdict="invalidate; investigate assignment"/>
          </branch>
          <branch when="srm_pass == true">
            <conclusion ref="secondary-metrics-pre-registered" verdict="proceed to verdict; analyze only pre-registered metrics"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="valid pre-reg, closed cleanly">
    pre_reg=true → split_ok=true → running=false → srm_pass=true → analyze + verdict.
  </example>
</text>
