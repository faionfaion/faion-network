<text id="06-decision-tree" title="Viral Loop Optimization Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="do not run this methodology; document skip rationale"/>
    </branch>

    <branch when="preconditions == true">
      <question id="q-readiness">Are all readiness gates green?</question>
      <branch when="baseline_stable == false">
        <conclusion ref="skip-this-methodology" verdict="wait for &gt;= 4 weeks stable baseline"/>
      </branch>
      <branch when="c_optimized_first == false">
        <conclusion ref="optimize-c-before-i" verdict="switch to c-side experiments first"/>
      </branch>
      <branch when="single_variable == false">
        <conclusion ref="one-variable-per-test" verdict="refactor test to single-variable"/>
      </branch>
      <branch when="k_eff_criterion == false">
        <conclusion ref="retention-adjusted-decision" verdict="use K_eff (not raw K) for ship gate"/>
      </branch>
      <branch when="share_at_win == false">
        <conclusion ref="share-moment-design-pattern" verdict="move share to user-win moment"/>
      </branch>
      <branch when="kill_unmoved == false">
        <conclusion ref="kill-experiments-no-lift-after-2-cycles" verdict="kill experiments unmoved after 2 cycle times"/>
      </branch>
      <branch when="all_checks_pass == true">
        <conclusion ref="kill-experiments-no-lift-after-2-cycles" verdict="run weekly experiment retrospective"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="happy-path">preconditions=true → readiness gates evaluated → all_checks_pass==true → conclusion ref=kill-experiments-no-lift-after-2-cycles</example>
</text>
