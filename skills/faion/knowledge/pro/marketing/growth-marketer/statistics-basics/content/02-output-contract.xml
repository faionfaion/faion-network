<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Statistical Significance: Basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the checklist artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/statistics-basics.json",
  "type": "object",
  "required": [
    "test_id",
    "alpha",
    "power",
    "mde",
    "baseline_rate",
    "sample_size_per_arm",
    "hypothesis",
    "peeking_policy",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_id": "cta-color-2026-04",
  "alpha": 0.05,
  "power": 0.8,
  "mde": 0.02,
  "baseline_rate": 0.085,
  "sample_size_per_arm": 7800,
  "hypothesis": {
    "h0": "p_control == p_treatment",
    "h1": "p_control != p_treatment",
    "sides": 2
  },
  "peeking_policy": "fixed_horizon_no_peek",
  "produced_at": "2026-05-23T09:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "test_id": "x",
  "alpha": 0.5,
  "hypothesis": "tbd"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-statistics-basics.py">Validator script</reference>
</text>
