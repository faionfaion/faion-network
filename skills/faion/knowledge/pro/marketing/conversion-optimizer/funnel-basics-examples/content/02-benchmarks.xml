<?xml version="1.0" encoding="UTF-8"?>
<text id="02-benchmarks" title="Funnel Conversion Benchmarks by Industry">
  <summary>Good vs. great conversion rate thresholds per step for SaaS, e-commerce, mobile apps, B2B lead gen, and email funnels.</summary>

  <section title="SaaS">
    <list>
      <item>Visitor to Signup: Good 2-5%, Great 5-10%</item>
      <item>Signup to Activated: Good 30-50%, Great 50-70%</item>
      <item>Activated to Paid: Good 3-5%, Great 5-10%</item>
      <item>Visitor to Paid (overall): Good 0.5-1%, Great 1-3%</item>
    </list>
  </section>

  <section title="E-commerce">
    <list>
      <item>Visitor to Cart: Good 3-8%, Great 8-15%</item>
      <item>Cart to Checkout: Good 40-60%, Great 60-80%</item>
      <item>Checkout to Purchase: Good 50-70%, Great 70-85%</item>
      <item>Visitor to Purchase (overall): Good 1-2%, Great 2-4%</item>
    </list>
  </section>

  <section title="Mobile Apps">
    <list>
      <item>Install to Open: Good 70-80%, Great 80-90%</item>
      <item>Open to Onboarding Complete: Good 40-60%, Great 60-80%</item>
      <item>Onboarding to Core Action: Good 25-40%, Great 40-60%</item>
      <item>Install to Core Action (overall): Good 20-30%, Great 30-50%</item>
    </list>
  </section>

  <section title="B2B Lead Generation">
    <list>
      <item>Visit to Lead Magnet Download: Good 5-10%, Great 10-20%</item>
      <item>Form View to Submit: Good 30-50%, Great 50-70%</item>
      <item>Lead to Qualified Lead: Good 20-30%, Great 30-50%</item>
      <item>Qualified to Demo: Good 30-40%, Great 40-60%</item>
      <item>Demo to Customer: Good 20-30%, Great 30-50%</item>
    </list>
  </section>

  <section title="Email Funnels">
    <list>
      <item>Delivered to Opened: Good 15-25%, Great 25-40%</item>
      <item>Opened to Clicked: Good 2-5%, Great 5-10%</item>
      <item>Clicked to Converted: Good 1-3%, Great 3-8%</item>
      <item>Delivered to Converted (overall): Good 0.1-0.5%, Great 0.5-2%</item>
    </list>
  </section>
</text>
