<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelance Rate Jump Tactics Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-case-studies">Do you have ≥3 published case studies in the new niche?</root-question>

    <branch when="case_studies &lt; 3">
      <conclusion ref="three-case-studies-required" verdict="STOP — produce more case studies before rate jump"/>
    </branch>

    <branch when="case_studies &gt;= 3">
      <question id="q-market">market_band researched with ≥3 sources?</question>
      <branch when="market_band == false">
        <conclusion ref="market-band-citation" verdict="STOP — research market band first"/>
      </branch>
      <branch when="market_band == true">
        <question id="q-notice">Notice to existing clients ≥60 days?</question>
        <branch when="notice &lt; 60">
          <conclusion ref="60-day-notice-existing-clients" verdict="STOP — extend notice to ≥60 days"/>
        </branch>
        <branch when="notice &gt;= 60">
          <conclusion ref="graduated-rollout" verdict="proceed; new leads at new rate immediately; WIP at old rate"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="all preconditions met">
    case_studies=3 → market_band=true → notice=60 → graduated-rollout → proceed.
  </example>
</text>
