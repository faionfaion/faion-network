<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Freelance Rate Jump Tactics Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the spec this methodology produces. Validator enforces the rule-set constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["jump_id", "niche", "current_rate", "target_rate", "market_band", "case_studies", "existing_client_notice", "rollout_plan", "owner"],
  "properties": {
    "jump_id": {"type": "string"},
    "niche": {"type": "string"},
    "current_rate": {"type": "number"},
    "target_rate": {"type": "number"},
    "market_band": {
      "type": "object",
      "required": ["median", "p75", "sources"],
      "properties": {
        "median": {"type": "number"},
        "p75": {"type": "number"},
        "sources": {"type": "array", "minItems": 3, "items": {"type": "string"}}
      }
    },
    "case_studies": {"type": "array", "minItems": 3, "items": {"type": "object", "required": ["customer", "outcome", "url"], "properties": {"customer": {"type": "string"}, "outcome": {"type": "string"}, "url": {"type": "string"}}}},
    "existing_client_notice": {
      "type": "object",
      "required": ["notice_days", "wip_billing"],
      "properties": {
        "notice_days": {"type": "integer", "minimum": 60},
        "wip_billing": {"enum": ["old-rate-until-complete"]}
      }
    },
    "rollout_plan": {"type": "object", "required": ["new_leads_at", "existing_clients_at"], "properties": {"new_leads_at": {"type": "string", "format": "date"}, "existing_clients_at": {"type": "string", "format": "date"}}},
    "owner": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "jump_id": "rj-2026q2-saas-onboarding",
  "niche": "B2B SaaS onboarding rebuild",
  "current_rate": 100,
  "target_rate": 150,
  "market_band": {"median": 140, "p75": 175, "sources": ["upwork-q1-2026", "codementor-rate-card", "peer-survey-2026"]},
  "case_studies": [
    {"customer": "Acme", "outcome": "+22% activation", "url": "https://example/acme"},
    {"customer": "Beta", "outcome": "-40% time-to-value", "url": "https://example/beta"},
    {"customer": "Gamma", "outcome": "+15 NPS", "url": "https://example/gamma"}
  ],
  "existing_client_notice": {"notice_days": 60, "wip_billing": "old-rate-until-complete"},
  "rollout_plan": {"new_leads_at": "2026-06-01", "existing_clients_at": "2026-08-01"},
  "owner": "@ruslan"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"jump_id": "rj-x", "current_rate": 100, "target_rate": 200, "case_studies": [], "owner": "team", "existing_client_notice": {"notice_days": 7}}
]]></code>
    <note>Violates one or more of the forbidden patterns listed below.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>case_studies length &lt; 3 (rule three-case-studies-required).</item>
      <item>market_band.sources &lt; 3 (rule market-band-citation).</item>
      <item>existing_client_notice.notice_days &lt; 60 (rule 60-day-notice-existing-clients).</item>
      <item>wip_billing != 'old-rate-until-complete' (rule no-retroactive-billing).</item>
    </list>
  </section>

  <reference path="scripts/validate-freelance-rate-jump-tactics.py">Validator script</reference>
</text>
