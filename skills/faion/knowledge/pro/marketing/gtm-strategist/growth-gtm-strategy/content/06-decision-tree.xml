<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Go-to-Market Strategy Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="do not run this methodology; document skip rationale"/>
    </branch>

    <branch when="preconditions == true">
      <question id="q-readiness">Are all readiness gates green?</question>
      <branch when="product_launched_or_ready == false">
        <conclusion ref="skip-this-methodology" verdict="first reach product readiness"/>
      </branch>
      <branch when="icp_single == false">
        <conclusion ref="one-icp-with-anti-icp" verdict="narrow to ONE ICP + explicit anti-ICP"/>
      </branch>
      <branch when="positioning_structured == false">
        <conclusion ref="forwhoisunlikewe-statement" verdict="rewrite via For/Who/Is/Unlike/We template"/>
      </branch>
      <branch when="channels_in_range == false">
        <conclusion ref="two-three-channels-only" verdict="cut to 2-3 primary channels"/>
      </branch>
      <branch when="motion_matches_acv == false">
        <conclusion ref="sales-motion-by-acv" verdict="align sales motion with ACV band"/>
      </branch>
      <branch when="assumptions_tagged == false">
        <conclusion ref="mark-unverified-assumption" verdict="tag every unverified claim as ASSUMPTION + schedule validation"/>
      </branch>
      <branch when="all_checks_pass == true">
        <conclusion ref="mark-unverified-assumption" verdict="execute phase 1; quarterly GTM review"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="happy-path">preconditions=true → readiness gates evaluated → all_checks_pass==true → conclusion ref=mark-unverified-assumption</example>
</text>
