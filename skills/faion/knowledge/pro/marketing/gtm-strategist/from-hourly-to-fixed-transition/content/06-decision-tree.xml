<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="From Hourly to Fixed-Price Transition Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="do not run this methodology; document skip rationale"/>
    </branch>

    <branch when="preconditions == true">
      <question id="q-readiness">Are all readiness gates green?</question>
      <branch when="cash_bridge_sufficient == false">
        <conclusion ref="cash-bridge-6-8-weeks" verdict="halt transition; build bridge first"/>
      </branch>
      <branch when="first_client_high_margin == false">
        <conclusion ref="highest-margin-first" verdict="reorder; start with highest-margin client"/>
      </branch>
      <branch when="overlap_two_three == false">
        <conclusion ref="two-three-client-overlap" verdict="maintain 2-3 hourly clients during pilot"/>
      </branch>
      <branch when="single_sku == false">
        <conclusion ref="one-productized-sku-only" verdict="drop second SKU; productize one only"/>
      </branch>
      <branch when="single_reprice_round == false">
        <conclusion ref="single-reprice-round" verdict="re-price all remaining clients in one week window"/>
      </branch>
      <branch when="all_checks_pass == true">
        <conclusion ref="single-reprice-round" verdict="execute phase 1 (audit); checkpoint at week 4"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="happy-path">preconditions=true → readiness gates evaluated → all_checks_pass==true → conclusion ref=single-reprice-round</example>
</text>
