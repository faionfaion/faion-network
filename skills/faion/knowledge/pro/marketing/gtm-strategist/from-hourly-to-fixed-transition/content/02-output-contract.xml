<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="From Hourly to Fixed-Price Transition Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/from-hourly-to-fixed-transition.json",
  "type": "object",
  "required": [
    "plan_id",
    "phases",
    "first_convert_client",
    "overlap_clients",
    "productized_sku",
    "reprice_window",
    "cash_bridge_weeks",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "plan_id": "transition-2026-Q2",
  "phases": [
    {
      "phase": "audit",
      "weeks": [
        1,
        4
      ]
    },
    {
      "phase": "pilot",
      "weeks": [
        5,
        8
      ]
    },
    {
      "phase": "convert",
      "weeks": [
        9,
        12
      ]
    }
  ],
  "first_convert_client": {
    "name": "Acme",
    "margin_pct": 1.2
  },
  "overlap_clients": [
    "Beta",
    "Gamma"
  ],
  "productized_sku": {
    "name": "30-day Audit Sprint",
    "appearances_in_past_engagements": 4
  },
  "reprice_window": {
    "start": "2026-08-01",
    "end": "2026-08-07"
  },
  "cash_bridge_weeks": 7,
  "owner": {
    "name": "Olha Riznyk",
    "role": "founder"
  },
  "produced_at": "2026-05-23T11:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "plan_id": "x",
  "cash_bridge_weeks": 2,
  "overlap_clients": []
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-from-hourly-to-fixed-transition.py">Validator script</reference>
</text>
