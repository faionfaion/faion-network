<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelance SaaS Billing Decision Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-predict">value_predictability?</root-question>

    <branch when="predict == low">
      <conclusion ref="four-signal-score" verdict="chosen=usage; customer pays for what they use"/>
    </branch>

    <branch when="predict == high">
      <question id="q-driver">primary_value_driver?</question>
      <branch when="driver == per_seat">
        <conclusion ref="four-signal-score" verdict="chosen=subscription; per-seat tier ladder"/>
      </branch>
      <branch when="driver == per_action">
        <conclusion ref="four-signal-score" verdict="chosen=usage; per-action with floor"/>
      </branch>
      <branch when="driver == per_outcome">
        <conclusion ref="four-signal-score" verdict="chosen=hybrid; outcome-tied platform fee + usage overage"/>
      </branch>
    </branch>

    <branch when="predict == medium">
      <question id="q-size">customer_size?</question>
      <branch when="size == enterprise">
        <conclusion ref="four-signal-score" verdict="chosen=hybrid; platform fee + usage"/>
      </branch>
      <branch when="size == smb OR size == midmarket">
        <conclusion ref="four-signal-score" verdict="chosen=subscription; tier ladder with seat caps"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="SMB SaaS with per-seat value">
    predict=high → driver=per_seat → four-signal-score → chosen=subscription.
  </example>
</text>
