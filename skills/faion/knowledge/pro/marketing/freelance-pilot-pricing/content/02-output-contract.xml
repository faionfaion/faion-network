<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Freelance Pilot Pricing Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the spec this methodology produces. Validator enforces the rule-set constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["pilot_id", "offering", "customer", "price", "cost_basis", "standard_price", "timebox_days", "case_study_consent", "transition_clause", "owner"],
  "properties": {
    "pilot_id": {"type": "string", "pattern": "^pp-[a-z0-9-]+$"},
    "offering": {"type": "string"},
    "customer": {"type": "string"},
    "price": {"type": "number", "minimum": 0},
    "cost_basis": {"type": "number", "minimum": 0},
    "standard_price": {"type": "number"},
    "timebox_days": {"type": "integer", "minimum": 1, "maximum": 14},
    "case_study_consent": {"type": "object", "required": ["logo", "metrics", "captured_at"], "properties": {"logo": {"type": "boolean"}, "metrics": {"type": "boolean"}, "captured_at": {"type": "string", "format": "date"}}},
    "transition_clause": {"type": "string", "minLength": 30},
    "owner": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pilot_id": "pp-acme-onboarding-2026q2",
  "offering": "2-week onboarding rebuild",
  "customer": "Acme Corp",
  "price": 3500,
  "cost_basis": 2800,
  "standard_price": 6000,
  "timebox_days": 14,
  "case_study_consent": {"logo": true, "metrics": true, "captured_at": "2026-05-20"},
  "transition_clause": "Continuation past 14-day timebox or renewal billed at standard $6000 rate.",
  "owner": "@ruslan"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"pilot_id": "pp-x", "price": 100, "cost_basis": 1000, "timebox_days": 30, "owner": "team"}
]]></code>
    <note>Violates one or more of the forbidden patterns listed below.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>price &lt; cost_basis (rule price-above-cost).</item>
      <item>timebox_days &gt; 14 (rule timebox-14-days).</item>
      <item>case_study_consent.captured_at missing (rule case-study-consent-written).</item>
      <item>transition_clause &lt; 30 chars or missing (rule transition-price-documented).</item>
    </list>
  </section>

  <reference path="scripts/validate-freelance-pilot-pricing.py">Validator script</reference>
</text>
