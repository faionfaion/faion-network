<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelance Pilot Pricing Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-count">Pilot count for this offering ≥ 5?</root-question>

    <branch when="count &gt;= 5">
      <conclusion ref="pilot-cap-5" verdict="STOP — transition to standard price"/>
    </branch>

    <branch when="count &lt; 5">
      <question id="q-cost">Pilot price ≥ cost basis?</question>
      <branch when="price &lt; cost_basis">
        <conclusion ref="price-above-cost" verdict="STOP — raise pilot price or refuse"/>
      </branch>
      <branch when="price &gt;= cost_basis">
        <question id="q-consent">Written case-study consent captured?</question>
        <branch when="consent == false">
          <conclusion ref="case-study-consent-written" verdict="STOP — capture written consent before start"/>
        </branch>
        <branch when="consent == true">
          <conclusion ref="transition-price-documented" verdict="proceed; ensure transition_clause documented"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="default path">
    Default path through the tree.
  </example>
</text>
