<text id="02-output-contract" title="spatial-ui-patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the spatial-ui-patterns methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spatial-ui-patterns.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "platforms",
    "panels"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "spatial-ui-patterns"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "spec"
        }
      }
    },
    "platforms": {
      "type": "array",
      "items": {
        "enum": [
          "visionos",
          "quest",
          "psvr2",
          "hololens",
          "android-xr",
          "webxr"
        ]
      },
      "minItems": 1
    },
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "distance_m",
          "min_target_pt",
          "primary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "world-locked",
              "head-locked",
              "body-locked",
              "hand-attached"
            ]
          },
          "distance_m": {
            "type": "number",
            "minimum": 0.3
          },
          "min_target_pt": {
            "type": "number",
            "minimum": 1
          },
          "primary": {
            "type": "boolean"
          },
          "fov_occupancy_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "head_locked_justification": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "spatial-ui-patterns",
    "version": "1.1.0",
    "produces": "spec"
  },
  "platforms": [
    "visionos",
    "quest"
  ],
  "panels": [
    {
      "id": "main-window",
      "type": "body-locked",
      "distance_m": 1.8,
      "min_target_pt": 60,
      "primary": true,
      "fov_occupancy_pct": 28
    },
    {
      "id": "battery-warning",
      "type": "head-locked",
      "distance_m": 1.5,
      "min_target_pt": 60,
      "primary": false,
      "fov_occupancy_pct": 3,
      "head_locked_justification": "safety telemetry; appears only when battery <10%"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platforms": [
    "visionos"
  ],
  "panels": [
    {
      "id": "hud",
      "type": "head-locked",
      "distance_m": 0.5,
      "min_target_pt": 24,
      "primary": true
    }
  ]
}
]]></code>
    <note>Missing __faion_header__; head-locked primary panel on visionOS without justification; distance &lt;1 m; target &lt;60 pt.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Primary head-locked panel on visionOS.</item>
      <item>Distance_m below 1.0 for primary panels.</item>
      <item>min_target_pt below 60.</item>
      <item>Primary panels with combined FoV occupancy &gt;40%.</item>
    </list>
  </section>

  <reference path="templates/panel-spec.json">Skeleton panel spec</reference>
  <reference path="scripts/validate-spatial-ui-patterns.py">Validator script</reference>
</text>
