<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="spatial-ui-patterns Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree by panel role + platform → panel type + distance. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-panel-role">Panel role?</root-question>

    <branch when="role == 'primary-content'">
      <conclusion ref="comfort-distance-min-1m" verdict="type=body-locked; distance 1.5-2.0 m"/>
    </branch>

    <branch when="role == 'tool-palette'">
      <conclusion ref="panel-type-mandatory" verdict="type=hand-attached; distance 0.4 m"/>
    </branch>

    <branch when="role == 'reference-content'">
      <conclusion ref="panel-type-mandatory" verdict="type=world-locked; distance ≥1.0 m"/>
    </branch>

    <branch when="role == 'safety-telemetry'">
      <conclusion ref="head-locked-forbidden-default" verdict="type=head-locked allowed with head_locked_justification"/>
    </branch>

    <branch when="fov_occupancy_sum &gt; 40">
      <conclusion ref="fov-occupancy-cap" verdict="demote panels or move off-primary"/>
    </branch>

  </decision-tree>

  <example trace="vp-productivity">
    role=primary-content → body-locked 1.8 m → role=tool-palette → hand-attached 0.4 m → FoV sum 34% → spec valid.
  </example>
</text>
