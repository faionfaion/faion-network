<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="tree-testing Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from research goal to tree-test config shape. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-goal">Goal of the study?</root-question>

    <branch when="goal == 'single-IA-validation'">
      <conclusion ref="sample-size-min-30" verdict="arms=[A]; n&gt;=30; 5-8 tasks"/>
    </branch>

    <branch when="goal == 'comparative-IA'">
      <conclusion ref="sample-size-min-30" verdict="arms=[A, B]; n&gt;=30 per arm"/>
    </branch>

    <branch when="tree.depth &gt; 4">
      <conclusion ref="depth-cap-4-levels" verdict="refactor IA before testing"/>
    </branch>

    <branch when="metrics missing directness">
      <conclusion ref="metrics-mandatory" verdict="add directness + first_click"/>
    </branch>

  </decision-tree>

  <example trace="ecommerce-redesign">
    goal=comparative-IA → arms=[A,B], n=50 per arm → directness present → config valid.
  </example>
</text>
