<text id="02-output-contract" title="spatial-ux-fundamentals Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the spatial-ux-fundamentals methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spatial-ux-fundamentals.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "platform",
    "elements",
    "recenter_affordance"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "spatial-ux-fundamentals"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "spec"
        }
      }
    },
    "platform": {
      "enum": [
        "visionos",
        "quest",
        "psvr2",
        "hololens",
        "android-xr",
        "webxr"
      ]
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "zone",
          "distance_m",
          "interactive",
          "anchor"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "zone": {
            "enum": [
              "near",
              "mid",
              "far"
            ]
          },
          "distance_m": {
            "type": "number",
            "minimum": 0.3
          },
          "interactive": {
            "type": "boolean"
          },
          "anchor": {
            "enum": [
              "head-locked",
              "head-locked-with-decay",
              "world-locked",
              "hand-attached"
            ]
          },
          "in_chin_region": {
            "type": "boolean"
          }
        }
      }
    },
    "recenter_affordance": {
      "type": "object",
      "required": [
        "button",
        "voice_command"
      ],
      "properties": {
        "button": {
          "type": "boolean",
          "const": true
        },
        "voice_command": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "spatial-ux-fundamentals",
    "version": "1.1.0",
    "produces": "spec"
  },
  "platform": "visionos",
  "elements": [
    {
      "id": "main-window",
      "zone": "mid",
      "distance_m": 1.8,
      "interactive": true,
      "anchor": "head-locked-with-decay",
      "in_chin_region": false
    },
    {
      "id": "ambient-clock",
      "zone": "far",
      "distance_m": 4.0,
      "interactive": false,
      "anchor": "world-locked",
      "in_chin_region": false
    }
  ],
  "recenter_affordance": {
    "button": true,
    "voice_command": true
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platform": "quest",
  "elements": [
    {
      "id": "cta",
      "zone": "far",
      "distance_m": 4.0,
      "interactive": true,
      "anchor": "world-locked"
    }
  ],
  "recenter_affordance": {
    "button": false,
    "voice_command": false
  }
}
]]></code>
    <note>Missing __faion_header__; interactive control in far field; recenter missing; primary control world-locked.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Interactive control with zone='far' or distance_m &gt; 3.0.</item>
      <item>Primary control anchored 'world-locked'.</item>
      <item>Recenter affordance missing.</item>
      <item>Critical UI in chin region (`in_chin_region: true`).</item>
    </list>
  </section>

