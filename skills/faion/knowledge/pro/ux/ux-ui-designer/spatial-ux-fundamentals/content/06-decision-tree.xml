<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="spatial-ux-fundamentals Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree: element role → field zone → anchor type → recenter check. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-element-role">Element role?</root-question>

    <branch when="role == 'primary-interactive'">
      <conclusion ref="three-field-zones" verdict="zone=mid (1.5-2.0 m); anchor=head-locked-with-decay or hand-attached"/>
    </branch>

    <branch when="role == 'tool-or-palette'">
      <conclusion ref="three-field-zones" verdict="zone=near (0.4-1.0 m); anchor=hand-attached"/>
    </branch>

    <branch when="role == 'reference-content'">
      <conclusion ref="three-field-zones" verdict="zone=mid; anchor=world-locked"/>
    </branch>

    <branch when="role == 'ambient-context'">
      <conclusion ref="no-interactive-in-far-field" verdict="zone=far; non-interactive only"/>
    </branch>

    <branch when="interactive == true AND zone == 'far'">
      <conclusion ref="no-interactive-in-far-field" verdict="reject; move to mid"/>
    </branch>

    <branch when="recenter_affordance missing">
      <conclusion ref="recenter-affordance-required" verdict="add button + voice command"/>
    </branch>

  </decision-tree>

  <example trace="vp-productivity">
    role=primary-interactive → zone=mid (1.8 m), anchor=head-locked-with-decay → recenter present → spec valid.
  </example>
</text>
