<text id="06-decision-tree" title="vui-privacy-security Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from data sensitivity + jurisdiction to required controls. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-data-sensitivity">Data sensitivity?</root-question>

    <branch when="data contains 'pii' OR 'health' OR 'financial'">
      <conclusion ref="pii-redact-at-boundary" verdict="on-device redaction mandatory"/>
    </branch>

    <branch when="jurisdictions contains 'EU'">
      <conclusion ref="transparency-before-capture" verdict="GDPR notice + consent gate"/>
    </branch>

    <branch when="sensitive_action exists">
      <conclusion ref="step-up-auth-sensitive" verdict="PIN/biometric/2FA mandatory per intent"/>
    </branch>

    <branch when="audience may include minors">
      <conclusion ref="minor-extra-protection" verdict="COPPA / GDPR Art. 8 parental gate"/>
    </branch>

    <branch when="retention &gt; 30 OR deletion_control false">
      <conclusion ref="retention-and-deletion" verdict="set retention ≤30 days + expose deletion"/>
    </branch>

  </decision-tree>

  <example trace="voice-banking">
    data=PII+financial → on-device redaction → EU jurisdiction → consent gate → sensitive=payment → biometric step-up → retention 14 days + deletion → spec valid.
  </example>
</text>
