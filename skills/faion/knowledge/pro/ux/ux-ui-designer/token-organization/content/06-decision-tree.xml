<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="token-organization Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree: token role → tier → name pattern. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-token-role">Token role?</root-question>

    <branch when="role == 'raw-value'">
      <conclusion ref="three-tier-required" verdict="tier=primitives; pattern=color.&lt;scale&gt;.&lt;step&gt;"/>
    </branch>

    <branch when="role == 'design-intent'">
      <conclusion ref="naming-convention-dots" verdict="tier=semantic; pattern=&lt;category&gt;.&lt;property&gt;.&lt;variant&gt;.&lt;state&gt;"/>
    </branch>

    <branch when="role == 'component-scoped'">
      <conclusion ref="no-primitive-in-component" verdict="tier=component; references semantic only"/>
    </branch>

    <branch when="interactive == true AND state suffix missing">
      <conclusion ref="state-suffix-mandatory" verdict="add .default/.hover/.active/.disabled/.focus"/>
    </branch>

  </decision-tree>

  <example trace="saas-refactor">
    role=design-intent → tier=semantic → pattern=color.action.primary.default → references {color.blue.600} → valid.
  </example>
</text>
