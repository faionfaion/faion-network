<methodology slug="token-organization">
  <metadata>
    <tier>pro</tier>
    <group>ux</group>
    <domain>ux-ui-designer</domain>
    <summary>A three-tier hierarchy for design tokens — primitives, semantic, component — with self-documenting naming convention that prevents bloat and enables theming.</summary>
    <category>design-systems</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-28</created>
    <tags>
      <tag>design-tokens</tag>
      <tag>design-systems</tag>
