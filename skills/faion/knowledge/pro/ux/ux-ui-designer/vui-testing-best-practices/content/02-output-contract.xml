<text id="02-output-contract" title="vui-testing-best-practices Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the vui-testing-best-practices methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/vui-testing-best-practices.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "layers",
    "subgroup_buckets",
    "stress_conditions",
    "user_test_n",
    "completion_metric",
    "seeds_locked"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "vui-testing-best-practices"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "config"
        }
      }
    },
    "layers": {
      "type": "array",
      "items": {
        "enum": [
          "unit",
          "integration",
          "user",
          "stress"
        ]
      },
      "minItems": 4,
      "maxItems": 4
    },
    "subgroup_buckets": {
      "type": "array",
      "items": {
        "enum": [
          "accent",
          "age",
          "gender",
          "non-native",
          "speech-impairment"
        ]
      },
      "minItems": 2
    },
    "stress_conditions": {
      "type": "array",
      "items": {
        "enum": [
          "kitchen-noise",
          "traffic-noise",
          "multi-speaker",
          "accented-speech",
          "mid-utterance-interrupt"
        ]
      },
      "minItems": 3
    },
    "user_test_n": {
      "type": "integer",
      "minimum": 5
    },
    "completion_metric": {
      "const": "completion_at_attempt_N"
    },
    "seeds_locked": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "vui-testing-best-practices",
    "version": "1.1.0",
    "produces": "config"
  },
  "layers": [
    "unit",
    "integration",
    "user",
    "stress"
  ],
  "subgroup_buckets": [
    "accent",
    "age",
    "gender"
  ],
  "stress_conditions": [
    "kitchen-noise",
    "multi-speaker",
    "accented-speech"
  ],
  "user_test_n": 8,
  "completion_metric": "completion_at_attempt_N",
  "seeds_locked": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "layers": [
    "unit"
  ],
  "subgroup_buckets": [],
  "stress_conditions": [
    "quiet"
  ],
  "user_test_n": 3,
  "completion_metric": "binary",
  "seeds_locked": false
}
]]></code>
    <note>Missing __faion_header__; layers &lt;4; subgroup_buckets empty; stress 'quiet' not allowed; &lt;5 users; binary completion; seeds free.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>layers not exactly [unit, integration, user, stress].</item>
      <item>user_test_n &lt; 5.</item>
      <item>stress_conditions &lt; 3.</item>
      <item>subgroup_buckets count &lt; 2.</item>
      <item>seeds_locked == false when LLM voice is used.</item>
    </list>
  </section>

  <reference path="templates/test-plan.json">Skeleton test plan</reference>
