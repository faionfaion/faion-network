<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design System Success Factors Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "report_date",
    "owner",
    "docs_freshness_days",
    "adoption_per_team",
    "contribution_model_documented",
    "coverage_pct"
  ],
  "properties": {
    "report_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "docs_freshness_days": {
      "type": "integer",
      "maximum": 30
    },
    "adoption_per_team": {
      "type": "object"
    },
    "contribution_model_documented": {
      "type": "boolean"
    },
    "coverage_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "report_date": "2026-05-23",
  "owner": "design-system-lead@example.com",
  "docs_freshness_days": 7,
  "adoption_per_team": {
    "checkout": 0.92,
    "search": 0.71,
    "billing": 0.45
  },
  "contribution_model_documented": true,
  "coverage_pct": 78.5
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "report_date": "x"
}
]]></code>
    <note>Missing owner, docs_freshness_days, adoption_per_team, contribution_model_documented, coverage_pct; report_date not ISO.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>docs_freshness_days &gt; 30 — auto-fail health.</item>
      <item>owner field empty.</item>
      <item>coverage_pct &lt;70 without a remediation plan attached.</item>
    </list>
  </section>

  <reference path="scripts/validate-design-system-success-factors.py">Validator script</reference>
</text>
