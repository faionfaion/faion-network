<text id="02-output-contract" title="spatial-interaction-patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the spatial-interaction-patterns methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spatial-interaction-patterns.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "platforms",
    "interactions"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "spatial-interaction-patterns"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "spec"
        }
      }
    },
    "platforms": {
      "type": "array",
      "items": {
        "enum": [
          "visionos",
          "quest",
          "psvr2",
          "hololens",
          "android-xr",
          "webxr"
        ]
      },
      "minItems": 1
    },
    "interactions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "primary_modality",
          "fallback_modality",
          "state_machine"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "primary_modality": {
            "enum": [
              "hand-direct",
              "hand-raycast",
              "controller",
              "gaze+dwell",
              "voice",
              "gesture"
            ]
          },
          "fallback_modality": {
            "enum": [
              "hand-direct",
              "hand-raycast",
              "controller",
              "gaze+dwell",
              "voice",
              "gesture"
            ]
          },
          "state_machine": {
            "type": "array",
            "items": {
              "enum": [
                "idle",
                "hover",
                "active",
                "cancel",
                "error"
              ]
            },
            "minItems": 5
          },
          "per_platform_notes": {
            "type": "object"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "spatial-interaction-patterns",
    "version": "1.1.0",
    "produces": "spec"
  },
  "platforms": [
    "visionos",
    "quest"
  ],
  "interactions": [
    {
      "name": "select-window",
      "primary_modality": "gaze+dwell",
      "fallback_modality": "voice",
      "state_machine": [
        "idle",
        "hover",
        "active",
        "cancel",
        "error"
      ],
      "per_platform_notes": {
        "quest": "hand-raycast tap also accepted"
      }
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platforms": [
    "quest"
  ],
  "interactions": [
    {
      "name": "grab",
      "primary_modality": "hand-direct",
      "state_machine": [
        "idle",
        "active"
      ]
    }
  ]
}
]]></code>
    <note>Missing __faion_header__; no fallback_modality; state_machine missing cancel + error + hover.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Interaction with primary_modality == fallback_modality.</item>
      <item>state_machine without {cancel, error}.</item>
      <item>Cross-platform divergence without `per_platform_notes` entry.</item>
    </list>
  </section>

  <reference path="templates/interaction-spec.json">Skeleton interaction spec</reference>
  <reference path="templates/state-machine.dot">Graphviz template for one interaction state machine</reference>
