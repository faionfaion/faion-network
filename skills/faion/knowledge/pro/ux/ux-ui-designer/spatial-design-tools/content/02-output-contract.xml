<text id="02-output-contract" title="spatial-design-tools Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the spatial-design-tools methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spatial-design-tools.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "phase",
    "platforms",
    "tool_stack",
    "asset_format",
    "budgets"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "spatial-design-tools"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "config"
        }
      }
    },
    "phase": {
      "enum": [
        "concept",
        "prototype",
        "production"
      ]
    },
    "platforms": {
      "type": "array",
      "items": {
        "enum": [
          "visionos",
          "quest",
          "psvr2",
          "hololens",
          "android-xr",
          "webxr"
        ]
      },
      "minItems": 1
    },
    "tool_stack": {
      "type": "object",
      "required": [
        "concept",
        "prototype",
        "production"
      ],
      "properties": {
        "concept": {
          "type": "array",
          "items": {
            "enum": [
              "figma",
              "shapesxr",
              "miro",
              "sketch"
            ]
          },
          "minItems": 1
        },
        "prototype": {
          "type": "array",
          "items": {
            "enum": [
              "unity",
              "unreal",
              "realitycomposer-pro",
              "godot"
            ]
          },
          "minItems": 1,
          "maxItems": 1
        },
        "production": {
          "type": "array",
          "items": {
            "enum": [
              "unity",
              "unreal",
              "realitycomposer-pro",
              "godot"
            ]
          },
          "minItems": 1,
          "maxItems": 1
        }
      }
    },
    "asset_format": {
      "type": "object",
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "enum": [
            "usd",
            "usdz",
            "gltf",
            "glb"
          ]
        },
        "secondary": {
          "type": "array",
          "items": {
            "enum": [
              "usd",
              "usdz",
              "gltf",
              "glb"
            ]
          }
        }
      }
    },
    "budgets": {
      "type": "object",
      "required": [
        "polygon_max",
        "file_size_mb_max",
        "draw_calls_max"
      ],
      "properties": {
        "polygon_max": {
          "type": "integer",
          "minimum": 1000
        },
        "file_size_mb_max": {
          "type": "number",
          "minimum": 0.1
        },
        "draw_calls_max": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "engine_rationale": {
      "type": "string",
      "minLength": 40
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "spatial-design-tools",
    "version": "1.1.0",
    "produces": "config"
  },
  "phase": "prototype",
  "platforms": [
    "visionos",
    "quest"
  ],
  "tool_stack": {
    "concept": [
      "figma",
      "shapesxr"
    ],
    "prototype": [
      "unity"
    ],
    "production": [
      "unity"
    ]
  },
  "asset_format": {
    "primary": "gltf",
    "secondary": [
      "usdz"
    ]
  },
  "budgets": {
    "polygon_max": 100000,
    "file_size_mb_max": 30,
    "draw_calls_max": 100
  },
  "engine_rationale": "Team has 4 years Unity; Quest XR SDK + PolySpatial cover both targets."
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "phase": "prototype",
  "platforms": [
    "quest"
  ],
  "tool_stack": {
    "prototype": [
      "unity",
      "unreal"
    ]
  },
  "budgets": {}
}
]]></code>
    <note>Missing __faion_header__; prototype must pick exactly one engine; missing asset_format; budgets empty.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Prototype or production tool_stack containing more than one engine.</item>
      <item>Empty `budgets`.</item>
      <item>Mixed asset formats without documented conversion path.</item>
      <item>`engine_rationale` shorter than 40 chars when engine choice exists.</item>
    </list>
  </section>

