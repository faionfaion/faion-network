{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "comment": "W3C DTCG 3-tier token skeleton: primitive → semantic → component",

  "color": {
    "primitive": {
      "blue": {
        "500": { "$value": "#3B82F6", "$type": "color" },
        "600": { "$value": "#2563EB", "$type": "color" }
      },
      "gray": {
        "50":  { "$value": "#F9FAFB", "$type": "color" },
        "600": { "$value": "#4B5563", "$type": "color" },
        "900": { "$value": "#111827", "$type": "color" }
      },
      "white": { "$value": "#FFFFFF", "$type": "color" }
    },
    "semantic": {
      "text": {
        "default": { "$value": "{color.primitive.gray.900}", "$type": "color", "$description": "Default body text" },
        "muted":   { "$value": "{color.primitive.gray.600}", "$type": "color", "$description": "Secondary / hint text" }
      },
      "surface": {
        "primary": { "$value": "{color.primitive.white}", "$type": "color" }
      },
      "action": {
        "primary": { "$value": "{color.primitive.blue.500}", "$type": "color" },
        "primaryHover": { "$value": "{color.primitive.blue.600}", "$type": "color" }
      }
    },
    "component": {
      "button": {
        "background":      { "$value": "{color.semantic.action.primary}", "$type": "color" },
        "backgroundHover": { "$value": "{color.semantic.action.primaryHover}", "$type": "color" },
        "label":           { "$value": "{color.primitive.white}", "$type": "color" }
      }
    }
  },

  "spacing": {
    "primitive": {
      "xs": { "$value": "4px",  "$type": "dimension" },
      "sm": { "$value": "8px",  "$type": "dimension" },
      "md": { "$value": "16px", "$type": "dimension" },
      "lg": { "$value": "24px", "$type": "dimension" },
      "xl": { "$value": "32px", "$type": "dimension" }
    },
    "semantic": {
      "inset":  { "$value": "{spacing.primitive.md}", "$type": "dimension" },
      "stack":  { "$value": "{spacing.primitive.lg}", "$type": "dimension" }
    }
  }
}
