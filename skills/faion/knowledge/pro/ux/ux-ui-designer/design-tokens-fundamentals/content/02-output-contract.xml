<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Tokens Fundamentals Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "primitive",
    "semantic",
    "component"
  ],
  "properties": {
    "primitive": {
      "type": "object"
    },
    "semantic": {
      "type": "object"
    },
    "component": {
      "type": "object"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "primitive": {
    "color": {
      "blue-500": {
        "$value": "#1c5fdb",
        "$type": "color"
      },
      "blue-900": {
        "$value": "#0a2c66",
        "$type": "color"
      }
    },
    "motion": {
      "fast": {
        "$value": "80ms",
        "$type": "duration",
        "reduced_motion_variant": "0ms"
      }
    }
  },
  "semantic": {
    "color": {
      "text": {
        "primary": {
          "$value": "{primitive.color.blue-900}",
          "$type": "color",
          "contrast_ratio_on_white": 12.4,
          "pass": true
        }
      }
    }
  },
  "component": {
    "button": {
      "primary": {
        "background": {
          "$value": "{semantic.color.text.primary}",
          "$type": "color"
        }
      }
    }
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "primitive": {}
}
]]></code>
    <note>Missing semantic + component tiers; primitive empty.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>A semantic color token without contrast_ratio + pass.</item>
      <item>A motion token without reduced_motion_variant.</item>
      <item>left/right spacing in an RTL-scoped system.</item>
    </list>
  </section>

  <reference path="scripts/validate-design-tokens-fundamentals.py">Validator script</reference>
</text>
