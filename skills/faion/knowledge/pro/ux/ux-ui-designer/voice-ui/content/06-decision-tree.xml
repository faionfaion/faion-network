<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="voice-ui Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from intent characteristics to confirmation + error-ladder shape. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-intent-class">Intent class?</root-question>

    <branch when="intent.irreversible == true">
      <conclusion ref="explicit-confirmation-irreversible" verdict="add confirmation_prompt with explicit Yes/Cancel"/>
    </branch>

    <branch when="intent.irreversible == false">
      <conclusion ref="error-ladder-3-tier" verdict="skip confirmation; ensure 3-tier ladder"/>
    </branch>

    <branch when="sample_utterances count &lt; 3">
      <conclusion ref="dialogues-before-code" verdict="author more dialogues first"/>
    </branch>

    <branch when="prompt length &gt; 100 chars">
      <conclusion ref="prompt-grade-8-and-short" verdict="split or shorten prompt"/>
    </branch>

    <branch when="barge_in == false">
      <conclusion ref="barge-in-allowed" verdict="enable barge-in"/>
    </branch>

  </decision-tree>

  <example trace="send-payment">
    intent.irreversible=true → add confirmation_prompt → prompt 24 chars → barge_in true → spec valid.
  </example>
</text>
