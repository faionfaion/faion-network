<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="vui-market-context Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from use-case + audience to platform recommendation. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-use-case">Voice use case?</root-question>

    <branch when="use_case == 'smart-home'">
      <conclusion ref="matter-or-ha-for-smart-home" verdict="primary=matter; fallback=home-assistant"/>
    </branch>

    <branch when="use_case == 'app-embedded'">
      <conclusion ref="custom-llm-voice-allowed" verdict="primary=custom-llm; fallback=siri or google-assistant"/>
    </branch>

    <branch when="use_case == 'ivr'">
      <conclusion ref="custom-llm-voice-allowed" verdict="primary=custom-llm (Pipecat); fallback=Twilio Voice"/>
    </branch>

    <branch when="evidence pre-2024">
      <conclusion ref="cite-2025-2026-data" verdict="re-pull data"/>
    </branch>

    <branch when="recommendation.fallback empty">
      <conclusion ref="primary-plus-fallback" verdict="add fallback or document risk"/>
    </branch>

  </decision-tree>

  <example trace="smart-home-product">
    use_case=smart-home → matter primary + home-assistant fallback → 2025-2026 evidence → lock-in notes documented → record valid.
  </example>
</text>
