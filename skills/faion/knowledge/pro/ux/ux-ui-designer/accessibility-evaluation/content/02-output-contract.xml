<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Accessibility Evaluation Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "audit_date",
    "wcag_version",
    "axe_version",
    "findings",
    "summary"
  ],
  "properties": {
    "audit_date": {
      "type": "string",
      "format": "date"
    },
    "wcag_version": {
      "enum": [
        "2.1",
        "2.2"
      ]
    },
    "axe_version": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "sc",
          "priority",
          "location",
          "evidence",
          "recommendation"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "sc": {
            "type": "string"
          },
          "priority": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "location": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          },
          "w3c_technique": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "properties": {
        "critical": {
          "type": "integer"
        },
        "high": {
          "type": "integer"
        },
        "medium": {
          "type": "integer"
        },
        "low": {
          "type": "integer"
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "audit_date": "2026-05-23",
  "wcag_version": "2.2",
  "axe_version": "4.10.0",
  "findings": [
    {
      "id": "F-001",
      "sc": "1.3.1",
      "priority": "critical",
      "location": "form#contact input[type=email]",
      "evidence": "axe-core: label-required",
      "recommendation": "Add <label> association via for/id or wrap input in label",
      "w3c_technique": "H44"
    }
  ],
  "summary": {
    "critical": 1,
    "high": 0,
    "medium": 0,
    "low": 0
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "audit_date": "2026",
  "findings": []
}
]]></code>
    <note>audit_date not ISO; missing wcag_version, axe_version, summary; findings empty.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Compliance claim with no Stage 4 (screen-reader) evidence.</item>
      <item>Finding without sc (WCAG criterion) or priority enum.</item>
      <item>Screen-reader transcript without recording or machine-readable source.</item>
    </list>
  </section>

  <reference path="scripts/validate-accessibility-evaluation.py">Validator script</reference>
</text>
