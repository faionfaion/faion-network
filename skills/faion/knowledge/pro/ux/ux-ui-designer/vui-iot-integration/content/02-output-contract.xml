<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="vui-iot-integration Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the vui-iot-integration methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/vui-iot-integration.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "groups",
    "scenes",
    "routines",
    "partial_failure_feedback",
    "undo_supported",
    "noise_conditions"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "vui-iot-integration"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "config"
        }
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "device_ids"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "device_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "actions"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      }
    },
    "routines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      }
    },
    "partial_failure_feedback": {
      "type": "boolean",
      "const": true
    },
    "undo_supported": {
      "type": "boolean",
      "const": true
    },
    "noise_conditions": {
      "type": "array",
      "items": {
        "enum": [
          "quiet",
          "ambient",
          "kitchen",
          "tv",
          "multi-speaker"
        ]
      },
      "minItems": 3
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "vui-iot-integration",
    "version": "1.1.0",
    "produces": "config"
  },
  "groups": [
    {
      "id": "bedroom",
      "name": "bedroom",
      "device_ids": [
        "hue-001",
        "nest-thermo-002"
      ]
    }
  ],
  "scenes": [
    {
      "name": "good night",
      "actions": [
        {
          "device_id": "hue-001",
          "action": "off"
        },
        {
          "device_id": "nest-thermo-002",
          "action": "set",
          "value": 18
        }
      ]
    }
  ],
  "routines": [
    {
      "name": "movie night"
    }
  ],
  "partial_failure_feedback": true,
  "undo_supported": true,
  "noise_conditions": [
    "quiet",
    "kitchen",
    "tv"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "groups": [],
  "scenes": [
    {
      "name": "S1"
    }
  ],
  "routines": [],
  "partial_failure_feedback": false,
  "undo_supported": false,
  "noise_conditions": [
    "quiet"
  ]
}
]]></code>
    <note>Missing __faion_header__; groups empty; scene name acronym; routines empty; partial_failure_feedback false; undo false; noise_conditions &lt;3.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>groups list empty.</item>
      <item>Scene name shorter than 3 chars or acronym-only.</item>
      <item>partial_failure_feedback or undo_supported set to false.</item>
      <item>noise_conditions count &lt; 3.</item>
    </list>
  </section>

  <reference path="templates/iot-voice-config.json">Skeleton config</reference>
