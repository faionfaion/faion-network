<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="vui-conversation-design Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from dialog turn count + state count to spec coverage. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-turns">Dialog turn count?</root-question>

    <branch when="turns == 1">
      <conclusion ref="state-machine-explicit" verdict="use voice-ui single-turn methodology instead"/>
    </branch>

    <branch when="turns &gt;= 2">
      <conclusion ref="state-machine-explicit" verdict="model as state machine with explicit transitions"/>
    </branch>

    <branch when="reprompt count != 3">
      <conclusion ref="reprompt-cap-3" verdict="set reprompt_cap to 3"/>
    </branch>

    <branch when="voice_script length &gt; 100">
      <conclusion ref="prompt-12-word-limit" verdict="split into multiple prompts"/>
    </branch>

    <branch when="noise_test_conditions count &lt; 3">
      <conclusion ref="noise-test-required" verdict="add ≥3 noise conditions"/>
    </branch>

  </decision-tree>

  <example trace="booking-dialog">
    turns=2 → state machine → reprompt_cap=3 → voice_script ≤12 → 3 noise conditions → spec valid.
  </example>
</text>
