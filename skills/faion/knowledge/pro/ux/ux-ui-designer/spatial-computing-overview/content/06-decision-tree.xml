<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Spatial Computing Overview Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from use-case + audience + content-type to a primary platform + fallback pair. Every leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-use-case">Use case category?</root-question>

    <branch when="use_case == 'productivity'">
      <question id="q-prod-audience">Audience?</question>
      <branch when="audience == 'prosumer' OR audience == 'enterprise'">
        <conclusion ref="audience-fit" verdict="primary=visionos; fallback=webxr"/>
      </branch>
      <branch when="audience == 'consumer'">
        <conclusion ref="install_base" verdict="primary=quest; fallback=webxr"/>
      </branch>
    </branch>

    <branch when="use_case == 'entertainment'">
      <question id="q-content-entertainment">Content type?</question>
      <branch when="content_types contains 'active-gaming'">
        <conclusion ref="content-type-fit" verdict="primary=quest; fallback=psvr2"/>
      </branch>
      <branch when="content_types contains 'cinematic-video'">
        <conclusion ref="content-type-fit" verdict="primary=visionos; fallback=quest"/>
      </branch>
    </branch>

    <branch when="use_case == 'training' OR use_case == 'industrial'">
      <question id="q-overlay">Overlay onto real world?</question>
      <branch when="overlay_required == true">
        <conclusion ref="content-type-fit" verdict="primary=hololens; fallback=quest passthrough"/>
      </branch>
      <branch when="overlay_required == false">
        <conclusion ref="content-type-fit" verdict="primary=quest; fallback=psvr2"/>
      </branch>
    </branch>

    <branch when="evidence_sources.any pre 2024">
      <conclusion ref="cite-2026-data" verdict="re-pull data — stale evidence forbidden"/>
    </branch>

    <branch when="recommendation.fallback empty">
      <conclusion ref="primary-plus-fallback" verdict="add fallback or document risk_notes"/>
    </branch>
  </decision-tree>

  <example trace="3d-model-review-prosumer">
    use_case=productivity → audience=prosumer → primary=visionos, fallback=webxr; risk_notes cite small install base.
  </example>
</text>
