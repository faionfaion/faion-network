<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="surveys Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from research goal + n to instrument + channels + analysis test. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-goal">Research goal type?</root-question>

    <branch when="goal == 'satisfaction-tracking'">
      <conclusion ref="instrument-mandatory" verdict="instrument=[csat]; scale=likert-1-5; channel=in-app"/>
    </branch>

    <branch when="goal == 'recommendation-likelihood'">
      <conclusion ref="instrument-mandatory" verdict="instrument=[nps]; scale=nps-0-10"/>
    </branch>

    <branch when="goal == 'task-ease'">
      <conclusion ref="instrument-mandatory" verdict="instrument=[seq]; scale=likert-1-7; in-app intercept"/>
    </branch>

    <branch when="goal == 'usability'">
      <conclusion ref="instrument-mandatory" verdict="instrument=[sus]; 10 items; likert-1-5"/>
    </branch>

    <branch when="target_n &lt; 30">
      <conclusion ref="response-rate-target" verdict="skip-this-methodology — use qualitative methods"/>
    </branch>

    <branch when="analysis post-hoc added">
      <conclusion ref="analysis-plan-pre-registered" verdict="flag as exploratory; do not claim significance"/>
    </branch>

  </decision-tree>

  <example trace="onboarding-uplift">
    goal=task-ease → instrument=[seq] → likert-1-7 → target_n=400 → t-test pre-registered → valid.
  </example>
</text>
