{
  "$schema": "https://design-tokens.org/schema.json",
  "color": {
    "blue": {
      "500": {
        "$type": "color",
        "$value": "#3B82F6",
        "$description": "Primary brand blue, WCAG AA contrast on white"
      }
    },
    "neutral": {
      "100": {
        "$type": "color",
        "$value": "#F5F5F5",
        "$description": "Lightest neutral surface"
      }
    },
    "action": {
      "primary": {
        "$type": "color",
        "$value": "{color.blue.500}",
        "$description": "Primary CTA button background"
      }
    }
  },
  "dimension": {
    "spacing": {
      "sm": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "Small spacing unit (half base)"
      },
      "md": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "Base spacing unit"
      },
      "lg": {
        "$type": "dimension",
        "$value": "24px",
        "$description": "Large spacing unit (1.5x base)"
      }
    }
  },
  "fontWeight": {
    "regular": {
      "$type": "fontWeight",
      "$value": 400,
      "$description": "Body text weight"
    },
    "bold": {
      "$type": "fontWeight",
      "$value": 700,
      "$description": "Emphasis and heading weight"
    }
  }
}
