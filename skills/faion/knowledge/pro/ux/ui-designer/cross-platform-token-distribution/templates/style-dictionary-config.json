{
  "source": ["tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "prefix": "",
      "buildPath": "platforms/css/",
      "files": [
        {
          "destination": "variables.css",
          "format": "css/variables",
          "options": { "outputReferences": true }
        }
      ]
    },
    "scss": {
      "transformGroup": "scss",
      "buildPath": "platforms/scss/",
      "files": [
        {
          "destination": "_variables.scss",
          "format": "scss/variables"
        }
      ]
    },
    "ios": {
      "transformGroup": "ios-swift",
      "buildPath": "platforms/ios/",
      "files": [
        {
          "destination": "StyleDictionary.swift",
          "format": "ios-swift/class.swift",
          "className": "StyleDictionary"
        }
      ]
    },
    "android": {
      "transformGroup": "android",
      "buildPath": "platforms/android/src/main/res/values/",
      "files": [
        {
          "destination": "style_dictionary_colors.xml",
          "format": "android/colors",
          "filter": { "attributes": { "category": "color" } }
        },
        {
          "destination": "style_dictionary_dimens.xml",
          "format": "android/dimens",
          "filter": { "attributes": { "category": "spacing" } }
        }
      ]
    },
    "react-native": {
      "transformGroup": "react-native",
      "buildPath": "platforms/react-native/",
      "files": [
        {
          "destination": "tokens.js",
          "format": "javascript/es6"
        }
      ]
    }
  }
}
