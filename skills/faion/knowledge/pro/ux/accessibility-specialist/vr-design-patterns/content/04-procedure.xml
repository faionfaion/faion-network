<text id="04-procedure" title="VR Design Patterns for Accessibility and Comfort Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply VR Design Patterns for Accessibility and Comfort end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="comfort-defaults">
      <input>View + turn settings</input>
      <action>Set snap turn + vignette default-on.</action>
      <output>Comfort defaults.</output>
    </step>

    <step n="2" name="locomotion-modes">
      <input>Locomotion list</input>
      <action>Ensure ≥2 modes; teleport default.</action>
      <output>Locomotion policy.</output>
      <decision-gate>If smooth is only mode, STOP.</decision-gate>
    </step>

    <step n="3" name="hand-presence">
      <input>Interaction list</input>
      <action>Pair hand-tracking with controller fallback.</action>
      <output>Presence policy.</output>
    </step>

    <step n="4" name="retreat">
      <input>Scene + menu graph</input>
      <action>Add persistent retreat control reachable ≤2 inputs.</action>
      <output>Retreat spec.</output>
    </step>

    <step n="5" name="record">
      <input>All settings</input>
      <action>Compile VR-pattern record; validate.</action>
      <output>Record ready.</output>
    </step>

  </section>
</text>
