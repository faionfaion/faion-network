<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="VR Design Patterns for Accessibility and Comfort Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/vr-design-patterns.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">Smooth-turn-default without snap alternate.</pattern>
      <pattern id="f2">Vignette off during locomotion.</pattern>
      <pattern id="f3">Single locomotion mode (no teleport).</pattern>
      <pattern id="f4">No retreat control.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "vr-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@xr-designer",
  "scope": {
    "experience": "training-vr",
    "platform": "Quest"
  },
  "findings": [
    {
      "rule": "snap-turn-default",
      "verdict": "pass"
    },
    {
      "rule": "vignette-on-during-locomotion",
      "verdict": "pass"
    },
    {
      "rule": "locomotion-choice",
      "verdict": "pass"
    },
    {
      "rule": "hand-presence-options",
      "verdict": "pass"
    },
    {
      "rule": "retreat-affordance",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": []
}
]]></code>
    <note>findings empty; missing artefact_id, version, last_reviewed, owner, scope.</note>
  </example>

  <reference path="scripts/validate-vr-design-patterns.py">Schema validator (stdlib only).</reference>
</text>
