<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="ADA Title II Compliance 2026 Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ada-title-ii-compliance-2026.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">Conformance target below WCAG 2.1 AA.</pattern>
      <pattern id="f2">Exception listed without rationale or §35.201 clause citation.</pattern>
      <pattern id="f3">Service area without named owner.</pattern>
      <pattern id="f4">Non-pass area without remediation_url.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ada-titleii-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@counsel-a",
  "scope": {
    "entity": "City of Faion",
    "covered": true,
    "population": 120000,
    "track": "2026"
  },
  "findings": [
    {
      "service_area": "permits-portal",
      "owner": "@gov-it-lead",
      "verdict": "partial",
      "wcag_version": "2.1",
      "level": "AA",
      "exceptions": [],
      "remediation_url": "https://gov/titleii/permits-plan"
    }
  ],
  "verdict": "partial"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "findings": [
    {
      "service_area": "permits",
      "verdict": "in-progress"
    }
  ]
}
]]></code>
    <note>owner &apos;team&apos; (forbidden); verdict &apos;in-progress&apos; not in enum; missing artefact_id, version, last_reviewed, scope; row missing service-area owner and remediation_url.</note>
  </example>

  <reference path="scripts/validate-ada-title-ii-compliance-2026.py">Schema validator (stdlib only).</reference>
</text>
