<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cognitive Inclusion Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/cognitive-inclusion-design.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">Reading-level metric below target with no documented locale override.</pattern>
      <pattern id="f2">Jargon used without inline definition.</pattern>
      <pattern id="f3">Critical action single-click destructive.</pattern>
      <pattern id="f4">Timeout without extension default.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "cog-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@designer",
  "scope": {
    "component": "signup-flow",
    "reading_level": {
      "flesch": 72,
      "grade": 6
    },
    "language": "en"
  },
  "findings": [
    {
      "rule": "plain-language-target",
      "verdict": "pass"
    },
    {
      "rule": "predictable-navigation",
      "verdict": "pass"
    },
    {
      "rule": "error-tolerance",
      "verdict": "pass"
    },
    {
      "rule": "recoverable-critical-actions",
      "verdict": "pass"
    },
    {
      "rule": "time-extension-defaults",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scope": {
    "reading_level": {
      "flesch": 35
    }
  },
  "findings": []
}
]]></code>
    <note>Flesch 35 below target; findings empty; missing artefact_id, version, last_reviewed, owner.</note>
  </example>

  <reference path="scripts/validate-cognitive-inclusion-design.py">Schema validator (stdlib only).</reference>
</text>
