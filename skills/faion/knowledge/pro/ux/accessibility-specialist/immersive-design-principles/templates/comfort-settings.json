{
  "_comment": "Default XR comfort-settings schema. All defaults set to highest comfort. Users opt into lower comfort.",
  "comfort": {
    "locomotion": {
      "type": "enum",
      "values": ["teleport", "smooth", "seated"],
      "default": "teleport",
      "note": "Teleport is always the default. Smooth is opt-in with vignette enforced."
    },
    "turning": {
      "type": "enum",
      "values": ["snap_30", "snap_45", "smooth"],
      "default": "snap_30"
    },
    "vignette": {
      "type": "enum",
      "values": ["off", "light", "medium", "strong"],
      "default": "medium",
      "auto_enable_on_smooth_locomotion": true
    },
    "fov_cap_during_motion_deg": {
      "type": "number",
      "min": 50,
      "max": 110,
      "default": 80
    },
    "seated_mode": {
      "type": "boolean",
      "default": false,
      "note": "When true, all content must be reachable from seated position."
    },
    "height_offset_cm": {
      "type": "number",
      "min": -30,
      "max": 30,
      "default": 0
    }
  },
  "visual": {
    "high_contrast": {"type": "boolean", "default": false},
    "text_scale": {"type": "number", "min": 0.8, "max": 2.0, "default": 1.0},
    "reduce_particles": {"type": "boolean", "default": false},
    "reduce_screen_shake": {"type": "boolean", "default": true},
    "motion_blur": {"type": "boolean", "default": false}
  },
  "audio": {
    "captions": {"type": "boolean", "default": true},
    "caption_size": {"type": "enum", "values": ["small", "medium", "large"], "default": "medium"},
    "spatial_audio": {"type": "boolean", "default": true},
    "master_volume": {"type": "number", "min": 0, "max": 1, "default": 1.0},
    "per_source_volume": {
      "music": 0.7,
      "sfx": 1.0,
      "voice": 1.0,
      "ui": 0.8
    }
  },
  "interaction": {
    "hand_tracking": {"type": "boolean", "default": true},
    "voice_commands": {"type": "boolean", "default": true},
    "dwell_select_ms": {"type": "number", "min": 500, "max": 3000, "default": 1500},
    "gaze_highlight": {"type": "boolean", "default": true}
  },
  "performance": {
    "target_fps": 90,
    "min_fps": 90,
    "max_motion_to_photon_ms": 20,
    "dynamic_resolution_scaling": true,
    "note": "Drop visual fidelity before dropping below min_fps."
  }
}
