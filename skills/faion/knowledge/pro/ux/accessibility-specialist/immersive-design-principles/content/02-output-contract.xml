<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Immersive Design Principles Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/immersive-design-principles.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">Smooth-locomotion-only experience without teleport alternate.</pattern>
      <pattern id="f2">Flashes per second &gt; 3 or &gt; 25% of viewport.</pattern>
      <pattern id="f3">Audio peak &gt; -3 dBFS.</pattern>
      <pattern id="f4">Retreat-option not persistently available.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "imm-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@xr-lead",
  "scope": {
    "experience": "training-vr",
    "platform": "Quest",
    "session_minutes": 12
  },
  "findings": [
    {
      "rule": "comfort-defaults",
      "verdict": "pass"
    },
    {
      "rule": "safe-locomotion-choice",
      "verdict": "pass"
    },
    {
      "rule": "sensory-budget-per-minute",
      "verdict": "pass"
    },
    {
      "rule": "explicit-agency",
      "verdict": "pass"
    },
    {
      "rule": "retreat-option-always",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": [
    {
      "rule": "comfort-defaults",
      "verdict": "n/a"
    }
  ]
}
]]></code>
    <note>verdict &apos;n/a&apos; not in enum; missing artefact_id, version, last_reviewed, owner, scope.</note>
  </example>

  <reference path="scripts/validate-immersive-design-principles.py">Schema validator (stdlib only).</reference>
</text>
