<text id="02-output-contract" title="Accessibility-First Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the spec artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/accessibility-first-design.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "component",
    "owner",
    "structure",
    "focus_order",
    "aria_budget",
    "contrast_tokens",
    "motion_alternates"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "component": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "structure": {
      "type": "object"
    },
    "focus_order": {
      "type": "array"
    },
    "aria_budget": {
      "type": "array"
    },
    "contrast_tokens": {
      "type": "object"
    },
    "motion_alternates": {
      "type": "array"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">aria_budget item without rationale.</pattern>
      <pattern id="f2">motion_alternates empty when animations are spec&apos;d in structure or tokens.</pattern>
      <pattern id="f3">contrast_tokens ratio below 4.5:1 for text or 3:1 for UI without override.</pattern>
      <pattern id="f4">focus_order missing for any modal / drawer / overlay component.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "afd-modal-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "component": "checkout-confirm-modal",
  "owner": "@designer-a",
  "structure": {
    "heading_level": "h2",
    "landmark": "dialog"
  },
  "focus_order": [
    "close-button",
    "cancel-button",
    "confirm-button"
  ],
  "aria_budget": [
    {
      "attr": "aria-modal=true",
      "rationale": "native <dialog> not used; emulate modal semantics"
    }
  ],
  "contrast_tokens": {
    "text-on-surface": "4.7:1",
    "primary-button": "5.2:1"
  },
  "motion_alternates": [
    {
      "animation": "modal-slide-in",
      "reduced": "opacity-fade-150ms"
    }
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "component": "modal",
  "aria_budget": [
    {
      "attr": "aria-label=button"
    }
  ],
  "motion_alternates": []
}
]]></code>
    <note>aria entry lacks rationale; motion_alternates empty; missing artefact_id, version, last_reviewed, owner, structure, focus_order, contrast_tokens.</note>
  </example>

  <reference path="scripts/validate-accessibility-first-design.py">Schema validator (stdlib only).</reference>
</text>
