<text id="02-output-contract" title="Regulatory Compliance 2026 Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/regulatory-compliance-2026.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">WCAG floor below 2.1 AA.</pattern>
      <pattern id="f2">Regime listed without effective date.</pattern>
      <pattern id="f3">Exception listed without clause citation.</pattern>
      <pattern id="f4">Missing per-regime artefact (e.g. EU shipping without EAA statement).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "reg-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@counsel",
  "scope": {
    "regimes": [
      "ada-title-ii",
      "eu-eaa",
      "aoda"
    ],
    "wcag_floor": "2.2-AA"
  },
  "findings": [
    {
      "regime": "ada-title-ii",
      "artefact": "vpat-acr",
      "verdict": "pass"
    },
    {
      "regime": "eu-eaa",
      "artefact": "accessibility-statement",
      "verdict": "pass"
    },
    {
      "regime": "aoda",
      "artefact": "filing",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": [
    {
      "regime": "ada-title-ii",
      "artefact": "vpat-acr"
    }
  ]
}
]]></code>
    <note>verdict missing on finding; missing artefact_id, version, last_reviewed, owner, scope.</note>
  </example>

  <reference path="scripts/validate-regulatory-compliance-2026.py">Schema validator (stdlib only).</reference>
</text>
