<text id="02-output-contract" title="AR Design Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ar-design-patterns.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">World-locked element without anchor spec.</pattern>
      <pattern id="f2">Single contrast token for multi-environment scope.</pattern>
      <pattern id="f3">Dwell-only or gaze-only input without alternate.</pattern>
      <pattern id="f4">Animation &gt; 30s/min cumulative without reduced-motion alternate.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ar-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@xr-designer",
  "scope": {
    "component": "maintenance-overlay",
    "environments": [
      "indoor",
      "outdoor"
    ],
    "inputs": [
      "pinch",
      "dwell"
    ]
  },
  "findings": [
    {
      "id": "anchor",
      "verdict": "pass"
    },
    {
      "id": "contrast",
      "verdict": "pass"
    },
    {
      "id": "input-alt",
      "verdict": "pass"
    },
    {
      "id": "motion-budget",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scope": {
    "component": "x",
    "environments": [
      "outdoor"
    ],
    "inputs": [
      "dwell"
    ]
  },
  "findings": []
}
]]></code>
    <note>dwell-only inputs with no alternate; findings empty; missing artefact_id, version, last_reviewed, owner.</note>
  </example>

  <reference path="scripts/validate-ar-design-patterns.py">Schema validator (stdlib only).</reference>
</text>
