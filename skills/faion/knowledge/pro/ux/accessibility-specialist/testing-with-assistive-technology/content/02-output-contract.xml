<text id="02-output-contract" title="Testing with Assistive Technology Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/testing-with-assistive-technology.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">AT version not pinned.</pattern>
      <pattern id="f2">Critical flow with only one AT covered.</pattern>
      <pattern id="f3">Finding without recording_url.</pattern>
      <pattern id="f4">AT rig auto-updated mid-cycle without re-baseline.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "at-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@qa-lead",
  "scope": {
    "flows": [
      "/checkout"
    ],
    "ats": [
      "NVDA-2024.2",
      "VoiceOver-iOS-17.4",
      "VoiceControl-macOS-14.4"
    ]
  },
  "findings": [
    {
      "at": "NVDA-2024.2",
      "sc": "4.1.2",
      "severity": "major",
      "recording_url": "https://artifacts/nvda-checkout.log"
    },
    {
      "at": "VoiceOver-iOS-17.4",
      "sc": "1.3.1",
      "severity": "blocker",
      "recording_url": "https://artifacts/vo-checkout.mp4"
    }
  ],
  "verdict": "fail"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": [
    {
      "at": "NVDA",
      "sc": "4.1.2"
    }
  ]
}
]]></code>
    <note>AT version not pinned; severity missing; recording_url missing; missing artefact_id, version, last_reviewed, owner, scope.</note>
  </example>

  <reference path="scripts/validate-testing-with-assistive-technology.py">Schema validator (stdlib only).</reference>
</text>
