<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Post-Mortem Template Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the report artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-post-mortem-template.json",
  "type": "object",
  "required": ["report_id", "as_of", "findings", "recommendations", "author"],
  "properties": {
    "report_id": {"type": "string"},
    "as_of": {"type": "string", "format": "date"},
    "findings": {"type": "array", "items": {"type": "object", "required": ["id", "summary"], "properties": {"id": {"type": "string"}, "summary": {"type": "string"}, "evidence": {"type": "string"}}}, "minItems": 1},
    "recommendations": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "author": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "report_id": "ai-post-mortem-template-2026Q2",
  "as_of": "2026-05-23",
  "findings": [{"id": "f1", "summary": "main finding", "evidence": "link/to/data"}],
  "recommendations": ["recommendation-1"],
  "author": "analyst@example.com"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "report_id": "ai-post-mortem-template-2026Q2"
}
]]></code>
    <note>Missing required fields per the schema above.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">report without findings array</pattern>
      <pattern id="f2">recommendations empty</pattern>
      <pattern id="f3">as_of missing or stale (&gt;30 days)</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Auto-populate timestamps from the validation moment.</transformation>
      <transformation>Normalise enum casing to schema lowercase.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-ai-post-mortem-template.py">Validator script</reference>
</text>
