<text id="06-decision-tree" title="AI Feature Observability — Four Pillars Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for ai-feature-observability-four-pillars.</summary>

  <decision-tree>
      <root-question id="q-root">Are all four pillars instrumented + alerted + reviewed?</root-question>

      <branch when="quality_pillar_missing == true">
        <conclusion ref="r1-all-four-pillars" verdict="BLOCK — eval-on-sample required"/>
      </branch>
      <branch when="latency_pillar_missing == true">
        <conclusion ref="r1-all-four-pillars" verdict="BLOCK — TTFT + p95 required"/>
      </branch>
      <branch when="cost_pillar_missing == true">
        <conclusion ref="r1-all-four-pillars" verdict="BLOCK — cost-per-outcome required"/>
      </branch>
      <branch when="drift_pillar_missing == true">
        <conclusion ref="r1-all-four-pillars" verdict="BLOCK — drift metrics + sampling required"/>
      </branch>
      <branch when="all_pillars_live == true">
        <conclusion ref="r1-all-four-pillars" verdict="APPROVE — schedule monthly review"/>
      </branch>

      <branch when="preconditions_unmet == true">
        <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
      </branch>
    </decision-tree>

    <example trace="ai-feature-observability-four-pillars-happy-path">
      preconditions met → first branch matches → conclusion ref resolves to a rule in 01-core-rules.xml.
    </example>
</text>
