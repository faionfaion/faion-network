<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Research Repository Setup Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/research-repository-setup.json",
  "type": "object",
  "required": [
    "platform",
    "taxonomy",
    "access_matrix",
    "ingestion_sources",
    "backfill"
  ],
  "properties": {
    "platform": {
      "type": "object",
      "required": [
        "picked",
        "scorecard"
      ]
    },
    "taxonomy": {
      "type": "object",
      "required": [
        "classes",
        "tag_count"
      ],
      "properties": {
        "tag_count": {
          "type": "integer",
          "minimum": 30,
          "maximum": 80
        }
      }
    },
    "access_matrix": {
      "type": "object"
    },
    "ingestion_sources": {
      "type": "array",
      "minItems": 1
    },
    "backfill": {
      "type": "object",
      "required": [
        "window_days",
        "completed"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "platform": {
    "picked": "Dovetail",
    "scorecard": [
      {
        "platform": "Dovetail",
        "api": 5,
        "ai": 4,
        "integrations": 5,
        "cost": 3,
        "zdr": 4
      },
      {
        "platform": "Condens",
        "api": 3,
        "ai": 3,
        "integrations": 3,
        "cost": 4,
        "zdr": 3
      },
      {
        "platform": "Looppanel",
        "api": 3,
        "ai": 5,
        "integrations": 3,
        "cost": 3,
        "zdr": 3
      }
    ]
  },
  "taxonomy": {
    "classes": [
      "segment",
      "pain",
      "jtbd",
      "behavior"
    ],
    "tag_count": 47
  },
  "access_matrix": {
    "admin": [
      "read",
      "tag",
      "edit",
      "admin"
    ],
    "researcher": [
      "read",
      "tag",
      "edit"
    ],
    "read_only": [
      "read"
    ]
  },
  "ingestion_sources": [
    "Otter",
    "Looppanel",
    "Intercom",
    "PostHog"
  ],
  "backfill": {
    "window_days": 90,
    "completed": true
  }
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platform": {
    "picked": "Dovetail"
  },
  "taxonomy": {
    "tag_count": 5
  }
}
]]></code>
    <note>Platform scorecard missing; tag_count below 30 floor; access_matrix/ingestion_sources/backfill absent.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="single-vendor-pick">Platform selection without a scorecard of &gt;=3 candidates.</pattern>
      <pattern id="tag-count-out-of-range">Taxonomy with &lt;30 or &gt;80 tags at setup.</pattern>
      <pattern id="zero-day-backfill">Setup published without a 90-day backfill.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-research-repository-setup.py">Validator script (see scripts/).</reference>
</text>
