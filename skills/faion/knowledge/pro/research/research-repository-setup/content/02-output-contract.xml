<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Research Repository Setup — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>A method artefact: trigger named, output shape fixed, evidence anchored, owner accountable, and reviewed against outcomes at a published cadence.</summary>

  <section title="Required fields">
    <list>
      <item>trigger (event / threshold / schedule)</item>
      <item>output.shape (template / schema / artefact path)</item>
      <item>conclusion.evidence_links</item>
      <item>owner (named)</item>
      <item>review.cadence + review.last_run_at</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>trigger &apos;when needed&apos;</description>
      <reason>Either fires constantly or never.</reason>
    </antipattern>
    <antipattern>
      <description>free-form output</description>
      <reason>One-off and unreusable.</reason>
    </antipattern>
    <antipattern>
      <description>unevidenced conclusions</description>
      <reason>Demote to hypothesis.</reason>
    </antipattern>
    <antipattern>
      <description>no outcome review</description>
      <reason>Methodology becomes folklore.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Trigger named and concrete.</item>
      <item>Output shape fixed.</item>
      <item>Each conclusion has evidence links.</item>
      <item>Owner accountable for next actions.</item>
      <item>Outcome review run at published cadence.</item>
    </list>
  </section>
</text>
