<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Research Repository Operations Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/research-repository-ops.json",
  "type": "object",
  "required": [
    "week",
    "throughput",
    "retention_pass",
    "access_changes"
  ],
  "properties": {
    "week": {
      "type": "string"
    },
    "throughput": {
      "type": "object",
      "required": [
        "ingested",
        "tagged",
        "deduped"
      ]
    },
    "retention_pass": {
      "type": "object",
      "required": [
        "archived",
        "deleted",
        "kept"
      ]
    },
    "access_changes": {
      "type": "array"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "week": "2026-W21",
  "throughput": {
    "ingested": 612,
    "tagged": 598,
    "deduped": 14
  },
  "retention_pass": {
    "archived": 12,
    "deleted": 0,
    "kept": 1240
  },
  "access_changes": [
    {
      "action": "remove",
      "user": "ex-employee@example.com",
      "reason": "off-boarded"
    }
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "week": "this week",
  "throughput": {
    "ingested": -1
  }
}
]]></code>
    <note>Week not ISO format; ingested is negative; retention_pass and access_changes missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="name-only-dedup">Deduplication by name only (collision risk).</pattern>
      <pattern id="silent-week">Health report skipped or empty without explanation.</pattern>
      <pattern id="delete-without-legal">Delete operation on a study without legal review.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-research-repository-operations.py">Validator script (see scripts/).</reference>
</text>
