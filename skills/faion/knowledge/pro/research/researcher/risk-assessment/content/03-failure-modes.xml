<text id="03-failure-modes" title="Risk Assessment Failure Modes" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Antipatterns observed in real deployments of Risk Assessment. Each ties a symptom to a root cause and a concrete fix.</summary>
  <section title="Antipatterns">
    <antipattern id="verbal-likelihood-drift" severity="high">
      <symptom>Risk listed with likelihood='medium'; different reviewers interpret differently.</symptom>
      <root-cause source="Internal — risk calibration policy">Author used qualitative descriptors.</root-cause>
      <fix>Replace with P10/P50/P90 numeric bands; lint at audit.</fix>
    </antipattern>
    <antipattern id="unowned-risks" severity="high">
      <symptom>Top 5 risks have owner='team'.</symptom>
      <root-cause source="Internal — Q3 2025 risk autopsy">No accountability lock at authoring.</root-cause>
      <fix>Require named individual owner; reject 'team' / 'TBD'.</fix>
    </antipattern>
    <antipattern id="vague-triggers" severity="medium">
      <symptom>Trigger phrased as 'if churn rises'.</symptom>
      <root-cause source="Internal — runtime-monitor mapping">Author skipped operational thresholds.</root-cause>
      <fix>Require metric + threshold + window: 'monthly churn &gt; 4% for 2 consecutive months'.</fix>
    </antipattern>
    <antipattern id="monitor-as-decision" severity="medium">
      <symptom>Decision='monitor'; nothing ever happens.</symptom>
      <root-cause source="Internal — decision-record spec">Confused trigger with decision.</root-cause>
      <fix>Force escalate|accept|mitigate; monitor is the trigger phase, not the decision.</fix>
    </antipattern>
  </section>
</text>
