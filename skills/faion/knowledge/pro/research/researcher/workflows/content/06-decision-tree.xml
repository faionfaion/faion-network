<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Research Workflows Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="goal-shape">What does the user want?</root-question>
      <branch when="goal == single_methodology">
        <conclusion ref="skip-this-methodology" verdict="call the methodology directly"/>
      </branch>
      <branch when="goal == composite_research">
        <question id="mode-clear">Is the canonical mode obvious?</question>
          <branch when="mode == ambiguous">
            <conclusion ref="eight-canonical-modes" verdict="halt; clarify the mode with the user"/>
          </branch>
          <branch when="mode == clear">
            <conclusion ref="each-step-names-methodology" verdict="compose workflow plan with &lt;=6 steps"/>
          </branch>
      </branch>
  </decision-tree>
  <example trace="goal=composite_research -&gt; mode=personas -&gt; compose 2-step plan.">Worked path from root-question to conclusion.</example>
</text>
