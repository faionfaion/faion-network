<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="User Research at Scale Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="volume">Sessions per week?</root-question>
      <branch when="n &lt; 500">
        <conclusion ref="skip-this-methodology" verdict="small-N study; use manual coding instead"/>
      </branch>
      <branch when="n &gt;= 500">
        <question id="pii-mode">Are transcripts PII-bearing?</question>
          <branch when="pii == true">
            <question id="zdr-ready">ZDR endpoint configured?</question>
              <branch when="zdr == false">
                <conclusion ref="zdr-only-for-pii" verdict="halt; configure ZDR before any LLM call"/>
              </branch>
              <branch when="zdr == true">
                <conclusion ref="frozen-codebook-plus-overflow" verdict="run 9-stage pipeline with HITL gate"/>
              </branch>
          </branch>
          <branch when="pii == false">
            <conclusion ref="hitl-gate-before-publish" verdict="run 9-stage pipeline; HITL still mandatory"/>
          </branch>
      </branch>
  </decision-tree>
  <example trace="n=612 -&gt; pii=true -&gt; zdr=true -&gt; run pipeline -&gt; HITL gate accepts 3/5 findings.">Worked path from root-question to conclusion.</example>
</text>
