<text id="06-decision-tree" title="Research Frameworks Router Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="goal-shape">What shape is the goal?</root-question>
      <branch when="goal == sizing">
        <conclusion ref="name-the-slug" verdict="load market-research-tam-sam-som"/>
      </branch>
      <branch when="goal == competitive_structure">
        <conclusion ref="name-the-slug" verdict="load competitor-analysis or competitive-intelligence"/>
      </branch>
      <branch when="goal == user_motivation">
        <conclusion ref="name-the-slug" verdict="load persona-building or user-research-at-scale"/>
      </branch>
      <branch when="goal == prioritization">
        <conclusion ref="name-the-slug" verdict="load opportunity-solution-trees or risk-assessment"/>
      </branch>
      <branch when="goal == business_model">
        <conclusion ref="name-the-slug" verdict="load business-model-research"/>
      </branch>
      <branch when="goal == undefined_brainstorm">
        <conclusion ref="skip-this-methodology" verdict="run idea-generation first; no framework matches yet"/>
      </branch>
  </decision-tree>
  <example trace="goal=sizing -&gt; pick market-research-tam-sam-som -&gt; emit decision-record.">Worked path from root-question to conclusion.</example>
</text>
