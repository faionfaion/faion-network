<methodology slug="methodologies-detail">
  <metadata>
    <tier>pro</tier>
    <group>research</group>
    <domain>researcher</domain>
    <summary>Flat TOC of 20 research methodologies with abridged frameworks, agent modes, and routing rules. Use to look up names, then load the canonical per-methodology folder.</summary>
    <tags>
      <tag>reference</tag>
      <tag>methodology-index</tag>
      <tag>research-methods</tag>
      <tag>cheat-sheet</tag>
      <tag>routing</tag>
    </tags>
    <difficulty>beginner</difficulty>
    <created>2026-04-29</created>
    <updated>2026-05-01</updated>
