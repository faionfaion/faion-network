<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agency Revenue Mix Audit Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Defines the quarterly audit report schema.</summary>

  <output-contract>
    <required>
      <field name="audit_metadata">
        <subfield name="quarter_label" type="string"/>
        <subfield name="window_quarters" type="integer" min="6" max="6"/>
        <subfield name="auditor" type="string"/>
        <subfield name="audited_at" type="iso_date"/>
      </field>
      <field name="line_classified_revenue" format="quarterly_table">
        <subfield name="rows[].quarter" type="string"/>
        <subfield name="rows[].project_revenue" type="number"/>
        <subfield name="rows[].retainer_revenue" type="number"/>
        <subfield name="rows[].productized_revenue" type="number"/>
        <subfield name="rows[].misc_revenue" type="number"/>
      </field>
      <field name="margin_per_line_per_quarter" format="quarterly_table">
        <subfield name="rows[].quarter" type="string"/>
        <subfield name="rows[].project_margin_percent" type="number"/>
        <subfield name="rows[].retainer_margin_percent" type="number"/>
        <subfield name="rows[].productized_margin_percent" type="number"/>
      </field>
      <field name="concentration">
        <subfield name="within_line_top_3_percent" type="dict"/>
        <subfield name="across_all_top_3_percent" type="number"/>
      </field>
      <field name="reclassification_log" format="list"/>
      <field name="decision_questions" min_items="5" max_items="5">
        <subfield name="decision_questions[].question" type="string"/>
        <subfield name="decision_questions[].recommended_answer" enum="YES,NO,DEFER"/>
        <subfield name="decision_questions[].evidence_summary" type="string"/>
        <subfield name="decision_questions[].follow_up_owner" type="string"/>
      </field>
    </required>

    <forbidden>
      <pattern id="f1">window_quarters != 6</pattern>
      <pattern id="f2">line_classified_revenue with any quarter where project+retainer+productized+misc != total_revenue for that quarter</pattern>
      <pattern id="f3">margin_per_line_per_quarter missing direct_costs sourcing notes</pattern>
      <pattern id="f4">concentration computed at only one level (within-line OR across-all, not both)</pattern>
      <pattern id="f5">decision_questions count != 5</pattern>
      <pattern id="f6">audit_report missing line-mix trend chart OR margin-per-line trend table</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>"Productized" line may show 0 if not yet launched — keep the row to track its introduction.</transformation>
      <transformation>For agencies with &lt; 6 quarters of history, the audit runs in "preliminary" mode with quarter_count noted; full audit deferred until window populates.</transformation>
      <transformation>Decision question recommendations may be DEFER with explicit re-evaluation date (e.g., "revisit Q3'26") — does not bypass the 5-question requirement.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/audit-report.md"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>exactly 6 quarters in window</item>
      <item>every invoice classified to a line; reclassification_log populated for edge cases</item>
      <item>direct_costs sourced from accounting (not estimated) per quarter</item>
      <item>both within-line + across-all concentration computed</item>
      <item>exactly 5 decision questions with YES/NO/DEFER + evidence + owner</item>
      <item>trend chart shows all 6 quarters; margin table shows all 6 quarters</item>
    </list>
  </section>
</text>
