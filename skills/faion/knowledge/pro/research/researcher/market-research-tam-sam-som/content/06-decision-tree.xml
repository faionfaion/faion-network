<text id="06-decision-tree" title="Market Research: TAM/SAM/SOM Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="scope-fixed">Geography + ICP + price band pinned?</root-question>
      <branch when="scope == not_pinned">
        <conclusion ref="geo-and-icp-pinned" verdict="STOP; pin geography + ICP before any number"/>
      </branch>
      <branch when="scope == pinned">
        <question id="sources-available">Industry report + bottom-up data available?</question>
          <branch when="sources == none">
            <conclusion ref="skip-this-methodology" verdict="category-creation; cannot size TAM yet"/>
          </branch>
          <branch when="sources == top_down_only">
            <conclusion ref="both-top-down-and-bottom-up" verdict="build bottom-up before publishing"/>
          </branch>
          <branch when="sources == both">
            <conclusion ref="reconcile-30pct-delta" verdict="compute both, triangulate, tag confidence"/>
          </branch>
      </branch>
  </decision-tree>
  <example trace="scope=pinned -&gt; sources=both -&gt; compute TAM/SAM/SOM -&gt; delta=18% (within tolerance) -&gt; confidence=medium.">Worked path from root-question to conclusion.</example>
</text>
