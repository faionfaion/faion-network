<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Trend Analysis Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/trend-analysis.json",
  "type": "object",
  "required": [
    "trends"
  ],
  "properties": {
    "trends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "signals",
          "composite_score",
          "decay_curve",
          "verdict"
        ],
        "properties": {
          "composite_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "verdict": {
            "enum": [
              "hype",
              "structural"
            ]
          }
        }
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "trends": [
    {
      "name": "on-device LLM inference",
      "signals": {
        "search": 78,
        "papers": 62,
        "funding": 71,
        "github_stars": 85,
        "social": 64
      },
      "composite_score": 72,
      "decay_curve": {
        "q1": 0.95,
        "q2": 0.9,
        "q3": 0.85,
        "q4": 0.8
      },
      "verdict": "structural"
    }
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "trends": [
    {
      "name": "AI",
      "signals": {
        "twitter": 99
      }
    }
  ]
}
]]></code>
    <note>Only 1 signal class (need &gt;=5); composite_score missing; decay_curve absent; verdict missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="single-signal-class">Trend with fewer than 5 signal classes.</pattern>
      <pattern id="no-decay-curve">Trend without a 4-quarter decay-curve estimate.</pattern>
      <pattern id="unflagged-trend">Trend without hype|structural flag.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-trend-analysis.py">Validator script (see scripts/).</reference>
</text>
