<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Distribution Channel Research Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="budget">Test budget available?</root-question>
      <branch when="budget &lt; $1500">
        <conclusion ref="skip-this-methodology" verdict="skip; cannot fund 3x$500 tests"/>
      </branch>
      <branch when="budget &gt;= $1500">
        <question id="icp-stable">Is ICP stable?</question>
          <branch when="icp == drifting">
            <conclusion ref="skip-this-methodology" verdict="halt; re-run persona-building first"/>
          </branch>
          <branch when="icp == stable">
            <question id="platform-lock">Single platform mandates one channel?</question>
              <branch when="lock == true">
                <conclusion ref="skip-this-methodology" verdict="use the mandated channel; methodology unnecessary"/>
              </branch>
              <branch when="lock == false">
                <conclusion ref="shortlist-three-channels" verdict="run full 19-&gt;3-&gt;2 bullseye pipeline"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="budget=$2k -&gt; icp=stable -&gt; lock=false -&gt; shortlist 3 channels and run tests.">Worked path from root-question to conclusion.</example>
</text>
