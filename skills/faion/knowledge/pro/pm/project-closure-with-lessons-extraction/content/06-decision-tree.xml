<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Project Closure with Lessons Extraction Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping closure-report state to a rule.</summary>

  <decision-tree>
    <root-question id="q-variance">Is outcome-vs-charter variance documented with reason?</root-question>

    <branch when="variance_missing == true">
      <conclusion ref="outcome-vs-charter" verdict="compute and document variance + reason"/>
    </branch>
    <branch when="variance_missing == false">
      <question id="q-behaviour">Is every lesson phrased as a behaviour change?</question>
      <branch when="lesson_generic == true">
        <conclusion ref="behaviour-change-lessons" verdict="rewrite generic lessons as verb+object+signal"/>
      </branch>
      <branch when="lesson_generic == false">
        <question id="q-owner">Does every lesson have a named owner?</question>
        <branch when="owner_missing == true">
          <conclusion ref="named-owner-per-lesson" verdict="assign owner per lesson"/>
        </branch>
        <branch when="owner_missing == false">
          <question id="q-date">Does every lesson have a target adoption date ≤ 90 days?</question>
          <branch when="date_invalid == true">
            <conclusion ref="target-adoption-date" verdict="set concrete date within 90 days"/>
          </branch>
          <branch when="date_invalid == false">
            <question id="q-review">Is the next-project review scheduled?</question>
            <branch when="next_review_missing == true">
              <conclusion ref="next-project-review" verdict="schedule lesson-adoption review at next kick-off"/>
            </branch>
            <branch when="next_review_missing == false">
              <conclusion ref="outcome-vs-charter" verdict="accept closure report"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="phoenix-rescue">
    variance_missing=false, lesson_generic=false, owner_missing=false, date_invalid=false, next_review_missing=false → accept closure report.
  </example>
</text>
