<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Post-Handover Warranty Runbook Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping runbook state to a rule.</summary>

  <decision-tree>
    <root-question id="q-precond">Does every step have an observable precondition?</root-question>

    <branch when="precond_missing == true">
      <conclusion ref="preconditions-explicit" verdict="add precondition or remove step"/>
    </branch>
    <branch when="precond_missing == false">
      <question id="q-actor">Is actor named as role+system on every step?</question>
      <branch when="actor_vague == true">
        <conclusion ref="named-actor" verdict="rewrite vague actor with role+system"/>
      </branch>
      <branch when="actor_vague == false">
        <question id="q-rollback">Do all side-effect steps have rollback or STOP?</question>
        <branch when="rollback_missing == true">
          <conclusion ref="rollback-or-stop" verdict="add rollback path or hard STOP"/>
        </branch>
        <branch when="rollback_missing == false">
          <question id="q-budget">Do all phases publish wall-clock budget?</question>
          <branch when="budget_missing == true">
            <conclusion ref="timeboxed-checkpoints" verdict="add per-phase budget"/>
          </branch>
          <branch when="budget_missing == false">
            <question id="q-record">Are run-records committed after execution?</question>
            <branch when="records_missing == true">
              <conclusion ref="post-action-record" verdict="enforce run-record artefact per execution"/>
            </branch>
            <branch when="records_missing == false">
              <conclusion ref="preconditions-explicit" verdict="accept runbook"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="checkout-api-30d-warranty">
    precond_missing=false, actor_vague=false, rollback_missing=false, budget_missing=false, records_missing=false → accept runbook.
  </example>
</text>
