{
  "__faion_header__": {
    "purpose": "JSON Schema (draft-07) for the Client Handover Master Checklist output contract",
    "consumes": "subagent-generated artefact",
    "produces": "validated checklist artefact",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "~400 tokens when loaded as schema reference"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pm/client-handover-master-checklist.json",
  "title": "Client Handover Master Checklist",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "decision",
    "rationale",
    "inputs_used",
    "version",
    "last_reviewed",
    "items"
  ],
  "additionalProperties": true,
  "properties": {
    "artefact_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "not": {
        "enum": [
          "team",
          "we",
          "us",
          "engineering"
        ]
      }
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 40
    },
    "inputs_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "text",
          "done",
          "owner"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          },
          "owner": {
            "type": "string"
          },
          "due_by": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
