<text id="02-output-contract" title="Cross-Tool Migration Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>JSON Schema draft-07 for the playbook-step artefact this methodology produces. Validator rejects artefacts that violate the schema or any forbidden pattern.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cross-tool-migration.json",
  "type": "object",
  "required": [
    "source_tool",
    "target_tool",
    "phase_state",
    "field_map_path",
    "identity_merge_strategy",
    "rollback_gate"
  ],
  "properties": {
    "source_tool": {
      "type": "string"
    },
    "target_tool": {
      "type": "string"
    },
    "phase_state": {
      "type": "object",
      "required": [
        "discover",
        "field_map",
        "dry_run",
        "cutover",
        "verify",
        "decommission"
      ],
      "properties": {
        "discover": {
          "enum": [
            "pending",
            "in-progress",
            "done"
          ]
        },
        "field_map": {
          "enum": [
            "pending",
            "in-progress",
            "done"
          ]
        },
        "dry_run": {
          "enum": [
            "pending",
            "in-progress",
            "done"
          ]
        },
        "cutover": {
          "enum": [
            "pending",
            "in-progress",
            "done"
          ]
        },
        "verify": {
          "enum": [
            "pending",
            "in-progress",
            "done"
          ]
        },
        "decommission": {
          "enum": [
            "pending",
            "in-progress",
            "done"
          ]
        }
      }
    },
    "field_map_path": {
      "type": "string",
      "minLength": 1
    },
    "identity_merge_strategy": {
      "enum": [
        "sso-mapping",
        "manual-roster",
        "email-fallback"
      ]
    },
    "rollback_gate": {
      "type": "object",
      "required": [
        "deadline",
        "rollback_owner",
        "verification_criteria"
      ],
      "properties": {
        "deadline": {
          "type": "string",
          "format": "date-time"
        },
        "rollback_owner": {
          "type": "string"
        },
        "verification_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "source_tool": "jira",
  "target_tool": "linear",
  "phase_state": {
    "discover": "done",
    "field_map": "done",
    "dry_run": "done",
    "cutover": "in-progress",
    "verify": "pending",
    "decommission": "pending"
  },
  "field_map_path": "./field-map.yaml",
  "identity_merge_strategy": "sso-mapping",
  "rollback_gate": {
    "deadline": "2026-06-15T20:00:00Z",
    "rollback_owner": "U_PM",
    "verification_criteria": [
      "issue parity 100%",
      "comment parity 100%",
      "attachment parity 100%"
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "source_tool": "jira",
  "target_tool": "linear",
  "phase_state": {
    "discover": "done"
  },
  "field_map_path": "",
  "identity_merge_strategy": "guess",
  "rollback_gate": {}
}
]]></code>
    <note>phase_state missing 5 of 6 phases; field_map_path empty; identity_merge_strategy not in enum; rollback_gate empty.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>decommission phase != 'pending' while verify phase != 'done'.</item>
      <item>cutover phase != 'pending' while dry_run phase != 'done'.</item>
      <item>identity_merge_strategy = 'email-fallback' when SSO is available.</item>
      <item>field_map_path pointing to a draft or scratchpad — must be reviewable artefact.</item>
      <item>rollback_gate.deadline in the past at cutover start.</item>
    </list>
  </section>

  <reference path="scripts/validate-cross-tool-migration.py">Validator script enforcing this schema</reference>
</text>
