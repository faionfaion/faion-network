<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Scope Management Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Requirement / change event?</root-question>
    <branch when="signal == new_requirement">
      <conclusion ref="ac-per-must" verdict="MoSCoW + AC + source stakeholder; lint via moscow-lint.py"/>
    </branch>
    <branch when="signal == change_request">
      <conclusion ref="baseline-then-cr" verdict="compute cross-area delta; cost/schedule/risk impact"/>
    </branch>
    <branch when="signal == must_marked_wont">
      <conclusion ref="must-never-wont" verdict="block; force sponsor decision (descope must OR cancel)"/>
    </branch>
    <branch when="signal == rtm_update">
      <conclusion ref="rtm-in-source-control" verdict="unified diff to rtm.yaml; trace-check.py"/>
    </branch>
  </decision-tree>
</text>
