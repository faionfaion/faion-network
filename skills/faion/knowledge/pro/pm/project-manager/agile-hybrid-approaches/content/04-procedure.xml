<text id="04-procedure" title="Agile Hybrid Approaches Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>6-step procedure to choose + re-evaluate mode.</summary>

  <section title="Procedure">
    <step n="1" name="gather">
      <input>Charter + team profile + domain notes</input>
      <action>Collect evidence per dimension; assign rater per dimension.</action>
      <output>Evidence pack</output>
    </step>
    <step n="2" name="score">
      <input>Evidence pack</input>
      <action>Score 0-1 per dimension; cite evidence per score.</action>
      <output>Scored dimensions</output>
      <decision-gate>Reject scores without evidence.</decision-gate>
    </step>
    <step n="3" name="recommend">
      <input>Scored dimensions</input>
      <action>Run approach-score.py; produce recommendation + average.</action>
      <output>Recommendation</output>
    </step>
    <step n="4" name="debate">
      <input>Recommendation + team + sponsor</input>
      <action>Walk recommendation; if hybrid, name the tilt with boundaries.</action>
      <output>Final mode + named hybrid tilt (if hybrid)</output>
      <decision-gate>If hybrid, reject record without named tilt.</decision-gate>
    </step>
    <step n="5" name="record">
      <input>Final mode + dimensions</input>
      <action>Commit decision record (ADR-style); sponsor signs.</action>
      <output>Committed ADR</output>
    </step>
    <step n="6" name="re-evaluate">
      <input>Velocity + escalation metrics</input>
      <action>When trigger fires, re-run scoring; reconvene decision.</action>
      <output>Updated ADR (if mode changes)</output>
    </step>
  </section>
</text>
