<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agile Hybrid Approaches Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping score state to a rule.</summary>

  <decision-tree>
    <root-question id="q-six-dim">Are all 6 dimensions scored?</root-question>

    <branch when="dims_complete == false">
      <conclusion ref="six-dimension-score" verdict="score all 6 Boehm + Turner dimensions before recommending"/>
    </branch>
    <branch when="dims_complete == true">
      <question id="q-evidence">Does every dimension cite evidence?</question>
      <branch when="evidence_missing == true">
        <conclusion ref="evidence-per-dimension" verdict="add evidence citation per dimension"/>
      </branch>
      <branch when="evidence_missing == false">
        <question id="q-avg">Average score range?</question>
        <branch when="avg &gt;= 0.7">
          <conclusion ref="six-dimension-score" verdict="recommend agile mode"/>
        </branch>
        <branch when="avg &lt;= 0.3">
          <conclusion ref="six-dimension-score" verdict="recommend predictive mode"/>
        </branch>
        <branch when="avg &gt; 0.3 AND avg &lt; 0.7">
          <question id="q-tilt">Is the hybrid tilt named with boundaries?</question>
          <branch when="tilt_unnamed == true">
            <conclusion ref="named-hybrid-tilt" verdict="name hybrid tilt with explicit per-workstream boundary"/>
          </branch>
          <branch when="tilt_unnamed == false">
            <question id="q-triggers">Are ≥2 reevaluation triggers set?</question>
            <branch when="triggers_few == true">
              <conclusion ref="reevaluation-triggers" verdict="add ≥2 measurable triggers"/>
            </branch>
            <branch when="triggers_few == false">
              <conclusion ref="decision-record-committed" verdict="accept decision; commit to version control with sponsor signature"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="regulated-claims-platform">
    dims_complete=true, evidence_missing=false, avg=0.48 (hybrid), tilt_unnamed=false, triggers_few=false → accept decision.
  </example>
</text>
