<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agency Cash-Flow Friday Routine Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping artefact state to a rule.</summary>

  <decision-tree>
    <root-question id="q-time">Did the routine complete within 15 minutes?</root-question>

    <branch when="time_over == true">
      <conclusion ref="fifteen-min-cap" verdict="trim checks or pre-export to fit 15 min"/>
    </branch>
    <branch when="time_over == false">
      <question id="q-items">All 5 mandatory items checked?</question>
      <branch when="items_missing == true">
        <conclusion ref="five-mandatory-items" verdict="complete all 5 checks before logging"/>
      </branch>
      <branch when="items_missing == false">
        <question id="q-action">Every amber/red item has named action?</question>
        <branch when="amber_no_action == true">
          <conclusion ref="named-action-when-amber" verdict="add named action before closing routine"/>
        </branch>
        <branch when="amber_no_action == false">
          <question id="q-ledger">Was ledger entry committed?</question>
          <branch when="ledger_missing == true">
            <conclusion ref="ledger-entry-mandatory" verdict="append ledger row before publishing"/>
          </branch>
          <branch when="ledger_missing == false">
            <question id="q-runway">Is runway &lt; 3 months?</question>
            <branch when="runway_critical == true">
              <conclusion ref="runway-trigger" verdict="activate contingency plan"/>
            </branch>
            <branch when="runway_critical == false">
              <conclusion ref="fifteen-min-cap" verdict="accept routine"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="2026-05-22">
    time_over=false, items_missing=false, amber_no_action=false, ledger_missing=false, runway_critical=false → accept routine.
  </example>
</text>
