<text id="06-decision-tree" title="Agency Pipeline Hygiene 15min Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping artefact state to a rule.</summary>

  <decision-tree>
    <root-question id="q-time">Did routine complete within 15 min?</root-question>

    <branch when="time_over == true">
      <conclusion ref="fifteen-min-cap" verdict="reduce checks or pre-export"/>
    </branch>
    <branch when="time_over == false">
      <question id="q-items">All 5 items checked?</question>
      <branch when="items_missing == true">
        <conclusion ref="five-items" verdict="complete all 5 items"/>
      </branch>
      <branch when="items_missing == false">
        <question id="q-hot">Every hot opp has named next-step?</question>
        <branch when="hot_missing_next == true">
          <conclusion ref="hot-opp-next-step" verdict="add next-step + owner + by-when"/>
        </branch>
        <branch when="hot_missing_next == false">
          <question id="q-loss">Every closed-lost tagged with reason?</question>
          <branch when="loss_untagged == true">
            <conclusion ref="loss-reason-tagged" verdict="apply bounded-enum loss reason"/>
          </branch>
          <branch when="loss_untagged == false">
            <question id="q-source">Every new opp tagged with source?</question>
            <branch when="source_untagged == true">
              <conclusion ref="source-tagged" verdict="apply source tag on new opps"/>
            </branch>
            <branch when="source_untagged == false">
              <conclusion ref="fifteen-min-cap" verdict="accept routine"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="2026-05-22">
    time_over=false, items_missing=false, hot_missing_next=false, loss_untagged=false, source_untagged=false → accept routine.
  </example>
</text>
