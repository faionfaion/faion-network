<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="PMBoK Performance Domains Overview Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree on observables (project_duration_weeks, pmo_requires_assessment, framework_alignment) to apply / fall-back / skip. Each leaf references a rule id from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-duration">project_duration_weeks ≥ 4?</root-question>

    <branch when="project_duration_weeks &gt;= 4">
      <question id="q-pmo-required">PMO requires PMBoK-aligned assessment?</question>
      <branch when="pmo_requires_assessment == true">
        <conclusion ref="eight-domains-covered" verdict="apply full 8-domain rubric quarterly"/>
      </branch>
      <branch when="pmo_requires_assessment == false">
        <conclusion ref="skip-this-methodology" verdict="lightweight project — pick salient domains only"/>
      </branch>
    </branch>

    <branch when="project_duration_weeks &lt; 4">
      <conclusion ref="skip-this-methodology" verdict="too short — domains have no time to manifest"/>
    </branch>
  </decision-tree>

  <example trace="performance-domains-overview-canonical">
    project_duration_weeks=24 → pmo_requires_assessment=true → apply 8-domain rubric (rule eight-domains-covered).
  </example>
</text>
