<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agency P&amp;L Tracker Template Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping artefact state to a rule.</summary>

  <decision-tree>
    <root-question id="q-cadence">Was P&amp;L closed monthly?</root-question>

    <branch when="cadence_off == true">
      <conclusion ref="monthly-cadence" verdict="close every month; backfill last quarter if needed"/>
    </branch>
    <branch when="cadence_off == false">
      <question id="q-split">Revenue split into 3 lines?</question>
      <branch when="aggregate_only == true">
        <conclusion ref="revenue-line-split" verdict="split by project/retainer/productised"/>
      </branch>
      <branch when="aggregate_only == false">
        <question id="q-contractor">Contractor fees in COGS (not OpEx)?</question>
        <branch when="contractor_misclassed == true">
          <conclusion ref="contractor-vs-payroll" verdict="move contractor fees to COGS"/>
        </branch>
        <branch when="contractor_misclassed == false">
          <question id="q-util">Utilisation reported?</question>
          <branch when="util_missing == true">
            <conclusion ref="utilisation-mandatory" verdict="compute utilisation from time-tracking"/>
          </branch>
          <branch when="util_missing == false">
            <question id="q-variance">Variance vs annual plan computed?</question>
            <branch when="variance_missing == true">
              <conclusion ref="monthly-variance-vs-plan" verdict="compute variance + reason vs plan"/>
            </branch>
            <branch when="variance_missing == false">
              <conclusion ref="monthly-cadence" verdict="accept P&amp;L"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="acme-studio-2026-04">
    cadence_off=false, aggregate_only=false, contractor_misclassed=false, util_missing=false, variance_missing=false → accept P&amp;L.
  </example>
</text>
