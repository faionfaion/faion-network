<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Scope Change vs Scope Creep Detection Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Ticket triage outcome?</root-question>
    <branch when="signal == matches_signed_spec">
      <conclusion ref="signed-baseline-as-ground-truth" verdict="in_scope → accept; no further action"/>
    </branch>
    <branch when="signal == explicit_in_out_of_scope_list">
      <conclusion ref="evidence-citation-required" verdict="creep → pushback-message.md with quoted out-of-scope clause"/>
    </branch>
    <branch when="signal == new_value_outside_baseline">
      <conclusion ref="four-outcome-routing" verdict="legitimate_change → change-impact-draft.md → change-control board"/>
    </branch>
    <branch when="signal == citations_dont_resolve_cleanly">
      <conclusion ref="human-override-with-log" verdict="ambiguous → PM escalation brief"/>
    </branch>
  </decision-tree>
</text>
