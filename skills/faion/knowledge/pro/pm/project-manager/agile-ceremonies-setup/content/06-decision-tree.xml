<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agile Ceremonies Setup Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping config state to a rule.</summary>

  <decision-tree>
    <root-question id="q-purpose">Does every ceremony have a published purpose?</root-question>

    <branch when="purpose_missing == true">
      <conclusion ref="purpose-stated" verdict="add purpose statement per ceremony"/>
    </branch>
    <branch when="purpose_missing == false">
      <question id="q-timebox">Are time-boxes set + enforced?</question>
      <branch when="timebox_missing == true">
        <conclusion ref="timebox-per-event" verdict="set + enforce time-box per ceremony"/>
      </branch>
      <branch when="timebox_missing == false">
        <question id="q-actions">Every retro produces actions with owner + due?</question>
        <branch when="retro_actions_missing == true">
          <conclusion ref="retro-action-owner-due" verdict="enforce ≥1 retro action with owner + due-date"/>
        </branch>
        <branch when="retro_actions_missing == false">
          <question id="q-overhead">Is overhead_pct &lt; 0.10?</question>
          <branch when="overhead_high == true">
            <conclusion ref="overhead-under-10pct" verdict="retune time-boxes; merge or trim ceremonies"/>
          </branch>
          <branch when="overhead_high == false">
            <question id="q-attendees">Attendees mandatory/optional split set?</question>
            <branch when="attendees_open == true">
              <conclusion ref="attendees-bounded" verdict="bound attendees; move others to optional"/>
            </branch>
            <branch when="attendees_open == false">
              <conclusion ref="purpose-stated" verdict="accept config"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="platform-team-2w">
    purpose_missing=false, timebox_missing=false, retro_actions_missing=false, overhead_high=false, attendees_open=false → accept config.
  </example>
</text>
