<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Stakeholder Engagement Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Stakeholder quadrant?</root-question>
    <branch when="signal == high_power_high_interest">
      <conclusion ref="default-cadence-by-quadrant" verdict="Manage Closely — weekly 1:1; real-time dashboard"/>
    </branch>
    <branch when="signal == high_power_low_interest">
      <conclusion ref="default-cadence-by-quadrant" verdict="Keep Satisfied — biweekly; no surprises"/>
    </branch>
    <branch when="signal == low_power_high_interest">
      <conclusion ref="default-cadence-by-quadrant" verdict="Keep Informed — monthly digest"/>
    </branch>
    <branch when="signal == low_power_low_interest">
      <conclusion ref="default-cadence-by-quadrant" verdict="Monitor — release notes only"/>
    </branch>
    <branch when="signal == hidden_unmapped">
      <conclusion ref="hidden-stakeholder-pass" verdict="explicit search: legal/infosec/procurement/works-council/accessibility"/>
    </branch>
  </decision-tree>
</text>
