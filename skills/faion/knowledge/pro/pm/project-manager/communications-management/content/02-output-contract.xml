<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Communications Management Output Contract" version="1.1.0" est_tokens="850" depth="essential">
  <summary>JSON Schema draft-07 for the spec artefact this methodology produces. Validator rejects artefacts that violate the schema or any forbidden pattern.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/communications-management.json",
  "type": "object",
  "required": [
    "project_id",
    "comms_matrix",
    "decision_log_pointer",
    "meeting_cadence"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "comms_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "stakeholder",
          "artefact",
          "channel",
          "owner",
          "cadence",
          "format",
          "escalation"
        ],
        "properties": {
          "stakeholder": {
            "type": "string"
          },
          "artefact": {
            "type": "string"
          },
          "channel": {
            "enum": [
              "email",
              "slack",
              "teams",
              "confluence",
              "meeting",
              "report"
            ]
          },
          "owner": {
            "type": "string"
          },
          "cadence": {
            "enum": [
              "daily",
              "weekly",
              "biweekly",
              "monthly",
              "quarterly",
              "ad-hoc"
            ]
          },
          "format": {
            "type": "string"
          },
          "escalation": {
            "type": "string"
          }
        }
      }
    },
    "decision_log_pointer": {
      "type": "string",
      "format": "uri-reference"
    },
    "meeting_cadence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "meeting",
          "cadence",
          "owner"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "acme",
  "comms_matrix": [
    {
      "stakeholder": "sponsor",
      "artefact": "status report",
      "channel": "email",
      "owner": "U_PM",
      "cadence": "weekly",
      "format": "1-page md",
      "escalation": "U_HEAD_OF_DELIVERY"
    }
  ],
  "decision_log_pointer": "./decision-log.md",
  "meeting_cadence": [
    {
      "meeting": "weekly status",
      "cadence": "weekly",
      "owner": "U_PM"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "x",
  "comms_matrix": [],
  "decision_log_pointer": "",
  "meeting_cadence": []
}
]]></code>
    <note>comms_matrix empty; decision_log_pointer empty; meeting_cadence empty.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>comms_matrix row without escalation path.</item>
      <item>status-report channel with ad-hoc cadence.</item>
      <item>decision_log_pointer pointing to a mutable spreadsheet (sheet, doc, board).</item>
      <item>meeting cadence without owner.</item>
      <item>two rows for same stakeholder × artefact with conflicting cadence.</item>
    </list>
  </section>

  <reference path="scripts/validate-communications-management.py">Validator script enforcing this schema</reference>
</text>
