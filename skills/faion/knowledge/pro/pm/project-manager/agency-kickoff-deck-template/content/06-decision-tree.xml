<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agency Kickoff Deck Template Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping artefact state to a rule.</summary>

  <decision-tree>
    <root-question id="q-slides">Is deck ≤12 slides?</root-question>

    <branch when="slides_over == true">
      <conclusion ref="max-12-slides" verdict="trim deck to ≤12 slides"/>
    </branch>
    <branch when="slides_over == false">
      <question id="q-asks">Numbered decision-asks slide present?</question>
      <branch when="asks_missing == true">
        <conclusion ref="decision-asks-mandatory" verdict="add penultimate decision-asks slide"/>
      </branch>
      <branch when="asks_missing == false">
        <question id="q-owners">Workstream owners named (both sides)?</question>
        <branch when="owner_tbd == true">
          <conclusion ref="named-owners" verdict="negotiate named owners before kickoff"/>
        </branch>
        <branch when="owner_tbd == false">
          <question id="q-risks">Exactly 5 risks with owner + trigger?</question>
          <branch when="risks_count != 5">
            <conclusion ref="top-5-risks" verdict="select exactly top-5 risks"/>
          </branch>
          <branch when="risks_count == 5">
            <question id="q-comms">Comms cadence slide present?</question>
            <branch when="comms_missing == true">
              <conclusion ref="comms-cadence-explicit" verdict="add comms cadence slide before kickoff"/>
            </branch>
            <branch when="comms_missing == false">
              <conclusion ref="max-12-slides" verdict="accept deck"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="acme-checkout-kickoff">
    slides_over=false, asks_missing=false, owner_tbd=false, risks_count==5, comms_missing=false → accept deck.
  </example>
</text>
