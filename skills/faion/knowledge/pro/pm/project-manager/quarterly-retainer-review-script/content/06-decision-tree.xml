<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Quarterly Retainer Review Script Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Renewal decision?</root-question>
    <branch when="signal == continue">
      <conclusion ref="named-decision-exit" verdict="decision-record.decision=continue; next-review-date set"/>
    </branch>
    <branch when="signal == scale_up">
      <conclusion ref="scope-delta-written" verdict="scope_delta with hours_bought delta + deliverables + SLA; 24h follow-up"/>
    </branch>
    <branch when="signal == scope_down">
      <conclusion ref="scope-delta-written" verdict="scope_delta with hours_bought reduction; 24h follow-up"/>
    </branch>
    <branch when="signal == terminate">
      <conclusion ref="named-decision-exit" verdict="project-closure script triggered; transition handover"/>
    </branch>
    <branch when="signal == deferred_with_date">
      <conclusion ref="named-decision-exit" verdict="specific date ≤14d when client commits to one of 4 options"/>
    </branch>
  </decision-tree>
</text>
