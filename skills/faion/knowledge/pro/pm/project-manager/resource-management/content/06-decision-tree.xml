<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Resource Management Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Demand vs supply state?</root-question>
    <branch when="signal == underloaded_&lt;50">
      <conclusion ref="cap-effective-capacity-80" verdict="underutilized; reassign or descope"/>
    </branch>
    <branch when="signal == healthy_50_75">
      <conclusion ref="cap-effective-capacity-80" verdict="healthy with buffer; sustainable"/>
    </branch>
    <branch when="signal == optimal_75_85">
      <conclusion ref="stretch-bench" verdict="optimal; preserve stretch bench"/>
    </branch>
    <branch when="signal == hot_85_100">
      <conclusion ref="cap-effective-capacity-80" verdict="burnout risk rising; level via delay/split/add"/>
    </branch>
    <branch when="signal == over_100">
      <conclusion ref="cap-effective-capacity-80" verdict="unsustainable; level immediately via cut scope or extend timeline + sponsor CR"/>
    </branch>
  </decision-tree>
</text>
