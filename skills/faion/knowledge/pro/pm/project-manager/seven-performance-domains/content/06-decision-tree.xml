<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Seven Performance Domains (PMBoK 8) Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Artefact under which domain?</root-question>
    <branch when="signal == charter_or_value_stream">
      <conclusion ref="canonical-seven" verdict="Governance"/>
    </branch>
    <branch when="signal == wbs_or_rtm">
      <conclusion ref="canonical-seven" verdict="Scope"/>
    </branch>
    <branch when="signal == gantt_or_milestones">
      <conclusion ref="canonical-seven" verdict="Schedule"/>
    </branch>
    <branch when="signal == budget_or_evm">
      <conclusion ref="canonical-seven" verdict="Finance"/>
    </branch>
    <branch when="signal == comms_or_register">
      <conclusion ref="canonical-seven" verdict="Stakeholders"/>
    </branch>
    <branch when="signal == raci_or_team_charter">
      <conclusion ref="canonical-seven" verdict="Resources"/>
    </branch>
    <branch when="signal == risk_register">
      <conclusion ref="canonical-seven" verdict="Risk"/>
    </branch>
    <branch when="signal == homeless">
      <conclusion ref="default-to-governance" verdict="Governance (default)"/>
    </branch>
  </decision-tree>
</text>
