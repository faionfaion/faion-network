<text id="02-output-contract" title="Seven Performance Domains (PMBoK 8) Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the rubric artefact this methodology produces. The validator script enforces the schema.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/seven-performance-domains.json",
  "title": "Seven Performance Domains (PMBoK 8)",
  "type": "object",
  "required": [
    "__faion_header__",
    "rubric_id",
    "criteria"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces",
        "rules_satisfied"
      ],
      "properties": {
        "methodology": {
          "const": "seven-performance-domains"
        },
        "version": {
          "const": "1.1.0"
        },
        "produces": {
          "const": "rubric"
        },
        "rules_satisfied": {
          "type": "array",
          "items": {
            "enum": [
              "canonical-seven",
              "fixed-domain-order",
              "audit-before-steering",
              "gap-equals-risk",
              "default-to-governance"
            ]
          },
          "minItems": 1
        }
      }
    },
    "rubric_id": {
      "type": "string"
    },
    "criteria": {
      "type": "array",
      "minItems": 1
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item>Missing __faion_header__ block — every artefact MUST carry methodology, version, produces, rules_satisfied.</item>
      <item>rules_satisfied containing IDs outside the seven-performance-domains rule set.</item>
      <item>Empty top-level body (no sections / data / entries / items / criteria) — the artefact must carry payload, not metadata only.</item>
      <item>Free-form prose substituted for the typed sub-fields the schema requires.</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "seven-performance-domains",
    "version": "1.1.0",
    "produces": "rubric",
    "rules_satisfied": [
      "canonical-seven",
      "fixed-domain-order",
      "audit-before-steering"
    ]
  },
  "rubric_id": "seven-performance-domains-rubric-v1",
  "criteria": [
    {
      "id": "R1",
      "weight": 0.5
    }
  ]
}
]]></code>
    <note>Header carries methodology + version + produces + rules_satisfied; body matches the per-produces shape.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_path": "docs/seven-performance-domains.md"
}
]]></code>
    <note>Header missing → validator rejects; rules_satisfied not declared → no audit trail.</note>
  </example>

  <reference path="scripts/validate-seven-performance-domains.py">Validator script</reference>
</text>
