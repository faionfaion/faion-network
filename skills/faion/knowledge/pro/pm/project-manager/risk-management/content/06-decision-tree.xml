<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Risk Management Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Response strategy decision?</root-question>
    <branch when="signal == threat_low_cost_to_eliminate">
      <conclusion ref="track-opportunities-too" verdict="Avoid"/>
    </branch>
    <branch when="signal == threat_third_party_owns_skill">
      <conclusion ref="track-opportunities-too" verdict="Transfer (insurance / fixed-price / warranty)"/>
    </branch>
    <branch when="signal == threat_mitigatable">
      <conclusion ref="named-owner-with-trigger" verdict="Mitigate; assign owner + trigger + actions"/>
    </branch>
    <branch when="signal == threat_low_emv_or_unavoidable">
      <conclusion ref="contingency-for-accept" verdict="Accept WITH contingency line item = EMV"/>
    </branch>
    <branch when="signal == opportunity">
      <conclusion ref="track-opportunities-too" verdict="Exploit / Enhance / Share / Accept (with positive trigger)"/>
    </branch>
  </decision-tree>
</text>
