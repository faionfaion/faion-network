<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="PMBoK 8 Six Core Principles Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-1">Audit outcome?</root-question>
    <branch when="signal == all_six_pass_with_quotes">
      <conclusion ref="positive-evidence-required" verdict="stage gate passes; commit audit to record"/>
    </branch>
    <branch when="signal == any_principle_fail">
      <conclusion ref="fail-blocks-gate" verdict="block gate; require fix or escalation"/>
    </branch>
    <branch when="signal == sustainability_narrative_only">
      <conclusion ref="sustainability-numeric-proxy" verdict="reject; require numeric proxy"/>
    </branch>
    <branch when="signal == eighth_or_renamed_principle">
      <conclusion ref="canonical-six-names" verdict="reject; regenerate with canonical six"/>
    </branch>
  </decision-tree>
</text>
