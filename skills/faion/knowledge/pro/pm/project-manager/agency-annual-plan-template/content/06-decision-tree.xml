<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Agency Annual Plan Template Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping artefact state to a rule.</summary>

  <decision-tree>
    <root-question id="q-one-page">Does the plan fit on one page (≤600 words)?</root-question>

    <branch when="page_over == true">
      <conclusion ref="one-page" verdict="trim to one page; move model to appendix"/>
    </branch>
    <branch when="page_over == false">
      <question id="q-split">Are quarterly revenue targets split by line?</question>
      <branch when="aggregate_only == true">
        <conclusion ref="quarterly-targets-mandatory" verdict="split by project/retainer/productised"/>
      </branch>
      <branch when="aggregate_only == false">
        <question id="q-owner">Are all milestones named-owner?</question>
        <branch when="team_owner == true">
          <conclusion ref="named-milestone-owners" verdict="reassign team-owned milestones to named humans"/>
        </branch>
        <branch when="team_owner == false">
          <question id="q-cap">Are all investment lines capped + ROI-stated?</question>
          <branch when="uncapped_line == true">
            <conclusion ref="investment-line-cap" verdict="cap line; state expected return"/>
          </branch>
          <branch when="uncapped_line == false">
            <question id="q-checkpoint">Is quarterly checkpoint scheduled?</question>
            <branch when="checkpoint_missing == true">
              <conclusion ref="quarterly-checkpoint" verdict="schedule quarterly checkpoint with sponsor"/>
            </branch>
            <branch when="checkpoint_missing == false">
              <conclusion ref="one-page" verdict="accept plan"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="acme-studio-2026">
    page_over=false, aggregate_only=false, team_owner=false, uncapped_line=false, checkpoint_missing=false → accept plan.
  </example>
</text>
