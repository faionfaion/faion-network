<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Small Team Comms Rhythm Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Tree mapping team_size + ritual_count + sync_duration + founder_only to run / repair / graduate.</summary>

  <decision-tree>
    <root-question id="q-size">team_size in [2, 3]?</root-question>

    <branch when="team_size_out_of_range == true">
      <conclusion ref="r5-graduation-trigger" verdict="graduate: retire this methodology; adopt formal PM / agile framework"/>
    </branch>

    <branch when="team_size_out_of_range == false">
      <question id="q-rituals">ritual count == 3 (daily_pulse + weekly_sync + monthly_direction)?</question>

      <branch when="ritual_count_invalid == true">
        <conclusion ref="r1-three-rituals-only" verdict="repair: collapse extra rituals OR add missing; reject 4th recurring meeting"/>
      </branch>

      <branch when="ritual_count_invalid == false">
        <question id="q-async">daily_pulse.mode == async?</question>

        <branch when="daily_sync == true">
          <conclusion ref="r3-async-by-default" verdict="repair: convert daily standup to async text thread; do not run synchronous daily"/>
        </branch>

        <branch when="daily_sync == false">
          <question id="q-sync-duration">weekly_sync.duration_minutes_cap &lt;= 30 AND agenda_published_24h == true?</question>
          <branch when="sync_too_long_or_agendaless == true">
            <conclusion ref="r4-weekly-30-min-cap" verdict="repair: cap weekly at 30 min; require 24h agenda; postpone if missing"/>
          </branch>
          <branch when="sync_too_long_or_agendaless == false">
            <question id="q-founder">founder_only == false across cycle_log?</question>
            <branch when="founder_only_true == true">
              <conclusion ref="r2-founder-not-presenter" verdict="repair: every participant produces own pulse; founder one voice among 2-3"/>
            </branch>
            <branch when="founder_only_true == false">
              <conclusion ref="r1-three-rituals-only" verdict="run: continue rhythm; check graduation in next monthly check"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="indie-2-W20">
    size=2 → 3 rituals → async daily → weekly 30 min with agenda → not founder-only → run.
  </example>
</text>
