<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Trio Rituals Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the session artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/product-trio-session.json",
  "type": "object",
  "required": [
    "date",
    "attendees",
    "agenda",
    "decisions"
  ],
  "properties": {
    "date": {
      "type": "string",
      "format": "date"
    },
    "attendees": {
      "type": "object",
      "required": [
        "pm",
        "design",
        "eng"
      ],
      "properties": {
        "pm": {
          "type": "string"
        },
        "design": {
          "type": "string"
        },
        "eng": {
          "type": "string"
        }
      }
    },
    "agenda": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "topic",
          "owner",
          "desired_outcome",
          "timebox_minutes"
        ],
        "properties": {
          "topic": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "desired_outcome": {
            "type": "string"
          },
          "timebox_minutes": {
            "type": "integer",
            "maximum": 10
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "statement",
          "rationale",
          "follow_up_owner"
        ],
        "properties": {
          "statement": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          },
          "follow_up_owner": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "date": "2026-05-22",
  "attendees": {
    "pm": "Iryna",
    "design": "Olena",
    "eng": "Petro"
  },
  "agenda": [
    {
      "topic": "Apple Pay rollout sequencing",
      "owner": "Iryna",
      "desired_outcome": "decide canary geography",
      "timebox_minutes": 10
    }
  ],
  "decisions": [
    {
      "statement": "Canary in UA + PT first, US in week 6.",
      "rationale": "Latency + p95 measured better on EU edges; lower payment-method conversion volatility.",
      "follow_up_owner": "Petro"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "date": "2026-05-22",
  "attendees": {
    "pm": "x"
  }
}
]]></code>
    <note>Missing design/eng attendees; agenda missing; decisions missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="missing-role"><description>attendees.design or attendees.eng missing</description><reason>Session not trio.</reason></forbidden-pattern>
    <forbidden-pattern id="no-outcome"><description>agenda item missing desired_outcome</description><reason>Theatre, not movement.</reason></forbidden-pattern>
    <forbidden-pattern id="over-10-timebox"><description>timebox_minutes &gt; 10</description><reason>Breaks per-item discipline.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-product-trio-rituals.py">Validator script</reference>
</text>
