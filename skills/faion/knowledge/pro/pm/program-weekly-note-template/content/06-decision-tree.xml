<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Program Weekly Note Template Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping note state to a rule.</summary>

  <decision-tree>
    <root-question id="q-headline">Is headline one sentence ≤ 280 chars?</root-question>

    <branch when="headline_too_long == true">
      <conclusion ref="headline-one-sentence" verdict="cut headline to one sentence"/>
    </branch>
    <branch when="headline_too_long == false">
      <question id="q-evidence">Does every progress line cite evidence?</question>
      <branch when="evidence_missing == true">
        <conclusion ref="evidence-per-progress" verdict="attach evidence per progress line"/>
      </branch>
      <branch when="evidence_missing == false">
        <question id="q-top3">Are exactly 3 risks listed in risks_moved?</question>
        <branch when="risks_count != 3">
          <conclusion ref="top-3-risks-moved" verdict="reduce to exactly the 3 risks that moved most"/>
        </branch>
        <branch when="risks_count == 3">
          <question id="q-asks">Are sponsor asks numbered + decision-shaped?</question>
          <branch when="asks_malformed == true">
            <conclusion ref="numbered-sponsor-asks" verdict="rewrite asks as numbered decisions"/>
          </branch>
          <branch when="asks_malformed == false">
            <question id="q-outcomes">Is last-week outcomes table present + complete?</question>
            <branch when="outcomes_missing == true">
              <conclusion ref="last-week-outcomes" verdict="add last-week outcomes table"/>
            </branch>
            <branch when="outcomes_missing == false">
              <conclusion ref="headline-one-sentence" verdict="accept note"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="week-5-checkout-redesign">
    headline_too_long=false, evidence_missing=false, risks_count==3, asks_malformed=false, outcomes_missing=false → accept note.
  </example>
</text>
