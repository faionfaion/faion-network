<text id="03-failure-modes" title="PM Certification Exam Changes 2026 Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns observed in real deployments. Each pairs a symptom (observable signal) with root cause and concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="summary-only" severity="medium">
      <symptom>Diff is a paragraph with no task-level changes.</symptom>
      <root-cause>&lt;3 explicit task deltas listed</root-cause>
      <fix>List each added/removed/renamed task.</fix>
    </antipattern>

    <antipattern id="approximate-weights" severity="high">
      <symptom>Weights cited as 'around 33%'.</symptom>
      <root-cause>non-exact percentages used</root-cause>
      <fix>Use exact ECO percentages.</fix>
    </antipattern>

    <antipattern id="no-effective-date" severity="medium">
      <symptom>Reader unsure whether change applies to their sitting.</symptom>
      <root-cause>no 2026-07-01 mention</root-cause>
      <fix>Flag effective date prominently.</fix>
    </antipattern>

  </section>

  <see-also>
    <link path="content/01-core-rules.xml"/>
    <link path="content/06-decision-tree.xml"/>
  </see-also>
</text>
