<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Risk Register Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the register artefact. Validator enforces the 5 core rules at row level.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/risk-register-list.json",
  "type": "object",
  "required": [
    "project",
    "owner",
    "last_reviewed",
    "risks"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "category",
          "p",
          "i",
          "score",
          "strategy",
          "owner",
          "trigger",
          "evidence",
          "status",
          "last_reviewed"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R-\\d{3,}$"
          },
          "description": {
            "type": "string",
            "minLength": 6
          },
          "category": {
            "enum": [
              "technical",
              "vendor",
              "people",
              "regulatory",
              "market",
              "financial",
              "operational"
            ]
          },
          "p": {
            "enum": [
              "VL",
              "L",
              "M",
              "H",
              "VH"
            ]
          },
          "i": {
            "enum": [
              "VL",
              "L",
              "M",
              "H",
              "VH"
            ]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "strategy": {
            "enum": [
              "avoid",
              "transfer",
              "mitigate",
              "accept",
              "exploit",
              "enhance",
              "share"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 2
          },
          "trigger": {
            "type": "string",
            "minLength": 6
          },
          "evidence": {
            "type": "string",
            "minLength": 4
          },
          "status": {
            "enum": [
              "active",
              "closed_materialized",
              "closed_passed",
              "merged"
            ]
          },
          "last_reviewed": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project": "checkout-redesign-q2",
  "owner": "PM Iryna",
  "last_reviewed": "2026-05-22",
  "risks": [
    {
      "id": "R-001",
      "description": "Vendor API breaks",
      "category": "vendor",
      "p": "L",
      "i": "H",
      "score": 0.06,
      "strategy": "transfer",
      "owner": "Tech Lead",
      "trigger": "vendor changelog signals deprecation",
      "evidence": "contract-sow-v2.pdf section 4",
      "status": "active",
      "last_reviewed": "2026-05-22"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project": "x",
  "risks": [
    {
      "id": "1"
    }
  ]
}
]]></code>
    <note>Project name too short; risk row missing required columns; id not matching R-NNN.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="free-text-status"><description>Status field with values outside the enum</description><reason>Breaks diff/audit tooling.</reason></forbidden-pattern>
    <forbidden-pattern id="deleted-row"><description>Row removed across versions</description><reason>Destroys audit trail.</reason></forbidden-pattern>
    <forbidden-pattern id="empty-evidence"><description>Score field set with `evidence` empty</description><reason>Evidence-less scores converge to Medium.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-risk-register.py">Validator script</reference>
</text>
