<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Engagement Advanced Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for engagement plan.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-engagement-advanced.json",
  "type": "object",
  "required": [
    "as_of",
    "plans"
  ],
  "properties": {
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "plans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stakeholder_id",
          "current_engagement",
          "desired_engagement",
          "strategy",
          "indicators"
        ],
        "properties": {
          "stakeholder_id": {
            "type": "string",
            "pattern": "^S-\\d{3,}$"
          },
          "current_engagement": {
            "enum": [
              "unaware",
              "resistant",
              "neutral",
              "supportive",
              "leading"
            ]
          },
          "desired_engagement": {
            "enum": [
              "unaware",
              "resistant",
              "neutral",
              "supportive",
              "leading"
            ]
          },
          "strategy": {
            "type": "string",
            "minLength": 12
          },
          "indicators": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "name",
                "baseline",
                "target",
                "evidence_source"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "baseline": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "target": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "evidence_source": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "as_of": "2026-05-22",
  "plans": [
    {
      "stakeholder_id": "S-001",
      "current_engagement": "neutral",
      "desired_engagement": "supportive",
      "strategy": "Weekly 1:1 + show progress on the two metrics they raised at kickoff.",
      "indicators": [
        {
          "name": "attends weekly",
          "baseline": 0,
          "target": 1,
          "evidence_source": "calendar"
        },
        {
          "name": "approves PR within 24h",
          "baseline": 0.4,
          "target": 0.9,
          "evidence_source": "GitHub stats"
        }
      ]
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "plans": [
    {
      "stakeholder_id": "1",
      "strategy": ""
    }
  ]
}
]]></code>
    <note>as_of missing; plan missing required keys; indicators less than 2.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="vague-strategy"><description>strategy field shorter than 12 chars</description><reason>Non-actionable strategy.</reason></forbidden-pattern>
    <forbidden-pattern id="fewer-than-2-indicators"><description>indicators array length &lt; 2</description><reason>Single indicator is brittle.</reason></forbidden-pattern>
    <forbidden-pattern id="no-evidence-source"><description>indicator missing evidence_source</description><reason>Measurement cannot be re-derived.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-stakeholder-engagement-advanced.py">Validator script</reference>
</text>
