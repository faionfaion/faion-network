<text id="03-failure-modes" title="Cost Estimation Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns observed in real deployments. Each pairs a symptom (observable signal) with root cause and concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="flat-contingency" severity="high">
      <symptom>10% added to total without risk-register linkage.</symptom>
      <root-cause>contingency not traceable to risks</root-cause>
      <fix>Compute from EMV(risks); document linkage.</fix>
    </antipattern>

    <antipattern id="base-rate-only" severity="high">
      <symptom>Labour costed at base salary without overhead.</symptom>
      <root-cause>loading multiplier &lt;1.3</root-cause>
      <fix>Apply documented 1.3-1.5× multiplier.</fix>
    </antipattern>

    <antipattern id="oversized-package" severity="medium">
      <symptom>Single package estimated at 400 hours.</symptom>
      <root-cause>any package &gt;80h</root-cause>
      <fix>Decompose to ≤80h leaves.</fix>
    </antipattern>

  </section>

  <see-also>
    <link path="content/01-core-rules.xml"/>
    <link path="content/06-decision-tree.xml"/>
  </see-also>
</text>
