<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Scope Management Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping scope state to a rule.</summary>

  <decision-tree>
    <root-question id="q-exclusions">Is the out_of_scope list non-empty?</root-question>

    <branch when="out_of_scope_empty == true">
      <conclusion ref="exclusions-explicit" verdict="reject baseline; force explicit exclusions"/>
    </branch>
    <branch when="out_of_scope_empty == false">
      <question id="q-ac">Is every AC marked testable=true with observable criterion?</question>
      <branch when="ac_testable_all == false">
        <conclusion ref="ac-testable" verdict="rewrite untestable AC before baseline"/>
      </branch>
      <branch when="ac_testable_all == true">
        <question id="q-signed">Is baseline_signed=true?</question>
        <branch when="baseline_signed == false">
          <conclusion ref="signed-baseline" verdict="block downstream WBS; obtain sponsor signature first"/>
        </branch>
        <branch when="baseline_signed == true">
          <question id="q-rtm">Does RTM map every REQ to an AC and every AC to a REQ?</question>
          <branch when="rtm_orphans &gt; 0">
            <conclusion ref="rtm-complete" verdict="resolve orphans before release"/>
          </branch>
          <branch when="rtm_orphans == 0">
            <question id="q-cc">Are all changes routed through change-control?</question>
            <branch when="absorbed_changes &gt; 0">
              <conclusion ref="change-control-gate" verdict="recover unrecorded changes via retroactive CC"/>
            </branch>
            <branch when="absorbed_changes == 0">
              <conclusion ref="exclusions-explicit" verdict="accept scope"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="checkout-redesign">
    out_of_scope_empty=false, ac_testable_all=true, baseline_signed=true, rtm_orphans=0, absorbed_changes=0 → accept scope.
  </example>
</text>
