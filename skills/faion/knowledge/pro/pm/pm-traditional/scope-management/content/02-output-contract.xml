<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Scope Management Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the scope-statement artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/scope-statement.json",
  "type": "object",
  "required": [
    "project",
    "in_scope",
    "out_of_scope",
    "acceptance_criteria",
    "rtm",
    "baseline_signed",
    "sponsor"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 3
    },
    "sponsor": {
      "type": "string",
      "minLength": 2
    },
    "baseline_signed": {
      "type": "boolean"
    },
    "in_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 4
      },
      "minItems": 1
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 4
      },
      "minItems": 1
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "testable"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-\\d{3,}$"
          },
          "statement": {
            "type": "string",
            "minLength": 8
          },
          "testable": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "rtm": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "req_id",
          "source",
          "ac_id"
        ],
        "properties": {
          "req_id": {
            "type": "string",
            "pattern": "^REQ-\\d+$"
          },
          "source": {
            "type": "string"
          },
          "ac_id": {
            "type": "string",
            "pattern": "^AC-\\d{3,}$"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project": "checkout-redesign",
  "sponsor": "VP Engineering",
  "baseline_signed": true,
  "in_scope": [
    "Refactor payment intent flow",
    "Add Apple Pay button"
  ],
  "out_of_scope": [
    "Loyalty programme",
    "Refund automation"
  ],
  "acceptance_criteria": [
    {
      "id": "AC-001",
      "statement": "p95 < 500ms in canary for 14 days",
      "testable": true
    }
  ],
  "rtm": [
    {
      "req_id": "REQ-1",
      "source": "charter \u00a73.1",
      "ac_id": "AC-001"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project": "x",
  "in_scope": [
    "a"
  ],
  "out_of_scope": []
}
]]></code>
    <note>Project too short; out_of_scope empty; ac missing; rtm missing; baseline_signed missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="empty-exclusions"><description>out_of_scope is empty</description><reason>Default-to-include silently widens scope.</reason></forbidden-pattern>
    <forbidden-pattern id="untestable-ac"><description>acceptance_criteria entries with testable=false</description><reason>Disputes at handoff.</reason></forbidden-pattern>
    <forbidden-pattern id="unsigned-baseline"><description>baseline_signed=false but WBS started</description><reason>WBS investment wasted on moving target.</reason></forbidden-pattern>
    <forbidden-pattern id="orphan-requirement"><description>REQ without AC mapping in RTM</description><reason>Silent feature loss at acceptance.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-scope-management.py">Validator script</reference>
</text>
