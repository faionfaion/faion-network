<text id="04-procedure" title="Stakeholder Register Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to maintain the register.</summary>

  <section title="Procedure">
    <step n="1" name="list">
      <input>Org chart + kickoff interviews + charter</input>
      <action>Enumerate every role/person with stake or veto power; assign stable S-NNN IDs.</action>
      <output>Raw stakeholder list</output>
    </step>
    <step n="2" name="classify">
      <input>Raw list + observed signals</input>
      <action>Set power/interest; choose attitude from enum.</action>
      <output>Classified register</output>
      <decision-gate>Reject non-enum attitude.</decision-gate>
    </step>
    <step n="3" name="strategy">
      <input>Classified register</input>
      <action>Write differentiated strategy per row (≥24 chars, behaviour-specific).</action>
      <output>Register with strategies</output>
      <decision-gate>Reject template-copy strategies.</decision-gate>
    </step>
    <step n="4" name="evidence">
      <input>Strategies + meeting notes</input>
      <action>Attach evidence citation per row.</action>
      <output>Evidence-anchored register</output>
      <decision-gate>Reject rows with empty evidence.</decision-gate>
    </step>
    <step n="5" name="review">
      <input>Monthly review cycle</input>
      <action>Re-validate against org; bump last_reviewed; address staleness flags.</action>
      <output>Reviewed register</output>
      <decision-gate>Block publication if any row stale &gt; 30 days.</decision-gate>
    </step>
  </section>
</text>
