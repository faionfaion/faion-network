<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Stakeholder Register Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping register state to a rule.</summary>

  <decision-tree>
    <root-question id="q-ids">Are all stakeholder IDs unique and match S-NNN format?</root-question>

    <branch when="ids_valid == false">
      <conclusion ref="unique-stable-ids" verdict="renumber to stable monotonic IDs"/>
    </branch>
    <branch when="ids_valid == true">
      <question id="q-attitude">Are attitude values in the enum?</question>
      <branch when="attitude_in_enum == false">
        <conclusion ref="attitude-enum" verdict="reject free-text attitudes"/>
      </branch>
      <branch when="attitude_in_enum == true">
        <question id="q-evidence">Does every row cite evidence?</question>
        <branch when="evidence_present == false">
          <conclusion ref="evidence-required" verdict="attach evidence per row"/>
        </branch>
        <branch when="evidence_present == true">
          <question id="q-strategy">Is every strategy ≥24 chars and specific?</question>
          <branch when="strategy_valid == false">
            <conclusion ref="strategy-min-length" verdict="rewrite generic strategies"/>
          </branch>
          <branch when="strategy_valid == true">
            <question id="q-stale">Are any rows stale (>30d)?</question>
            <branch when="stale_count &gt; 0">
              <conclusion ref="staleness-30d" verdict="re-validate stale rows before publishing"/>
            </branch>
            <branch when="stale_count == 0">
              <conclusion ref="unique-stable-ids" verdict="accept register"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="full-register">
    ids_valid=true, attitude_in_enum=true, evidence_present=true, strategy_valid=true, stale_count=0 → accept register.
  </example>
</text>
