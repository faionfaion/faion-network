<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Register Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the register.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-register.json",
  "type": "object",
  "required": [
    "as_of",
    "stakeholders"
  ],
  "properties": {
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "role",
          "power",
          "interest",
          "attitude",
          "strategy",
          "evidence",
          "last_reviewed"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S-\\d{3,}$"
          },
          "name": {
            "type": "string",
            "minLength": 2
          },
          "role": {
            "type": "string",
            "minLength": 2
          },
          "power": {
            "enum": [
              "low",
              "high"
            ]
          },
          "interest": {
            "enum": [
              "low",
              "high"
            ]
          },
          "attitude": {
            "enum": [
              "champion",
              "supporter",
              "neutral",
              "critic",
              "blocker"
            ]
          },
          "strategy": {
            "type": "string",
            "minLength": 24
          },
          "evidence": {
            "type": "string",
            "minLength": 4
          },
          "last_reviewed": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "as_of": "2026-05-22",
  "stakeholders": [
    {
      "id": "S-001",
      "name": "Iryna Petrenko",
      "role": "VP Engineering",
      "power": "high",
      "interest": "high",
      "attitude": "supporter",
      "strategy": "Weekly 1:1 with crisp asks; share charter progress monthly.",
      "evidence": "minutes-20260518.md",
      "last_reviewed": "2026-05-18"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "stakeholders": [
    {
      "id": "X",
      "name": "y",
      "role": "z"
    }
  ]
}
]]></code>
    <note>as_of missing; id not S-NNN; missing required fields; strategy too short.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="free-text-attitude"><description>attitude not in enum</description><reason>Breaks register analytics.</reason></forbidden-pattern>
    <forbidden-pattern id="empty-evidence"><description>evidence empty</description><reason>Folklore classification.</reason></forbidden-pattern>
    <forbidden-pattern id="short-strategy"><description>strategy &lt; 24 chars</description><reason>Thoughtless placeholder.</reason></forbidden-pattern>
    <forbidden-pattern id="stale-not-flagged"><description>last_reviewed &gt; 30 days, no staleness flag</description><reason>Programme drifts on phantom context.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-stakeholder-register.py">Validator script</reference>
</text>
