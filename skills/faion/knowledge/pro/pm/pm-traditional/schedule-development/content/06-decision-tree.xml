<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Schedule Development Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping schedule state to a rule.</summary>

  <decision-tree>
    <root-question id="q-verb">Is every activity name verb-led?</root-question>

    <branch when="verb_led_all == false">
      <conclusion ref="verb-led-activities" verdict="rename non-verb activities before continuing"/>
    </branch>
    <branch when="verb_led_all == true">
      <question id="q-pert">Do all activities &gt;5 days carry PERT estimates?</question>
      <branch when="pert_compliance == false">
        <conclusion ref="pert-over-5-days" verdict="apply three-point estimates on long activities"/>
      </branch>
      <branch when="pert_compliance == true">
        <question id="q-dep-types">Are all predecessor links typed (FS/SS/FF/SF)?</question>
        <branch when="links_typed == false">
          <conclusion ref="dep-types-explicit" verdict="reject untyped links"/>
        </branch>
        <branch when="links_typed == true">
          <question id="q-buffer">Are buffers held visibly at project + feeding level?</question>
          <branch when="buffers_visible == false">
            <conclusion ref="buffers-visible" verdict="extract hidden padding into named buffers"/>
          </branch>
          <branch when="buffers_visible == true">
            <question id="q-fresh">Has the schedule been refreshed within 14 days?</question>
            <branch when="days_since_refresh &gt; 14">
              <conclusion ref="weekly-refresh" verdict="flag stale; refresh schedule"/>
            </branch>
            <branch when="days_since_refresh &lt;= 14">
              <conclusion ref="verb-led-activities" verdict="accept schedule"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="data-platform">
    verb_led_all=true, pert_compliance=true, links_typed=true, buffers_visible=true, days_since_refresh=3 → accept schedule.
  </example>
</text>
