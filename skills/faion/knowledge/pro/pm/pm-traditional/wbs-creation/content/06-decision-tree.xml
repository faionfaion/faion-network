<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="WBS Creation Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping WBS state to a rule.</summary>

  <decision-tree>
    <root-question id="q-noun">Are all elements noun-led (deliverable-oriented)?</root-question>

    <branch when="noun_led_all == false">
      <conclusion ref="deliverable-oriented" verdict="rename verb-led elements; move verbs to schedule"/>
    </branch>
    <branch when="noun_led_all == true">
      <question id="q-100">Does every level sum to 100% of parent scope?</question>
      <branch when="hundred_percent == false">
        <conclusion ref="hundred-percent-rule" verdict="close gaps; remove overlap"/>
      </branch>
      <branch when="hundred_percent == true">
        <question id="q-leaf-size">Are all leaves estimable in 8-80h?</question>
        <branch when="leaf_size_violation == true">
          <conclusion ref="work-package-size" verdict="decompose mega-leaves; merge sub-8h items"/>
        </branch>
        <branch when="leaf_size_violation == false">
          <question id="q-dict">Does every leaf have a dictionary entry?</question>
          <branch when="dictionary_complete == false">
            <conclusion ref="dictionary-mandatory" verdict="author dictionary per missing leaf"/>
          </branch>
          <branch when="dictionary_complete == true">
            <question id="q-baseline">Does the tree match the signed scope baseline (no gold-plating)?</question>
            <branch when="orphan_nodes &gt; 0">
              <conclusion ref="no-gold-plating" verdict="remove orphans or open change-request"/>
            </branch>
            <branch when="orphan_nodes == 0">
              <conclusion ref="hundred-percent-rule" verdict="accept WBS"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="checkout-redesign">
    noun_led_all=true, hundred_percent=true, leaf_size_violation=false, dictionary_complete=true, orphan_nodes=0 → accept WBS.
  </example>
</text>
