<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Engagement Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for engagement register.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-engagement.json",
  "type": "object",
  "required": [
    "as_of",
    "stakeholders"
  ],
  "properties": {
    "as_of": {
      "type": "string",
      "format": "date"
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "role",
          "power",
          "interest",
          "quadrant",
          "current_engagement",
          "desired_engagement",
          "cadence",
          "last_engagement",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^S-\\d{3,}$"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "power": {
            "enum": [
              "low",
              "high"
            ]
          },
          "interest": {
            "enum": [
              "low",
              "high"
            ]
          },
          "quadrant": {
            "enum": [
              "manage_closely",
              "keep_satisfied",
              "keep_informed",
              "monitor"
            ]
          },
          "current_engagement": {
            "enum": [
              "unaware",
              "resistant",
              "neutral",
              "supportive",
              "leading"
            ]
          },
          "desired_engagement": {
            "enum": [
              "unaware",
              "resistant",
              "neutral",
              "supportive",
              "leading"
            ]
          },
          "cadence": {
            "enum": [
              "weekly",
              "biweekly",
              "monthly"
            ]
          },
          "last_engagement": {
            "type": "string",
            "format": "date"
          },
          "evidence": {
            "type": "string",
            "minLength": 4
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "as_of": "2026-05-22",
  "stakeholders": [
    {
      "id": "S-001",
      "name": "Iryna Petrenko",
      "role": "VP Eng",
      "power": "high",
      "interest": "high",
      "quadrant": "manage_closely",
      "current_engagement": "supportive",
      "desired_engagement": "leading",
      "cadence": "weekly",
      "last_engagement": "2026-05-18",
      "evidence": "minutes-20260518.md"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "stakeholders": [
    {
      "id": "1"
    }
  ]
}
]]></code>
    <note>as_of missing; stakeholder id not S-NNN; mandatory fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden-pattern id="no-quadrant"><description>Stakeholder without quadrant</description><reason>Cannot derive cadence.</reason></forbidden-pattern>
    <forbidden-pattern id="no-evidence"><description>Quadrant set with evidence empty</description><reason>Folklore classification.</reason></forbidden-pattern>
    <forbidden-pattern id="wrong-cadence"><description>Cadence not matching quadrant rule</description><reason>Register drifts to ad-hoc.</reason></forbidden-pattern>
  </section>

  <reference path="scripts/validate-stakeholder-engagement.py">Validator script</reference>
</text>
