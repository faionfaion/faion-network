<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Stakeholder Engagement Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree mapping engagement state to a rule.</summary>

  <decision-tree>
    <root-question id="q-quadrant">Does every stakeholder entry have a quadrant assigned?</root-question>

    <branch when="any_quadrant_missing == true">
      <conclusion ref="every-stakeholder-quadrant" verdict="classify all entries before cadencing"/>
    </branch>
    <branch when="any_quadrant_missing == false">
      <question id="q-evidence">Does every quadrant entry cite evidence?</question>
      <branch when="evidence_missing == true">
        <conclusion ref="evidence-required" verdict="reject classification without evidence citation"/>
      </branch>
      <branch when="evidence_missing == false">
        <question id="q-cadence">Does cadence match quadrant rules?</question>
        <branch when="cadence_mismatch == true">
          <conclusion ref="cadence-per-quadrant" verdict="align cadence to quadrant or document deviation"/>
        </branch>
        <branch when="cadence_mismatch == false">
          <question id="q-overdue">Are any entries overdue per cadence?</question>
          <branch when="overdue_count &gt; 0">
            <conclusion ref="overdue-blocks-status" verdict="address overdue before publishing status"/>
          </branch>
          <branch when="overdue_count == 0">
            <conclusion ref="current-vs-desired" verdict="accept register; monitor current-vs-desired delta"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="vp-eng-classified">
    any_quadrant_missing=false, evidence_missing=false, cadence_mismatch=false, overdue_count=0 → accept register.
  </example>
</text>
