{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/performance-domains-overview.json",
  "__faion_header__": {
    "purpose": "JSON Schema for the Performance Domains Overview artefact",
    "consumes": "see content/02-output-contract.xml inputs for performance-domains-overview",
    "produces": "artefact conforming to content/02-output-contract.xml schema",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~200-1000 tokens when loaded as context"
  },
  "type": "object",
  "required": [
    "report_id",
    "project_id",
    "assessor",
    "domains",
    "remediations"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "assessor": {
      "type": "string"
    },
    "domains": {
      "type": "object",
      "required": [
        "stakeholder",
        "team",
        "development_approach",
        "planning",
        "project_work",
        "delivery",
        "measurement",
        "uncertainty"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "score",
          "evidence"
        ],
        "properties": {
          "score": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "evidence": {
            "type": "array",
            "minItems": 2
          }
        }
      }
    },
    "remediations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "domain",
          "action",
          "owner",
          "due"
        ]
      }
    }
  }
}
