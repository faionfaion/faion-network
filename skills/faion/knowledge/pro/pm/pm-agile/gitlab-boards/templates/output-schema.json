{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/gitlab-boards.json",
  "__faion_header__": {
    "purpose": "JSON Schema for the GitLab Issue Boards artefact",
    "consumes": "see content/02-output-contract.xml inputs for gitlab-boards",
    "produces": "artefact conforming to content/02-output-contract.xml schema",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~200-1000 tokens when loaded as context"
  },
  "type": "object",
  "required": [
    "project_id",
    "labels",
    "boards"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "required": [
        "workflow",
        "priority",
        "type"
      ],
      "properties": {
        "workflow": {
          "type": "array",
          "minItems": 3
        },
        "priority": {
          "type": "array",
          "minItems": 3
        },
        "type": {
          "type": "array",
          "minItems": 2
        }
      }
    },
    "boards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "columns"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "columns": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "object",
              "required": [
                "label",
                "wip_limit"
              ]
            }
          },
          "policy_url": {
            "type": "string"
          }
        }
      }
    },
    "issue_templates": {
      "type": "array",
      "minItems": 2
    }
  }
}
