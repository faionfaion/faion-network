<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="PMF Rubric for Solos Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys and forbidden patterns.</summary>
  <section title="Schema">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pmf-rubric-for-solos.json",
  "title": "PMF Rubric for Solos",
  "type": "object",
  "required": [
    "rubric_id",
    "owner",
    "last_touched",
    "dimensions",
    "scores",
    "verdict",
    "thresholds"
  ],
  "properties": {
    "rubric_id": {},
    "owner": {},
    "last_touched": {},
    "dimensions": {},
    "scores": {},
    "verdict": {},
    "thresholds": {}
  },
  "additionalProperties": true
}]]></code>
    </schema>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[{
  "rubric_id": "pmf-jane-2026q2",
  "owner": "jane@indie.io",
  "last_touched": "2026-05-23T11:00:00Z",
  "dimensions": [
    "very_disappointed_pct",
    "w12_retention",
    "organic_pull",
    "willingness_to_pay",
    "founder_confidence",
    "runway_fit"
  ],
  "scores": {
    "very_disappointed_pct": 38,
    "w12_retention": 0.22,
    "organic_pull": 0.18,
    "willingness_to_pay": 0.11,
    "founder_confidence": 3,
    "runway_fit": 4,
    "evidence": "Tally survey 2026-05-22 + BI cohort 2026-05-22"
  },
  "verdict": "near-pmf",
  "thresholds": {
    "very_disappointed_pct": 40,
    "w12_retention": 0.25,
    "organic_pull": 0.2,
    "willingness_to_pay": 0.1
  },
  "template_version": "1.1.0",
  "status": "ready_for_review"
}]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[{
  "rubric_id": "x",
  "scores": {},
  "verdict": "good"
}]]></code>
    <note>Missing required fields; violates schema constraints for `pmf-rubric-for-solos`. Validator rejects with explicit violation list.</note>
  </example>
  <section title="Forbidden patterns">
    <pattern>verdict not in {pre-pmf, near-pmf, pmf, post-pmf}</pattern>
    <pattern>very_disappointed_pct outside [0,100]</pattern>
    <pattern>retention values outside [0,1]</pattern>
    <pattern>founder_confidence outside [1,5]</pattern>
    <pattern>scores object missing any required dimension</pattern>
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
  </section>
  <reference path="scripts/validate-pmf-rubric-for-solos.py">Validator script</reference>
</text>
