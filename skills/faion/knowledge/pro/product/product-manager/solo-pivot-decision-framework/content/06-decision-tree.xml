<text id="06-decision-tree" title="Solo Pivot Decision Framework Decision Tree" version="1.1.0" est_tokens="650" depth="essential">
  <summary>Routing tree on observable signals to apply / skip / route-elsewhere. Each leaf references a rule id from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-age">Product live &gt;=90 days with users?</root-question>
    <branch when="age_ok == false">
      <conclusion ref="skip-this-methodology" verdict="too early; use customer-development first"/>
    </branch>
    <branch when="age_ok == true">
      <question id="q-triggers">&gt;=1 quantitative trigger crossed?</question>
      <branch when="triggers_crossed == false">
        <conclusion ref="skip-this-methodology" verdict="no signal; persevere or run product-lifecycle audit"/>
      </branch>
      <branch when="triggers_crossed == true">
        <question id="q-runway">Operator runway &gt;= 8 weeks?</question>
        <branch when="runway_ok == false">
          <conclusion ref="runway-feasibility-gate" verdict="runway-less; honestly quit, do not pivot"/>
        </branch>
        <branch when="runway_ok == true">
          <conclusion ref="pivot-taxonomy-named" verdict="classify pivot type + author DR"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="acme-saas-2026">
    age_ok=true -&gt; triggers_crossed=true -&gt; runway_ok=true -&gt; classify pivot (rule pivot-taxonomy-named).
  </example>
</text>
