<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Review PR Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the checklist artefact this methodology produces, with valid and invalid examples plus forbidden patterns.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-review-pr-checklist.json",
  "type": "object",
  "required": [
    "pr_id",
    "reviewer",
    "per_item_results",
    "evidence_per_item",
    "decision"
  ],
  "properties": {
    "pr_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "review_duration_min": {
      "type": "integer",
      "minimum": 1
    },
    "handoff_package_link": {
      "type": "string",
      "format": "uri"
    },
    "per_item_results": {
      "type": "object",
      "required": [
        "tokens",
        "components",
        "states",
        "motion",
        "accessibility",
        "content_rules",
        "breakpoints",
        "images",
        "dark_mode",
        "cross_browser"
      ],
      "additionalProperties": {
        "enum": [
          "pass",
          "needs-changes",
          "n/a-with-reason"
        ]
      }
    },
    "evidence_per_item": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "deltas_flagged_back": {
      "type": "array"
    },
    "decision": {
      "enum": [
        "approve",
        "changes-needed",
        "needs-handoff-update"
      ]
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pr_id": "acme/web#1421",
  "reviewer": "jane.s",
  "review_duration_min": 13,
  "per_item_results": {
    "tokens": "pass",
    "components": "pass",
    "states": "pass",
    "motion": "pass",
    "accessibility": "pass",
    "content_rules": "pass",
    "breakpoints": "pass",
    "images": "pass",
    "dark_mode": "pass",
    "cross_browser": "pass"
  },
  "evidence_per_item": {
    "tokens": "ok",
    "components": "ok",
    "states": "ok",
    "motion": "ok",
    "accessibility": "ok",
    "content_rules": "ok",
    "breakpoints": "ok",
    "images": "ok",
    "dark_mode": "ok",
    "cross_browser": "ok"
  },
  "decision": "approve"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pr_id": "acme/web#1422",
  "reviewer": "alex.k",
  "review_duration_min": 1,
  "per_item_results": {
    "tokens": "pass"
  },
  "evidence_per_item": {},
  "decision": "approve"
}
]]></code>
    <note>per_item_results missing 9 keys; evidence_per_item empty; decision=approve with no per-item coverage (rubber-stamp).</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>per_item_results missing any of the 10 required keys (incomplete coverage).</item>
      <item>any per_item_results value = pass without a corresponding evidence_per_item entry.</item>
      <item>decision = approve while any per_item_results value = needs-changes.</item>
      <item>review_duration_min &lt; 5 on a UI PR with &gt; 200 lines AND decision = approve (rubber-stamp).</item>
      <item>checklist items beyond the 10 (style cleanup, test coverage) — out of lane.</item>
    </list>
  </section>

  <reference path="scripts/validate-design-review-pr-checklist.py">Validator script enforcing this schema</reference>
</text>
