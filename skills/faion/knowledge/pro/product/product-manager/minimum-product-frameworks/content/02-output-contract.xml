<text id="02-output-contract" title="Minimum Product Frameworks Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the decision-record artefact this methodology produces, with valid and invalid examples plus forbidden patterns.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/minimum-product-frameworks.json",
  "type": "object",
  "required": [
    "dr_id",
    "signals",
    "selected_framework",
    "scorecard",
    "differentiator_proof",
    "revisit_triggers"
  ],
  "properties": {
    "dr_id": {
      "type": "string",
      "pattern": "^dr-[a-z0-9-]+-[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "signals": {
      "type": "object",
      "required": [
        "market_density",
        "buyer_type",
        "differentiator"
      ],
      "properties": {
        "market_density": {
          "enum": [
            "blue-ocean",
            "red-ocean",
            "purple-ocean"
          ]
        },
        "buyer_type": {
          "enum": [
            "consumer",
            "prosumer",
            "enterprise",
            "dev"
          ]
        },
        "differentiator": {
          "enum": [
            "price",
            "experience",
            "capability",
            "distribution"
          ]
        }
      }
    },
    "selected_framework": {
      "enum": [
        "MVP",
        "MLP",
        "MMP",
        "MAC",
        "RAT",
        "MDP",
        "MVA",
        "MFP",
        "SLC"
      ]
    },
    "scorecard": {
      "type": "object",
      "required": [
        "MVP",
        "MLP",
        "MMP",
        "MAC",
        "RAT",
        "MDP",
        "MVA",
        "MFP",
        "SLC"
      ],
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 5
      }
    },
    "differentiator_proof": {
      "type": "string",
      "minLength": 15
    },
    "revisit_triggers": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 10
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "dr_id": "dr-acme-cards-2026-05-23",
  "signals": {
    "market_density": "blue-ocean",
    "buyer_type": "prosumer",
    "differentiator": "experience"
  },
  "selected_framework": "MLP",
  "scorecard": {
    "MVP": 3,
    "MLP": 5,
    "MMP": 3,
    "MAC": 2,
    "RAT": 2,
    "MDP": 1,
    "MVA": 1,
    "MFP": 1,
    "SLC": 4
  },
  "differentiator_proof": "Day-30 retention >= 45% and NPS >= 40 within 60 days of GA.",
  "revisit_triggers": [
    "Day-30 retention < 25% for 2 consecutive monthly cohorts.",
    "NPS < 20 in the second post-launch survey wave."
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dr_id": "DR1",
  "signals": {
    "market_density": "??",
    "buyer_type": "?",
    "differentiator": "?"
  },
  "selected_framework": "agile",
  "scorecard": {
    "MVP": 99
  },
  "differentiator_proof": "tbd",
  "revisit_triggers": [
    "?"
  ]
}
]]></code>
    <note>dr_id pattern mismatch; signals enums invalid; selected_framework not in enum; scorecard incomplete + out-of-range; proof too short; trigger too short + only 1.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>scorecard missing any of the 9 frameworks (incomplete coverage).</item>
      <item>selected_framework outside the 9-enum.</item>
      <item>differentiator_proof shorter than 15 chars (no real proof gate).</item>
      <item>revisit_triggers fewer than 2 entries (no real reassessment criteria).</item>
      <item>framework chosen without market_density + buyer_type + differentiator signals captured.</item>
    </list>
  </section>

  <reference path="scripts/validate-minimum-product-frameworks.py">Validator script enforcing this schema</reference>
</text>
