<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Product Explainability (PM Angle) Decision Tree" version="1.1.0" est_tokens="650" depth="essential">
  <summary>Routing tree on observable signals to apply / skip / route-elsewhere. Each leaf references a rule id from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-visible">Customer-visible change AND &gt;=2 internal audiences need explanation?</root-question>
    <branch when="applies == false">
      <conclusion ref="skip-this-methodology" verdict="infra/internal-tool/GTM-owned; methodology does not apply"/>
    </branch>
    <branch when="applies == true">
      <question id="q-evidence">Evidence link (quote / metric / session) available?</question>
      <branch when="evidence_present == false">
        <conclusion ref="evidence-link-required" verdict="block narrative; gather evidence first"/>
      </branch>
      <branch when="evidence_present == true">
        <conclusion ref="one-canonical-narrative" verdict="author canonical + derive audience renders"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="checkout-redesign-2026q2">
    applies=true -&gt; evidence_present=true -&gt; author canonical (rule one-canonical-narrative).
  </example>
</text>
