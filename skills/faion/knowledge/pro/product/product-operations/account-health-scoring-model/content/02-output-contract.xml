<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Account Health Scoring Model (Sub-20 Accounts) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/account-health.json",
  "type": "object",
  "required": [
    "week",
    "accounts"
  ],
  "properties": {
    "week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$"
    },
    "accounts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "signals",
          "score",
          "tier",
          "trend"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "signals": {
            "type": "object",
            "required": [
              "utilization",
              "engagement",
              "scope_creep",
              "payment",
              "advocacy",
              "sponsor"
            ],
            "properties": {
              "utilization": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              },
              "engagement": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              },
              "scope_creep": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              },
              "payment": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              },
              "advocacy": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              },
              "sponsor": {
                "type": "integer",
                "minimum": 0,
                "maximum": 2
              }
            }
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 12
          },
          "tier": {
            "enum": [
              "green",
              "yellow",
              "red"
            ]
          },
          "trend": {
            "enum": [
              "up",
              "flat",
              "down"
            ]
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "week": "2026-W21",
  "accounts": [
    {
      "id": "acme",
      "signals": {
        "utilization": 2,
        "engagement": 2,
        "scope_creep": 1,
        "payment": 2,
        "advocacy": 2,
        "sponsor": 2
      },
      "score": 11,
      "tier": "green",
      "trend": "up"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "week": "May 2026",
  "accounts": [
    {
      "id": "acme",
      "score": 7,
      "tier": "yellow"
    }
  ]
}
]]></code>
    <note>Week format must be ISO Wxx; signals object required; tier must be derived from score by fixed cutoffs.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">per-account threshold override</pattern>
    <pattern id="f2">NPS-only score</pattern>
    <pattern id="f3">founder gut-feel signal</pattern>
    <pattern id="f4">stale signal source &gt;7d without flag</pattern>
  </section>

  <reference path="scripts/validate-account-health-scoring-model.py">Validator script (stdlib-only).</reference>
</text>
