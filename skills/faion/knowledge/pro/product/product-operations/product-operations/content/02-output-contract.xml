<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Operations Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/product-ops-config.json",
  "type": "object",
  "required": [
    "function",
    "owned_systems",
    "canonical_rollup",
    "process_docs",
    "automation_first"
  ],
  "properties": {
    "function": {
      "const": "product-operations"
    },
    "owned_systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "roadmap-tool",
          "experiment-platform",
          "feedback-ingest",
          "metric-warehouse"
        ]
      }
    },
    "canonical_rollup": {
      "type": "object",
      "required": [
        "owner",
        "cadence",
        "template"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "cadence": {
          "const": "weekly"
        },
        "template": {
          "type": "string"
        }
      }
    },
    "process_docs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "process",
          "canonical_path"
        ]
      }
    },
    "automation_first": {
      "type": "boolean",
      "const": true
    },
    "headcount_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "automation_attempt",
          "automation_result"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "function": "product-operations",
  "owned_systems": [
    "roadmap-tool",
    "experiment-platform",
    "feedback-ingest",
    "metric-warehouse"
  ],
  "canonical_rollup": {
    "owner": "ruslan",
    "cadence": "weekly",
    "template": ".aidocs/process/weekly-rollup.md"
  },
  "process_docs": [
    {
      "process": "intake",
      "canonical_path": ".aidocs/process/intake.md"
    }
  ],
  "automation_first": true,
  "headcount_requests": []
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "function": "ops",
  "owned_systems": [],
  "automation_first": false
}
]]></code>
    <note>function value not 'product-operations'; owned_systems empty; automation_first must be true.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">parallel weekly rollups</pattern>
    <pattern id="f2">headcount request without automation attempt</pattern>
    <pattern id="f3">ad-hoc stakeholder update shape</pattern>
    <pattern id="f4">process docs duplicated outside canonical location</pattern>
  </section>

  <reference path="scripts/validate-product-operations.py">Validator script (stdlib-only).</reference>
</text>
