  <example valid="false">
    <code lang="json"><![CDATA[
{
  "client": "acme",
  "quarter": "Q2",
  "slides": [
    {
      "n": 1,
      "title": "cover"
    }
  ],
  "asks": []
}
]]></code>
    <note>Quarter format; slides must be exactly 10; owner + evidence_anchors required per slide; asks ≥1.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">custom slide order or count != 10</pattern>
    <pattern id="f2">slide without owner</pattern>
    <pattern id="f3">claim without evidence anchor</pattern>
    <pattern id="f4">output-recap framing instead of outcome review</pattern>
    <pattern id="f5">asks slide empty</pattern>
  </section>

  <reference path="scripts/validate-qbr-deck-template-services.py">Validator script (stdlib-only).</reference>
