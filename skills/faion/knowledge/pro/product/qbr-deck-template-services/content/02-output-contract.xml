<text id="02-output-contract" title="QBR Deck Template Services Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys, types, and forbidden patterns. Valid + invalid examples below.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/qbr-deck.json",
  "type": "object",
  "required": [
    "client",
    "quarter",
    "slides",
    "asks"
  ],
  "properties": {
    "client": {
      "type": "string"
    },
    "quarter": {
      "type": "string",
      "pattern": "^\\d{4}-Q[1-4]$"
    },
    "slides": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "n",
          "title",
          "owner",
          "evidence_anchors"
        ],
        "properties": {
          "n": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "title": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "evidence_anchors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      }
    },
    "asks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string"
      }
    },
    "outcome_review_included": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

