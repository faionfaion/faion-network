<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Agency-to-SaaS Readiness Checklist Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Defines the readiness audit report.</summary>

  <output-contract>
    <required>
      <field name="audit_metadata">
        <subfield name="audit_date" type="iso_date"/>
        <subfield name="founder" type="string"/>
        <subfield name="candidate_saas_idea" type="string" min_words="20"/>
      </field>
      <field name="dimensions" required_keys="D1,D2,D3,D4,D5">
        <subfield name="D1.score" enum="0,1,2"/>
        <subfield name="D1.evidence" type="string" min_words="20"/>
        <subfield name="D1.sow_audit_table" type="table"/>
        <subfield name="D2.score" enum="0,1,2"/>
        <subfield name="D2.evidence" type="string"/>
        <subfield name="D2.shipped_instances" min_items="0"/>
        <subfield name="D3.score" enum="0,1,2"/>
        <subfield name="D3.repo_inventory" type="table"/>
        <subfield name="D4.score" enum="0,1,2"/>
        <subfield name="D4.runway_stress_test_months" type="number"/>
        <subfield name="D4.churn_scenario" type="string"/>
        <subfield name="D5.score" enum="0,1,2"/>
        <subfield name="D5.replacement_lead_name" type="string"/>
        <subfield name="D5.founder_time_hours_per_week" type="number"/>
      </field>
      <field name="total_score" type="integer" min="0" max="10"/>
      <field name="decision" enum="READY,PRE_WORK_NEEDED,NOT_VIABLE"/>
      <field name="pre_work_plan" required_if="decision == PRE_WORK_NEEDED"/>
      <field name="re_evaluate_date" required_if="decision == NOT_VIABLE"/>
    </required>

    <forbidden>
      <pattern id="f1">any dimension missing or scored "TBD"</pattern>
      <pattern id="f2">D1.score &gt; 0 without sow_audit_table populated</pattern>
      <pattern id="f3">D2.score == 2 with shipped_instances count &lt; 3 OR client_count &lt; 3</pattern>
      <pattern id="f4">D4.score == 2 with runway_stress_test_months &lt; 9</pattern>
      <pattern id="f5">D5.score &gt; 0 with replacement_lead_name == "TBD" or empty</pattern>
      <pattern id="f6">total_score doesn't match sum of dimension scores</pattern>
      <pattern id="f7">decision doesn't match the total_score mapping (≥8 READY, 5-7 PRE_WORK, ≤4 NOT_VIABLE)</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>"PRE_WORK_NEEDED" decision must include a per-dimension gap-closure plan with deadlines; without plan, decision becomes NOT_VIABLE.</transformation>
      <transformation>Dimensions may receive a "0 with plan to upgrade" annotation — counts as 0 in current score but the plan is tracked for the next audit.</transformation>
      <transformation>For founders without past SOWs (newer agencies), D1 may default to 1 (mixed) with the recommendation to fix all forward-going SOWs.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/readiness-scorecard.md"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>all 5 dimensions scored 0/1/2 with evidence</item>
      <item>D1 backed by per-SOW IP audit (no memory-based scoring)</item>
      <item>D2 requires ≥ 3 instances + ≥ 3 clients for score 2</item>
      <item>D4 stress test assumes top-1 retainer churn</item>
      <item>D5 names a real replacement lead</item>
      <item>decision matches total_score mapping</item>
      <item>PRE_WORK or NOT_VIABLE includes follow-up plan / date</item>
    </list>
  </section>
</text>
