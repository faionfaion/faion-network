{
  "__faion_header__": {
    "purpose": "Opportunity Solution Tree JSON schema",
    "consumes": "discovery interview synthesis",
    "produces": "OST data file consumed by spec-opp-link.yml",
    "depends-on": "spec-opp-link.yml",
    "token-budget-impact": "low"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["outcome", "opportunities"],
  "properties": {
    "outcome": {"type": "string"},
    "opportunities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "evidence_interview_ids"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "evidence_interview_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "solutions": {"type": "array", "items": {"type": "object", "required": ["id", "label", "risky_assumptions"]}}
        }
      }
    }
  }
}
