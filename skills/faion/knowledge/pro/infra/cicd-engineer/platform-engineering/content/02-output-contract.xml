<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Platform Engineering Output Contract" version="1.1.0" est_tokens="1000" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact. Validator script in `scripts/validate-platform-engineering.py` enforces it.</summary>

  <schema lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/platform-engineering.json",
  "type": "object",
  "required": [
    "org",
    "current_state",
    "decisions",
    "metrics",
    "non_goals_year1"
  ],
  "properties": {
    "org": {
      "type": "string",
      "minLength": 1
    },
    "current_state": {
      "type": "object",
      "required": [
        "devops_tickets_month",
        "ttfd_days",
        "service_count"
      ],
      "properties": {
        "devops_tickets_month": {
          "type": "integer",
          "minimum": 0
        },
        "ttfd_days": {
          "type": "number",
          "minimum": 0
        },
        "dev_nps": {
          "type": "integer"
        },
        "service_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "decisions": {
      "type": "object",
      "required": [
        "portal",
        "orchestrator",
        "iac",
        "golden_path_first",
        "rbac_includes_ai_agents"
      ],
      "properties": {
        "portal": {
          "enum": [
            "backstage",
            "port",
            "cortex",
            "none-yet"
          ]
        },
        "orchestrator": {
          "enum": [
            "crossplane",
            "humanitec",
            "kratix",
            "homegrown"
          ]
        },
        "iac": {
          "enum": [
            "terraform",
            "pulumi",
            "both"
          ]
        },
        "golden_path_first": {
          "type": "string",
          "minLength": 1
        },
        "rbac_includes_ai_agents": {
          "type": "boolean"
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "dora",
        "platform"
      ],
      "properties": {
        "dora": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 4
        },
        "platform": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 3
        }
      }
    },
    "non_goals_year1": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
]]></schema>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "org": "acme",
  "current_state": {
    "devops_tickets_month": 220,
    "ttfd_days": 14,
    "dev_nps": -5,
    "service_count": 38
  },
  "decisions": {
    "portal": "backstage",
    "orchestrator": "crossplane",
    "iac": "terraform",
    "golden_path_first": "go-microservice",
    "rbac_includes_ai_agents": true
  },
  "metrics": {
    "dora": [
      "DF",
      "LT",
      "MTTR",
      "CFR"
    ],
    "platform": [
      "adoption_rate",
      "ttfd_new_dev",
      "ticket_trend",
      "nps"
    ]
  },
  "non_goals_year1": [
    "multi-cloud",
    "self-service databases"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "org": "acme",
  "current_state": {
    "devops_tickets_month": 220,
    "ttfd_days": 14,
    "service_count": 38
  },
  "decisions": {
    "portal": "backstage",
    "orchestrator": "crossplane",
    "iac": "terraform",
    "golden_path_first": "go-microservice",
    "rbac_includes_ai_agents": false
  },
  "metrics": {
    "dora": [
      "DF"
    ],
    "platform": []
  },
  "non_goals_year1": []
}
]]></code>
    <note>AI agents not first-class principals; metrics arrays under minItems; non_goals empty.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">decisions.rbac_includes_ai_agents = false in 2026+ specs (violates ai-agents-are-citizens)</pattern>
    <pattern id="f2">metrics.dora missing one of DF / LT / MTTR / CFR</pattern>
    <pattern id="f3">non_goals_year1 empty (forces explicit scope)</pattern>
    <pattern id="f4">decisions.portal absent or = 'all-three' (violates one-portal-per-org rule)</pattern>
    <pattern id="f5">decisions.golden_path_first = 'all' or comma-separated list (violates one-golden-path-at-start)</pattern>
  </section>

  <reference path="scripts/validate-platform-engineering.py">Validator script</reference>
</text>