<text id="06-decision-tree" title="Filesystem Backup with Restic Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule id from content/01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-skip">Does the host already have managed snapshots (cloud provider, CSI) covering the RPO target?</root-question>

    <branch when="answer == yes">
      <conclusion ref="skip-this-methodology" verdict="skip this methodology; alternative applies"/>
    </branch>

    <branch when="answer == no">
      <question id="q-apply">Are the preconditions in Applies If satisfied (ALL must hold)?</question>
      <branch when="preconditions_satisfied == false">
        <conclusion ref="skip-this-methodology" verdict="halt; gather missing preconditions first"/>
      </branch>
      <branch when="preconditions_satisfied == true">
        <question id="q-primary">Which constraint dominates the artefact shape?</question>
        <branch when="constraint == primary">
          <conclusion ref="password-from-secrets-manager" verdict="apply primary rule"/>
        </branch>
        <branch when="constraint == secondary">
          <conclusion ref="weekly-repo-check" verdict="apply secondary rule"/>
        </branch>
        <branch when="constraint == tertiary">
          <conclusion ref="forget-with-prune" verdict="apply tertiary rule"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="primary-path">
    answer=no → preconditions_satisfied=true → constraint=primary → conclusion=password-from-secrets-manager.
  </example>
</text>
