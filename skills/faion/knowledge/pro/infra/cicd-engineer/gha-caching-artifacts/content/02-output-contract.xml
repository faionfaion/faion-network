<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitHub Actions — Caching and Artifacts Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gha-caching-artifacts.json",
  "title": "GitHub Actions \u2014 Caching and Artifacts",
  "type": "object",
  "required": [
    "caches",
    "artifacts",
    "docker_cache",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "caches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "key",
          "restore_keys"
        ]
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "path",
          "retention_days"
        ]
      }
    },
    "docker_cache": {
      "type": "object",
      "required": [
        "enabled",
        "cache_from",
        "cache_to"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "caches": [
    {
      "path": "~/.npm",
      "key": "${{ runner.os }}-node-${{ hashFiles('**/package-lock.json') }}",
      "restore_keys": [
        "${{ runner.os }}-node-"
      ]
    }
  ],
  "artifacts": [
    {
      "name": "build-output",
      "path": "dist/",
      "retention_days": 7
    }
  ],
  "docker_cache": {
    "enabled": true,
    "cache_from": "type=gha",
    "cache_to": "type=gha,mode=max"
  },
  "owner": "ci-lead@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "caches": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-gha-caching-artifacts.py">Validator script</reference>
</text>
