<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Nginx Configuration Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact. Validator script in `scripts/validate-nginx-configuration.py` enforces it.</summary>

  <schema lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nginx-configuration.json",
  "type": "object",
  "required": [
    "domain",
    "upstream",
    "tls",
    "headers",
    "http2"
  ],
  "properties": {
    "domain": {
      "type": "string",
      "minLength": 3
    },
    "upstream": {
      "type": "string",
      "minLength": 1
    },
    "tls": {
      "type": "object",
      "required": [
        "protocols",
        "hsts_max_age"
      ],
      "properties": {
        "protocols": {
          "type": "array",
          "items": {
            "enum": [
              "TLSv1.2",
              "TLSv1.3"
            ]
          },
          "minItems": 1
        },
        "hsts_max_age": {
          "type": "integer",
          "minimum": 15768000
        },
        "ocsp_stapling": {
          "type": "boolean"
        }
      }
    },
    "headers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 4
    },
    "rate_limit_zones": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "http2": {
      "type": "boolean",
      "const": true
    },
    "websocket_upgrade": {
      "type": "boolean"
    }
  }
}
]]></schema>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "domain": "example.com",
  "upstream": "backend:8000",
  "tls": {
    "protocols": [
      "TLSv1.2",
      "TLSv1.3"
    ],
    "hsts_max_age": 63072000,
    "ocsp_stapling": true
  },
  "headers": [
    "Strict-Transport-Security",
    "X-Content-Type-Options",
    "X-Frame-Options",
    "Content-Security-Policy"
  ],
  "rate_limit_zones": [
    "auth=5r/s"
  ],
  "http2": true,
  "websocket_upgrade": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "domain": "example.com",
  "upstream": "backend:8000",
  "tls": {
    "protocols": [
      "TLSv1.0",
      "TLSv1.1",
      "TLSv1.2"
    ],
    "hsts_max_age": 3600
  },
  "headers": [
    "X-Frame-Options"
  ],
  "http2": false
}
]]></code>
    <note>TLS 1.0/1.1 enabled; HSTS max-age below 6 months; only one security header; HTTP/2 disabled.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">ssl_protocols contains TLSv1 or TLSv1.1</pattern>
    <pattern id="f2">missing add_header Strict-Transport-Security on HTTPS server block</pattern>
    <pattern id="f3">listen 443 ssl; without http2 or http3 token</pattern>
    <pattern id="f4">proxy_pass on location without include of proxy-params.conf (missing Host / X-Forwarded-* headers)</pattern>
    <pattern id="f5">gzip on; without gzip_types whitelist (compresses image/* and video/*)</pattern>
  </section>

  <reference path="scripts/validate-nginx-configuration.py">Validator script</reference>
</text>