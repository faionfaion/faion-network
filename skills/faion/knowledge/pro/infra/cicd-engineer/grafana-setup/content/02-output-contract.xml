<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Grafana — Deployment and Provisioning Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/grafana-setup.json",
  "title": "Grafana \u2014 Deployment and Provisioning",
  "type": "object",
  "required": [
    "platform",
    "ha",
    "provisioning",
    "alloy_migration",
    "backup",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "platform": {
      "type": "string",
      "enum": [
        "kubernetes",
        "docker",
        "vm"
      ]
    },
    "ha": {
      "type": "object",
      "required": [
        "replicas",
        "database",
        "session_store"
      ]
    },
    "provisioning": {
      "type": "object",
      "required": [
        "datasources_path",
        "dashboards_path",
        "alerting_path"
      ]
    },
    "alloy_migration": {
      "type": "object",
      "required": [
        "status",
        "target_date"
      ]
    },
    "backup": {
      "type": "object",
      "required": [
        "target",
        "frequency",
        "drill_cadence"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "platform": "kubernetes",
  "ha": {
    "replicas": 3,
    "database": "postgresql://grafana@db/grafana",
    "session_store": "database"
  },
  "provisioning": {
    "datasources_path": "provisioning/datasources/",
    "dashboards_path": "provisioning/dashboards/",
    "alerting_path": "provisioning/alerting/"
  },
  "alloy_migration": {
    "status": "completed",
    "target_date": "2025-10-01"
  },
  "backup": {
    "target": "s3://acme-grafana-backups/",
    "frequency": "daily",
    "drill_cadence": "quarterly"
  },
  "owner": "sre@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platform": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-grafana-setup.py">Validator script</reference>
</text>
