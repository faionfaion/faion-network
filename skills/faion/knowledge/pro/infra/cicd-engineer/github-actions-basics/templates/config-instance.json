{
  "workflow_file": ".github/workflows/ci.yml",
  "triggers": {
    "push": {
      "branches": [
        "main"
      ]
    },
    "pull_request": {
      "branches": [
        "main"
      ],
      "paths": [
        "src/**",
        "tests/**"
      ]
    }
  },
  "permissions": {
    "contents": "read",
    "checks": "write"
  },
  "jobs": [
    {
      "name": "test",
      "steps": [
        "checkout@<sha>",
        "setup-node@<sha>",
        "cache@<sha>",
        "npm ci",
        "npm test"
      ]
    }
  ],
  "artifact": {
    "name": "test-report",
    "path": "coverage/",
    "retention_days": 14
  },
  "owner": "ci-lead@team.io",
  "last_reviewed": "2026-05-23",
  "__faion_header__": {
    "purpose": "GitHub Actions \u2014 Basics config skeleton",
    "consumes": "Prerequisites bundle (see AGENTS.md)",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends_on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  }
}
