<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="GitHub Actions — Basics Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="no-trigger-filter" severity="high">
      <symptom>Workflow runs on every doc-only commit; budget burned.</symptom>
      <root-cause>on: push without filters.</root-cause>
      <fix>Add branches: + paths: filters.</fix>
    </antipattern>

    <antipattern id="default-write-permissions" severity="medium">
      <symptom>Compromised step gains broad write.</symptom>
      <root-cause>permissions block missing.</root-cause>
      <fix>Declare explicit minimum scopes.</fix>
    </antipattern>

    <antipattern id="no-cache" severity="medium">
      <symptom>Each run installs deps from scratch; 3min/run wasted.</symptom>
      <root-cause>Cache step omitted.</root-cause>
      <fix>Add cache action keyed on lockfile hash.</fix>
    </antipattern>

    <antipattern id="orphan-workflow" severity="high">
      <symptom>Workflow breaks; nobody knows who owns it.</symptom>
      <root-cause>No owner comment.</root-cause>
      <fix>Add owner comment + changelog discipline.</fix>
    </antipattern>

  </section>
</text>
