<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitHub Actions — Basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/github-actions-basics.json",
  "title": "GitHub Actions \u2014 Basics",
  "type": "object",
  "required": [
    "workflow_file",
    "triggers",
    "permissions",
    "jobs",
    "artifact",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "workflow_file": {
      "type": "string"
    },
    "triggers": {
      "type": "object",
      "required": [
        "push",
        "pull_request"
      ]
    },
    "permissions": {
      "type": "object"
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "steps"
        ]
      }
    },
    "artifact": {
      "type": "object",
      "required": [
        "name",
        "path",
        "retention_days"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "workflow_file": ".github/workflows/ci.yml",
  "triggers": {
    "push": {
      "branches": [
        "main"
      ]
    },
    "pull_request": {
      "branches": [
        "main"
      ],
      "paths": [
        "src/**",
        "tests/**"
      ]
    }
  },
  "permissions": {
    "contents": "read",
    "checks": "write"
  },
  "jobs": [
    {
      "name": "test",
      "steps": [
        "checkout@<sha>",
        "setup-node@<sha>",
        "cache@<sha>",
        "npm ci",
        "npm test"
      ]
    }
  ],
  "artifact": {
    "name": "test-report",
    "path": "coverage/",
    "retention_days": 14
  },
  "owner": "ci-lead@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "workflow_file": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-github-actions-basics.py">Validator script</reference>
</text>
