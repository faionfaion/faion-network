<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Flux CD — Setup and Operation Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gitops-flux.json",
  "title": "Flux CD \u2014 Setup and Operation",
  "type": "object",
  "required": [
    "sources",
    "kustomizations",
    "helmreleases",
    "notifications",
    "tenants",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "name",
          "url"
        ]
      }
    },
    "kustomizations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "source_ref",
          "path",
          "prune"
        ]
      }
    },
    "helmreleases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "chart_ref",
          "image_automation"
        ]
      }
    },
    "notifications": {
      "type": "object",
      "required": [
        "provider",
        "channel"
      ]
    },
    "tenants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "namespace",
          "rbac_ref"
        ]
      }
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "sources": [
    {
      "kind": "GitRepository",
      "name": "platform-state",
      "url": "https://github.com/acme/platform-state.git"
    }
  ],
  "kustomizations": [
    {
      "name": "platform",
      "source_ref": "platform-state",
      "path": "./clusters/prod",
      "prune": true
    }
  ],
  "helmreleases": [
    {
      "name": "ingress",
      "chart_ref": "oci://ghcr.io/acme/charts/ingress",
      "image_automation": true
    }
  ],
  "notifications": {
    "provider": "slack",
    "channel": "#platform-flux"
  },
  "tenants": [
    {
      "name": "team-a",
      "namespace": "tenant-a",
      "rbac_ref": "rbac/team-a.yaml"
    }
  ],
  "owner": "platform@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "sources": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-gitops-flux.py">Validator script</reference>
</text>
