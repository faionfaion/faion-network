<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Grafana — Basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/grafana-basics.json",
  "title": "Grafana \u2014 Basics",
  "type": "object",
  "required": [
    "datasources",
    "dashboards_repo",
    "alerting",
    "folder_rbac",
    "public_links_default_off",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "datasources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "url"
        ]
      }
    },
    "dashboards_repo": {
      "type": "object",
      "required": [
        "path",
        "format"
      ]
    },
    "alerting": {
      "type": "object",
      "required": [
        "rules_repo",
        "contact_points"
      ]
    },
    "folder_rbac": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "folder",
          "owner_team",
          "viewers"
        ]
      }
    },
    "public_links_default_off": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "datasources": [
    {
      "name": "Prometheus",
      "type": "prometheus",
      "url": "http://prometheus.monitoring:9090"
    },
    {
      "name": "Loki",
      "type": "loki",
      "url": "http://loki.monitoring:3100"
    }
  ],
  "dashboards_repo": {
    "path": "git@github.com:acme/dashboards.git",
    "format": "grafonnet"
  },
  "alerting": {
    "rules_repo": "git@github.com:acme/alerts.git",
    "contact_points": [
      "slack:#alerts",
      "pagerduty:platform"
    ]
  },
  "folder_rbac": [
    {
      "folder": "platform",
      "owner_team": "platform",
      "viewers": [
        "eng-all"
      ]
    }
  ],
  "public_links_default_off": true,
  "owner": "sre@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "datasources": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-grafana-basics.py">Validator script</reference>
</text>
