{
  "__faion_header__": {
    "purpose": "Filled config artefact conforming to content/02-output-contract.xml",
    "consumes": "RPO/RTO target + storage URI + secrets source decision",
    "produces": "validated backup pipeline config",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "~120 tokens when loaded as context"
  },
  "db_name": "billing",
  "backup_format": "custom",
  "verify_before_upload": true,
  "wal_monitoring": {"enabled": true, "alert_on_failed_count_increase": true},
  "secrets_source": "vault",
  "remote_storage": {"kind": "s3", "uri": "s3://backups-prod/postgres/billing/"},
  "retention_local_days": 7,
  "retention_remote_days": 90,
  "encryption_at_rest": true,
  "parallel_workers": 4
}
