<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="mTLS Service-to-Service Deployment Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cicd-mtls-deployment.json",
  "type": "object",
  "required": [
    "ca_kind",
    "cert_lifetime_hours",
    "per_workload_identity",
    "ssl_verify_client",
    "revocation"
  ],
  "properties": {
    "ca_kind": {
      "enum": [
        "step-ca",
        "vault-pki",
        "spiffe-spire",
        "service-mesh-issuer"
      ]
    },
    "cert_lifetime_hours": {
      "type": "integer",
      "minimum": 1,
      "maximum": 24
    },
    "per_workload_identity": {
      "const": true
    },
    "ssl_verify_client": {
      "enum": [
        "on",
        "on-strict"
      ]
    },
    "revocation": {
      "enum": [
        "ocsp-stapling",
        "crl-dp"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "ca_kind": "step-ca",
  "cert_lifetime_hours": 1,
  "per_workload_identity": true,
  "ssl_verify_client": "on",
  "revocation": "ocsp-stapling"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ca_kind": null
}
]]></code>
    <note>Required field set to null and other required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>ca_kind: must match enum: step-ca, vault-pki, spiffe-spire, service-mesh-issuer; otherwise reject.</item>
      <item>cert_lifetime_hours: must match integer 1..24; otherwise reject.</item>
      <item>per_workload_identity: must match boolean const true; otherwise reject.</item>
      <item>ssl_verify_client: must match enum: on, on-strict; otherwise reject.</item>
      <item>revocation: must match enum: ocsp-stapling, crl-dp; otherwise reject.</item>
    </list>
  </section>

  <reference path="scripts/validate-cicd-mtls-deployment.py">Validator script</reference>
</text>
