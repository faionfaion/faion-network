# purpose: Multi-stage Dockerfile with cache mounts + distroless + non-root + digest-pinned base
# consumes: source code + base image digest
# produces: optimized container image
# depends-on: content/01-core-rules.xml
# token-budget-impact: ~250 tokens when loaded as context

# syntax=docker/dockerfile:1.7
FROM gcr.io/distroless/static-debian12 AS runtime
USER 10001
COPY app /app
ENTRYPOINT ["/app"]
