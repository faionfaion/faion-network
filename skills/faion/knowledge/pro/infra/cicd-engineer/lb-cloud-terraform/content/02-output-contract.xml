<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cloud LB Terraform Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the Terraform LB artefact this methodology produces. Validator enforces deletion protection, TLS policy, logs, redirect, security-group tightness.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lb-cloud-terraform.json",
  "type": "object",
  "required": ["provider", "lb_type", "deletion_protection", "tls_policy", "access_logs_bucket", "http_to_https_redirect", "security_group_tight"],
  "properties": {
    "provider": {"enum": ["aws", "gcp"]},
    "lb_type": {"enum": ["alb", "nlb", "gcp-global-http", "gcp-global-tcp", "azure"]},
    "deletion_protection": {"type": "boolean", "const": true},
    "tls_policy": {"type": "string", "pattern": "^(ELBSecurityPolicy-TLS13-1-2-2021-06|MODERN|RESTRICTED)$"},
    "access_logs_bucket": {"type": "string", "minLength": 3},
    "http_to_https_redirect": {"type": "boolean", "const": true},
    "security_group_tight": {"type": "boolean", "const": true},
    "waf_attached": {"type": "boolean"},
    "target_health_check_path": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "provider": "aws",
  "lb_type": "alb",
  "deletion_protection": true,
  "tls_policy": "ELBSecurityPolicy-TLS13-1-2-2021-06",
  "access_logs_bucket": "company-alb-logs-prod",
  "http_to_https_redirect": true,
  "security_group_tight": true,
  "waf_attached": true,
  "target_health_check_path": "/health"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "provider": "aws",
  "lb_type": "alb",
  "deletion_protection": false,
  "tls_policy": "ELBSecurityPolicy-2016-08",
  "access_logs_bucket": "",
  "http_to_https_redirect": false,
  "security_group_tight": false
}
]]></code>
    <note>No deletion protection; TLS 1.0/1.1 policy; no logs; HTTP forwards plain; SG allows all → multiple rule violations.</note>
  </example>

  <forbidden>
    <pattern id="f-no-deletion-protection">deletion_protection != true on a production LB</pattern>
    <pattern id="f-old-tls">tls_policy matches ELBSecurityPolicy-2016 or earlier</pattern>
    <pattern id="f-no-logs">access_logs_bucket missing or empty</pattern>
  </forbidden>

  <reference path="scripts/validate-lb-cloud-terraform.py">Validator script</reference>
</text>
