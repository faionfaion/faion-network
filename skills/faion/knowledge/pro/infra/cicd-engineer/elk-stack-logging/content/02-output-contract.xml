<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="ELK / OpenSearch Centralized Logging Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/elk-stack-logging.json",
  "type": "object",
  "required": [
    "stack",
    "ilm_policy",
    "security_enabled",
    "agent_auth",
    "structured_logs_only",
    "kibana_dashboards_versioned"
  ],
  "properties": {
    "stack": {
      "enum": [
        "elasticsearch-elk",
        "opensearch"
      ]
    },
    "ilm_policy": {
      "type": "object",
      "required": [
        "hot_days",
        "warm_days",
        "cold_days",
        "delete_days"
      ]
    },
    "security_enabled": {
      "const": true
    },
    "agent_auth": {
      "enum": [
        "mtls",
        "api-token"
      ]
    },
    "structured_logs_only": {
      "const": true
    },
    "kibana_dashboards_versioned": {
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "stack": "elasticsearch-elk",
  "ilm_policy": {
    "hot_days": "x",
    "warm_days": "x",
    "cold_days": "x",
    "delete_days": "x"
  },
  "security_enabled": true,
  "agent_auth": "mtls",
  "structured_logs_only": true,
  "kibana_dashboards_versioned": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "stack": null
}
]]></code>
    <note>Required field set to null and other required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>stack: must match enum: elasticsearch-elk, opensearch; otherwise reject.</item>
      <item>ilm_policy: must match object: hot_days, warm_days, cold_days, delete_days, all int&gt;=0; otherwise reject.</item>
      <item>security_enabled: must match boolean const true; otherwise reject.</item>
      <item>agent_auth: must match enum: mtls, api-token; otherwise reject.</item>
      <item>structured_logs_only: must match boolean const true; otherwise reject.</item>
      <item>kibana_dashboards_versioned: must match boolean const true; otherwise reject.</item>
    </list>
  </section>

  <reference path="scripts/validate-elk-stack-logging.py">Validator script</reference>
</text>
