<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Nginx Production LB Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals (workload, TLS, rate-limit, static content) to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-workers">worker_processes set to "auto"?</root-question>

    <branch when="workers != auto">
      <conclusion ref="worker-auto" verdict="set worker_processes auto; worker_rlimit_nofile 65535;"/>
    </branch>

    <branch when="workers == auto">
      <question id="q-zone">Upstream blocks have zone&lt;name&gt;?</question>
      <branch when="zone_missing == true">
        <conclusion ref="upstream-zone" verdict="add zone &lt;name&gt; 64k; to every upstream block"/>
      </branch>
      <branch when="zone_missing == false">
        <question id="q-keepalive">upstream keepalive set + proxy_http_version 1.1?</question>
        <branch when="keepalive_missing == true">
          <conclusion ref="keepalive-upstream" verdict="add keepalive 32 + proxy_http_version 1.1 + Connection \"\""/>
        </branch>
        <branch when="keepalive_missing == false">
          <question id="q-tls">TLS 1.2+ AND OCSP stapling?</question>
          <branch when="tls_low == true">
            <conclusion ref="tls-1-2-min" verdict="ssl_protocols TLSv1.2 TLSv1.3 + ssl_stapling on"/>
          </branch>
          <branch when="tls_low == false">
            <question id="q-rl">limit_req_zone declared?</question>
            <branch when="rate_limit_missing == true">
              <conclusion ref="limit-req-zone" verdict="declare limit_req_zone + apply limit_req on public routes"/>
            </branch>
            <branch when="rate_limit_missing == false">
              <conclusion ref="security-headers" verdict="add 5 security headers (HSTS, XFO, XCTO, Referrer-Policy, Permissions-Policy)"/>
            </branch>
          </branch>
        </question>
      </branch>
    </branch>
  </decision-tree>

  <example trace="greenfield-public-https">
    workers=auto → zone present → keepalive 32 present → TLS 1.2+ + stapling → limit_req_zone declared → 5 headers added → satisfies all 6 rules.
  </example>
</text>
