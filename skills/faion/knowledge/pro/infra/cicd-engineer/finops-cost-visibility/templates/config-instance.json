{
  "mandatory_tags": [
    "team",
    "product",
    "environment",
    "cost-center",
    "owner"
  ],
  "policy_engine": {
    "name": "aws-config",
    "config_ref": "config/tag-policy.yaml"
  },
  "dashboard": {
    "tool": "grafana",
    "url": "https://grafana.acme.com/d/cost",
    "refresh_hours": 24,
    "panels": [
      "total_spend",
      "by_team",
      "by_env",
      "by_service"
    ]
  },
  "baseline_kpis": {
    "unit_cost_metric": "usd_per_mau",
    "value": 0.42,
    "baseline_date": "2026-05-01"
  },
  "coverage_gate": {
    "target_pct": 80,
    "blocker": "promotion_to_optimize_phase"
  },
  "owner": "finops-lead@team.io",
  "last_reviewed": "2026-05-23",
  "__faion_header__": {
    "purpose": "FinOps INFORM Phase \u2014 Cost Visibility config skeleton",
    "consumes": "Prerequisites bundle (see AGENTS.md)",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends_on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  }
}
