<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="FinOps INFORM Phase — Cost Visibility Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/finops-cost-visibility.json",
  "title": "FinOps INFORM Phase \u2014 Cost Visibility",
  "type": "object",
  "required": [
    "mandatory_tags",
    "policy_engine",
    "dashboard",
    "baseline_kpis",
    "coverage_gate",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "mandatory_tags": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string"
      }
    },
    "policy_engine": {
      "type": "object",
      "required": [
        "name",
        "config_ref"
      ]
    },
    "dashboard": {
      "type": "object",
      "required": [
        "tool",
        "url",
        "refresh_hours",
        "panels"
      ]
    },
    "baseline_kpis": {
      "type": "object",
      "required": [
        "unit_cost_metric",
        "value",
        "baseline_date"
      ]
    },
    "coverage_gate": {
      "type": "object",
      "required": [
        "target_pct",
        "blocker"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "mandatory_tags": [
    "team",
    "product",
    "environment",
    "cost-center",
    "owner"
  ],
  "policy_engine": {
    "name": "aws-config",
    "config_ref": "config/tag-policy.yaml"
  },
  "dashboard": {
    "tool": "grafana",
    "url": "https://grafana.acme.com/d/cost",
    "refresh_hours": 24,
    "panels": [
      "total_spend",
      "by_team",
      "by_env",
      "by_service"
    ]
  },
  "baseline_kpis": {
    "unit_cost_metric": "usd_per_mau",
    "value": 0.42,
    "baseline_date": "2026-05-01"
  },
  "coverage_gate": {
    "target_pct": 80,
    "blocker": "promotion_to_optimize_phase"
  },
  "owner": "finops-lead@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "mandatory_tags": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-finops-cost-visibility.py">Validator script</reference>
</text>
