<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Kubernetes Cluster Backup with Velero Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/backup-kubernetes-velero.json",
  "type": "object",
  "required": [
    "velero_version",
    "uploader_type",
    "csi_enabled",
    "backup_storage_location",
    "schedules",
    "hooks_for_stateful"
  ],
  "properties": {
    "velero_version": {
      "type": "string",
      "pattern": "^1\\.(1[5-9]|[2-9][0-9])\\."
    },
    "uploader_type": {
      "const": "kopia"
    },
    "csi_enabled": {
      "const": true
    },
    "backup_storage_location": {
      "type": "object",
      "required": [
        "kind",
        "uri",
        "region"
      ],
      "properties": {
        "kind": {
          "enum": [
            "s3",
            "gcs",
            "azure-blob"
          ]
        },
        "uri": {
          "type": "string"
        },
        "region": {
          "type": "string"
        }
      }
    },
    "schedules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "cron",
          "ttl_hours"
        ]
      }
    },
    "hooks_for_stateful": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "velero_version": "example-value",
  "uploader_type": "kopia",
  "csi_enabled": true,
  "backup_storage_location": {
    "kind": "s3",
    "uri": "x",
    "region": "x"
  },
  "schedules": [
    "x"
  ],
  "hooks_for_stateful": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "velero_version": null
}
]]></code>
    <note>Required field set to null and other required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>velero_version: must match string &gt;= 1.15.0; otherwise reject.</item>
      <item>uploader_type: must match const kopia; otherwise reject.</item>
      <item>csi_enabled: must match const true; otherwise reject.</item>
      <item>backup_storage_location: must match object: kind, uri, region different from cluster_region; otherwise reject.</item>
      <item>schedules: must match array of Schedule descriptors with name, cron, ttl_hours, namespace_includes; otherwise reject.</item>
      <item>hooks_for_stateful: must match boolean: pre/post hooks declared when stateful namespaces included; otherwise reject.</item>
    </list>
  </section>

  <reference path="scripts/validate-backup-kubernetes-velero.py">Validator script</reference>
</text>
