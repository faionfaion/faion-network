<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Jenkins Basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the Jenkinsfile / JCasC artefact this methodology produces. Validator enforces required keys + agent strategy + secret handling.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/jenkins-basics.json",
  "type": "object",
  "required": ["syntax", "agent_kind", "controller_executors", "options", "secrets_strategy", "post_actions"],
  "properties": {
    "syntax": {"enum": ["declarative", "scripted"]},
    "agent_kind": {"enum": ["kubernetes", "docker", "label", "controller-only"]},
    "controller_executors": {"type": "integer", "minimum": 0, "maximum": 0},
    "options": {
      "type": "object",
      "required": ["timeout_minutes", "buildDiscarder_keep", "disableConcurrentBuilds"],
      "properties": {
        "timeout_minutes": {"type": "integer", "minimum": 1, "maximum": 240},
        "buildDiscarder_keep": {"type": "integer", "minimum": 1},
        "disableConcurrentBuilds": {"type": "boolean", "const": true}
      }
    },
    "secrets_strategy": {"enum": ["withCredentials", "credentials-binding", "vault-plugin"]},
    "post_actions": {
      "type": "array",
      "items": {"enum": ["cleanWs", "junit", "archiveArtifacts", "slackSend", "emailext"]},
      "contains": {"const": "cleanWs"}
    },
    "jcasc_yaml_path": {"type": "string"},
    "shared_library_pinned": {"type": "boolean"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "syntax": "declarative",
  "agent_kind": "kubernetes",
  "controller_executors": 0,
  "options": {"timeout_minutes": 30, "buildDiscarder_keep": 10, "disableConcurrentBuilds": true},
  "secrets_strategy": "withCredentials",
  "post_actions": ["cleanWs", "junit", "slackSend"],
  "jcasc_yaml_path": "jcasc/jenkins.yaml",
  "shared_library_pinned": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "syntax": "scripted",
  "agent_kind": "controller-only",
  "controller_executors": 4,
  "options": {"timeout_minutes": 0, "disableConcurrentBuilds": false},
  "secrets_strategy": "hardcoded",
  "post_actions": []
}
]]></code>
    <note>Scripted (not declarative); builds on controller; no timeout; hardcoded secrets; missing cleanWs.</note>
  </example>

  <forbidden>
    <pattern id="f-hardcoded-cred">String literal that matches `password\s*=\s*['\"]\w+['\"]` inside the Jenkinsfile.</pattern>
    <pattern id="f-agent-any">Top-level `agent any` directive.</pattern>
    <pattern id="f-controller-builds">controller_executors &gt; 0.</pattern>
  </forbidden>

  <reference path="scripts/validate-jenkins-basics.py">Validator script</reference>
</text>
