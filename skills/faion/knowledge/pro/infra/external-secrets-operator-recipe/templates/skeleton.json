{
  "__faion_header__": {
    "purpose": "Skeleton artefact for External Secrets Operator Recipe matching content/02-output-contract.xml schema.",
    "consumes": "user inputs per content/01-core-rules.xml prerequisites",
    "produces": "Validated artefact (produces=config)",
    "depends_on": "content/02-output-contract.xml",
    "token_budget_impact": "~400 tokens when filled in"
  },
  "cluster_secret_store": {
    "name": "vault-prod",
    "backend": "vault",
    "auth_method": "kubernetes",
    "identity_ref": "system:serviceaccount:eso:vault-auth"
  },
  "external_secrets": [
    {
      "name": "api-db-creds",
      "namespace": "prod-api",
      "refresh_interval": "1h",
      "target_path": "/var/run/secrets/db/",
      "key_refs": [
        "prod/api/db-password"
      ]
    }
  ],
  "rbac_scope": "namespace",
  "alert_on_sync_failure": true,
  "rotation_test_runbook_path": "runbooks/secret-rotation.md",
  "mount_type": "file"
}
