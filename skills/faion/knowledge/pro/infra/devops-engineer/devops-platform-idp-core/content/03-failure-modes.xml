<text id="03-failure-modes" title="Internal Developer Platform (IDP) Core Model Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="project-mode" severity="high">
      <symptom>Year-2 IDP is abandoned; tooling rots.</symptom>
      <root-cause>Treated as one-off project.</root-cause>
      <fix>Run as product; PM + roadmap + NPS.</fix>
    </antipattern>
    <antipattern id="no-personas" severity="medium">
      <symptom>Built features nobody uses.</symptom>
      <root-cause>No persona research.</root-cause>
      <fix>Run discovery interviews; list top pains per persona.</fix>
    </antipattern>
    <antipattern id="metrics-vanity-only" severity="medium">
      <symptom>Adoption % flat; nobody knows why.</symptom>
      <root-cause>No DORA tie-in.</root-cause>
      <fix>DORA + adoption metrics together.</fix>
    </antipattern>
    <antipattern id="understaffed" severity="high">
      <symptom>On-call burns out; quality drops.</symptom>
      <root-cause>&lt;3 engineers.</root-cause>
      <fix>Staff ≥3 dedicated; not borrowed SREs.</fix>
    </antipattern>

  </section>
</text>
