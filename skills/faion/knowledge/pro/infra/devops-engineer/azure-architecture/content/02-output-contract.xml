<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Azure Architecture (Well-Architected + Landing Zones) Output Contract" version="1.1.0" est_tokens="1000" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact. Validator script in `scripts/validate-azure-architecture.py` enforces it.</summary>

  <schema lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/azure-architecture.json",
  "type": "object",
  "required": [
    "org",
    "tenant_id",
    "iac_engine",
    "mg_hierarchy_levels",
    "policy_initiative",
    "identity",
    "network",
    "bcdr"
  ],
  "properties": {
    "org": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "iac_engine": {
      "enum": [
        "avm-bicep",
        "terraform-avm"
      ]
    },
    "mg_hierarchy_levels": {
      "type": "integer",
      "minimum": 3
    },
    "policy_initiative": {
      "type": "string",
      "minLength": 1
    },
    "identity": {
      "type": "object",
      "required": [
        "entra_id",
        "managed_identity",
        "pim_enabled"
      ],
      "properties": {
        "entra_id": {
          "type": "boolean",
          "const": true
        },
        "managed_identity": {
          "type": "boolean",
          "const": true
        },
        "pim_enabled": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "network": {
      "type": "object",
      "required": [
        "topology"
      ],
      "properties": {
        "topology": {
          "enum": [
            "hub-spoke",
            "virtual-wan",
            "mesh"
          ]
        },
        "private_endpoints": {
          "type": "boolean"
        }
      }
    },
    "bcdr": {
      "type": "object",
      "required": [
        "immutable_backup",
        "rto_hours",
        "rpo_hours"
      ],
      "properties": {
        "immutable_backup": {
          "type": "boolean",
          "const": true
        },
        "rto_hours": {
          "type": "number",
          "minimum": 0
        },
        "rpo_hours": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
]]></schema>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "org": "acme",
  "tenant_id": "00000000-0000-0000-0000-000000000000",
  "iac_engine": "avm-bicep",
  "mg_hierarchy_levels": 3,
  "policy_initiative": "baseline-initiative",
  "identity": {
    "entra_id": true,
    "managed_identity": true,
    "pim_enabled": true
  },
  "network": {
    "topology": "hub-spoke",
    "private_endpoints": true
  },
  "bcdr": {
    "immutable_backup": true,
    "rto_hours": 4,
    "rpo_hours": 1
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "org": "acme",
  "tenant_id": "bad",
  "iac_engine": "eslz-terraform",
  "mg_hierarchy_levels": 1,
  "policy_initiative": "",
  "identity": {
    "entra_id": false,
    "managed_identity": false,
    "pim_enabled": false
  },
  "network": {
    "topology": "mesh"
  },
  "bcdr": {
    "immutable_backup": false,
    "rto_hours": 24,
    "rpo_hours": 24
  }
}
]]></code>
    <note>ESLZ Terraform (deprecated); single MG level; no Entra/MI/PIM; mutable backup; tenant_id malformed.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">iac_engine = 'eslz-terraform' (deprecated 2026)</pattern>
    <pattern id="f2">mg_hierarchy_levels &lt; 3</pattern>
    <pattern id="f3">identity.entra_id = false OR identity.pim_enabled = false (prod)</pattern>
    <pattern id="f4">bcdr.immutable_backup = false</pattern>
    <pattern id="f5">policy_initiative empty</pattern>
  </section>

  <reference path="scripts/validate-azure-architecture.py">Validator script</reference>
</text>