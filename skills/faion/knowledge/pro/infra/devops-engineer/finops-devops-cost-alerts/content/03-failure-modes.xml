<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="FinOps Cost Alerts and Anomaly Workflow Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="single-threshold" severity="medium">
      <symptom>Budget already blown by the time the only alert fires.</symptom>
      <root-cause>Only 100% alert.</root-cause>
      <fix>Add 50/75/90/100% ladder.</fix>
    </antipattern>
    <antipattern id="shared-channel" severity="medium">
      <symptom>Alerts ignored in a noisy shared channel.</symptom>
      <root-cause>Routing to #all-cost.</root-cause>
      <fix>Per-team channel + named owner.</fix>
    </antipattern>
    <antipattern id="no-anomaly-detector" severity="high">
      <symptom>Intra-month spike caught only at month-end.</symptom>
      <root-cause>Detector disabled.</root-cause>
      <fix>Enable AWS Cost Anomaly / GCP.</fix>
    </antipattern>
    <antipattern id="freeform-investigation" severity="low">
      <symptom>Postmortems vary; lessons lost.</symptom>
      <root-cause>No structured template.</root-cause>
      <fix>Use impact/cause/remediation template.</fix>
    </antipattern>

  </section>
</text>
