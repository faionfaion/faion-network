<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AWS Monitoring, Alerting, and Disaster Recovery Decision Tree" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Routing tree mapping observable signals on the input to a rule from 01-core-rules.xml. Use when the right path is ambiguous.</summary>

  <decision-tree>
    <root-question id="q-root">RTO target?</root-question>
    <branch when="rto &gt; 24h">
      <conclusion ref="dr-strategy-matches-rto" verdict="backup-restore + quarterly drill"/>
    </branch>
    <branch when="rto &gt;= 1h AND rto &lt;= 24h">
      <conclusion ref="dr-strategy-matches-rto" verdict="pilot-light + quarterly drill"/>
    </branch>
    <branch when="rto &lt; 1h AND rto &gt;= seconds">
      <conclusion ref="dr-strategy-matches-rto" verdict="warm-standby + quarterly drill"/>
    </branch>
    <branch when="rto &lt; seconds">
      <conclusion ref="dr-strategy-matches-rto" verdict="active-active multi-region + monthly drill"/>
    </branch>
  </decision-tree>

  <example trace="checkout-api">rto=1h → warm-standby. References rule dr-strategy-matches-rto.</example>
</text>