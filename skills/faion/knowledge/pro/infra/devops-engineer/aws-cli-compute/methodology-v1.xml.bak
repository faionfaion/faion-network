<methodology slug="aws-cli-compute">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>devops-engineer</domain>
    <summary>AWS CLI operations for EC2 instances, S3 buckets, key pairs, AMIs, Elastic IPs, and Lambda functions including invocation and event mappings.</summary>
