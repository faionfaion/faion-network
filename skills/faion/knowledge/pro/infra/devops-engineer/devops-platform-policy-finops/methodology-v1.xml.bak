<methodology slug="devops-platform-policy-finops">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>devops-engineer</domain>
    <summary>Platform governance via OPA/Gatekeeper admission policies (labels, resource limits, security) plus FinOps integration for per-team cost visibility and pre-deployment cost estimation.</summary>
    <tags>
