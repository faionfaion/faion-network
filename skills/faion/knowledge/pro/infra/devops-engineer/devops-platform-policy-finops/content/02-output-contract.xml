<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Platform Governance: Policy-as-Code + FinOps Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/devops-platform-policy-finops.json",
  "title": "Platform Governance: Policy-as-Code + FinOps",
  "type": "object",
  "required": [
    "admission_policies",
    "cost_visibility",
    "cost_estimate_threshold_usd",
    "policy_bundle_repo",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "admission_policies": {
      "type": "array",
      "minItems": 4,
      "items": {
        "enum": [
          "labels_required",
          "resource_limits",
          "image_allowlist",
          "host_network_ban",
          "privileged_ban",
          "psa_baseline"
        ]
      }
    },
    "cost_visibility": {
      "type": "object",
      "required": [
        "per_team",
        "dashboard_url"
      ]
    },
    "cost_estimate_threshold_usd": {
      "type": "integer",
      "minimum": 0
    },
    "policy_bundle_repo": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "admission_policies": [
    "labels_required",
    "resource_limits",
    "image_allowlist",
    "host_network_ban"
  ],
  "cost_visibility": {
    "per_team": true,
    "dashboard_url": "https://grafana.acme.io/d/cost-per-team"
  },
  "cost_estimate_threshold_usd": 50,
  "policy_bundle_repo": "git@github.com:acme/opa-policies.git",
  "owner": "platform-sec@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "admission_policies": [],
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-devops-platform-policy-finops.py">Validator script</reference>
</text>
