              },
              "pass": {
                "type": "boolean"
              },
              "severity": {
                "enum": [
                  "HIGH",
                  "MED",
                  "LOW"
                ]
              }
            }
          },
          "minItems": 1
        },
        "sustainability": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
