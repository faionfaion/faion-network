<methodology slug="docker-llm-prompts">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>devops-engineer</domain>
    <summary>LLM prompt templates for Docker tasks: Dockerfile generation, optimization, security audit, troubleshooting, CI/CD pipeline integration, and architecture review.</summary>
    <tags>
      <tag>docker</tag>
      <tag>llm-prompts</tag>
