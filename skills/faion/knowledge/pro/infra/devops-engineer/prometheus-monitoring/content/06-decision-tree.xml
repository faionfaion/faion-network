<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Prometheus Monitoring Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Includes a skip-this-methodology branch.</summary>

  <decision-tree>
    <root-question id="q-root">Metric purpose?</root-question>
    <branch when="purpose == per_request_event">
      <conclusion ref="r3-no-unbounded-labels">use a log or trace system, not Prometheus</conclusion>
    </branch>
    <branch when="purpose == latency_measurement">
      <question id="q-sub-0">single replica or distributed?</question>
      <branch when="distributed == true">
        <conclusion ref="r1-histogram-over-summary">use histogram with explicit buckets</conclusion>
      </branch>
      <branch when="distributed == false">
        <conclusion ref="r2-naming-convention">summary acceptable; still apply naming</conclusion>
      </branch>
    </branch>
    <branch when="purpose == counter_rate">
      <conclusion ref="r7-rate-on-counters">wrap in rate(); never plot raw counter</conclusion>
    </branch>
    <branch when="purpose == alert">
      <conclusion ref="r6-symptom-not-cause-alerts">alert on symptom; add runbook_url</conclusion>
    </branch>
    <branch when="preconditions_not_met == true">
      <conclusion ref="r2-naming-convention">skip-this-methodology — preconditions in &quot;Applies If&quot; not satisfied</conclusion>
    </branch>
  </decision-tree>

  <example trace="typical">
    <note>Metric purpose? → matches branch &quot;purpose == per_request_event&quot; → conclusion ref=r3-no-unbounded-labels</note>
  </example>
</text>
