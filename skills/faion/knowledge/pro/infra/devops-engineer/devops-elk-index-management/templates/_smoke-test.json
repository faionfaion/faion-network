{
  "__faion_header__": {
    "purpose": "Minimum config used by validate-devops-elk-index-management.py --self-test",
    "consumes": "inputs declared in AGENTS.md `## Prerequisites`",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~350 tokens when loaded"
  },
  "index_pattern": "logs-*",
  "policy_name": "logs-policy",
  "phases": [
    "hot",
    "warm",
    "cold",
    "delete"
  ],
  "rollover": {
    "max_primary_shard_size": "50gb",
    "max_age_days": 7
  },
  "shard_count": 1,
  "replica_count": 1,
  "write_alias": "logs-write"
}
