{
  "__faion_header__": {
    "purpose": "Index template + component templates for logs-*",
    "consumes": "inputs declared in AGENTS.md `## Prerequisites`",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~350 tokens when loaded"
  },
  "index_patterns": [
    "logs-*"
  ],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1,
      "index.lifecycle.name": "logs-policy",
      "index.lifecycle.rollover_alias": "logs-write",
      "refresh_interval": "5s"
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "service": {
          "type": "keyword"
        },
        "environment": {
          "type": "keyword"
        },
        "level": {
          "type": "keyword"
        },
        "message": {
          "type": "text"
        },
        "kubernetes.pod.name": {
          "type": "keyword"
        }
      }
    }
  },
  "data_stream": {}
}
