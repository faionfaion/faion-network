<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Load Balancer Health Checks Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/devops-lb-health-checks.json",
  "title": "Load Balancer Health Checks",
  "type": "object",
  "required": [
    "liveness",
    "readiness",
    "tuning",
    "language_impl",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "liveness": {
      "type": "object",
      "required": [
        "path",
        "method",
        "expect_status"
      ]
    },
    "readiness": {
      "type": "object",
      "required": [
        "path",
        "method",
        "expect_status",
        "deps_checked"
      ]
    },
    "tuning": {
      "type": "object",
      "required": [
        "interval_s",
        "timeout_ms",
        "fall",
        "rise"
      ]
    },
    "language_impl": {
      "enum": [
        "go",
        "python_fastapi",
        "node_express",
        "other"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "liveness": {
    "path": "/healthz",
    "method": "GET",
    "expect_status": 200
  },
  "readiness": {
    "path": "/ready",
    "method": "GET",
    "expect_status": 200,
    "deps_checked": [
      "postgres",
      "redis"
    ]
  },
  "tuning": {
    "interval_s": 10,
    "timeout_ms": 500,
    "fall": 3,
    "rise": 2
  },
  "language_impl": "python_fastapi",
  "owner": "sre@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "liveness": {
    "path": "/healthz"
  },
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-devops-lb-health-checks.py">Validator script</reference>
</text>
