{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deployment Event",
  "description": "Schema for recording a production deployment event for DORA metrics collection",
  "type": "object",
  "required": ["service", "commit", "timestamp", "status"],
  "properties": {
    "service": {
      "type": "string",
      "description": "Service or repository name (e.g. myorg/myapp)"
    },
    "commit": {
      "type": "string",
      "description": "Git commit SHA of the deployed version"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 deployment completion timestamp"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure", "rollback"],
      "description": "Deployment outcome"
    },
    "environment": {
      "type": "string",
      "enum": ["production", "staging"],
      "description": "Target environment"
    },
    "deployer": {
      "type": "string",
      "description": "GitHub Actions actor or human who triggered the deploy"
    },
    "version": {
      "type": "string",
      "description": "Application version tag or build number"
    }
  }
}
