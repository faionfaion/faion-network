<text id="03-failure-modes" title="Docker Core Operations Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="root-user-runtime" severity="high">
      <symptom>Container escape gains root on host namespace.</symptom>
      <root-cause>No `USER` directive.</root-cause>
      <fix>Add `RUN adduser app &amp;&amp; USER app`.</fix>
    </antipattern>
    <antipattern id="single-stage-build" severity="medium">
      <symptom>Production image carries 800 MB of build tools.</symptom>
      <root-cause>No multi-stage split.</root-cause>
      <fix>Builder stage → runtime copy `--from=builder`.</fix>
    </antipattern>
    <antipattern id="secret-in-arg" severity="high">
      <symptom>AWS key leaked in image layer.</symptom>
      <root-cause>`ARG AWS_KEY=...`.</root-cause>
      <fix>Use `RUN --mount=type=secret`.</fix>
    </antipattern>
    <antipattern id="no-dockerignore" severity="medium">
      <symptom>Build context &gt; 500 MB; CI slow.</symptom>
      <root-cause>`.dockerignore` missing.</root-cause>
      <fix>Add `.dockerignore` excluding `.git`, `node_modules`, etc.</fix>
    </antipattern>

  </section>
</text>
