<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Docker Core Operations Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/docker.json",
  "title": "Docker Core Operations",
  "type": "object",
  "required": [
    "base_image",
    "stages",
    "user",
    "healthcheck",
    "dockerignore_present",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "base_image": {
      "type": "object",
      "required": [
        "name",
        "digest_pinned"
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "name",
          "role"
        ]
      }
    },
    "user": {
      "type": "string",
      "pattern": "^(?!root$|0$).+"
    },
    "healthcheck": {
      "type": "object",
      "required": [
        "cmd",
        "interval"
      ]
    },
    "dockerignore_present": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "base_image": {
    "name": "python:3.12-slim",
    "digest_pinned": true
  },
  "stages": [
    {
      "name": "builder",
      "role": "build"
    },
    {
      "name": "runtime",
      "role": "run"
    }
  ],
  "user": "app",
  "healthcheck": {
    "cmd": "curl -fsS http://localhost:8080/healthz",
    "interval": "30s"
  },
  "dockerignore_present": true,
  "owner": "sre@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "base_image": {
    "name": "ubuntu",
    "digest_pinned": false
  },
  "user": "root",
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-docker.py">Validator script</reference>
</text>
