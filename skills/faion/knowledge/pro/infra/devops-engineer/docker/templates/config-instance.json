{
  "base_image": {
    "name": "python:3.12-slim",
    "digest_pinned": true
  },
  "stages": [
    {
      "name": "builder",
      "role": "build"
    },
    {
      "name": "runtime",
      "role": "run"
    }
  ],
  "user": "app",
  "healthcheck": {
    "cmd": "curl -fsS http://localhost:8080/healthz",
    "interval": "30s"
  },
  "dockerignore_present": true,
  "owner": "sre@acme.io",
  "last_reviewed": "2026-05-23",
  "__faion_header__": {
    "purpose": "Docker Core Operations config skeleton",
    "consumes": "Prerequisites bundle (see AGENTS.md)",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends_on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  }
}
