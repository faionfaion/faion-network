{
  "__faion_header__": {
    "purpose": "Minimum config artefact used by validate-devops-aws-serverless-api.py --self-test",
    "consumes": "inputs declared in AGENTS.md `## Prerequisites`",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~350 tokens when loaded"
  },
  "project": "checkout-api",
  "lambda": {
    "architecture": "arm64",
    "runtime": "python3.12",
    "tracing_mode": "Active",
    "timeout_s": 30
  },
  "api_gateway": {
    "protocol_type": "HTTP",
    "cors_origins": [
      "https://app.example.com"
    ],
    "throttling_burst": 5000,
    "throttling_rate": 1000,
    "custom_domain": "api.example.com"
  },
  "dynamodb": {
    "billing_mode": "PAY_PER_REQUEST",
    "pitr": true
  },
  "dlq": true,
  "step_functions": false
}
