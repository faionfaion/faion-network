<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Backstage Developer Portal Deployment Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/devops-platform-backstage.json",
  "title": "Backstage Developer Portal Deployment",
  "type": "object",
  "required": [
    "entities",
    "techdocs",
    "templates",
    "plugins",
    "ownership",
    "upgrade_cadence_days",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "owner"
        ]
      }
    },
    "techdocs": {
      "type": "object",
      "required": [
        "source_layout",
        "builder"
      ]
    },
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "purpose"
        ]
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "version"
        ]
      }
    },
    "ownership": {
      "type": "object",
      "required": [
        "product_owner",
        "fte"
      ]
    },
    "upgrade_cadence_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "entities": [
    {
      "name": "api-checkout",
      "kind": "Component",
      "owner": "team-checkout"
    }
  ],
  "techdocs": {
    "source_layout": "mkdocs+docs",
    "builder": "ci"
  },
  "templates": [
    {
      "name": "new-go-service",
      "purpose": "scaffold service + CI + ArgoCD app"
    }
  ],
  "plugins": [
    {
      "id": "cost-insights",
      "version": "0.50.0"
    }
  ],
  "ownership": {
    "product_owner": "platform-pm@acme.io",
    "fte": 1.0
  },
  "upgrade_cadence_days": 14,
  "owner": "platform-pm@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "entities": [],
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-devops-platform-backstage.py">Validator script</reference>
</text>
