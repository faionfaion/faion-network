<text id="02-output-contract" title="Jenkins Declarative Pipelines Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the `code` artefact produced by jenkins-pipelines, plus valid / invalid / forbidden examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "slug",
    "language",
    "entrypoint",
    "files"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "language": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "build_command": {
      "type": "string"
    },
    "test_command": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "jenkins-pipelines",
  "language": "yaml",
  "entrypoint": "Chart.yaml",
  "files": [
    "Chart.yaml",
    "values.yaml",
    "templates/deployment.yaml"
  ],
  "build_command": "helm lint .",
  "test_command": "helm template . | kubeconform -"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "jenkins-pipelines"
}
]]></code>
    <note>Missing all required fields beyond `slug`; schema rejects on the first missing required key.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Plain prose / markdown output instead of a JSON object</item>
      <item>Placeholder tokens or empty required fields anywhere inside the artefact</item>
      <item>Unbounded arrays whose item schema is missing</item>
    </list>
  </section>

  <reference path="scripts/validate-jenkins-pipelines.py">Validator script — exit 0 on pass, 1 on fail.</reference>
</text>
