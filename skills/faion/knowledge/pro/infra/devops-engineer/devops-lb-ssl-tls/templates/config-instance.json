{
  "strategy": "termination",
  "min_tls_version": "TLSv1.2",
  "cipher_list": [
    "ECDHE-ECDSA-AES128-GCM-SHA256",
    "ECDHE-RSA-AES128-GCM-SHA256",
    "ECDHE-ECDSA-CHACHA20-POLY1305",
    "ECDHE-RSA-AES256-GCM-SHA384"
  ],
  "hsts": {
    "enabled": true,
    "max_age": 63072000,
    "include_subdomains": true,
    "preload": true
  },
  "ocsp_stapling": true,
  "cert_source": "cert_manager",
  "owner": "sec@acme.io",
  "last_reviewed": "2026-05-23",
  "__faion_header__": {
    "purpose": "SSL/TLS Termination at the Load Balancer config skeleton",
    "consumes": "Prerequisites bundle (see AGENTS.md)",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends_on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  }
}
