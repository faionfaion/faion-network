<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="SSL/TLS Termination at the Load Balancer Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="tls10-or-11" severity="high">
      <symptom>Compliance scanner flags weak TLS; PCI audit fail.</symptom>
      <root-cause>Old protocol versions still enabled.</root-cause>
      <fix>Disable TLS 1.0/1.1; allow only TLS 1.2+.</fix>
    </antipattern>
    <antipattern id="default-cipher-list" severity="medium">
      <symptom>Weak ciphers (CBC, RC4) negotiated by old clients.</symptom>
      <root-cause>No explicit cipher allowlist.</root-cause>
      <fix>Pin Mozilla intermediate AEAD list.</fix>
    </antipattern>
    <antipattern id="no-hsts" severity="medium">
      <symptom>MITM downgrade attacks possible on public domain.</symptom>
      <root-cause>HSTS header missing.</root-cause>
      <fix>Add preload-eligible HSTS header.</fix>
    </antipattern>
    <antipattern id="manual-cert-rotation" severity="high">
      <symptom>Cert expired Sunday 03:00; pager fire.</symptom>
      <root-cause>No automation.</root-cause>
      <fix>cert-manager or ACM auto-renewal.</fix>
    </antipattern>

  </section>
</text>
