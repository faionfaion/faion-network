<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Container Image Digest Pinning Policy Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the `config` artefact produced by image-digest-pinning-policy, plus valid / invalid / forbidden examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "slug",
    "version",
    "settings"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "settings": {
      "type": "object",
      "minProperties": 3
    },
    "applied_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "image-digest-pinning-policy",
  "version": "1.0.0",
  "settings": {
    "key1": "value1",
    "key2": "value2",
    "key3": "value3"
  },
  "applied_to": [
    "prod"
  ],
  "notes": "Generated by image-digest-pinning-policy methodology."
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "image-digest-pinning-policy"
}
]]></code>
    <note>Missing all required fields beyond `slug`; schema rejects on the first missing required key.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Plain prose / markdown output instead of a JSON object</item>
      <item>Placeholder tokens or empty required fields anywhere inside the artefact</item>
      <item>Unbounded arrays whose item schema is missing</item>
    </list>
  </section>

  <reference path="scripts/validate-image-digest-pinning-policy.py">Validator script — exit 0 on pass, 1 on fail.</reference>
</text>
