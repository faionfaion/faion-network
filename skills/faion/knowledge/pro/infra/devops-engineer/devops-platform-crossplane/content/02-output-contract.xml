<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Crossplane Composition for Self-Service Infra Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/devops-platform-crossplane.json",
  "title": "Crossplane Composition for Self-Service Infra",
  "type": "object",
  "required": [
    "abstractions",
    "provider_credentials",
    "security_defaults",
    "blast_radius_caps",
    "gitops_managed",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "abstractions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "xrd_kind",
          "resources_composed"
        ]
      }
    },
    "provider_credentials": {
      "enum": [
        "irsa",
        "workload_identity",
        "managed_identity",
        "static_long_lived"
      ]
    },
    "security_defaults": {
      "type": "array",
      "minItems": 1
    },
    "blast_radius_caps": {
      "type": "object",
      "required": [
        "max_cpu",
        "max_memory_gb",
        "max_storage_gb",
        "max_instances"
      ]
    },
    "gitops_managed": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "abstractions": [
    {
      "name": "PostgresDB",
      "xrd_kind": "PostgresDB",
      "resources_composed": [
        "RDSInstance",
        "SubnetGroup",
        "SecurityGroup"
      ]
    }
  ],
  "provider_credentials": "irsa",
  "security_defaults": [
    "encryption_at_rest",
    "backup_7d",
    "iam_least_privilege"
  ],
  "blast_radius_caps": {
    "max_cpu": 16,
    "max_memory_gb": 64,
    "max_storage_gb": 500,
    "max_instances": 5
  },
  "gitops_managed": true,
  "owner": "platform@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "abstractions": [],
  "provider_credentials": "static_long_lived",
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-devops-platform-crossplane.py">Validator script</reference>
</text>
