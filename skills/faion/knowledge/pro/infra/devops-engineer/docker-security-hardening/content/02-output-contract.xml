<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Docker Security Hardening Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/docker-security-hardening.json",
  "title": "Docker Security Hardening",
  "type": "object",
  "required": [
    "user",
    "capabilities",
    "read_only_fs",
    "secrets_policy",
    "scanner",
    "signing",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "user": {
      "type": "string",
      "pattern": "^(?!root$|0$).+"
    },
    "capabilities": {
      "type": "object",
      "required": [
        "drop",
        "add"
      ]
    },
    "read_only_fs": {
      "type": "boolean"
    },
    "secrets_policy": {
      "enum": [
        "docker_secrets",
        "vault",
        "irsa",
        "workload_identity",
        "envfile_rejected"
      ]
    },
    "scanner": {
      "type": "object",
      "required": [
        "tool",
        "fail_on_severity"
      ]
    },
    "signing": {
      "type": "object",
      "required": [
        "enabled",
        "tool"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "user": "app",
  "capabilities": {
    "drop": [
      "ALL"
    ],
    "add": [
      "NET_BIND_SERVICE"
    ]
  },
  "read_only_fs": true,
  "secrets_policy": "vault",
  "scanner": {
    "tool": "trivy",
    "fail_on_severity": "HIGH"
  },
  "signing": {
    "enabled": true,
    "tool": "cosign"
  },
  "owner": "sec@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "user": "root",
  "capabilities": {
    "drop": []
  },
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-docker-security-hardening.py">Validator script</reference>
</text>
