<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="On-Call Rotation Bootstrap Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, with valid + invalid examples and a forbidden-pattern list.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/on-call-rotation-bootstrap.json",
  "type": "object",
  "required": [
    "charter",
    "schedule",
    "load_report"
  ],
  "properties": {
    "charter": {
      "type": "string",
      "description": "string"
    },
    "schedule": {
      "type": "string",
      "description": "string (pagerduty|opsgenie|betterstack|squadcast)"
    },
    "load_report": {
      "type": "string",
      "description": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "charter": {
    "team_name": "platform",
    "effective_date": "2026-06-01",
    "shift_length_hours": 168,
    "tiers": "primary_plus_secondary",
    "ack_sla_seconds": {
      "sev1": 300,
      "sev2": 900,
      "sev3": 0
    },
    "escalation_tree": [
      "primary",
      "secondary",
      "manager"
    ],
    "comp_policy_doc_url": "https://wiki.acme/hr/on-call-comp",
    "rotation_owner": "tlead@acme"
  },
  "schedule": {
    "tool": "pagerduty",
    "config_path": "config/pagerduty/platform.yaml"
  },
  "load_report": {
    "period_start": "2026-05-16",
    "period_end": "2026-05-22",
    "per_engineer": [
      {
        "engineer": "alice",
        "pages": 4,
        "off_hours_pages": 2,
        "weekend_pages": 0
      }
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "charter": {
    "team_name": "",
    "shift_length_hours": 168,
    "tiers": "primary",
    "comp_policy_doc_url": ""
  }
}
]]></code>
    <note>Missing required fields and contains forbidden patterns; validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>charter.tiers = primary AND charter.participants &gt;= 8 (single-tier for team large enough to support secondary)</item>
      <item>charter.ack_sla_seconds.sev1 &gt; 600 (sev-1 must be under 10 minutes)</item>
      <item>charter.comp_policy_doc_url empty OR points to placeholder</item>
      <item>schedule.config_path missing OR not in version-controlled repo</item>
      <item>load_report omitted for &gt;2 consecutive weeks</item>
    </list>
  </section>

  <reference path="scripts/validate-on-call-rotation-bootstrap.py">Validator script enforcing required keys + forbidden patterns</reference>
</text>
