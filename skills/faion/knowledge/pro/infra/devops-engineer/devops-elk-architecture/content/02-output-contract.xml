<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="ELK Stack Architecture and Deployment Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact. Validator script in `scripts/validate-devops-elk-architecture.py` enforces it.</summary>

  <schema lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/devops-elk-architecture.json",
  "type": "object",
  "required": [
    "cluster",
    "variant",
    "volume_gb_per_day",
    "retention_days",
    "node_roles",
    "tiers",
    "deployment"
  ],
  "properties": {
    "cluster": {
      "type": "string",
      "minLength": 1
    },
    "variant": {
      "enum": [
        "elk",
        "efk",
        "elastic-stack"
      ]
    },
    "volume_gb_per_day": {
      "type": "number",
      "minimum": 0
    },
    "retention_days": {
      "type": "integer",
      "minimum": 1
    },
    "node_roles": {
      "type": "object",
      "required": [
        "master",
        "data_hot"
      ],
      "properties": {
        "master": {
          "type": "integer",
          "minimum": 3
        },
        "data_hot": {
          "type": "integer",
          "minimum": 2
        },
        "data_warm": {
          "type": "integer",
          "minimum": 0
        },
        "coordinating": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tiers": {
      "type": "object",
      "required": [
        "hot_days",
        "warm_days",
        "cold_days"
      ]
    },
    "deployment": {
      "enum": [
        "eck",
        "elastic-cloud",
        "opensearch-service",
        "docker-compose"
      ]
    }
  }
}
]]></schema>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "cluster": "prod-logs",
  "variant": "elk",
  "volume_gb_per_day": 200,
  "retention_days": 90,
  "node_roles": {
    "master": 3,
    "data_hot": 3,
    "data_warm": 2,
    "coordinating": 2
  },
  "tiers": {
    "hot_days": 7,
    "warm_days": 30,
    "cold_days": 53
  },
  "deployment": "eck"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "cluster": "prod-logs",
  "variant": "elk",
  "volume_gb_per_day": 200,
  "retention_days": 90,
  "node_roles": {
    "master": 2,
    "data_hot": 1
  },
  "tiers": {
    "hot_days": 90,
    "warm_days": 0,
    "cold_days": 0
  },
  "deployment": "docker-compose"
}
]]></code>
    <note>2 masters (split-brain); single data-hot; no warm/cold tier; docker-compose for prod.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">node_roles.master in {1, 2, 4} (must be 3 or 5+)</pattern>
    <pattern id="f2">data_hot &lt; 2</pattern>
    <pattern id="f3">deployment = 'docker-compose' on prod</pattern>
    <pattern id="f4">tiers.warm_days = 0 AND retention_days &gt; 30</pattern>
    <pattern id="f5">node_roles missing 'coordinating' for clusters &gt; 5 data nodes</pattern>
  </section>

  <reference path="scripts/validate-devops-elk-architecture.py">Validator script</reference>
</text>