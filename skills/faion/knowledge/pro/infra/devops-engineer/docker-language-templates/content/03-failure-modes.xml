<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Docker Language Templates Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="wrong-template" severity="medium">
      <symptom>Node Dockerfile applied to Python service; fails to build.</symptom>
      <root-cause>Language mismatch.</root-cause>
      <fix>Pick the template matching language.</fix>
    </antipattern>
    <antipattern id="unpinned-template" severity="low">
      <symptom>Service breaks because template was mutated upstream.</symptom>
      <root-cause>No semver pinning.</root-cause>
      <fix>Pin `template_version`.</fix>
    </antipattern>
    <antipattern id="disable-healthcheck" severity="medium">
      <symptom>Container marked Healthy even when crashing.</symptom>
      <root-cause>Opt-out of HEALTHCHECK.</root-cause>
      <fix>Keep HEALTHCHECK; require justification for removal.</fix>
    </antipattern>
    <antipattern id="public-base-image" severity="high">
      <symptom>Supply-chain risk; surprise bumps.</symptom>
      <root-cause>Random Docker Hub image.</root-cause>
      <fix>Pull from allowlisted internal registry.</fix>
    </antipattern>

  </section>
</text>
