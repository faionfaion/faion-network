<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Docker Language Templates Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/docker-language-templates.json",
  "title": "Docker Language Templates",
  "type": "object",
  "required": [
    "language",
    "framework",
    "template_version",
    "base_image",
    "port",
    "health_path",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "language": {
      "enum": [
        "python",
        "node",
        "go",
        "rust",
        "java",
        "static"
      ]
    },
    "framework": {
      "type": "string"
    },
    "template_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "base_image": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "health_path": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "language": "python",
  "framework": "fastapi",
  "template_version": "1.2.0",
  "base_image": {
    "name": "python:3.12-slim-bookworm"
  },
  "port": 8080,
  "health_path": "/healthz",
  "owner": "sre@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "language": "cobol",
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-docker-language-templates.py">Validator script</reference>
</text>
