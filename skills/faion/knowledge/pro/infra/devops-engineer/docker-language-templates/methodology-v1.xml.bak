<methodology slug="docker-language-templates">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>devops-engineer</domain>
    <summary>Production-ready Dockerfile and Docker Compose templates for Python, Node.js, Go, Rust, Java, and static sites — multi-stage, non-root, health-checked.</summary>
    <tags>
      <tag>docker</tag>
      <tag>dockerfile</tag>
      <tag>docker-compose</tag>
      <tag>templates</tag>
      <tag>containerization</tag>
    </tags>
    <category>docker</category>
    <difficulty>beginner</difficulty>
    <created>2026-04-27</created>
    <languages>
      <language>python</language>
      <language>typescript</language>
      <language>go</language>
      <language>rust</language>
      <language>java</language>
    </languages>
