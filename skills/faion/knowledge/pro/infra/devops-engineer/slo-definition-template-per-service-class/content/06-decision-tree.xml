<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="SLO Definition Template Per Service Class Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Includes a skip-this-methodology branch.</summary>

  <decision-tree>
    <root-question id="q-root">Service class?</root-question>
    <branch when="service_class == http_api">
      <conclusion ref="r2-customer-facing-sli">availability + latency SLIs; window 28d</conclusion>
    </branch>
    <branch when="service_class == async_worker">
      <conclusion ref="r1-template-per-service-class">durability + processing-lag SLIs</conclusion>
    </branch>
    <branch when="service_class == batch">
      <conclusion ref="r1-template-per-service-class">success-rate + completion-time SLIs</conclusion>
    </branch>
    <branch when="service_class == static_asset">
      <conclusion ref="r2-customer-facing-sli">availability + freshness SLIs</conclusion>
    </branch>
    <branch when="service_class == scheduled_job">
      <conclusion ref="r4-window-matched-to-decision">schedule-adherence SLI; window matches cadence</conclusion>
    </branch>
    <branch when="service_class unknown">
      <conclusion ref="r6-class-coverage-required">flag as gap; classify before authoring</conclusion>
    </branch>
    <branch when="preconditions_not_met == true">
      <conclusion ref="r2-customer-facing-sli">skip-this-methodology — preconditions in &quot;Applies If&quot; not satisfied</conclusion>
    </branch>
  </decision-tree>

  <example trace="typical">
    <note>Service class? → matches branch &quot;service_class == http_api&quot; → conclusion ref=r2-customer-facing-sli</note>
  </example>
</text>
