{
  "__faion_header__": {
    "purpose": "Minimum config used by validate-devops-aws-terraform-cicd.py --self-test",
    "consumes": "inputs declared in AGENTS.md `## Prerequisites`",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~350 tokens when loaded"
  },
  "layout": "per-env-dirs",
  "envs": [
    "dev",
    "staging",
    "prod"
  ],
  "backend": {
    "type": "s3",
    "lock_table": "acme-tfstate-lock",
    "encrypt": true
  },
  "auth": "oidc",
  "default_tags": [
    "Project",
    "Environment",
    "ManagedBy"
  ],
  "sequential_apply": true,
  "prod_approval": true
}
