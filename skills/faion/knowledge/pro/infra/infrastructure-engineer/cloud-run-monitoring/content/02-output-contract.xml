<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cloud Run Monitoring Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-cloud-run-monitoring.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cloud-run-monitoring.json",
  "title": "monitoring-config",
  "type": "object",
  "required": [
    "service_name",
    "log_format",
    "alert_policies",
    "trace_propagation",
    "notification_channels"
  ],
  "additionalProperties": false,
  "properties": {
    "service_name": {
      "type": "string",
      "minLength": 1
    },
    "log_format": {
      "type": "string",
      "minLength": 1
    },
    "alert_policies": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "trace_propagation": {
      "type": "boolean"
    },
    "notification_channels": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service_name": "example-service_name",
  "log_format": "example-log_format",
  "alert_policies": [],
  "trace_propagation": true,
  "notification_channels": []
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service_name": 123
}
]]></code>
    <note>Missing required keys and `service_name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="service_name"/>
      <field name="log_format"/>
      <field name="alert_policies"/>
      <field name="trace_propagation"/>
      <field name="notification_channels"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-cloud-run-monitoring.py">Validator script that enforces this schema.</reference>
</text>
