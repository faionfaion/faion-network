<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Cloud Run Monitoring Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="cloud_run_monitoring_root">Що логуєш / моніториш?</root-question>
    <branch when="output_shape == structured_json">
      <conclusion ref="structured-json-logging" verdict="use Cloud Logging native parsing"/>
    </branch>
    <branch when="output_shape == unstructured_text">
      <conclusion ref="structured-json-logging" verdict="refactor to JSON before going live"/>
    </branch>
    <branch when="incident_in_progress == true">
      <conclusion ref="alerting-on-key-metrics" verdict="raise sampling to 100% on Cloud Trace"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `output_shape == structured_json` → conclusion `structured-json-logging` from `content/01-core-rules.xml`.
  </example>
</text>
