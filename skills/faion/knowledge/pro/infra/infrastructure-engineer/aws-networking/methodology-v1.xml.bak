  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>infrastructure-engineer</domain>
    <summary>VPC, subnets, security groups, NACLs, Transit Gateway, VPC endpoints — concrete checklists, Terraform templates, AWS CLI verifications for autonomous agents.</summary>
    <category>cloud</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-26</created>
    <updated>2026-05-01</updated>
