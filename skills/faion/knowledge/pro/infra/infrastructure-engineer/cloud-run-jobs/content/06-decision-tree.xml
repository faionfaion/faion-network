<text id="06-decision-tree" title="Cloud Run Jobs Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="cloud_run_jobs_root">Що це за workload?</root-question>
    <branch when="workload == http_request_response">
      <conclusion ref="skip-this-methodology" verdict="use Cloud Run Services"/>
    </branch>
    <branch when="workload == run_to_completion_batch">
      <conclusion ref="task-idempotency-required" verdict="use Cloud Run Jobs; ensure idempotency"/>
    </branch>
    <branch when="workload == streaming_continuous">
      <conclusion ref="skip-this-methodology" verdict="use Dataflow or Pub/Sub push"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `workload == http_request_response` → conclusion `skip-this-methodology` from `content/01-core-rules.xml`.
  </example>
</text>
