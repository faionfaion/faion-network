<text id="04-procedure" title="Kubernetes Deployment Workloads Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply `Kubernetes Deployment Workloads` end-to-end. Each step has an input, an action, an output, and (where relevant) a decision gate.</summary>

  <section title="Procedure">

    <step n="1" name="scope-check">
      <input>Applies-If / Skip-If.</input>
      <action>Confirm preconditions.</action>
      <output>GO / NO-GO.</output>
    </step>

    <step n="2" name="behaviour-profile">
      <input>Service runtime profile.</input>
      <action>Answer: stateless? stable id? per-node? one-shot?</action>
      <output>Profile vector.</output>
    </step>

    <step n="3" name="pick-kind">
      <input>Profile.</input>
      <action>Apply kind-matches-behaviour rule; document rationale.</action>
      <output>Kind decision + rationale.</output>
    </step>

    <step n="4" name="manifest-skeleton">
      <input>Kind + image + persistence.</input>
      <action>Generate manifest skeleton with required fields per kind.</action>
      <output>Manifest draft.</output>
    </step>

    <step n="5" name="validate">
      <input>Manifest + validator.</input>
      <action>Run scripts/validate-k8s-deployment-workloads.py + kubeconform.</action>
      <output>Exit 0.</output>
    </step>

  </section>
</text>
