<text id="06-decision-tree" title="Gce Autoscaling Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gce_autoscaling_root">Що скейлиш?</root-question>
    <branch when="metric == cpu_utilization">
      <conclusion ref="cpu-target-default" verdict="use CPU-target 60–70%"/>
    </branch>
    <branch when="metric == custom_queue_depth">
      <conclusion ref="custom-metric-autoscaling" verdict="Cloud Monitoring custom metric"/>
    </branch>
    <branch when="metric == scheduled_pattern">
      <conclusion ref="scheduled-scaling-profiles" verdict="use scaling schedules"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `metric == cpu_utilization` → conclusion `cpu-target-default` from `content/01-core-rules.xml`.
  </example>
</text>
