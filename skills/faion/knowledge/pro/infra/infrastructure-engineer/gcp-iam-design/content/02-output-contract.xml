<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Iam Design Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gcp-iam-design.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-iam-design.json",
  "title": "iam-bindings",
  "type": "object",
  "required": [
    "principal",
    "role",
    "scope",
    "condition"
  ],
  "additionalProperties": false,
  "properties": {
    "principal": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "principal": "example-principal",
  "role": "example-role",
  "scope": "example-scope",
  "condition": "example-condition"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "principal": 123
}
]]></code>
    <note>Missing required keys and `principal` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="principal"/>
      <field name="role"/>
      <field name="scope"/>
      <field name="condition"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-iam-design.py">Validator script that enforces this schema.</reference>
</text>
