<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Resource Hierarchy Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator: scripts/validate-gcp-resource-hierarchy.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-resource-hierarchy.json",
  "title": "hierarchy-spec",
  "type": "object",
  "required": [
    "organization",
    "folders",
    "projects",
    "naming_convention",
    "policy_inheritance"
  ],
  "additionalProperties": false,
  "properties": {
    "organization": {
      "type": "string",
      "minLength": 1
    },
    "folders": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "naming_convention": {
      "type": "string",
      "minLength": 1
    },
    "policy_inheritance": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "organization": "example-organization",
  "folders": [],
  "projects": [],
  "naming_convention": "example-naming_convention",
  "policy_inheritance": "example-policy_inheritance"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "organization": 123
}
]]></code>
    <note>Missing required keys and `organization` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="organization"/>
      <field name="folders"/>
      <field name="projects"/>
      <field name="naming_convention"/>
      <field name="policy_inheritance"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-resource-hierarchy.py">Validator script that enforces this schema.</reference>
</text>
