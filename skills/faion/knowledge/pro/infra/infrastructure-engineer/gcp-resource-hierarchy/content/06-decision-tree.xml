<text id="06-decision-tree" title="Gcp Resource Hierarchy Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_resource_hierarchy_root">Який рівень ієрархії організовуєш?</root-question>
    <branch when="level == organization">
      <conclusion ref="org-level-policies" verdict="set org policies + billing"/>
    </branch>
    <branch when="level == folder">
      <conclusion ref="folder-per-bu-env" verdict="Folder per BU/env"/>
    </branch>
    <branch when="level == project">
      <conclusion ref="project-naming-convention" verdict="naming convention {env}-{bu}-{service}"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `level == organization` → conclusion `org-level-policies` from `content/01-core-rules.xml`.
  </example>
</text>
