<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gce Spot Vms Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gce-spot-vms.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gce-spot-vms.json",
  "title": "spot-vm-config",
  "type": "object",
  "required": [
    "scheduling",
    "provisioning_model",
    "instance_termination_action",
    "checkpoint_target"
  ],
  "additionalProperties": false,
  "properties": {
    "scheduling": {
      "type": "string",
      "minLength": 1
    },
    "provisioning_model": {
      "type": "string",
      "minLength": 1
    },
    "instance_termination_action": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_target": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "scheduling": "example-scheduling",
  "provisioning_model": "example-provisioning_model",
  "instance_termination_action": "example-instance_termination_action",
  "checkpoint_target": "example-checkpoint_target"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scheduling": 123
}
]]></code>
    <note>Missing required keys and `scheduling` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="scheduling"/>
      <field name="provisioning_model"/>
      <field name="instance_termination_action"/>
      <field name="checkpoint_target"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gce-spot-vms.py">Validator script that enforces this schema.</reference>
</text>
