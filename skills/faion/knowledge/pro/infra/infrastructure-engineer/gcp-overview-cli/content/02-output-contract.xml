<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Overview Cli Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the checklist artefact this methodology produces. Validator: scripts/validate-gcp-overview-cli.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-overview-cli.json",
  "title": "gcloud-bootstrap",
  "type": "object",
  "required": [
    "configuration",
    "auth_mode",
    "default_project",
    "impersonation_target"
  ],
  "additionalProperties": false,
  "properties": {
    "configuration": {
      "type": "string",
      "minLength": 1
    },
    "auth_mode": {
      "type": "string",
      "minLength": 1
    },
    "default_project": {
      "type": "string",
      "minLength": 1
    },
    "impersonation_target": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "configuration": "example-configuration",
  "auth_mode": "example-auth_mode",
  "default_project": "example-default_project",
  "impersonation_target": "example-impersonation_target"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "configuration": 123
}
]]></code>
    <note>Missing required keys and `configuration` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="configuration"/>
      <field name="auth_mode"/>
      <field name="default_project"/>
      <field name="impersonation_target"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-overview-cli.py">Validator script that enforces this schema.</reference>
</text>
