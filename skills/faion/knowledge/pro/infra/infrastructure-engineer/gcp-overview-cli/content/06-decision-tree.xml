<text id="06-decision-tree" title="Gcp Overview Cli Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_overview_cli_root">Що робиш у gcloud?</root-question>
    <branch when="step == auth_setup">
      <conclusion ref="gcloud-auth-application-default" verdict="gcloud auth application-default login"/>
    </branch>
    <branch when="step == multi_env">
      <conclusion ref="gcloud-configurations-per-env" verdict="gcloud config configurations create per env"/>
    </branch>
    <branch when="step == impersonation">
      <conclusion ref="service-account-impersonation" verdict="--impersonate-service-account=..."/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `step == auth_setup` → conclusion `gcloud-auth-application-default` from `content/01-core-rules.xml`.
  </example>
</text>
