<text id="02-output-contract" title="GCP Security and IAM Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-security-iam.json",
  "type": "object",
  "required": [
    "project_id",
    "owner",
    "service_accounts",
    "vpcsc_perimeter",
    "cmek_keys",
    "audit_sink",
    "wif_pools",
    "produced_at"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{4,28}[a-z0-9]$"
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "role": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "service_accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "email",
          "purpose",
          "roles"
        ],
        "properties": {
          "email": {
            "type": "string",
            "pattern": ".+@.+\\.iam\\.gserviceaccount\\.com$"
          },
          "purpose": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    },
    "vpcsc_perimeter": {
      "type": "object",
      "required": [
        "name",
        "restricted_services"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "restricted_services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "cmek_keys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "rotation_period_days"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "rotation_period_days": {
            "type": "integer",
            "maximum": 90
          }
        }
      },
      "minItems": 1
    },
    "audit_sink": {
      "type": "object",
      "required": [
        "destination",
        "retention_days"
      ],
      "properties": {
        "destination": {
          "type": "string"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 400
        }
      }
    },
    "wif_pools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pool_id",
          "provider",
          "issuer_uri"
        ],
        "properties": {
          "pool_id": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "issuer_uri": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "project_id": "acme-prod-12",
  "owner": {
    "name": "Olena Boyko",
    "role": "head of security"
  },
  "service_accounts": [
    {
      "email": "deploy@acme-prod-12.iam.gserviceaccount.com",
      "purpose": "CI deploys via WIF",
      "roles": [
        "roles/run.developer",
        "roles/iam.serviceAccountUser"
      ]
    }
  ],
  "vpcsc_perimeter": {
    "name": "prod-perimeter",
    "restricted_services": [
      "storage.googleapis.com",
      "bigquery.googleapis.com"
    ]
  },
  "cmek_keys": [
    {
      "name": "projects/acme-kms/locations/eu/keyRings/prod/cryptoKeys/sql",
      "rotation_period_days": 90
    }
  ],
  "audit_sink": {
    "destination": "bigquery.googleapis.com/projects/acme-logs/datasets/audit",
    "retention_days": 400
  },
  "wif_pools": [
    {
      "pool_id": "github-pool",
      "provider": "github-provider",
      "issuer_uri": "https://token.actions.githubusercontent.com"
    }
  ],
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "Acme_Prod!",
  "owner": "ops"
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Service account email patterns indicating key-file usage (`-key@`, `-static@`).</description>
      <reason>All SAs must use WIF; static-key patterns signal forbidden auth path.</reason>
    </antipattern>
    <antipattern>
      <description>`cmek_keys` rotation_period_days &amp;gt; 90.</description>
      <reason>Exceeds NIST SP 800-57 rotation guidance for production data.</reason>
    </antipattern>
    <antipattern>
      <description>audit_sink.destination pointing to same project_id.</description>
      <reason>Sink must be in a separate project to survive Owner-level tampering.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-gcp-security-iam.py">Validator script</reference>
</text>
