<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Networking Vpc Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gcp-networking-vpc.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-networking-vpc.json",
  "title": "vpc-config",
  "type": "object",
  "required": [
    "vpc_name",
    "mode",
    "subnets",
    "firewall_basis",
    "flow_logs"
  ],
  "additionalProperties": false,
  "properties": {
    "vpc_name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "subnets": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "firewall_basis": {
      "type": "string",
      "minLength": 1
    },
    "flow_logs": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "vpc_name": "example-vpc_name",
  "mode": "example-mode",
  "subnets": [],
  "firewall_basis": "example-firewall_basis",
  "flow_logs": "example-flow_logs"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "vpc_name": 123
}
]]></code>
    <note>Missing required keys and `vpc_name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="vpc_name"/>
      <field name="mode"/>
      <field name="subnets"/>
      <field name="firewall_basis"/>
      <field name="flow_logs"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-networking-vpc.py">Validator script that enforces this schema.</reference>
</text>
