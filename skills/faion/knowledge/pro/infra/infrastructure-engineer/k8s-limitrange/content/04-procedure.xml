<text id="04-procedure" title="Kubernetes LimitRange Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply `Kubernetes LimitRange` end-to-end. Each step has an input, an action, an output, and (where relevant) a decision gate.</summary>

  <section title="Procedure">

    <step n="1" name="scope-check">
      <input>Applies-If / Skip-If.</input>
      <action>Confirm preconditions.</action>
      <output>GO / NO-GO.</output>
    </step>

    <step n="2" name="tier-profile">
      <input>Namespace + tier.</input>
      <action>Pick profile (dev/staging/prod).</action>
      <output>Profile selection.</output>
    </step>

    <step n="3" name="tune-bounds">
      <input>Workload size profile.</input>
      <action>Adjust defaults / max / ratio per workload size.</action>
      <output>Tuned LimitRange YAML.</output>
    </step>

    <step n="4" name="apply-and-test">
      <input>LimitRange + smoke workload.</input>
      <action>Apply LimitRange first; deploy a no-request smoke pod; verify defaults inject.</action>
      <output>Smoke pod with injected defaults.</output>
    </step>

    <step n="5" name="validate">
      <input>LimitRange + validator.</input>
      <action>Run scripts/validate-k8s-limitrange.py.</action>
      <output>Exit 0.</output>
    </step>

  </section>
</text>
