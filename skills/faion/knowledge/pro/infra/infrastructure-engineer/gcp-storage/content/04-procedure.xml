<text id="04-procedure" title="GCP Cloud Storage Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply `GCP Cloud Storage` end-to-end. Each step has an input, an action, an output, and (where relevant) a decision gate.</summary>

  <section title="Procedure">

    <step n="1" name="scope-check">
      <input>Applies-If / Skip-If from AGENTS.md.</input>
      <action>Confirm preconditions; route away if Skip-If trigger fires.</action>
      <output>GO / NO-GO.</output>
      <decision-gate>NO-GO → STOP.</decision-gate>
    </step>

    <step n="2" name="classify-data">
      <input>Data inventory + access-pattern profile.</input>
      <action>Map data to storage class + retention class + CMEK requirement.</action>
      <output>Classification table.</output>
    </step>

    <step n="3" name="draft-bucket-config">
      <input>Classification + naming convention + templates/bucket.json.</input>
      <action>Fill the template; pick lifecycle rules; set CMEK + retention.</action>
      <output>Draft JSON artefact.</output>
    </step>

    <step n="4" name="review-against-rules">
      <input>Draft + 01-core-rules.xml.</input>
      <action>Run rule-by-rule check; fix violations.</action>
      <output>Reviewed artefact.</output>
      <decision-gate>Any failed rule → REJECT.</decision-gate>
    </step>

    <step n="5" name="validate">
      <input>Artefact + scripts/validate-gcp-storage.py.</input>
      <action>Run validator; fix VIOLATIONs.</action>
      <output>Validator exit 0.</output>
      <decision-gate>Non-zero → return to draft.</decision-gate>
    </step>

  </section>
</text>
