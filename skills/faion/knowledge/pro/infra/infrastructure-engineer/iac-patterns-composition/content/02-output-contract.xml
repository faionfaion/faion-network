<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="IaC Module Composition Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/iac-patterns-composition.json",
  "type": "object",
  "required": [
    "root_name",
    "leaves",
    "graph_acyclic",
    "outputs_documented",
    "owner",
    "produced_at"
  ],
  "properties": {
    "root_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "leaves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "version",
          "owners"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "owners": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    },
    "graph_acyclic": {
      "type": "boolean",
      "const": true
    },
    "outputs_documented": {
      "type": "boolean",
      "const": true
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "root_name": "acme-prod-root",
  "leaves": [
    {
      "name": "network",
      "version": "v1.4.0",
      "owners": [
        "platform"
      ]
    },
    {
      "name": "iam",
      "version": "v2.0.0",
      "owners": [
        "security"
      ]
    },
    {
      "name": "workload",
      "version": "v0.7.2",
      "owners": [
        "app-team"
      ]
    }
  ],
  "graph_acyclic": true,
  "outputs_documented": true,
  "owner": {
    "name": "Andriy Koval",
    "role": "platform lead"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "root_name": "BAD",
  "leaves": []
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>graph_acyclic false.</description>
      <reason>Cycles cause nondeterministic plans.</reason>
    </antipattern>
    <antipattern>
      <description>Two leaves with overlapping resource ownership.</description>
      <reason>Race on apply.</reason>
    </antipattern>
    <antipattern>
      <description>Output rename without major-version bump.</description>
      <reason>Breaks downstream consumers.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-iac-patterns-composition.py">Validator script</reference>
</text>
