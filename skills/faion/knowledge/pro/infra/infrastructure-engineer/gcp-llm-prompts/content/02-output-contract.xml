<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Llm Prompts Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator: scripts/validate-gcp-llm-prompts.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-llm-prompts.json",
  "title": "prompt-template",
  "type": "object",
  "required": [
    "task",
    "template_id",
    "inputs",
    "expected_output_shape",
    "constraints"
  ],
  "additionalProperties": false,
  "properties": {
    "task": {
      "type": "string",
      "minLength": 1
    },
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "expected_output_shape": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "task": "example-task",
  "template_id": "example-template_id",
  "inputs": [],
  "expected_output_shape": "example-expected_output_shape",
  "constraints": "example-constraints"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "task": 123
}
]]></code>
    <note>Missing required keys and `task` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="task"/>
      <field name="template_id"/>
      <field name="inputs"/>
      <field name="expected_output_shape"/>
      <field name="constraints"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-llm-prompts.py">Validator script that enforces this schema.</reference>
</text>
