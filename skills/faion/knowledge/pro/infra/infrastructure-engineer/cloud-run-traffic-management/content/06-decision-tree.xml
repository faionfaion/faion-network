<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Cloud Run Traffic Management Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="cloud_run_traffic_management_root">Який тип rollout?</root-question>
    <branch when="rollout == canary">
      <conclusion ref="canary-traffic-split" verdict="deploy with --no-traffic + gradual --to-revisions"/>
    </branch>
    <branch when="rollout == blue_green">
      <conclusion ref="tagged-revision-promote" verdict="tag → smoke → promote 100%"/>
    </branch>
    <branch when="rollout == ab_experiment">
      <conclusion ref="split-by-revision" verdict="fixed split between two stable revisions"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `rollout == canary` → conclusion `canary-traffic-split` from `content/01-core-rules.xml`.
  </example>
</text>
