<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cloud Run Traffic Management Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-cloud-run-traffic-management.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cloud-run-traffic-management.json",
  "title": "traffic-split",
  "type": "object",
  "required": [
    "service",
    "splits",
    "tags",
    "rollout_strategy"
  ],
  "additionalProperties": false,
  "properties": {
    "service": {
      "type": "string",
      "minLength": 1
    },
    "splits": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "rollout_strategy": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service": "example-service",
  "splits": [],
  "tags": [],
  "rollout_strategy": "example-rollout_strategy"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service": 123
}
]]></code>
    <note>Missing required keys and `service` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="service"/>
      <field name="splits"/>
      <field name="tags"/>
      <field name="rollout_strategy"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-cloud-run-traffic-management.py">Validator script that enforces this schema.</reference>
</text>
