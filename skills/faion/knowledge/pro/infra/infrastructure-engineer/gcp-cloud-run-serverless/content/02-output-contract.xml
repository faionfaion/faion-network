<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Cloud Run Serverless Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gcp-cloud-run-serverless.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-cloud-run-serverless.json",
  "title": "cloud-run-service",
  "type": "object",
  "required": [
    "name",
    "image",
    "min_instances",
    "max_instances",
    "concurrency",
    "cpu",
    "memory"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string",
      "minLength": 1
    },
    "min_instances": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "max_instances": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "concurrency": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "cpu": {
      "type": "string",
      "minLength": 1
    },
    "memory": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "example-name",
  "image": "example-image",
  "min_instances": 1,
  "max_instances": 1,
  "concurrency": 1,
  "cpu": "example-cpu",
  "memory": 1
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": 123
}
]]></code>
    <note>Missing required keys and `name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="name"/>
      <field name="image"/>
      <field name="min_instances"/>
      <field name="max_instances"/>
      <field name="concurrency"/>
      <field name="cpu"/>
      <field name="memory"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-cloud-run-serverless.py">Validator script that enforces this schema.</reference>
</text>
