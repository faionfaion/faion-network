<text id="06-decision-tree" title="Gcp Compute Gke Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_compute_gke_root">Який mode GKE підходить?</root-question>
    <branch when="ops_capacity == low">
      <conclusion ref="gke-autopilot-when-low-ops" verdict="use Autopilot"/>
    </branch>
    <branch when="ops_capacity == high_custom_pools">
      <conclusion ref="gke-standard-node-pools" verdict="Standard mode + node-pools"/>
    </branch>
    <branch when="workload_identity_needed == true">
      <conclusion ref="workload-identity-required" verdict="enable Workload Identity"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `ops_capacity == low` → conclusion `gke-autopilot-when-low-ops` from `content/01-core-rules.xml`.
  </example>
</text>
