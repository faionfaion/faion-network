<text id="04-procedure" title="IaC CI/CD Patterns Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply `IaC CI/CD Patterns` end-to-end. Each step has an input, an action, an output, and (where relevant) a decision gate.</summary>

  <section title="Procedure">

    <step n="1" name="scope-check">
      <input>Applies-If / Skip-If.</input>
      <action>Confirm preconditions.</action>
      <output>GO / NO-GO.</output>
    </step>

    <step n="2" name="stage-design">
      <input>Env list + reviewer policy.</input>
      <action>Define plan-on-PR, apply-on-merge-dev, manual-gate-prod stages.</action>
      <output>Stage matrix.</output>
    </step>

    <step n="3" name="wif-binding">
      <input>CI provider + cloud SA.</input>
      <action>Create WIF pool + provider; bind repo subject; remove static keys.</action>
      <output>WIF config + secret cleanup.</output>
    </step>

    <step n="4" name="drift-job">
      <input>Schedule + alert sink.</input>
      <action>Add scheduled `plan` job; wire alert to platform channel.</action>
      <output>Drift-detect workflow.</output>
    </step>

    <step n="5" name="validate">
      <input>Pipeline + validator.</input>
      <action>Run scripts/validate-iac-patterns-cicd.py; lint workflow YAML.</action>
      <output>Validator exit 0.</output>
    </step>

  </section>
</text>
