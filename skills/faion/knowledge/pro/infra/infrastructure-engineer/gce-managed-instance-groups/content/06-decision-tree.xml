<text id="06-decision-tree" title="Gce Managed Instance Groups Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gce_managed_instance_groups_root">Яка топологія MIG?</root-question>
    <branch when="placement == regional_multi_zone">
      <conclusion ref="regional-multi-zone-ha" verdict="regional MIG, ≥3 zones"/>
    </branch>
    <branch when="rollout == rolling_update">
      <conclusion ref="controlled-rolling-update" verdict="maxSurge/maxUnavailable + initialDelay"/>
    </branch>
    <branch when="health == requires_self_heal">
      <conclusion ref="auto-healing-with-health-check" verdict="HTTP health-check + initial delay"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `placement == regional_multi_zone` → conclusion `regional-multi-zone-ha` from `content/01-core-rules.xml`.
  </example>
</text>
