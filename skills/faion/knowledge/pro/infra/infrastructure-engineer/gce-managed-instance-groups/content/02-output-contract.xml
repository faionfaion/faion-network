<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gce Managed Instance Groups Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gce-managed-instance-groups.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gce-managed-instance-groups.json",
  "title": "mig-config",
  "type": "object",
  "required": [
    "name",
    "template",
    "placement",
    "target_size",
    "rolling_update",
    "health_check"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "template": {
      "type": "string",
      "minLength": 1
    },
    "placement": {
      "type": "string",
      "minLength": 1
    },
    "target_size": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "rolling_update": {
      "type": "string",
      "minLength": 1
    },
    "health_check": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "example-name",
  "template": "example-template",
  "placement": "example-placement",
  "target_size": 1,
  "rolling_update": "example-rolling_update",
  "health_check": "example-health_check"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": 123
}
]]></code>
    <note>Missing required keys and `name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="name"/>
      <field name="template"/>
      <field name="placement"/>
      <field name="target_size"/>
      <field name="rolling_update"/>
      <field name="health_check"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gce-managed-instance-groups.py">Validator script that enforces this schema.</reference>
</text>
