<text id="06-decision-tree" title="Cloud Run Vpc Access Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="cloud_run_vpc_access_root">Чим викликаєш приватні ресурси?</root-question>
    <branch when="target == cloud_sql_private_ip">
      <conclusion ref="use-connector-or-direct-egress" verdict="VPC connector OR direct VPC egress"/>
    </branch>
    <branch when="target == on_prem_via_vpn">
      <conclusion ref="use-connector-or-direct-egress" verdict="VPC connector + Cloud VPN/Interconnect"/>
    </branch>
    <branch when="target == public_internet_only">
      <conclusion ref="skip-this-methodology" verdict="no VPC integration needed"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `target == cloud_sql_private_ip` → conclusion `use-connector-or-direct-egress` from `content/01-core-rules.xml`.
  </example>
</text>
