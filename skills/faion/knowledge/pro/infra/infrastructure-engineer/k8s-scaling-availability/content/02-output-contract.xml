<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Kubernetes Scaling and Availability Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/k8s-scaling-availability.json",
  "type": "object",
  "required": [
    "service",
    "hpa",
    "topology_spread",
    "pdb",
    "owner",
    "produced_at"
  ],
  "properties": {
    "service": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "hpa": {
      "type": "object",
      "required": [
        "api_version",
        "min_replicas",
        "max_replicas",
        "metrics",
        "stabilization_window_seconds"
      ],
      "properties": {
        "api_version": {
          "const": "autoscaling/v2"
        },
        "min_replicas": {
          "type": "integer",
          "minimum": 2
        },
        "max_replicas": {
          "type": "integer"
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "minItems": 1
        },
        "stabilization_window_seconds": {
          "type": "integer",
          "minimum": 300
        }
      }
    },
    "topology_spread": {
      "type": "object",
      "required": [
        "topology_key",
        "max_skew"
      ],
      "properties": {
        "topology_key": {
          "type": "string"
        },
        "max_skew": {
          "type": "integer",
          "maximum": 1
        }
      }
    },
    "pdb": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "min_available": {
          "type": "string"
        },
        "max_unavailable": {
          "type": "string"
        }
      }
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service": "acme-api",
  "hpa": {
    "api_version": "autoscaling/v2",
    "min_replicas": 3,
    "max_replicas": 20,
    "metrics": [
      {
        "type": "Resource",
        "resource": {
          "name": "cpu",
          "target": {
            "type": "Utilization",
            "averageUtilization": 70
          }
        }
      }
    ],
    "stabilization_window_seconds": 300
  },
  "topology_spread": {
    "topology_key": "topology.kubernetes.io/zone",
    "max_skew": 1
  },
  "pdb": {
    "name": "acme-api-pdb",
    "min_available": "60%"
  },
  "owner": {
    "name": "Olena Boyko",
    "role": "platform lead"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service": "api",
  "hpa": {
    "api_version": "autoscaling/v1",
    "min_replicas": 1,
    "max_replicas": 1
  }
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>hpa.api_version not autoscaling/v2.</description>
      <reason>v1 lacks multi-metric + stabilization.</reason>
    </antipattern>
    <antipattern>
      <description>min_replicas 1 in production.</description>
      <reason>Single replica means no availability.</reason>
    </antipattern>
    <antipattern>
      <description>Missing topology_spread on multi-AZ cluster.</description>
      <reason>Zone outage equals total outage.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-k8s-scaling-availability.py">Validator script</reference>
</text>
