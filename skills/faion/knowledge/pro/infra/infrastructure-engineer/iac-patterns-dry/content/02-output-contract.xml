<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="IaC DRY Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the rubric artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/iac-patterns-dry.json",
  "type": "object",
  "required": [
    "repo",
    "audited_patterns",
    "abstractions_introduced",
    "owner",
    "produced_at"
  ],
  "properties": {
    "repo": {
      "type": "string"
    },
    "audited_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pattern",
          "instances",
          "action"
        ],
        "properties": {
          "pattern": {
            "type": "string"
          },
          "instances": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "enum": [
              "factored",
              "deferred",
              "rejected"
            ]
          }
        }
      },
      "minItems": 1
    },
    "abstractions_introduced": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "repo": "acme/infra-terraform",
  "audited_patterns": [
    {
      "pattern": "per-subnet route table",
      "instances": 4,
      "action": "factored"
    },
    {
      "pattern": "per-region KMS key ring",
      "instances": 2,
      "action": "deferred"
    }
  ],
  "abstractions_introduced": [
    "module.route_tables (for_each)",
    "locals.common_tags"
  ],
  "owner": {
    "name": "Olha Petrenko",
    "role": "platform lead"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "repo": "acme/infra",
  "audited_patterns": []
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>action factored when instances under 3.</description>
      <reason>Violates rule-of-three; premature abstraction.</reason>
    </antipattern>
    <antipattern>
      <description>Per-environment copies of a module instead of overlay.</description>
      <reason>Doubles change surface.</reason>
    </antipattern>
    <antipattern>
      <description>Numeric magic constants in audited_patterns marked as accepted.</description>
      <reason>Bare numbers obscure intent.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-iac-patterns-dry.py">Validator script</reference>
</text>
