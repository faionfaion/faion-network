<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="IaC DRY Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="skip"/>
    </branch>

    <branch when="instances_lt_3 == true">
      <conclusion ref="rule-of-three" verdict="defer abstraction"/>
    </branch>

    <branch when="instances_ge_3 == true &amp;&amp; copy_paste == true">
      <conclusion ref="for-each-over-copy" verdict="refactor to for_each"/>
    </branch>

    <branch when="per_env_copies == true">
      <conclusion ref="env-overlay-not-copy" verdict="consolidate via tfvars overlay"/>
    </branch>

    <branch when="all_checks_passed == true">
      <conclusion ref="locals-for-shared-constants" verdict="extract shared constants to locals"/>
    </branch>

  </decision-tree>

  <example trace="happy-path">preconditions == false -&gt; instances_lt_3 == true -&gt; instances_ge_3 == true &amp;&amp; copy_paste == true -> conclusion ref.</example>
</text>
