<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Networking Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gcp-networking.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-networking.json",
  "title": "network-design",
  "type": "object",
  "required": [
    "vpc_topology",
    "lb_strategy",
    "egress",
    "private_services",
    "firewall_strategy"
  ],
  "additionalProperties": false,
  "properties": {
    "vpc_topology": {
      "type": "string",
      "minLength": 1
    },
    "lb_strategy": {
      "type": "string",
      "minLength": 1
    },
    "egress": {
      "type": "string",
      "minLength": 1
    },
    "private_services": {
      "type": "string",
      "minLength": 1
    },
    "firewall_strategy": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "vpc_topology": "example-vpc_topology",
  "lb_strategy": "example-lb_strategy",
  "egress": "example-egress",
  "private_services": "example-private_services",
  "firewall_strategy": "example-firewall_strategy"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "vpc_topology": 123
}
]]></code>
    <note>Missing required keys and `vpc_topology` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="vpc_topology"/>
      <field name="lb_strategy"/>
      <field name="egress"/>
      <field name="private_services"/>
      <field name="firewall_strategy"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-networking.py">Validator script that enforces this schema.</reference>
</text>
