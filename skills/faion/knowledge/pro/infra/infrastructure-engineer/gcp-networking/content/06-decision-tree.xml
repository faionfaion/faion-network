<text id="06-decision-tree" title="Gcp Networking Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_networking_root">Яка networking-задача?</root-question>
    <branch when="scope == multi_project_shared">
      <conclusion ref="shared-vpc" verdict="Shared VPC від host-project"/>
    </branch>
    <branch when="scope == egress_to_internet_private">
      <conclusion ref="cloud-nat" verdict="Cloud NAT для приватних instance-ів"/>
    </branch>
    <branch when="scope == global_l7_lb">
      <conclusion ref="global-https-lb-cdn-armor" verdict="Global HTTPS LB + Cloud Armor + CDN"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `scope == multi_project_shared` → conclusion `shared-vpc` from `content/01-core-rules.xml`.
  </example>
</text>
