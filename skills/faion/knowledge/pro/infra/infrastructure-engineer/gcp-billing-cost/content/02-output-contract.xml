<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Billing Cost Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. Validator: scripts/validate-gcp-billing-cost.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-billing-cost.json",
  "title": "cost-report",
  "type": "object",
  "required": [
    "period",
    "projects",
    "top_cost_drivers",
    "savings_opportunities",
    "recommendations"
  ],
  "additionalProperties": false,
  "properties": {
    "period": {
      "type": "string",
      "minLength": 1
    },
    "projects": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "top_cost_drivers": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "savings_opportunities": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "period": "example-period",
  "projects": [],
  "top_cost_drivers": [],
  "savings_opportunities": [],
  "recommendations": []
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "period": 123
}
]]></code>
    <note>Missing required keys and `period` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="period"/>
      <field name="projects"/>
      <field name="top_cost_drivers"/>
      <field name="savings_opportunities"/>
      <field name="recommendations"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-billing-cost.py">Validator script that enforces this schema.</reference>
</text>
