<text id="06-decision-tree" title="Gcp Billing Cost Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_billing_cost_root">Який крок FinOps виконуєш?</root-question>
    <branch when="step == visibility">
      <conclusion ref="bigquery-billing-export" verdict="enable BQ billing export"/>
    </branch>
    <branch when="step == budgets">
      <conclusion ref="budget-alerts-50-90-100" verdict="set tiered budget alerts"/>
    </branch>
    <branch when="step == optimization">
      <conclusion ref="committed-use-discounts" verdict="evaluate 1y/3y CUDs"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `step == visibility` → conclusion `bigquery-billing-export` from `content/01-core-rules.xml`.
  </example>
</text>
