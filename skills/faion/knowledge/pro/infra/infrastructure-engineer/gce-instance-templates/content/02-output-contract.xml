<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gce Instance Templates Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gce-instance-templates.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gce-instance-templates.json",
  "title": "instance-template",
  "type": "object",
  "required": [
    "name",
    "machine_type",
    "image",
    "service_account",
    "startup_script",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "machine_type": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string",
      "minLength": 1
    },
    "service_account": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "startup_script": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "example-name",
  "machine_type": "example-machine_type",
  "image": "example-image",
  "service_account": 1,
  "startup_script": "example-startup_script",
  "metadata": "example-metadata"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": 123
}
]]></code>
    <note>Missing required keys and `name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="name"/>
      <field name="machine_type"/>
      <field name="image"/>
      <field name="service_account"/>
      <field name="startup_script"/>
      <field name="metadata"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gce-instance-templates.py">Validator script that enforces this schema.</reference>
</text>
