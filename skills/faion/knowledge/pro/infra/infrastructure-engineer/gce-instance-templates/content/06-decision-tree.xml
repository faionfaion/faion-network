<text id="06-decision-tree" title="Gce Instance Templates Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gce_instance_templates_root">Темплейт стане базою чого?</root-question>
    <branch when="consumer == managed_instance_group">
      <conclusion ref="immutable-versioned-templates" verdict="version + tag template; never edit in place"/>
    </branch>
    <branch when="consumer == one_off_vm">
      <conclusion ref="skip-this-methodology" verdict="create instance directly"/>
    </branch>
    <branch when="ssh_strategy == os_login_iap">
      <conclusion ref="os-login-iap-no-metadata-keys" verdict="enable OS Login + IAP"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `consumer == managed_instance_group` → conclusion `immutable-versioned-templates` from `content/01-core-rules.xml`.
  </example>
</text>
