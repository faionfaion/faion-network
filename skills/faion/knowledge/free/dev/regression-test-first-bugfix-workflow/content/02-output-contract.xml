<text id="02-output-contract" title="Regression Test First Bugfix Workflow — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the workflow record produced by one application: alert link, red-test commit, fix PR, verification check, owner, and next-review date.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://regression-test-first-bugfix-workflow/output.schema.json",
  "type": "object",
  "required": ["trigger", "red_test", "fix", "verification", "owner", "review"],
  "properties": {
    "trigger": {
      "type": "object",
      "required": ["kind", "url"],
      "properties": {
        "kind": {"type": "string", "enum": ["sentry", "datadog", "customer-ticket", "log-aggregator"]},
        "url": {"type": "string", "format": "uri"}
      }
    },
    "red_test": {
      "type": "object",
      "required": ["path", "commit", "asserts"],
      "properties": {
        "path": {"type": "string", "pattern": "^tests/"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
        "asserts": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    },
    "fix": {
      "type": "object",
      "required": ["pr_url", "diff_lines"],
      "properties": {
        "pr_url": {"type": "string", "format": "uri"},
        "diff_lines": {"type": "integer", "minimum": 1}
      }
    },
    "verification": {
      "type": "object",
      "required": ["ci_run_url", "passed"],
      "properties": {
        "ci_run_url": {"type": "string", "format": "uri"},
        "passed": {"type": "boolean", "const": true}
      }
    },
    "owner": {"type": "string", "pattern": "^[a-z-]+:[a-z0-9._-]+$"},
    "review": {
      "type": "object",
      "required": ["cadence", "next_review_at"],
      "properties": {
        "cadence": {"type": "string", "enum": ["monthly", "quarterly"]},
        "next_review_at": {"type": "string", "format": "date"}
      }
    }
  }
}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "trigger": {"kind": "sentry", "url": "https://sentry.io/x/issues/12345/"},
  "red_test": {"path": "tests/regression/test_checkout_zero_amount.py", "commit": "a1b2c3d", "asserts": ["status_code == 422", "Order.count == 0"]},
  "fix": {"pr_url": "https://github.com/org/repo/pull/9981", "diff_lines": 18},
  "verification": {"ci_run_url": "https://github.com/org/repo/actions/runs/77", "passed": true},
  "owner": "swe:alice",
  "review": {"cadence": "quarterly", "next_review_at": "2026-08-22"}
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "trigger": {"kind": "gut feel", "url": "tbd"},
  "red_test": {"path": "src/billing.py", "commit": "main"},
  "fix": {"pr_url": "soon", "diff_lines": 0},
  "verification": {"passed": false},
  "owner": "team",
  "review": {}
}
]]></code>
      <note>Invalid: trigger.kind not in enum; red_test.path outside tests/; commit not a hash; fix.pr_url not URL; verification.passed must be true; owner must be role:person; review missing fields.</note>
    </example>
  </section>

  <section title="Required fields">
    <list>
      <item>trigger (event / threshold / schedule)</item>
      <item>output.shape (template / schema / artefact path)</item>
      <item>conclusion.evidence_links</item>
      <item>owner (named)</item>
      <item>review.cadence + review.last_run_at</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>trigger &apos;when needed&apos;</description>
      <reason>Either fires constantly or never.</reason>
    </antipattern>
    <antipattern>
      <description>free-form output</description>
      <reason>One-off and unreusable.</reason>
    </antipattern>
    <antipattern>
      <description>unevidenced conclusions</description>
      <reason>Demote to hypothesis.</reason>
    </antipattern>
    <antipattern>
      <description>no outcome review</description>
      <reason>Methodology becomes folklore.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Trigger named and concrete.</item>
      <item>Output shape fixed.</item>
      <item>Each conclusion has evidence links.</item>
      <item>Owner accountable for next actions.</item>
      <item>Outcome review run at published cadence.</item>
    </list>
  </section>
</text>
