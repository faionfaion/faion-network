{
  "_purpose": "JSON Schema for the One Command Dev Env Template decision-record output.",
  "_consumes": "nothing — schema only.",
  "_produces": "schema document.",
  "_depends-on": "content/02-output-contract.xml.",
  "_token-budget-impact": "~180 tokens.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.network/schema/one-command-dev-env-template.json",
  "type": "object",
  "required": ["artefact_id", "owner", "decision", "rationale", "inputs_used", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string", "minLength": 1},
    "decision": {"type": "string", "minLength": 4},
    "rationale": {"type": "string", "minLength": 60},
    "inputs_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {"type": "string"},
          "source": {"type": "string"}
        }
      }
    },
    "status": {"type": "string", "enum": ["pending", "active", "deprecated"]},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "notes": {"type": "string"}
  }
}
