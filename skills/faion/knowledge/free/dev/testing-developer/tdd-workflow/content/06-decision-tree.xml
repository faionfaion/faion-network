<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="TDD Workflow Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (behavior_known, visual_feedback_drives, performance_dominant)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-known" text="Is behavior_known true?">
          <branch when="behavior_known == false">
            <conclusion ref="r-spike-first">Run a spike first; write tests after the spec stabilises.</conclusion>
          </branch>
          <branch when="behavior_known == true">
            <question id="q-visual" text="Does visual_feedback_drives apply?">
              <branch when="visual_feedback_drives == true">
                <conclusion ref="r6-no-tdd-when-spec-unknown">Defer TDD; use screenshots + manual review while the layout settles.</conclusion>
              </branch>
              <branch when="visual_feedback_drives == false">
                <question id="q-perf" text="Is performance_dominant true?">
                  <branch when="performance_dominant == true">
                    <conclusion ref="r-benchmark-driven">Swap TDD for benchmark-driven development.</conclusion>
                  </branch>
                  <branch when="performance_dominant == false">
                    <conclusion ref="r-strict-tdd">Run strict TDD with PostToolUse hook + per-behavior loop.</conclusion>
                  </branch>
                </question>
              </branch>
            </question>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="behavior_known=true, visual_feedback_drives=false, performance_dominant=false">
      q-root yes → q-known yes → q-visual no → q-perf no → r-strict-tdd
    </example>
  </decision-tree>
</text>
