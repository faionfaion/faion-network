<text id="02-output-contract" title="Integration Testing Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the integration-test-config artefact. Subagent output MUST validate before being returned.</summary>

  <output-contract produces="config">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "integration-testing"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["framework", "isolation_strategy", "container_engine", "external_http_strategy", "factory_uniqueness", "conftest_path"],
      "properties": {
        "framework": {"enum": ["fastapi", "django", "flask"]},
        "isolation_strategy": {"enum": ["rollback", "truncate", "unique-id-only", "in-memory-sqlite"]},
        "container_engine": {"enum": ["postgres", "mysql", "redis", "none"]},
        "external_http_strategy": {"enum": ["respx", "wiremock", "none"]},
        "factory_uniqueness": {"enum": ["sequence", "uuid"]},
        "conftest_path": {"type": "string"}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["db_engine_required", "commit_time_behavior_under_test", "parallel_target", "external_http_calls"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="FastAPI + Postgres + respx, 4 parallel workers"><![CDATA[
{
  "slug": "integration-testing",
  "version": "2.0.0",
  "decision": {
    "framework": "fastapi",
    "isolation_strategy": "rollback",
    "container_engine": "postgres",
    "external_http_strategy": "respx",
    "factory_uniqueness": "uuid",
    "conftest_path": "tests/conftest.py"
  },
  "drivers": {"db_engine_required": true, "commit_time_behavior_under_test": false, "parallel_target": 4, "external_http_calls": "few"},
  "audit": {"rule_refs": ["r1-rollback-default", "r2-container-scoping", "r5-factory-uniqueness", "r-rollback-strategy", "r-respx-pick"]}
}
]]></example>

    <example valid="false" title="Missing isolation_strategy + empty rule_refs"><![CDATA[
{
  "slug": "integration-testing",
  "version": "2.0.0",
  "decision": {"framework": "fastapi"},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>decision missing isolation_strategy, container_engine, external_http_strategy, factory_uniqueness, conftest_path.</violation>
      <violation>drivers missing db_engine_required, commit_time_behavior_under_test, parallel_target, external_http_calls.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.isolation_strategy matches the rule that drove the tree branch.</item>
      <item>audit.rule_refs cites the rule from the branch + r5 if parallel_target &gt;= 2.</item>
    </list>
  </section>

  <reference path="templates/conftest_postgres.py">Working Postgres conftest emitted from this decision.</reference>
  <reference path="scripts/validate-integration-testing.py">Schema validator.</reference>
</text>
