<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Test Fixtures Decision Tree" version="2.0.0" est_tokens="600">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (has_subobjects, has_many_optional_fields, domain_scenarios_named, xdist_workers)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-many" text="Does the model have many optional fields?">
          <branch when="has_many_optional_fields == true">
            <conclusion ref="r-builder-pick">Use the Builder pattern (fluent with-* methods).</conclusion>
          </branch>
          <branch when="has_many_optional_fields == false">
            <question id="q-named" text="Are domain scenarios named (premium_user, banned_user)?">
              <branch when="domain_scenarios_named == true">
                <conclusion ref="r-mother-pick">Use Factory + Object Mother (semantic methods on top of Factory).</conclusion>
              </branch>
              <branch when="domain_scenarios_named == false">
                <conclusion ref="r-factory-pick">Use plain Factory.</conclusion>
              </branch>
            </question>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true, has_many_optional_fields=false, domain_scenarios_named=true">
      q-root yes → q-many no → q-named yes → r-mother-pick
    </example>
  </decision-tree>
</text>
