<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Test Fixtures Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the fixture-design config artefact.</summary>

  <output-contract produces="config">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "test-fixtures"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["framework", "fixtures", "rollback_strategy", "xdist_db_strategy", "conftest_path"],
      "properties": {
        "framework": {"enum": ["django", "sqlalchemy", "sqlmodel"]},
        "fixtures": {"type": "array", "items": {"type": "object", "required": ["model", "pattern", "scope", "uniqueness"], "properties": {"pattern": {"enum": ["factory", "builder", "object-mother", "factory+mother"]}, "scope": {"enum": ["function", "class", "module", "session"]}, "uniqueness": {"enum": ["sequence", "uuid"]}}}},
        "rollback_strategy": {"enum": ["transactional", "truncate", "savepoint"]},
        "xdist_db_strategy": {"enum": ["worker-db", "single-db", "none"]},
        "conftest_path": {"type": "string"}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["has_subobjects", "has_many_optional_fields", "domain_scenarios_named", "xdist_workers"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Django + Factory + Mother, 4 workers"><![CDATA[
{
  "slug": "test-fixtures",
  "version": "2.0.0",
  "decision": {
    "framework": "django",
    "fixtures": [
      {"model": "User", "pattern": "factory+mother", "scope": "function", "uniqueness": "uuid"},
      {"model": "Order", "pattern": "builder", "scope": "function", "uniqueness": "uuid"}
    ],
    "rollback_strategy": "transactional",
    "xdist_db_strategy": "worker-db",
    "conftest_path": "tests/conftest.py"
  },
  "drivers": {"has_subobjects": true, "has_many_optional_fields": true, "domain_scenarios_named": true, "xdist_workers": 4},
  "audit": {"rule_refs": ["r1-scope-matches-state", "r5-factory-uniqueness-xdist", "r6-xdist-worker-db", "r-mother-pick", "r-builder-pick"]}
}
]]></example>

    <example valid="false" title="Sequence uniqueness under xdist + empty audit"><![CDATA[
{
  "slug": "test-fixtures",
  "version": "2.0.0",
  "decision": {"framework": "django", "fixtures": [{"model": "User", "pattern": "factory", "scope": "function", "uniqueness": "sequence"}], "rollback_strategy": "transactional", "xdist_db_strategy": "single-db", "conftest_path": "tests/conftest.py"},
  "drivers": {"has_subobjects": false, "has_many_optional_fields": false, "domain_scenarios_named": false, "xdist_workers": 4},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>xdist_workers=4 with uniqueness=sequence violates r5.</violation>
      <violation>xdist_db_strategy=single-db with xdist_workers&gt;1 violates r6.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every fixture has pattern+scope+uniqueness.</item>
      <item>No fixture with scope=session is also stateful.</item>
      <item>If xdist_workers&gt;1, all uniqueness=uuid AND xdist_db_strategy=worker-db.</item>
    </list>
  </section>

  <reference path="templates/factory-boy-factory.py">Factory Boy base.</reference>
  <reference path="templates/conftest-transactional.py">Rollback conftest.</reference>
  <reference path="scripts/validate-test-fixtures.py">Schema validator.</reference>
</text>
