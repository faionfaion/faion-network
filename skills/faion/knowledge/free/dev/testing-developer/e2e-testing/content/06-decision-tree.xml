<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="E2E Testing Decision Tree" version="2.0.0" est_tokens="600">
  <decision-tree>
    <root-question id="q-root" text="Does the input profile satisfy preconditions (drivers present: framework_preference, visual_regression_needed, ci_machine_budget, journey_count)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-framework" text="What is framework_preference?">
          <branch when="framework_preference == 'greenfield'">
            <conclusion ref="r-greenfield">Pick Playwright — superior parallelism, network interception, tracing.</conclusion>
          </branch>
          <branch when="framework_preference == 'cypress-migration'">
            <question id="q-visual" text="Is visual_regression_needed true?">
              <branch when="visual_regression_needed == true">
                <conclusion ref="r-component-screenshot">Stay on Cypress short-term; use component-scoped snapshots with masked regions.</conclusion>
              </branch>
              <branch when="visual_regression_needed == false">
                <question id="q-shard" text="Is ci_machine_budget &gt;= 4?">
                  <branch when="ci_machine_budget &gt;= 4">
                    <conclusion ref="r8-sharded-ci">Shard the suite across 4 CI machines; merge blob reports.</conclusion>
                  </branch>
                  <branch when="ci_machine_budget &lt; 4">
                    <conclusion ref="r-single-runner">Single runner with retries: 2 and trace: on-first-retry.</conclusion>
                  </branch>
                </question>
              </branch>
            </question>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true, framework_preference=greenfield">
      q-root yes → q-framework greenfield → r-greenfield
    </example>
  </decision-tree>
</text>
