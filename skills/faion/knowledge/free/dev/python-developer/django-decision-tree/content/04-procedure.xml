<text id="04-procedure" title="django-decision-tree Procedure" version="1.1.0" est_tokens="700" depth="deep">
  <summary>Seven steps walking the decision tree at bootstrap or refactor checkpoint.</summary>

  <section title="Steps">

    <step n="1" name="collect-signals">
      <input>Team / model / traffic / deployment context.</input>
      <action>Fill signals object: team_size, model_count, traffic_req_s, needs_admin, needs_async, bounded_contexts.</action>
      <output>signals object.</output>
    </step>

    <step n="2" name="pick-framework">
      <input>signals.</input>
      <action>Apply rule r1-pick-framework using the 5-signal score.</action>
      <output>decisions.framework + rationale.</output>
      <decision-gate>Reject framework=fastapi when needs_admin=true.</decision-gate>
    </step>

    <step n="3" name="pick-api-stack">
      <input>decisions.framework + project context.</input>
      <action>Apply rule r2-pick-api-stack.</action>
      <output>decisions.api_stack + rationale.</output>
    </step>

    <step n="4" name="pick-layering">
      <input>signals.model_count + signals.team_size + bounded_contexts.</input>
      <action>Apply rule r3-pick-layering.</action>
      <output>decisions.layering + rationale.</output>
      <decision-gate>Reject mismatched tiers (clean-arch for &lt; 10 models; simple for ≥ 50).</decision-gate>
    </step>

    <step n="5" name="pick-db">
      <input>traffic + concurrency + features (JSONB, full-text search).</input>
      <action>Apply rule r4-pick-db.</action>
      <output>decisions.db + rationale.</output>
    </step>

    <step n="6" name="pick-deployment">
      <input>Team DevOps maturity + scale target.</input>
      <action>Apply rule r5-pick-deployment.</action>
      <output>decisions.deployment + rationale.</output>
    </step>

    <step n="7" name="audit-deps">
      <input>Candidate third-party package list.</input>
      <action>For each: collect 8 signals, set verdict ∈ {adopt, trial, hold, sunset}.</action>
      <output>dependencies array.</output>
      <decision-gate>Reject verdict=adopt with audit failures.</decision-gate>
    </step>

  </section>
</text>
