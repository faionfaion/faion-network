<text id="02-output-contract" title="Poetry Project Setup — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Output schema for the subagent applying python-poetry-setup. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['pep621_present', 'lockfile_committed', 'dev_group_separate', 'venv_in_project'],
  "properties": {
    "pep621_present": { "type": "boolean" },
    "lockfile_committed": { "type": "boolean" },
    "dev_group_separate": { "type": "boolean" },
    "venv_in_project": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>pep621_present</item>
      <item>lockfile_committed</item>
      <item>dev_group_separate</item>
      <item>venv_in_project</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "pep621_present": true,
  "lockfile_committed": true,
  "dev_group_separate": true,
  "venv_in_project": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "pep621_present": false,
  "lockfile_committed": false,
  "dev_group_separate": false,
  "venv_in_project": false
}
]]></code>
      <note>All gates red; methodology not applied — fix the violations before claiming completion.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field is present and boolean true.</item>
      <item>Artefact references the rule id from 01-core-rules.xml (e.g., r1-pep621-layout).</item>
      <item>No extra properties outside the schema.</item>
    </list>
  </section>
</text>
