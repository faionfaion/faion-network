<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Python Ecosystem Overview — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Output schema for the subagent applying python-overview. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['domain_one_value', 'framework_one_value', 'python_version_pinned', 'downstream_methodologies_listed'],
  "properties": {
    "domain_one_value": { "type": "boolean" },
    "framework_one_value": { "type": "boolean" },
    "python_version_pinned": { "type": "boolean" },
    "downstream_methodologies_listed": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>domain_one_value</item>
      <item>framework_one_value</item>
      <item>python_version_pinned</item>
      <item>downstream_methodologies_listed</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "domain_one_value": true,
  "framework_one_value": true,
  "python_version_pinned": true,
  "downstream_methodologies_listed": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "domain_one_value": false,
  "framework_one_value": false,
  "python_version_pinned": false,
  "downstream_methodologies_listed": false
}
]]></code>
      <note>All gates red; methodology not applied — fix the violations before claiming completion.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field is present and boolean true.</item>
      <item>Artefact references the rule id from 01-core-rules.xml (e.g., r1-classify-first).</item>
      <item>No extra properties outside the schema.</item>
    </list>
  </section>
</text>
