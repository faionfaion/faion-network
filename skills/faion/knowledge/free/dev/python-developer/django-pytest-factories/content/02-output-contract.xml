<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-pytest-factories Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON schema for a pytest-factoryboy factories spec.</summary>

  <output-contract>
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artefact_id", "owner", "django_version", "factories", "register_calls", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string"},
    "django_version": {"type": "string"},
    "factories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "model", "subfactories", "post_generation", "mute_signals", "skip_postgeneration_save"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]*Factory$"},
          "model": {"type": "string"},
          "subfactories": {"type": "array", "items": {"type": "string"}},
          "post_generation": {"type": "array", "items": {"type": "string"}},
          "mute_signals": {"type": "boolean"},
          "skip_postgeneration_save": {"type": "boolean"}
        }
      }
    },
    "register_calls": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["factory"]}},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></schema>

    <forbidden>
      <pattern id="f1">factory.name not ending in "Factory"</pattern>
      <pattern id="f2">factory.post_generation non-empty AND skip_postgeneration_save=false (Django 4.2+ requires the flag)</pattern>
      <pattern id="f3">register_calls empty</pattern>
      <pattern id="f4">owner equals "team" or empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Sort factories alphabetically by name.</transformation>
    </allowed-transformations>
  </output-contract>

  <example valid="true"><![CDATA[
{
  "artefact_id": "billing-factories",
  "owner": "ruslan@faion.net",
  "django_version": "5.2.1",
  "factories": [
    {"name": "UserFactory", "model": "accounts.User", "subfactories": [], "post_generation": ["set_password"], "mute_signals": true, "skip_postgeneration_save": true},
    {"name": "InvoiceFactory", "model": "billing.Invoice", "subfactories": ["customer=CustomerFactory"], "post_generation": [], "mute_signals": false, "skip_postgeneration_save": true}
  ],
  "register_calls": [
    {"factory": "UserFactory"},
    {"factory": "InvoiceFactory"}
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

  <example valid="false"><![CDATA[
{
  "artefact_id": "bad",
  "owner": "team",
  "django_version": "5",
  "factories": [{"name": "User", "model": "auth.User", "subfactories": [], "post_generation": ["set_password"], "mute_signals": false, "skip_postgeneration_save": false}],
  "register_calls": [],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>
</text>
