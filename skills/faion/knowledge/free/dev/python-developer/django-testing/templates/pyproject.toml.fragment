# purpose: Pytest-django config block: DJANGO_SETTINGS_MODULE, addopts, markers, coverage.
# consumes: 01-core-rules.xml
# produces: code
# depends-on: content/01-core-rules.xml
# token-budget-impact: small

[tool.ruff]
target-version = "py313"
line-length = 100

[tool.ruff.lint]
select = ["E", "W", "F", "I", "B", "UP", "SIM", "T20", "S", "ASYNC"]

[tool.mypy]
python_version = "3.13"
strict = true

[tool.pytest.ini_options]
addopts = "--strict-markers --cov --cov-fail-under=80 -n auto"
testpaths = ["tests"]
markers = ["integration: requires external services"]
