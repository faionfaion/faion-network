<text id="02-output-contract" title="pytest Parametrize — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Output schema for the subagent applying python-pytest-parametrize. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['parametrize_used_for_repeats', 'ids_present', 'no_cartesian_explosion', 'pytest_param_for_per_case_marks'],
  "properties": {
    "parametrize_used_for_repeats": { "type": "boolean" },
    "ids_present": { "type": "boolean" },
    "no_cartesian_explosion": { "type": "boolean" },
    "pytest_param_for_per_case_marks": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>parametrize_used_for_repeats</item>
      <item>ids_present</item>
      <item>no_cartesian_explosion</item>
      <item>pytest_param_for_per_case_marks</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "parametrize_used_for_repeats": true,
  "ids_present": true,
  "no_cartesian_explosion": true,
  "pytest_param_for_per_case_marks": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
