<methodology slug="django-service-layer">
  <metadata>
    <tier>free</tier>
    <group>dev</group>
    <domain>python-developer</domain>
    <summary>Django service layer pattern: write operations in keyword-only service functions with transaction.atomic(), full_clean(), and domain exceptions. Keeps views thin and logic testable in isolation.</summary>
    <tags>
      <tag>django</tag>
      <tag>service-layer</tag>
      <tag>architecture</tag>
      <tag>transactions</tag>
    </tags>
    <category>architecture</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-27</created>
    <frameworks>
      <framework>django</framework>
    </frameworks>
    <languages>
      <language>python</language>
