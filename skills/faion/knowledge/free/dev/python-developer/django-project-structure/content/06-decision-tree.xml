<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="django-project-structure Decision Tree" version="1.1.0" est_tokens="200">
  <summary>Per concept: which folder owns it?</summary>

  <decision-tree>
    <root-question id="q-concept-domain">Does this concept belong to one business domain (orders, accounts, billing, ...)?</root-question>

    <branch when="q-concept-domain == 'one-domain'">
      <question id="q-concept-kind">What kind of code is it?</question>

      <branch when="q-concept-kind == 'write-with-side-effects'">
        <conclusion ref="r2-per-app-inventory">apps/&lt;domain&gt;/services.py (entity_action naming).</conclusion>
      </branch>

      <branch when="q-concept-kind == 'pure-read-query'">
        <conclusion ref="r2-per-app-inventory">apps/&lt;domain&gt;/selectors.py (entity_query naming).</conclusion>
      </branch>

      <branch when="q-concept-kind == 'http-handler'">
        <conclusion ref="r2-per-app-inventory">apps/&lt;domain&gt;/apis.py.</conclusion>
      </branch>

      <branch when="q-concept-kind == 'data-shape'">
        <conclusion ref="r2-per-app-inventory">apps/&lt;domain&gt;/models.py.</conclusion>
      </branch>

      <branch when="q-concept-kind == 'enum-or-limit'">
        <conclusion ref="r2-per-app-inventory">apps/&lt;domain&gt;/constants.py.</conclusion>
      </branch>
    </branch>

    <branch when="q-concept-domain == 'cross-domain-shared'">
      <conclusion ref="r3-core-no-import-from-apps">core/ — base classes, exceptions, pagination, permissions. core/ MUST NOT import from apps/.</conclusion>
    </branch>

    <branch when="q-concept-domain == 'configuration-or-wiring'">
      <conclusion ref="r4-config-package">config/ — settings split, urls, celery, ASGI/WSGI.</conclusion>
    </branch>

    <branch when="q-concept-domain == 'test-factory'">
      <conclusion ref="r2-per-app-inventory">tests/factories/ at the project root.</conclusion>
    </branch>
  </decision-tree>

  <example trace="invoice-create-service"><![CDATA[
concept: function "invoice_create" that writes to DB + sends an email
q-concept-domain -> 'one-domain' (billing)
q-concept-kind -> 'write-with-side-effects'
=> conclusion r2: apps/billing/services.py
]]></example>
</text>
