<text id="06-decision-tree" title="pnpm-package-management Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is this a JS/TS project where pnpm is acceptable as the package manager?</root-question>
    <branch when="pnpm_acceptable == true">
      <question>Can the project use corepack (Node >= 16.10)?</question>
      <branch when="corepack_supported == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="corepack_supported == false">
        <conclusion ref="r1"/>
      </branch>
    </branch>
    <branch when="pnpm_acceptable == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new TS monorepo, Node 20, pnpm 9 -> run-the-checklist"/>
  </decision-tree>
</text>
