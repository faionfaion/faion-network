<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="bun-runtime Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying bun-runtime. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["bun_version","tsconfig_module_resolution","bunfig_frozen_lockfile","server_uses_bun_serve"],"properties":{"bun_version":{"type":"string","pattern":"^\\d+\\.\\d+\\.\\d+$"},"tsconfig_module_resolution":{"const":"bundler"},"bunfig_frozen_lockfile":{"const":true},"server_uses_bun_serve":{"const":true},"scripts":{"type":"object","required":["dev","start","test","build"]}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"bun_version":"1.1.20","tsconfig_module_resolution":"bundler","bunfig_frozen_lockfile":true,"server_uses_bun_serve":true,"scripts":{"dev":"bun --watch src/server.ts","start":"bun src/server.ts","test":"bun test","build":"bun build src/server.ts --outdir dist"}}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"bun_version":"latest","tsconfig_module_resolution":"node","bunfig_frozen_lockfile":false,"server_uses_bun_serve":false}
]]></code>
      <note>Invalid: pinned to 'latest', non-bundler resolution, frozen-lockfile off, server uses node:http.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>bun_version is semver pinned (not 'latest').</item>
      <item>tsconfig moduleResolution == 'bundler'.</item>
      <item>bunfig has frozen-lockfile = true.</item>
      <item>Server uses Bun.serve (Hono-on-Bun OK).</item>
      <item>All four scripts present.</item>
    </list>
  </section>
</text>
