{
  "__faion_header__": {
    "purpose": "Pinned Bun version + dev/start/test/build scripts.",
    "consumes": "project repo; see methodology AGENTS.md.",
    "produces": "the working artifact; placement: Merge into repo package.json.",
    "depends-on": "the tooling pinned in the methodology AGENTS.md.",
    "token-budget-impact": "zero — local-only template."
  },

  "name": "my-bun-app",
  "type": "module",
  "packageManager": "bun@1.1.34",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap=external"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@hono/zod-validator": "^0.2.0",
    "hono": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
