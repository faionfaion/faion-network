<text id="06-decision-tree" title="javascript Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Is this a TS 5.x project (or migration target) where strict mode is acceptable?</root-question>
    <branch when="ts5_strict_ok == true">
      <question>Can the project adopt pnpm and ESLint 9 flat config?</question>
      <branch when="pnpm_and_eslint9 == true">
        <question>Will the team accept Vitest + MSW for testing?</question>
        <branch when="vitest_msw_ok == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="vitest_msw_ok == false">
          <conclusion ref="r8"/>
        </branch>
      </branch>
      <branch when="pnpm_and_eslint9 == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="ts5_strict_ok == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new React 18 project, TS 5.4, pnpm 9, Vitest -> run-the-checklist"/>
  </decision-tree>
</text>
