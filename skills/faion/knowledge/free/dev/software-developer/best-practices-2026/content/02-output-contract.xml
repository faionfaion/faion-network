<text id="02-output-contract" title="best-practices-2026 Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the constitution-snapshot record: pinned stack versions, list of extracted rule ids, drift-scan date, deprecated rules.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://best-practices-2026/output.schema.json",
  "type": "object",
  "required": ["snapshot_version", "stack", "extracted_rules", "drift_scan_date"],
  "properties": {
    "snapshot_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "stack": {
      "type": "object",
      "properties": {
        "python": {"type": "string"},
        "typescript": {"type": "string"},
        "react": {"type": "string"},
        "nextjs": {"type": "string"}
      }
    },
    "extracted_rules": {
      "type": "array",
      "items": {"type": "string", "pattern": "^r[0-9]+-[a-z-]+$"},
      "minItems": 1
    },
    "drift_scan_date": {"type": "string", "format": "date"},
    "deprecated_rules": {"type": "array", "items": {"type": "string"}}
  }
}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"snapshot_version": "1.1.0", "stack": {"python": "3.12", "typescript": "5.5", "react": "19.0", "nextjs": "15.0"}, "extracted_rules": ["r1-match-tool-to-task", "r4-ts-strict-flags", "r6-python-baseline"], "drift_scan_date": "2026-05-22", "deprecated_rules": []}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"snapshot_version": "latest", "extracted_rules": [], "drift_scan_date": "soon"}
]]></code>
      <note>Invalid: snapshot_version not semver, extracted_rules empty, drift_scan_date not ISO date, stack missing.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>At least one rule extracted into the project's `constitution.md`.</item>
      <item>Stack versions match what is actually pinned in package.json / pyproject.toml.</item>
      <item>drift_scan_date is within the last 90 days.</item>
      <item>Deprecated rules listed (not deleted) so historical references resolve.</item>
    </list>
  </section>
</text>
