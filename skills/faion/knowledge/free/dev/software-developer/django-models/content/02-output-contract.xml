<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-models Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-models. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["inherits_base_model","fks_explicit_on_delete","text_choices_for_enums","composite_indexes_present","no_business_logic_on_model"],"properties":{"inherits_base_model":{"const":true},"fks_explicit_on_delete":{"const":true},"text_choices_for_enums":{"const":true},"composite_indexes_present":{"const":true},"no_business_logic_on_model":{"const":true}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"inherits_base_model":true,"fks_explicit_on_delete":true,"text_choices_for_enums":true,"composite_indexes_present":true,"no_business_logic_on_model":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"inherits_base_model":false,"fks_explicit_on_delete":false,"text_choices_for_enums":false,"composite_indexes_present":false,"no_business_logic_on_model":false}
]]></code>
      <note>Invalid: all model-design rules violated.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every model inherits BaseModel.</item>
      <item>Every FK declares on_delete.</item>
      <item>Enums via TextChoices.</item>
      <item>Composite query patterns covered by Meta.indexes.</item>
      <item>No business logic on model methods/managers.</item>
    </list>
  </section>
</text>
