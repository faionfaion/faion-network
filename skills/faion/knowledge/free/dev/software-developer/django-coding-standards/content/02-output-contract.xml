<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-coding-standards Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-coding-standards. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["layout","cross_app_imports_aliased","service_layer_used","keyword_only_in_services","text_choices_for_enums","update_fields_on_save"],"properties":{"layout":{"type":"string","enum":["apps-core-config","flat","mixed"]},"cross_app_imports_aliased":{"const":true},"service_layer_used":{"const":true},"keyword_only_in_services":{"const":true},"text_choices_for_enums":{"const":true},"update_fields_on_save":{"const":true}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"layout":"apps-core-config","cross_app_imports_aliased":true,"service_layer_used":true,"keyword_only_in_services":true,"text_choices_for_enums":true,"update_fields_on_save":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"layout":"flat","cross_app_imports_aliased":false,"service_layer_used":false,"keyword_only_in_services":false,"text_choices_for_enums":false,"update_fields_on_save":false}
]]></code>
      <note>Invalid: flat layout, no service layer, no aliased imports, no TextChoices, no update_fields, positional args.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Layout is apps + core + config.</item>
      <item>All cross-app imports aliased.</item>
      <item>Service layer used; no logic in views/models.</item>
      <item>Service args keyword-only.</item>
      <item>Enums via TextChoices/IntegerChoices.</item>
      <item>save(update_fields=[...]) on every update.</item>
    </list>
  </section>
</text>
