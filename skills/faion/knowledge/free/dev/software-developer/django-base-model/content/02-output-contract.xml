<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-base-model Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-base-model. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["has_int_pk","has_uuid_uid","has_timestamps","abstract_true","fks_explicit_on_delete"],"properties":{"has_int_pk":{"const":true},"has_uuid_uid":{"const":true},"has_timestamps":{"const":true},"abstract_true":{"const":true},"fks_explicit_on_delete":{"const":true},"composite_indexes_declared":{"type":"boolean"}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"has_int_pk":true,"has_uuid_uid":true,"has_timestamps":true,"abstract_true":true,"fks_explicit_on_delete":true,"composite_indexes_declared":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"has_int_pk":false,"has_uuid_uid":false,"has_timestamps":false,"abstract_true":false,"fks_explicit_on_delete":false}
]]></code>
      <note>Invalid: every field of the BaseModel pattern missing.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Integer PK is `id`, UUIDField is `uid`.</item>
      <item>`created_at` / `updated_at` present with `auto_now_add` / `auto_now`.</item>
      <item>`Meta.abstract = True` on BaseModel.</item>
      <item>Every FK declares `on_delete=`.</item>
      <item>Multi-column query patterns covered by `Meta.indexes`.</item>
    </list>
  </section>
</text>
