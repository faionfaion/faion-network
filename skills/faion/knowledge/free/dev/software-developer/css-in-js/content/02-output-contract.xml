<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="css-in-js Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying css-in-js. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["library","runtime_kind","uses_rsc"],"properties":{"library":{"type":"string","enum":["vanilla-extract","panda","linaria","emotion","styled-components","none"]},"runtime_kind":{"type":"string","enum":["zero","runtime"]},"uses_rsc":{"type":"boolean"},"theme_type_augmented":{"type":"boolean"}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"library":"vanilla-extract","runtime_kind":"zero","uses_rsc":true,"theme_type_augmented":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"library":"emotion","runtime_kind":"runtime","uses_rsc":true,"theme_type_augmented":false}
]]></code>
      <note>Invalid: emotion (runtime) chosen for an RSC app.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>library is one of the allowed enum values.</item>
      <item>uses_rsc == true → runtime_kind MUST be 'zero'.</item>
      <item>TypeScript theme augmentation present.</item>
    </list>
  </section>
</text>
