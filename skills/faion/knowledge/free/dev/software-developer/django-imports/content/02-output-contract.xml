<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-imports Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-imports. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["cross_app_aliased","no_star_imports","isort_first_party_configured","type_imports_under_type_checking"],"properties":{"cross_app_aliased":{"const":true},"no_star_imports":{"const":true},"isort_first_party_configured":{"const":true},"type_imports_under_type_checking":{"const":true}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"cross_app_aliased":true,"no_star_imports":true,"isort_first_party_configured":true,"type_imports_under_type_checking":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"cross_app_aliased":false,"no_star_imports":false,"isort_first_party_configured":false,"type_imports_under_type_checking":false}
]]></code>
      <note>Invalid: every import-discipline rule violated.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All cross-app imports aliased.</item>
      <item>No `import *` anywhere.</item>
      <item>isort/ruff first-party config matches apps/core/config.</item>
      <item>Type-only imports under `if TYPE_CHECKING:` (or via TCH ruff).</item>
    </list>
  </section>
</text>
