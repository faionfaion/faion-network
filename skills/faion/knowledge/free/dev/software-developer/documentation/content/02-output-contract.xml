<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="documentation Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying documentation. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["claude_md_aliases","agents_md_lines","file_table_present","per_module_coverage_pct"],"properties":{"claude_md_aliases":{"const":true},"agents_md_lines":{"type":"integer","minimum":20,"maximum":120},"file_table_present":{"const":true},"per_module_coverage_pct":{"type":"number","minimum":0,"maximum":100},"agents_folder_indexed":{"type":"boolean"}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"claude_md_aliases":true,"agents_md_lines":52,"file_table_present":true,"per_module_coverage_pct":98.2,"agents_folder_indexed":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"claude_md_aliases":false,"agents_md_lines":350,"file_table_present":false,"per_module_coverage_pct":35}
]]></code>
      <note>Invalid: CLAUDE.md not aliasing AGENTS.md; AGENTS.md too long; missing file table; coverage too low.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>CLAUDE.md is exactly `@AGENTS.md`.</item>
      <item>AGENTS.md is 20-80 lines (hard cap 120).</item>
      <item>File table present.</item>
      <item>Per-module coverage &gt;= 90%.</item>
      <item>`.agents/` indexed via INDEX.md when present.</item>
    </list>
  </section>
</text>
