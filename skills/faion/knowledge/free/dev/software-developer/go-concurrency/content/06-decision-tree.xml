<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="go-concurrency Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Does the code spawn goroutines, use channels, or use select/sync primitives?</root-question>
    <branch when="has_concurrency == true">
      <question>Is ctx.Context plumbed into every goroutine entry point?</question>
      <branch when="ctx_plumbed == true">
        <question>Does CI run go test -race -count>=10 for the package?</question>
        <branch when="ci_race_x10 == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="ci_race_x10 == false">
          <conclusion ref="r8"/>
        </branch>
      </branch>
      <branch when="ctx_plumbed == false">
        <conclusion ref="r2"/>
      </branch>
    </branch>
    <branch when="has_concurrency == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new Pool with ctx + select ctx.Done, CI race x10 -> run-the-checklist"/>
  </decision-tree>
</text>
