<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-testing Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-testing. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["runner","data_strategy","service_tests_real_code","drf_client_used","db_isolation"],"properties":{"runner":{"const":"pytest-django"},"data_strategy":{"type":"string","enum":["model-bakery","factory-boy","mixed"]},"service_tests_real_code":{"const":true},"drf_client_used":{"const":"APIClient"},"db_isolation":{"type":"string","enum":["transactional","commit-when-needed"]}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"runner":"pytest-django","data_strategy":"factory-boy","service_tests_real_code":true,"drf_client_used":"APIClient","db_isolation":"transactional"}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"runner":"unittest","data_strategy":"inline","service_tests_real_code":false,"drf_client_used":"Client","db_isolation":"commit-everywhere"}
]]></code>
      <note>Invalid: unittest runner, inline data, internal mocks, plain Client for DRF.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Runner is pytest-django.</item>
      <item>Data created via bakery/factory_boy.</item>
      <item>Service tests call real code.</item>
      <item>DRF tests use APIClient.</item>
      <item>Default DB isolation is transactional.</item>
    </list>
  </section>
</text>
