<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Unit Testing — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Output schema for the subagent applying unit-testing. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['aaa_explicit', 'single_behaviour_per_test', 'no_real_io_in_unit', 'descriptive_name'],
  "properties": {
    "aaa_explicit": { "type": "boolean" },
    "single_behaviour_per_test": { "type": "boolean" },
    "no_real_io_in_unit": { "type": "boolean" },
    "descriptive_name": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>aaa_explicit</item>
      <item>single_behaviour_per_test</item>
      <item>no_real_io_in_unit</item>
      <item>descriptive_name</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "aaa_explicit": true,
  "single_behaviour_per_test": true,
  "no_real_io_in_unit": true,
  "descriptive_name": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "aaa_explicit": false,
  "single_behaviour_per_test": false,
  "no_real_io_in_unit": false,
  "descriptive_name": false
}
]]></code>
      <note>All gates red; methodology not applied — fix the violations before claiming completion.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field is present and boolean true.</item>
      <item>Artefact references the rule id from 01-core-rules.xml (e.g., r1-one-behaviour).</item>
      <item>No extra properties outside the schema.</item>
    </list>
  </section>
</text>
