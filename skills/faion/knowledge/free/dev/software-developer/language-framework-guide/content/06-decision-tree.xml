<text id="06-decision-tree" title="language-framework-guide Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Is project longevity >= 3 months and stack choice owned by this team?</root-question>
    <branch when="longevity_months >= 3 AND owns_choice == true">
      <question>Is the project type one of the canonical mappings (backend API, frontend, full-stack, CLI, systems)?</question>
      <branch when="canonical_type == true">
        <question>Is longevity > 6 months (ADR required)?</question>
        <branch when="longevity_months > 6">
          <conclusion ref="r6"/>
        </branch>
        <branch when="longevity_months &lt;= 6">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
      <branch when="canonical_type == false">
        <conclusion ref="r1"/>
      </branch>
    </branch>
    <branch when="longevity_months &lt; 3 OR owns_choice == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="solo founder, 12mo API project -> ADR required (r6) -> run-the-checklist after ADR is filed"/>
  </decision-tree>
</text>
