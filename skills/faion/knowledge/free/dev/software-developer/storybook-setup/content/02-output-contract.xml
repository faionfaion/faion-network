<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Storybook Setup — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Output schema for the subagent applying storybook-setup. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['csf3_used', 'autodocs_present', 'args_cover_required', 'chromatic_in_ci'],
  "properties": {
    "csf3_used": { "type": "boolean" },
    "autodocs_present": { "type": "boolean" },
    "args_cover_required": { "type": "boolean" },
    "chromatic_in_ci": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>csf3_used</item>
      <item>autodocs_present</item>
      <item>args_cover_required</item>
      <item>chromatic_in_ci</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "csf3_used": true,
  "autodocs_present": true,
  "args_cover_required": true,
  "chromatic_in_ci": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "csf3_used": false,
  "autodocs_present": false,
  "args_cover_required": false,
  "chromatic_in_ci": false
}
]]></code>
      <note>All gates red; methodology not applied — fix the violations before claiming completion.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field is present and boolean true.</item>
      <item>Artefact references the rule id from 01-core-rules.xml (e.g., r1-csf3-satisfies).</item>
      <item>No extra properties outside the schema.</item>
    </list>
  </section>
</text>
