<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="TDD Workflow — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Output schema for the subagent applying tdd-workflow. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['red_commit_present', 'single_assertion_red', 'refactor_stays_green', 'spec_referenced'],
  "properties": {
    "red_commit_present": { "type": "boolean" },
    "single_assertion_red": { "type": "boolean" },
    "refactor_stays_green": { "type": "boolean" },
    "spec_referenced": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>red_commit_present</item>
      <item>single_assertion_red</item>
      <item>refactor_stays_green</item>
      <item>spec_referenced</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "red_commit_present": true,
  "single_assertion_red": true,
  "refactor_stays_green": true,
  "spec_referenced": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "red_commit_present": false,
  "single_assertion_red": false,
  "refactor_stays_green": false,
  "spec_referenced": false
}
]]></code>
      <note>All gates red; methodology not applied — fix the violations before claiming completion.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field is present and boolean true.</item>
      <item>Artefact references the rule id from 01-core-rules.xml (e.g., r1-red-first).</item>
      <item>No extra properties outside the schema.</item>
    </list>
  </section>
</text>
