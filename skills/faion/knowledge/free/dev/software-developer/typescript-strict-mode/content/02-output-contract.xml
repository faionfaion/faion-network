<text id="02-output-contract" title="TypeScript Strict Mode — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>Output schema for the subagent applying typescript-strict-mode. Encodes required boolean checks against the artefact under review.</summary>

  <section title="Schema (JSON Schema fragment)">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ['strict_true', 'four_extras_enabled', 'zod_at_io', 'no_bare_any', 'no_unjustified_ts_ignore'],
  "properties": {
    "strict_true": { "type": "boolean" },
    "four_extras_enabled": { "type": "boolean" },
    "zod_at_io": { "type": "boolean" },
    "no_bare_any": { "type": "boolean" },
    "no_unjustified_ts_ignore": { "type": "boolean" }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Required fields">
    <list>
      <item>strict_true</item>
      <item>four_extras_enabled</item>
      <item>zod_at_io</item>
      <item>no_bare_any</item>
      <item>no_unjustified_ts_ignore</item>
    </list>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "strict_true": true,
  "four_extras_enabled": true,
  "zod_at_io": true,
  "no_bare_any": true,
  "no_unjustified_ts_ignore": true
}
]]></code>
      <note>All gates green; methodology applied.</note>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "strict_true": false,
  "four_extras_enabled": false,
  "zod_at_io": false,
  "no_bare_any": false,
  "no_unjustified_ts_ignore": false
}
]]></code>
      <note>All gates red; methodology not applied — fix the violations before claiming completion.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field is present and boolean true.</item>
      <item>Artefact references the rule id from 01-core-rules.xml (e.g., r1-strict-true).</item>
      <item>No extra properties outside the schema.</item>
    </list>
  </section>
</text>
