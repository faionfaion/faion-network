// purpose: TS strict baseline + four recommended extras
// consumes: content/01-core-rules.xml
// produces: config
// depends-on: content/01-core-rules.xml
// token-budget-impact: small

{
  "_comment_purpose": "Canonical 2026 baseline with strict + four extras + module/moduleResolution.",
  "_comment_consumes": "01-core-rules.xml",
  "_comment_produces": "config",
  "_comment_depends_on": "content/01-core-rules.xml",
  "_comment_token_budget_impact": "small",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": ["src/**/*"]
}
