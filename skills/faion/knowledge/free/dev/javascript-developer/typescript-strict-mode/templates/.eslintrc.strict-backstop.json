{
  "_purpose": "ESLint backstop rules that prevent regressions of TS strict mode wins.",
  "_consumes": "nothing — extend in repo .eslintrc.",
  "_produces": "rule set.",
  "_depends-on": "@typescript-eslint/eslint-plugin >= 7.",
  "_token-budget-impact": "~80 tokens.",
  "extends": ["plugin:@typescript-eslint/recommended-type-checked"],
  "rules": {
    "@typescript-eslint/no-non-null-assertion": "error",
    "@typescript-eslint/no-explicit-any": ["error", {"ignoreRestArgs": false}],
    "@typescript-eslint/no-unsafe-assignment": "error",
    "@typescript-eslint/no-unsafe-member-access": "error",
    "@typescript-eslint/no-unsafe-return": "error",
    "@typescript-eslint/ban-ts-comment": ["error", {"ts-expect-error": true, "ts-ignore": true, "ts-nocheck": "allow-with-description"}]
  }
}
