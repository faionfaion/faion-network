<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Bun Runtime (Simple) Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the generated service spec.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/bun-runtime-simple.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "service_name",
    "routes",
    "auth"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "service_name": {
      "type": "string"
    },
    "bun_version": {
      "type": "string"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "path"
        ],
        "properties": {
          "method": {
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "auth": {
      "enum": [
        "none",
        "token",
        "session"
      ]
    },
    "uses_npm": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "brs-001",
  "service_name": "user-api",
  "bun_version": "1.1.30",
  "routes": [
    {
      "method": "POST",
      "path": "/login"
    },
    {
      "method": "GET",
      "path": "/me"
    }
  ],
  "auth": "token",
  "uses_npm": [
    "hono"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service_name": "x",
  "routes": [],
  "auth": "none",
  "uses_npm": [
    "express",
    "bcrypt",
    "dotenv"
  ]
}
]]></code>
    <note>uses_npm contains forbidden packages (express, bcrypt, dotenv); missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-bun-runtime-simple.py">schema validator</reference>
</text>
