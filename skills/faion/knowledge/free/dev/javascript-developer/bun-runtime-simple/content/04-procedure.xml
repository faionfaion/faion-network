<text id="04-procedure" title="Bun Runtime (Simple) Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>5-step Bun service scaffold.</summary>

  <section title="Procedure">

    <step n="1" name="init">
      <input>service_name</input>
      <action>Run `bun init -y`; install hono.</action>
      <output>Empty Bun project.</output>
    </step>
    <step n="2" name="wire-router">
      <input>Routes spec</input>
      <action>Replace index.ts with Hono app + routes.</action>
      <output>Routing layer.</output>
    </step>
    <step n="3" name="wire-auth">
      <input>auth choice</input>
      <action>If token / session, add Bun.password hash + verify helpers; mount auth middleware.</action>
      <output>Auth layer.</output>
      <decision-gate>If auth == none, skip; otherwise verify Bun.password API present (Bun &amp;gt;= 1.0).</decision-gate>
    </step>
    <step n="4" name="wire-tests">
      <input>Routes + auth</input>
      <action>Add bun:test files per route.</action>
      <output>Test suite.</output>
    </step>
    <step n="5" name="verify">
      <input>All above</input>
      <action>Run `bun test`; run `bun start`; smoke-test routes.</action>
      <output>Working service.</output>
    </step>

  </section>
</text>
