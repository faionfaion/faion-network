<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="React Decomposition Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Dominant concern → extraction kind.</summary>

  <decision-tree>
    <root-question id="q-dom">What dominates the component (lines of)?</root-question>
    <branch when="dominant == logic">
      <conclusion ref="hooks-for-logic" verdict="extract custom hook"/>
    </branch>
    <branch when="dominant == io">
      <conclusion ref="services-for-io" verdict="extract service module"/>
    </branch>
    <branch when="dominant == state_machine">
      <conclusion ref="hooks-for-logic" verdict="extract useReducer + Context provider"/>
    </branch>
    <branch when="dominant == multi_feature">
      <conclusion ref="feature-folders" verdict="split into feature folders"/>
    </branch>
  </decision-tree>
</text>
