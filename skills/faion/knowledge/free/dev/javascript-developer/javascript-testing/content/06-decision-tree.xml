<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="JavaScript Testing Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Build tool + surface → runner &amp; mocks.</summary>
  <decision-tree>
    <root-question id="q-build">What is the build tool?</root-question>
    <branch when="build == vite">
      <conclusion ref="vitest-default" verdict="Vitest + V8 coverage"/>
    </branch>
    <branch when="build == webpack">
      <question id="q-react">React with CRA legacy?</question>
      <branch when="cra == true">
        <conclusion ref="vitest-default" verdict="Migrate to Vite + Vitest"/>
      </branch>
      <branch when="cra == false">
        <conclusion ref="vitest-default" verdict="Vitest if ESM-friendly; Jest if SystemJS / legacy"/>
      </branch>
    </branch>
    <branch when="build == none">
      <conclusion ref="vitest-default" verdict="Vitest for pure logic; tinypool runner"/>
    </branch>
  </decision-tree>
</text>
