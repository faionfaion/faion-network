<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Modern JS/TS Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the config bundle artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/javascript-modern.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "runtime",
    "package_manager",
    "tsconfig",
    "eslint_config",
    "named_exports_only"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "runtime": {
      "enum": [
        "node",
        "bun",
        "browser",
        "edge",
        "mixed"
      ]
    },
    "package_manager": {
      "enum": [
        "pnpm",
        "npm",
        "yarn",
        "bun"
      ]
    },
    "tsconfig": {
      "type": "object"
    },
    "eslint_config": {
      "type": "string"
    },
    "named_exports_only": {
      "type": "boolean"
    },
    "monorepo": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "jm-001",
  "runtime": "node",
  "package_manager": "pnpm",
  "tsconfig": {
    "strict": true,
    "target": "ES2022"
  },
  "eslint_config": "eslint.config.js",
  "named_exports_only": true,
  "monorepo": true,
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "runtime": "deno",
  "package_manager": "yarn",
  "tsconfig": {
    "strict": false
  },
  "eslint_config": ".eslintrc.json",
  "named_exports_only": false,
  "monorepo": false
}
]]></code>
    <note>runtime 'deno' not in enum; tsconfig strict must be true; .eslintrc.json forbidden; named_exports_only must be true; missing required fields.</note>
  </example>

  <reference path="scripts/validate-javascript-modern.py">schema validator</reference>
</text>
