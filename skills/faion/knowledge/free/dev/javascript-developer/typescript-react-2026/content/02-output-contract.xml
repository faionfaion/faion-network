<text id="02-output-contract" title="typescript-react-2026 Output Contract" version="1.1.0" est_tokens="1000" depth="essential">
  <summary>JSON schema for the App-Router scaffold spec.</summary>

  <output-contract>
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artefact_id", "owner", "app_name", "next_version", "react_version", "ts_version", "routes", "actions", "tsconfig_flags", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string"},
    "app_name": {"type": "string"},
    "next_version": {"type": "string"},
    "react_version": {"type": "string"},
    "ts_version": {"type": "string"},
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "files"],
        "properties": {
          "path": {"type": "string"},
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["file", "boundary"],
              "properties": {
                "file": {"type": "string"},
                "boundary": {"type": "string", "enum": ["server-default", "use-client", "use-server"]},
                "uses_hooks": {"type": "boolean"}
              }
            }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "mutates", "revalidate"],
        "properties": {
          "name": {"type": "string"},
          "mutates": {"type": "boolean"},
          "revalidate": {
            "type": "object",
            "properties": {
              "kind": {"type": "string", "enum": ["path", "tag", "none"]},
              "target": {"type": "string"}
            }
          },
          "input_schema": {"type": "string"}
        }
      }
    },
    "tsconfig_flags": {
      "type": "object",
      "required": ["strict", "noUncheckedIndexedAccess", "exactOptionalPropertyTypes"],
      "properties": {
        "strict": {"const": true},
        "noUncheckedIndexedAccess": {"const": true},
        "exactOptionalPropertyTypes": {"const": true},
        "verbatimModuleSyntax": {"type": "boolean"}
      }
    },
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></schema>

    <forbidden>
      <pattern id="f1">a file with file.endsWith('layout.tsx') and boundary == 'use-client'</pattern>
      <pattern id="f2">an action with mutates=true but revalidate.kind=='none'</pattern>
      <pattern id="f3">tsconfig_flags missing any of strict / noUncheckedIndexedAccess / exactOptionalPropertyTypes (or set to false)</pattern>
      <pattern id="f4">owner equals "team" or empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Sort routes alphabetically by path.</transformation>
    </allowed-transformations>
  </output-contract>

  <example valid="true"><![CDATA[
{
  "artefact_id": "billing-app-router",
  "owner": "ruslan@faion.net",
  "app_name": "billing",
  "next_version": "^15.0.0",
  "react_version": "^19.0.0",
  "ts_version": "^5.4.0",
  "routes": [
    {
      "path": "/dashboard",
      "files": [
        {"file": "app/dashboard/layout.tsx", "boundary": "server-default"},
        {"file": "app/dashboard/page.tsx",   "boundary": "server-default"},
        {"file": "app/dashboard/Sidebar.tsx","boundary": "use-client", "uses_hooks": true}
      ]
    }
  ],
  "actions": [
    {"name": "createInvoice", "mutates": true, "revalidate": {"kind": "path", "target": "/dashboard"}, "input_schema": "CreateInvoiceSchema"}
  ],
  "tsconfig_flags": {"strict": true, "noUncheckedIndexedAccess": true, "exactOptionalPropertyTypes": true, "verbatimModuleSyntax": true},
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

  <example valid="false"><![CDATA[
{
  "artefact_id": "bad",
  "owner": "team",
  "app_name": "x",
  "next_version": "15",
  "react_version": "19",
  "ts_version": "5",
  "routes": [
    {"path": "/d", "files": [{"file": "app/d/layout.tsx", "boundary": "use-client"}]}
  ],
  "actions": [{"name": "createX", "mutates": true, "revalidate": {"kind": "none"}}],
  "tsconfig_flags": {"strict": false, "noUncheckedIndexedAccess": false, "exactOptionalPropertyTypes": false},
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>
</text>
