<methodology slug="nodejs-fastify">
  <metadata>
    <tier>free</tier>
    <group>dev</group>
    <domain>javascript-developer</domain>
    <summary>High-performance TypeScript-first Node.js framework with JSON Schema validation, plugin architecture, and built-in security and rate limiting.</summary>
    <tags>
      <tag>nodejs</tag>
      <tag>fastify</tag>
      <tag>typescript</tag>
      <tag>rest-api</tag>
      <tag>http-framework</tag>
    </tags>
