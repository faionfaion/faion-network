<text id="06-decision-tree" title="Node.js Fastify Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Surface + plugin set tree.</summary>
  <decision-tree>
    <root-question id="q-surface">What kind of surface does the service expose?</root-question>
    <branch when="surface == rest">
      <conclusion ref="schema-required" verdict="Fastify + TypeBox schemas per route"/>
    </branch>
    <branch when="surface == websocket">
      <conclusion ref="plugins-before-routes" verdict="Fastify + @fastify/websocket plugin"/>
    </branch>
    <branch when="surface == hybrid">
      <conclusion ref="plugins-before-routes" verdict="Fastify + both plugins; separate route groups"/>
    </branch>
  </decision-tree>
</text>
