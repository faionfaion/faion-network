<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Node.js Fastify Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the Fastify service spec.</summary>
  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/nodejs-fastify.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "service_name",
    "routes",
    "plugins"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "service_name": {
      "type": "string"
    },
    "node_version": {
      "type": "string"
    },
    "fastify_version": {
      "type": "string"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "path",
          "has_schema"
        ],
        "properties": {
          "method": {
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string"
          },
          "has_schema": {
            "type": "boolean",
            "const": true
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "nf-001",
  "service_name": "billing-api",
  "node_version": "20.12.0",
  "fastify_version": "4.27.0",
  "routes": [
    {
      "method": "GET",
      "path": "/health",
      "has_schema": true
    },
    {
      "method": "POST",
      "path": "/invoices",
      "has_schema": true
    }
  ],
  "plugins": [
    "@fastify/helmet",
    "@fastify/cors",
    "@fastify/compress",
    "@fastify/rate-limit"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service_name": "x",
  "routes": [
    {
      "method": "GET",
      "path": "/x",
      "has_schema": false
    }
  ],
  "plugins": []
}
]]></code>
    <note>route has_schema must be true; plugins empty; missing required fields.</note>
  </example>
  <reference path="scripts/validate-nodejs-fastify.py">schema validator</reference>
</text>
