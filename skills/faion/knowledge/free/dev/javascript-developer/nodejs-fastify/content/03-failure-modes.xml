<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Node.js Fastify Failure Modes" version="1.1.0" est_tokens="700" depth="essential">
  <summary>3 antipatterns.</summary>
  <section title="Antipatterns">
    <antipattern id="no-route-schema" severity="high">
      <symptom>Route declared without schema option; Fastify defaults to no validation.</symptom>
      <root-cause source="Fastify docs">Author copied minimal example.</root-cause>
      <fix>Add schema option per route; reject PR otherwise.</fix>
    </antipattern>
    <antipattern id="plugin-after-route" severity="high">
      <symptom>fastify.register(authPlugin) appears AFTER fastify.get(...).</symptom>
      <root-cause source="Fastify docs — Plugin scope">Misunderstanding of encapsulation.</root-cause>
      <fix>Move all plugin registrations to the top; routes after.</fix>
    </antipattern>
    <antipattern id="custom-error-formatter-leak" severity="high">
      <symptom>Error response includes stack trace in production.</symptom>
      <root-cause source="Fastify docs — Errors">setErrorHandler not configured.</root-cause>
      <fix>Add setErrorHandler that maps errors to safe JSON, no stacks.</fix>
    </antipattern>
  </section>
</text>
