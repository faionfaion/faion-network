<text id="02-output-contract" title="Stripe Payment Links No Backend Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the payment-links-spec artefact. Subagent output MUST validate against this schema before being returned.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "owner", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "stripe-payment-links-no-backend"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "owner": {"type": "string", "minLength": 3, "not": {"pattern": "^(team|we|us|engineering|support|the (team|squad|group))$"}},
    "decision": {
      "type": "object",
      "required": ["mode", "links", "webhook_endpoint", "signature_strategy", "idempotency_store", "fulfillment_channels"],
      "properties": {
        "mode": {"enum": ["payment-link", "checkout-session", "reject-connect"]},
        "links": {"type": "array", "items": {"type": "object", "required": ["sku", "url", "price_cents", "currency"]}},
        "webhook_endpoint": {"type": "string", "format": "uri"},
        "signature_strategy": {"enum": ["hmac-sha256-stripe-sdk", "hmac-sha256-manual"]},
        "idempotency_store": {"type": "string"},
        "fulfillment_channels": {"type": "array", "minItems": 1}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["billing_model", "custom_amount_per_buyer", "connect_required", "catalog_size"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Lifetime-deal indie product, one webhook channel"><![CDATA[
{
  "slug": "stripe-payment-links-no-backend",
  "version": "2.0.0",
  "last_reviewed": "2026-05-22",
  "owner": "ruslan@faion.net",
  "decision": {
    "mode": "payment-link",
    "links": [{"sku": "ltd-29", "url": "https://buy.stripe.com/abc", "price_cents": 2900, "currency": "usd"}],
    "webhook_endpoint": "https://hooks.zapier.com/hooks/catch/.../...",
    "signature_strategy": "hmac-sha256-stripe-sdk",
    "idempotency_store": "https://docs.google.com/spreadsheets/d/.../edit#gid=0",
    "fulfillment_channels": [{"channel": "email", "address": "downloads@faion.net"}]
  },
  "drivers": {"billing_model": "one-off", "custom_amount_per_buyer": false, "connect_required": false, "catalog_size": 1},
  "audit": {"rule_refs": ["r1-verify-signature", "r3-idempotency-key", "r-payment-link"]}
}
]]></example>

    <example valid="false" title="Missing signature_strategy + empty rule_refs"><![CDATA[
{
  "slug": "stripe-payment-links-no-backend",
  "version": "2.0.0",
  "owner": "team",
  "decision": {"mode": "payment-link", "links": [], "webhook_endpoint": "https://x", "idempotency_store": "", "fulfillment_channels": []},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>owner matches forbidden plural pattern "team".</violation>
      <violation>decision.signature_strategy missing — fails r1-verify-signature.</violation>
      <violation>decision.fulfillment_channels empty — fails contract.</violation>
      <violation>audit.rule_refs empty — fails r5-versioned-stale-flag traceability.</violation>
      <violation>drivers missing required keys (billing_model, custom_amount_per_buyer, connect_required, catalog_size).</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.mode matches the decision tree branch given drivers.</item>
      <item>audit.rule_refs cites the rules that drove the branch (≥ r1, r3, plus mode-specific rule).</item>
      <item>last_reviewed is within 90 days of today.</item>
    </list>
  </section>

  <reference path="templates/payment-links-spec.md">Markdown wrapper of this JSON for code review.</reference>
  <reference path="scripts/validate-stripe-payment-links-no-backend.py">Schema validator.</reference>
</text>
