<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Code Decomposition Principles Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree for split / leave / merge per candidate file.</summary>

  <decision-tree>
    <root-question id="q-size">Does the file meet the size trigger (LOC ≥ 300 OR tokens ≥ 10000)?</root-question>
    <branch when="size_trigger == false">
      <question id="q-merge">Is the file always co-edited with one sibling in the same concern bucket?</question>
      <branch when="always_co_edited == true">
        <conclusion ref="size-trigger" verdict="merge"/>
      </branch>
      <branch when="always_co_edited == false">
        <conclusion ref="size-trigger" verdict="leave"/>
      </branch>
    </branch>
    <branch when="size_trigger == true">
      <question id="q-srp">Are ≥2 distinct responsibility tags present, each on &amp;gt;10% of symbols?</question>
      <branch when="srp_violated == true">
        <conclusion ref="srp-detector" verdict="split"/>
      </branch>
      <branch when="srp_violated == false">
        <question id="q-llm">Does the file exceed 10k tokens?</question>
        <branch when="tokens &amp;gt; 10000">
          <conclusion ref="llm-fit" verdict="split"/>
        </branch>
        <branch when="tokens &amp;lt;= 10000">
          <conclusion ref="size-trigger" verdict="leave"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>
</text>
