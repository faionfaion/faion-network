<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Tech Debt Basics Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Fowler quadrant picker.</summary>

  <decision-tree>
    <root-question id="q-deliberate">Was the debt incurred deliberately (a known trade-off)?</root-question>
    <branch when="deliberate == true">
      <question id="q-aware-deliberate">Was the team aware of the future consequence?</question>
      <branch when="aware == true">
        <conclusion ref="fowler-quadrant" verdict="deliberate-prudent (monitor)"/>
      </branch>
      <branch when="aware == false">
        <conclusion ref="fowler-quadrant" verdict="deliberate-reckless (educate + refactor)"/>
      </branch>
    </branch>
    <branch when="deliberate == false">
      <question id="q-aware-inadvertent">Was the consequence visible at the time?</question>
      <branch when="visible == true">
        <conclusion ref="fowler-quadrant" verdict="inadvertent-prudent (accept + monitor)"/>
      </branch>
      <branch when="visible == false">
        <conclusion ref="fowler-quadrant" verdict="inadvertent-reckless (refactor priority)"/>
      </branch>
    </branch>
  </decision-tree>
</text>
