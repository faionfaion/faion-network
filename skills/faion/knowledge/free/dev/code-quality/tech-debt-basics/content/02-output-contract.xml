<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Tech Debt Basics Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for register entries.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/tech-debt-basics.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "items"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "severity",
          "location",
          "evidence",
          "weekly_cost",
          "owner"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "deliberate-reckless",
              "deliberate-prudent",
              "inadvertent-reckless",
              "inadvertent-prudent"
            ]
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "location": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "weekly_cost": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "added": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "tdb-001",
  "items": [
    {
      "id": "td-001",
      "type": "inadvertent-reckless",
      "severity": "high",
      "location": "src/cache/",
      "evidence": "#pr2200",
      "weekly_cost": "~3h on-call",
      "owner": "ruslan",
      "added": "2026-04-15"
    }
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "items": [
    {
      "id": "x"
    }
  ]
}
]]></code>
    <note>items entry missing required fields; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-tech-debt-basics.py">schema validator</reference>
</text>
