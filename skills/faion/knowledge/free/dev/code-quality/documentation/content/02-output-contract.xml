<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Documentation Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the doc-spec artefact listing every dir + required headers.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/documentation.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "dirs"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "dirs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "status"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "status": {
            "enum": [
              "present",
              "missing",
              "stale",
              "exempt"
            ]
          },
          "lines": {
            "type": "integer"
          },
          "sections_present": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "doc-spec-001",
  "dirs": [
    {
      "path": "src/auth/",
      "status": "present",
      "lines": 45,
      "sections_present": [
        "title",
        "purpose",
        "files",
        "commands",
        "gotchas"
      ]
    },
    {
      "path": "src/generated/",
      "status": "exempt"
    },
    {
      "path": "src/billing/",
      "status": "missing"
    }
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dirs": [
    {
      "path": "x"
    }
  ]
}
]]></code>
    <note>dir entry missing status; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-documentation.py">schema validator</reference>
</text>
