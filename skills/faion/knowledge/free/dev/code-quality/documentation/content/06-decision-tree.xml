<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Documentation Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Dir kind → pair-or-exempt tree.</summary>

  <decision-tree>
    <root-question id="q-kind">What kind of directory is this?</root-question>
    <branch when="kind == source">
      <conclusion ref="pair-required" verdict="AGENTS.md + CLAUDE.md required"/>
    </branch>
    <branch when="kind == tests">
      <conclusion ref="pair-required" verdict="AGENTS.md required (slim)"/>
    </branch>
    <branch when="kind == generated OR kind == vendored">
      <conclusion ref="pair-required" verdict="exempt"/>
    </branch>
    <branch when="kind == docs">
      <conclusion ref="no-readme-shadowing" verdict="AGENTS.md optional; README acceptable"/>
    </branch>
  </decision-tree>
</text>
