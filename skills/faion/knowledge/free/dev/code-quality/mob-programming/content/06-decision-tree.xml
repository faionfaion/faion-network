<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Mob Programming Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Topic-shape → mob-shape routing.</summary>

  <decision-tree>
    <root-question id="q-topic">Is the topic non-trivial (architectural / cross-cutting)?</root-question>
    <branch when="non_trivial == false">
      <conclusion ref="4-human-cap" verdict="skip mob; use pair or solo"/>
    </branch>
    <branch when="non_trivial == true">
      <question id="q-size">Are 3-4 humans available?</question>
      <branch when="humans &amp;gt;= 3 AND humans &amp;lt;= 4">
        <conclusion ref="facilitator-named" verdict="run mob with facilitator + named agent role"/>
      </branch>
      <branch when="humans &amp;lt; 3">
        <conclusion ref="4-human-cap" verdict="downgrade to pair"/>
      </branch>
      <branch when="humans &amp;gt; 4">
        <conclusion ref="4-human-cap" verdict="split mob; pick the 4 most-needed voices"/>
      </branch>
    </branch>
  </decision-tree>
</text>
