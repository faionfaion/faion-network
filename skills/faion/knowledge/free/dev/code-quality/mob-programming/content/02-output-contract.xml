<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mob Programming Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the session plan + post-session report.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/mob-programming.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "topic",
    "attendees",
    "facilitator",
    "rotation_minutes",
    "agent_role"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "topic": {
      "type": "string"
    },
    "attendees": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "string"
      }
    },
    "facilitator": {
      "type": "string"
    },
    "rotation_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 15
    },
    "agent_role": {
      "enum": [
        "transcriber",
        "researcher",
        "snippet-retriever",
        "none"
      ]
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "decisions_per_hour": {
          "type": "number"
        },
        "rotations": {
          "type": "integer"
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "mob-2026-05-22-billing-refactor",
  "topic": "Billing module decomposition",
  "attendees": [
    "ruslan",
    "anna",
    "petro"
  ],
  "facilitator": "ruslan",
  "rotation_minutes": 10,
  "agent_role": "researcher",
  "decisions": [
    "Extract StripeClient as separate service"
  ],
  "metrics": {
    "decisions_per_hour": 2.0,
    "rotations": 9
  },
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "topic": "x",
  "attendees": [
    "a",
    "b",
    "c",
    "d",
    "e"
  ],
  "facilitator": "",
  "rotation_minutes": 30,
  "agent_role": "primary-navigator"
}
]]></code>
    <note>attendees &amp;gt; 4 (cap violation); rotation_minutes &amp;gt; 15; agent_role not in enum; empty facilitator; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-mob-programming.py">schema validator</reference>
</text>
