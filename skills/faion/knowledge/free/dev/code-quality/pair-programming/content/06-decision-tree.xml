<text id="06-decision-tree" title="Pair Programming Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Topic shape → style picker.</summary>

  <decision-tree>
    <root-question id="q-shape">What is the topic shape?</root-question>
    <branch when="shape == TDD">
      <conclusion ref="named-style" verdict="ping-pong"/>
    </branch>
    <branch when="shape == debug">
      <conclusion ref="named-style" verdict="driver-navigator"/>
    </branch>
    <branch when="shape == teaching">
      <conclusion ref="named-style" verdict="strong-style"/>
    </branch>
    <branch when="shape == codebase-tour">
      <conclusion ref="named-style" verdict="tour-guide"/>
    </branch>
  </decision-tree>
</text>
