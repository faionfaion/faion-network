<text id="06-decision-tree" title="Code Decomposition Patterns Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Pattern picker. Input observables: has_io, has_ui, pure_logic_only, mostly_constants, types_only.</summary>

  <decision-tree>
    <root-question id="q-has-io">Does the file perform I/O (network, disk, db, env)?</root-question>
    <branch when="has_io == true">
      <conclusion ref="pattern-match-first" verdict="extract-service"/>
    </branch>
    <branch when="has_io == false">
      <question id="q-has-ui">Does the file render UI?</question>
      <branch when="has_ui == true">
        <conclusion ref="pattern-match-first" verdict="extract-component"/>
      </branch>
      <branch when="has_ui == false">
        <question id="q-mostly-constants">Is &amp;gt;60% of the file constants / lookup tables?</question>
        <branch when="mostly_constants == true">
          <conclusion ref="pattern-match-first" verdict="extract-configuration"/>
        </branch>
        <branch when="mostly_constants == false">
          <question id="q-types-only">Is the file types-only (no runtime code)?</question>
          <branch when="types_only == true">
            <conclusion ref="pattern-match-first" verdict="extract-types"/>
          </branch>
          <branch when="types_only == false">
            <conclusion ref="pattern-match-first" verdict="extract-module"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="billing-file-extract-service">Worked path through the tree.</example>
</text>
