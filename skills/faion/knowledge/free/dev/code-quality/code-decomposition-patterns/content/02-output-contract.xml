<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Decomposition Patterns Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the move-list artefact a refactor agent or developer executes. Each entry pins source range, destination, and rationale.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/code-decomposition-patterns.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "pattern",
    "moves"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "pattern": {
      "enum": [
        "extract-service",
        "extract-component",
        "extract-module",
        "extract-configuration",
        "extract-types"
      ]
    },
    "moves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "src",
          "lines",
          "dst",
          "symbol"
        ],
        "properties": {
          "src": {
            "type": "string"
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "dst": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "cdp-001",
  "pattern": "extract-service",
  "moves": [
    {
      "src": "src/billing.py",
      "lines": [
        120,
        240
      ],
      "dst": "src/billing/stripe_client.py",
      "symbol": "StripeClient"
    }
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pattern": "split",
  "moves": [
    {
      "src": "x.py",
      "dst": "y.py"
    }
  ]
}
]]></code>
    <note>pattern 'split' is not in the closed enum; moves entry missing lines + symbol; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="templates/pattern-guard.sh">guard that runs before the move-list is executed</reference>
  <reference path="scripts/validate-code-decomposition-patterns.py">schema validator</reference>
</text>
