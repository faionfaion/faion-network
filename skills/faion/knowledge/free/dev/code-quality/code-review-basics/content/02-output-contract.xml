<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Review Basics Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the 5-item checklist artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/code-review-basics.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "pr_ref",
    "checklist",
    "verdict"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "pr_ref": {
      "type": "string"
    },
    "checklist": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "question",
          "answer"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "answer": {
            "enum": [
              "yes",
              "no",
              "na"
            ]
          },
          "comment_label": {
            "enum": [
              "praise",
              "nitpick",
              "suggestion",
              "issue",
              "question"
            ]
          },
          "body": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "enum": [
        "approve-pending-human",
        "request-changes",
        "block-size"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "crb-001",
  "pr_ref": "pr/123",
  "checklist": [
    {
      "question": "Does the PR description explain what + why?",
      "answer": "yes"
    },
    {
      "question": "Do tests cover the new behaviour?",
      "answer": "no",
      "comment_label": "issue",
      "body": "No test for the empty-input branch."
    },
    {
      "question": "Are public API changes backward-compatible?",
      "answer": "yes"
    },
    {
      "question": "Any obvious security implication?",
      "answer": "no"
    },
    {
      "question": "Is the diff under 400 lines?",
      "answer": "yes"
    }
  ],
  "verdict": "request-changes",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pr_ref": "x",
  "checklist": [],
  "verdict": "approve-pending-human"
}
]]></code>
    <note>checklist must have exactly 5 items; verdict approve incompatible with empty checklist.</note>
  </example>

  <reference path="scripts/validate-code-review-basics.py">schema validator</reference>
</text>
