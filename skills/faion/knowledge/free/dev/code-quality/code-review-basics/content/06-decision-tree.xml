<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Code Review Basics Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Size + checklist → verdict tree.</summary>

  <decision-tree>
    <root-question id="q-size">Is PR diff (excluding tests + lockfiles) ≤ 400 lines?</root-question>
    <branch when="size &amp;gt; 400">
      <conclusion ref="size-cap-400-lines" verdict="block-size"/>
    </branch>
    <branch when="size &amp;lt;= 400">
      <question id="q-any-no">Does any checklist answer == 'no'?</question>
      <branch when="any_no == true">
        <conclusion ref="conventional-labels" verdict="request-changes"/>
      </branch>
      <branch when="any_no == false">
        <conclusion ref="human-approver" verdict="approve-pending-human"/>
      </branch>
    </branch>
  </decision-tree>
</text>
