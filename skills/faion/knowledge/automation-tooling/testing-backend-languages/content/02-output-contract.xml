<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Backend Testing Across Languages Output Contract" version="2.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the code artefact this methodology produces. Validator enforces required keys + per-field constraints + forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/testing-backend-languages.json",
  "type": "object",
  "required": [
    "language",
    "runner",
    "scope_discipline_ok",
    "mock_shallowness_ok",
    "ci_lt_10min"
  ],
  "properties": {
    "language": {
      "enum": [
        "ruby_rails",
        "laravel",
        "spring",
        "dotnet",
        "rust"
      ]
    },
    "runner": {
      "enum": [
        "rspec",
        "pest",
        "junit5",
        "xunit",
        "cargo_test"
      ]
    },
    "scope_discipline_ok": {
      "type": "boolean",
      "const": true
    },
    "mock_shallowness_ok": {
      "type": "boolean",
      "const": true
    },
    "ci_lt_10min": {
      "type": "boolean",
      "const": true
    },
    "uses_factory_bot": {
      "type": "boolean"
    },
    "uses_refresh_db": {
      "type": "boolean"
    },
    "spring_uses_slices": {
      "type": "boolean"
    },
    "dotnet_uses_webfactory": {
      "type": "boolean"
    },
    "async_uses_tokio_test": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "language": "spring",
  "runner": "junit5",
  "scope_discipline_ok": true,
  "mock_shallowness_ok": true,
  "ci_lt_10min": true,
  "spring_uses_slices": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "language": "spring",
  "runner": "junit5",
  "spring_uses_slices": false
}
]]></code>
    <note>Spring with @SpringBootTest everywhere; mocks 4 levels deep; CI &gt; 10min.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f-spring-boot-test-default">
      <description>@SpringBootTest on every test class by default</description>
      <why>Violates spring-slice-not-full-context; cold startup explodes test time.</why>
    </pattern>
    <pattern id="f-asyncfn-bare-test">
      <description>#[test] over async fn (without tokio::test)</description>
      <why>Violates rust-tokio-test-for-async; future never polled.</why>
    </pattern>
    <pattern id="f-deep-mocks">
      <description>Mock setup chains 4+ levels deep</description>
      <why>Violates mock-shallowness; freezes refactor; tests lie when collaborators change.</why>
    </pattern>
  </section>

  <reference path="scripts/validate-testing-backend-languages.py">Validator script</reference>
</text>
