<text id="02-output-contract" title="Frontend Component Practices Output Contract" version="2.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the code artefact this methodology produces. Validator enforces required keys + per-field constraints + forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/practices-frontend-components.json",
  "type": "object",
  "required": [
    "component_name",
    "framework",
    "typed_props",
    "a11y_attrs_present",
    "style_scope"
  ],
  "properties": {
    "component_name": {
      "type": "string",
      "pattern": "^[A-Z][a-zA-Z0-9]+$"
    },
    "framework": {
      "enum": [
        "react",
        "vue",
        "svelte",
        "angular"
      ]
    },
    "typed_props": {
      "type": "boolean",
      "const": true
    },
    "a11y_attrs_present": {
      "type": "boolean",
      "const": true
    },
    "style_scope": {
      "enum": [
        "css-modules",
        "scoped",
        "styled-components",
        "tailwind"
      ]
    },
    "controlled_mode": {
      "enum": [
        "controlled",
        "uncontrolled",
        "stateless"
      ]
    },
    "lines": {
      "type": "integer",
      "maximum": 150
    },
    "has_test": {
      "type": "boolean"
    },
    "has_story": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "component_name": "OrderRow",
  "framework": "react",
  "typed_props": true,
  "a11y_attrs_present": true,
  "style_scope": "css-modules",
  "controlled_mode": "stateless",
  "lines": 64,
  "has_test": true,
  "has_story": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "component_name": "order_row",
  "framework": "react",
  "typed_props": false,
  "lines": 312
}
]]></code>
    <note>Component name must be PascalCase; typed_props false; lines exceed 150; a11y_attrs_present + style_scope missing.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f-spread-on-dom">
      <description>&lt;div {...rest} /&gt; spreading arbitrary props onto a DOM node</description>
      <why>Violates typed-props; leaks framework-specific keys onto HTML.</why>
    </pattern>
    <pattern id="f-global-tag-selector">
      <description>button { color: red } inside a component-local style block</description>
      <why>Violates css-scoping; leaks across the app.</why>
    </pattern>
    <pattern id="f-onclick-no-keyboard">
      <description>&lt;div onClick={...}&gt; with no role/onKeyDown</description>
      <why>Violates a11y-from-day-one; keyboard-only users can't activate.</why>
    </pattern>
  </section>

  <reference path="scripts/validate-practices-frontend-components.py">Validator script</reference>
</text>
