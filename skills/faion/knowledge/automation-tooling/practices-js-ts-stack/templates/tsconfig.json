{
  "__faion_header__": {
    "purpose": "Strict TS config for ESM Node.js + library output",
    "consumes": "input artefacts described in AGENTS.md ## Prerequisites",
    "produces": "artefact conforming to content/02-output-contract.xml for practices-js-ts-stack",
    "depends_on": "content/01-core-rules.xml",
    "token_budget_impact": "~200-1200 tokens when loaded as context"
  },
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts"
  ]
}
