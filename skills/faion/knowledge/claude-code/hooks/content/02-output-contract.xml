<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Claude Code Hooks Reference Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/hooks.json",
  "type": "object",
  "required": ["event", "matcher", "script_path", "timeout_sec"],
  "properties": {
    "event": {"enum": ["PreToolUse", "PostToolUse", "SessionStart", "Stop"]},
    "matcher": {"type": "string"},
    "script_path": {"type": "string"},
    "timeout_sec": {"type": "integer", "minimum": 1, "maximum": 60},
    "reversible": {"type": "boolean", "const": true},
    "audit_log_path": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "event": "PreToolUse",
  "matcher": "Bash",
  "script_path": ".claude/hooks/block-dangerous-bash.sh",
  "timeout_sec": 5,
  "reversible": true,
  "audit_log_path": ".claude/logs/hook-audit.jsonl"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "event": "PreToolUse"
}
]]></code>
    <note>Missing matcher, script_path, timeout_sec.</note>
  </example>

  <reference path="scripts/validate-hooks.py">Validator script</reference>
</text>
