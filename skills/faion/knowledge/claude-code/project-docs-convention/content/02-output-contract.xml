<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Project Documentation Convention Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the spec artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/project-docs-convention.json",
  "type": "object",
  "required": ["repo_root", "dirs", "violations"],
  "properties": {
    "repo_root": {"type": "string"},
    "audited_at": {"type": "string", "format": "date"},
    "dirs": {"type": "array", "items": {"type": "object", "required": ["path", "has_claude_md", "has_agents_md", "agents_md_lines", "verdict"], "properties": {"path": {"type": "string"}, "has_claude_md": {"type": "boolean"}, "has_agents_md": {"type": "boolean"}, "agents_md_lines": {"type": "integer"}, "verdict": {"enum": ["ok", "create", "trim", "split"]}}}},
    "violations": {"type": "array", "items": {"type": "string"}}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "repo_root": "/home/nero/workspace/projects/faion-net/faion-network",
  "audited_at": "2026-05-22",
  "dirs": [
    {
      "path": "skills/faion/knowledge/free/dev/code-quality",
      "has_claude_md": true,
      "has_agents_md": true,
      "agents_md_lines": 42,
      "verdict": "ok"
    },
    {
      "path": "skills/faion/knowledge/free/dev/legacy-prototype",
      "has_claude_md": false,
      "has_agents_md": false,
      "agents_md_lines": 0,
      "verdict": "create"
    }
  ],
  "violations": []
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dirs": []
}
]]></code>
    <note>Missing repo_root + violations.</note>
  </example>

  <reference path="scripts/validate-project-docs-convention.py">Validator script</reference>
</text>
