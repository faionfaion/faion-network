<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="mcp-resource-vs-tool-vs-prompt Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for mcp-resource-vs-tool-vs-prompt. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "mcp-resource-vs-tool-vs-prompt"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["classifications"],
      "properties": {
        "classifications": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["side_effect", "user_facing", "llm_reasons_on_result"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "mcp-resource-vs-tool-vs-prompt",
  "version": "2.0.0",
  "decision": {"classifications": "TODO"},
  "drivers": {"side_effect": "val", "user_facing": "val", "llm_reasons_on_result": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "mcp-resource-vs-tool-vs-prompt",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "classifications".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
