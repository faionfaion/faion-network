# purpose: env block to drop into systemd/.env for LangSmith-traced LangChain app
# consumes: validated decision-record
# produces: live tracing
# depends-on: LANGCHAIN_API_KEY in secret store
# token-budget-impact: 0 (runtime config, not loaded by agent)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=prod-bot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=  # injected by 1Password / vault; never commit
LANGCHAIN_CALLBACKS_BACKGROUND=true
LANGCHAIN_TRACING_SAMPLE_RATE=1.0
