<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llamaindex-indexes-queries Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llamaindex-indexes-queries. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llamaindex-indexes-queries"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["index_type", "query_engine", "response_synthesizer", "retriever"],
      "properties": {
        "index_type": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "query_engine": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "response_synthesizer": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "retriever": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["data_shape", "hop_depth_max", "query_types"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llamaindex-indexes-queries",
  "version": "2.0.0",
  "decision": {"index_type": "TODO", "query_engine": "TODO", "response_synthesizer": "TODO", "retriever": "TODO"},
  "drivers": {"data_shape": "val", "hop_depth_max": "val", "query_types": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llamaindex-indexes-queries",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "index_type", "query_engine", "response_synthesizer", "retriever".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
