<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Autonomous Agents Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>The autonomous-agent spec schema.</summary>

  <output-contract>
    <required>
      <field name="spec_id" type="string" required="true"/>
      <field name="agent_name" type="string" required="true"/>
      <field name="pattern" type="enum" required="true">react | plan-and-execute | reflexion</field>
      <field name="subagent_roles" type="object" required="true">{planner?, executor, verifier, critic?} with model per role</field>
      <field name="caps" type="object" required="true">{max_iterations, max_attempts?, max_steps?}</field>
      <field name="terminal_condition" type="string" required="true">testable</field>
      <field name="idempotency_class_per_tool" type="object" required="true">tool_name → idempotent | dedup-keyed | non-idempotent</field>
      <field name="sandbox_required" type="bool" required="true"/>
      <field name="human_checkpoint_per_action" type="object" required="true">tool_name → required | not-required</field>
      <field name="owner" type="string" required="true"/>
      <field name="version" type="string" required="true">semver</field>
      <field name="produced_at" type="datetime" required="true"/>
    </required>
    <forbidden>
      <pattern id="f1">any tool listed as non-idempotent AND human_checkpoint_per_action[tool] = not-required</pattern>
      <pattern id="f2">caps.max_iterations missing or &gt; 50</pattern>
      <pattern id="f3">sandbox_required=true but agent has no sandbox URL configured</pattern>
      <pattern id="f4">terminal_condition is "agent decides"</pattern>
      <pattern id="f5">subagent_roles.executor missing</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Substitute opus → sonnet for cost when role doesn't require deep reasoning.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>
</text>
