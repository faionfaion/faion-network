<text id="02-output-contract" title="PostTool Hook Self-Correction Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the hook-config artefact.</summary>

  <output-contract produces="config">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "posttool-hook-self-correction"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["hooks", "retry_max", "exempt_globs", "settings_json_path"],
      "properties": {
        "hooks": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["matcher", "glob", "command", "timeout_seconds"], "properties": {"timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 30}}}},
        "retry_max": {"type": "integer", "minimum": 1, "maximum": 10},
        "exempt_globs": {"type": "array"},
        "settings_json_path": {"type": "string"}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["language", "runtime_per_file", "validators_available"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Python ruff hook"><![CDATA[
{
  "slug": "posttool-hook-self-correction",
  "version": "2.0.0",
  "decision": {
    "hooks": [{"matcher": "Write|Edit", "glob": "**/*.py", "command": "ruff check --quiet $CLAUDE_FILE_PATH", "timeout_seconds": 5}],
    "retry_max": 3,
    "exempt_globs": ["migrations/**", "**/__init__.py"],
    "settings_json_path": ".claude/settings.json"
  },
  "drivers": {"language": "python", "runtime_per_file": 1, "validators_available": ["ruff"]},
  "audit": {"rule_refs": ["r1-scope-per-file", "r2-nonzero-exit", "r3-timeout-cap", "r-python-ruff"]}
}
]]></example>

    <example valid="false" title="Repo-wide validator + no retry cap"><![CDATA[
{
  "slug": "posttool-hook-self-correction",
  "version": "2.0.0",
  "decision": {"hooks": [{"matcher": "Write|Edit", "glob": "**", "command": "ruff check .", "timeout_seconds": 0}], "retry_max": 0, "exempt_globs": [], "settings_json_path": ".claude/settings.json"},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>command runs repo-wide instead of scoping via $CLAUDE_FILE_PATH (r1).</violation>
      <violation>timeout_seconds must be 1..30.</violation>
      <violation>retry_max must be &gt;= 1.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every hook command references $CLAUDE_FILE_PATH (or equivalent) for file scoping.</item>
      <item>retry_max set; exempt_globs explicit.</item>
    </list>
  </section>

  <reference path="templates/settings-json-snippet.json">Settings.json fragment.</reference>
  <reference path="scripts/validate-posttool-hook-self-correction.py">Validator.</reference>
</text>
