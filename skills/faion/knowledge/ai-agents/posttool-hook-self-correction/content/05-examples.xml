<?xml version="1.0" encoding="UTF-8"?>
<text id="05-examples" title="PostTool Hook Self-Correction Worked Examples" version="2.0.0" est_tokens="600" depth="recommended">
  <summary>Ruff (python), tsc+eslint (typescript), pytest -x (test files).</summary>

  <example type="good">
    <note>Python ruff hook (r1, r2, r3, r-python-ruff).</note>
    <code lang="json"><![CDATA[
{
  "hooks": {
    "PostToolUse": [{
      "matcher": "Write|Edit",
      "hooks": [{
        "type": "command",
        "command": "case \"$CLAUDE_FILE_PATH\" in *.py) ruff check --quiet \"$CLAUDE_FILE_PATH\" ;; esac",
        "timeout_seconds": 5
      }]
    }]
  }
}
]]></code>
  </example>

  <example type="good">
    <note>TypeScript tsc + eslint chained (r-typescript-tsc-eslint).</note>
    <code lang="json"><![CDATA[
{
  "command": "case \"$CLAUDE_FILE_PATH\" in *.ts|*.tsx) tsc --noEmit && eslint --max-warnings 0 \"$CLAUDE_FILE_PATH\" ;; esac",
  "timeout_seconds": 10
}
]]></code>
  </example>

  <example type="bad">
    <note>Bad — no file scope, no timeout (r1, r3 violations).</note>
    <code lang="json"><![CDATA[
{"command": "ruff check .", "timeout_seconds": 0}
]]></code>
  </example>
</text>
