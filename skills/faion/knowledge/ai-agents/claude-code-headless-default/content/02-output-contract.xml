<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Claude Code Headless Default Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>CLI-vs-SDK decision record schema.</summary>

  <output-contract>
    <required>
      <field name="decision_id" type="string" required="true"/>
      <field name="task_brief" type="string" required="true"/>
      <field name="chosen_runtime" type="enum" required="true">claude-code-headless | agent-sdk</field>
      <field name="switch_trigger" type="enum" required="false">non-coding-domain | custom-tools-beyond-mcp | inner-loop-control | saas-cannot-shell-out</field>
      <field name="invocation_argv" type="list" required="true">canonical claude -p arguments when chosen_runtime=claude-code-headless</field>
      <field name="allowed_tools" type="list" required="true"/>
      <field name="max_turns" type="integer" required="true">≥1</field>
      <field name="output_format" type="string" required="true">stream-json (default)</field>
      <field name="owner" type="string" required="true"/>
      <field name="version" type="string" required="true">semver</field>
      <field name="produced_at" type="datetime" required="true"/>
    </required>
    <forbidden>
      <pattern id="f1">chosen_runtime=agent-sdk AND switch_trigger missing</pattern>
      <pattern id="f2">chosen_runtime=claude-code-headless AND -p flag missing from invocation_argv</pattern>
      <pattern id="f3">allowed_tools is "*" (must be enumerated for safety)</pattern>
      <pattern id="f4">max_turns missing or &gt; 50</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Substitute output_format with json (single blob) only when orchestrator cannot stream.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>
</text>
