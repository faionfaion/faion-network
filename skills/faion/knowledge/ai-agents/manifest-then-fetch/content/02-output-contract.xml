<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="manifest-then-fetch Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for manifest-then-fetch. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "manifest-then-fetch"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["wrapped_tools", "manifest_max_tokens", "store_backend", "retention_ttl_seconds", "preview_strategy"],
      "properties": {
        "wrapped_tools": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "manifest_max_tokens": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "store_backend": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "retention_ttl_seconds": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "preview_strategy": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["tool_outputs_avg_bytes", "store_backend", "sensitivity"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "manifest-then-fetch",
  "version": "2.0.0",
  "decision": {"wrapped_tools": "TODO", "manifest_max_tokens": "TODO", "store_backend": "TODO", "retention_ttl_seconds": "TODO", "preview_strategy": "TODO"},
  "drivers": {"tool_outputs_avg_bytes": "val", "store_backend": "val", "sensitivity": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "manifest-then-fetch",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "wrapped_tools", "manifest_max_tokens", "store_backend", "retention_ttl_seconds", "preview_strategy".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
