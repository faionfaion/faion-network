<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Feature Brief Extension Pack Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Extended brief schema covering the four AI-specific sections.</summary>

  <output-contract>
    <required>
      <field name="brief_id" type="string" required="true"/>
      <field name="base_prd_ref" type="string" required="true">URL or path</field>
      <field name="model_section" type="object" required="true">{chosen_model, version, provider, fallback_chain[], deprecation_window_months}</field>
      <field name="eval_section" type="object" required="true">{golden_set_version, n_examples, threshold_pass_rate, ci_width, eval_method_ref}</field>
      <field name="policy_section" type="object" required="true">{policy_per_risk{factual_claim_with_source, numerical_summary, legal_implication}, audit_log_path}</field>
      <field name="cost_section" type="object" required="true">{per_request_soft_cap_usd, per_day_hard_cap_usd, outlier_alert_threshold_usd, billing_owner}</field>
      <field name="reviewers" type="object" required="true">{product, engineering, finance, compliance?}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="produced_at" type="datetime" required="true"/>
    </required>
    <forbidden>
      <pattern id="f1">any section contains placeholder strings (lorem ipsum, &lt;fill&gt;)</pattern>
      <pattern id="f2">model_section.chosen_model is "latest" or "newest"</pattern>
      <pattern id="f3">eval_section.threshold_pass_rate not numeric</pattern>
      <pattern id="f4">policy_section missing any of the three named risk classes</pattern>
      <pattern id="f5">cost_section caps missing or per_request_soft_cap &gt; per_day_hard_cap</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Default ci_width to 0.05.</transformation>
      <transformation>Default deprecation_window_months to 12.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>
</text>
