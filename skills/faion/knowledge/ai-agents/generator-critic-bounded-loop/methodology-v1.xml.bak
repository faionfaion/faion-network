<methodology slug="generator-critic-bounded-loop">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>ai-agents</domain>
    <summary>Wrap generation in bounded Generator → Critic → Generator loops. Exit on veto, plateau, or hard cap of 3 iterations. Use cheap models for rubric criticism.</summary>
    <tags>
      <tag>agents</tag>
      <tag>reflection</tag>
      <tag>bounded-loops</tag>
      <tag>self-correction</tag>
      <tag>cost-optimization</tag>
