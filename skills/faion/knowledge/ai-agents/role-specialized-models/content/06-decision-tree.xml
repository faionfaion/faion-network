<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Role-Specialized Models Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (role_count, monthly_cost_target, quality_floor)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="role_count &gt;= 3">
            <conclusion ref="r1-competence-floor">Build role-map per competence floor with fallback chain.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="skip-this-methodology">Single/dual role — routing complexity exceeds savings.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → skip-this-methodology
    </example>
  </decision-tree>
</text>
