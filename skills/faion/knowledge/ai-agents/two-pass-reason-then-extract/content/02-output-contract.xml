<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Two-Pass: Free-Form Reasoning Then Structured Extraction Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/two-pass-reason-then-extract.json",
  "type": "object",
  "required": ["pass1_model", "pass1_thinking", "pass2_model", "schema_uri", "ab_baseline"],
  "properties": {
    "pass1_model": {"type": "string"},
    "pass1_thinking": {"type": "object", "properties": {"type": {"const": "enabled"}, "budget_tokens": {"type": "integer", "minimum": 1024}}},
    "pass2_model": {"type": "string"},
    "pass2_temperature": {"type": "number", "minimum": 0, "maximum": 0.5},
    "schema_uri": {"type": "string", "format": "uri-reference"},
    "transcript_cap_tokens": {"type": "integer", "minimum": 512, "maximum": 32768},
    "ab_baseline": {"type": "object", "required": ["single_pass_accuracy", "two_pass_accuracy", "delta_pct", "n"], "properties": {"single_pass_accuracy": {"type": "number"}, "two_pass_accuracy": {"type": "number"}, "delta_pct": {"type": "number"}, "n": {"type": "integer"}}}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pass1_model": "claude-opus-4-7",
  "pass1_thinking": {
    "type": "enabled",
    "budget_tokens": 16000
  },
  "pass2_model": "claude-haiku-4-7",
  "pass2_temperature": 0.0,
  "schema_uri": "schemas/verdict.json",
  "transcript_cap_tokens": 8000,
  "ab_baseline": {
    "single_pass_accuracy": 0.74,
    "two_pass_accuracy": 0.86,
    "delta_pct": 12.0,
    "n": 50
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pass1_model": "haiku"
}
]]></code>
    <note>Missing pass2_model, schema_uri, ab_baseline; pass1 is a cheap model defeating the whole pattern.</note>
  </example>

  <reference path="scripts/validate-two-pass-reason-then-extract.py">Validator script</reference>
</text>
