<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Array Items Wrapper Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>The envelope schema every variable-cardinality extraction returns.</summary>

  <output-contract>
    <required>
      <field name="items" type="list" required="true">list of Entity (per-extraction type)</field>
      <field name="total_found" type="integer" required="true">model's belief about source cardinality; ≥ len(items)</field>
      <field name="truncated" type="bool" required="true">total_found > len(items)</field>
    </required>

    <forbidden>
      <pattern id="f1">top-level value is an array (not an object)</pattern>
      <pattern id="f2">items is null instead of []</pattern>
      <pattern id="f3">total_found is null or omitted</pattern>
      <pattern id="f4">truncated=false AND total_found &gt; len(items)</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Cap items[] at max_items, mark truncated=true, preserve total_found.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/output-schema.json"/>
  </output-contract>

  <section title="Self-check">
    <list>
      <item>top-level is object</item>
      <item>items present (possibly empty)</item>
      <item>total_found ≥ len(items)</item>
      <item>truncated consistent with total_found and len(items)</item>
    </list>
  </section>
</text>
