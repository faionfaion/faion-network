<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Record-Replay Debugging Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (failure_reproduction_difficulty, production_failures_per_month, tool_count)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="failure_reproduction_difficulty == &apos;high&apos;">
            <conclusion ref="r1-record-all-calls">Enable full recording on prod; replay on developer machines.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="r5-replay-in-ci">Capture one canonical recording; replay as CI integration test.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → r5-replay-in-ci
    </example>
  </decision-tree>
</text>
