<text id="05-examples" title="Record-Replay Debugging Worked Example" version="2.0.0" est_tokens="600" depth="recommended">
  <summary>Canonical happy-path spec emitted from the smoke-test input.</summary>

  <example type="good">
    <note>Smoke-test driver values flow through the decision tree to the default leaf (r1-record-all-calls). The emitted JSON satisfies the schema in 02-output-contract.xml.</note>
    <code lang="json"><![CDATA[
{
  "slug": "record-replay-debugging",
  "version": "2.0.0",
  "decision": {
    "record_mode": "value",
    "replay_mode": "value",
    "redaction_policy": "value",
    "ci_recordings": "value"
  },
  "drivers": {
    "failure_reproduction_difficulty": "v",
    "production_failures_per_month": "v",
    "tool_count": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-record-all-calls"
    ]
  }
}
]]></code>
  </example>

  <example type="bad">
    <note>Bad — empty decision and audit; validator fails fast.</note>
    <code lang="json"><![CDATA[
{
  "slug": "record-replay-debugging",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></code>
  </example>
</text>
