<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Reasoning-First Architectures Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the reasoning-first-architectures spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "reasoning-first-architectures"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "architecture",
        "max_turns",
        "thinking_budget_tokens",
        "replan_trigger"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "task_complexity",
        "branching",
        "error_recovery_needed",
        "horizon"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "reasoning-first-architectures",
  "version": "2.0.0",
  "decision": {
    "architecture": "value",
    "max_turns": "value",
    "thinking_budget_tokens": "value",
    "replan_trigger": "value"
  },
  "drivers": {
    "task_complexity": "v",
    "branching": "v",
    "error_recovery_needed": "v",
    "horizon": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-thought-before-action"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "reasoning-first-architectures",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: architecture, max_turns, thinking_budget_tokens, replan_trigger.</violation>
      <violation>drivers missing required keys: task_complexity, branching, error_recovery_needed, horizon.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-reasoning-first-architectures.py">Schema validator.</reference>
</text>
