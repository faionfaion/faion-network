<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llamaindex-sql-query Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llamaindex-sql-query. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llamaindex-sql-query"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["dsn", "include_tables", "use_object_index", "max_returned_rows", "read_only"],
      "properties": {
        "dsn": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "include_tables": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "use_object_index": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "max_returned_rows": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "read_only": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["table_count", "schema_size_chars", "read_only_required"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llamaindex-sql-query",
  "version": "2.0.0",
  "decision": {"dsn": "TODO", "include_tables": "TODO", "use_object_index": "TODO", "max_returned_rows": "TODO", "read_only": "TODO"},
  "drivers": {"table_count": "val", "schema_size_chars": "val", "read_only_required": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llamaindex-sql-query",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "dsn", "include_tables", "use_object_index", "max_returned_rows", "read_only".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
