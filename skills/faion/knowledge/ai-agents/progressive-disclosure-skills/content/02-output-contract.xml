<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Progressive Disclosure Skills Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the progressive-disclosure-skills spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "progressive-disclosure-skills"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "frontmatter_token_budget",
        "body_token_budget",
        "references_layout",
        "trigger_set"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "body_tokens",
        "ref_count",
        "trigger_precision",
        "session_token_cap"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "progressive-disclosure-skills",
  "version": "2.0.0",
  "decision": {
    "frontmatter_token_budget": "value",
    "body_token_budget": "value",
    "references_layout": "value",
    "trigger_set": "value"
  },
  "drivers": {
    "body_tokens": "v",
    "ref_count": "v",
    "trigger_precision": "v",
    "session_token_cap": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-frontmatter-bounded"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "progressive-disclosure-skills",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: frontmatter_token_budget, body_token_budget, references_layout, trigger_set.</violation>
      <violation>drivers missing required keys: body_tokens, ref_count, trigger_precision, session_token_cap.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-progressive-disclosure-skills.py">Schema validator.</reference>
</text>
