<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cheap-Guardrail Tripwire Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>The verdict schema returned by the guardrail call.</summary>

  <output-contract>
    <required>
      <field name="tripwire_triggered" type="bool" required="true"/>
      <field name="reason" type="enum" required="true">off-topic | jailbreak_attempt | abuse | spam | none</field>
      <field name="confidence" type="number" required="true">0..1</field>
    </required>
    <forbidden>
      <pattern id="f1">tripwire_triggered=true AND reason="none"</pattern>
      <pattern id="f2">confidence outside [0,1]</pattern>
      <pattern id="f3">reason is free string instead of enum</pattern>
      <pattern id="f4">extra fields present (strict additionalProperties=false)</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Round confidence to 2 decimals.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json"/>
  </output-contract>

  <section title="Self-check">
    <list>
      <item>Schema validates in strict mode</item>
      <item>reason consistent with tripwire_triggered</item>
      <item>confidence in [0,1]</item>
    </list>
  </section>
</text>
