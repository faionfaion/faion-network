<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Schema Version Pinning Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (schema_change_rate_per_quarter, agent_deploys, recorded_calls_count)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="schema_change_rate_per_quarter == 0">
            <conclusion ref="skip-this-methodology">No drift; pinning overhead exceeds benefit.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="r1-semver-in-schema">Pin ~major.minor; ship breaking changes with migration + deprecation.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → r1-semver-in-schema
    </example>
  </decision-tree>
</text>
