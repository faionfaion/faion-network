<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Schema Version Pinning Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the schema-version-pinning spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "schema-version-pinning"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "pin_range",
        "migration_script_path",
        "deprecation_window_days"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "schema_change_rate_per_quarter",
        "agent_deploys",
        "recorded_calls_count"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "schema-version-pinning",
  "version": "2.0.0",
  "decision": {
    "pin_range": "value",
    "migration_script_path": "value",
    "deprecation_window_days": "value"
  },
  "drivers": {
    "schema_change_rate_per_quarter": "v",
    "agent_deploys": "v",
    "recorded_calls_count": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-semver-in-schema"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "schema-version-pinning",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: pin_range, migration_script_path, deprecation_window_days.</violation>
      <violation>drivers missing required keys: schema_change_rate_per_quarter, agent_deploys, recorded_calls_count.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-schema-version-pinning.py">Schema validator.</reference>
</text>
