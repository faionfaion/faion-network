<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Rerank Before Reasoning Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (top_1_miss_rate, latency_budget_ms, context_budget_tokens)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="top_1_miss_rate &gt; 0.2 and k_retrieved &gt; k_final * 3">
            <conclusion ref="r1-rerank-required">Insert cross-encoder reranker stage.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="skip-this-methodology">Embed-only suffices; rerank ROI not justified.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → skip-this-methodology
    </example>
  </decision-tree>
</text>
