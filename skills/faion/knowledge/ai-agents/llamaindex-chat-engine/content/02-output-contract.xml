<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="llamaindex-chat-engine Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>Decision-record schema for llamaindex-chat-engine. Every emitted record must validate against this JSON schema; both valid and invalid examples below.</summary>

  <output-contract produces="decision-record">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "llamaindex-chat-engine"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["chat_mode", "token_limit", "streaming", "context_prompt"],
      "properties": {
        "chat_mode": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "token_limit": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "streaming": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]},
        "context_prompt": {"type": ["string", "integer", "number", "boolean", "array", "object", "null"]}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["follow_up_complexity", "tool_use", "latency_target_ms"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9]+$"}}}
    }
  }
}
]]></schema>
    <example valid="true" title="Canonical happy-path"><![CDATA[
{
  "slug": "llamaindex-chat-engine",
  "version": "2.0.0",
  "decision": {"chat_mode": "TODO", "token_limit": "TODO", "streaming": "TODO", "context_prompt": "TODO"},
  "drivers": {"follow_up_complexity": "val", "tool_use": "val", "latency_target_ms": "val"},
  "audit": {"rule_refs": ["r1"]}
}
]]></example>
    <example valid="false" title="Empty decision + empty rule_refs"><![CDATA[
{
  "slug": "llamaindex-chat-engine",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>
    <example-violations>
      <violation>decision missing required keys: "chat_mode", "token_limit", "streaming", "context_prompt".</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision contains all required keys.</item>
      <item>drivers contains all listed driver fields.</item>
      <item>audit.rule_refs cites ≥1 rule from 01-core-rules.xml.</item>
    </list>
  </section>
</text>
