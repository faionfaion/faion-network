<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Verb-Object Tool Naming with Namespace Prefix Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the rubric artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/verb-object-tool-naming.json",
  "type": "object",
  "required": ["catalog_version", "audited_at", "tools"],
  "properties": {
    "catalog_version": {"type": "string"},
    "audited_at": {"type": "string", "format": "date"},
    "tools": {"type": "array", "items": {"type": "object", "required": ["name", "checks", "verdict"], "properties": {"name": {"type": "string"}, "checks": {"type": "object", "required": ["verb_object", "snake_case", "namespaced", "token_count_ok", "schema_aligned"], "additionalProperties": {"type": "integer", "minimum": 0, "maximum": 1}}, "verdict": {"enum": ["ok", "rename", "split"]}, "proposed_name": {"type": "string"}}}}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "catalog_version": "1.4.2",
  "audited_at": "2026-05-22",
  "tools": [
    {
      "name": "github_search_issues",
      "checks": {
        "verb_object": 1,
        "snake_case": 1,
        "namespaced": 1,
        "token_count_ok": 1,
        "schema_aligned": 1
      },
      "verdict": "ok"
    },
    {
      "name": "manage",
      "checks": {
        "verb_object": 0,
        "snake_case": 1,
        "namespaced": 0,
        "token_count_ok": 1,
        "schema_aligned": 0
      },
      "verdict": "rename",
      "proposed_name": "github_update_repo_settings"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tools": [
    {
      "name": "X"
    }
  ]
}
]]></code>
    <note>Missing catalog_version + audited_at; tool entry missing checks + verdict; uppercase X violates snake_case.</note>
  </example>

  <reference path="scripts/validate-verb-object-tool-naming.py">Validator script</reference>
</text>
