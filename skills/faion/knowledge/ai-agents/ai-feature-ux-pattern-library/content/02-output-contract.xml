<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Feature UX Pattern Library Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a AI Feature UX Pattern Library deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="feature_id" format="stable_id" />
      <field name="gate_name" type="string" />
      <field name="pre_registered_criteria" type="list" min="3" />
      <field name="evidence_per_criterion" type="object" />
      <field name="kill_criteria" type="list" min="1" />
      <field name="rollback_artifacts" type="list" />
      <field name="crossfunctional_signoffs" type="list" />
    </required>
    <forbidden>
      <pattern id="f1">criterion added at gate review (not pre-registered)</pattern>
      <pattern id="f2">no rollback_artifacts</pattern>
      <pattern id="f3">signoffs collected after the gate</pattern>
      <pattern id="f4">kill_criteria empty</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Re-baseline criterion only with explicit version stamp.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Criteria pre-registered</item>
      <item>Evidence per criterion</item>
      <item>Rollback tested</item>
      <item>Signoffs in hand</item>
    </list>
  </section>
</text>
