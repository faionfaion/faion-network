<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Multi-Agent Production Bus Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the multi-agent-system spec.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "multi-agent-production-bus"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["strategy", "agents", "handler_timeout_seconds", "per_run_token_cap", "observability_backend", "message_schema_ref"],
      "properties": {
        "strategy": {"enum": ["sequential", "parallel", "hierarchical"]},
        "agents": {"type": "array", "minItems": 2, "items": {"type": "object", "required": ["name", "role", "model", "budget_tokens"]}},
        "handler_timeout_seconds": {"type": "integer", "minimum": 1},
        "per_run_token_cap": {"type": "integer", "minimum": 1},
        "observability_backend": {"enum": ["agentops", "langsmith", "none"]},
        "message_schema_ref": {"type": "string"}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["subtasks_independent", "chain_shape", "agent_count", "audit_required"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Hierarchical 4-agent prod system"><![CDATA[
{
  "slug": "multi-agent-production-bus",
  "version": "2.0.0",
  "decision": {
    "strategy": "hierarchical",
    "agents": [
      {"name": "planner", "role": "decompose", "model": "opus", "budget_tokens": 20000},
      {"name": "researcher", "role": "search", "model": "sonnet", "budget_tokens": 30000},
      {"name": "writer", "role": "draft", "model": "sonnet", "budget_tokens": 30000},
      {"name": "synthesizer", "role": "merge", "model": "opus", "budget_tokens": 20000}
    ],
    "handler_timeout_seconds": 60,
    "per_run_token_cap": 200000,
    "observability_backend": "agentops",
    "message_schema_ref": "templates/message-bus.py#Message"
  },
  "drivers": {"subtasks_independent": false, "chain_shape": "dependent_dag", "agent_count": 4, "audit_required": true},
  "audit": {"rule_refs": ["r1-structured-message", "r2-handler-timeout", "r5-cost-gate", "r6-observability-tags", "r-hierarchical"]}
}
]]></example>

    <example valid="false" title="Missing timeout + empty audit"><![CDATA[
{
  "slug": "multi-agent-production-bus",
  "version": "2.0.0",
  "decision": {"strategy": "hierarchical", "agents": [{"name": "a", "role": "x", "model": "sonnet", "budget_tokens": 1000}, {"name": "b", "role": "y", "model": "sonnet", "budget_tokens": 1000}], "per_run_token_cap": 1000, "observability_backend": "none", "message_schema_ref": ""},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>decision.handler_timeout_seconds missing — violates r2.</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>decision.strategy matches the decision-tree branch.</item>
      <item>Every agent has name+role+model+budget_tokens.</item>
      <item>Sum of agent budgets &lt;= per_run_token_cap.</item>
    </list>
  </section>

  <reference path="templates/message-bus.py">MessageBus impl.</reference>
  <reference path="scripts/validate-multi-agent-production-bus.py">Validator.</reference>
</text>
