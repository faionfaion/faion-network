<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Schema Field Order Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (answer_quality_floor, latency_budget_ms, schema_modifiable)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error, do not guess defaults.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-pick" text="Which conclusion best matches the driver profile?">
          <branch when="schema_modifiable == false">
            <conclusion ref="skip-this-methodology">Schema fixed externally; cannot apply.</conclusion>
          </branch>
          <branch when="default">
            <conclusion ref="r1-reasoning-first">Reorder fields: reasoning → intermediate → answer.</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="drivers.valid=true (default path)">
      q-root yes → q-pick default → r1-reasoning-first
    </example>
  </decision-tree>
</text>
