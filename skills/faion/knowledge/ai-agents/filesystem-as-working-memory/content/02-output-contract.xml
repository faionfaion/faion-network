<text id="02-output-contract" title="filesystem-as-working-memory Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>Offloaded-envelope schema and the four FS tool definitions.</summary>

  <section title="Offloaded-envelope schema">
    <code lang="json"><![CDATA[
{
  "$id": "filesystem-as-working-memory/offloaded-envelope",
  "type": "object",
  "required": ["kind", "path", "head"],
  "additionalProperties": false,
  "properties": {
    "kind": {"const": "offloaded"},
    "path": {"type": "string", "pattern": "^(search|docs|plan|scratch)/[^\\s]+$"},
    "head": {"type": "string", "maxLength": 800}
  }
}
    ]]></code>
  </section>

  <section title="Inline-envelope schema (small results)">
    <code lang="json"><![CDATA[
{
  "$id": "filesystem-as-working-memory/inline-envelope",
  "type": "object",
  "required": ["kind", "inline"],
  "additionalProperties": false,
  "properties": {
    "kind":   {"const": "inline"},
    "inline": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <section title="Good example (offloaded)">
    <example type="good">
      <code lang="json"><![CDATA[
{"kind": "offloaded", "path": "search/refund-policy.json", "head": "Refund policy v3.2 — 30-day window, exceptions for digital goods..."}
      ]]></code>
      <note>Path is under the canonical taxonomy; head fits the 800-char cap.</note>
    </example>
  </section>

  <section title="Bad example (path outside taxonomy)">
    <example type="bad">
      <code lang="json"><![CDATA[
{"kind": "offloaded", "path": "tmp/random-blob.json", "head": "..."}
      ]]></code>
      <note>Path violates the stable taxonomy. Validator rejects.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Path is rooted at `search/`, `docs/`, `plan/`, or `scratch/`.</item>
      <item>Head is at most 800 characters.</item>
      <item>Inline kind is only used for outputs &lt;= 2000 tokens.</item>
    </list>
  </section>
</text>
