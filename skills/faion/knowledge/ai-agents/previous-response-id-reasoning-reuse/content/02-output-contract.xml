<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="previous_response_id Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the agent-continuity spec.</summary>
  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "previous-response-id-reasoning-reuse"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {"type": "object", "required": ["mode", "session_store", "retention_ttl_hours", "log_destination"], "properties": {"mode": {"enum": ["previous-response-id", "message-array"]}, "retention_ttl_hours": {"type": "integer", "minimum": 1}}},
    "drivers": {"type": "object", "required": ["api_flavor", "multi_turn", "reasoning_model_used"], "additionalProperties": true},
    "audit": {"type": "object", "required": ["rule_refs"], "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}}
  }
}
]]></schema>
    <example valid="true" title="Responses API multi-turn"><![CDATA[
{"slug": "previous-response-id-reasoning-reuse", "version": "2.0.0",
 "decision": {"mode": "previous-response-id", "session_store": "redis://...", "retention_ttl_hours": 24, "log_destination": "stdout-json"},
 "drivers": {"api_flavor": "responses", "multi_turn": true, "reasoning_model_used": true},
 "audit": {"rule_refs": ["r1-pass-previous-id", "r2-store-per-conversation", "r-use-previous-id"]}}
]]></example>
    <example valid="false" title="Chat API + previous_response_id"><![CDATA[
{"slug": "previous-response-id-reasoning-reuse", "version": "2.0.0",
 "decision": {"mode": "previous-response-id", "session_store": "x", "retention_ttl_hours": 0, "log_destination": "x"},
 "drivers": {}, "audit": {"rule_refs": []}}
]]></example>
    <example-violations>
      <violation>retention_ttl_hours must be &gt;= 1.</violation>
      <violation>drivers missing required keys.</violation>
    </example-violations>
  </output-contract>
  <reference path="scripts/validate-previous-response-id-reasoning-reuse.py">Validator.</reference>
</text>
