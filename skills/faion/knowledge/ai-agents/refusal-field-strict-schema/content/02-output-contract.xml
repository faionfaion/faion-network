<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Refusal Field Strict Schema Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the refusal-field-strict-schema spec artefact.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "slug",
    "version",
    "decision",
    "drivers",
    "audit"
  ],
  "properties": {
    "slug": {
      "const": "refusal-field-strict-schema"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decision": {
      "type": "object",
      "required": [
        "schema_path",
        "strict_mode",
        "refusal_branch_code"
      ],
      "additionalProperties": true
    },
    "drivers": {
      "type": "object",
      "required": [
        "api_flavor",
        "production_refusal_rate",
        "downstream_consumer_count"
      ],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": [
        "rule_refs"
      ],
      "properties": {
        "rule_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^r[0-9a-z-]+$"
          }
        }
      }
    }
  }
}
]]></schema>

    <example valid="true" title="Canonical happy path"><![CDATA[
{
  "slug": "refusal-field-strict-schema",
  "version": "2.0.0",
  "decision": {
    "schema_path": "value",
    "strict_mode": "value",
    "refusal_branch_code": "value"
  },
  "drivers": {
    "api_flavor": "v",
    "production_refusal_rate": "v",
    "downstream_consumer_count": "v"
  },
  "audit": {
    "rule_refs": [
      "r1-top-level-refusal"
    ]
  }
}
]]></example>

    <example valid="false" title="Empty decision + drivers"><![CDATA[
{
  "slug": "refusal-field-strict-schema",
  "version": "2.0.0",
  "decision": {},
  "drivers": {},
  "audit": {
    "rule_refs": []
  }
}
]]></example>

    <example-violations>
      <violation>decision missing required keys: schema_path, strict_mode, refusal_branch_code.</violation>
      <violation>drivers missing required keys: api_flavor, production_refusal_rate, downstream_consumer_count.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>JSON validates against the schema above.</item>
      <item>decision.* present per the matched decision-tree branch.</item>
      <item>audit.rule_refs cites the leaf rule id.</item>
    </list>
  </section>

  <reference path="scripts/validate-refusal-field-strict-schema.py">Schema validator.</reference>
</text>
