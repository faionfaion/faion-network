<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Preference-Trained Router Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the router-spec artefact.</summary>
  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "preference-trained-router"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {"type": "object", "required": ["mode", "router_arch", "weak_model", "strong_model", "uncertainty_band", "drift_threshold", "fallback_model"], "properties": {"mode": {"enum": ["router-deploy", "static-rule"]}, "router_arch": {"enum": ["logistic-regression", "small-bert", "lightgbm", "none"]}, "uncertainty_band": {"type": "number", "minimum": 0, "maximum": 1}, "drift_threshold": {"type": "number", "minimum": 0, "maximum": 1}}},
    "drivers": {"type": "object", "required": ["prompt_volume_per_day", "weak_strong_cost_ratio", "preference_data_size", "latency_budget_ms"], "additionalProperties": true},
    "audit": {"type": "object", "required": ["rule_refs"], "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}}
  }
}
]]></schema>
    <example valid="true" title="RouteLLM-style deployment"><![CDATA[
{
  "slug": "preference-trained-router",
  "version": "2.0.0",
  "decision": {"mode": "router-deploy", "router_arch": "small-bert", "weak_model": "haiku", "strong_model": "opus", "uncertainty_band": 0.1, "drift_threshold": 0.85, "fallback_model": "opus"},
  "drivers": {"prompt_volume_per_day": 5000, "weak_strong_cost_ratio": 15, "preference_data_size": 4000, "latency_budget_ms": 1500},
  "audit": {"rule_refs": ["r1-binary-classifier", "r3-calibrated-threshold", "r5-drift-monitor", "r-deploy-router"]}
}
]]></example>
    <example valid="false" title="Multi-class router + no audit"><![CDATA[
{"slug": "preference-trained-router", "version": "2.0.0", "decision": {"mode": "router-deploy", "router_arch": "small-bert", "weak_model": "h", "strong_model": "o", "uncertainty_band": 2, "drift_threshold": 0.5, "fallback_model": "o"}, "drivers": {}, "audit": {"rule_refs": []}}
]]></example>
    <example-violations>
      <violation>uncertainty_band must be 0..1 (r4).</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>
  <reference path="scripts/validate-preference-trained-router.py">Validator.</reference>
</text>
