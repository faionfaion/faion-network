<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Preference-Trained Router Decision Tree" version="2.0.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root" text="Are drivers present (prompt_volume_per_day, weak_strong_cost_ratio, preference_data_size, latency_budget_ms)?">
      <branch when="drivers.valid == false">
        <conclusion ref="skip-this-methodology">Profile incomplete — return structured error.</conclusion>
      </branch>
      <branch when="drivers.valid == true">
        <question id="q-data" text="Is preference_data_size &gt;= 1000 AND weak_strong_cost_ratio &gt;= 5?">
          <branch when="preference_data_size &gt;= 1000 and weak_strong_cost_ratio &gt;= 5">
            <conclusion ref="r-deploy-router">Deploy binary preference router with calibration + uncertainty fallback + drift monitor.</conclusion>
          </branch>
          <branch when="preference_data_size &lt; 1000 or weak_strong_cost_ratio &lt; 5">
            <conclusion ref="r-static-rule">Fall back to a static rule (always-strong or task-tag-based).</conclusion>
          </branch>
        </question>
      </branch>
    </root-question>
    <example trace="preference_data_size=4000, weak_strong_cost_ratio=15">
      q-root yes → q-data both yes → r-deploy-router
    </example>
  </decision-tree>
</text>
