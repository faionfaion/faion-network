<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Decision Log Template Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-decision-log-template.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "row_id",
    "context",
    "decision",
    "alternatives",
    "thread_link",
    "status"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "row_id": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "alternatives": {
      "type": "array"
    },
    "thread_link": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Accepted",
        "Superseded",
        "Deprecated"
      ]
    },
    "supersedes": {
      "type": "string"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">decision text starts with passive phrasing (&apos;it was decided&apos;, &apos;we have decided&apos;).</pattern>
      <pattern id="f2">alternatives array length &lt; 2.</pattern>
      <pattern id="f3">owner is a plural pronoun or empty.</pattern>
      <pattern id="f4">status not in the enum, OR status=Superseded without supersedes set.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-decision-log-template-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "row_id": "row_id value",
  "context": "context value",
  "decision": "decision value",
  "alternatives": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "thread_link": "thread_link value",
  "status": "Accepted",
  "supersedes": "supersedes value"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-design-decision-log-template.py">Stdlib-only validator implementing this schema.</reference>
</text>
