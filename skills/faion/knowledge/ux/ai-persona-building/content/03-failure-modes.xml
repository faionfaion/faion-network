<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="AI Persona Building (Single-Pass) Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns observed when applying ai-persona-building. Each pairs symptom + root cause + concrete fix.</summary>
  <section title="Antipatterns">
    <antipattern id="treat-as-validated" severity="high">
      <symptom>Single-pass personas land in PRDs without validation; product diverges from users.</symptom>
      <root-cause source="Internal — ai-persona-building authoring">Output not labelled.</root-cause>
      <fix>Hard-enforce validated=false + validation_required flag.</fix>
    </antipattern>
    <antipattern id="no-secondary-sources" severity="medium">
      <symptom>Personas pure speculation; stakeholders dismiss.</symptom>
      <root-cause source="Internal — ai-persona-building authoring">No source-citation rule.</root-cause>
      <fix>Require ≥1 secondary source per persona.</fix>
    </antipattern>
    <antipattern id="overcount" severity="low">
      <symptom>10 personas generated; team paralysed.</symptom>
      <root-cause source="Internal — ai-persona-building authoring">No cap.</root-cause>
      <fix>Cap at 5; pick highest-leverage personas.</fix>
    </antipattern>
    <antipattern id="missing-next-step" severity="low">
      <symptom>Single-pass output published with no upgrade path.</symptom>
      <root-cause source="Internal — ai-persona-building authoring">No next_step field.</root-cause>
      <fix>Always name the upgrade path to the two-pass methodology.</fix>
    </antipattern>
  </section>
</text>
