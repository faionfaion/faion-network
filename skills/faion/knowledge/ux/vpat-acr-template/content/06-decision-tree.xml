<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="VPAT / ACR Template Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-audit">WCAG 2.2 audit available?</root-question>

    <branch when="audit_available == false">
      <conclusion ref="vpat-25-edition" verdict="halt — run wcag-22-compliance first"/>
    </branch>

    <branch when="audit_available == true">
      <question id="q-edition">vpat_edition >= 2.5?</question>
      <branch when="edition_ok == false">
        <conclusion ref="vpat-25-edition" verdict="upgrade template to VPAT 2.5"/>
      </branch>
      <branch when="edition_ok == true">
        <question id="q-signed">signed_by present?</question>
        <branch when="signed == false">
          <conclusion ref="named-owner-signed" verdict="halt publication; assign accessibility lead"/>
        </branch>
        <branch when="signed == true">
          <conclusion ref="per-row-remarks-required" verdict="ACR ready; publish + share with procurement"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="faionapp-v2.4-acr">
    audit_available=true → edition_ok=true → signed=true → conclusion per-row-remarks-required → ACR published.
  </example>
</text>
