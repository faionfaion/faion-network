<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="vui-privacy-security Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the vui-privacy-security methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/vui-privacy-security.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "jurisdictions",
    "trust_indicators",
    "step_up_auth",
    "redaction",
    "retention",
    "deletion_control"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "vui-privacy-security"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "spec"
        }
      }
    },
    "jurisdictions": {
      "type": "array",
      "items": {
        "enum": [
          "EU",
          "US",
          "CA",
          "UK",
          "BR",
          "AU",
          "JP"
        ]
      },
      "minItems": 1
    },
    "trust_indicators": {
      "type": "object",
      "required": [
        "visual",
        "audio"
      ],
      "properties": {
        "visual": {
          "type": "boolean",
          "const": true
        },
        "audio": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "step_up_auth": {
      "type": "object",
      "required": [
        "sensitive_actions"
      ],
      "properties": {
        "sensitive_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "intent",
              "method"
            ],
            "properties": {
              "intent": {
                "type": "string"
              },
              "method": {
                "enum": [
                  "pin",
                  "biometric",
                  "2fa",
                  "tap-confirm"
                ]
              }
            }
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "required": [
        "on_device",
        "categories"
      ],
      "properties": {
        "on_device": {
          "type": "boolean",
          "const": true
        },
        "categories": {
          "type": "array",
          "items": {
            "enum": [
              "name",
              "account_number",
              "ssn",
              "address",
              "dob",
              "health_term"
            ]
          },
          "minItems": 1
        }
      }
    },
    "retention": {
      "type": "object",
      "required": [
        "transcript_days"
      ],
      "properties": {
        "transcript_days": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30
        }
      }
    },
    "deletion_control": {
      "type": "boolean",
      "const": true
    },
    "minor_protections": {
      "type": "object",
      "properties": {
        "parental_consent": {
          "type": "boolean"
        },
        "no_profiling": {
          "type": "boolean"
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "vui-privacy-security",
    "version": "1.1.0",
    "produces": "spec"
  },
  "jurisdictions": [
    "EU",
    "US",
    "CA"
  ],
  "trust_indicators": {
    "visual": true,
    "audio": true
  },
  "step_up_auth": {
    "sensitive_actions": [
      {
        "intent": "send-payment",
        "method": "biometric"
      },
      {
        "intent": "change-account",
        "method": "pin"
      }
    ]
  },
  "redaction": {
    "on_device": true,
    "categories": [
      "name",
      "account_number",
      "ssn",
      "address"
    ]
  },
  "retention": {
    "transcript_days": 14
  },
  "deletion_control": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "jurisdictions": [],
  "trust_indicators": {
    "visual": false,
    "audio": false
  },
  "step_up_auth": {
    "sensitive_actions": []
  },
  "redaction": {
    "on_device": false,
    "categories": []
  },
  "retention": {
    "transcript_days": 365
  },
  "deletion_control": false
}
]]></code>
    <note>Missing __faion_header__; jurisdictions empty; trust_indicators false; step_up_auth empty; on-device redaction false; retention &gt;30 days; deletion_control false.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>trust_indicators.visual or .audio set to false.</item>
      <item>step_up_auth.sensitive_actions empty when sensitive intents exist.</item>
      <item>redaction.on_device == false.</item>
      <item>retention.transcript_days &gt; 30 for non-essential.</item>
      <item>deletion_control == false.</item>
    </list>
  </section>

  <reference path="templates/privacy-spec.json">Skeleton spec</reference>
