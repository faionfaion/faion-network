<text id="05-examples" title="vui-privacy-security Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: voice banking — 14-day retention, biometric step-up, on-device PII redaction.</summary>

  <section title="Scenario">
    <p>Voice banking app serving EU + US. Sensitive intents: send-payment, change-account.</p>
  </section>

  <section title="Resulting artefact">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "vui-privacy-security",
    "version": "1.1.0",
    "produces": "spec"
  },
  "jurisdictions": [
    "EU",
    "US"
  ],
  "trust_indicators": {
    "visual": true,
    "audio": true
  },
  "step_up_auth": {
    "sensitive_actions": [
      {
        "intent": "send-payment",
        "method": "biometric"
      },
      {
        "intent": "change-account",
        "method": "pin"
      }
    ]
  },
  "redaction": {
    "on_device": true,
    "categories": [
      "name",
      "account_number",
      "ssn",
      "address",
      "dob"
    ]
  },
  "retention": {
    "transcript_days": 14
  },
  "deletion_control": true
}
]]></code>
  </section>

  <section title="Outcome">
    <p>Validator exits 0. Legal sign-off complete. PII redaction integrated into mobile SDK.</p>
  </section>
</text>
