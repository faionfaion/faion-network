{
  "__faion_header__": {
    "purpose": "Canonical token source",
    "consumes": "design decisions",
    "produces": "tokens.json for Style Dictionary",
    "depends_on": "DTCG spec",
    "tokens": "~300 for skeleton"
  },
  "color": {
    "primitive": {
      "blue-500": {
        "$value": "#1c5fdb",
        "$type": "color"
      }
