<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cross-Platform Token Distribution Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "source",
    "platforms",
    "transforms"
  ],
  "properties": {
    "source": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "minItems": 2,
      "items": {
        "enum": [
          "web-css",
          "ios-swift",
          "android-xml",
          "tailwind",
          "json"
        ]
      }
    },
    "transforms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "transform",
          "output_path"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "source": "tokens.json",
  "platforms": [
    "web-css",
    "ios-swift",
    "android-xml",
    "tailwind"
  ],
  "transforms": [
    {
      "platform": "web-css",
      "transform": "css-variables",
      "output_path": "dist/web/tokens.css"
    },
    {
      "platform": "ios-swift",
      "transform": "ios-swift-class",
      "output_path": "dist/ios/Tokens.swift"
    },
    {
      "platform": "android-xml",
      "transform": "android-color-resource",
      "output_path": "dist/android/colors.xml"
    },
    {
      "platform": "tailwind",
      "transform": "tailwind-config",
      "output_path": "dist/web/tailwind.config.js"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "source": "x"
}
]]></code>
    <note>Missing platforms (need &gt;=2) and transforms; source is just a name.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>A platforms array with &lt;2 entries.</item>
      <item>A transform without output_path.</item>
      <item>Hand-edits in dist/* outputs.</item>
    </list>
  </section>

  <reference path="scripts/validate-cross-platform-token-distribution.py">Validator script</reference>
</text>
