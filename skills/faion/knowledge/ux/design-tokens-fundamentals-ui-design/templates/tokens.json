{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "comment": "W3C DTCG compliant token file. Three tiers: global (raw values), semantic (aliases), component (scoped).",

  "color": {
    "comment": "GLOBAL TIER — raw primitive values. Never reference directly from components.",
    "blue": {
      "500": { "value": "#3B82F6", "type": "color" },
      "600": { "value": "#2563EB", "type": "color" }
    },
    "red": {
      "500": { "value": "#EF4444", "type": "color" }
    },
    "gray": {
      "900": { "value": "#111827", "type": "color" },
      "600": { "value": "#4B5563", "type": "color" },
      "100": { "value": "#F3F4F6", "type": "color" }
    },

    "comment2": "SEMANTIC TIER — intent aliases. Always reference global tokens, never raw values.",
    "primary": {
      "default": { "value": "{color.blue.500}", "type": "color", "description": "Primary brand color — use for CTAs, links, focus rings" },
      "hover": { "value": "{color.blue.600}", "type": "color", "description": "Primary brand color hover state" }
    },
    "feedback": {
      "error": { "value": "{color.red.500}", "type": "color", "description": "Destructive actions, validation errors" }
    },
    "text": {
      "default": { "value": "{color.gray.900}", "type": "color", "description": "Body text" },
      "muted": { "value": "{color.gray.600}", "type": "color", "description": "Secondary text, captions, placeholders" }
    },
    "surface": {
      "subtle": { "value": "{color.gray.100}", "type": "color", "description": "Subtle background surfaces" }
    }
  },

  "spacing": {
    "comment": "GLOBAL TIER — base spacing scale in pixels.",
    "xs": { "value": "4px", "type": "dimension" },
    "sm": { "value": "8px", "type": "dimension" },
    "md": { "value": "16px", "type": "dimension" },
    "lg": { "value": "24px", "type": "dimension" },
    "xl": { "value": "32px", "type": "dimension" },
    "2xl": { "value": "48px", "type": "dimension" }
  }
}
