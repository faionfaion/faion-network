<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Tokens Fundamentals Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-tokens-fundamentals.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "source_of_truth",
    "tiers",
    "ci_lint_status",
    "consumers"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "source_of_truth": {
      "type": "string",
      "enum": [
        "figma-variables",
        "tokens-json"
      ]
    },
    "tiers": {
      "type": "object"
    },
    "ci_lint_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "breaking_renames": {
      "type": "array"
    },
    "consumers": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">tiers object missing any of {global, semantic, component}.</pattern>
      <pattern id="f2">any semantic token value is a raw hex / px / number instead of a {global.x} reference.</pattern>
      <pattern id="f3">source_of_truth declared as both figma-variables and tokens-json (must be one).</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-tokens-fundamentals-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "source_of_truth": "figma-variables",
  "tiers": {
    "key": "value"
  },
  "ci_lint_status": "pass",
  "breaking_renames": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "consumers": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-design-tokens-fundamentals.py">Stdlib-only validator implementing this schema.</reference>
</text>
