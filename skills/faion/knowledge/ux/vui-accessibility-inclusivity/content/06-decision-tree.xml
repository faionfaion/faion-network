<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="vui-accessibility-inclusivity Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree from audience scope + measurement to remediation actions. Each leaf references a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-audience">Audience scope?</root-question>

    <branch when="audience includes 'non-native' OR 'elderly'">
      <conclusion ref="wer-per-slice" verdict="measure WER per slice with n&gt;=30"/>
    </branch>

    <branch when="fairness_gap_pct &gt; 10">
      <conclusion ref="wer-fairness-gap-cap" verdict="block launch; remediation plan required"/>
    </branch>

    <branch when="any prompt grade &gt; 8">
      <conclusion ref="prompt-grade-8-cap" verdict="simplify prompts"/>
    </branch>

    <branch when="transcript_available == false">
      <conclusion ref="visual-transcript-alternative" verdict="add visual transcript"/>
    </branch>

    <branch when="non_voice_fallback == false">
      <conclusion ref="non-voice-fallback" verdict="add tap/type fallback"/>
    </branch>

  </decision-tree>

  <example trace="voice-banking">
    audience=mixed → per-slice WER 4 slices → gap 5.8 pp → prompts grade ≤8 → transcript + fallback present → report valid.
  </example>
</text>
