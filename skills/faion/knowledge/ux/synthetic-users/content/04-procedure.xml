<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Synthetic Users Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply synthetic-users end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="draft-concepts">
      <input>Feature brief</input>
      <action>Draft ≥5 concept variants.</action>
      <output>Concept set</output>
    </step>
    <step n="2" name="seed-personas">
      <input>Concept set + persona seed</input>
      <action>Bind concepts to synthetic personas; generate reactions.</action>
      <output>Reactions</output>
    </step>
    <step n="3" name="flag-surprises">
      <input>Reactions</input>
      <action>Mark each reaction surprise_flag=true|false against team priors.</action>
      <output>Annotated reactions</output>
    </step>
    <step n="4" name="write-validation-plan">
      <input>Annotated reactions</input>
      <action>Schedule real-user validation within 30 days; capture URL.</action>
      <output>Validation plan</output>
    </step>
    <step n="5" name="emit-report">
      <input>Annotated reactions + plan</input>
      <action>Compose JSON report with all guard flags.</action>
      <output>synthetic-report.json</output>
    </step>
  </section>
</text>
