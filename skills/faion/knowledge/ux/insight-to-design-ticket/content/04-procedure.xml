<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Insight-to-Design-Ticket Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Insight-to-Design-Ticket end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="pull-insight">
      <input>Research notes + evidence</input>
      <action>Quote the insight verbatim; pin the evidence_link.</action>
      <output>insight + evidence_link populated.</output>
    </step>
    <step n="2" name="draft-hypothesis">
      <input>Insight + product theme</input>
      <action>Write IF / THEN hypothesis.</action>
      <output>hypothesis populated.</output>
    </step>
    <step n="3" name="pick-success-metric">
      <input>Hypothesis + analytics</input>
      <action>Set measurable target OR explicit no-metric.</action>
      <output>success_metric populated.</output>
    </step>
    <step n="4" name="enumerate-constraints">
      <input>Brand / tokens / a11y / motion</input>
      <action>List 2+ named constraints.</action>
      <output>design_constraints populated.</output>
    </step>
    <step n="5" name="draft-ac">
      <input>All previous outputs</input>
      <action>Draft 3+ AC items; mark refinement-at-handoff.</action>
      <output>draft_acceptance_criteria populated.</output>
    </step>
    <step n="6" name="store-and-route">
      <input>Filled ticket</input>
      <action>Run validator; create tracker row; assign owner.</action>
      <output>Stored ticket.</output>
    </step>

  </section>
</text>
