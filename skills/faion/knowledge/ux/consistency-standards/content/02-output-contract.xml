<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Consistency and Standards Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/consistency-standards.json",
  "type": "object",
  "required": [
    "artefact_id",
    "scope",
    "checks",
    "blocking_count",
    "advisory_count",
    "version",
    "last_reviewed",
    "lint_status",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "checks": {
      "type": "array"
    },
    "blocking_count": {
      "type": "integer"
    },
    "advisory_count": {
      "type": "integer"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "lint_status": {
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">lint_status == 'fail' AND artefact submitted as final.</pattern>
      <pattern id="f2">owner == 'team' / 'we' / '' / null.</pattern>
      <pattern id="f3">version not in semver MAJOR.MINOR.PATCH form.</pattern>
      <pattern id="f4">required field missing or set to a placeholder string (e.g. 'tbd', '...', 'fill in').</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "consistency-standards-example",
  "scope": "Scope of the checklist \u2014 one paragraph.",
  "checks": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "blocking_count": 5,
  "advisory_count": 3,
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "lint_status": "pass",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-consistency-standards.py">Schema validator (stdlib only).</reference>
</text>
