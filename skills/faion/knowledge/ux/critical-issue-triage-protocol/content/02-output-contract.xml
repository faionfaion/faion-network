<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Critical-Issue Triage Protocol Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/critical-issue-triage-protocol.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "session_id",
    "sample_size_n",
    "findings",
    "actions_summary"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "session_id": {
      "type": "string"
    },
    "sample_size_n": {
      "type": "integer"
    },
    "findings": {
      "type": "array"
    },
    "actions_summary": {
      "type": "object"
    },
    "overrides": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner is a plural pronoun or empty.</pattern>
      <pattern id="f2">findings array empty AND session_id non-empty (use discard-record instead).</pattern>
      <pattern id="f3">any finding&apos;s severity outside 0..4 OR frequency outside {SINGLE,FEW,MANY,MOST}.</pattern>
      <pattern id="f4">an override entry without a written justification string.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "critical-issue-triage-protocol-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "session_id": "session_id value",
  "sample_size_n": 1,
  "findings": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "actions_summary": {
    "key": "value"
  },
  "overrides": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-critical-issue-triage-protocol.py">Stdlib-only validator implementing this schema.</reference>
</text>
