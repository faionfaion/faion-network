<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Scope-Creep Park List Template Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/scope-creep-park-list-template.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "walkthrough_session_id",
    "sprint_scope",
    "rows"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "walkthrough_session_id": {
      "type": "string"
    },
    "sprint_scope": {
      "type": "string"
    },
    "rows": {
      "type": "array"
    },
    "revisit_outcomes": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">any row&apos;s revisit_gate value is &apos;later&apos; or &apos;someday&apos; (vague).</pattern>
      <pattern id="f2">any row missing acknowledgement_line.</pattern>
      <pattern id="f3">owner is a plural pronoun or empty.</pattern>
      <pattern id="f4">rows array empty AND walkthrough_session_id non-empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "scope-creep-park-list-template-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "walkthrough_session_id": "walkthrough_session_id value",
  "sprint_scope": "sprint_scope value",
  "rows": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "revisit_outcomes": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-scope-creep-park-list-template.py">Stdlib-only validator implementing this schema.</reference>
</text>
