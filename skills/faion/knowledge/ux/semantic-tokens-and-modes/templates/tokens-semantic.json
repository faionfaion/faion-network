{
  "__faion_header__": {
    "purpose": "DTCG-format semantic-layer skeleton with mode collection",
    "consumes": "reference-layer palette + mode list",
    "produces": "system-layer token tree consumed by style-dictionary build",
    "depends_on": "content/01-core-rules.xml three-layer-strict rule",
    "token_budget_impact": "~300 tokens when loaded as context"
  },
  "color": {
    "action": {
      "primary": {
        "$type": "color",
        "intent": "primary interactive surface",
        "values_by_mode": {
          "light": "{color.blue.600}",
          "dark": "{color.blue.400}",
          "high-contrast": "{color.blue.900}"
        }
      },
      "primary-hover": {
        "$type": "color",
        "intent": "primary interactive surface — hover state",
        "values_by_mode": {
          "light": "{color.blue.700}",
          "dark": "{color.blue.300}",
          "high-contrast": "{color.blue.950}"
        }
      }
    },
    "surface": {
      "page": {
        "$type": "color",
        "intent": "page background",
        "values_by_mode": {
          "light": "{color.gray.50}",
          "dark": "{color.gray.950}",
          "high-contrast": "{color.gray.1000}"
        }
      }
    }
  }
}
