<methodology slug="regulatory-compliance-2026">
  <metadata>
    <tier>pro</tier>
    <group>ux</group>
    <domain>ux-ui-designer</domain>
    <summary>Map product surfaces to accessibility regulations (ADA Title II April 2026, EAA June 2025, AODA, Section 508) and implement WCAG 2.1 AA with documented audits.</summary>
    <category>compliance</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-25</created>
    <tags>
