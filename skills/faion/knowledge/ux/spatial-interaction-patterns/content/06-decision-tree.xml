<text id="06-decision-tree" title="spatial-interaction-patterns Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree: per-interaction, picks modalities and required state-machine states. Every leaf references a rule in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-interaction-class">Interaction class?</root-question>

    <branch when="interaction == 'select-or-tap'">
      <conclusion ref="primary-plus-fallback-modality" verdict="primary=gaze+dwell or hand-direct; fallback=voice"/>
    </branch>

    <branch when="interaction == 'manipulation'">
      <question id="q-platform-manip">Hand-tracking primary platform?</question>
      <branch when="platform == 'visionos'">
        <conclusion ref="primary-plus-fallback-modality" verdict="primary=hand-direct; fallback=voice"/>
      </branch>
      <branch when="platform == 'quest'">
        <conclusion ref="primary-plus-fallback-modality" verdict="primary=controller; fallback=hand-direct"/>
      </branch>
    </branch>

    <branch when="interaction == 'navigation'">
      <conclusion ref="voice-as-equal-modality" verdict="primary=voice; fallback=gaze+dwell"/>
    </branch>

    <branch when="state_machine missing cancel/error">
      <conclusion ref="state-machine-explicit" verdict="reject; add cancel + error states"/>
    </branch>

  </decision-tree>

  <example trace="productivity-select-window">
    interaction=select-or-tap → primary=gaze+dwell, fallback=voice → state-machine=[idle,hover,active,cancel,error] → spec valid.
  </example>
</text>
