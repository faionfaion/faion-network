<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="VUI Accessibility and Inclusivity Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/vui-accessibility-inclusivity.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">Accent WER &gt; 15% on any covered dialect without waiver.</pattern>
      <pattern id="f2">Voice flow without text-mode alternate.</pattern>
      <pattern id="f3">Critical action confirmed audibly only.</pattern>
      <pattern id="f4">No &apos;what can I say&apos; help.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "vui-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@vui-lead",
  "scope": {
    "product": "faion-vui",
    "languages": [
      "en",
      "uk"
    ],
    "wer_floor": "15%"
  },
  "findings": [
    {
      "rule": "accent-dialect-coverage",
      "verdict": "pass"
    },
    {
      "rule": "text-alternate-required",
      "verdict": "pass"
    },
    {
      "rule": "dual-confirmation",
      "verdict": "pass"
    },
    {
      "rule": "what-can-i-say-help",
      "verdict": "pass"
    },
    {
      "rule": "consent-and-opt-out",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": []
}
]]></code>
    <note>findings empty; missing artefact_id, version, last_reviewed, owner, scope.</note>
  </example>

  <reference path="scripts/validate-vui-accessibility-inclusivity.py">Schema validator (stdlib only).</reference>
</text>
