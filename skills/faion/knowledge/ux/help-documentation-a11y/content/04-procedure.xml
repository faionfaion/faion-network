<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Help and Documentation Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Help and Documentation end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Task inventory</input>
      <action>List user tasks needing help.</action>
      <output>Task list</output>
    </step>

    <step n="2" name="score-coverage">
      <input>Task list</input>
      <action>Score each against r1..r4; flag gaps.</action>
      <output>Coverage score</output>
    </step>

    <step n="3" name="measure-deflection">
      <input>Support tickets</input>
      <action>Compute deflection rate per page.</action>
      <output>Deflection table</output>
    </step>

    <step n="4" name="remediate">
      <input>Scores + deflection</input>
      <action>Author remediation list.</action>
      <output>Remediation</output>
    </step>

    <step n="5" name="validate">
      <input>Full rubric</input>
      <action>Run scripts/validate-help-documentation.py.</action>
      <output>Validated rubric</output>
    </step>

  </section>
</text>
