<text id="05-examples" title="Multimodal VUI Design Worked Example" version="1.1.0" est_tokens="700" depth="essential">
  <summary>One end-to-end worked example: input → procedure → output spec.</summary>
  <example>
    <input>
      <description>Feature brief + Target devices + APL version + Accessibility constraints + Localization scope</description>
    </input>
    <trace>
      <step n="1" name="pick-pattern">Select one of four patterns based on initiation + output surface.</step>
      <step n="2" name="define-fallback">Document voice → touch → keyboard tiers.</step>
      <step n="3" name="specify-timeout-error">Set timeout_ms + error_state_ui per prompt.</step>
      <step n="4" name="design-statesync-test">Write automated test verifying screen state per voice intent.</step>
      <step n="5" name="localise">Translate prompts; run ASR per locale; record verdict.</step>
      <step n="6" name="emit-spec">Compose feature spec JSON.</step>
    </trace>
    <output valid="true">
      <code lang="json"><![CDATA[
{
  "feature_id": "play-recipe-cards",
  "pattern": "voice-nav-visual-content",
  "fallback_tiers": [
    "voice",
    "touch",
    "keyboard"
  ],
  "timeout_ms": 8000,
  "error_state_ui": "Show 'Try saying next step' + tap-to-advance button.",
  "statesync_test_path": "tests/vui/recipe-cards-statesync.test.ts",
  "locales": [
    "en-US",
    "es-MX",
    "uk-UA"
  ]
}
]]></code>
    </output>
  </example>
</text>
