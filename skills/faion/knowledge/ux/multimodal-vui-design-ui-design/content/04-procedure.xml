<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Multimodal VUI Design Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>6-step procedure to apply multimodal-vui-design end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="pick-pattern">
      <input>Feature brief</input>
      <action>Select one of four patterns based on initiation + output surface.</action>
      <output>Pattern decision</output>
    </step>
    <step n="2" name="define-fallback">
      <input>Pattern + accessibility constraints</input>
      <action>Document voice → touch → keyboard tiers.</action>
      <output>Fallback spec</output>
    </step>
    <step n="3" name="specify-timeout-error">
      <input>Pattern + accessibility constraints</input>
      <action>Set timeout_ms + error_state_ui per prompt.</action>
      <output>Timeout/error block</output>
    </step>
    <step n="4" name="design-statesync-test">
      <input>Pattern + intents</input>
      <action>Write automated test verifying screen state per voice intent.</action>
      <output>Statesync test</output>
    </step>
    <step n="5" name="localise">
      <input>Locale list</input>
      <action>Translate prompts; run ASR per locale; record verdict.</action>
      <output>Localisation report</output>
    </step>
    <step n="6" name="emit-spec">
      <input>All blocks</input>
      <action>Compose feature spec JSON.</action>
      <output>feature-spec.json</output>
    </step>
  </section>
</text>
