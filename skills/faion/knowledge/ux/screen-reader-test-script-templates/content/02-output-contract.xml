<text id="02-output-contract" title="Screen Reader Test Script Templates Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the report artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/screen-reader-test-script-templates.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "scope",
    "findings"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object"
    },
    "findings": {
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-applicable"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">Step without gesture (vague &apos;navigate to&apos;).</pattern>
      <pattern id="f2">Step without expected string.</pattern>
      <pattern id="f3">Step without pass/fail criterion.</pattern>
      <pattern id="f4">Script without SR version pin.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "sr-script-2026-0001",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@qa-a",
  "scope": {
    "flow": "/signup",
    "device": "iPhone 15",
    "os": "iOS 17.4",
    "sr": "VoiceOver",
    "sr_version": "iOS 17.4"
  },
  "findings": [
    {
      "step": 1,
      "gesture": "right-flick",
      "expected": "Email, edit text",
      "criterion": "contains",
      "sc": "1.3.1",
      "verdict": "pass"
    }
  ],
  "verdict": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "findings": [
    {
      "step": 1,
      "gesture": "swipe",
      "expected": "Email"
    }
  ]
}
]]></code>
    <note>criterion missing; sc mapping missing; verdict missing; gesture &apos;swipe&apos; too vague; missing artefact_id, version, last_reviewed, owner, scope.</note>
  </example>

  <reference path="scripts/validate-screen-reader-test-script-templates.py">Schema validator (stdlib only).</reference>
</text>
