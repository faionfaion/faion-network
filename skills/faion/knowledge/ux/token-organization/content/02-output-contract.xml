<text id="02-output-contract" title="token-organization Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact produced by the token-organization methodology. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/token-organization.json",
  "type": "object",
  "required": [
    "__faion_header__",
    "tiers",
    "naming_convention",
    "tokens",
    "lint"
  ],
  "properties": {
    "__faion_header__": {
      "type": "object",
      "required": [
        "methodology",
        "version",
        "produces"
      ],
      "properties": {
        "methodology": {
          "const": "token-organization"
        },
        "version": {
          "type": "string"
        },
        "produces": {
          "const": "config"
        }
      }
    },
    "tiers": {
      "type": "array",
      "items": {
        "enum": [
          "primitives",
          "semantic",
          "component"
        ]
      },
      "minItems": 3,
      "maxItems": 3
    },
    "naming_convention": {
      "const": "{category}.{property}.{variant}.{state}"
    },
    "tokens": {
      "type": "object",
      "required": [
        "primitives",
        "semantic",
        "component"
      ],
      "properties": {
        "primitives": {
          "type": "object"
        },
        "semantic": {
          "type": "object"
        },
        "component": {
          "type": "object"
        }
      }
    },
    "lint": {
      "type": "object",
      "required": [
        "reject_primitive_in_component",
        "reject_raw_values_above_primitives",
        "require_state_suffix"
      ],
      "properties": {
        "reject_primitive_in_component": {
          "type": "boolean",
          "const": true
        },
        "reject_raw_values_above_primitives": {
          "type": "boolean",
          "const": true
        },
        "require_state_suffix": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "__faion_header__": {
    "methodology": "token-organization",
    "version": "1.1.0",
    "produces": "config"
  },
  "tiers": [
    "primitives",
    "semantic",
    "component"
  ],
  "naming_convention": "{category}.{property}.{variant}.{state}",
  "tokens": {
    "primitives": {
      "color.blue.600": "#0066cc"
    },
    "semantic": {
      "color.action.primary.default": "{color.blue.600}",
      "color.action.primary.hover": "{color.blue.700}"
    },
    "component": {
      "button.primary.background.default": "{color.action.primary.default}"
    }
  },
  "lint": {
    "reject_primitive_in_component": true,
    "reject_raw_values_above_primitives": true,
    "require_state_suffix": true
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tiers": [
    "primitives",
    "semantic"
  ],
  "naming_convention": "color-action-primary",
  "tokens": {
    "semantic": {
      "primary": "#0066cc"
    }
  }
}
]]></code>
    <note>Missing __faion_header__; only 2 tiers; non-dot naming; raw hex in semantic; missing component tier; missing lint.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Token name containing `-` or camelCase in source.</item>
      <item>Raw hex / rgb / px in `semantic` or `component` tokens.</item>
      <item>Interactive token without `.hover/.active/.disabled/.focus` siblings.</item>
      <item>Reference from `component` directly to `primitives`.</item>
    </list>
  </section>

