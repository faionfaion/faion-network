<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pattern Bank Tagging Schema Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pattern-bank-tagging-schema.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "entry_id",
    "surface",
    "intent",
    "pattern_type",
    "severity",
    "source_link"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "entry_id": {
      "type": "string"
    },
    "surface": {
      "type": "string",
      "enum": [
        "auth",
        "checkout",
        "dashboard",
        "nav",
        "onboarding",
        "settings",
        "profile",
        "search",
        "content",
        "empty-state",
        "error",
        "a11y"
      ]
    },
    "intent": {
      "type": "string",
      "enum": [
        "educate",
        "persuade",
        "confirm",
        "warn",
        "delight",
        "navigate",
        "input",
        "feedback"
      ]
    },
    "pattern_type": {
      "type": "string",
      "enum": [
        "anti",
        "good",
        "neutral"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "0",
        "1",
        "2",
        "3",
        "4"
      ]
    },
    "source_link": {
      "type": "string"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">surface / intent / pattern_type value not in closed vocabulary.</pattern>
      <pattern id="f2">severity not in 0..4.</pattern>
      <pattern id="f3">source_link missing OR not a URL / repo path.</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "pattern-bank-tagging-schema-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "entry_id": "entry_id value",
  "surface": "auth",
  "intent": "educate",
  "pattern_type": "anti",
  "severity": "0",
  "source_link": "source_link value"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-pattern-bank-tagging-schema.py">Stdlib-only validator implementing this schema.</reference>
</text>
