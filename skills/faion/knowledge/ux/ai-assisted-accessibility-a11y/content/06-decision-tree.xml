<text id="06-decision-tree" title="AI-Assisted Accessibility Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Every leaf references a rule id (including `skip-this-methodology`).</summary>

  <decision-tree>
    <root-question id="q-root">Is there a recurring WCAG audit cycle AND is a human a11y expert available?</root-question>

      <branch when="recurring_cycle == false OR expert_available == false">
        <conclusion ref="skip-this-methodology" verdict="wrong context for this methodology"/>
      </branch>
      <branch when="one_model_for_all == true">
        <conclusion ref="two-model-split" verdict="reject: Sonnet used for filter or Haiku used for fixes"/>
      </branch>
      <branch when="expert_validated_count == 0 AND tickets_created &gt; 0">
        <conclusion ref="expert-validates-everything" verdict="reject: AI direct-to-backlog"/>
      </branch>
      <branch when="critical_paths_single_tool == true">
        <conclusion ref="scan-twice-cross-check" verdict="reject: blind spots on critical paths"/>
      </branch>
      <branch when="wcag_citations_complete == false">
        <conclusion ref="fix-attached-source" verdict="reject: fixes lack provenance"/>
      </branch>
      <branch when="bulk_alt_text_unthrottled == true">
        <conclusion ref="alt-text-bulk-throttle" verdict="reject: unthrottled bulk"/>
      </branch>
      <branch when="all_above_pass == true">
        <conclusion ref="alt-text-bulk-throttle" verdict="accept: audit pipeline complete"/>
      </branch>

  </decision-tree>

  <example trace="ai-assisted-accessibility-happy-path">
    Quarterly audit on 48 pages → axe+pa11y → Haiku ranks 134 → Sonnet drafts 84 → expert keeps 71 → tickets opened.
  </example>
</text>
