<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Review Facilitation Script Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-review-facilitation-script.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "session_id",
    "review_ask",
    "reviewers",
    "feedback_rounds",
    "must_fix_per_reviewer",
    "committed_actions"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "session_id": {
      "type": "string"
    },
    "review_ask": {
      "type": "string"
    },
    "reviewers": {
      "type": "array"
    },
    "feedback_rounds": {
      "type": "object"
    },
    "must_fix_per_reviewer": {
      "type": "array"
    },
    "committed_actions": {
      "type": "array"
    },
    "declined_actions": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">feedback_rounds missing any of {clarify, critique, suggest}.</pattern>
      <pattern id="f2">must_fix_per_reviewer length != reviewers length.</pattern>
      <pattern id="f3">committed_actions or declined_actions empty when must_fix items exist (designer skipped commit/decline).</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-review-facilitation-script-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "session_id": "session_id value",
  "review_ask": "review_ask value",
  "reviewers": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "feedback_rounds": {
    "key": "value"
  },
  "must_fix_per_reviewer": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "committed_actions": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "declined_actions": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-design-review-facilitation-script.py">Stdlib-only validator implementing this schema.</reference>
</text>
