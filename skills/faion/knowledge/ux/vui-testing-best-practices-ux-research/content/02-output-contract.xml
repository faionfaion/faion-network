<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="VUI Testing Best Practices Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "report_date",
    "asr_version",
    "tier1",
    "tier2",
    "tier_suite"
  ],
  "properties": {
    "report_date": {
      "type": "string",
      "format": "date"
    },
    "asr_version": {
      "type": "string"
    },
    "tier1": {
      "type": "object",
      "required": [
        "intent_f1",
        "slot_f1",
        "dialog_completion_pct"
      ]
    },
    "tier2": {
      "type": "object",
      "required": [
        "naturalness",
        "error_recovery",
        "goal_completion"
      ]
    },
    "tier_suite": {
      "enum": [
        "smoke",
        "full",
        "field-replay"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "report_date": "2026-05-23",
  "asr_version": "whisper-large-v3-20250115",
  "tier1": {
    "intent_f1": 0.94,
    "slot_f1": 0.89,
    "dialog_completion_pct": 87
  },
  "tier2": {
    "naturalness": 4.2,
    "error_recovery": 4.0,
    "goal_completion": 0.85
  },
  "tier_suite": "full"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "report_date": "x",
  "tier1": {}
}
]]></code>
    <note>report_date not ISO; tier1 missing intent_f1, slot_f1, dialog_completion_pct; missing tier2, tier_suite, asr_version.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>A report aggregating tier1 + tier2 into a single score.</item>
      <item>tier_suite outside the smoke/full/field-replay enum.</item>
      <item>ASR version omitted from any published report.</item>
    </list>
  </section>

  <reference path="scripts/validate-vui-testing-best-practices.py">Validator script</reference>
</text>
