{
  "flow_id": "set-timer",
  "description": "Example: timer-setting intent with all required transitions",
  "nodes": [
    {
      "id": "ask-duration",
      "class": "directed",
      "intent": "set-timer",
      "prompt_variants": [
        "For how long?",
        "How many minutes?",
        "What duration?"
      ],
      "slots_to_fill": ["duration"],
      "destructive": false,
      "transitions": [
        { "trigger": "slot-filled:duration", "to": "confirm-timer" },
        { "trigger": "no-match", "to": "ask-duration-retry-1" },
        { "trigger": "no-input", "to": "ask-duration-retry-1" },
        { "trigger": "max-retry", "to": "escalate-to-human" }
      ]
    },
    {
      "id": "confirm-timer",
      "class": "confirm",
      "intent": "set-timer",
      "prompt_variants": [
        "{duration}-{unit} timer — shall I start it?",
        "Start a {duration}-{unit} timer?",
        "Ready to set {duration} {unit}. Confirm?"
      ],
      "destructive": false,
      "transitions": [
        { "trigger": "yes", "to": "timer-started" },
        { "trigger": "no", "to": "ask-duration" },
        { "trigger": "no-match", "to": "confirm-timer-retry-1" },
        { "trigger": "no-input", "to": "confirm-timer-retry-1" },
        { "trigger": "max-retry", "to": "escalate-to-human" }
      ]
    },
    {
      "id": "escalate-to-human",
      "class": "open",
      "prompt_variants": [
        "I'm having trouble understanding. Let me connect you with support.",
        "Let me get you some help."
      ],
      "transitions": []
    }
  ]
}
