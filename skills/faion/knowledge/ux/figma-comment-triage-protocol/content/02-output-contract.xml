<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Figma Comment Triage Protocol Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/figma-comment-triage-protocol.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "figma_file_url",
    "sweep_date",
    "rows",
    "queue_depth_after_sweep"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "figma_file_url": {
      "type": "string"
    },
    "sweep_date": {
      "type": "string",
      "format": "date"
    },
    "rows": {
      "type": "array"
    },
    "queue_depth_after_sweep": {
      "type": "integer"
    },
    "sla_warnings": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">any row&apos;s category not in {FIX, DECIDE, ANSWER, IGNORE}.</pattern>
      <pattern id="f2">any row&apos;s owner is a plural pronoun.</pattern>
      <pattern id="f3">any FIX row resolved without an evidence_link.</pattern>
      <pattern id="f4">queue_depth_after_sweep &lt; 0 OR rows array empty AND queue_depth_after_sweep &gt; 0.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "figma-comment-triage-protocol-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "figma_file_url": "figma_file_url value",
  "sweep_date": "2026-05-23",
  "rows": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "queue_depth_after_sweep": 1,
  "sla_warnings": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-figma-comment-triage-protocol.py">Stdlib-only validator implementing this schema.</reference>
</text>
