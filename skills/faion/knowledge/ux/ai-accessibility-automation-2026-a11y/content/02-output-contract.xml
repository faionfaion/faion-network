<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Accessibility Automation 2026 Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft 2020-12) for the spec artefact this methodology produces, plus one valid example, one invalid example, and the forbidden-pattern list. The companion validator (`scripts/validate-ai-accessibility-automation-2026.py`) enforces the same constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-accessibility-automation-2026.json",
  "title": "A11yPipelineSpec",
  "type": "object",
  "required": [
    "scan_per_deploy",
    "ai_ranker_config",
    "human_lead_gate",
    "vpat_signoff_required",
    "alt_text_confidence_floor",
    "caption_review_rate_pct",
    "regulated_content_review_pct"
  ],
  "properties": {
    "scan_per_deploy": {
      "type": "boolean",
      "const": true
    },
    "ai_ranker_config": {
      "type": "object",
      "required": [
        "dedup_threshold",
        "severity_weights"
      ]
    },
    "human_lead_gate": {
      "type": "boolean",
      "const": true
    },
    "vpat_signoff_required": {
      "type": "boolean",
      "const": true
    },
    "alt_text_confidence_floor": {
      "type": "number",
      "minimum": 0.7,
      "maximum": 1.0
    },
    "caption_review_rate_pct": {
      "type": "integer",
      "minimum": 10,
      "maximum": 100
    },
    "regulated_content_review_pct": {
      "type": "integer",
      "const": 100
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "scan_per_deploy": true,
  "ai_ranker_config": {
    "dedup_threshold": 0.85,
    "severity_weights": {
      "critical": 5,
      "serious": 3,
      "moderate": 2
    }
  },
  "human_lead_gate": true,
  "vpat_signoff_required": true,
  "alt_text_confidence_floor": 0.8,
  "caption_review_rate_pct": 20,
  "regulated_content_review_pct": 100
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scan_per_deploy": false,
  "human_lead_gate": false,
  "vpat_signoff_required": false,
  "alt_text_confidence_floor": 0.3,
  "caption_review_rate_pct": 0,
  "regulated_content_review_pct": 0
}
]]></code>
    <note>Scans skipped; no human gate; VPAT unsigned; alt-text confidence floor too low; regulated content unreviewed.</note>
  </example>

  <section title="Forbidden patterns">
    <forbidden>
      <pattern id="f1">scan_per_deploy == false</pattern>
      <pattern id="f2">human_lead_gate == false</pattern>
      <pattern id="f3">vpat_signoff_required == false</pattern>
      <pattern id="f4">regulated_content_review_pct &lt; 100</pattern>
    </forbidden>
  </section>

  <reference path="scripts/validate-ai-accessibility-automation-2026.py">Validator script enforcing this contract.</reference>
</text>
