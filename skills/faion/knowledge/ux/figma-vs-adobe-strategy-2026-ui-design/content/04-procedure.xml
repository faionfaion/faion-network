<text id="04-procedure" title="Figma vs Adobe Strategy 2026 Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply figma-vs-adobe-strategy-2026 end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="collect-inputs">
      <input>Team + tasks + budget + agent reqs</input>
      <action>Quantify each input; produce a normalised inputs JSON.</action>
      <output>Inputs block</output>
    </step>
    <step n="2" name="score-vendors">
      <input>Inputs</input>
      <action>Score each vendor on five axes; produce score matrix.</action>
      <output>Score matrix</output>
    </step>
    <step n="3" name="quantify-migration">
      <input>Score matrix + current state</input>
      <action>Estimate component-port + training + license overlap.</action>
      <output>Migration cost block</output>
    </step>
    <step n="4" name="write-record">
      <input>All blocks</input>
      <action>Emit JSON decision record with rationale.</action>
      <output>record.json</output>
    </step>
    <step n="5" name="schedule-revisit">
      <input>Record</input>
      <action>Add 6-month calendar reminder + Config / MAX watch.</action>
      <output>Calendar entry</output>
    </step>
  </section>
</text>
