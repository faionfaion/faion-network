<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Accessibility-First Design Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "wcag_target",
    "tokens",
    "archetypes"
  ],
  "properties": {
    "wcag_target": {
      "enum": [
        "2.1-AA",
        "2.2-AA"
      ]
    },
    "tokens": {
      "type": "object",
      "required": [
        "color_pairs",
        "motion",
        "spacing"
      ],
      "properties": {
        "color_pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "fg",
              "bg",
              "contrast_ratio",
              "pass"
            ]
          }
        },
        "motion": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "reduced_motion_variant"
            ]
          }
        },
        "spacing": {
          "type": "object"
        }
      }
    },
    "archetypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "focus_visible"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "wcag_target": "2.2-AA",
  "tokens": {
    "color_pairs": [
      {
        "fg": "#111",
        "bg": "#fff",
        "contrast_ratio": 18.7,
        "pass": true
      }
    ],
    "motion": [
      {
        "name": "fade-in-200",
        "reduced_motion_variant": "none"
      }
    ],
    "spacing": {
      "unit": "logical"
    }
  },
  "archetypes": [
    {
      "name": "button-primary",
      "role": "button",
      "focus_visible": "2px outline accent-500"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tokens": {}
}
]]></code>
    <note>Missing wcag_target, archetypes; tokens lacks color_pairs/motion/spacing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>A color_pair with pass=false in tokens.color_pairs.</item>
      <item>A motion token without reduced_motion_variant.</item>
      <item>An archetype without focus_visible declaration.</item>
    </list>
  </section>

  <reference path="scripts/validate-accessibility-first-design.py">Validator script</reference>
</text>
