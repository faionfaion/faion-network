{
  "__faion_header__": {
    "purpose": "Token scanner glob list + violation severity mapping.",
    "consumes": "see content/02-output-contract.xml inputs",
    "produces": "artefact conforming to content/02-output-contract.xml",
    "depends_on": "content/01-core-rules.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  },
  "ds_root": "FILL_ME",
  "token_map": "FILL_ME",
  "doc_generator": {
    "source": "packages/ds/src",
    "story_root": "packages/ds/stories",
    "output": "packages/ds/docs"
  },
  "token_scanner": {
    "block_on_violation": true,
    "scan_globs": [
      "apps/**/*.tsx"
    ]
  },
  "variant_generator": {
    "visreg_provider": "chromatic",
    "max_variants_per_component": 24
  },
  "human_review_required": true
}
