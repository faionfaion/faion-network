<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Design System Drift Dashboard Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply design-system-drift-dashboard end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="gather-inputs">
      <input>Consumer repo list + token map</input>
      <action>Clone each repo at HEAD; load v2 token map and component mapping.</action>
      <output>Working set</output>
    </step>
    <step n="2" name="scan-repos">
      <input>Working set</input>
      <action>Grep each repo for hardcoded literals; classify as adoption or drift.</action>
      <output>Raw findings</output>
    </step>
    <step n="3" name="compute-metrics">
      <input>Raw findings</input>
      <action>Compute adoption_pct + drift_count.</action>
      <output>Metrics block</output>
    </step>
    <step n="4" name="render-report">
      <input>Metrics + threshold</input>
      <action>Emit JSON drift report + Markdown exec summary.</action>
      <output>report.json + report.md</output>
    </step>
    <step n="5" name="schedule-cadence">
      <input>CI pipeline</input>
      <action>Weekly run + 8-week persistence + threshold alerting.</action>
      <output>Scheduled job</output>
    </step>
  </section>
</text>
