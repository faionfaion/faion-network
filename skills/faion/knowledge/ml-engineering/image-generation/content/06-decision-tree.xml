<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Image Generation Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Task → model selector.</summary>

  <decision-tree>
    <root-question id="q-text">Does the image need readable text?</root-question>
    <branch when="text_in_image == true">
      <conclusion ref="model-by-task" verdict="dall-e-3 or gpt-4o-image"/>
    </branch>
    <branch when="text_in_image == false">
      <question id="q-brand">Need brand-consistent identity across many images?</question>
      <branch when="brand_consistent == true">
        <conclusion ref="lora-for-brand" verdict="sd-lora trained on 10-20 refs OR flux-kontext"/>
      </branch>
      <branch when="brand_consistent == false">
        <question id="q-bulk">Daily volume ≥ 1000 images?</question>
        <branch when="bulk == true">
          <conclusion ref="schnell-for-bulk" verdict="flux-schnell self-hosted"/>
        </branch>
        <branch when="bulk == false">
          <question id="q-photoreal">Photorealism critical?</question>
          <branch when="photoreal == true">
            <conclusion ref="model-by-task" verdict="flux-pro"/>
          </branch>
          <branch when="photoreal == false">
            <conclusion ref="model-by-task" verdict="dall-e-3 default; flux-dev for stylised"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="bulk news headers → flux-schnell self-hosted">
    <code lang="text"><![CDATA[
text=false → brand=false → bulk=true → flux-schnell, concurrency 8
]]></code>
  </example>
</text>
