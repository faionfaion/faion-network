{
  "__faion_header__": {
    "purpose": "Template fixture for gemini-basics: gemini-config-basic.schema.json",
    "consumes": "content/01-core-rules.xml",
    "produces": "JSON Schema artefact",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "small"
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/gemini-config-basic",
  "_purpose": "JSON Schema for starter Gemini config.",
  "_consumes": "operator-authored config",
  "_produces": "validator verdict",
  "_depends_on": "content/02-output-contract.xml",
  "_token_budget_impact": "validator only",
  "type": "object",
  "required": [
    "model",
    "temperature",
    "max_output_tokens"
  ],
  "properties": {
    "model": {
      "type": "string",
      "pattern": "^gemini-"
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "max_output_tokens": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65536
    },
    "response_mime_type": {
      "enum": [
        "text/plain",
        "application/json"
      ]
    },
    "streaming": {
      "type": "boolean"
    }
  }
}
