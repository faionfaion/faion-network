<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Image Generation Tools Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for ImageService config + per-call audit log entry.</summary>

  <section title="Config schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/img-gen-tools-config",
  "type": "object",
  "required": ["providers", "fallback_chain", "cache_uri", "template_library_path", "attribution_enabled"],
  "properties": {
    "providers": {"type": "array", "items": {"enum": ["dalle3", "flux-schnell", "sdxl", "stability"]}, "minItems": 1},
    "fallback_chain": {"type": "array", "items": {"type": "string"}, "minItems": 2},
    "cache_uri": {"type": "string", "format": "uri"},
    "template_library_path": {"type": "string"},
    "attribution_enabled": {"type": "boolean", "const": true}
  }
}]]></code>
  </section>

  <section title="Per-call audit log entry">
    <code lang="json"><![CDATA[{
  "ts": "2026-05-22T14:32:00Z",
  "tenant_id": "tenant-123",
  "provider_used": "dalle3",
  "input_hash": "<sha1>",
  "revised_prompt": "...",
  "storage_uri": "s3://.../...png",
  "cost_usd": 0.04,
  "fallback_count": 0
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "providers": ["dalle3", "flux-schnell", "sdxl"],
  "fallback_chain": ["dalle3", "flux-schnell", "sdxl"],
  "cache_uri": "s3://img-cache/",
  "template_library_path": "templates/prompt-templates.py",
  "attribution_enabled": true
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"providers": [], "fallback_chain": ["dalle3"], "cache_uri": "", "attribution_enabled": false}]]></code>
      <note>Fails: empty providers, fallback chain &lt;2, empty cache URI, attribution off.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>providers non-empty.</item>
      <item>fallback_chain has ≥2 entries.</item>
      <item>cache_uri is a reachable URI.</item>
      <item>attribution_enabled = true.</item>
    </list>
  </section>
</text>
