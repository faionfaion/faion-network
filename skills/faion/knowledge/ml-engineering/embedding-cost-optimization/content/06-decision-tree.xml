<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Embedding Cost Optimization Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes cost level + bench availability + corpus size to lever priority.</summary>

  <decision-tree>
    <root-question id="q-cost-level">Monthly embedding cost ≥$500?</root-question>
    <branch when="monthly_cost &lt; 100">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="monthly_cost &gt;= 500">
      <question id="q-bench">Eval bench available to gate quality?</question>
      <branch when="bench_available == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
      <branch when="bench_available == true">
        <question id="q-scale">Corpus &gt;1M vectors?</question>
        <branch when="corpus_size &lt; 1000000">
          <conclusion ref="r1-dedup-on-ingest"/>
        </branch>
        <branch when="corpus_size &gt;= 1000000">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="kb-corpus-q2-2026">
    monthly_cost=2400 → bench_available=true → corpus_size=2_000_000 → run-the-checklist (all 5 levers).
  </example>
</text>
