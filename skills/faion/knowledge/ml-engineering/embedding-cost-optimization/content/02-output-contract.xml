<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Embedding Cost Optimization Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the cost-opt-config artefact + examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/embedding-cost-optimization.json",
  "type": "object",
  "required": ["dedup_on_ingest", "batch_size", "cache_enabled", "matryoshka_dim", "two_stage_retrieval", "recall_tolerance_pp"],
  "properties": {
    "dedup_on_ingest": {"type": "boolean", "const": true},
    "batch_size": {"type": "integer", "minimum": 32, "maximum": 2048},
    "cache_enabled": {"type": "boolean"},
    "matryoshka_dim": {"type": "integer", "minimum": 256, "maximum": 3072},
    "two_stage_retrieval": {"type": "boolean"},
    "recall_tolerance_pp": {"type": "number", "minimum": 0.0, "maximum": 5.0}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">dedup_on_ingest=false (rule r1)</item>
      <item id="f2">batch_size &lt;32 or &gt;2048 (rule r2)</item>
      <item id="f3">matryoshka_dim &lt;256 (rule r4)</item>
      <item id="f4">recall_tolerance_pp &gt;5 (rule r4)</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "dedup_on_ingest": true,
  "batch_size": 512,
  "cache_enabled": true,
  "matryoshka_dim": 512,
  "two_stage_retrieval": true,
  "recall_tolerance_pp": 1.0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dedup_on_ingest": false,
  "batch_size": 1,
  "cache_enabled": false,
  "matryoshka_dim": 64,
  "two_stage_retrieval": false,
  "recall_tolerance_pp": 25.0
}
]]></code>
    <note>dedup off (f1); batch=1 (f2); dim &lt;256 (f3); tolerance &gt;5 (f4).</note>
  </example>

  <reference path="scripts/validate-embedding-cost-optimization.py">Validator script</reference>
</text>
