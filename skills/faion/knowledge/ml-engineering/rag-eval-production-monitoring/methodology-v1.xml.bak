<methodology slug="rag-eval-production-monitoring">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>rag-engineer</domain>
    <summary>Monitor a live RAG system by logging per-query latency, source count, and user feedback signals, then detecting anomalies (latency spikes, feedback drops) against calibrated production baselines.</summary>
