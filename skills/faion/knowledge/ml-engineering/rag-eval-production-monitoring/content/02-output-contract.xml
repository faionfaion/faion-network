<text id="02-output-contract" title="rag-eval-production-monitoring Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one rag-eval-production-monitoring output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rag-monitor-rolling-summary",
  "type": "object",
  "required": ["window", "n_queries", "latency", "hit_rate", "feedback", "thresholds", "anomalies"],
  "properties": {
    "window": {"type": "string"},
    "n_queries": {"type": "integer"},
    "latency": {"type": "object", "required": ["p50_ms", "p95_ms"]},
    "hit_rate": {"type": "number"},
    "feedback": {"type": "object", "required": ["thumbs_up", "thumbs_down"]},
    "thresholds": {"type": "object"},
    "anomalies": {"type": "array"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "window": "24h",
  "n_queries": 1200,
  "latency": {"p50_ms": 480, "p95_ms": 1800},
  "hit_rate": 0.91,
  "feedback": {"thumbs_up": 90, "thumbs_down": 7},
  "thresholds": {"latency_p95_ms": 2000, "hit_rate": 0.88, "thumbs_down_ratio": 0.1},
  "anomalies": []
}
    ]]></code>
    <note>Valid: rolling window, lightweight metrics, calibrated thresholds, no anomalies.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"window": "24h", "n_queries": 1200}
    ]]></code>
    <note>Invalid: missing latency, hit_rate, feedback, thresholds, anomalies.</note>
  </example>

  <reference path="scripts/validate-rag-eval-production-monitoring.py">Validates an output file against this schema.</reference>
</text>
