<methodology slug="eu-ai-act-compliance">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>ml-engineer</domain>
    <summary>Risk classification, documentation, and controls for EU AI Act compliance. Phased enforcement: prohibited practices (Feb 2025), GPAI (Aug 2025), high-risk (Aug 2026).</summary>
    <difficulty>advanced</difficulty>
    <created>2026-04-26</created>
    <tags>
      <tag>eu-ai-act</tag>
      <tag>compliance</tag>
      <tag>risk-classification</tag>
