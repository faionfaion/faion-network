<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="LLM Cost Basics — Pricing, Usage Tracking, Baseline Optimisation Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is per-call metadata logged?</root-question>
    <branch when="per_call_metadata_logged == false">
      <conclusion ref="per-call-metadata" verdict="apply rule per-call-metadata"/>
    </branch>
    <branch when="cache_baseline_applied == false">
      <conclusion ref="cache-as-baseline" verdict="apply rule cache-as-baseline"/>
    </branch>
    <branch when="history_truncated == false">
      <conclusion ref="truncate-history-default" verdict="apply rule truncate-history-default"/>
    </branch>
    <branch when="else">
      <conclusion ref="default-cheap-route" verdict="apply rule default-cheap-route"/>
    </branch>
  </decision-tree>
</text>
