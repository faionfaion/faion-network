<text id="06-decision-tree" title="LLM Decision Framework — Decision Tree" version="1.1.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root">Does prompting on sample queries already meet the accuracy target?</root-question>
    <branch when="prompt_score &gt;= target_accuracy">
      <conclusion ref="r1-prompt-first">Pick prompt-only. Document baseline + cost; revisit on drift.</conclusion>
    </branch>
    <branch when="prompt_score &lt; target_accuracy">
      <question id="q-sub">What is data freshness frequency?</question>
        <branch when="freshness_freq == 'daily' OR 'hourly'">
          <conclusion ref="r2-freshness-bias-rag">Pick RAG. Stand up vector index + reranker; refresh on schedule.</conclusion>
        </branch>
        <branch when="freshness_freq == 'monthly_or_stable' AND fine_tune_score &gt; rag_score + 5pts">
          <conclusion ref="r2-freshness-bias-rag">Pick fine-tune. Run finetuning methodology.</conclusion>
        </branch>
        <branch when="freshness_freq == 'monthly_or_stable' AND fine_tune_score - rag_score &lt; 5pts">
          <conclusion ref="r5-team-skill-check">Pick RAG (cheaper, reversible). FT only if delta is decisive.</conclusion>
        </branch>
        <branch when="complex_multi_hop AND rag_alone_insufficient">
          <conclusion ref="r2-freshness-bias-rag">Pick RAFT (RAG + fine-tune). Document hybrid plan.</conclusion>
        </branch>
    </branch>
    <example trace="worked-example">
      <p>Support assistant, target 80%, prompt 68%, RAG 82%, FT 84%, freshness daily → RAG branch (FT incompatible with daily) → chosen=RAG.</p>
    </example>
  </decision-tree>
</text>
