<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Model Context Protocol — Architecture and Core Primitives — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `mcp-architecture`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://mcp-architecture/output.schema.json",
  "type": "object",
  "required": ["spec_name", "protocol_version", "primitives", "transport", "auth_method"],
  "properties": {
    "spec_name": {"type": "string"},
    "protocol_version": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "primitives": {"type": "object", "required": ["tools", "resources", "prompts"]},
    "transport": {"enum": ["stdio", "http_sse", "streamable_http"]},
    "auth_method": {"enum": ["none_local", "oauth2.1_pkce", "api_key"]}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "spec_name": "filesystem-mcp",
  "protocol_version": "2025-11-25",
  "primitives": {
    "tools": [
      "read_file",
      "write_file"
    ],
    "resources": [
      "file://"
    ],
    "prompts": []
  },
  "transport": "stdio",
  "auth_method": "none_local"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "spec_name": "",
  "protocol_version": "v1",
  "primitives": {},
  "transport": "ws",
  "auth_method": "trust"
}
]]></code>
      <note>Invalid: empty name; bad version format; empty primitives; bogus transport; bogus auth.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-mcp-architecture.py --self-test exits 0.</item>
    </list>
  </section>
</text>
