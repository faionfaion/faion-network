<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Local LLM Ollama Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>JSON Schema for ollama-config.json.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ollama-config",
  "type": "object",
  "required": ["model", "quantisation", "modelfile_path", "openai_compat", "fallback_model"],
  "properties": {
    "model": {"type": "string", "minLength": 1},
    "quantisation": {"enum": ["q4_0", "q4_K_M", "q5_0", "q5_K_M", "q6_K", "q8_0", "f16"]},
    "modelfile_path": {"type": "string"},
    "openai_compat": {"type": "boolean", "const": true},
    "base_url": {"type": "string", "pattern": "^http"},
    "fallback_model": {"type": "string", "minLength": 1},
    "vram_required_gb": {"type": "number", "minimum": 0}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "model": "llama3.1:8b",
  "quantisation": "q5_K_M",
  "modelfile_path": "templates/Modelfile",
  "openai_compat": true,
  "base_url": "http://localhost:11434/v1",
  "fallback_model": "claude-sonnet-4-5",
  "vram_required_gb": 6
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"model": "llama3.1", "quantisation": "q4_0", "openai_compat": false}]]></code>
      <note>Fails: model not version-pinned, openai_compat must be true, modelfile_path + fallback_model missing.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>model includes a tag.</item>
      <item>quantisation chosen explicitly (≥q5_K_M for serious work).</item>
      <item>modelfile_path exists.</item>
      <item>openai_compat = true.</item>
      <item>fallback_model is named.</item>
    </list>
  </section>
</text>
