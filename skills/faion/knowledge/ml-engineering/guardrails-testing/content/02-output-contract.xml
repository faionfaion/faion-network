<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Guardrails Testing Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Schema for guardrail-test-report.json.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/guardrails-testing.json",
  "type": "object",
  "required": ["artefact_id", "version", "last_reviewed", "system_under_test", "suites", "verdict"],
  "properties": {
    "artefact_id": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "system_under_test": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"},
        "model": {"type": "string"}
      }
    },
    "suites": {
      "type": "object",
      "required": ["security", "accuracy", "perf"],
      "properties": {
        "security": {
          "type": "object",
          "required": ["payloads_total", "blocked", "leaked"],
          "properties": {
            "payloads_total": {"type": "integer", "minimum": 1},
            "blocked": {"type": "integer", "minimum": 0},
            "leaked": {"type": "integer", "minimum": 0}
          }
        },
        "accuracy": {
          "type": "object",
          "required": ["legit_total", "passed", "false_positive_rate", "fp_budget"],
          "properties": {
            "legit_total": {"type": "integer", "minimum": 1},
            "passed": {"type": "integer", "minimum": 0},
            "false_positive_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "fp_budget": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "perf": {
          "type": "object",
          "required": ["p50_ms", "p99_ms", "throughput_rps", "baseline_p99_ms"],
          "properties": {
            "p50_ms": {"type": "number"},
            "p99_ms": {"type": "number"},
            "throughput_rps": {"type": "number"},
            "baseline_p99_ms": {"type": "number"}
          }
        }
      }
    },
    "verdict": {"enum": ["pass", "fail"]}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "gtr-2026-05-22",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22",
  "system_under_test": {"name": "support-bot", "version": "1.4.2", "model": "gpt-4o"},
  "suites": {
    "security": {"payloads_total": 250, "blocked": 248, "leaked": 2},
    "accuracy": {"legit_total": 500, "passed": 497, "false_positive_rate": 0.006, "fp_budget": 0.01},
    "perf": {"p50_ms": 22, "p99_ms": 180, "throughput_rps": 80, "baseline_p99_ms": 175}
  },
  "verdict": "pass"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "system_under_test": {},
  "suites": {"security": {}},
  "verdict": "unknown"
}
]]></code>
    <note>system_under_test missing required fields; suites incomplete; verdict not in enum; missing artefact_id/version/last_reviewed.</note>
  </example>

