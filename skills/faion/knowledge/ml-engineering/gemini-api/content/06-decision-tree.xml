<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Gemini API Integration — Decision Tree" version="1.1.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root">What is the primary use case?</root-question>
    <branch when="usecase == 'long_context' (&gt;=200k tokens)">
      <question id="q-sub">Is context repeated across requests?</question>
        <branch when="context_reuse_count &gt;= 5 AND context_tokens &gt;= 1024">
          <conclusion ref="r3-cache-when-context-repeats">Use context caching. gemini-3-pro-001 + cache_ttl_s=3600.</conclusion>
        </branch>
        <branch when="context_reuse_count &lt; 5">
          <conclusion ref="r5-model-version-pinned">Skip caching. gemini-3-pro-001 pinned. Use long-context window directly.</conclusion>
        </branch>
    </branch>
    <branch when="usecase == 'realtime_voice_video'">
      <conclusion ref="r6-live-api-resource-budget">Use Live API. gemini-2.0-flash-live or gemini-3-flash. Cap session length.</conclusion>
    </branch>
    <branch when="usecase == 'general_chat'">
      <conclusion ref="r5-model-version-pinned">gemini-3-flash-001 default. Pin version. Wire safety + retry.</conclusion>
    </branch>
    <example trace="worked-example">
      <p>Document QA over 800k-token corpus reused 50x/day → long context branch → r3 caching → gemini-3-pro-001 + cache_ttl_s=3600.</p>
    </example>
  </decision-tree>
</text>
