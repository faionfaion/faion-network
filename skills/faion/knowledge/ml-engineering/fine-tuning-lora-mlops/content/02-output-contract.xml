<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fine-tuning with LoRA (PEFT + TRL) Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the fine-tuning-lora artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/fine-tuning-lora.json",
  "type": "object",
  "required": [
    "run_id",
    "base_model",
    "rank",
    "alpha",
    "lr",
    "epochs"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "base_model": {
      "type": "string"
    },
    "rank": {
      "type": "integer"
    },
    "alpha": {
      "type": "integer"
    },
    "lr": {
      "type": "number"
    },
    "epochs": {
      "type": "integer"
    },
    "best_eval_score": {
      "type": "number"
    },
    "adapter_uri": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "run_id": "example-run_id",
  "base_model": "example-base_model",
  "rank": 1,
  "alpha": 1,
  "lr": 1.0,
  "epochs": 1,
  "best_eval_score": 1.0,
  "adapter_uri": "example-adapter_uri"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "run_id": 123
}
]]></code>
    <note>field "run_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-fine-tuning-lora.py">schema validator</reference>
</text>
