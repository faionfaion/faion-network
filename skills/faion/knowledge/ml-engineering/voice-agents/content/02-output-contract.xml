<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Voice Agents Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the voice-agents artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/voice-agents.json",
  "type": "object",
  "required": [
    "call_id",
    "agent_version",
    "avg_handle_time_s",
    "escalation_rate",
    "p95_stt_ms",
    "p95_llm_ms"
  ],
  "properties": {
    "call_id": {
      "type": "string"
    },
    "agent_version": {
      "type": "string"
    },
    "avg_handle_time_s": {
      "type": "number"
    },
    "escalation_rate": {
      "type": "number"
    },
    "p95_stt_ms": {
      "type": "number"
    },
    "p95_llm_ms": {
      "type": "number"
    },
    "p95_tts_ms": {
      "type": "number"
    },
    "transcript_url": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "call_id": "example-call_id",
  "agent_version": "example-agent_version",
  "avg_handle_time_s": 1.0,
  "escalation_rate": 1.0,
  "p95_stt_ms": 1.0,
  "p95_llm_ms": 1.0,
  "p95_tts_ms": 1.0,
  "transcript_url": "example-transcript_url"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "call_id": 123
}
]]></code>
    <note>field "call_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-voice-agents.py">schema validator</reference>
</text>
