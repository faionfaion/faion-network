<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="OpenAI Supervised Fine-Tuning (SFT) — Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure for applying `fine-tuning-openai-sft`. Each step lists input artifact, action, output artifact. Decision gates live in content/06-decision-tree.xml.</summary>

  <section title="Procedure">
    <step n="1" name="prepare-job">
      <input>file IDs + base + hyperparams.</input>
      <action>Assemble openai.fine_tuning.jobs.create() args.</action>
      <output>Job-create payload.</output>
    </step>

    <step n="2" name="launch">
      <input>Job-create payload.</input>
      <action>Call API; receive job_id.</action>
      <output>job_id string.</output>
    </step>

    <step n="3" name="poll">
      <input>job_id.</input>
      <action>Poll with exponential backoff; surface events.</action>
      <output>Final status.</output>
    </step>

    <step n="4" name="record-model-id">
      <input>Final status with fine_tuned_model.</input>
      <action>Append to model-id-registry.yaml.</action>
      <output>Registry entry.</output>
    </step>
  </section>
</text>
