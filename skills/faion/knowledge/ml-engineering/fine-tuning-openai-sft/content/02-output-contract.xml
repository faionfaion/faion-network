<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OpenAI Supervised Fine-Tuning (SFT) — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `fine-tuning-openai-sft`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://fine-tuning-openai-sft/output.schema.json",
  "type": "object",
  "required": ["base_model", "training_file_id", "validation_file_id", "n_epochs", "lr_multiplier", "job_id", "fine_tuned_model_id"],
  "properties": {
    "base_model": {"type": "string"},
    "training_file_id": {"type": "string", "pattern": "^file-"},
    "validation_file_id": {"type": "string", "pattern": "^file-"},
    "n_epochs": {"type": "integer", "minimum": 1, "maximum": 8},
    "lr_multiplier": {"type": "number", "exclusiveMinimum": 0, "maximum": 4},
    "job_id": {"type": "string", "pattern": "^ftjob-"},
    "fine_tuned_model_id": {"type": "string", "pattern": "^ft:"}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "base_model": "gpt-4o-mini-2024-07-18",
  "training_file_id": "file-abc123",
  "validation_file_id": "file-def456",
  "n_epochs": 3,
  "lr_multiplier": 1.0,
  "job_id": "ftjob-xyz789",
  "fine_tuned_model_id": "ft:gpt-4o-mini-2024-07-18:org::tone_v1"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "base_model": "",
  "training_file_id": "x",
  "validation_file_id": "",
  "n_epochs": 50,
  "lr_multiplier": 100.0,
  "job_id": "",
  "fine_tuned_model_id": ""
}
]]></code>
      <note>Invalid: empty base; file IDs not file- prefixed; epochs &gt; 8; lr_multiplier way too high; missing job/model IDs.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-fine-tuning-openai-sft.py --self-test exits 0.</item>
    </list>
  </section>
</text>
