<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Vision Document Extraction Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Was the doc-type classifier confident?</root-question>
    <branch when="doc_type_confidence &lt; 0.7">
      <conclusion ref="doc-type-router" verdict="apply rule doc-type-router"/>
    </branch>
    <branch when="extractor schema failed">
      <conclusion ref="pydantic-required" verdict="apply rule pydantic-required"/>
    </branch>
    <branch when="post_validator failed">
      <conclusion ref="review-queue-on-fail" verdict="apply rule review-queue-on-fail"/>
    </branch>
    <branch when="post_validator passed AND per-field confidence &gt;= 0.8">
      <conclusion ref="per-field-confidence" verdict="apply rule per-field-confidence"/>
    </branch>
  </decision-tree>
</text>
