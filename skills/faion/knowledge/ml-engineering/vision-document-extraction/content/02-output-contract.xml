<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vision Document Extraction Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the vision-document-extraction artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/vision-document-extraction.json",
  "type": "object",
  "required": [
    "doc_id",
    "doc_type",
    "validation_status",
    "review_queue_id"
  ],
  "properties": {
    "doc_id": {
      "type": "string"
    },
    "doc_type": {
      "type": "string"
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    },
    "field_confidence": {
      "type": "object",
      "additionalProperties": true
    },
    "validation_status": {
      "type": "string"
    },
    "review_queue_id": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "doc_id": "example-doc_id",
  "doc_type": "example-doc_type",
  "fields": {
    "k": "v"
  },
  "field_confidence": {
    "k": "v"
  },
  "validation_status": "example-validation_status",
  "review_queue_id": "example-review_queue_id"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "doc_id": 123
}
]]></code>
    <note>field "doc_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-vision-document-extraction.py">schema validator</reference>
</text>
