<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vector DB Dev Setup — Output Contract" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Pins dev-setup.yaml shape.</summary>

  <output-contract>
    <required>
      <field name="db_kind" type="enum" values="qdrant|weaviate|milvus|pgvector|chroma"/>
      <field name="image_tag" type="string"/>
      <field name="data_volume" type="string"/>
      <field name="client_version" type="string"/>
      <field name="smoke_passed" type="boolean"/>
      <field name="gitignore_entries" type="array"/>
    </required>

    <forbidden>
      <pattern id="f1">image_tag ends with ":latest" (r1-pin-image-version)</pattern>
      <pattern id="f2">data_volume empty (r2-persistent-volume)</pattern>
      <pattern id="f3">client_version major.minor != image_tag major.minor (r3-matching-client-version)</pattern>
      <pattern id="f4">smoke_passed == false (r4-smoke-test)</pattern>
    </forbidden>

    <schema-reference path="templates/dev-setup.schema.yaml"/>
  </output-contract>
</text>
