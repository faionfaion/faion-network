<text id="04-procedure" title="Fine-tuning OpenAI — Production Pipeline Procedure" version="1.1.0" est_tokens="700" depth="reference">
  <summary>5-step procedure for applying fine-tuning-openai-production.</summary>

  <section title="Procedure">
    <step n="1" name="gather-inputs">
      <input>Prerequisites listed in AGENTS.md</input>
      <action>Collect all required artefacts; validate presence + format.</action>
      <output>Validated input bundle.</output>
      <decision-gate>All prerequisites present?</decision-gate>
    </step>
    <step n="2" name="apply-core-rules">
      <input>Validated input bundle.</input>
      <action>Walk core rules from 01-core-rules.xml; flag any violations.</action>
      <output>Rule-check report.</output>
    </step>
    <step n="3" name="route-via-decision-tree">
      <input>Rule-check report.</input>
      <action>Traverse 06-decision-tree.xml; pick conclusion path.</action>
      <output>Selected rule / branch.</output>
    </step>
    <step n="4" name="produce-artefact">
      <input>Selected rule / branch.</input>
      <action>Fill template under templates/ matching the methodology produces= field.</action>
      <output>Draft artefact conforming to 02-output-contract.xml schema.</output>
    </step>
    <step n="5" name="validate-and-publish">
      <input>Draft artefact.</input>
      <action>Run scripts/validate-fine-tuning-openai-production.py on the draft; remediate violations; publish.</action>
      <output>Validated artefact; audit log entry.</output>
      <decision-gate>Validator exit code = 0?</decision-gate>
    </step>
  </section>
</text>
