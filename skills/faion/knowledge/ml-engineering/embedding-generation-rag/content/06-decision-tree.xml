<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Embedding Generation Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes corpus class + provider to embedder config.</summary>

  <decision-tree>
    <root-question id="q-semantic-needed">Semantic similarity needed (vs pure keyword)?</root-question>
    <branch when="semantic_needed == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="semantic_needed == true">
      <question id="q-provider">Provider choice?</question>
      <branch when="provider == cohere">
        <conclusion ref="r6-provider-specific"/>
      </branch>
      <branch when="provider == openai OR provider == voyage OR provider == local">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="kb-corpus-q2-2026">
    semantic_needed=true → provider=openai → run-the-checklist.
  </example>
</text>
