<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Vision Agentic Pipeline — Production Architecture Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Has the pipeline received a new image event?</root-question>
    <branch when="image_hash exists in result cache">
      <conclusion ref="idempotent-by-hash" verdict="apply rule idempotent-by-hash"/>
    </branch>
    <branch when="doc_type unknown after router">
      <conclusion ref="router-cheap-model" verdict="apply rule router-cheap-model"/>
    </branch>
    <branch when="extractor schema validation failed once">
      <conclusion ref="retry-on-schema-fail" verdict="apply rule retry-on-schema-fail"/>
    </branch>
    <branch when="extractor schema validation failed twice OR validator vetoed">
      <conclusion ref="validator-veto" verdict="apply rule validator-veto"/>
    </branch>
  </decision-tree>
</text>
