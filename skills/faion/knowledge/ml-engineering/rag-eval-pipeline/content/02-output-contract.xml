<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="rag-eval-pipeline Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one rag-eval-pipeline output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rag-eval-pipeline-report",
  "type": "object",
  "required": ["snapshot", "n_questions", "retrieval", "generation", "per_query"],
  "properties": {
    "snapshot": {
      "type": "object",
      "required": ["pipeline_version", "judge_model", "embedding_model", "test_set_hash"]
    },
    "n_questions": {"type": "integer", "minimum": 20},
    "retrieval": {
      "type": "object",
      "required": ["precision_at_5", "recall_at_5", "mrr", "hit_rate"]
    },
    "generation": {
      "type": "object",
      "required": ["faithfulness", "answer_relevance", "context_relevance"]
    },
    "per_query": {"type": "array"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "snapshot": {"pipeline_version": "v0.4.1", "judge_model": "gpt-4o", "embedding_model": "text-embedding-3-large", "test_set_hash": "sha256:abcd"},
  "n_questions": 50,
  "retrieval": {"precision_at_5": 0.74, "recall_at_5": 0.81, "mrr": 0.77, "hit_rate": 0.94},
  "generation": {"faithfulness": 0.92, "answer_relevance": 0.88, "context_relevance": 0.80},
  "per_query": []
}
    ]]></code>
    <note>Valid: snapshot complete, both metric blocks present.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"n_questions": 50, "retrieval": {"mrr": 0.7}}
    ]]></code>
    <note>Invalid: missing snapshot, generation metrics, per_query.</note>
  </example>

  <reference path="scripts/validate-rag-eval-pipeline.py">Validates an output file against this schema.</reference>
</text>
