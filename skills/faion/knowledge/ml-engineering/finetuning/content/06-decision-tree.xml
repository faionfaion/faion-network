<text id="06-decision-tree" title="LLM Fine-tuning (General Guide) — Decision Tree" version="1.1.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root">Did prompt+RAG baseline plateau (gap to target ≥10pts after best-of-N prompting)?</root-question>
    <branch when="baseline_gap_pts &lt; 10">
      <conclusion ref="r1-prompt-rag-first">Skip fine-tuning. Iterate on prompts / retrieval.</conclusion>
    </branch>
    <branch when="baseline_gap_pts &gt;= 10 AND data_volume &gt;= 100">
      <question id="q-sub">What is data volume × hardware budget?</question>
        <branch when="data_volume &lt;= 10000 AND provider == 'openai'">
          <conclusion ref="r4-technique-by-budget">API SFT via OpenAI fine-tuning endpoint.</conclusion>
        </branch>
        <branch when="data_volume &lt;= 100000 AND gpu_count == 1">
          <conclusion ref="r4-technique-by-budget">QLoRA on Unsloth/Axolotl. 4-bit, single GPU.</conclusion>
        </branch>
        <branch when="data_volume &lt;= 500000 AND gpu_count &gt; 1">
          <conclusion ref="r4-technique-by-budget">LoRA on Axolotl/LLaMA-Factory. Multi-GPU.</conclusion>
        </branch>
        <branch when="data_volume &gt;= 100000 AND gpu_count &gt;= 8">
          <conclusion ref="r4-technique-by-budget">Full FT via TRL. Budget + data justify.</conclusion>
        </branch>
    </branch>
    <example trace="worked-example">
      <p>Tone task, prompt 61%, RAG 68%, target 90% → gap≥10 → 4200 ex → 1xA100 → QLoRA on Axolotl.</p>
    </example>
  </decision-tree>
</text>
