<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Guardrails Implementation Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for guardrails-config.json + violation_log record.</summary>

  <section title="Config schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/guardrails-config",
  "type": "object",
  "required": ["version", "input_pipeline", "output_pipeline", "fail_closed", "audit_retention_days"],
  "properties": {
    "version": {"type": "string"},
    "input_pipeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "order"],
        "properties": {
          "type": {"enum": ["rule_based", "moderation_api", "llm_check"]},
          "order": {"type": "integer", "minimum": 1}
        }
      }
    },
    "output_pipeline": {
      "type": "object",
      "required": ["validators", "filters"],
      "properties": {
        "validators": {"type": "array", "items": {"type": "object"}},
        "filters": {"type": "array", "items": {"type": "object"}}
      }
    },
    "fail_closed": {"type": "boolean", "const": true},
    "async_fanout": {"type": "boolean"},
    "audit_retention_days": {"type": "integer", "minimum": 90}
  }
}]]></code>
  </section>

  <section title="Violation log record schema">
    <code lang="json"><![CDATA[{
  "type": "object",
  "required": ["ts", "rule_id", "severity", "tenant_id", "feature", "input_hash"],
  "properties": {
    "ts": {"type": "string"},
    "rule_id": {"type": "string"},
    "severity": {"enum": ["low", "medium", "high", "critical"]},
    "tenant_id": {"type": "string"},
    "feature": {"type": "string"},
    "input_hash": {"type": "string"}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "version": "1.0.0",
  "input_pipeline": [
    {"type": "rule_based", "order": 1},
    {"type": "moderation_api", "order": 2},
    {"type": "llm_check", "order": 3}
  ],
  "output_pipeline": {"validators": [{"name": "no_pii"}], "filters": [{"name": "strip_links"}]},
  "fail_closed": true,
  "async_fanout": false,
  "audit_retention_days": 90
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"version": "1", "input_pipeline": [], "fail_closed": false, "audit_retention_days": 30}]]></code>
      <note>Fails: empty input_pipeline, fail_closed false, audit retention &lt;90.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>version is non-empty.</item>
      <item>input_pipeline has ≥1 entry; order strictly increasing.</item>
      <item>output_pipeline.validators distinct from filters.</item>
      <item>fail_closed = true.</item>
      <item>audit_retention_days ≥ 90.</item>
    </list>
  </section>
</text>
