<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="LLM Cost Reduction Strategies Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for cost-reduction-strategies.</summary>

  <section title="Antipatterns">

    <antipattern id="permanent-cache" severity="medium">
      <symptom>Cache entries have no TTL.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Author skipped TTL config.</root-cause>
      <fix>Set 24h TTL; bump version on prompt-template change.</fix>
    </antipattern>
    <antipattern id="router-no-eval" severity="medium">
      <symptom>Cheap-model routing without quality gate.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Eval harness was deferred.</root-cause>
      <fix>Add LLM-as-judge gate; fall back to expensive on failure.</fix>
    </antipattern>
    <antipattern id="compress-with-llm" severity="medium">
      <symptom>Prompt compression done with an LLM call.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Author skipped mechanical compression first.</root-cause>
      <fix>Mechanical first; LLM only on stubborn boilerplate.</fix>
    </antipattern>

  </section>
</text>
