<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="LLM Cost Reduction Strategies Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Does the request stream contain repeat prompts (cache potential)?</root-question>
    <branch when="duplicate_rate &gt; 0.2">
      <conclusion ref="cache-key-sha256" verdict="apply rule cache-key-sha256"/>
    </branch>
    <branch when="avg_prompt_tokens &gt; 1000 AND whitespace_share &gt; 0.1">
      <conclusion ref="compress-whitespace-first" verdict="apply rule compress-whitespace-first"/>
    </branch>
    <branch when="batchable_share &gt; 0.3">
      <conclusion ref="batch-only-non-interactive" verdict="apply rule batch-only-non-interactive"/>
    </branch>
    <branch when="else (mostly unique interactive prompts)">
      <conclusion ref="router-confidence-gate" verdict="apply rule router-confidence-gate"/>
    </branch>
  </decision-tree>
</text>
