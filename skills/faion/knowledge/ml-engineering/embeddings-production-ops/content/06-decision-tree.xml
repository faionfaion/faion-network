<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Embeddings Production Ops — Decision Tree" version="1.1.0" est_tokens="400">
  <decision-tree>
    <root-question id="q-root">What&apos;s the production volume tier?</root-question>
    <branch when="volume_monthly &gt;= 1_000_000">
      <conclusion ref="r1-slo-defined">Apply all five rules; ops dashboards mandatory.</conclusion>
    </branch>
    <branch when="volume_monthly &gt;= 100_000 and volume_monthly &lt; 1_000_000">
      <conclusion ref="r2-rate-limit-handling">Apply rate-limit + cost + fault tolerance; SLO optional but recommended.</conclusion>
    </branch>
    <branch when="volume_monthly &lt; 100_000">
      <conclusion ref="r5-migration-playbook">Apply migration playbook + light cost tracking; SLO not yet needed.</conclusion>
    </branch>
    <example trace="volume_monthly &gt;= 1_000_000">
      <p>Apply all five rules; ops dashboards mandatory.</p>
    </example>
  </decision-tree>
</text>
