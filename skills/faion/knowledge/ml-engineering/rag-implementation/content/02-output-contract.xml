<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="rag-implementation Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one rag-implementation output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rag-pipeline-config",
  "type": "object",
  "required": ["loaders", "chunker", "embedding", "store", "retrieval", "generation", "incremental"],
  "properties": {
    "loaders": {"type": "array", "items": {"type": "string", "enum": ["txt", "md", "pdf", "directory"]}},
    "chunker": {"type": "object", "required": ["strategy", "size"]},
    "embedding": {"type": "object", "required": ["model"]},
    "store": {"type": "object", "required": ["backend", "path"]},
    "retrieval": {"type": "object", "required": ["top_k", "query_enhancement"]},
    "generation": {"type": "object", "required": ["model", "answer_only_from_context"]},
    "incremental": {"type": "boolean"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "loaders": ["md", "pdf"],
  "chunker": {"strategy": "md-header", "size": 1024},
  "embedding": {"model": "text-embedding-3-large"},
  "store": {"backend": "chroma", "path": "./chroma-docs"},
  "retrieval": {"top_k": 10, "query_enhancement": "hyde"},
  "generation": {"model": "claude-sonnet-4-6", "answer_only_from_context": true},
  "incremental": true
}
    ]]></code>
    <note>Valid: all 7 sections present; strict prompt flag on; incremental on.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"chunker": {"strategy": "fixed"}}
    ]]></code>
    <note>Invalid: missing loaders, embedding, store, retrieval, generation, incremental.</note>
  </example>

  <reference path="scripts/validate-rag-implementation.py">Validates an output file against this schema.</reference>
</text>
