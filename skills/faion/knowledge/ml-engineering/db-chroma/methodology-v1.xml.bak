<methodology slug="db-chroma">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>rag-engineer</domain>
    <summary>Chroma is an in-process vector store backed by SQLite/HNSW, ideal for local development. Zero infrastructure, idempotent ingestion, LangChain/LlamaIndex integration.</summary>
    <tags>
      <tag>vector-database</tag>
      <tag>chroma</tag>
      <tag>rag</tag>
      <tag>prototyping</tag>
      <tag>embedding</tag>
    </tags>
    <category>vector-db</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-25</created>
    <related>
      <ref slug="db-qdrant"/>
      <ref slug="db-weaviate"/>
