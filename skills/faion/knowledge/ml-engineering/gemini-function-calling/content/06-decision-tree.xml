<text id="06-decision-tree" title="Gemini Function Calling Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is Gemini the chosen vendor AND ≥1 function-call needed (or schema-constrained JSON output)?</root-question>
    <branch when="vendor == 'gemini' AND tools.needed &gt;= 1">
      <question>Is the deployment production-grade (manual-mode required)?</question>
      <branch when="env.production == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="env.production == false">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
    <branch when="vendor != 'gemini' OR tools.needed == 0">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="Gemini + 5 manual-mode tools + production → run-the-checklist"/>
  </decision-tree>
</text>
