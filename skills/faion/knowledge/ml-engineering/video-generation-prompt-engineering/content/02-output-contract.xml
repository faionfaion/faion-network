<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Video Prompt Engineering — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins prompt-template.yaml shape.</summary>

  <output-contract>
    <required>
      <field name="provider" type="enum" values="runway|luma|veo|sora|kling"/>
      <field name="sasscl" type="object" required_keys="subject_slot,action_slot,setting,style,camera,lighting"/>
      <field name="provider_overlay" type="object"/>
      <field name="max_chars" type="integer" min="100" max="4000"/>
      <field name="eval" type="object" required_keys="rubric_path,sample_size,promotion_threshold"/>
      <field name="brand_locks" type="array" items="style|camera|lighting"/>
    </required>

    <forbidden>
      <pattern id="f1">any sasscl key missing (r1-sasscl-formula)</pattern>
      <pattern id="f2">provider_overlay missing (r2-provider-quirk-overlay)</pattern>
      <pattern id="f3">eval.sample_size &lt; 5 OR promotion_threshold &lt; 4/5 (r3-five-gen-eval-gate)</pattern>
      <pattern id="f4">max_chars exceeds provider cap (r4-max-prompt-length)</pattern>
      <pattern id="f5">brand_locks does not include all of {style, camera, lighting} (r5-brand-style-locked)</pattern>
    </forbidden>

    <schema-reference path="templates/prompt-template.schema.yaml"/>
  </output-contract>
</text>
