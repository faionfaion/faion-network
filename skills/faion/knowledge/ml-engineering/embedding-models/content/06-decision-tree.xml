<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Embedding Models Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes corpus class to candidate family.</summary>

  <decision-tree>
    <root-question id="q-recurring">New project OR provider migration AND bench set available?</root-question>
    <branch when="new_or_migration == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="new_or_migration == true">
      <question id="q-class">Corpus class?</question>
      <branch when="corpus_class == code">
        <conclusion ref="r8-mteb-task-specific"/>
      </branch>
      <branch when="corpus_class == multilingual">
        <conclusion ref="r10-asymmetric-index-query"/>
      </branch>
      <branch when="corpus_class == general OR corpus_class == legal OR corpus_class == biomedical">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="kb-corpus-q2-2026">
    new_or_migration=true → corpus_class=general → run-the-checklist (shortlist + bench).
  </example>
</text>
