<methodology slug="video-gen-basics">
  <metadata>
    <tier>geek</tier>
    <group>ai</group>
    <domain>multimodal-ai</domain>
    <summary>Generating short video clips from text or image input using Runway, Luma, Replicate, or Pika. Covers service comparison, structured prompt construction, and async generation polling.</summary>
    <tags>
      <tag>video-generation</tag>
      <tag>ai-video</tag>
      <tag>runway</tag>
      <tag>async-polling</tag>
      <tag>ffmpeg</tag>
    </tags>
