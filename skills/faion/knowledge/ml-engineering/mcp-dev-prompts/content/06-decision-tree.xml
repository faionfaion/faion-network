<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="MCP Development Prompts — Server, Debug, Architecture, Testing — Decision Tree" version="1.1.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root">What is the prompt purpose?</root-question>
    <branch when="purpose == 'scaffolding_or_template_fill'">
      <conclusion ref="r3-model-recommendation">haiku. Cheap, fast, structured fill.</conclusion>
    </branch>
    <branch when="purpose != 'scaffolding_or_template_fill'">
      <question id="q-sub">Is the purpose review / debug / cross-cutting?</question>
        <branch when="purpose == 'code_review_or_security_audit'">
          <conclusion ref="r3-model-recommendation">sonnet. Structured judgement at moderate cost.</conclusion>
        </branch>
        <branch when="purpose == 'debug_or_incident_triage'">
          <conclusion ref="r3-model-recommendation">opus. Cross-cutting reasoning; rare-but-high-impact.</conclusion>
        </branch>
        <branch when="purpose == 'test_generation' OR 'docgen'">
          <conclusion ref="r3-model-recommendation">sonnet. Structured generation.</conclusion>
        </branch>
    </branch>
    <example trace="worked-example">
      <p>MCP server create prompt → scaffolding_or_template_fill → haiku; debug.connection → debug branch → opus.</p>
    </example>
  </decision-tree>
</text>
