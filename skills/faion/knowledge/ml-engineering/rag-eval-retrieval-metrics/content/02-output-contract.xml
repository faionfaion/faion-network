<text id="02-output-contract" title="rag-eval-retrieval-metrics Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one rag-eval-retrieval-metrics output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rag-retrieval-metrics-report",
  "type": "object",
  "required": ["k", "snapshot", "per_query", "aggregate"],
  "properties": {
    "k": {"type": "integer", "minimum": 1},
    "snapshot": {"type": "object"},
    "per_query": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["query_id", "retrieved_ids", "relevant_ids", "precision", "recall", "mrr"]
      }
    },
    "aggregate": {"type": "object", "required": ["precision", "recall", "mrr", "hit_rate"]}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "k": 5,
  "snapshot": {"embedding_model": "text-embedding-3-large", "index_hash": "sha256:abcd"},
  "per_query": [{"query_id": "q1", "retrieved_ids": ["a", "b"], "relevant_ids": ["a"], "precision": 0.2, "recall": 1.0, "mrr": 1.0}],
  "aggregate": {"precision": 0.2, "recall": 1.0, "mrr": 1.0, "hit_rate": 1.0}
}
    ]]></code>
    <note>Valid: K explicit, snapshot present, per-query rows + aggregate.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"per_query": []}
    ]]></code>
    <note>Invalid: missing k, snapshot, aggregate.</note>
  </example>

  <reference path="scripts/validate-rag-eval-retrieval-metrics.py">Validates an output file against this schema.</reference>
</text>
