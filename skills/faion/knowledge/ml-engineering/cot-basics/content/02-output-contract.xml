<text id="02-output-contract" title="CoT Basics Output Contract" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Structured CoT output format + parser regex.</summary>

  <section title="Output format">
    <code lang="text"><![CDATA[<reasoning>
{step 1}
{step 2}
...
</reasoning>
<answer>{final answer, one line}</answer>
]]></code>
  </section>

  <section title="JSON Schema (parsed)">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["reasoning", "answer"],
  "properties": {
    "reasoning": {"type": "string", "minLength": 1},
    "answer": {"type": "string", "minLength": 1}
  }
}]]></code>
  </section>

  <section title="Parser regex">
    <code lang="python"><![CDATA[REASONING_RE = re.compile(r"<reasoning>(.*?)</reasoning>", re.DOTALL)
ANSWER_RE = re.compile(r"<answer>(.*?)</answer>", re.DOTALL)]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="text"><![CDATA[<reasoning>
The cafe sold 24 cookies. Half went to one customer = 12. Of the rest (12), 1/3 (4) were chocolate.
</reasoning>
<answer>4</answer>]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="text"><![CDATA[Let me think. There are 24 cookies and... [stream of text]
The answer is 4.]]></code>
      <note>Fails: no tags; parser cannot extract reliably.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Output contains exactly one `&lt;reasoning&gt;` block.</item>
      <item>Output contains exactly one `&lt;answer&gt;` block; content non-empty.</item>
      <item>Nothing after `&lt;/answer&gt;` is consumed.</item>
    </list>
  </section>
</text>
