<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="rag-eval-strategy Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one rag-eval-strategy output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rag-eval-strategy",
  "type": "object",
  "required": ["gates", "tiers", "sampling", "rollback", "owner", "revisit_date"],
  "properties": {
    "gates": {"type": "object", "required": ["mrr_min", "faithfulness_min", "latency_p95_ms_max", "cost_per_query_usd_max"]},
    "tiers": {"type": "object", "required": ["per_pr", "per_release", "weekly"]},
    "sampling": {"type": "object", "required": ["fraction", "seed"]},
    "rollback": {"type": "object"},
    "owner": {"type": "string"},
    "revisit_date": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "gates": {"mrr_min": 0.7, "faithfulness_min": 0.9, "latency_p95_ms_max": 2000, "cost_per_query_usd_max": 0.02},
  "tiers": {"per_pr": {"n": 20, "metric": "mrr"}, "per_release": {"n": 200, "metric": "full-triad"}, "weekly": {"sample": 0.1, "metric": "faithfulness"}},
  "sampling": {"fraction": 0.1, "seed": 42},
  "rollback": {"faithfulness_drop": 0.05, "mrr_drop": 0.05},
  "owner": "alice",
  "revisit_date": "2026-08-22"
}
    ]]></code>
    <note>Valid: numeric gates, three tiers, deterministic sampling, owner + revisit.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"gates": {"faithfulness_min": 0.9}}
    ]]></code>
    <note>Invalid: missing tiers, sampling, rollback, owner.</note>
  </example>

  <reference path="scripts/validate-rag-eval-strategy.py">Validates an output file against this schema.</reference>
</text>
