<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vision Accessibility — Alt Text &amp; Scene Description Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the vision-accessibility artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/vision-accessibility.json",
  "type": "object",
  "required": [
    "artefact_id",
    "image_url",
    "alt_text",
    "long_description",
    "is_decorative",
    "contains_text"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "alt_text": {
      "type": "string"
    },
    "long_description": {
      "type": "string"
    },
    "is_decorative": {
      "type": "boolean"
    },
    "contains_text": {
      "type": "boolean"
    },
    "text_content": {
      "type": "string"
    },
    "chart_insight": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "example-artefact_id",
  "image_url": "example-image_url",
  "alt_text": "example-alt_text",
  "long_description": "example-long_description",
  "is_decorative": true,
  "contains_text": true,
  "text_content": "example-text_content",
  "chart_insight": "example-chart_insight"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": 123
}
]]></code>
    <note>field "artefact_id" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-vision-accessibility.py">schema validator</reference>
</text>
