<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Vision Accessibility — Alt Text &amp; Scene Description Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is the image decorative (per CMS flag or dimensions+alpha rule)?</root-question>
    <branch when="is_decorative == true">
      <conclusion ref="decorative-empty" verdict="apply rule decorative-empty"/>
    </branch>
    <branch when="contains_chart == true">
      <conclusion ref="chart-insight" verdict="apply rule chart-insight"/>
    </branch>
    <branch when="contains_embedded_text == true">
      <conclusion ref="embedded-text-verbatim" verdict="apply rule embedded-text-verbatim"/>
    </branch>
    <branch when="else (regular image with page context)">
      <conclusion ref="context-required" verdict="apply rule context-required"/>
    </branch>
  </decision-tree>
</text>
