<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Evaluation Framework — Offline Harness + LLM-as-Judge + Production Sampling Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>3 antipatterns for evaluation-framework.</summary>

  <section title="Antipatterns">

    <antipattern id="inline-rubric" severity="medium">
      <symptom>Each class inlines its own copy of the rubric.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Author optimised for file count.</root-cause>
      <fix>Extract rubric to one module; import everywhere.</fix>
    </antipattern>
    <antipattern id="boolean-gate" severity="medium">
      <symptom>CI gate just says pass/fail.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Threshold not exposed.</root-cause>
      <fix>Expose threshold as config; allow tightening without code change.</fix>
    </antipattern>
    <antipattern id="nondeterministic-judge" severity="medium">
      <symptom>Judge runs at temperature 0.7.</symptom>
      <root-cause source="v1-methodology + 2026 production review">Defaults left in place.</root-cause>
      <fix>Set temperature=0; record judge_model_id + judge_prompt_hash per run.</fix>
    </antipattern>

  </section>
</text>
