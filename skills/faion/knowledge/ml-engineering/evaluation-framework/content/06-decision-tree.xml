<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Evaluation Framework — Offline Harness + LLM-as-Judge + Production Sampling Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is this an offline harness run or a production sample?</root-question>
    <branch when="mode == offline">
      <conclusion ref="three-class-split" verdict="apply rule three-class-split"/>
    </branch>
    <branch when="mode == production_sample">
      <conclusion ref="rubric-module-shared" verdict="apply rule rubric-module-shared"/>
    </branch>
    <branch when="mode == ci_gate">
      <conclusion ref="ci-gate-threshold" verdict="apply rule ci-gate-threshold"/>
    </branch>
    <branch when="else">
      <conclusion ref="judge-temperature-zero" verdict="apply rule judge-temperature-zero"/>
    </branch>
  </decision-tree>
</text>
