<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="LLM Observability Stack — Decision Tree" version="1.1.0" est_tokens="500">
  <decision-tree>
    <root-question id="q-root">What is the deployment scale?</root-question>
    <branch when="scale == 'dev_or_small'">
      <conclusion ref="r2-version-pin">Use docker_compose. langfuse + otel-collector + prom + grafana. Pin versions.</conclusion>
    </branch>
    <branch when="scale == 'production'">
      <question id="q-sub">Where must trace data reside?</question>
        <branch when="data_origin == 'eu' OR self_host_required == true">
          <conclusion ref="r6-self-host-eu">k8s self-host in EU region. Langfuse + OTel + Prom + Grafana + Alertmanager.</conclusion>
        </branch>
        <branch when="data_origin == 'us_or_anywhere' AND ops_budget_low == true">
          <conclusion ref="r6-self-host-eu">Managed (Langfuse Cloud or LangSmith). Lower ops cost; vendor lock-in accepted.</conclusion>
        </branch>
        <branch when="data_origin == 'us_or_anywhere' AND ops_budget_normal == true">
          <conclusion ref="r6-self-host-eu">k8s self-host. Lowest unit cost at scale.</conclusion>
        </branch>
    </branch>
    <example trace="worked-example">
      <p>EU SaaS, k8s prod, EU residency → k8s self-host → Langfuse 3.18 + OTel collector 0.95 + Prom 2.55 + Grafana 11.2.</p>
    </example>
  </decision-tree>
</text>
