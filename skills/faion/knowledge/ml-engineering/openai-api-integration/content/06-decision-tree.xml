<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="OpenAI API Integration — Decision Tree" version="1.1.0" est_tokens="400">
  <decision-tree>
    <root-question id="q-root">Is the OpenAI call on a production hot path?</root-question>
    <branch when="on_production_hotpath == true and batch_size &gt;= 5">
      <conclusion ref="r4-async-batch">Use AsyncOpenAI with bounded concurrency.</conclusion>
    </branch>
    <branch when="on_production_hotpath == true and batch_size &lt; 5">
      <conclusion ref="r3-retry-policy">Use sync client with tenacity retry + telemetry.</conclusion>
    </branch>
    <branch when="on_production_hotpath == false">
      <question id="q-sub-2">Is the call exploratory / notebook code?</question>
      <branch when="notebook_or_one_off == true">
        <conclusion ref="r1-model-by-task">Start with gpt-4o-mini, skip retries, log token usage manually.</conclusion>
      </branch>
      <branch when="notebook_or_one_off == false">
        <conclusion ref="r2-typed-responses">Treat as production: typed response + retry + telemetry from day 1.</conclusion>
      </branch>
    </branch>
    <example trace="on_production_hotpath == true and batch_size &gt;= 5">
      <p>Use AsyncOpenAI with bounded concurrency.</p>
    </example>
  </decision-tree>
</text>
