<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vision Image Classification &amp; Content Moderation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema + valid / invalid examples for the vision-classification-moderation artefact.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/vision-classification-moderation.json",
  "type": "object",
  "required": [
    "image_hash",
    "category",
    "severity",
    "confidence",
    "model_used",
    "audit_id"
  ],
  "properties": {
    "image_hash": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "severity": {
      "type": "string"
    },
    "confidence": {
      "type": "number"
    },
    "model_used": {
      "type": "string"
    },
    "audit_id": {
      "type": "string"
    }
  }
}
]]></schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "image_hash": "example-image_hash",
  "category": "example-category",
  "severity": "example-severity",
  "confidence": 1.0,
  "model_used": "example-model_used",
  "audit_id": "example-audit_id"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "image_hash": 123
}
]]></code>
    <note>field "image_hash" must be string, not integer; other required fields also missing.</note>
  </example>

  <reference path="scripts/validate-vision-classification-moderation.py">schema validator</reference>
</text>
