<text id="02-output-contract" title="sota-onboarding-1day-runbook Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON schema for one sota-onboarding-1day-runbook output, with valid and invalid examples.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sota-onboarding-decision-record",
  "type": "object",
  "required": ["model_id", "version", "eval_scores", "cost_delta", "latency_delta", "decision", "owner", "revisit_date"],
  "properties": {
    "model_id": {"type": "string"},
    "version": {"type": "string"},
    "eval_scores": {"type": "object", "required": ["incumbent", "candidate"]},
    "cost_delta": {"type": "object", "required": ["input_per_1k_pct", "output_per_1k_pct"]},
    "latency_delta": {"type": "object", "required": ["p50_ms", "p95_ms"]},
    "decision": {"type": "string", "enum": ["GO", "NO-GO", "DEFER"]},
    "rollout_pct": {"type": "number"},
    "feature_flag": {"type": "string"},
    "owner": {"type": "string"},
    "revisit_date": {"type": "string"}
  }
}
    ]]></code>
  </section>

  <example type="good">
    <code lang="json"><![CDATA[
{
  "model_id": "claude-opus-4-7",
  "version": "2026-05-20",
  "eval_scores": {"incumbent": 0.821, "candidate": 0.864},
  "cost_delta": {"input_per_1k_pct": 50, "output_per_1k_pct": 50},
  "latency_delta": {"p50_ms": 200, "p95_ms": 400},
  "decision": "GO",
  "rollout_pct": 3,
  "feature_flag": "model.opus47",
  "owner": "maria",
  "revisit_date": "2026-05-27"
}
    ]]></code>
    <note>Valid: numeric scores + cost/latency deltas + decision + flag + owner.</note>
  </example>

  <example type="bad">
    <code lang="json"><![CDATA[
{"model_id": "x", "decision": "good"}
    ]]></code>
    <note>Invalid: missing eval_scores, cost/latency deltas, owner; decision not in enum.</note>
  </example>

  <reference path="scripts/validate-sota-onboarding-1day-runbook.py">Validates an output file against this schema.</reference>
</text>
