<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Feature GA Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the checklist artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-feature-ga-checklist.json",
  "type": "object",
  "required": ["artefact_id", "checks", "verdict", "reviewer_id", "reviewed_at"],
  "properties": {
    "artefact_id": {"type": "string"},
    "checks": {"type": "array", "items": {"type": "object", "required": ["id", "verdict", "evidence_pointer"], "properties": {"id": {"type": "string"}, "verdict": {"enum": ["PASS", "FAIL", "WAIVED", "APPROVE", "REQUEST_CHANGES", "BLOCK", "APPROVE_WITH_NOTE"]}, "evidence_pointer": {"type": "string"}}}, "minItems": 1},
    "verdict": {"enum": ["BLOCK", "REQUEST_CHANGES", "APPROVE", "APPROVE_WITH_NOTE"]},
    "rationale": {"type": "string"},
    "reviewer_id": {"type": "string"},
    "reviewed_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "fig-1234",
  "checks": [{"id": "c01", "verdict": "APPROVE", "evidence_pointer": "research/ticket-842.md"}],
  "verdict": "APPROVE",
  "reviewer_id": "designer@example.com",
  "reviewed_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "fig-1234",
  "verdict": "APPROVE"
}
]]></code>
    <note>Missing required fields per the schema above.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">verdict = APPROVE with any check entry marked BLOCK or FAIL</pattern>
      <pattern id="f2">checks array empty or missing required ids</pattern>
      <pattern id="f3">rationale missing when verdict != APPROVE</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Auto-populate timestamps from the validation moment.</transformation>
      <transformation>Normalise enum casing to schema lowercase.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-ai-feature-ga-checklist.py">Validator script</reference>
</text>
