<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Guardrails AI — Validator-Based Output Pipeline — Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>The artifact produced by applying `guardrails-ai-framework`. Schema below pins the shape; valid + invalid examples bracket the contract.</summary>

  <section title="JSON Schema">
    <schema lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "faion://guardrails-ai-framework/output.schema.json",
  "type": "object",
  "required": ["pipeline_name", "schema_path", "validators", "on_fail_default", "max_reasks"],
  "properties": {
    "pipeline_name": {"type": "string"},
    "schema_path": {"type": "string"},
    "validators": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "on_fail"]}},
    "on_fail_default": {"enum": ["reask", "fix", "refrain", "filter", "noop"]},
    "max_reasks": {"type": "integer", "minimum": 0, "maximum": 5}
  }
}
]]></schema>
  </section>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "pipeline_name": "support-reply",
  "schema_path": "schemas/support_reply.py",
  "validators": [
    {
      "id": "hub:DetectPII@0.0.3",
      "on_fail": "filter"
    },
    {
      "id": "hub:ToxicLanguage@0.0.5",
      "on_fail": "refrain"
    }
  ],
  "on_fail_default": "reask",
  "max_reasks": 3
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "pipeline_name": "",
  "schema_path": "",
  "validators": [],
  "on_fail_default": "yolo",
  "max_reasks": 999
}
]]></code>
      <note>Invalid: empty fields; no validators; bogus on_fail; max_reasks &gt; 5.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>All required fields present.</item>
      <item>No placeholder / stub strings in any required field.</item>
      <item>scripts/validate-guardrails-ai-framework.py --self-test exits 0.</item>
    </list>
  </section>
</text>
