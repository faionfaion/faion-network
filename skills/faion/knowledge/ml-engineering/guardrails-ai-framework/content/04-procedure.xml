<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Guardrails AI — Validator-Based Output Pipeline — Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure for applying `guardrails-ai-framework`. Each step lists input artifact, action, output artifact. Decision gates live in content/06-decision-tree.xml.</summary>

  <section title="Procedure">
    <step n="1" name="declare-schema">
      <input>Domain artifact shape.</input>
      <action>Define Pydantic class (or RAIL XML).</action>
      <output>schema.py.</output>
    </step>

    <step n="2" name="choose-validators">
      <input>Schema + use case.</input>
      <action>Pick Hub validators (or custom subclass).</action>
      <output>validators[] list.</output>
    </step>

    <step n="3" name="wire-on-fail">
      <input>Validators + safety policy.</input>
      <action>Set per-validator on_fail; cap max_reasks=3.</action>
      <output>Pipeline config.</output>
    </step>

    <step n="4" name="run">
      <input>Config + LLM provider.</input>
      <action>Wrap LLM call; record validator results.</action>
      <output>Validated output OR refrain signal.</output>
    </step>

    <step n="5" name="observe">
      <input>Pipeline runs.</input>
      <action>Send validator results to observability stack; alarm on repeat-fail.</action>
      <output>Observability dashboard.</output>
    </step>
  </section>
</text>
