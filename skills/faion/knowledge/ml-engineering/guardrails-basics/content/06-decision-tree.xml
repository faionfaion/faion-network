<text id="06-decision-tree" title="Guardrails Basics Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Does the application accept untrusted user input OR produce public-facing output?</root-question>
    <branch when="input.untrusted == true OR output.public == true">
      <question>Latency budget allows up to ~1s overhead?</question>
      <branch when="latency.budget_ms &gt;= 1000">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="latency.budget_ms &lt; 1000">
        <conclusion ref="r2"/>
      </branch>
    </branch>
    <branch when="input.untrusted == false AND output.public == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="customer chatbot accepting free text + budget 900ms → run-the-checklist"/>
  </decision-tree>
</text>
