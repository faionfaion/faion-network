<text id="02-output-contract" title="Prompt Version Pinning Runbook — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the `playbook-step` artefact this methodology produces, with one valid and one invalid worked example.</summary>

  <section title="Schema">
    <reference path="scripts/validate-prompt-version-pinning-runbook.py">Mechanical validator wired to this schema.</reference>
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/prompt-version-pinning-runbook.json",
  "type": "object",
  "required": [
    "slug",
    "version",
    "date",
    "produces",
    "signature",
    "payload",
    "forbidden_seen"
  ],
  "properties": {
    "slug": {
      "const": "prompt-version-pinning-runbook"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "produces": {
      "const": "playbook-step"
    },
    "signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "payload": {
      "type": "object",
      "required": [
        "trigger",
        "action",
        "verification",
        "rollback"
      ],
      "properties": {
        "trigger": {
          "type": "string"
        },
        "action": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        },
        "rollback": {
          "type": "string"
        }
      }
    },
    "forbidden_seen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "slug": "prompt-version-pinning-runbook",
  "version": "1.0.0",
  "date": "2026-05-22",
  "produces": "playbook-step",
  "signature": "2fd213e797732483",
  "payload": {
    "trigger": "deploy event",
    "action": "rollout 5% canary",
    "verification": "eval delta within \u00b12 pp",
    "rollback": "gateway rollback to prev hash"
  },
  "forbidden_seen": []
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "slug": "prompt-version-pinning-runbook",
  "version": "v1",
  "date": "today",
  "produces": "playbook-step",
  "signature": "tooshort",
  "payload": {
    "TBD": true
  },
  "forbidden_seen": [
    "empty_intent"
  ]
}
]]></code>
      <note>Fails validation: missing required fields and contains forbidden patterns.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Required keys present and typed correctly.</item>
      <item>`forbidden_seen` array empty.</item>
      <item>`signature` matches sha1(slug + version + ISO date)[:16].</item>
      <item>`date` is ISO 8601 (YYYY-MM-DD).</item>
    </list>
  </section>
</text>
