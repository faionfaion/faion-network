<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="LLM Observability Stack (2026) Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Root question + 4 branches that route to rule ids in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Is data residency required (EU)?</root-question>
    <branch when="residency_eu == true">
      <conclusion ref="self-host-when-residency" verdict="apply rule self-host-when-residency"/>
    </branch>
    <branch when="multi_agent == true">
      <conclusion ref="one-span-tree" verdict="apply rule one-span-tree"/>
    </branch>
    <branch when="pii_in_payload == true">
      <conclusion ref="pii-redaction-edge" verdict="apply rule pii-redaction-edge"/>
    </branch>
    <branch when="else">
      <conclusion ref="trace-budget-per-span" verdict="apply rule trace-budget-per-span"/>
    </branch>
  </decision-tree>
</text>
