<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Video Async API — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Pins VideoJob shape and provider-config block.</summary>

  <output-contract>
    <required>
      <field name="provider" type="enum" values="runway|luma|veo|sora|kling"/>
      <field name="idempotency_key" type="string"/>
      <field name="poll_backoff_seconds" type="array"/>
      <field name="total_wait_cap_seconds" type="integer" min="60" max="900"/>
      <field name="artefact_storage" type="object" required_keys="bucket,key_prefix"/>
      <field name="fallback" type="object" required_keys="provider,trigger"/>
    </required>

    <forbidden>
      <pattern id="f1">idempotency_key missing (r1-idempotency-key)</pattern>
      <pattern id="f2">poll_backoff_seconds[0] &lt; 1 (r2-exp-backoff-polling)</pattern>
      <pattern id="f3">total_wait_cap_seconds &gt; 900 (r3-total-wait-cap)</pattern>
      <pattern id="f4">artefact_storage missing (r4-download-before-expiry)</pattern>
      <pattern id="f5">fallback.provider == provider (r5-provider-fallback)</pattern>
    </forbidden>

    <schema-reference path="templates/video-job.schema.yaml"/>
  </output-contract>

  <section title="VideoJob JSON shape">
    <code lang="json"><![CDATA[
{
  "job_id": "job_abc123",
  "provider": "runway",
  "status": "succeeded",
  "submitted_at": "2026-05-22T14:32:00Z",
  "completed_at": "2026-05-22T14:35:20Z",
  "artefact_url": "s3://media/2026/05/22/job_abc123.mp4",
  "provider_response_log": [],
  "idempotency_key": "...",
  "cost_usd": 0.50
}
]]></code>
  </section>
</text>
