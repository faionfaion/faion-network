<text id="02-output-contract" title="Multi-Agent Design Patterns — Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the `decision-record` artefact this methodology produces, with one valid and one invalid worked example.</summary>

  <section title="Schema">
    <reference path="scripts/validate-multi-agent-design-patterns.py">Mechanical validator wired to this schema.</reference>
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/multi-agent-design-patterns.json",
  "type": "object",
  "required": [
    "slug",
    "version",
    "date",
    "produces",
    "signature",
    "payload",
    "forbidden_seen"
  ],
  "properties": {
    "slug": {
      "const": "multi-agent-design-patterns"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "produces": {
      "const": "decision-record"
    },
    "signature": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "payload": {
      "type": "object",
      "required": [
        "criteria",
        "scores",
        "recommendation"
      ],
      "properties": {
        "criteria": {
          "type": "array"
        },
        "scores": {
          "type": "object"
        },
        "recommendation": {
          "type": "string"
        }
      }
    },
    "forbidden_seen": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{
  "slug": "multi-agent-design-patterns",
  "version": "1.0.0",
  "date": "2026-05-22",
  "produces": "decision-record",
  "signature": "b677c7cc1c524cc0",
  "payload": {
    "criteria": [
      "accuracy",
      "latency",
      "cost"
    ],
    "scores": {
      "a": 3,
      "b": 5
    },
    "recommendation": "Pick option B."
  },
  "forbidden_seen": []
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{
  "slug": "multi-agent-design-patterns",
  "version": "v1",
  "date": "today",
  "produces": "decision-record",
  "signature": "tooshort",
  "payload": {
    "TBD": true
  },
  "forbidden_seen": [
    "empty_intent"
  ]
}
]]></code>
      <note>Fails validation: missing required fields and contains forbidden patterns.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Required keys present and typed correctly.</item>
      <item>`forbidden_seen` array empty.</item>
      <item>`signature` matches sha1(slug + version + ISO date)[:16].</item>
      <item>`date` is ISO 8601 (YYYY-MM-DD).</item>
    </list>
  </section>
</text>
