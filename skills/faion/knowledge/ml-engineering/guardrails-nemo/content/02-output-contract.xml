<text id="02-output-contract" title="NeMo Guardrails Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Schema for the `config/` directory: config.yml + Colang files + actions module.</summary>

  <section title="JSON Schema for config.yml">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/guardrails-nemo.json",
  "type": "object",
  "required": ["artefact_id", "version", "last_reviewed", "models", "rails"],
  "properties": {
    "artefact_id": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "models": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "engine", "model"],
        "properties": {
          "type": {"const": "main"},
          "engine": {"type": "string"},
          "model": {"type": "string"}
        }
      }
    },
    "rails": {
      "type": "object",
      "required": ["input", "output"],
      "properties": {
        "input": {"type": "object", "required": ["flows"], "properties": {"flows": {"type": "array", "items": {"type": "string"}}}},
        "output": {"type": "object", "required": ["flows"], "properties": {"flows": {"type": "array", "items": {"type": "string"}}}}
      }
    },
    "prompts": {"type": "array"},
    "knowledge_base": {"type": "array"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="yaml"><![CDATA[
artefact_id: gn-support-bot-2026-05
version: 1.0.0
last_reviewed: 2026-05-22
models:
  - type: main
    engine: openai
    model: gpt-4o
rails:
  input:
    flows:
      - self check input
      - check jailbreak
      - check topic
  output:
    flows:
      - self check output
      - check facts
prompts:
  - task: self_check_input
    content: "..."
knowledge_base:
  - type: local
    path: ./knowledge
]]></code>
  </example>

  <example valid="false">
    <code lang="yaml"><![CDATA[
models: []
rails:
  input: {}
]]></code>
    <note>models empty; rails.input missing flows; rails.output absent; missing version, last_reviewed, artefact_id.</note>
  </example>

  <reference path="scripts/validate-guardrails-nemo.py">YAML shape validator</reference>
  <reference path="templates/config.yml">YAML skeleton</reference>
</text>
