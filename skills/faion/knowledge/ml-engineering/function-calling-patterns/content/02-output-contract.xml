<text id="02-output-contract" title="Function Calling Patterns Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for one tool registry entry and the canonical cross-vendor agent loop trace.</summary>

  <section title="Tool registry entry schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/tool-registry-entry",
  "type": "object",
  "required": ["name", "version", "description", "schema_id", "input_schema", "category"],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "description": {"type": "string", "minLength": 30},
    "schema_id": {"type": "string"},
    "input_schema": {"type": "object", "required": ["type", "properties"]},
    "category": {"type": "string"},
    "side_effects": {"enum": ["read", "write", "external_call"]}
  }
}]]></code>
  </section>

  <section title="Cross-vendor trace shape">
    <code lang="text"><![CDATA[# Anthropic
messages = [{"role":"user",...}, {"role":"assistant","content":[<text|tool_use>...]}, {"role":"user","content":[<tool_result>...]}]
# OpenAI
messages = [{"role":"user",...}, {"role":"assistant","tool_calls":[{...}]}, {"role":"tool","tool_call_id":"...","content":"..."}]
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "name": "search_kb",
  "version": "1.2.0",
  "description": "Search the knowledge base for articles matching a query. Returns up to 5 results.",
  "schema_id": "kb-search-1.2",
  "category": "knowledge",
  "side_effects": "read",
  "input_schema": {
    "type": "object",
    "properties": {"query": {"type": "string"}},
    "required": ["query"]
  }
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"name": "Search KB", "input_schema": {}}]]></code>
      <note>Fails: invalid identifier, missing version + schema_id + description + category, empty input_schema.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>name matches identifier regex.</item>
      <item>version is semver.</item>
      <item>description ≥30 chars.</item>
      <item>schema_id non-empty and stable per version.</item>
      <item>category present (used by router).</item>
    </list>
  </section>
</text>
