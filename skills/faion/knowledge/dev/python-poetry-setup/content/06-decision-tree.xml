<text id="06-decision-tree" title="python-poetry-setup Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Is this a Python project where Poetry is acceptable as the dep manager?</root-question>
    <branch when="poetry_acceptable == true">
      <question>Can CI install Poetry and cache the .venv directory?</question>
      <branch when="ci_supports_poetry == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="ci_supports_poetry == false">
        <conclusion ref="r8"/>
      </branch>
    </branch>
    <branch when="poetry_acceptable == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new Python service, GHA, Poetry accepted -> run-the-checklist"/>
  </decision-tree>
</text>
