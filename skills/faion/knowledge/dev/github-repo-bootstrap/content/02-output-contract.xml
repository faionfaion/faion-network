<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitHub Repo Bootstrap Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for bootstrap config artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/github-repo-bootstrap.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "namespace",
    "name",
    "visibility",
    "license",
    "ci_stack",
    "merge_mode"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "namespace": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "visibility": {
      "enum": [
        "private",
        "public",
        "internal"
      ]
    },
    "license": {
      "type": "string"
    },
    "ci_stack": {
      "enum": [
        "python",
        "node",
        "go",
        "rust",
        "mixed",
        "none"
      ]
    },
    "merge_mode": {
      "const": "squash"
    },
    "required_reviewers": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "secrets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "grb-001",
  "namespace": "faionfaion",
  "name": "faion-new-thing",
  "visibility": "private",
  "license": "MIT",
  "ci_stack": "python",
  "merge_mode": "squash",
  "required_reviewers": 1,
  "secrets": [
    "PYPI_TOKEN"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "namespace": "x",
  "name": "y",
  "visibility": "secret",
  "license": "",
  "ci_stack": "php",
  "merge_mode": "merge"
}
]]></code>
    <note>visibility/ci_stack not in enums; merge_mode must be 'squash'; empty license; missing required fields.</note>
  </example>

  <reference path="scripts/validate-github-repo-bootstrap.py">schema validator</reference>
</text>
