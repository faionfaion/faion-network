<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="GitHub Repo Bootstrap Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Visibility + stack → bootstrap config.</summary>

  <decision-tree>
    <root-question id="q-visibility">What is the repo visibility?</root-question>
    <branch when="visibility == private">
      <question id="q-stack">Detected stack?</question>
      <branch when="stack == python">
        <conclusion ref="gh-cli-primary" verdict="private + python CI + Dependabot pip"/>
      </branch>
      <branch when="stack == node">
        <conclusion ref="gh-cli-primary" verdict="private + node CI + Dependabot npm"/>
      </branch>
      <branch when="stack == none">
        <conclusion ref="gh-cli-primary" verdict="private + empty CI scaffold"/>
      </branch>
    </branch>
    <branch when="visibility == public">
      <conclusion ref="protect-default-branch" verdict="public + license required + CODEOWNERS + 2 reviewers"/>
    </branch>
    <branch when="visibility == internal">
      <conclusion ref="gh-cli-primary" verdict="internal + org-default CI + Dependabot"/>
    </branch>
  </decision-tree>
</text>
