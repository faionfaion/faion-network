<text id="02-output-contract" title="PHPUnit Testing Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one test class artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/php-phpunit-testing.json",
  "type": "object",
  "required": [
    "test_class",
    "follows_aaa",
    "uses_factory",
    "uses_data_provider",
    "uses_constructor_mocks",
    "passes_random_order"
  ],
  "properties": {
    "test_class": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]+Test$"
    },
    "follows_aaa": {
      "type": "boolean",
      "const": true
    },
    "uses_factory": {
      "type": "boolean",
      "const": true
    },
    "uses_data_provider": {
      "type": "boolean"
    },
    "uses_constructor_mocks": {
      "type": "boolean",
      "const": true
    },
    "passes_random_order": {
      "type": "boolean",
      "const": true
    },
    "facade_fake_in_unit_count": {
      "type": "integer",
      "maximum": 0
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_class": "OrderServiceTest",
  "follows_aaa": true,
  "uses_factory": true,
  "uses_data_provider": true,
  "uses_constructor_mocks": true,
  "passes_random_order": true,
  "facade_fake_in_unit_count": 0
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "test_class": "TestOrders",
  "follows_aaa": false,
  "uses_factory": false,
  "uses_data_provider": false,
  "uses_constructor_mocks": false,
  "passes_random_order": false,
  "facade_fake_in_unit_count": 5
}
]]></code>
    <note>Naming pattern off; no AAA; shared setUp state; copy-pasted parameterized tests; facade fakes in unit tests; fails random-order.</note>
  </example>
  <forbidden>
      <pattern id="shared-state-setup">`protected static $sharedOrder` mutated across tests.</pattern>
      <pattern id="facade-fake-in-unit">`Mail::fake()` in a test that doesn't use the Laravel HTTP kernel.</pattern>
      <pattern id="test-order-coupling">Test A creates a record that Test B asserts on.</pattern>
  </forbidden>

  <reference path="scripts/validate-php-phpunit-testing.py">Validator script</reference>
</text>
