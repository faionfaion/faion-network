<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Mobile Performance Budget Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping perf budget gap to a rule.</summary>

  <decision-tree>
      <root-question id="q-budget-state">Where is the budget today?</root-question>

        <branch when="state == no_budget">
          <conclusion ref="budget-per-route" verdict="set per-route budgets + CWV thresholds + CI enforcement"/>
        </branch>
        <branch when="state == global_only">
          <conclusion ref="budget-per-route" verdict="split into route-group budgets"/>
        </branch>
        <branch when="state == size_only">
          <conclusion ref="core-web-vitals-included" verdict="add LCP/INP/CLS thresholds"/>
        </branch>
        <branch when="state == desktop_only">
          <conclusion ref="mobile-3g-baseline" verdict="switch CI validation to mobile preset"/>
        </branch>
        <branch when="state == documented_not_enforced">
          <conclusion ref="ci-enforcement" verdict="wire Lighthouse CI / bundle-size action as required status check"/>
        </branch>
        <branch when="state == enforced_no_review">
          <conclusion ref="quarterly-review" verdict="schedule quarterly review + rationale process"/>
        </branch>
    </decision-tree>

    <example trace="commerce site">
      state=no_budget → set per-route budgets + CWV + CI.
    </example>
</text>
