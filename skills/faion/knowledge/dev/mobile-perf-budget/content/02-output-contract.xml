<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mobile Performance Budget Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one route's perf budget artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mobile-perf-budget.json",
  "type": "object",
  "required": [
    "route",
    "lcp_ms",
    "inp_ms",
    "cls",
    "transfer_total_kb",
    "js_gz_kb",
    "image_kb",
    "ci_enforced"
  ],
  "properties": {
    "route": {
      "type": "string",
      "minLength": 1
    },
    "lcp_ms": {
      "type": "integer",
      "maximum": 2500
    },
    "inp_ms": {
      "type": "integer",
      "maximum": 200
    },
    "cls": {
      "type": "number",
      "maximum": 0.1
    },
    "transfer_total_kb": {
      "type": "integer",
      "maximum": 1500
    },
    "js_gz_kb": {
      "type": "integer",
      "maximum": 200
    },
    "image_kb": {
      "type": "integer",
      "maximum": 800
    },
    "tbt_ms": {
      "type": "integer",
      "maximum": 300
    },
    "ci_enforced": {
      "type": "boolean",
      "const": true
    },
    "validation_env": {
      "enum": [
        "lighthouse-mobile",
        "webpagetest-mobile-3g",
        "k6-browser-mobile"
      ]
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "route": "/",
  "lcp_ms": 2200,
  "inp_ms": 150,
  "cls": 0.05,
  "transfer_total_kb": 1200,
  "js_gz_kb": 170,
  "image_kb": 700,
  "tbt_ms": 250,
  "ci_enforced": true,
  "validation_env": "lighthouse-mobile"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "route": "/",
  "lcp_ms": 4500,
  "inp_ms": 800,
  "cls": 0.4,
  "transfer_total_kb": 3500,
  "js_gz_kb": 800,
  "image_kb": 2500,
  "tbt_ms": 1200,
  "ci_enforced": false,
  "validation_env": "lighthouse-desktop"
}
]]></code>
    <note>LCP/INP/CLS/sizes all over budget; CI not enforcing; validation on desktop not mobile.</note>
  </example>
  <forbidden>
      <pattern id="global-only-budget">A single budget JSON applying to all routes — no per-route override.</pattern>
      <pattern id="desktop-validation">Budget validated only on desktop preset — mobile reality ignored.</pattern>
      <pattern id="size-only-budget">Budget covers bundle size but not Core Web Vitals.</pattern>
  </forbidden>

  <reference path="scripts/validate-mobile-perf-budget.py">Validator script</reference>
</text>
