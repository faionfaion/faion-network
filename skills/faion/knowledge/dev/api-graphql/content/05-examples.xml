<text id="05-examples" title="GraphQL API Design Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: GQL-MOBILE-API ships a persisted-query-only endpoint with 2 DataLoaders and depth=10, complexity=1000.</summary>

  <section title="Scenario">
    <p>Mobile client needs flexible queries on orders + users; latency budget 100ms p95.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "types": 8,
  "relations_1n": 2,
  "rps_target": 500
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "pack_id": "GQL-MOBILE-API",
  "schema_path": "graphql/schema.graphql",
  "persisted_queries_only": true,
  "dataloaders": [
    {
      "name": "userByIdLoader",
      "relation": "Order.user"
    },
    {
      "name": "orderItemsLoader",
      "relation": "Order.items"
    }
  ],
  "max_depth": 10,
  "max_complexity": 1000,
  "error_extensions_format": "rfc-7807",
  "n_plus_1_hotspots": 0
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-api-graphql.py --file artefact.json
OK
]]></code>
  </section>
</text>
