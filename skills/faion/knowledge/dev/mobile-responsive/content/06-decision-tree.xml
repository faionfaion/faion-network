<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="mobile-responsive Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Is this a web UI (HTML/CSS) served to mobile devices?</root-question>
    <branch when="web_ui_mobile == true">
      <question>Can CI run Playwright + Lighthouse for the verification gate?</question>
      <branch when="ci_supports_playwright == true">
        <question>Will the team accept mobile-first refactor of existing CSS (if any)?</question>
        <branch when="refactor_accepted == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="refactor_accepted == false">
          <conclusion ref="r2"/>
        </branch>
      </branch>
      <branch when="ci_supports_playwright == false">
        <conclusion ref="r7"/>
      </branch>
    </branch>
    <branch when="web_ui_mobile == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new landing page, GHA with Playwright -> run-the-checklist"/>
  </decision-tree>
</text>
