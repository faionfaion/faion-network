<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="code-coverage Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying code-coverage. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["metric","diff_coverage_pct","repo_total_pct","mutation_run_on_critical"],"properties":{"metric":{"const":"branch"},"diff_coverage_pct":{"type":"number","minimum":0,"maximum":100},"repo_total_pct":{"type":"number","minimum":0,"maximum":100},"mutation_run_on_critical":{"type":"boolean"},"critical_modules":{"type":"array","items":{"type":"string"}}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"metric":"branch","diff_coverage_pct":94.2,"repo_total_pct":82.1,"mutation_run_on_critical":true,"critical_modules":["apps/billing","apps/auth"]}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"metric":"line","diff_coverage_pct":40,"repo_total_pct":100,"mutation_run_on_critical":false}
]]></code>
      <note>Invalid: metric is line (must be branch); diff &lt; 90; mutation off on critical modules.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>metric == 'branch'.</item>
      <item>diff_coverage_pct &gt;= 90 on changed lines.</item>
      <item>repo_total_pct is reported as a soft trend.</item>
      <item>mutation_run_on_critical == true.</item>
    </list>
  </section>
</text>
