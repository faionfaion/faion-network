<text id="06-decision-tree" title="mutation-testing-ci-gate Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-root">Does the language stack have a maintained mutator?</root-question>
      <branch when="has_maintained_mutator == false">
        <conclusion ref="skip-this-methodology" verdict="skip — wait for tooling or use the geek-tier AI-mutation pipeline"/>
      </branch>
      <branch when="has_maintained_mutator == true">
        <question id="q-next">shadow_days &gt;= 14?</question>
        <branch when="shadow_days &lt; 14">
          <conclusion ref="r5-gate-after-stabilize" verdict="stay in shadow mode"/>
        </branch>
        <branch when="shadow_days &gt;= 14">
          <question id="q-next">noise_rate_pct &lt; 10?</question>
          <branch when="noise_rate_pct &lt; 10">
            <conclusion ref="r5-gate-after-stabilize" verdict="flip to blocking per-module"/>
          </branch>
          <branch when="noise_rate_pct &gt;= 10">
            <conclusion ref="r3-equivalent-mutant-handling" verdict="triage equivalents; extend shadow"/>
          </branch>
        </branch>
      </branch>
  </decision-tree>
</text>
