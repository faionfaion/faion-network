<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stripe Webhook Hardening Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stripe-webhook-hardening.json",
  "type": "object",
  "required": [
    "timestamp_tolerance_sec",
    "rotation_cadence_days",
    "raw_body_verified",
    "edge_rate_limit_rpm",
    "audit_log_destination",
    "owner"
  ],
  "properties": {
    "timestamp_tolerance_sec": {
      "type": "integer",
      "minimum": 60,
      "maximum": 300
    },
    "rotation_cadence_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 90
    },
    "raw_body_verified": {
      "type": "boolean"
    },
    "edge_rate_limit_rpm": {
      "type": "integer",
      "minimum": 1
    },
    "audit_log_destination": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "ip_allowlist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "timestamp_tolerance_sec": 300,
  "rotation_cadence_days": 90,
  "raw_body_verified": true,
  "edge_rate_limit_rpm": 200,
  "audit_log_destination": "logs://webhook-audit",
  "owner": "ruslan@faion.net",
  "ip_allowlist": [
    "3.18.12.63/32",
    "3.130.192.231/32"
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "timestamp_tolerance_sec": 3600,
  "rotation_cadence_days": 365,
  "raw_body_verified": false,
  "edge_rate_limit_rpm": 0,
  "audit_log_destination": "",
  "owner": "team"
}
]]></code>
    <note>timestamp_tolerance_sec &gt; 300 (replay window); rotation_cadence_days &gt; 90; raw_body_verified false; edge_rate_limit_rpm &lt; 1; audit_log_destination empty; owner plural.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="wide-tolerance">timestamp tolerance &gt; 5 minutes opens replay window.</pattern>
      <pattern id="no-rotation">secret rotated rarely or never; long-lived shared secret.</pattern>
      <pattern id="parsed-before-verify">body parsed by framework before signature verify - signature breaks.</pattern>
      <pattern id="no-edge-limit">endpoint exposed with no rate limit; brute-force saturates verify path.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-stripe-webhook-hardening.py">Validator script (see scripts/).</reference>
</text>
