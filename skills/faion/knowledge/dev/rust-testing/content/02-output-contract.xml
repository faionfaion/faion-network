<text id="02-output-contract" title="Rust Testing Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the Rust test-strategy config artefact.</summary>

  <section title="Test-strategy schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/rust-testing-strategy.json",
  "type": "object",
  "required": ["layers", "coverage", "version", "last_reviewed"],
  "properties": {
    "layers": {
      "type": "object",
      "required": ["unit", "integration", "doctest"],
      "properties": {
        "unit":        {"type": "boolean", "const": true},
        "integration": {"type": "boolean", "const": true},
        "doctest":     {"type": "boolean", "const": true},
        "proptest":    {"type": "boolean"}
      }
    },
    "coverage": {
      "type": "object",
      "required": ["tool", "diff_threshold"],
      "properties": {
        "tool":            {"const": "cargo-llvm-cov"},
        "diff_threshold":  {"type": "integer", "minimum": 80, "maximum": 95},
        "global_report":   {"type": "boolean"}
      }
    },
    "proptest_cases": {"type": "integer", "minimum": 64, "maximum": 65536},
    "version":       {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "layers": {"unit": true, "integration": true, "doctest": true, "proptest": true},
  "coverage": {"tool": "cargo-llvm-cov", "diff_threshold": 85, "global_report": true},
  "proptest_cases": 1024,
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "layers": {"unit": true, "integration": false, "doctest": false},
  "coverage": {"tool": "tarpaulin", "diff_threshold": 60}
}
]]></code>
    <note>integration + doctest must be true; tool must be cargo-llvm-cov; diff_threshold below minimum; missing version + last_reviewed.</note>
  </example>

  <reference path="templates/rust-coverage-gate.sh">CI gate script</reference>
  <reference path="scripts/validate-rust-testing.py">Validator</reference>
</text>
