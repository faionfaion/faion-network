<text id="02-output-contract" title="Ruby on Rails Service Objects Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one service-object artefact.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ruby-rails-patterns.json",
  "type": "object",
  "required": [
    "service_class",
    "single_action",
    "returns_result",
    "uses_transaction",
    "called_from_callback"
  ],
  "properties": {
    "service_class": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]+Service$"
    },
    "single_action": {
      "type": "boolean",
      "const": true
    },
    "returns_result": {
      "type": "boolean",
      "const": true
    },
    "uses_transaction": {
      "type": "boolean"
    },
    "called_from_callback": {
      "type": "boolean",
      "const": false
    },
    "has_unit_test": {
      "type": "boolean",
      "const": true
    },
    "lines_of_code": {
      "type": "integer",
      "maximum": 150
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service_class": "PlaceOrderService",
  "single_action": true,
  "returns_result": true,
  "uses_transaction": true,
  "called_from_callback": false,
  "has_unit_test": true,
  "lines_of_code": 80
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service_class": "OrderHelper",
  "single_action": false,
  "returns_result": false,
  "uses_transaction": false,
  "called_from_callback": true,
  "has_unit_test": false,
  "lines_of_code": 350
}
]]></code>
    <note>Service class name not 'Service'-suffixed; multi-action; returns nil/exception; called from callback; 350 LoC.</note>
  </example>
  <forbidden>
      <pattern id="multi-action-service">Service class exposes &gt;1 public action method (create + update + delete).</pattern>
      <pattern id="raise-for-failure">Service raises StandardError to indicate business failure (instead of ServiceResult.failure).</pattern>
      <pattern id="callback-calls-service">Model's after_create / after_save calls a service.</pattern>
  </forbidden>

  <reference path="scripts/validate-ruby-rails-patterns.py">Validator script</reference>
</text>
