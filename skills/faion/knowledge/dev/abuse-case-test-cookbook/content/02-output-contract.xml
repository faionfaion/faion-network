<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Abuse Case Test Cookbook Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Pins the shape of a Abuse Case Test Cookbook deliverable. Subagent must satisfy this before returning.</summary>
  <output-contract>
    <required>
      <field name="steps" type="list" min="4" schema="{id,input,owner,exit_criterion,output_location}" />
      <field name="decision_branches" type="list" />
      <field name="owner_of_playbook" type="string" />
      <field name="deviation_log_reference" format="url_or_path" />
    </required>
    <forbidden>
      <pattern id="f1">step without exit_criterion</pattern>
      <pattern id="f2">playbook without named owner</pattern>
      <pattern id="f3">decision branch without explicit signal</pattern>
      <pattern id="f4">deviation log missing</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Reorder steps as long as input/output graph stays acyclic.</transformation>
    </allowed-transformations>
    <schema-reference path="templates/output-schema.json" />
  </output-contract>
  <section title="Self-check checklist">
    <list>
      <item>Every step has exit_criterion</item>
      <item>Owner named</item>
      <item>Branches explicit</item>
      <item>Deviation log exists</item>
    </list>
  </section>
</text>
