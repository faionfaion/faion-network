<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Code Review Process Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Platform + team-size routing.</summary>

  <decision-tree>
    <root-question id="q-platform">Which platform hosts the repo?</root-question>
    <branch when="platform == github">
      <question id="q-size">Team size?</question>
      <branch when="team_size &amp;lt; 10">
        <conclusion ref="branch-protection-required" verdict="1 required reviewer + CI green"/>
      </branch>
      <branch when="team_size &amp;gt;= 10">
        <conclusion ref="branch-protection-required" verdict="2 required reviewers + CODEOWNERS"/>
      </branch>
    </branch>
    <branch when="platform == gitlab">
      <conclusion ref="branch-protection-required" verdict="MR approval rules + push rules"/>
    </branch>
    <branch when="platform == bitbucket">
      <conclusion ref="branch-protection-required" verdict="PR default reviewers + merge checks"/>
    </branch>
  </decision-tree>
</text>
