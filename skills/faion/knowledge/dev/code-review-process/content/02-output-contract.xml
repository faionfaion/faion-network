<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Review Process Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the process bundle artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/code-review-process.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "platform",
    "pr_template",
    "branch_protection",
    "scenarios",
    "metrics"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "platform": {
      "enum": [
        "github",
        "gitlab",
        "bitbucket"
      ]
    },
    "pr_template": {
      "type": "string"
    },
    "branch_protection": {
      "type": "object"
    },
    "scenarios": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "enum": [
          "bug-fix",
          "new-design",
          "security",
          "performance"
        ]
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "enum": [
          "time-to-first-review",
          "cycle-time",
          "rework-rate"
        ]
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "crp-001",
  "platform": "github",
  "pr_template": ".github/PULL_REQUEST_TEMPLATE.md",
  "branch_protection": {
    "required_approving_review_count": 1,
    "required_status_checks": [
      "ci"
    ],
    "allow_force_pushes": false
  },
  "scenarios": [
    "bug-fix",
    "new-design",
    "security",
    "performance"
  ],
  "metrics": [
    "time-to-first-review",
    "cycle-time",
    "rework-rate"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platform": "phabricator",
  "pr_template": "",
  "branch_protection": {},
  "scenarios": [],
  "metrics": []
}
]]></code>
    <note>platform 'phabricator' not in enum; pr_template empty; scenarios + metrics empty; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-code-review-process.py">schema validator</reference>
</text>
