<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="REST API Design Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-path-shape">all resource paths plural-noun?</root-question>
    <branch when="verb_path_present">
      <conclusion ref="plural-resource-paths" verdict="verdict=fail; rename verbs out of paths"/>
    </branch>
    <branch when="paths_clean">
      <question id="q-idempotency">verbs match idempotency expectations?</question>
      <branch when="idempotency_violated">
        <conclusion ref="verb-idempotency-match" verdict="verdict=fail; correct verb or behaviour"/>
      </branch>
      <branch when="idempotency_ok">
        <question id="q-side-effects">monetary POSTs accept Idempotency-Key?</question>
        <branch when="missing_key">
          <conclusion ref="idempotency-key-on-charge" verdict="verdict=fail; add Idempotency-Key support"/>
        </branch>
        <branch when="keys_present">
          <conclusion ref="status-codes-rfc-9110" verdict="verdict=pass; ship resource spec"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="rest-orders-v1">
    paths plural → idempotency ok → POST /orders has Idempotency-Key=true → conclusion status-codes-rfc-9110 → pass.
  </example>
</text>
