<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mocking Strategies Output Contract" version="2.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the mocking-spec artefact. Subagent output MUST validate before being returned.</summary>

  <output-contract produces="spec">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "mocking-strategies"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["language", "runner", "doubles", "adapter_layer_path"],
      "properties": {
        "language": {"enum": ["python", "typescript", "go"]},
        "runner": {"enum": ["pytest", "vitest", "jest", "go-test"]},
        "doubles": {"type": "array", "items": {"type": "object", "required": ["dep_name", "type", "boundary", "tool"], "properties": {"type": {"enum": ["dummy", "stub", "spy", "mock", "fake", "real"]}, "boundary": {"enum": ["io-network", "io-fs", "time", "random", "third-party", "own-code"]}}}},
        "adapter_layer_path": {"type": "string"}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["is_own_code", "is_io_or_time_or_random", "verify_calls_needed", "stateful_reuse_count"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Python pytest, mock HTTP + freeze time, fake repo"><![CDATA[
{
  "slug": "mocking-strategies",
  "version": "2.0.0",
  "decision": {
    "language": "python",
    "runner": "pytest",
    "doubles": [
      {"dep_name": "stripe.Charge", "type": "mock", "boundary": "third-party", "tool": "pytest-mock+autospec"},
      {"dep_name": "datetime.now", "type": "stub", "boundary": "time", "tool": "freezegun"},
      {"dep_name": "UserRepository", "type": "fake", "boundary": "own-code", "tool": "in-memory-impl"}
    ],
    "adapter_layer_path": "myapp/adapters/"
  },
  "drivers": {"is_own_code": false, "is_io_or_time_or_random": true, "verify_calls_needed": true, "stateful_reuse_count": 5},
  "audit": {"rule_refs": ["r1-mock-at-boundary", "r2-autospec-mandatory", "r6-time-via-freezegun", "r7-prefer-fake", "r-mock-pick", "r-fake-pick"]}
}
]]></example>

    <example valid="false" title="Missing required keys"><![CDATA[
{
  "slug": "mocking-strategies",
  "version": "2.0.0",
  "decision": {"language": "python"},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>decision missing runner, doubles, adapter_layer_path.</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every double has type+boundary+tool present.</item>
      <item>No double with boundary=own-code is type=mock unless verify_calls_needed=true.</item>
      <item>If any double boundary=third-party, decision.adapter_layer_path is populated.</item>
    </list>
  </section>

  <reference path="templates/over-mock-lint.py">Optional lint pass over an existing suite.</reference>
  <reference path="scripts/validate-mocking-strategies.py">Schema validator.</reference>
</text>
