<methodology slug="web-scraping-element-extraction">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>automation-tooling</domain>
    <summary>Extract text, attributes, and table data from DOM elements using Puppeteer and Playwright selectors, with data cleaning helpers for text, prices, and dates.</summary>
    <tags>
