<text id="02-output-contract" title="typescript-patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON schema for a typed-shapes spec describing the domain types of a service or library.</summary>

  <output-contract>
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artefact_id", "owner", "scope", "ts_version", "types", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string"},
    "scope": {"type": "string"},
    "ts_version": {"type": "string"},
    "types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "kind", "representation"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]*$"},
          "kind": {"type": "string", "enum": ["external-input", "internal", "id-brand", "result", "config"]},
          "representation": {"type": "string", "enum": ["interface", "zod-schema", "discriminated-union", "branded-string", "branded-number"]},
          "validation": {"type": "string", "enum": ["zod-parse", "zod-safe-parse", "type-guard", "assertion-fn", "none"]},
          "discriminator": {"type": "string"},
          "variants": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></schema>

    <forbidden>
      <pattern id="f1">type with kind="external-input" but validation="none" or "type-guard" (must use zod-parse or zod-safe-parse)</pattern>
      <pattern id="f2">type with representation="discriminated-union" missing a discriminator field</pattern>
      <pattern id="f3">representation="branded-string" but no factory function declared in scope of the spec consumer</pattern>
      <pattern id="f4">owner equals "team" or empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Sort types alphabetically by name for diff hygiene.</transformation>
    </allowed-transformations>
  </output-contract>

  <example valid="true"><![CDATA[
{
  "artefact_id": "billing-domain-types",
  "owner": "ruslan@faion.net",
  "scope": "billing service domain types",
  "ts_version": "^5.4.0",
  "types": [
    {"name": "UserId",  "kind": "id-brand", "representation": "branded-string"},
    {"name": "OrderId", "kind": "id-brand", "representation": "branded-string"},
    {"name": "Order",   "kind": "internal", "representation": "interface"},
    {"name": "CreateOrderInput", "kind": "external-input", "representation": "zod-schema", "validation": "zod-safe-parse"},
    {"name": "OrderResult", "kind": "result", "representation": "discriminated-union", "validation": "none", "discriminator": "success", "variants": ["ok", "err"]}
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

  <example valid="false"><![CDATA[
{
  "artefact_id": "bad",
  "owner": "team",
  "scope": "x",
  "ts_version": "5",
  "types": [
    {"name": "input", "kind": "external-input", "representation": "interface", "validation": "none"},
    {"name": "Result", "kind": "result", "representation": "discriminated-union"}
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>
</text>
