<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="React Decomposition Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the React decomposition plan.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/decomposition-react.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "component",
    "extractions"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "component": {
      "type": "string"
    },
    "extractions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "name",
          "src_lines",
          "dst"
        ],
        "properties": {
          "kind": {
            "enum": [
              "hook",
              "service",
              "subcomponent",
              "reducer",
              "context"
            ]
          },
          "name": {
            "type": "string"
          },
          "src_lines": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "dst": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "drc-001",
  "component": "src/features/billing/InvoiceList.tsx",
  "extractions": [
    {
      "kind": "hook",
      "name": "useInvoiceFilter",
      "src_lines": [
        20,
        55
      ],
      "dst": "src/features/billing/useInvoiceFilter.ts"
    },
    {
      "kind": "service",
      "name": "invoiceApi",
      "src_lines": [
        10,
        18
      ],
      "dst": "src/features/billing/invoiceApi.ts"
    }
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "component": "x",
  "extractions": [
    {
      "kind": "helper",
      "name": "x"
    }
  ]
}
]]></code>
    <note>kind 'helper' not in enum; src_lines and dst missing; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-decomposition-react.py">schema validator</reference>
</text>
