<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="QA Rollback Trigger Canon Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Is there a rollback mechanism and monitoring to act on declared triggers?</root-question>
    <branch when="rollback_mechanism_exists == false">
      <conclusion ref="skip-this-methodology" verdict="skip — fix deploys first"/>
    </branch>
    <branch when="monitoring_present == false">
      <conclusion ref="skip-this-methodology" verdict="skip — write monitoring first"/>
    </branch>
    <branch when="trigger_signal_is_metric == false">
      <conclusion ref="observable-signal" verdict="translate to metric path"/>
    </branch>
    <branch when="window_minutes &lt; 2 OR window_minutes &gt; 15">
      <conclusion ref="threshold-and-window" verdict="set 2-15 min window"/>
    </branch>
    <branch when="action == ticket">
      <conclusion ref="auto-or-one-click" verdict="wire to auto or one-click"/>
    </branch>
    <branch when="owner == team">
      <conclusion ref="named-owner" verdict="name a single owner/schedule"/>
    </branch>
  </decision-tree>
</text>
