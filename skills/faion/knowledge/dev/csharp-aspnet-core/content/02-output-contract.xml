<text id="02-output-contract" title="C# / ASP.NET Core Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces, plus valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "layering",
    "dbcontext_lifetime",
    "cancellation_token_propagated",
    "error_format",
    "dto_kind",
    "time_provider",
    "test_db_strategy",
    "pagination",
    "loading",
    "transactions"
  ],
  "properties": {
    "layering": {
      "enum": [
        "controller-service-repository",
        "vertical-slice"
      ]
    },
    "dbcontext_lifetime": {
      "const": "scoped"
    },
    "cancellation_token_propagated": {
      "const": true
    },
    "error_format": {
      "const": "problem-details-rfc7807"
    },
    "dto_kind": {
      "const": "record"
    },
    "time_provider": {
      "const": true
    },
    "test_db_strategy": {
      "const": "testcontainers"
    },
    "pagination": {
      "const": "keyset"
    },
    "loading": {
      "const": "eager-include"
    },
    "transactions": {
      "const": "explicit"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "layering": "controller-service-repository",
  "dbcontext_lifetime": "scoped",
  "cancellation_token_propagated": true,
  "error_format": "problem-details-rfc7807",
  "dto_kind": "record",
  "time_provider": true,
  "test_db_strategy": "testcontainers",
  "pagination": "keyset",
  "loading": "eager-include",
  "transactions": "explicit"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "layering": "controller-only",
  "dbcontext_lifetime": "singleton",
  "cancellation_token_propagated": false,
  "error_format": "raw-exception-message",
  "dto_kind": "ef-entity",
  "time_provider": false,
  "test_db_strategy": "ef-in-memory",
  "pagination": "skip-take",
  "loading": "lazy",
  "transactions": "implicit"
}
]]></code>
    <note>Direct DbContext access (r1); singleton (r2); no CT (r3); raw exceptions (r4); EF entities returned (r5); DateTime.UtcNow (r6); InMemory tests (r7); Skip/Take (r8); lazy load (r9); implicit tx (r10).</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">dbcontext_lifetime is not `scoped` (r2)</pattern>
      <pattern id="f2">cancellation_token_propagated is false (r3)</pattern>
      <pattern id="f3">error_format is not `problem-details-rfc7807` (r4)</pattern>
      <pattern id="f4">dto_kind is `ef-entity` (r5)</pattern>
      <pattern id="f5">time_provider is false (r6)</pattern>
      <pattern id="f6">test_db_strategy is `ef-in-memory` (r7)</pattern>
      <pattern id="f7">pagination is `skip-take` (r8)</pattern>
      <pattern id="f8">loading is `lazy` (r9)</pattern>
      <pattern id="f9">transactions is `implicit` (r10)</pattern>
    </forbidden>
  </output-contract>

  <reference path="scripts/validate-csharp-aspnet-core.py">Validator script</reference>
</text>
