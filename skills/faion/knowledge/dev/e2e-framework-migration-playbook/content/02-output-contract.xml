<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="E2E Framework Migration Playbook Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/e2e-framework-migration-playbook.json",
  "type": "object",
  "required": ["migration_id", "wave", "entry_criteria_met", "exit_criteria_met", "modules_in_wave", "rollback_documented"],
  "properties": {
    "migration_id": {"type": "string", "minLength": 3},
    "wave": {"type": "integer", "minimum": 1, "maximum": 4},
    "entry_criteria_met": {"type": "boolean"},
    "exit_criteria_met": {"type": "boolean"},
    "modules_in_wave": {"type": "integer", "minimum": 1},
    "rollback_documented": {"type": "boolean"},
    "parity_tests_passing": {"type": "integer", "minimum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "migration_id": "cypress-to-playwright-2026q2",
  "wave": 2,
  "entry_criteria_met": true,
  "exit_criteria_met": false,
  "modules_in_wave": 18,
  "rollback_documented": true,
  "parity_tests_passing": 12,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "migration_id": "x",
  "wave": 5,
  "modules_in_wave": 0
}
]]></code>
    <note>migration_id too short, wave out of range, modules_in_wave below minimum, missing required boolean fields.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Wave declared complete without exit_criteria_met == true</pattern>
      <pattern id="f2">Wave 3 cutover without parity_tests_passing matching modules_in_wave</pattern>
      <pattern id="f3">Wave started with rollback_documented == false</pattern>
      <pattern id="f4">Wave 4 marked skipped (must be executed to close migration)</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Sort wave records by wave number then by timestamp.</transformation>
      <transformation>Normalise migration_id to kebab-case.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-e2e-framework-migration-playbook.py">Validator script</reference>
</text>
