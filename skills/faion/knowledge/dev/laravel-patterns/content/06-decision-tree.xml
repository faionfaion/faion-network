<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Laravel Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping endpoint shape to a Laravel layering rule.</summary>

  <decision-tree>
      <root-question id="q-endpoint-shape">Endpoint shape?</root-question>

        <branch when="shape == html_response">
          <conclusion ref="no-eloquent-in-controller" verdict="use Inertia/Livewire conventions instead of this methodology"/>
        </branch>
        <branch when="shape == api_json">
          <question id="q-eloquent">Controller contains Eloquent calls?</question>
          <branch when="eloquent_in_controller == true">
            <conclusion ref="no-eloquent-in-controller" verdict="extract data access to OrderService"/>
          </branch>
          <branch when="eloquent_in_controller == false">
            <question id="q-validate">Validation inline?</question>
            <branch when="inline_validation == true">
              <conclusion ref="form-request-for-validation" verdict="extract to StoreOrderRequest + UpdateOrderRequest"/>
            </branch>
            <branch when="inline_validation == false">
              <conclusion ref="api-resource-for-response" verdict="wrap response in OrderResource; ship"/>
            </branch>
          </branch>
        </branch>
    </decision-tree>

    <example trace="POST /api/v1/orders">
      shape=api_json → eloquent_in_controller=false → inline_validation=false → wrap in OrderResource + ship.
    </example>
</text>
