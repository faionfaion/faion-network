<text id="02-output-contract" title="Laravel Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing the Laravel slice artefact (controller + form request + service + resource + policy).</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/laravel-patterns.json",
  "type": "object",
  "required": [
    "controller",
    "form_request",
    "service",
    "resource",
    "policy",
    "eloquent_in_controller",
    "tx_in_controller"
  ],
  "properties": {
    "controller": {
      "type": "string",
      "pattern": "^Api\\\\\\\\V[0-9]+\\\\\\\\[A-Z][A-Za-z]+Controller$"
    },
    "form_request": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]+(Store|Update|Destroy)Request$"
    },
    "service": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]+Service$"
    },
    "resource": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]+Resource$"
    },
    "policy": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z]+Policy$"
    },
    "eloquent_in_controller": {
      "type": "boolean",
      "const": false
    },
    "tx_in_controller": {
      "type": "boolean",
      "const": false
    },
    "controller_lines": {
      "type": "integer",
      "maximum": 50
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "controller": "Api\\\\V1\\\\OrderController",
  "form_request": "StoreOrderRequest",
  "service": "OrderService",
  "resource": "OrderResource",
  "policy": "OrderPolicy",
  "eloquent_in_controller": false,
  "tx_in_controller": false,
  "controller_lines": 32
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "controller": "OrderController",
  "form_request": "OrderRequest",
  "service": "OrderManager",
  "resource": "OrderArray",
  "policy": "",
  "eloquent_in_controller": true,
  "tx_in_controller": true,
  "controller_lines": 180
}
]]></code>
    <note>Controller not Api\V1-namespaced; FormRequest not Store/Update/Destroy-suffixed; service not 'Service'-suffixed; no Resource (returns array); no Policy; Eloquent + tx in controller; 180-line controller.</note>
  </example>
  <forbidden>
      <pattern id="eloquent-in-controller">`Model::query()` / `Model::find()` / `Model::create()` inside a Controller class.</pattern>
      <pattern id="tx-in-controller">`DB::transaction(...)` called from a controller method.</pattern>
      <pattern id="raw-model-response">`return $model;` from a controller action — bypasses Resource.</pattern>
  </forbidden>

  <reference path="scripts/validate-laravel-patterns.py">Validator script</reference>
</text>
