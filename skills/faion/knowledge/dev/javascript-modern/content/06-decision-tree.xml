<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Modern JS/TS Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Runtime + monorepo → config shape.</summary>

  <decision-tree>
    <root-question id="q-runtime">What is the target runtime?</root-question>
    <branch when="runtime == node">
      <question id="q-mono">Monorepo?</question>
      <branch when="monorepo == true">
        <conclusion ref="pnpm-for-monorepo" verdict="Node 22 + pnpm workspaces + strict TS"/>
      </branch>
      <branch when="monorepo == false">
        <conclusion ref="typescript-strict" verdict="Node 22 + npm/pnpm + strict TS"/>
      </branch>
    </branch>
    <branch when="runtime == bun">
      <conclusion ref="typescript-strict" verdict="Bun + bun install + strict TS; see [[bun-runtime-simple]]"/>
    </branch>
    <branch when="runtime == browser">
      <conclusion ref="runtime-targeted-placement" verdict="Browser lib only + Vite/Vite-like bundler"/>
    </branch>
    <branch when="runtime == edge">
      <conclusion ref="runtime-targeted-placement" verdict="Edge runtime (Cloudflare Workers / Vercel Edge) + WebStandard APIs only"/>
    </branch>
    <branch when="runtime == mixed">
      <conclusion ref="runtime-targeted-placement" verdict="Per-package config + cross-runtime markers"/>
    </branch>
  </decision-tree>
</text>
