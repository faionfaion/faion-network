<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-pytest Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-pytest. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["runner","uses_fixtures","factory_strategy","db_marker_used","auth_strategy"],"properties":{"runner":{"const":"pytest"},"uses_fixtures":{"const":true},"factory_strategy":{"type":"string","enum":["factory-boy","model-bakery","mixed"]},"db_marker_used":{"const":true},"auth_strategy":{"const":"force_authenticate"},"boundary_mocks_only":{"type":"boolean"}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"runner":"pytest","uses_fixtures":true,"factory_strategy":"factory-boy","db_marker_used":true,"auth_strategy":"force_authenticate","boundary_mocks_only":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"runner":"unittest","uses_fixtures":false,"factory_strategy":"none","db_marker_used":false,"auth_strategy":"login-each-test","boundary_mocks_only":false}
]]></code>
      <note>Invalid: unittest runner, no fixtures, no factories, no DB marker, login per test, internal mocks.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Runner is pytest + pytest-django.</item>
      <item>Test data via factory_boy or model_bakery.</item>
      <item>Every DB-touching test uses @pytest.mark.django_db.</item>
      <item>Auth via APIClient.force_authenticate.</item>
      <item>Mocks at process boundaries only.</item>
    </list>
  </section>
</text>
