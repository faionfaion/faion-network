<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Refactoring Patterns Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the atomic-move plan: ordered list of (transform, target, before, after).</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/refactoring-patterns.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "file",
    "plan"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "file": {
      "type": "string"
    },
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "transform",
          "target",
          "intent"
        ],
        "properties": {
          "transform": {
            "enum": [
              "extract-function",
              "inline-function",
              "extract-variable",
              "replace-conditional-with-polymorphism",
              "introduce-parameter-object",
              "replace-magic-number-with-constant",
              "decompose-conditional",
              "rename"
            ]
          },
          "target": {
            "type": "string"
          },
          "intent": {
            "type": "string"
          }
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "rfp-001",
  "file": "src/billing/invoice.py",
  "plan": [
    {
      "transform": "extract-function",
      "target": "lines 80-140",
      "intent": "isolate tax computation"
    },
    {
      "transform": "replace-magic-number-with-constant",
      "target": "0.21",
      "intent": "name VAT_RATE_NL"
    }
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "file": "x",
  "plan": [
    {
      "transform": "fix-stuff",
      "target": "all"
    }
  ]
}
]]></code>
    <note>transform not in catalog; missing intent; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-refactoring-patterns.py">schema validator</reference>
</text>
