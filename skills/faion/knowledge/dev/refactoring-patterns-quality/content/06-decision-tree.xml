<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Refactoring Patterns Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Smell → canonical transform routing.</summary>

  <decision-tree>
    <root-question id="q-smell">What is the named code smell?</root-question>
    <branch when="smell == long-function">
      <conclusion ref="named-transform" verdict="extract-function"/>
    </branch>
    <branch when="smell == complex-conditional">
      <conclusion ref="named-transform" verdict="decompose-conditional OR replace-conditional-with-polymorphism"/>
    </branch>
    <branch when="smell == magic-number">
      <conclusion ref="named-transform" verdict="replace-magic-number-with-constant"/>
    </branch>
    <branch when="smell == large-parameter-list">
      <conclusion ref="named-transform" verdict="introduce-parameter-object"/>
    </branch>
    <branch when="smell == inappropriate-name">
      <conclusion ref="atomic-rename-via-tool" verdict="rename via LSP"/>
    </branch>
    <branch when="smell == one-liner-wrapper">
      <conclusion ref="named-transform" verdict="inline-function"/>
    </branch>
    <branch when="smell == repeated-expression">
      <conclusion ref="named-transform" verdict="extract-variable"/>
    </branch>
  </decision-tree>
</text>
