<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="DDD Aggregates Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for an aggregate spec — root, command methods, invariants, event types.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ddd-aggregates.json",
  "type": "object",
  "required": ["aggregate_root", "commands", "invariants", "events", "cross_aggregate_refs", "child_entity_count"],
  "properties": {
    "aggregate_root": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"},
    "has_public_setters": {"type": "boolean", "const": false},
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"}
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "object", "required": ["name", "test_name"],
        "properties": {
          "name": {"type": "string"},
          "test_name": {"type": "string", "pattern": "^test_(cannot|can|must)_[a-z0-9_]+$"}
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"}
    },
    "cross_aggregate_refs": {
      "type": "array",
      "items": {"type": "object", "required": ["aggregate", "ref_kind"],
        "properties": {
          "aggregate": {"type": "string"},
          "ref_kind": {"enum": ["identity", "object"]}
        }
      }
    },
    "child_entity_count": {"type": "integer", "minimum": 0, "maximum": 5}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "aggregate_root": "Order",
  "has_public_setters": false,
  "commands": ["place", "add_item", "cancel", "ship"],
  "invariants": [
    {"name": "cannot place empty order", "test_name": "test_cannot_place_empty_order"},
    {"name": "cannot ship unpaid order", "test_name": "test_cannot_ship_unpaid_order"}
  ],
  "events": ["OrderPlaced", "OrderShipped", "OrderCancelled"],
  "cross_aggregate_refs": [
    {"aggregate": "Customer", "ref_kind": "identity"}
  ],
  "child_entity_count": 2
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "aggregate_root": "order",
  "has_public_setters": true,
  "commands": ["set_status"],
  "invariants": [{"name": "x", "test_name": "shouldWork"}],
  "events": [],
  "cross_aggregate_refs": [{"aggregate": "Customer", "ref_kind": "object"}],
  "child_entity_count": 12
}
]]></code>
    <note>root lower-case; public setters; setter-style command; invariant test name not test_*; events empty; object ref to another aggregate; child entity count exceeds 5.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>`has_public_setters == true`.</description>
      <reason>Violates `root-only-mutation` rule.</reason>
    </antipattern>
    <antipattern>
      <description>Any `cross_aggregate_refs[i].ref_kind == "object"`.</description>
      <reason>Violates `identity-only-refs` rule.</reason>
    </antipattern>
    <antipattern>
      <description>`child_entity_count &gt; 5`.</description>
      <reason>Violates `small-aggregate` rule — split the aggregate.</reason>
    </antipattern>
    <antipattern>
      <description>`events.length == 0` while `commands.length &gt; 0`.</description>
      <reason>Violates `raise-event-on-mutation` rule.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-ddd-aggregates.py">Validator script</reference>
</text>
