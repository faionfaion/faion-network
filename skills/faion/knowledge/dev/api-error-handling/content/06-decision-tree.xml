<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="API Error Handling Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-envelope">envelope_shape == "rfc-7807"?</root-question>
    <branch when="envelope_wrong">
      <conclusion ref="rfc-7807-envelope" verdict="verdict=fail; adopt RFC 7807"/>
    </branch>
    <branch when="envelope_ok">
      <question id="q-classes">all errors have class matching status?</question>
      <branch when="class_mismatch">
        <conclusion ref="4xx-vs-5xx-split" verdict="verdict=fail; remap mis-classified errors"/>
      </branch>
      <branch when="class_match">
        <question id="q-trace">traceid_field present in enum?</question>
        <branch when="trace_missing">
          <conclusion ref="traceid-required" verdict="verdict=fail; add traceId to envelope"/>
        </branch>
        <branch when="trace_present">
          <conclusion ref="stable-type-uri" verdict="verdict=pass; publish catalogue"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="err-public-api">
    envelope=rfc-7807 → class matches status for all entries → traceid_field=traceId → conclusion stable-type-uri → pass.
  </example>
</text>
