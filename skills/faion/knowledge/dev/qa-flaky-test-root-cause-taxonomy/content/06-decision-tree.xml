<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="QA Flaky Test Root-Cause Taxonomy Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Are we classifying flakes by root cause to drive remediation?</root-question>
    <branch when="suite_size &lt; 50">
      <conclusion ref="skip-this-methodology" verdict="skip — too small"/>
    </branch>
    <branch when="org_taxonomy_exists == true">
      <conclusion ref="skip-this-methodology" verdict="skip — use org taxonomy"/>
    </branch>
    <branch when="category_not_in_enum == true">
      <conclusion ref="closed-enum" verdict="remap to one of 8 or 'unknown'"/>
    </branch>
    <branch when="unknown_age_days &gt; 7">
      <conclusion ref="unknown-allowed-7d" verdict="reclassify or quarantine"/>
    </branch>
    <branch when="mask_age_days &gt; 30 AND fix_plan == null">
      <conclusion ref="retest-not-fix" verdict="require fix plan or remove mask"/>
    </branch>
  </decision-tree>
</text>
