<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="SEO for SPAs Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/seo-for-spas.json",
  "type": "object",
  "required": [
    "routes",
    "metadata_strategy",
    "structured_data",
    "sitemap",
    "cwv_targets"
  ],
  "properties": {
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "rendering_mode"
        ]
      }
    },
    "metadata_strategy": {
      "type": "string",
      "enum": [
        "per_route",
        "global_only"
      ]
    },
    "structured_data": {
      "type": "object",
      "required": [
        "enabled",
        "types"
      ]
    },
    "sitemap": {
      "type": "object",
      "required": [
        "path",
        "auto_generated"
      ]
    },
    "hreflang": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cwv_targets": {
      "type": "object",
      "required": [
        "lcp_ms",
        "inp_ms",
        "cls"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "routes": [
    {
      "path": "/",
      "rendering_mode": "SSG"
    },
    {
      "path": "/blog/[slug]",
      "rendering_mode": "ISR"
    },
    {
      "path": "/app/*",
      "rendering_mode": "CSR"
    }
  ],
  "metadata_strategy": "per_route",
  "structured_data": {
    "enabled": true,
    "types": [
      "Article",
      "BreadcrumbList"
    ]
  },
  "sitemap": {
    "path": "/sitemap.xml",
    "auto_generated": true
  },
  "hreflang": [
    "en",
    "uk",
    "x-default"
  ],
  "cwv_targets": {
    "lcp_ms": 2500,
    "inp_ms": 200,
    "cls": 0.1
  }
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "routes": [
    {
      "path": "/",
      "rendering_mode": "CSR"
    }
  ],
  "metadata_strategy": "global_only",
  "structured_data": {
    "enabled": false
  },
  "sitemap": {},
  "cwv_targets": {
    "lcp_ms": 5000
  }
}
]]></code>
    <note>marketing route on CSR; metadata_strategy=global_only forbidden; structured_data missing types; sitemap missing path/auto_generated; cwv_targets missing inp_ms+cls.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="csr-marketing">Google indexes empty homepage; organic traffic flat for months.</pattern>
      <pattern id="global-metadata">Every page in SERPs shows same title 'My App'.</pattern>
      <pattern id="missing-hreflang">EN users see UK pages; duplicate-content warnings in Search Console.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-seo-for-spas.py">Validator script (see scripts/).</reference>
</text>
