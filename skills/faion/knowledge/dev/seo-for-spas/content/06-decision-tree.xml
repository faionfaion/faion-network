<text id="06-decision-tree" title="SEO for SPAs Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="seo-goal">Is search-driven traffic a goal?</root-question>
      <branch when="goal == no">
        <conclusion ref="skip-this-methodology" verdict="skip; rely on direct/paid"/>
      </branch>
      <branch when="goal == yes">
        <question id="marketing-render">Are marketing routes rendered server-side (SSG/SSR/ISR)?</question>
          <branch when="render == csr_only">
            <conclusion ref="rendering-mode-per-route" verdict="switch marketing to SSG/ISR"/>
          </branch>
          <branch when="render == server_side">
            <question id="metadata-scope">Is metadata per-route?</question>
              <branch when="metadata == global_only">
                <conclusion ref="per-page-metadata" verdict="wire per-route metadata API"/>
              </branch>
              <branch when="metadata == per_route">
                <conclusion ref="core-web-vitals-targets" verdict="declare CWV targets + wire Lighthouse CI"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="goal=yes -&amp;gt; render=server_side -&amp;gt; metadata=per_route -&amp;gt; core-web-vitals-targets.">Worked path from root-question to conclusion.</example>
</text>
