<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-api Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-api. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["views_layer_thin","services_take_domain_types","openapi_via_spectacular","list_endpoints_paginated","error_shape"],"properties":{"views_layer_thin":{"const":true},"services_take_domain_types":{"const":true},"openapi_via_spectacular":{"const":true},"list_endpoints_paginated":{"const":true},"error_shape":{"const":"rfc-7807"},"max_view_body_lines":{"type":"integer","maximum":25}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"views_layer_thin":true,"services_take_domain_types":true,"openapi_via_spectacular":true,"list_endpoints_paginated":true,"error_shape":"rfc-7807","max_view_body_lines":18}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"views_layer_thin":false,"services_take_domain_types":false,"openapi_via_spectacular":false,"list_endpoints_paginated":false,"error_shape":"custom"}
]]></code>
      <note>Invalid: views fat, services take request, hand-maintained openapi, unpaginated list, non-RFC-7807 errors.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Views &lt;= 25 lines and contain no ORM/external calls.</item>
      <item>Services accept domain types, never request.*.</item>
      <item>openapi.json auto-generated via drf-spectacular.</item>
      <item>Every list endpoint paginated.</item>
      <item>Error shape matches RFC 7807.</item>
    </list>
  </section>
</text>
