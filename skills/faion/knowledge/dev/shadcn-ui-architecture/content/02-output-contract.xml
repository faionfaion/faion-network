<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="shadcn/ui Architecture Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/shadcn-ui-architecture.json",
  "type": "object",
  "required": [
    "primitive_dir",
    "token_source",
    "variant_policy",
    "lint_rules",
    "codeowners_path"
  ],
  "properties": {
    "primitive_dir": {
      "type": "string"
    },
    "token_source": {
      "type": "string"
    },
    "variant_policy": {
      "type": "object",
      "required": [
        "max_variants_per_prop",
        "compound_variants_required"
      ]
    },
    "lint_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "codeowners_path": {
      "type": "string"
    },
    "asChild_required": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "primitive_dir": "src/components/ui/",
  "token_source": "src/styles/globals.css",
  "variant_policy": {
    "max_variants_per_prop": 6,
    "compound_variants_required": true
  },
  "lint_rules": [
    "no-arbitrary-tailwind",
    "no-business-import-in-ui",
    "require-forwardRef",
    "require-displayName"
  ],
  "codeowners_path": "/components/ui/ @design-system",
  "asChild_required": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "primitive_dir": "",
  "token_source": "",
  "variant_policy": {
    "max_variants_per_prop": 20
  },
  "lint_rules": [],
  "codeowners_path": ""
}
]]></code>
    <note>primitive_dir empty; token_source empty; variant_policy max&gt;6 + compound_variants_required missing; lint_rules empty; codeowners_path empty.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="business-in-button">`&lt;Button&gt;` imports useAuth; every feature touches Button.</pattern>
      <pattern id="variant-explosion">Button has 14 variants; visual QA can't cover them all.</pattern>
      <pattern id="concrete-shade-dark">Dark mode mismatch: cards stay `bg-white` while page is `bg-gray-900`.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-shadcn-ui-architecture.py">Validator script (see scripts/).</reference>
</text>
