<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Monorepo with Turborepo Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for monorepo-turborepo.</summary>

  <decision-tree>
    <root-question id="q-root">Is the repo multi-package JS/TS AND will caching across CI runs pay off?</root-question>

    <branch when="package_count &lt;= 1">
      <conclusion ref="skip-this-methodology" verdict="SKIP — single package doesn't need Turborepo"/>
    </branch>
    <branch when="language_scope == polyglot">
      <conclusion ref="skip-this-methodology" verdict="SKIP — use Bazel/Nx with language plugins"/>
    </branch>
    <branch when="package_manager != pnpm">
      <conclusion ref="r1-pnpm-workspaces-not-npm" verdict="BLOCK — migrate to pnpm"/>
    </branch>
    <branch when="task_without_outputs == true">
      <conclusion ref="r4-cache-outputs-declared" verdict="BLOCK — declare outputs"/>
    </branch>
    <branch when="floating_versions &gt; 0">
      <conclusion ref="r3-pinned-versions" verdict="BLOCK — pin versions"/>
    </branch>
    <branch when="remote_cache_in_ci == false">
      <conclusion ref="r5-remote-cache-in-ci" verdict="BLOCK — wire remote cache"/>
    </branch>
    <branch when="bypass_script_present == true">
      <conclusion ref="r6-no-top-level-bypass-scripts" verdict="BLOCK — migrate to turbo task"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — monorepo config ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="monorepo-turborepo-happy-path">
    7 packages + JS/TS + pnpm → first two branches do not match → outputs declared → versions pinned → remote cache wired → no bypass scripts → APPROVE.
  </example>
</text>
