<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="methodologies Output Contract" version="1.0.0" est_tokens="500" depth="essential">
  <summary>JSON Schema for a single-slug dispatch report.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/methodologies-dispatcher",
  "type": "object",
  "required": ["task", "candidate"],
  "properties": {
    "task": {"type": "string"},
    "candidate": {
      "type": ["object", "null"],
      "properties": {
        "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "path": {"type": "string"},
        "resolved": {"type": "boolean"}
      },
      "required": ["slug", "path", "resolved"]
    },
    "escalation": {"type": "string"}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{"task": "scaffold gin handler",
 "candidate": {
   "slug": "go-http-handlers",
   "path": "skills/faion/knowledge/free/dev/software-developer/go-http-handlers/AGENTS.md",
   "resolved": true
 }}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{"task": "thing",
 "candidate": {"slug": "go-fancy-handler", "path": "...", "resolved": false},
 "alt_candidate": {"slug": "go-http-stuff"}}]]></code>
      <note>Two violations: candidate.resolved=false (r2), alt_candidate is multi-pick (r3).</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>candidate has slug + path + resolved=true, OR candidate is null with non-empty escalation.</item>
      <item>slug copied verbatim from a row in this dispatcher.</item>
      <item>path resolves on disk (Glob succeeds before resolved=true is set).</item>
      <item>No alternative-candidate field; downstream uses files-reference if multi-pick needed.</item>
    </list>
  </section>
</text>
