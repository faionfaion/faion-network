<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="cap-pacelc-walkthrough Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply the cap-pacelc-walkthrough methodology end-to-end.</summary>

  <section title="Procedure">
    <step n="1" name="collect-axes-inputs">
      <input>RPO/RTO + workload split + partition exposure</input>
      <action>List inputs as typed citations.</action>
      <output>typed inputs list</output>
    </step>
    <step n="2" name="decide-cap-mode">
      <input>RPO/RTO + read-vs-write criticality</input>
      <action>Pick AP or CP under partition.</action>
      <output>cap_mode value</output>
    </step>
    <step n="3" name="decide-pacelc-mode">
      <input>latency budget + consistency-on-healthy-network preference</input>
      <action>Pick EL or EC.</action>
      <output>pacelc_mode value</output>
      <decision-gate>If latency_budget_p95 &lt; 100ms, default to EL unless data correctness &gt; latency.</decision-gate>
    </step>
    <step n="4" name="draft-decision-and-rationale">
      <input>both modes + inputs</input>
      <action>Write decision + &gt;=2-sentence rationale citing inputs.</action>
      <output>draft ADR</output>
    </step>
    <step n="5" name="validate-and-publish">
      <input>draft</input>
      <action>Run validator; commit + assign owner.</action>
      <output>published ADR</output>
    </step>
  </section>
</text>
