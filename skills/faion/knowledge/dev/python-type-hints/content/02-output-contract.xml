<text id="02-output-contract" title="Python Type Hints Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the typed-module spec emitted by this methodology — covers mypy config, file allowlist, ignore policy, version metadata.</summary>

  <section title="Typed-module spec schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/python-type-hints-spec.json",
  "type": "object",
  "required": ["python_version", "mode", "strict_files", "checker", "version", "last_reviewed"],
  "properties": {
    "python_version":  {"type": "string", "pattern": "^3\\.(9|1[0-9])$"},
    "mode":            {"enum": ["greenfield", "legacy", "library"]},
    "checker":         {"enum": ["mypy", "pyright"]},
    "strict_files":    {"type": "array", "items": {"type": "string"}},
    "test_relax":      {"type": "boolean", "default": true},
    "ignore_policy":   {"enum": ["coded-only", "any"], "default": "coded-only"},
    "future_annotations_pydantic_v2_only": {"type": "boolean", "default": true},
    "version":         {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed":   {"type": "string", "format": "date"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "python_version": "3.12",
  "mode": "legacy",
  "checker": "mypy",
  "strict_files": ["src/api/handlers.py", "src/services/billing.py"],
  "test_relax": true,
  "ignore_policy": "coded-only",
  "future_annotations_pydantic_v2_only": true,
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "python_version": "3.8",
  "mode": "strict-everywhere",
  "checker": "mypy",
  "ignore_policy": "any"
}
]]></code>
    <note>python_version 3.8 below minimum (3.9 required for `list[T]`); mode value not in enum; ignore_policy=any forbidden in this methodology (coded-only mandated); missing version + last_reviewed + strict_files.</note>
  </example>

  <reference path="templates/mypy.toml">Canonical mypy config block</reference>
  <reference path="templates/typecheck-touched.sh">CI gate script</reference>
  <reference path="scripts/validate-python-type-hints.py">Schema validator</reference>
</text>
