<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Coverage Rebuild Playbook Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/coverage-rebuild-playbook.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner",
    "step_id",
    "objective",
    "actions",
    "exit_criteria"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "step_id": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "actions": {
      "type": "array"
    },
    "exit_criteria": {
      "type": "array"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "coverage-rebuild-playbook-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "owner": "@solo-founder",
  "step_id": "step-1",
  "objective": "what this step achieves",
  "actions": [
    "action-1",
    "action-2",
    "action-3"
  ],
  "exit_criteria": [
    "criterion-1"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-coverage-rebuild-playbook.py">Schema validator (stdlib only).</reference>
</text>
