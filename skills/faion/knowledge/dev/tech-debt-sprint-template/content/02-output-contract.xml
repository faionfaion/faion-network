<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Tech Debt Sprint Template Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/tech-debt-sprint-template.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "sprint_window",
    "scope_items",
    "guardrails",
    "exit_metrics",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "sprint_window": {
      "type": "object",
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string"
        },
        "end": {
          "type": "string"
        }
      }
    },
    "scope_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "size"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "size": {
            "type": "string",
            "enum": [
              "XS",
              "S",
              "M",
              "L"
            ]
          }
        }
      }
    },
    "guardrails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "exit_metrics": {
      "type": "object",
      "required": [
        "lint_warn_before",
        "lint_warn_target"
      ],
      "properties": {
        "lint_warn_before": {
          "type": "integer",
          "minimum": 0
        },
        "lint_warn_target": {
          "type": "integer",
          "minimum": 0
        },
        "coverage_pct_target": {
          "type": "number"
        }
      }
    },
    "retro_link": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "td-2026-q2",
  "owner": "ruslan@faion.net",
  "sprint_window": {
    "start": "2026-05-26",
    "end": "2026-06-06"
  },
  "scope_items": [
    {
      "id": "i1",
      "title": "Drop deprecated v1 auth shim",
      "size": "M"
    }
  ],
  "guardrails": [
    "no new features",
    "no migrations"
  ],
  "exit_metrics": {
    "lint_warn_before": 87,
    "lint_warn_target": 40,
    "coverage_pct_target": 75.0
  },
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "",
  "owner": "team",
  "sprint_window": {},
  "scope_items": [],
  "guardrails": [],
  "exit_metrics": {},
  "version": "",
  "last_reviewed": ""
}
    ]]></code>
    <note>Violates required-field presence / forbidden-pattern constraints above.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="collective-owner">owner is &apos;team&apos; / &apos;we&apos; / &apos;engineering&apos;</pattern>
      <pattern id="empty-scope">scope_items is empty</pattern>
      <pattern id="missing-exit-metric">exit_metrics omits a measurable target</pattern>
    </list>
  </section>
  <reference path="scripts/validate-tech-debt-sprint-template.py">Validator script (see scripts/).</reference>
</text>
