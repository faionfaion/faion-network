<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="JavaScript Testing Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the test config bundle.</summary>
  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/javascript-testing.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "runner",
    "dom",
    "http_mock",
    "coverage"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "runner": {
      "enum": [
        "vitest",
        "jest",
        "bun-test"
      ]
    },
    "dom": {
      "enum": [
        "testing-library",
        "none"
      ]
    },
    "http_mock": {
      "enum": [
        "msw",
        "none"
      ]
    },
    "coverage": {
      "type": "object",
      "required": [
        "provider",
        "branch",
        "global_threshold",
        "diff_threshold"
      ],
      "properties": {
        "provider": {
          "enum": [
            "v8",
            "istanbul"
          ]
        },
        "branch": {
          "type": "boolean"
        },
        "global_threshold": {
          "type": "integer",
          "minimum": 70,
          "maximum": 95
        },
        "diff_threshold": {
          "type": "integer",
          "minimum": 80,
          "maximum": 95
        }
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "jt-001",
  "runner": "vitest",
  "dom": "testing-library",
  "http_mock": "msw",
  "coverage": {
    "provider": "v8",
    "branch": true,
    "global_threshold": 80,
    "diff_threshold": 90
  },
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "runner": "mocha",
  "dom": "enzyme",
  "http_mock": "fetch-mock",
  "coverage": {}
}
]]></code>
    <note>runner / dom not in enums; http_mock 'fetch-mock' violates rule msw-for-http; coverage empty; missing required fields.</note>
  </example>
  <reference path="scripts/validate-javascript-testing.py">schema validator</reference>
</text>
