<text id="06-decision-tree" title="Code Quality Trends Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Stack → category → recommendation routing.</summary>

  <decision-tree>
    <root-question id="q-stack">What is the detected stack?</root-question>
    <branch when="stack == typescript">
      <conclusion ref="typed-strict-mode" verdict="strict=true; no-floating-promises; consistent-type-imports"/>
    </branch>
    <branch when="stack == python">
      <conclusion ref="typed-strict-mode" verdict="ruff full set + mypy --strict / pyright strict"/>
    </branch>
    <branch when="stack == react">
      <conclusion ref="perf-budget-required" verdict="Lighthouse budget + RSC-aware lint rules"/>
    </branch>
    <branch when="stack == node">
      <conclusion ref="typed-strict-mode" verdict="TS strict + helmet + npm-audit"/>
    </branch>
    <branch when="stack == mixed">
      <conclusion ref="refresh-quarterly" verdict="per-language sub-audit merged"/>
    </branch>
  </decision-tree>
</text>
