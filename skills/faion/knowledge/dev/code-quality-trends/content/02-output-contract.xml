<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Quality Trends Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for an audit report: per-category gap list + remediation diffs.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/code-quality-trends.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "stack",
    "categories",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "stack": {
      "enum": [
        "typescript",
        "python",
        "react",
        "node",
        "go",
        "rust",
        "mixed"
      ]
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "status",
          "gaps"
        ],
        "properties": {
          "status": {
            "enum": [
              "pass",
              "gap",
              "skipped"
            ]
          },
          "gaps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "diff"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "diff": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "cqt-2026-q2-ts",
  "stack": "typescript",
  "categories": {
    "lint": {
      "status": "gap",
      "gaps": [
        {
          "id": "no-floating-promises",
          "diff": "+ \"@typescript-eslint/no-floating-promises\": \"error\""
        }
      ]
    },
    "types": {
      "status": "pass",
      "gaps": []
    },
    "tests": {
      "status": "gap",
      "gaps": []
    }
  },
  "owner": "ruslan",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "stack": "java",
  "categories": {}
}
]]></code>
    <note>stack 'java' not in enum; missing owner; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-code-quality-trends.py">schema validator</reference>
</text>
