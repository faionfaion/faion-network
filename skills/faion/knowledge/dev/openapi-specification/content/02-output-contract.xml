<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OpenAPI Specification Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/openapi-specification.json",
  "type": "object",
  "required": [
    "openapi_version",
    "canonical_path",
    "lint_config",
    "breaking_change_gate",
    "operation_id_coverage"
  ],
  "properties": {
    "openapi_version": {
      "type": "string",
      "enum": [
        "3.0.3",
        "3.1.0",
        "3.1.1"
      ]
    },
    "canonical_path": {
      "type": "string"
    },
    "lint_config": {
      "type": "object",
      "required": [
        "redocly",
        "spectral"
      ]
    },
    "breaking_change_gate": {
      "type": "object",
      "required": [
        "enabled",
        "tool"
      ]
    },
    "operation_id_coverage": {
      "type": "object",
      "required": [
        "covered",
        "total"
      ]
    },
    "components_reuse_ratio": {
      "type": "number"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "openapi_version": "3.1.0",
  "canonical_path": "openapi.yaml",
  "lint_config": {
    "redocly": ".redocly.yaml",
    "spectral": ".spectral.yaml"
  },
  "breaking_change_gate": {
    "enabled": true,
    "tool": "oasdiff"
  },
  "operation_id_coverage": {
    "covered": 42,
    "total": 42
  },
  "components_reuse_ratio": 0.85
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "openapi_version": "2.0",
  "canonical_path": "",
  "lint_config": {},
  "breaking_change_gate": {
    "enabled": false
  },
  "operation_id_coverage": {
    "covered": 10,
    "total": 42
  }
}
]]></code>
    <note>openapi_version not in enum; lint_config missing required keys; breaking gate disabled; coverage incomplete.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="duplicate-inline-schemas">Same User schema inlined in three operation responses; one updated, two stale.</pattern>
      <pattern id="missing-required-array">Generated TypeScript client treats every field as Partial; runtime crashes on missing keys.</pattern>
      <pattern id="merged-breaking-change">Mobile clients crash en masse after backend deploy; required field added to request schema.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-openapi-specification.py">Validator script (see scripts/).</reference>
</text>
