<text id="06-decision-tree" title="Extreme Programming Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="preconditions">Are preconditions satisfied: build under 30 min, version control with trunk feasible, customer or proxy reachable?</root-question>
      <branch when="preconditions == no">
        <conclusion ref="skip-this-methodology" verdict="fix CI / VCS / customer access first; XP is impractical without these"/>
      </branch>
      <branch when="preconditions == yes">
        <question id="ci-fast">Is CI under 10 minutes?</question>
          <branch when="ci == slow">
            <conclusion ref="trunk-based-green-ci" verdict="halt; optimise CI first"/>
          </branch>
          <branch when="ci == fast">
            <question id="branch-age">Are branches typically &lt;3 days old?</question>
              <branch when="branch == long">
                <conclusion ref="trunk-based-green-ci" verdict="switch to trunk-based + feature flags"/>
              </branch>
              <branch when="branch == short">
                <question id="customer-access">Is a named customer available with &lt;=24h SLA?</question>
                  <branch when="customer == absent">
                    <conclusion ref="on-site-customer-or-proxy" verdict="appoint customer + SLA before continuing"/>
                  </branch>
                  <branch when="customer == present">
                    <conclusion ref="tdd-red-green-refactor" verdict="introduce TDD red-green-refactor on hot paths"/>
                  </branch>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="ci=fast -&amp;gt; branch=short -&amp;gt; customer=present -&amp;gt; tdd-red-green-refactor.">Worked path from root-question to conclusion.</example>
</text>
