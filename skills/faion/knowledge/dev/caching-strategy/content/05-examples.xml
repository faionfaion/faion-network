<text id="05-examples" title="Caching Strategy Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: CACHE-PRICING-GET picks cache-aside on Redis with 300±20% TTL, pubsub-event invalidation, single-flight, and 0.85 hit-rate target.</summary>

  <section title="Scenario">
    <p>GET /pricing hits 12k QPS; pricing data changes on admin edit (~10x/day).</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "endpoint": "GET /pricing",
  "rps": 12000,
  "stale_tolerance_seconds": 60
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "strategy_id": "CACHE-PRICING-GET",
  "pattern": "cache-aside",
  "ttl_seconds_base": 300,
  "ttl_jitter_pct": 20,
  "invalidation": {
    "mode": "pubsub-event",
    "channel": "pricing-changes"
  },
  "single_flight": true,
  "hit_rate_target": 0.85,
  "store": "redis"
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-caching-strategy.py --file artefact.json
OK
]]></code>
  </section>
</text>
