<text id="02-output-contract" title="Go Project Structure Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/go-project-structure.json",
  "type": "object",
  "required": ["module_path", "cmd_binaries", "internal_packages", "pkg_packages", "top_level_loose_files", "cycles_detected"],
  "properties": {
    "module_path": {"type": "string", "pattern": "^[a-z0-9./_-]+$"},
    "cmd_binaries": {"type": "integer", "minimum": 1},
    "internal_packages": {"type": "integer", "minimum": 1},
    "pkg_packages": {"type": "integer", "minimum": 0},
    "top_level_loose_files": {"type": "integer", "minimum": 0, "maximum": 0},
    "cycles_detected": {"type": "integer", "minimum": 0, "maximum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "module_path": "github.com/acme/payments",
  "cmd_binaries": 2,
  "internal_packages": 11,
  "pkg_packages": 0,
  "top_level_loose_files": 0,
  "cycles_detected": 0,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "module_path": "X",
  "cmd_binaries": 0,
  "internal_packages": 0,
  "top_level_loose_files": 4,
  "cycles_detected": 2
}
]]></code>
    <note>module_path has uppercase, cmd_binaries below minimum, internal_packages below minimum, loose files and cycles above 0.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">main.go containing business logic instead of just wiring</pattern>
      <pattern id="f2">Internal-only package placed in pkg/ instead of internal/</pattern>
      <pattern id="f3">Cyclic import between internal subpackages</pattern>
      <pattern id="f4">Loose .go file at module root</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Normalise module_path to lowercase.</transformation>
      <transformation>Sort cmd binaries alphabetically in the spec.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-go-project-structure.py">Validator script</reference>
</text>
