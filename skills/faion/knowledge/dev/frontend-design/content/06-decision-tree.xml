<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Frontend Design Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for frontend-design.</summary>

  <decision-tree>
    <root-question id="q-root">Is the design direction undecided AND component count &gt;=20?</root-question>

    <branch when="design_system_locked == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — inherit existing system"/>
    </branch>
    <branch when="component_count &lt; 20 OR scope == single_page">
      <conclusion ref="skip-this-methodology" verdict="SKIP — direct build is faster"/>
    </branch>
    <branch when="variant_set_size_outside_3_to_5 == true">
      <conclusion ref="r1-three-to-five-distinct-variants" verdict="BLOCK — regenerate variant set with correct cardinality"/>
    </branch>
    <branch when="variants_differ_only_in_color == true">
      <conclusion ref="r1-three-to-five-distinct-variants" verdict="BLOCK — enforce structural distinctness"/>
    </branch>
    <branch when="selection_without_screenshots == true">
      <conclusion ref="r2-screenshot-before-decide" verdict="BLOCK — render and compare first"/>
    </branch>
    <branch when="components_started_before_tokens == true">
      <conclusion ref="r3-tokens-before-components" verdict="BLOCK — author tokens first"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — proceed with scaffold"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="frontend-design-happy-path">
    32 components + undecided direction → first two branches do not match → 4 distinct variants → screenshots rendered → tokens defined first → all_gates_green=true → APPROVE.
  </example>
</text>
