<text id="06-decision-tree" title="nodejs-express-fastify Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Is this a long-lived Node.js HTTP service (Express or Fastify)?</root-question>
    <branch when="node_http_longlived == true">
      <question>Can the team install helmet + cors + rate-limit + pino?</question>
      <branch when="deps_installable == true">
        <question>Will the team accept one central error handler?</question>
        <branch when="one_error_handler == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="one_error_handler == false">
          <conclusion ref="r5"/>
        </branch>
      </branch>
      <branch when="deps_installable == false">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="node_http_longlived == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="new Fastify service with rate-limit + error handler -> run-the-checklist"/>
  </decision-tree>
</text>
