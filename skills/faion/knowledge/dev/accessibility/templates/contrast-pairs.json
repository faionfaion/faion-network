{
  "__faion_header__": {
    "purpose": "Contrast-pair table for one screen",
    "consumes": "design tokens (foreground/background pairs)",
    "produces": "checks.contrast block input",
    "depends_on": "content/01-core-rules.xml",
    "token_budget_impact": "~120 tokens when loaded"
  },
  "pairs": [
    {"context": "body text", "fg": "#1a1a1a", "bg": "#ffffff", "ratio_required": 4.5},
    {"context": "muted text", "fg": "#555555", "bg": "#ffffff", "ratio_required": 4.5},
    {"context": "primary CTA text", "fg": "#ffffff", "bg": "#1e6bdb", "ratio_required": 4.5},
    {"context": "focus ring", "fg": "#1e6bdb", "bg": "#ffffff", "ratio_required": 3.0},
    {"context": "disabled button", "fg": "#999999", "bg": "#f0f0f0", "ratio_required": 3.0, "non_interactive": true}
  ]
}
