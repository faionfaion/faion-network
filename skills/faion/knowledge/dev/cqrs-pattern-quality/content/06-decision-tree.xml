<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="cqrs-pattern Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-root">Are reads and writes asymmetric enough to justify separate models?</root-question>
      <branch when="read_write_asymmetry == false">
        <conclusion ref="skip-this-methodology" verdict="skip — repository pattern is sufficient"/>
      </branch>
      <branch when="read_write_asymmetry == true">
        <question id="q-next">team_understands_eventual_consistency == true?</question>
        <branch when="team_understands_eventual_consistency == true">
          <conclusion ref="r1" verdict="split into CommandHandler + QueryHandler + Mediator"/>
        </branch>
        <branch when="team_understands_eventual_consistency == false">
          <conclusion ref="skip-this-methodology" verdict="skip until team has read-after-write story; CQRS without that is a foot-gun"/>
        </branch>
      </branch>
  </decision-tree>
</text>
