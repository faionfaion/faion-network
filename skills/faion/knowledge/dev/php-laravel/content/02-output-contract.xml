<text id="02-output-contract" title="Laravel Framework Fundamentals Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema describing one Laravel module artefact (provider + service + middleware + config).</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/php-laravel.json",
  "type": "object",
  "required": [
    "service_provider",
    "contract_bound",
    "facade_in_services_count",
    "route_in_route_file_only",
    "env_outside_config_count"
  ],
  "properties": {
    "service_provider": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]+ServiceProvider$"
    },
    "contract_bound": {
      "type": "boolean",
      "const": true
    },
    "facade_in_services_count": {
      "type": "integer",
      "maximum": 0
    },
    "route_in_route_file_only": {
      "type": "boolean",
      "const": true
    },
    "env_outside_config_count": {
      "type": "integer",
      "maximum": 0
    },
    "middleware_used_for_crosscutting": {
      "type": "boolean",
      "const": true
    },
    "config_cache_compatible": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service_provider": "PaymentServiceProvider",
  "contract_bound": true,
  "facade_in_services_count": 0,
  "route_in_route_file_only": true,
  "env_outside_config_count": 0,
  "middleware_used_for_crosscutting": true,
  "config_cache_compatible": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service_provider": "Payment",
  "contract_bound": false,
  "facade_in_services_count": 12,
  "route_in_route_file_only": false,
  "env_outside_config_count": 8,
  "middleware_used_for_crosscutting": false,
  "config_cache_compatible": false
}
]]></code>
    <note>Provider name missing suffix; no binding; facades in services; routes inline; env() outside config; no middleware; config:cache breaks.</note>
  </example>
  <forbidden>
      <pattern id="facade-in-service">Calling a Facade (`Mail::send`, `Cache::get`) from inside a service class.</pattern>
      <pattern id="env-outside-config">`env(...)` call outside `config/*.php` files.</pattern>
      <pattern id="inline-bind">`app()-&gt;bind(...)` outside a Service Provider's register().</pattern>
  </forbidden>

  <reference path="scripts/validate-php-laravel.py">Validator script</reference>
</text>
