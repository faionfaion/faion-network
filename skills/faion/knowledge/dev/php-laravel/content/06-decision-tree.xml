<text id="06-decision-tree" title="Laravel Framework Fundamentals Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping framework smell to a Laravel rule.</summary>

  <decision-tree>
      <root-question id="q-smell">What's the smell?</root-question>

        <branch when="smell == facade_in_service">
          <conclusion ref="constructor-injection-over-facades" verdict="refactor to constructor-injected contract"/>
        </branch>
        <branch when="smell == env_outside_config">
          <conclusion ref="config-via-config-helper" verdict="move env() to config/*.php; reference via config()"/>
        </branch>
        <branch when="smell == inline_route_closure">
          <conclusion ref="routes-in-route-files-only" verdict="convert to controller method reference"/>
        </branch>
        <branch when="smell == repeated_cross_cut">
          <conclusion ref="middleware-for-crosscutting" verdict="extract to middleware"/>
        </branch>
        <branch when="smell == inline_bind">
          <conclusion ref="contract-bind-in-provider" verdict="move binding to a Service Provider"/>
        </branch>
    </decision-tree>

    <example trace="PaymentService refactor">
      smell=facade_in_service → constructor-inject the contract.
    </example>
</text>
