<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="TDD Workflow Output Contract" version="2.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the tdd-workflow-config artefact.</summary>

  <output-contract produces="playbook-step">
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["slug", "version", "decision", "drivers", "audit"],
  "properties": {
    "slug": {"const": "tdd-workflow"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {
      "type": "object",
      "required": ["mode", "test_command", "claude_md_path", "settings_json_path", "behavior_order"],
      "properties": {
        "mode": {"enum": ["strict-tdd", "spike-first", "benchmark-driven", "visual-deferred"]},
        "test_command": {"type": "string"},
        "claude_md_path": {"type": "string"},
        "settings_json_path": {"type": "string"},
        "behavior_order": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      }
    },
    "drivers": {
      "type": "object",
      "required": ["behavior_known", "visual_feedback_drives", "performance_dominant"],
      "additionalProperties": true
    },
    "audit": {
      "type": "object",
      "required": ["rule_refs"],
      "properties": {"rule_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^r[0-9a-z-]+$"}}}
    }
  }
}
]]></schema>

    <example valid="true" title="Strict TDD with pytest hook"><![CDATA[
{
  "slug": "tdd-workflow",
  "version": "2.0.0",
  "decision": {
    "mode": "strict-tdd",
    "test_command": "pytest tests -x --tb=short",
    "claude_md_path": "CLAUDE.md",
    "settings_json_path": ".claude/settings.json",
    "behavior_order": ["happy-path-success", "edge-empty-input", "error-timeout"]
  },
  "drivers": {"behavior_known": true, "visual_feedback_drives": false, "performance_dominant": false},
  "audit": {"rule_refs": ["r1-red-before-green", "r2-one-behavior-per-cycle", "r-strict-tdd"]}
}
]]></example>

    <example valid="false" title="Empty behavior_order + missing audit"><![CDATA[
{
  "slug": "tdd-workflow",
  "version": "2.0.0",
  "decision": {"mode": "strict-tdd", "test_command": "x", "claude_md_path": "x", "settings_json_path": "x", "behavior_order": []},
  "drivers": {},
  "audit": {"rule_refs": []}
}
]]></example>

    <example-violations>
      <violation>decision.behavior_order must have minItems 1.</violation>
      <violation>drivers missing required keys.</violation>
      <violation>audit.rule_refs empty.</violation>
    </example-violations>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>decision.mode matches the decision-tree branch.</item>
      <item>If mode==strict-tdd, PostToolUse hook is wired in settings_json_path.</item>
      <item>If mode==spike-first, behavior_order documents the post-spike tests.</item>
    </list>
  </section>

  <reference path="templates/tdd-cycle.sh">Working per-behavior loop.</reference>
  <reference path="scripts/validate-tdd-workflow.py">Schema validator.</reference>
</text>
