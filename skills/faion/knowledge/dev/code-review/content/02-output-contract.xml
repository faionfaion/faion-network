<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="code-review Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying code-review. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["pr_lines","ci_green","approvals","conversations_resolved","agentic_pre_review_ran"],"properties":{"pr_lines":{"type":"integer","minimum":0},"ci_green":{"const":true},"approvals":{"type":"integer","minimum":1},"conversations_resolved":{"const":true},"agentic_pre_review_ran":{"const":true},"large_pr_approved":{"type":"boolean"}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"pr_lines":312,"ci_green":true,"approvals":1,"conversations_resolved":true,"agentic_pre_review_ran":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"pr_lines":1450,"ci_green":false,"approvals":0,"conversations_resolved":false,"agentic_pre_review_ran":false,"large_pr_approved":false}
]]></code>
      <note>Invalid: PR exceeds 400 lines without large-pr-approved label; CI not green; no approvals; conversations open; no pre-review.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>pr_lines &lt; 400 OR large_pr_approved == true.</item>
      <item>ci_green == true.</item>
      <item>approvals &gt;= 1 (&gt;=2 for critical modules).</item>
      <item>conversations_resolved == true.</item>
      <item>agentic_pre_review_ran == true.</item>
    </list>
  </section>
</text>
