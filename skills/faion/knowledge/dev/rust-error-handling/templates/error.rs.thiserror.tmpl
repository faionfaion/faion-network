// purpose:   thiserror-based Error enum scaffold for Rust libraries
// consumes:  list of fallible call sites from cargo check
// produces:  src/error.rs with typed variants + From conversions
// depends-on: thiserror crate in [dependencies]
// token-budget-impact: ~150 tokens when referenced

use thiserror::Error;

#[derive(Debug, Error)]
pub enum CrateError {
    #[error("I/O error: {0}")]
    Io(#[from] std::io::Error),

    #[error("parse error: {0}")]
    Parse(#[from] serde_json::Error),

    #[error("resource '{id}' not found")]
    NotFound { id: String },

    #[error("invalid state: {0}")]
    InvalidState(String),
}

pub type Result<T, E = CrateError> = std::result::Result<T, E>;
