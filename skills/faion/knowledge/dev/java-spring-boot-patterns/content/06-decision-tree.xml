<text id="06-decision-tree" title="Spring Boot Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Decision tree mapping configuration shape to a Boot pattern rule.</summary>

  <decision-tree>
      <root-question id="q-config-shape">Configuration shape?</root-question>

        <branch when="values_count_per_bean &gt; 3">
          <conclusion ref="configuration-properties-typed" verdict="extract to @ConfigurationProperties record"/>
        </branch>
        <branch when="exception_translation_needed == true">
          <conclusion ref="controller-advice-problem-detail" verdict="create @RestControllerAdvice with ProblemDetail mappings"/>
        </branch>
        <branch when="env_specific_logic_inline == true">
          <conclusion ref="conditional-on-property" verdict="replace runtime env branches with @Profile or @ConditionalOnProperty beans"/>
        </branch>
        <branch when="values_count_per_bean &lt;= 3">
          <conclusion ref="no-system-getenv" verdict="@Value acceptable; still forbid System.getenv()"/>
        </branch>
    </decision-tree>

    <example trace="MailService refactor">
      values_count_per_bean=8 → extract MailProperties record with @Validated.
    </example>
</text>
