<text id="05-examples" title="OpenAPI Spec Authoring Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: OAS-PUBLIC-API-V1 lints zero errors, has zero duplicates, declares url-path versioning with 180-day deprecation window.</summary>

  <section title="Scenario">
    <p>Public API spec at openapi/public-api.yaml; auth artefact AUTH-PARTNER-API; target lint-clean before contract-first ships.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "spec": "openapi/public-api.yaml",
  "auth_id": "AUTH-PARTNER-API"
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "spec_id": "OAS-PUBLIC-API-V1",
  "openapi_version": "3.1.0",
  "info_x_versioning": {
    "scheme": "url-path",
    "deprecation_window_days": 180,
    "breaking_change_policy": "major-bump-required"
  },
  "spectral_errors": 0,
  "spectral_warnings": 3,
  "duplicate_schemas": 0,
  "security_aligned_with_auth_id": "AUTH-PARTNER-API",
  "verdict": "pass"
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-api-openapi-spec.py --file artefact.json
OK
]]></code>
  </section>
</text>
