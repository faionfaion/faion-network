<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Go Standard Layout Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/go-standard-layout.json",
  "type": "object",
  "required": ["feature_path", "handler_logic_lines", "service_present", "repo_present", "http_imports_in_service", "db_imports_in_handler"],
  "properties": {
    "feature_path": {"type": "string", "pattern": "^internal/[a-z_]+$"},
    "handler_logic_lines": {"type": "integer", "minimum": 0, "maximum": 50},
    "service_present": {"type": "boolean"},
    "repo_present": {"type": "boolean"},
    "http_imports_in_service": {"type": "integer", "minimum": 0, "maximum": 0},
    "db_imports_in_handler": {"type": "integer", "minimum": 0, "maximum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "feature_path": "internal/orders",
  "handler_logic_lines": 12,
  "service_present": true,
  "repo_present": true,
  "http_imports_in_service": 0,
  "db_imports_in_handler": 0,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "feature_path": "app/orders",
  "handler_logic_lines": 180,
  "service_present": false,
  "http_imports_in_service": 2
}
]]></code>
    <note>feature_path not in internal/, handler_logic_lines too high, service missing, HTTP imports in service.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Handler containing branching business logic</pattern>
      <pattern id="f2">Service importing net/http or HTTP framework packages</pattern>
      <pattern id="f3">Handler importing database/sql or ORM directly</pattern>
      <pattern id="f4">Interface declared on the repo side rather than service side</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>gofmt before review.</transformation>
      <transformation>Sort exported symbols alphabetically per file.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-go-standard-layout.py">Validator script</reference>
</text>
