<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Node.js Express Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Auth + scale → service shape.</summary>
  <decision-tree>
    <root-question id="q-scale">Expected rps?</root-question>
    <branch when="rps &amp;lt; 1000">
      <question id="q-auth">Auth?</question>
      <branch when="auth == none">
        <conclusion ref="helmet-first" verdict="Express minimal stack"/>
      </branch>
      <branch when="auth == token">
        <conclusion ref="helmet-first" verdict="Express + JWT middleware"/>
      </branch>
      <branch when="auth == session">
        <conclusion ref="helmet-first" verdict="Express + express-session + Redis store"/>
      </branch>
    </branch>
    <branch when="rps &amp;gt;= 1000 AND rps &amp;lt; 5000">
      <conclusion ref="rate-limit-floor" verdict="Express + horizontal scale"/>
    </branch>
    <branch when="rps &amp;gt;= 5000">
      <conclusion ref="rate-limit-floor" verdict="Consider Fastify — see [[nodejs-fastify]]"/>
    </branch>
  </decision-tree>
</text>
