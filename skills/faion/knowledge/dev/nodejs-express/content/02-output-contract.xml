<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Node.js Express Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the Express service spec.</summary>
  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/nodejs-express.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "service_name",
    "routes",
    "middleware",
    "auth"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "service_name": {
      "type": "string"
    },
    "node_version": {
      "type": "string"
    },
    "express_version": {
      "type": "string"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "method",
          "path"
        ],
        "properties": {
          "method": {
            "enum": [
              "GET",
              "POST",
              "PUT",
              "PATCH",
              "DELETE"
            ]
          },
          "path": {
            "type": "string"
          }
        }
      }
    },
    "middleware": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auth": {
      "enum": [
        "none",
        "token",
        "session"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ne-001",
  "service_name": "billing-api",
  "node_version": "20.12.0",
  "express_version": "4.19.0",
  "routes": [
    {
      "method": "GET",
      "path": "/health"
    },
    {
      "method": "POST",
      "path": "/invoices"
    }
  ],
  "middleware": [
    "helmet",
    "cors",
    "compression",
    "pino-http",
    "express-rate-limit",
    "error-handler"
  ],
  "auth": "token",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service_name": "x",
  "routes": [],
  "middleware": [],
  "auth": "none"
}
]]></code>
    <note>middleware empty (helmet + rate-limit missing); missing artefact_id, version, last_reviewed.</note>
  </example>
  <reference path="scripts/validate-nodejs-express.py">schema validator</reference>
</text>
