<methodology slug="feature-flags">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>software-developer</domain>
    <summary>Use feature flags to gate incomplete code behind runtime toggles, enabling trunk-based development and progressive rollouts without redeployment.</summary>
    <category>release</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-25</created>
    <tags>
      <tag>feature-flags</tag>
      <tag>release-management</tag>
      <tag>trunk-based-dev</tag>
      <tag>progressive-rollout</tag>
      <tag>kill-switch</tag>
    </tags>
    <tools>
      <tool>claude-code</tool>
    </tools>
    <languages>
      <language>python</language>
      <language>javascript</language>
      <language>typescript</language>
    </languages>
