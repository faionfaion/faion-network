<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GraphQL API Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/graphql-api-design.json",
  "type": "object",
  "required": ["schema_id", "types_count", "mutations_count", "payload_types_present", "auth_directives_present", "non_payload_mutations", "scalar_id_relations"],
  "properties": {
    "schema_id": {"type": "string", "minLength": 3},
    "types_count": {"type": "integer", "minimum": 5},
    "mutations_count": {"type": "integer", "minimum": 1},
    "payload_types_present": {"type": "boolean"},
    "auth_directives_present": {"type": "boolean"},
    "non_payload_mutations": {"type": "integer", "minimum": 0, "maximum": 0},
    "scalar_id_relations": {"type": "integer", "minimum": 0, "maximum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "schema_id": "acme-platform-graph",
  "types_count": 18,
  "mutations_count": 12,
  "payload_types_present": true,
  "auth_directives_present": true,
  "non_payload_mutations": 0,
  "scalar_id_relations": 0,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "schema_id": "x",
  "types_count": 2,
  "non_payload_mutations": 5,
  "scalar_id_relations": 7
}
]]></code>
    <note>schema_id too short, types_count below minimum, missing mutations_count + flags, non_payload_mutations and scalar_id_relations above 0 (both must be 0).</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Mutation returning a scalar (Boolean, ID) instead of a Payload type</pattern>
      <pattern id="f2">Authorization check embedded in a resolver body instead of via directive</pattern>
      <pattern id="f3">Paginated list without Connection/Edge wrapper</pattern>
      <pattern id="f4">Relation using raw scalar ID instead of opaque ID</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Sort SDL types alphabetically for diff hygiene.</transformation>
      <transformation>Normalise directive arguments to camelCase.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-graphql-api-design.py">Validator script</reference>
</text>
