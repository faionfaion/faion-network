<text id="05-examples" title="API Contract-First Development Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: CPACK-PUBLIC-API-V1 ships a 1.4.0 spec with 18 operations, 42 examples, and CI gate.</summary>

  <section title="Scenario">
    <p>Public API with TS + Python SDK consumers. Spec at openapi/public-api.yaml.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "endpoints": 18,
  "consumers": [
    "web",
    "mobile",
    "partner"
  ]
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "pack_id": "CPACK-PUBLIC-API-V1",
  "spec_path": "openapi/public-api.yaml",
  "spec_version": "1.4.0",
  "ci_diff_job": ".github/workflows/contract-ci.yaml",
  "codegen_targets": [
    "typescript",
    "python"
  ],
  "examples_count": 42,
  "operations_count": 18,
  "verdict": "pass"
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-api-contract-first.py --file artefact.json
OK
]]></code>
  </section>
</text>
