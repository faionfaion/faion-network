<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI Diff Size Discipline Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by LOC + files + semantic-unit count to a rule in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-loc">loc_touched &lt;= 200?</root-question>

    <branch when="loc_touched &gt; 200">
      <conclusion ref="loc-cap" verdict="verdict=split; emit split-plan with ordered slices"/>
    </branch>

    <branch when="loc_touched &lt;= 200">
      <question id="q-files">files_touched &lt;= 8?</question>
      <branch when="files_touched &gt; 8">
        <conclusion ref="file-cap" verdict="verdict=split; refactor and feature must be separate"/>
      </branch>
      <branch when="files_touched &lt;= 8">
        <question id="q-units">len(semantic_units) == 1?</question>
        <branch when="semantic_units &gt; 1">
          <conclusion ref="single-unit" verdict="verdict=split; one unit per PR"/>
        </branch>
        <branch when="semantic_units == 1">
          <conclusion ref="split-plan-required" verdict="verdict=pass; allow merge"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="pr-1432">
    loc=142 &lt;= 200 → files=5 &lt;= 8 → semantic_units=[feature] (len=1) → conclusion split-plan-required → verdict=pass.
  </example>
</text>
