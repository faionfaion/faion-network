<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Continuous Delivery Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces, plus valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "every_commit_releasable",
    "pipeline_automated",
    "schema_migration_pattern",
    "pr_max_lines",
    "feature_flag_required_fields",
    "rollback_step_required"
  ],
  "properties": {
    "every_commit_releasable": {
      "const": true
    },
    "pipeline_automated": {
      "const": true
    },
    "schema_migration_pattern": {
      "const": "expand-contract"
    },
    "pr_max_lines": {
      "type": "integer",
      "maximum": 200
    },
    "feature_flag_required_fields": {
      "type": "array",
      "items": {
        "enum": [
          "owner",
          "expires_on"
        ]
      },
      "minItems": 2
    },
    "rollback_step_required": {
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "every_commit_releasable": true,
  "pipeline_automated": true,
  "schema_migration_pattern": "expand-contract",
  "pr_max_lines": 200,
  "feature_flag_required_fields": [
    "owner",
    "expires_on"
  ],
  "rollback_step_required": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "every_commit_releasable": false,
  "pipeline_automated": false,
  "schema_migration_pattern": "single-shot",
  "pr_max_lines": 1500,
  "feature_flag_required_fields": [],
  "rollback_step_required": false
}
]]></code>
    <note>Pipeline manual; single-shot migrations; oversized PRs; flags without owner/expiry; no rollback (rules r1-r6 violated).</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">every_commit_releasable is false (r1)</pattern>
      <pattern id="f2">pipeline_automated is false (r2)</pattern>
      <pattern id="f3">schema_migration_pattern is `single-shot` (r3)</pattern>
      <pattern id="f4">pr_max_lines >200 (r4)</pattern>
      <pattern id="f5">feature_flag_required_fields missing owner or expires_on (r5)</pattern>
      <pattern id="f6">rollback_step_required is false (r6)</pattern>
    </forbidden>
  </output-contract>

  <reference path="scripts/validate-continuous-delivery.py">Validator script</reference>
</text>
