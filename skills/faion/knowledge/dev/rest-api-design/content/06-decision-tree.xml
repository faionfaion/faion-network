<text id="06-decision-tree" title="REST API Design Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="rest-fits">Does the API surface fit a resource (CRUD-over-nouns) model?</root-question>
      <branch when="fits == false">
        <conclusion ref="skip-this-methodology" verdict="skip; use GraphQL or gRPC methodology"/>
      </branch>
      <branch when="fits == true">
        <question id="url-shape">Are existing URLs noun-based?</question>
          <branch when="urls == verb_in_path">
            <conclusion ref="nouns-not-verbs" verdict="rewrite URLs to plural nouns"/>
          </branch>
          <branch when="urls == noun_only">
            <question id="collection-size">Will any collection exceed 1k rows?</question>
              <branch when="size == large">
                <conclusion ref="cursor-pagination-for-large" verdict="use cursor pagination"/>
              </branch>
              <branch when="size == small">
                <conclusion ref="status-code-truthful" verdict="ensure status codes per RFC 9110"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="fits=true -&amp;gt; urls=noun_only -&amp;gt; size=large -&amp;gt; cursor-pagination-for-large.">Worked path from root-question to conclusion.</example>
</text>
