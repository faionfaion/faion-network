<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="REST API Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rest-api-design.json",
  "type": "object",
  "required": [
    "resources",
    "version_strategy",
    "error_format",
    "pagination",
    "status_codes"
  ],
  "properties": {
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "url"
        ]
      }
    },
    "version_strategy": {
      "type": "string",
      "enum": [
        "path",
        "header",
        "query"
      ]
    },
    "error_format": {
      "type": "string",
      "enum": [
        "problem_json",
        "custom"
      ]
    },
    "pagination": {
      "type": "string",
      "enum": [
        "cursor",
        "offset",
        "page_number"
      ]
    },
    "status_codes": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "auth_model": {
      "type": "string"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "resources": [
    {
      "name": "users",
      "url": "/v1/users"
    },
    {
      "name": "orders",
      "url": "/v1/orders"
    }
  ],
  "version_strategy": "path",
  "error_format": "problem_json",
  "pagination": "cursor",
  "status_codes": [
    200,
    201,
    204,
    400,
    401,
    403,
    404,
    409,
    422,
    429,
    500
  ],
  "auth_model": "OAuth2 Bearer"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "resources": [
    {
      "name": "user",
      "url": "/getUser"
    }
  ],
  "version_strategy": "implicit",
  "error_format": "plain",
  "pagination": "offset",
  "status_codes": [
    200
  ]
}
]]></code>
    <note>resource URL has verb; version_strategy not in enum; error_format=plain forbidden; pagination=offset at scale forbidden; status_codes incomplete.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="rpc-disguised-as-rest">Routes like `/api/getUser`, `/api/doRefund`; codegen produces unnatural client methods.</pattern>
      <pattern id="200-on-error">200 OK with `{error: 'not found'}` body; client SDK does not retry, monitoring dashboards green during outage.</pattern>
      <pattern id="offset-pagination-at-scale">Page 500 of /v1/events takes 8 seconds; DB CPU at 90%.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-rest-api-design.py">Validator script (see scripts/).</reference>
</text>
