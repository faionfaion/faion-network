<text id="06-decision-tree" title="go-http-handlers Decision Tree" version="1.0.0" est_tokens="500">
  <decision-tree>
    <root-question>Is this a long-lived Go HTTP server that owns its lifecycle?</root-question>
    <branch when="server_owns_lifecycle == true">
      <question>Can the team use explicit middleware composition (gin.New / echo.New)?</question>
      <branch when="explicit_mw == true">
        <question>Are all four http.Server timeouts available in config?</question>
        <branch when="timeouts_configurable == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="timeouts_configurable == false">
          <conclusion ref="r8"/>
        </branch>
      </branch>
      <branch when="explicit_mw == false">
        <conclusion ref="r2"/>
      </branch>
    </branch>
    <branch when="server_owns_lifecycle == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <example trace="Gin service, explicit middleware accepted, timeouts in env -> run-the-checklist"/>
  </decision-tree>
</text>
