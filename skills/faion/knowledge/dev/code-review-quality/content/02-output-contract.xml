<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Review Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for the review report artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/code-review.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "pr_ref",
    "verdict",
    "categories",
    "comments"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "pr_ref": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "approve",
        "request-changes",
        "block-size",
        "block-tests-red"
      ]
    },
    "categories": {
      "type": "object",
      "required": [
        "correctness",
        "design",
        "security",
        "performance",
        "tests",
        "docs"
      ],
      "additionalProperties": false,
      "properties": {
        "correctness": {
          "enum": [
            "ok",
            "gap",
            "na"
          ]
        },
        "design": {
          "enum": [
            "ok",
            "gap",
            "na"
          ]
        },
        "security": {
          "enum": [
            "ok",
            "gap",
            "na"
          ]
        },
        "performance": {
          "enum": [
            "ok",
            "gap",
            "na"
          ]
        },
        "tests": {
          "enum": [
            "ok",
            "gap",
            "na"
          ]
        },
        "docs": {
          "enum": [
            "ok",
            "gap",
            "na"
          ]
        }
      }
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "category",
          "body"
        ],
        "properties": {
          "label": {
            "enum": [
              "praise",
              "nitpick",
              "suggestion",
              "issue",
              "question"
            ]
          },
          "category": {
            "enum": [
              "correctness",
              "design",
              "security",
              "performance",
              "tests",
              "docs"
            ]
          },
          "body": {
            "type": "string"
          }
        }
      }
    },
    "agent_only": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "cr-001",
  "pr_ref": "https://github.com/org/repo/pull/2200",
  "verdict": "request-changes",
  "categories": {
    "correctness": "gap",
    "design": "ok",
    "security": "ok",
    "performance": "na",
    "tests": "gap",
    "docs": "ok"
  },
  "comments": [
    {
      "label": "issue",
      "category": "correctness",
      "body": "Race condition on the shared cache write at L142."
    },
    {
      "label": "suggestion",
      "category": "tests",
      "body": "Add an explicit test for the empty-input branch in handler()."
    }
  ],
  "agent_only": true,
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pr_ref": "x",
  "verdict": "approve",
  "categories": {},
  "comments": []
}
]]></code>
    <note>categories must include all six keys; missing artefact_id, version, last_reviewed. Agent-only approve violates rule no-sole-approver-agent.</note>
  </example>

  <reference path="scripts/validate-code-review.py">schema validator</reference>
</text>
