<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Code Review Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Size + tests → category coverage → verdict.</summary>

  <decision-tree>
    <root-question id="q-size">Is the PR diff (excluding tests + lockfiles) ≤ 400 lines?</root-question>
    <branch when="size &amp;gt; 400">
      <conclusion ref="size-cap-400-lines" verdict="block-size"/>
    </branch>
    <branch when="size &amp;lt;= 400">
      <question id="q-tests">Are required tests green?</question>
      <branch when="tests_green == false">
        <conclusion ref="size-cap-400-lines" verdict="block-tests-red"/>
      </branch>
      <branch when="tests_green == true">
        <question id="q-any-issue">Did the category scan find any 'issue' label comment?</question>
        <branch when="any_issue == true">
          <conclusion ref="six-categories" verdict="request-changes"/>
        </branch>
        <branch when="any_issue == false">
          <conclusion ref="no-sole-approver-agent" verdict="approve (human sign-off required)"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>
</text>
