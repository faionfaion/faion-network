<text id="06-decision-tree" title="Go Concurrency Patterns Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for go-concurrency-patterns.</summary>

  <decision-tree>
    <root-question id="q-root">Does the workload have parallelism potential AND is concurrency owned by application code (not framework)?</root-question>

    <branch when="concurrency_owned_by_framework == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — framework owns the pool"/>
    </branch>
    <branch when="parallelism_potential == false">
      <conclusion ref="skip-this-methodology" verdict="SKIP — sequential is fine"/>
    </branch>
    <branch when="unbounded_spawn_present == true">
      <conclusion ref="r1-bounded-pool-not-unbounded-goroutines" verdict="BLOCK — add a bound"/>
    </branch>
    <branch when="goroutine_without_context == true">
      <conclusion ref="r2-context-everywhere" verdict="BLOCK — plumb context"/>
    </branch>
    <branch when="channel_closed_by_receiver == true">
      <conclusion ref="r3-channel-closed-by-sender" verdict="BLOCK — move close to sender"/>
    </branch>
    <branch when="multi_worker_without_errgroup == true">
      <conclusion ref="r6-errgroup-for-first-error" verdict="BLOCK — switch to errgroup.WithContext"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — concurrent code ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="go-concurrency-patterns-happy-path">
    I/O-bound service + custom pool → first two branches do not match → bounded pool → context plumbed → sender closes → errgroup used → all_gates_green=true → APPROVE.
  </example>
</text>
