<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-quality Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the artifact produced by applying django-quality. </summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","required":["formatter","linter","type_checker","security_scanner","pre_commit_used","config_consolidated"],"properties":{"formatter":{"const":"ruff"},"linter":{"const":"ruff"},"type_checker":{"const":"mypy"},"security_scanner":{"const":"bandit"},"pre_commit_used":{"const":true},"config_consolidated":{"const":true},"django_stubs_plugin":{"const":true}}}
]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[
{"formatter":"ruff","linter":"ruff","type_checker":"mypy","security_scanner":"bandit","pre_commit_used":true,"config_consolidated":true,"django_stubs_plugin":true}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[
{"formatter":"black","linter":"flake8","type_checker":"none","security_scanner":"none","pre_commit_used":false,"config_consolidated":false}
]]></code>
      <note>Invalid: legacy tool stack, no pre-commit, scattered config.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>ruff used for both format and lint.</item>
      <item>mypy + django-stubs plugin wired.</item>
      <item>bandit at high severity in CI.</item>
      <item>pre-commit configured.</item>
      <item>All config in pyproject.toml.</item>
    </list>
  </section>
</text>
