<text id="02-output-contract" title="event-sourcing-basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces, with valid and invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/event-sourcing-basics.json",
  "type": "object",
  "required": [
    "aggregate_name",
    "events",
    "applies_via_dispatch",
    "uses_optimistic_concurrency"
  ],
  "properties": {
    "aggregate_name": {
      "type": "string",
      "minLength": 2
    },
    "events": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Za-z0-9]*(ed|en|d|t)$|^[A-Z][A-Za-z0-9]*(V[0-9]+)?$"
      },
      "minItems": 1
    },
    "applies_via_dispatch": {
      "const": true
    },
    "uses_optimistic_concurrency": {
      "const": true
    },
    "schema_evolution_plan_doc": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "aggregate_name": "Order",
  "events": [
    "OrderPlaced",
    "ItemAdded",
    "OrderShipped"
  ],
  "applies_via_dispatch": true,
  "uses_optimistic_concurrency": true,
  "schema_evolution_plan_doc": "docs/event-schema-evolution.md"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "aggregate_name": "x",
  "events": [
    "PlaceOrder"
  ],
  "applies_via_dispatch": false,
  "uses_optimistic_concurrency": false
}
]]></code>
    <note>aggregate_name too short; event name imperative not past tense; dispatch + concurrency disabled.</note>
  </example>

  <section title="Forbidden">
    <forbidden id="f1">Modifying or deleting persisted events.</forbidden>
    <forbidden id="f2">Imperative event names (PlaceOrder, AddItem).</forbidden>
    <forbidden id="f3">Inline state mutation in command handlers — must go through apply_new + _apply.</forbidden>
    <forbidden id="f4">Last-write-wins concurrency (no expected_version check).</forbidden>
  </section>

  <reference path="scripts/validate-event-sourcing-basics.py">Validator script.</reference>
</text>
