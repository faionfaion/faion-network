<text id="06-decision-tree" title="event-sourcing-basics Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
      <root-question id="q-root">Is a complete audit trail a hard requirement?</root-question>
      <branch when="audit_trail_required == false">
        <conclusion ref="skip-this-methodology" verdict="skip — state-based persistence is cheaper"/>
      </branch>
      <branch when="audit_trail_required == true">
        <question id="q-next">team_understands_eventual_consistency == true?</question>
        <branch when="team_understands_eventual_consistency == true">
          <conclusion ref="r1" verdict="scaffold event-sourced aggregate"/>
        </branch>
        <branch when="team_understands_eventual_consistency == false">
          <conclusion ref="skip-this-methodology" verdict="skip until team is ready; ES is unforgiving"/>
        </branch>
      </branch>
  </decision-tree>
</text>
