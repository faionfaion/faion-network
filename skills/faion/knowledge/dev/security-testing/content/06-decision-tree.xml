<text id="06-decision-tree" title="Security Testing Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="internet-facing">Does the service expose any internet-facing surface OR handle regulated data?</root-question>
      <branch when="exposure == none">
        <conclusion ref="skip-this-methodology" verdict="skip; reduce scope"/>
      </branch>
      <branch when="exposure == yes">
        <question id="sast-cadence">Is SAST per-PR?</question>
          <branch when="sast == quarterly">
            <conclusion ref="sast-on-pr" verdict="wire SAST into PR pipeline"/>
          </branch>
          <branch when="sast == per_pr">
            <question id="dep-coverage">Does audit cover transitive deps?</question>
              <branch when="deps == direct_only">
                <conclusion ref="dep-audit-with-transitive" verdict="switch to osv-scanner / pip-audit with transitive"/>
              </branch>
              <branch when="deps == transitive">
                <conclusion ref="dast-authenticated" verdict="wire authenticated DAST context"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="exposure=yes -&amp;gt; sast=per_pr -&amp;gt; deps=transitive -&amp;gt; dast-authenticated.">Worked path from root-question to conclusion.</example>
</text>
