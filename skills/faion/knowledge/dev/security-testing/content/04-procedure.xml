<text id="04-procedure" title="Security Testing Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply Security Testing end-to-end. Each step lists input, action, output, and an optional decision gate.</summary>
  <section title="Procedure">
    <step n="1" name="wire-sast">
      <input>Language inventory.</input>
      <action>Pick semgrep / bandit / gosec / brakeman per language; wire into PR pipeline.</action>
      <output>sast_tools array.</output>
      <decision-gate>Reject quarterly-only SAST.</decision-gate>
    </step>
    <step n="2" name="audit-deps">
      <input>Lockfiles.</input>
      <action>Run osv-scanner + ecosystem audit; transitive=true.</action>
      <output>dep_audit block.</output>
      <decision-gate>Reject direct-only audit.</decision-gate>
    </step>
    <step n="3" name="configure-dast">
      <input>Staging URL + test creds.</input>
      <action>Wire ZAP with authenticated context; tune for prod rate limits.</action>
      <output>dast block.</output>
      <decision-gate>Reject unauth-only scan.</decision-gate>
    </step>
    <step n="4" name="wire-secrets-scan">
      <input>Repo + dev workstations.</input>
      <action>Install gitleaks pre-commit + CI step.</action>
      <output>secrets_scan block.</output>
      <decision-gate>Reject CI-only.</decision-gate>
    </step>
    <step n="5" name="publish-asvs-matrix">
      <input>ASVS L1 controls.</input>
      <action>Map each control to covered / in-progress / accepted-risk with owner.</action>
      <output>asvs_coverage + fix_windows.</output>
      <decision-gate>Reject release without ASVS matrix.</decision-gate>
    </step>
  </section>
</text>
