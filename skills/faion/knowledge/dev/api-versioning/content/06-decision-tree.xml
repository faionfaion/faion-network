<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="API Versioning Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-breaking">change_kind == "breaking"?</root-question>
    <branch when="breaking_change">
      <question id="q-bump">next_version major &gt; current_version major?</question>
      <branch when="bump_short">
        <conclusion ref="semver-bump-on-breaking" verdict="verdict=fail; force major version bump"/>
      </branch>
      <branch when="bump_ok">
        <question id="q-window">deprecation_window_days &gt;= 90?</question>
        <branch when="window_short">
          <conclusion ref="deprecation-window-declared" verdict="verdict=fail; extend window to &gt;= 90 days"/>
        </branch>
        <branch when="window_ok">
          <conclusion ref="one-scheme-per-api" verdict="verdict=pass; ship plan + Sunset header"/>
        </branch>
      </branch>
    </branch>
    <branch when="additive_or_docs">
      <conclusion ref="breaking-change-classifier" verdict="verdict=pass; minor or patch bump; no deprecation needed"/>
    </branch>
  </decision-tree>

  <example trace="ver-public-v2">
    change_kind=breaking → next=v2 (major bump) → window=180 &gt;= 90 → conclusion one-scheme-per-api → pass.
  </example>
</text>
