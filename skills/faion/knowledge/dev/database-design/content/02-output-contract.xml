<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Database Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/database-design.json",
  "type": "object",
  "required": ["schema_id", "version", "tables_count", "foreign_keys_count", "indexes_count", "migration_plan"],
  "properties": {
    "schema_id": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "tables_count": {"type": "integer", "minimum": 1},
    "foreign_keys_count": {"type": "integer", "minimum": 0},
    "indexes_count": {"type": "integer", "minimum": 0},
    "migration_plan": {"type": "string", "enum": ["expand-only", "expand-then-contract", "new-schema"]},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "schema_id": "orders-v2",
  "version": "2.0.0",
  "tables_count": 6,
  "foreign_keys_count": 8,
  "indexes_count": 5,
  "migration_plan": "expand-then-contract",
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "schema_id": "x",
  "version": "2.0",
  "tables_count": 0,
  "migration_plan": "adhoc"
}
]]></code>
    <note>schema_id below minLength, version not semver, tables_count below minimum, migration_plan not in enum, missing required fields.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Schema artefact missing foreign_keys_count or migration_plan</pattern>
      <pattern id="f2">Single-shot destructive migration (drop + recreate in one step)</pattern>
      <pattern id="f3">Business logic stored as trigger or stored procedure</pattern>
      <pattern id="f4">Index defined without paired query in the workload list</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Normalise constraint names to snake_case.</transformation>
      <transformation>Sort tables alphabetically in the spec for diff hygiene.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-database-design.py">Validator script</reference>
</text>
