<text id="06-decision-tree" title="Bun Runtime (Simple) Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes + auth → wiring.</summary>

  <decision-tree>
    <root-question id="q-routes">How many routes does the service need?</root-question>
    <branch when="routes_count &amp;lt;= 5">
      <conclusion ref="hono-for-routing" verdict="single Hono app, flat routes"/>
    </branch>
    <branch when="routes_count &amp;gt; 5">
      <conclusion ref="hono-for-routing" verdict="Hono with route grouping via app.route()"/>
    </branch>
  </decision-tree>
</text>
