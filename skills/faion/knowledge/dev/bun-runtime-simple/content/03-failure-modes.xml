<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Bun Runtime (Simple) Failure Modes" version="1.1.0" est_tokens="700" depth="essential">
  <summary>3 antipatterns.</summary>

  <section title="Antipatterns">

    <antipattern id="express-pulled-in" severity="high">
      <symptom>package.json lists express despite running on Bun.</symptom>
      <root-cause source="Bun docs">Author copied Express tutorial without checking Bun-native equivalent.</root-cause>
      <fix>Remove express; replace with Hono. Re-write routes.</fix>
    </antipattern>
    <antipattern id="dotenv-imported" severity="medium">
      <symptom>Code imports dotenv/config.</symptom>
      <root-cause source="Bun docs">Author unaware Bun loads .env natively.</root-cause>
      <fix>Remove dotenv import; trust Bun's native .env loading.</fix>
    </antipattern>
    <antipattern id="bcrypt-imported" severity="high">
      <symptom>Code imports bcrypt or bcryptjs.</symptom>
      <root-cause source="OWASP cheat sheet; Bun docs">Author copied legacy auth tutorial.</root-cause>
      <fix>Replace with `await Bun.password.hash(pw)` and `Bun.password.verify(pw, hash)`.</fix>
    </antipattern>

  </section>
</text>
