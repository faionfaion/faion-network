{
  "__faion_header__": {
    "purpose": "TypeScript 5 strict tsconfig with all 2026-recommended flags.",
    "consumes": "Copy to repo root as tsconfig.json (drop __faion_header__ on copy).",
    "produces": "TS compiler with strict + indexed-access + exact-optional checks.",
    "depends-on": "typescript >= 5.0",
    "token-budget-impact": "zero; build-time only"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "allowImportingTsExtensions": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}
