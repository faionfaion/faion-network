<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="QA Suite Health Metrics Canon Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Is the suite large enough that trends matter more than per-test debugging?</root-question>
    <branch when="suite_size &lt; 100">
      <conclusion ref="skip-this-methodology" verdict="skip — too small"/>
    </branch>
    <branch when="ci_metrics_platform == null">
      <conclusion ref="skip-this-methodology" verdict="skip — set up metrics first"/>
    </branch>
    <branch when="metric_count != 6">
      <conclusion ref="closed-6-metric" verdict="trim or expand to 6"/>
    </branch>
    <branch when="owner == null">
      <conclusion ref="named-owner" verdict="name a single owner"/>
    </branch>
    <branch when="breach_action == null">
      <conclusion ref="breach-routes-to-methodology" verdict="wire route"/>
    </branch>
  </decision-tree>
</text>
