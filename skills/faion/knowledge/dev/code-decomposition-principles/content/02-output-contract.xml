<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Decomposition Principles Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Schema for a decomposition decision record. Each record names one file, the decision, and the supporting signals.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/code-decomposition-principles.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "file_path",
    "decision",
    "signals",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "file_path": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "split",
        "leave",
        "merge"
      ]
    },
    "signals": {
      "type": "object",
      "properties": {
        "loc": {
          "type": "integer"
        },
        "tokens": {
          "type": "integer"
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "churn_commits_90d": {
          "type": "integer"
        },
        "cross_concern_co_edit_pct": {
          "type": "number"
        }
      }
    },
    "owner": {
      "type": "string",
      "pattern": "^[^@]+@[^@]+$|^[a-z][a-z0-9-]+$"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "dec-001",
  "file_path": "src/billing/core.py",
  "decision": "split",
  "signals": {
    "loc": 612,
    "tokens": 14200,
    "responsibilities": [
      "io",
      "logic"
    ],
    "churn_commits_90d": 27,
    "cross_concern_co_edit_pct": 0.55
  },
  "owner": "ruslan",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "file_path": "src/x.py",
  "decision": "split",
  "owner": "team"
}
]]></code>
    <note>owner 'team' violates owner-named; missing artefact_id, signals, version, last_reviewed.</note>
  </example>

  <reference path="templates/decomp-candidates.sh">candidate scanner</reference>
  <reference path="scripts/validate-code-decomposition-principles.py">schema validator</reference>
</text>
