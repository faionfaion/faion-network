<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="WebSocket Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/websocket-design.json",
  "type": "object",
  "required": [
    "envelope",
    "heartbeat",
    "reconnect_policy",
    "send_queue",
    "auth"
  ],
  "properties": {
    "envelope": {
      "type": "object",
      "required": [
        "fields"
      ]
    },
    "heartbeat": {
      "type": "object",
      "required": [
        "interval_seconds",
        "timeout_seconds"
      ]
    },
    "reconnect_policy": {
      "type": "object",
      "required": [
        "base_ms",
        "max_ms",
        "jitter"
      ]
    },
    "send_queue": {
      "type": "object",
      "required": [
        "max_size",
        "shed_policy"
      ]
    },
    "auth": {
      "type": "object",
      "required": [
        "method",
        "ttl_seconds"
      ]
    },
    "message_schemas": {
      "type": "object"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "envelope": {
    "fields": [
      "v",
      "type",
      "id",
      "ts",
      "payload"
    ]
  },
  "heartbeat": {
    "interval_seconds": 30,
    "timeout_seconds": 90
  },
  "reconnect_policy": {
    "base_ms": 1000,
    "max_ms": 60000,
    "jitter": "full"
  },
  "send_queue": {
    "max_size": 1000,
    "shed_policy": "drop_oldest"
  },
  "auth": {
    "method": "signed_token_query",
    "ttl_seconds": 300
  },
  "message_schemas": {
    "chat.message": {
      "required": [
        "text",
        "from"
      ]
    }
  }
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "envelope": {},
  "heartbeat": {
    "interval_seconds": 0
  },
  "reconnect_policy": {
    "base_ms": 0
  },
  "send_queue": {
    "max_size": 0
  },
  "auth": {
    "method": "cookie"
  }
}
]]></code>
    <note>envelope missing fields; heartbeat interval=0; reconnect_policy missing max_ms+jitter; send_queue missing shed_policy + size=0; auth missing ttl_seconds.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="freeform-payload">Client crashes when server adds a new field to payload.</pattern>
      <pattern id="no-heartbeat">Connection appears alive client-side; server has dropped it 4 minutes ago via NAT timeout.</pattern>
      <pattern id="reconnect-storm">After server restart, 100k clients reconnect within 200ms; server crashes again.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-websocket-design.py">Validator script (see scripts/).</reference>
</text>
