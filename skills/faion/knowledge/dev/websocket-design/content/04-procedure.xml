<text id="04-procedure" title="WebSocket Design Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply WebSocket Design end-to-end. Each step lists input, action, output, and an optional decision gate.</summary>
  <section title="Procedure">
    <step n="1" name="define-envelope">
      <input>Message taxonomy.</input>
      <action>Declare envelope fields v/type/id/ts/payload; version=1.</action>
      <output>envelope block.</output>
      <decision-gate>Reject freeform payloads.</decision-gate>
    </step>
    <step n="2" name="wire-heartbeat">
      <input>Network policy.</input>
      <action>Server + client ping every 30s; close after 90s no pong.</action>
      <output>heartbeat block.</output>
      <decision-gate>Reject TCP-keepalive-only.</decision-gate>
    </step>
    <step n="3" name="reconnect-policy">
      <input>Expected outage window.</input>
      <action>Exponential base 1s max 60s + full jitter.</action>
      <output>reconnect_policy block.</output>
      <decision-gate>Reject fixed interval.</decision-gate>
    </step>
    <step n="4" name="send-queue-shed">
      <input>Memory budget.</input>
      <action>Bound queue at max_size; pick shed_policy.</action>
      <output>send_queue block.</output>
      <decision-gate>Reject unbounded queues.</decision-gate>
    </step>
    <step n="5" name="auth-and-schemas">
      <input>Auth model + message types.</input>
      <action>Short-lived signed token + JSON schema per type.</action>
      <output>auth + message_schemas blocks.</output>
      <decision-gate>Reject cookie-only or schema-less types.</decision-gate>
    </step>
  </section>
</text>
