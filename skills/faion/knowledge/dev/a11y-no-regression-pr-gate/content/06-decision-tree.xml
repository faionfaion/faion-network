<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="A11y No-Regression PR Gate Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="scanner-available">Is an a11y scanner installed in CI?</root-question>
      <branch when="scanner == no">
        <conclusion ref="skip-this-methodology" verdict="Install scanner first."/>
      </branch>
      <branch when="scanner == yes">
        <question id="baseline-in-vcs">Is the baseline committed to main (not edited from feature branches)?</question>
          <branch when="baseline_in_vcs == no">
            <conclusion ref="skip-this-methodology" verdict="Move baseline to VCS first."/>
          </branch>
          <branch when="baseline_in_vcs == yes">
          <question id="new-violations">Does the PR introduce new violations vs baseline?</question>
            <branch when="new == none">
              <conclusion ref="skip-this-methodology" verdict="Pass; record fixes if any."/>
            </branch>
            <branch when="new.critical_or_serious &gt; 0">
              <conclusion ref="skip-this-methodology" verdict="Block PR; require fix or expiring waiver."/>
            </branch>
            <branch when="new.moderate_or_minor &gt; 0 and ack_line == present">
              <conclusion ref="skip-this-methodology" verdict="Pass with ack."/>
            </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="scanner=yes -&gt; baseline_in_vcs=yes -&gt; new=none -&gt; pass">Worked path from root-question to conclusion.</example>
</text>
