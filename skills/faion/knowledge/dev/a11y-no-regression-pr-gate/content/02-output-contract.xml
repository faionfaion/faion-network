<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="A11y No-Regression PR Gate Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/a11y-no-regression-pr-gate.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "baseline_path",
    "waiver_path",
    "route_map_path",
    "severity_block",
    "waiver_max_days",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "baseline_path": {
      "type": "string",
      "minLength": 1
    },
    "waiver_path": {
      "type": "string",
      "minLength": 1
    },
    "route_map_path": {
      "type": "string",
      "minLength": 1
    },
    "severity_block": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "critical",
          "serious",
          "moderate",
          "minor"
        ]
      }
    },
    "severity_ack": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "critical",
          "serious",
          "moderate",
          "minor"
        ]
      }
    },
    "waiver_max_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 90
    },
    "nightly_full_scan": {
      "type": "boolean"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "a11y-gate-2026-q2",
  "owner": "frontend@faion.net",
  "baseline_path": ".a11y/baseline.json",
  "waiver_path": ".a11y-waivers.json",
  "route_map_path": ".a11y/route-map.json",
  "severity_block": [
    "critical",
    "serious"
  ],
  "severity_ack": [
    "moderate"
  ],
  "waiver_max_days": 90,
  "nightly_full_scan": true,
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "",
  "owner": "",
  "baseline_path": "",
  "waiver_path": "",
  "route_map_path": "",
  "severity_block": [],
  "waiver_max_days": 365,
  "version": "",
  "last_reviewed": ""
}
    ]]></code>
    <note>Violates required-field presence / forbidden-pattern constraints above.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="waiver-no-expiry">waiver_max_days &gt; 90</pattern>
      <pattern id="nothing-blocks">severity_block empty</pattern>
      <pattern id="baseline-outside-vcs">baseline_path not committed to repo</pattern>
    </list>
  </section>
  <reference path="scripts/validate-a11y-no-regression-pr-gate.py">Validator script (see scripts/).</reference>
</text>
