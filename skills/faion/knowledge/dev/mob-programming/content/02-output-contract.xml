<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="mob-programming Output Contract" version="1.0.0" est_tokens="500" depth="essential">
  <summary>JSON Schema for the session checklist and retrospective doc.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/mob-programming",
  "type": "object",
  "required": ["done", "rotationMinutes", "roster", "parkingLot", "retroPlanned"],
  "properties": {
    "done": {"type": "string", "minLength": 10, "maxLength": 200},
    "rotationMinutes": {"type": "integer", "minimum": 5, "maximum": 10},
    "roster": {"type": "array", "minItems": 3, "maxItems": 6, "items": {"type": "string"}},
    "parkingLot": {"type": "array", "items": {"type": "string"}},
    "retroPlanned": {"type": "boolean", "const": true},
    "breakEveryMinutes": {"type": "integer", "minimum": 75, "maximum": 90}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "done": "Refactor PaymentService to use the new Stripe webhook fixture; all unit tests green.",
  "rotationMinutes": 7,
  "roster": ["Alice", "Bob", "Carol", "Dan"],
  "parkingLot": [],
  "retroPlanned": true,
  "breakEveryMinutes": 90
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{
  "done": "improve code",
  "rotationMinutes": 30,
  "roster": ["Alice", "Bob"],
  "retroPlanned": false
}]]></code>
      <note>Four violations: vague Done (r4), rotation 30min (r3), too few people (skip-this), no retro (r6).</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>done is a single concrete sentence (10-200 chars).</item>
      <item>rotationMinutes in 5..10 range.</item>
      <item>roster has 3-6 names.</item>
      <item>retroPlanned == true at session start.</item>
      <item>parkingLot is initialised (empty array OK).</item>
    </list>
  </section>
</text>
