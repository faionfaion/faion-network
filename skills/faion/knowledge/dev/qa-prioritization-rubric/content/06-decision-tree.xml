<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="QA Prioritization Rubric Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Are bugs being triaged with consistent severities across triagers?</root-question>
    <branch when="backlog_size &lt; 30">
      <conclusion ref="skip-this-methodology" verdict="skip — informal triage fine"/>
    </branch>
    <branch when="org_rubric_exists == true">
      <conclusion ref="skip-this-methodology" verdict="skip — use org rubric"/>
    </branch>
    <branch when="tier_outside_enum == true">
      <conclusion ref="closed-4-tier" verdict="remap to S0..S3"/>
    </branch>
    <branch when="anchor_rule_id == null">
      <conclusion ref="triager-must-cite-anchor" verdict="require citation in tracker field"/>
    </branch>
    <branch when="workaround_documented == true AND tier == S1">
      <conclusion ref="workaround-downgrades" verdict="downgrade to S2"/>
    </branch>
  </decision-tree>
</text>
