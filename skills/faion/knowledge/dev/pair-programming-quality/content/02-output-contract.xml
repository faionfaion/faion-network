<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pair Programming Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Schema for the pair session plan + retro artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/pair-programming.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "topic",
    "participants",
    "style",
    "swap_minutes"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "topic": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "string"
      }
    },
    "style": {
      "enum": [
        "driver-navigator",
        "ping-pong",
        "strong-style",
        "tour-guide"
      ]
    },
    "swap_minutes": {
      "type": "integer",
      "minimum": 15,
      "maximum": 30
    },
    "agent_role": {
      "enum": [
        "silent",
        "test-writer",
        "hint-provider",
        "none"
      ]
    },
    "retro": {
      "type": "object",
      "properties": {
        "worked": {
          "type": "string"
        },
        "change": {
          "type": "string"
        },
        "metric": {
          "type": "string"
        }
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "pair-2026-05-22-cache",
  "topic": "Cache invalidation bug",
  "participants": [
    "ruslan",
    "anna"
  ],
  "style": "driver-navigator",
  "swap_minutes": 20,
  "agent_role": "silent",
  "retro": {
    "worked": "swap discipline tight",
    "change": "next time start with test",
    "metric": "1 defect found"
  },
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "topic": "x",
  "participants": [
    "a"
  ],
  "style": "freeform",
  "swap_minutes": 60
}
]]></code>
    <note>participants must be exactly 2; style not in enum; swap_minutes &amp;gt; 30; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-pair-programming.py">schema validator</reference>
</text>
