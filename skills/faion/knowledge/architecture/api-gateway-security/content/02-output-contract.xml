<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="API Gateway Security Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid config artefact for api-gateway-security. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/api-gateway-security.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "tls", "authentication", "authorization", "headers"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "tls": {
    "type": "object",
    "required": [
      "min_version"
    ]
  },
  "authentication": {
    "type": "object"
  },
  "authorization": {
    "type": "object",
    "required": [
      "default"
    ]
  },
  "headers": {
    "type": "object"
  },
  "waf": {
    "type": "object"
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "api-gateway-security-acme-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "tls": {
    "min_version": "1.2"
  },
  "authentication": {
    "jwt": {
      "issuer": "https://identity.example.com"
    }
  },
  "authorization": {
    "default": "deny"
  },
  "headers": {
    "x_content_type_options": "nosniff"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "tls": {
    "min_version": "1.0"
  },
  "authorization": {
    "default": "allow"
  }
}
]]></code>
    <note>Owner plural; TLS 1.0 below minimum; authz default allow violates deny-by-default rule.</note>
  </example>

  <forbidden>
    <pattern id="tls-below-1-2">`tls.min_version` is below 1.2.</pattern>
    <pattern id="authz-default-allow">`authorization.default` is `allow` — must be `deny`.</pattern>
    <pattern id="missing-jwt-jwks">`authentication.jwt` present but `jwks_url` missing.</pattern>
  </forbidden>

  <reference path="scripts/validate-api-gateway-security.py">Stdlib-only validator implementing this schema.</reference>
</text>
