<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Onion Architecture Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid spec artefact for arch-pattern-onion. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/arch-pattern-onion.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "layers", "lint_enforced"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "layers": {
    "type": "array",
    "minItems": 4,
    "maxItems": 4,
    "items": {
      "type": "object",
      "required": [
        "name",
        "modules"
      ]
    }
  },
  "lint_enforced": {
    "type": "boolean"
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "onion-layout-shop-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "layers": [
    {
      "name": "domain-model",
      "modules": [
        "Domain.Model"
      ]
    },
    {
      "name": "domain-services",
      "modules": [
        "Domain.Services"
      ]
    },
    {
      "name": "application-services",
      "modules": [
        "Application.Services"
      ]
    },
    {
      "name": "infrastructure-ui-tests",
      "modules": [
        "Infrastructure",
        "UI",
        "Tests"
      ]
    }
  ],
  "lint_enforced": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "layers": [
    {
      "name": "core"
    }
  ],
  "lint_enforced": false
}
]]></code>
    <note>Owner plural; layers has fewer than 4 entries; lint not enforced.</note>
  </example>

  <forbidden>
    <pattern id="layers-wrong-count">`layers` does not contain exactly 4 entries.</pattern>
    <pattern id="lint-not-enforced">`lint_enforced` false — Onion without enforcement decays in weeks.</pattern>
    <pattern id="infra-imports-domain">Module in Infrastructure layer is the SOURCE of an import that lands in Domain.* (always inverse).</pattern>
  </forbidden>

  <reference path="scripts/validate-arch-pattern-onion.py">Stdlib-only validator implementing this schema.</reference>
</text>
