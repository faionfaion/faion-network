{
  "__faion_header__": {
    "purpose": "Authorisation matrix (role \u00d7 resource \u00d7 operation).",
    "consumes": "see content/02-output-contract.xml",
    "produces": "spec",
    "depends_on": "content/01-core-rules.xml#r1-zero-trust-default",
    "token_budget_impact": "~150 tokens when loaded"
  },
  "roles": [
    {
      "name": "admin",
      "permissions": [
        "*"
      ]
    },
    {
      "name": "member",
      "permissions": [
        "read:profile",
        "write:profile",
        "read:posts",
        "write:posts"
      ]
    },
    {
      "name": "guest",
      "permissions": [
        "read:posts"
      ]
    }
  ],
  "resource_filters": [
    {
      "role": "member",
      "resource": "posts",
      "filter": "owner_id == user.id OR visibility == public"
    }
  ]
}
