<methodology slug="microservices-architecture">
  <metadata>
    <tier>pro</tier>
    <group>dev</group>
    <domain>software-architect</domain>
    <summary>Decomposing apps into independently deployable services by business capabilities. Decision framework, decomposition strategies, communication patterns, and anti-patterns.</summary>
    <tags>
      <tag>microservices</tag>
      <tag>architecture</tag>
      <tag>service-decomposition</tag>
