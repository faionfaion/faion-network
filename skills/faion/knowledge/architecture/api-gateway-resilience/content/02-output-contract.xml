<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="API Gateway Resilience Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid config artefact for api-gateway-resilience. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/api-gateway-resilience.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "rate_limits", "circuit_breakers", "retries", "timeouts"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "rate_limits": {
    "type": "array",
    "minItems": 1
  },
  "circuit_breakers": {
    "type": "array",
    "minItems": 1
  },
  "retries": {
    "type": "array",
    "minItems": 1
  },
  "timeouts": {
    "type": "object",
    "required": [
      "default_ms"
    ]
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "api-gateway-resilience-acme-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "rate_limits": [
    {
      "scope": "consumer",
      "requests_per_minute": 600
    }
  ],
  "circuit_breakers": [
    {
      "upstream": "payment-service",
      "failure_threshold_pct": 50
    }
  ],
  "retries": [
    {
      "method": "POST",
      "max_attempts": 2,
      "require_idempotency_key": true
    }
  ],
  "timeouts": {
    "default_ms": 5000
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "rate_limits": [],
  "retries": [
    {
      "method": "POST",
      "max_attempts": 5
    }
  ],
  "timeouts": {
    "default_ms": 60000
  }
}
]]></code>
    <note>Owner plural; rate_limits empty; POST retries without idempotency key; default timeout dangerously high.</note>
  </example>

  <forbidden>
    <pattern id="post-retry-no-idempotency">`retries[].method == POST` without `require_idempotency_key: true`.</pattern>
    <pattern id="timeout-too-high">`timeouts.default_ms` &gt; 30000 — risk of resource exhaustion.</pattern>
    <pattern id="empty-rate-limits">`rate_limits` empty.</pattern>
  </forbidden>

  <reference path="scripts/validate-api-gateway-resilience.py">Stdlib-only validator implementing this schema.</reference>
</text>
