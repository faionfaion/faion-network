<text id="02-output-contract" title="Serverless IaC and Templates Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator in scripts/validate-serverless-iac-and-templates.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/serverless-iac-and-templates.json",
  "type": "object",
  "title": "Serverless IaC config",
  "required": [
    "config_id",
    "tool",
    "stages",
    "iam_least_privilege",
    "drift_detection",
    "static_scanners",
    "version",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "config_id": {
      "type": "string",
      "pattern": "^iac-[a-z0-9-]+$"
    },
    "tool": {
      "enum": [
        "sam",
        "cdk",
        "serverless_framework",
        "pulumi",
        "terraform"
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "dev",
          "staging",
          "prod"
        ]
      }
    },
    "iam_least_privilege": {
      "type": "boolean",
      "const": true
    },
    "drift_detection": {
      "type": "boolean",
      "const": true
    },
    "static_scanners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "cfn_nag",
          "tfsec",
          "checkov",
          "cfn_lint",
          "tflint"
        ]
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "config_id": "iac-api-2026-05",
  "tool": "sam",
  "stages": [
    "dev",
    "staging",
    "prod"
  ],
  "iam_least_privilege": true,
  "drift_detection": true,
  "static_scanners": [
    "cfn_nag",
    "cfn_lint"
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "config_id": "iac 1",
  "tool": "click",
  "stages": [],
  "iam_least_privilege": false,
  "drift_detection": false,
  "static_scanners": [],
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>Forbidden traits: config_id pattern violation; tool enum violation; empty stages; iam_least_privilege / drift_detection false; empty static_scanners; version + date malformed.</note>
  </example>
  <reference path="scripts/validate-serverless-iac-and-templates.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
