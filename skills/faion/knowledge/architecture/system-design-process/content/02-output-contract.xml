<text id="02-output-contract" title="System Design Process Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-system-design-process.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/system-design-process.json",
  "type": "object",
  "title": "Architecture package",
  "required": [
    "package_id",
    "phases",
    "nfrs",
    "capacity_estimate",
    "c4_levels",
    "adr_refs",
    "peer_reviewer",
    "version",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "package_id": {
      "type": "string",
      "pattern": "^arch-[a-z0-9-]+$"
    },
    "phases": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "n",
          "name",
          "complete"
        ],
        "properties": {
          "n": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "name": {
            "type": "string"
          },
          "complete": {
            "type": "boolean"
          }
        }
      }
    },
    "nfrs": {
      "type": "object",
      "required": [
        "p95_ms",
        "rps",
        "availability_pct"
      ],
      "properties": {
        "p95_ms": {
          "type": "integer",
          "minimum": 1
        },
        "rps": {
          "type": "integer",
          "minimum": 1
        },
        "availability_pct": {
          "type": "number",
          "minimum": 90,
          "maximum": 100
        }
      }
    },
    "capacity_estimate": {
      "type": "object",
      "required": [
        "storage_gb_per_month",
        "compute_cores"
      ],
      "properties": {
        "storage_gb_per_month": {
          "type": "number",
          "minimum": 0
        },
        "compute_cores": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "c4_levels": {
      "type": "array",
      "minItems": 2,
      "items": {
        "enum": [
          "l1_context",
          "l2_container",
          "l3_component",
          "l4_code"
        ]
      }
    },
    "adr_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "peer_reviewer": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "package_id": "arch-orders-dash-2026-05",
  "phases": [
    {
      "n": 1,
      "name": "understand",
      "complete": true
    },
    {
      "n": 2,
      "name": "scope_nfrs",
      "complete": true
    },
    {
      "n": 3,
      "name": "design",
      "complete": true
    },
    {
      "n": 4,
      "name": "validate",
      "complete": true
    },
    {
      "n": 5,
      "name": "document",
      "complete": true
    }
  ],
  "nfrs": {
    "p95_ms": 200,
    "rps": 50,
    "availability_pct": 99.5
  },
  "capacity_estimate": {
    "storage_gb_per_month": 5.0,
    "compute_cores": 2.0
  },
  "c4_levels": [
    "l1_context",
    "l2_container"
  ],
  "adr_refs": [
    "adr-data-014",
    "adr-cache-002"
  ],
  "peer_reviewer": "olena.kovalenko@example.com",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "package_id": "arch 1",
  "phases": [
    {
      "n": 1,
      "name": "understand",
      "complete": false
    }
  ],
  "nfrs": {
    "p95_ms": 0,
    "rps": 0,
    "availability_pct": 50
  },
  "capacity_estimate": {
    "storage_gb_per_month": -1,
    "compute_cores": -1
  },
  "c4_levels": [
    "scribble"
  ],
  "adr_refs": [],
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>Forbidden traits: package_id pattern violation; phases not 5 entries; NFRs out of bounds; capacity negatives; c4_levels enum violation; empty adr_refs; empty peer_reviewer; version + date malformed.</note>
  </example>
  <reference path="scripts/validate-system-design-process.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
