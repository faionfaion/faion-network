<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="ADR Reversibility Tagging Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid decision-record artefact for adr-reversibility-tagging. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/adr-reversibility-tagging.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "adr_id", "reversibility", "rollback_estimate"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3,
    "maxLength": 100
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "adr_id": {
    "type": "string",
    "minLength": 1
  },
  "reversibility": {
    "type": "string",
    "enum": [
      "two_way_door",
      "partial_two_way",
      "one_way_door_costly",
      "one_way_door_irrevocable"
    ]
  },
  "rollback_estimate": {
    "type": "object",
    "required": [
      "engineering_weeks",
      "dollars_contract_exit",
      "customers_affected"
    ],
    "properties": {
      "engineering_weeks": {
        "type": "number",
        "minimum": 0
      },
      "dollars_contract_exit": {
        "type": "number",
        "minimum": 0
      },
      "customers_affected": {
        "type": "string",
        "enum": [
          "none",
          "internal_only",
          "subset",
          "all_active"
        ]
      }
    }
  },
  "pre_mortem": {
    "type": "object"
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "adr-reversibility-023-clerk-migration",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "adr_id": "023",
  "reversibility": "one_way_door_costly",
  "rollback_estimate": {
    "engineering_weeks": 4,
    "dollars_contract_exit": 12000,
    "customers_affected": "all_active"
  },
  "pre_mortem": {
    "reversal_triggers": [
      "bill/MAU > 2x",
      "enterprise SSO blocker"
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "reversibility": "maybe-reversible",
  "rollback_estimate": {}
}
]]></code>
    <note>Owner is plural pronoun; reversibility not in 4-tier enum; rollback_estimate empty.</note>
  </example>

  <forbidden>
    <pattern id="owner-plural">`owner` is a plural pronoun (`team`, `we`, `us`) or empty.</pattern>
    <pattern id="reversibility-not-enum">`reversibility` value not in the 4-tier enum.</pattern>
    <pattern id="missing-pre-mortem">`reversibility` starts with `one_way_door` AND no `pre_mortem` block.</pattern>
  </forbidden>

  <reference path="scripts/validate-adr-reversibility-tagging.py">Stdlib-only validator implementing this schema.</reference>
</text>
