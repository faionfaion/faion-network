<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cloud Provider Selection Decision Tree Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact this methodology produces. Validator in scripts/validate-decision-tree-cloud-provider.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/decision-tree-cloud-provider.json",
  "type": "object",
  "title": "Cloud provider ADR",
  "required": [
    "adr_id",
    "status",
    "chosen",
    "runner_up",
    "rationale",
    "review_trigger",
    "version",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "adr_id": {
      "type": "string",
      "pattern": "^adr-cloud-[a-z0-9-]+$"
    },
    "status": {
      "enum": [
        "proposed",
        "accepted",
        "superseded",
        "deprecated"
      ]
    },
    "chosen": {
      "enum": [
        "aws",
        "azure",
        "gcp",
        "none"
      ]
    },
    "runner_up": {
      "enum": [
        "aws",
        "azure",
        "gcp",
        "none"
      ]
    },
    "multi_cloud": {
      "type": "boolean",
      "default": false
    },
    "multi_cloud_goal": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale": {
      "type": "string",
      "minLength": 20
    },
    "review_trigger": {
      "type": "string",
      "minLength": 10
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "adr_id": "adr-cloud-saas-eu-2026-05",
  "status": "accepted",
  "chosen": "azure",
  "runner_up": "aws",
  "multi_cloud": false,
  "multi_cloud_goal": null,
  "rationale": "Microsoft AD + Office 365 incumbent; HITRUST + EU sovereign region available; workload = transactional CRUD with no analytics niche favouring GCP.",
  "review_trigger": "Azure egress exceeds 20% of monthly cost envelope OR EU sovereign requirements escalate.",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "adr_id": "adr cloud 1",
  "status": "ok",
  "chosen": "azure",
  "runner_up": "azure",
  "multi_cloud": true,
  "multi_cloud_goal": null,
  "rationale": "we want it",
  "review_trigger": "",
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>Forbidden traits: adr_id must match ^adr-cloud-...; status not in enum; runner_up equals chosen; multi_cloud=true without a documented goal; rationale too short; review_trigger empty; version/date malformed.</note>
  </example>
  <forbidden>
    <pattern id="adr-id-pattern">`adr_id` does not match `^adr-cloud-[a-z0-9-]+$`.</pattern>
    <pattern id="status-enum">`status` not in {proposed, accepted, superseded, deprecated}.</pattern>
    <pattern id="runner-up-equals-chosen">`runner_up` equals `chosen`.</pattern>
    <pattern id="multi-cloud-no-goal">`multi_cloud=true` AND `multi_cloud_goal` is null or empty.</pattern>
    <pattern id="rationale-too-short">`rationale` shorter than 20 characters.</pattern>
    <pattern id="review-trigger-empty">`review_trigger` empty or shorter than 10 characters.</pattern>
    <pattern id="version-malformed">`version` not semver (`^\d+\.\d+\.\d+$`) or `last_reviewed` not ISO date.</pattern>
  </forbidden>
  <reference path="scripts/validate-decision-tree-cloud-provider.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
