<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Cloud Provider Selection Decision Tree Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Are all four prerequisites populated (investment stack, workload profile, compliance matrix, cost envelope)?</root-question>
    <branch when="prereqs_complete == false">
      <conclusion ref="skip-this-methodology" verdict="abort"/>
    </branch>
    <branch when="compliance_required AND no_provider_covers_all_certs">
      <conclusion ref="r4-compliance-gates-first" verdict="exit_to_sovereign_or_self_host"/>
    </branch>
    <branch when="existing_stack == microsoft AND no_workload_disqualifier">
      <conclusion ref="r1-existing-investment-first" verdict="select_azure"/>
    </branch>
    <branch when="existing_stack == google AND no_workload_disqualifier">
      <conclusion ref="r1-existing-investment-first" verdict="select_gcp"/>
    </branch>
    <branch when="existing_stack == neutral AND workload == analytics_ml">
      <conclusion ref="r2-workload-fit-overrides-tie" verdict="select_gcp"/>
    </branch>
    <branch when="existing_stack == neutral AND workload == enterprise_breadth">
      <conclusion ref="r2-workload-fit-overrides-tie" verdict="select_aws"/>
    </branch>
    <branch when="decision_made AND no_runner_up_recorded">
      <conclusion ref="r5-record-runner-up" verdict="request_changes"/>
    </branch>
    <branch when="multi_cloud_proposed AND no_documented_goal">
      <conclusion ref="r3-multi-cloud-is-not-default" verdict="block"/>
    </branch>
    <branch when="all_gates_pass">
      <conclusion ref="run-the-checklist" verdict="approve"/>
    </branch>
  </decision-tree>
  <example trace="decision-tree-cloud-provider-typical">
    Inputs: Microsoft-shop, HIPAA-regulated SaaS, $40k/mo envelope, dominant workload = transactional CRUD. Step 2 keeps {AWS, Azure} (GCP lacks HITRUST for one service). Step 3 → Azure (investment-fit). Step 4 confirms. Step 5 emits ADR Azure / runner-up AWS / trigger=Azure egress &gt; 20 % budget.
  </example>
</text>
