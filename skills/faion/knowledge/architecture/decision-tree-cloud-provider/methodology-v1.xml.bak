<methodology slug="decision-tree-cloud-provider">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>software-architect</domain>
    <summary>Decision tree for selecting AWS vs Azure vs GCP based on existing technology investments, workload type, compliance requirements, and team expertise.</summary>
    <tags>
      <tag>decision-tree</tag>
      <tag>cloud-provider</tag>
      <tag>aws</tag>
      <tag>azure</tag>
      <tag>gcp</tag>
    </tags>
