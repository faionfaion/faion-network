<text id="04-procedure" title="Rust Error Handling Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply rust-error-handling end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="inventory-failures">
      <input>Domain</input>
      <action>List every observable failure mode.</action>
      <output>Failure list</output>
    </step>
    <step n="2" name="design-app-error">
      <input>Failure list</input>
      <action>Implement AppError enum with thiserror.</action>
      <output>AppError ready</output>
    </step>
    <step n="3" name="wire-anyhow-at-main">
      <input>Binary entry</input>
      <action>Use anyhow::Result at fn main() level.</action>
      <output>Main wraps errors</output>
    </step>
    <step n="4" name="install-ci-deny">
      <input>CI runner</input>
      <action>Add clippy deny for unwrap_used + expect_used in non-test.</action>
      <output>CI gate live</output>
    </step>
    <step n="5" name="validate">
      <input>Crate</input>
      <action>Run validate-rust-error-handling.py.</action>
      <output>Validated</output>
    </step>
  </section>
</text>
