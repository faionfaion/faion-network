<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rust Error Handling Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for rust-error-handling output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-error-handling.json",
  "type": "object",
  "required": [
    "app_error_present",
    "thiserror_used",
    "anyhow_at_boundaries",
    "unwrap_ban_in_ci"
  ],
  "properties": {
    "app_error_present": {
      "type": "boolean",
      "const": true
    },
    "thiserror_used": {
      "type": "boolean",
      "const": true
    },
    "anyhow_at_boundaries": {
      "type": "boolean"
    },
    "unwrap_ban_in_ci": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "app_error_present": true,
  "thiserror_used": true,
  "anyhow_at_boundaries": true,
  "unwrap_ban_in_ci": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "app_error_present": false,
  "thiserror_used": false,
  "unwrap_ban_in_ci": false
}
]]></code>
    <note>AppError missing; thiserror unused; unwrap allowed in CI.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-rust-error-handling.py">Validator script (--help, --self-test)</reference>
</text>
