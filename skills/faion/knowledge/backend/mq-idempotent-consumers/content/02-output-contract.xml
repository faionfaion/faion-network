<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Idempotent Message Queue Consumers Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for mq-idempotent-consumers output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mq-idempotent-consumers.json",
  "type": "object",
  "required": [
    "idempotency_key_field",
    "dedup_store",
    "ack_after_commit",
    "outbox_used"
  ],
  "properties": {
    "idempotency_key_field": {
      "type": "string",
      "minLength": 1
    },
    "dedup_store": {
      "enum": [
        "redis",
        "postgres",
        "dynamodb",
        "scylla"
      ]
    },
    "ack_after_commit": {
      "type": "boolean",
      "const": true
    },
    "outbox_used": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "idempotency_key_field": "event_id",
  "dedup_store": "postgres",
  "ack_after_commit": true,
  "outbox_used": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "dedup_store": "memcached",
  "ack_after_commit": false
}
]]></code>
    <note>idempotency_key_field missing; dedup_store not in enum; ack_after_commit false; outbox_used missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-mq-idempotent-consumers.py">Validator script (--help, --self-test)</reference>
</text>
