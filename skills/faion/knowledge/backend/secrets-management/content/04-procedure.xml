<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Secrets Management Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply Secrets Management end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="inventory-secrets">
      <input>Repo + /etc/*.env</input>
      <action>List every secret with name + class + current consumer.</action>
      <output>Secret inventory list.</output>
    </step>

    <step n="2" name="assign-owners">
      <input>Secret inventory</input>
      <action>Attach a single named owner per secret class.</action>
      <output>Owner-tagged inventory.</output>
    </step>

    <step n="3" name="wire-systemd">
      <input>Service unit list + owner-tagged inventory</input>
      <action>Convert any inline `Environment=` to `EnvironmentFile=/etc/&lt;svc&gt;.env` and `chmod 600`.</action>
      <output>Updated unit files + EnvironmentFile paths.</output>
      <decision-gate>If any unit still has inline Environment=secret, block deploy.</decision-gate>
    </step>

    <step n="4" name="install-guards">
      <input>Repo .gitignore + .git/hooks</input>
      <action>Add gitignore-secrets block + install pre-commit-secrets.sh.</action>
      <output>Pre-commit hook active.</output>
    </step>

    <step n="5" name="validate-plan">
      <input>SecretsPlan JSON</input>
      <action>Run validate-secrets-management.py --file plan.json.</action>
      <output>Pass/fail with violations.</output>
    </step>

  </section>
</text>
