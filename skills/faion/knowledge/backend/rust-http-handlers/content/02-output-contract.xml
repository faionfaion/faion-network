<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rust HTTP Handlers (Axum) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for rust-http-handlers output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rust-http-handlers.json",
  "type": "object",
  "required": [
    "routes",
    "dtos",
    "app_error",
    "tracing_instrument"
  ],
  "properties": {
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "method",
          "handler"
        ]
      },
      "minItems": 1
    },
    "dtos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "app_error": {
      "type": "boolean",
      "const": true
    },
    "tracing_instrument": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "routes": [
    {
      "path": "/users/:id",
      "method": "GET",
      "handler": "get_user"
    }
  ],
  "dtos": [
    "GetUserResponse",
    "CreateUserRequest"
  ],
  "app_error": true,
  "tracing_instrument": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "routes": [],
  "app_error": false
}
]]></code>
    <note>routes empty; dtos missing; app_error false; tracing_instrument missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-rust-http-handlers.py">Validator script (--help, --self-test)</reference>
</text>
