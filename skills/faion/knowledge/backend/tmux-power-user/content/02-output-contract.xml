<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="tmux Power User Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/tmux-power-user.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "prefix",
    "plugins",
    "history_limit",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "prefix": {
      "type": "string"
    },
    "plugins": {
      "type": "array"
    },
    "history_limit": {
      "type": "integer"
    },
    "os_targets": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">prefix == &apos;C-b&apos; (r1 violation).</pattern>
      <pattern id="f3">history_limit &lt; 50000 (r3).</pattern>
      <pattern id="f4">plugins list contains a plugin without a version tag (r2).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "tmux-faion",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "prefix": "C-a",
  "plugins": [
    "tmux-plugins/tpm",
    "tmux-plugins/tmux-resurrect",
    "tmux-plugins/tmux-continuum"
  ],
  "history_limit": 100000,
  "os_targets": [
    "linux",
    "macos"
  ],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "prefix": "C-b",
  "plugins": [],
  "history_limit": 1024,
  "owner": "team"
}
]]></code>
    <note>prefix=C-b (r1 violation); history_limit=1024 (r3 violation); owner=team; missing artefact_id, version, last_reviewed, os_targets.</note>
  </example>

  <reference path="scripts/validate-tmux-power-user.py">Schema validator (stdlib only).</reference>
</text>
