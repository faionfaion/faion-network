<text id="04-procedure" title="MongoDB Document Design Patterns Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply nosql-mongodb-patterns end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="enumerate-access-patterns">
      <input>Use cases</input>
      <action>Capture every query shape + frequency.</action>
      <output>Pattern list</output>
    </step>
    <step n="2" name="decide-embed-vs-ref">
      <input>Patterns + cardinality</input>
      <action>Apply decision tree per parent→child relation.</action>
      <output>Embedding plan</output>
    </step>
    <step n="3" name="design-indexes">
      <input>Patterns</input>
      <action>One index per filter/sort; compound matches field order.</action>
      <output>Index plan</output>
    </step>
    <step n="4" name="add-schemaVersion">
      <input>Schema</input>
      <action>Add schemaVersion + forward/backward migration scripts.</action>
      <output>Migrations ready</output>
    </step>
    <step n="5" name="validate">
      <input>All artefacts</input>
      <action>Run validate-nosql-mongodb-patterns.py.</action>
      <output>Validated</output>
    </step>
  </section>
</text>
