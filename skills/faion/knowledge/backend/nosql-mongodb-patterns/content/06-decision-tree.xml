<text id="06-decision-tree" title="MongoDB Document Design Patterns Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for nosql-mongodb-patterns.</summary>
  <decision-tree>
    <root-question id="q-root">Is MongoDB the right store?</root-question>
    <branch when="workload == heavy_relational_join"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="child_bounded_and_always_co_fetched == true"><conclusion ref="embed-when-bounded-and-cofetched"/></branch>
    <branch when="child_independent_or_unbounded == true"><conclusion ref="reference-when-independent-or-unbounded"/></branch>
    <branch when="missing_index_for_filter == true"><conclusion ref="index-every-filter-and-sort"/></branch>
    <branch when="missing_schemaVersion == true"><conclusion ref="schema-version-field-required"/></branch>
  </decision-tree>
