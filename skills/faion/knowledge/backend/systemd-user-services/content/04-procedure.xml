<text id="04-procedure" title="systemd User Services Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply systemd User Services end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="draft-unit">
      <input>Service inventory + paths</input>
      <action>Render .service from template with ExecStart, EnvironmentFile, MemoryHigh/Max.</action>
      <output>Candidate unit file.</output>
    </step>

    <step n="2" name="enable-linger">
      <input>Operator user</input>
      <action>`sudo loginctl enable-linger &lt;user&gt;` (if not already).</action>
      <output>Linger enabled.</output>
      <decision-gate>If linger cannot be enabled (e.g., requires sudo not available), block — service won&apos;t survive logout.</decision-gate>
    </step>

    <step n="3" name="install-unit">
      <input>Candidate unit</input>
      <action>Place in ~/.config/systemd/user/ + systemctl --user daemon-reload.</action>
      <output>Unit known to systemd.</output>
    </step>

    <step n="4" name="start-and-verify">
      <input>Installed unit</input>
      <action>systemctl --user enable --now &lt;unit&gt;; journalctl --user -u &lt;unit&gt; -f.</action>
      <output>Active service with journal lines.</output>
    </step>

    <step n="5" name="validate-plan">
      <input>UnitPlan JSON</input>
      <action>Run validate-systemd-user-services.py.</action>
      <output>Pass/fail.</output>
    </step>

  </section>
</text>
