# .envrc — Full Python project environment
# Run `direnv allow` after creating or modifying this file.

# Activate mise-managed runtime (reads .tool-versions or mise.toml)
use mise

# Create/activate virtualenv with mise-managed Python
layout python-venv .venv

# Load secrets from .env (no error if missing)
dotenv_if_exists .env

# Reload .envrc when these files change
watch_file requirements.txt
watch_file pyproject.toml

# Local scripts on PATH
PATH_add scripts

# Python settings
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUNBUFFERED=1
