<text id="06-decision-tree" title="Rust Project Structure (Axum/Actix) Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for rust-project-structure.</summary>
  <decision-tree>
    <root-question id="q-root">Is this a Rust HTTP service?</root-question>
    <branch when="service_kind == cli_or_library"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="service_kind == http_axum_or_actix"><conclusion ref="module-set-canonical"/></branch>
    <branch when="flat_layout_with_all_in_main == true"><conclusion ref="module-set-canonical"/></branch>
    <branch when="main_rs_over_100_loc == true"><conclusion ref="main-rs-thin"/></branch>
  </decision-tree>
</text>
