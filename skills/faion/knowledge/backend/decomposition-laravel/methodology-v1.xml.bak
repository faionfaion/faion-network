<methodology slug="decomposition-laravel">
  <metadata>
    <tier>pro</tier>
    <group>dev</group>
    <domain>backend-enterprise</domain>
    <summary>LLM-friendly code organization for Laravel using the Action + DTO + Form Request + Resource + Policy pattern. One Action = one verb; DTOs derive from Form Requests; controllers stay under 80 lines.</summary>
    <tags>
