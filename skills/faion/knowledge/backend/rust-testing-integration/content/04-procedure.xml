<text id="04-procedure" title="rust-testing-integration Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply the rust-testing-integration methodology end-to-end.</summary>

  <section title="Procedure">
    <step n="1" name="scaffold-tests-dir">
      <input>cargo workspace</input>
      <action>Create tests/&lt;feature&gt;_integration.rs for black-box tests.</action>
      <output>tests/ entry</output>
    </step>
    <step n="2" name="wire-testcontainers-fixture">
      <input>Cargo.toml dev-deps</input>
      <action>Add testcontainers + per-test schema fixture (uuid-named).</action>
      <output>test_db_pool() helper</output>
      <decision-gate>If only a single test needs DB, prefer transaction-rollback.</decision-gate>
    </step>
    <step n="3" name="drive-router-via-oneshot">
      <input>router builder fn</input>
      <action>Replace bind+await with app.oneshot(request).await.</action>
      <output>in-process router drive</output>
    </step>
    <step n="4" name="snapshot-output">
      <input>response body</input>
      <action>Switch hand-written expected strings to insta::assert_json_snapshot!.</action>
      <output>stored .snap files</output>
    </step>
    <step n="5" name="validate-and-run">
      <input>all test files</input>
      <action>Run validate-rust-testing-integration.py + cargo nextest run.</action>
      <output>green nextest report</output>
    </step>
  </section>
</text>
