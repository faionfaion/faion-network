# purpose: canonical per-app folder tree to copy when running startapp.
# consumes: a domain name (snake_case plural).
# produces: a self-contained app folder satisfying rule r2-per-app-inventory.
# depends-on: nothing — pure scaffold.
# token-budget-impact: ~80 tokens.

apps/<domain>/
├── __init__.py
├── apps.py
├── admin.py
├── apis.py
├── constants.py
├── models.py
├── selectors.py
├── serializers.py
├── services.py
├── urls.py
└── tests/
    ├── __init__.py
    ├── test_apis.py
    ├── test_models.py
    ├── test_selectors.py
    └── test_services.py
