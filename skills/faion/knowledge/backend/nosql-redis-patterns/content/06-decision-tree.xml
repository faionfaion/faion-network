<text id="06-decision-tree" title="Redis Data Structure Patterns Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for nosql-redis-patterns.</summary>
  <decision-tree>
    <root-question id="q-root">Is Redis the right tier for this data?</root-question>
    <branch when="redis_as_primary_store == true"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="rate_limit_needed == true"><conclusion ref="sorted-set-sliding-window"/></branch>
    <branch when="durable_event_log_needed == true"><conclusion ref="streams-over-pubsub"/></branch>
    <branch when="missing_ttl_on_key == true"><conclusion ref="ttl-on-every-key"/></branch>
    <branch when="missing_type_match == true"><conclusion ref="data-type-matches-access-pattern"/></branch>
  </decision-tree>
</text>
