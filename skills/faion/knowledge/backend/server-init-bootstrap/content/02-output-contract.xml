<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Server Init Bootstrap Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/server-init-bootstrap.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "hostname",
    "operator",
    "phases",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "hostname": {
      "type": "string"
    },
    "operator": {
      "type": "string"
    },
    "phases": {
      "type": "array"
    },
    "verifications": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">hostname in [&apos;localhost&apos;, &apos;ubuntu&apos;, &apos;&apos;].</pattern>
      <pattern id="f3">phases list missing &apos;security-hardening&apos; before &apos;services-foundation&apos;.</pattern>
      <pattern id="f4">verifications missing &apos;ssh-as-operator&apos; (r1 violation).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "bootstrap-faion-net-01",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "hostname": "faion-net-01",
  "operator": "faion",
  "phases": [
    "access-users",
    "system-identity",
    "packages-tools",
    "security-hardening",
    "services-foundation"
  ],
  "verifications": [
    "ssh-as-operator",
    "loginctl-linger-enabled",
    "ufw-active",
    "fail2ban-active"
  ],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "hostname": "localhost",
  "phases": [],
  "owner": "team"
}
]]></code>
    <note>hostname=localhost (forbidden default); phases empty; owner=team; missing artefact_id, version, last_reviewed, operator.</note>
  </example>

  <reference path="scripts/validate-server-init-bootstrap.py">Schema validator (stdlib only).</reference>
</text>
