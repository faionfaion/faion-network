<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="SSH Hardening Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ssh-hardening.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "host",
    "port",
    "allow_users",
    "password_auth",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "host": {
      "type": "string"
    },
    "port": {
      "type": "integer"
    },
    "allow_users": {
      "type": "array"
    },
    "password_auth": {
      "type": "boolean"
    },
    "permit_root_login": {
      "type": "boolean"
    },
    "second_terminal_verified": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">password_auth == true (violates r2).</pattern>
      <pattern id="f3">permit_root_login == true (violates r3).</pattern>
      <pattern id="f4">allow_users empty AND artefact claims hardened (everybody-allowed).</pattern>
      <pattern id="f5">second_terminal_verified == false (r1 — refuse to publish).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ssh-faion-net-01",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "host": "faion-net-01",
  "port": 22022,
  "allow_users": [
    "faion"
  ],
  "password_auth": false,
  "permit_root_login": false,
  "second_terminal_verified": true,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "host": "faion-net-01",
  "port": 22,
  "allow_users": [],
  "password_auth": true,
  "owner": "team"
}
]]></code>
    <note>password_auth=true (r2 violation); allow_users empty (r3 violation); owner=team; missing artefact_id, version, last_reviewed, permit_root_login.</note>
  </example>

  <reference path="scripts/validate-ssh-hardening.py">Schema validator (stdlib only).</reference>
</text>
