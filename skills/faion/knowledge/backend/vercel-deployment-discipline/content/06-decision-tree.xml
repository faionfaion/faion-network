<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Vercel Deployment Discipline Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from `01-core-rules.xml`. MANDATORY for every methodology — even flat ones — per F-066 DoD.</summary>

  <decision-tree>
      <root-question id="q-on-vercel">Is the app actually on Vercel production (not Hobby pre-launch)?</root-question>

      <branch when="vercel_prod == false">
        <conclusion ref="skip-this-methodology" verdict="skip"/>
      </branch>
      <branch when="vercel_prod == true">
        <question id="q-env-audit">Did env-audit pass?</question>
        <branch when="env_audit_pass == false">
          <conclusion ref="r1-env-scoping" verdict="hold-fix-env"/>
        </branch>
        <branch when="env_audit_pass == true">
          <question id="q-edge">Any edge-runtime violations?</question>
          <branch when="edge_violations.count &gt; 0">
            <conclusion ref="r2-runtime-allow-list" verdict="hold-fix-edge"/>
          </branch>
          <branch when="edge_violations.count == 0">
            <conclusion ref="run-the-checklist" verdict="go"/>
          </branch>
        </branch>
      </branch>
  </decision-tree>

  <example trace="vercel_prod=true → env_audit_pass=true → edge_violations=0 → go">
    All audits pass, rollback plan documented → deploy with confidence.
  </example>
</text>
