<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Message Queue Reliability Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml for mq-reliability.</summary>
  <decision-tree>
    <root-question id="q-root">Is the queue best-effort or production-grade?</root-question>
    <branch when="queue_class == best_effort"><conclusion ref="skip-this-methodology"/></branch>
    <branch when="publisher_confirms_missing == true"><conclusion ref="publisher-confirms-mandatory"/></branch>
    <branch when="dlq_missing == true"><conclusion ref="dlq-with-alert-mandatory"/></branch>
    <branch when="retry_no_jitter == true"><conclusion ref="exponential-backoff-with-jitter"/></branch>
    <branch when="prefetch_unbounded == true"><conclusion ref="prefetch-limit-required"/></branch>
    <branch when="no_schema_registry == true"><conclusion ref="schema-registry-required"/></branch>
  </decision-tree>
</text>
