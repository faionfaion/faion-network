<methodology slug="django-selectors">
  <metadata>
    <tier>free</tier>
    <group>dev</group>
    <domain>python-developer</domain>
    <summary>Centralize Django read operations in keyword-only selector functions that return QuerySet with select_related/prefetch_related. Prevents N+1 queries and scattered query logic across views and tests.</summary>
    <tags>
      <tag>django</tag>
      <tag>selectors</tag>
      <tag>queryset</tag>
      <tag>n-plus-one</tag>
    </tags>
    <category>architecture</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-27</created>
    <frameworks>
      <framework>django</framework>
    </frameworks>
    <languages>
      <language>python</language>
