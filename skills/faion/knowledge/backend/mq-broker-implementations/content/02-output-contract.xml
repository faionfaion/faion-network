<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Message Broker Implementations Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) + valid/invalid examples + forbidden patterns for mq-broker-implementations output.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mq-broker-implementations.json",
  "type": "object",
  "required": [
    "broker",
    "queue",
    "dlq",
    "publisher_confirms",
    "ack_after_commit"
  ],
  "properties": {
    "broker": {
      "enum": [
        "rabbitmq",
        "redis-streams",
        "celery",
        "sqs"
      ]
    },
    "queue": {
      "type": "string",
      "minLength": 1
    },
    "dlq": {
      "type": "string",
      "minLength": 1
    },
    "publisher_confirms": {
      "type": "boolean",
      "const": true
    },
    "ack_after_commit": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "broker": "rabbitmq",
  "queue": "orders.events.v1",
  "dlq": "orders.events.v1.dlq",
  "publisher_confirms": true,
  "ack_after_commit": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "broker": "kinesis",
  "publisher_confirms": false
}
]]></code>
    <note>broker not in enum; queue/dlq missing; confirms disabled; ack_after_commit missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <item>missing required fields</item>
      <item>wildcard / placeholder values where enum or pattern is required</item>
      <item>values outside numeric / enum / pattern bounds</item>
    </list>
  </section>
  <reference path="scripts/validate-mq-broker-implementations.py">Validator script (--help, --self-test)</reference>
</text>
