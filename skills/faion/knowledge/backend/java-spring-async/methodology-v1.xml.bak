    <domain>backend-enterprise</domain>
    <summary>Spring @Async offloads IO-bound work from request threads to ThreadPoolTaskExecutor for composability and exception visibility.</summary>
    <category>concurrency</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-28</created>
    <tags>
      <tag>async</tag>
      <tag>threading</tag>
      <tag>spring-boot</tag>
      <tag>concurrency</tag>
      <tag>executor</tag>
