<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GraphQL API Design Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-graphql-api-design.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/graphql-api-design.json",
  "type": "object",
  "title": "GraphQL design decision record",
  "required": [
    "schema_file",
    "pagination_style",
    "auth_strategy",
    "limits"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_file": {
      "type": "string",
      "minLength": 1
    },
    "pagination_style": {
      "enum": [
        "relay_cursor",
        "offset_forbidden"
      ]
    },
    "auth_strategy": {
      "enum": [
        "permission_classes",
        "directives"
      ]
    },
    "limits": {
      "type": "object",
      "required": [
        "max_depth",
        "max_complexity"
      ],
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 4,
          "maximum": 12
        },
        "max_complexity": {
          "type": "integer",
          "minimum": 50,
          "maximum": 1000
        }
      }
    },
    "dataloader_per_request": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "schema_file": "schema/users.graphql",
  "pagination_style": "relay_cursor",
  "auth_strategy": "permission_classes",
  "limits": {
    "max_depth": 10,
    "max_complexity": 200
  },
  "dataloader_per_request": true
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "schema_file": "schema.graphql",
  "pagination_style": "offset",
  "limits": {
    "max_depth": 20
  }
}
]]></code>
    <note>Forbidden traits: Missing required auth_strategy; pagination_style enum violation; max_depth above 12.</note>
  </example>
  <reference path="scripts/validate-graphql-api-design.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
