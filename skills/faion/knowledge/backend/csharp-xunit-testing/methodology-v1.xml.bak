<methodology slug="csharp-xunit-testing">
  <metadata>
    <tier>pro</tier>
    <group>dev</group>
    <domain>backend-enterprise</domain>
    <summary>Comprehensive testing methodology for .NET applications using xUnit, Moq, FluentAssertions, and WebApplicationFactory covering unit and integration tests.</summary>
    <difficulty>intermediate</difficulty>
    <created>2026-04-26</created>
    <tags>
      <tag>xunit</tag>
      <tag>testing</tag>
      <tag>dotnet</tag>
      <tag>moq</tag>
      <tag>integration-tests</tag>
    </tags>
    <languages>
