<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Shell Productivity Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/shell-productivity.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "shell",
    "tools",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "shell": {
      "type": "string",
      "enum": [
        "bash",
        "zsh"
      ]
    },
    "tools": {
      "type": "array"
    },
    "starship_preset": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">shell not in enum [bash, zsh].</pattern>
      <pattern id="f3">tools list empty AND artefact claims to be a productivity plan.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "shell-faion-net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "shell": "bash",
  "tools": [
    "fzf",
    "ripgrep",
    "bat",
    "starship",
    "zoxide",
    "eza"
  ],
  "starship_preset": "tokyo-night",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "shell": "fish",
  "tools": [],
  "owner": "team"
}
]]></code>
    <note>shell=fish not in enum; tools empty; owner=team; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-shell-productivity.py">Schema validator (stdlib only).</reference>
</text>
