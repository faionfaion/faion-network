<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Methodologies Detail Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/methodologies-detail.json",
  "type": "object",
  "required": [
    "slug",
    "sections",
    "rule_count",
    "has_valid_invalid_pair",
    "tbd_count"
  ],
  "properties": {
    "slug": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "minItems": 8
    },
    "rule_count": {
      "type": "integer",
      "minimum": 5
    },
    "has_valid_invalid_pair": {
      "type": "boolean"
    },
    "tbd_count": {
      "type": "integer",
      "maximum": 0
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "business-model-research",
  "sections": [
    "Summary",
    "When-to-use",
    "When-not-to-use",
    "Core rules",
    "Output contract",
    "Failure modes",
    "Procedure",
    "Examples",
    "Decision tree",
    "Templates",
    "Scripts",
    "Related"
  ],
  "rule_count": 6,
  "has_valid_invalid_pair": true,
  "tbd_count": 0
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "x",
  "sections": [
    "Summary"
  ],
  "rule_count": 2,
  "tbd_count": 4
}
]]></code>
    <note>Section list incomplete (8 missing); rule_count below the 5 minimum; tbd_count &gt; 0; has_valid_invalid_pair missing.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="tbd-token-present">Any TBD/TODO/FIXME token in published detail page.</pattern>
      <pattern id="missing-valid-pair">Output contract example block missing either valid or invalid case.</pattern>
      <pattern id="fewer-than-five-rules">Core rules table with &lt;5 rules.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-methodologies-detail.py">Validator script (see scripts/).</reference>
</text>
