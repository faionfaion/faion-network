<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Use Case Mapping Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Use Case Mapping output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="use_case_id" type="string" required="true">stable id (UC-001..)</field>
      <field name="primary_actor" type="string" required="true">named role</field>
      <field name="goal" type="string" required="true">active-verb statement</field>
      <field name="preconditions" type="array" required="true">system + actor state before flow starts</field>
      <field name="main_flow" type="array" required="true">numbered steps</field>
      <field name="alternative_flows" type="array" required="true">≥1 branching scenarios</field>
      <field name="postcondition" type="string" required="true">observable end state</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">primary_actor missing or empty</pattern>
      <pattern id="f2">main_flow length &lt; 1</pattern>
      <pattern id="f3">alternative_flows length &lt; 1</pattern>
      <pattern id="f4">postcondition empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to inline ≤2 alternative flows back into main flow when they share preconditions.</transformation>
      <transformation>Allowed to merge two use-cases when their actor + goal + 80% of steps overlap.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/use-case-mapping.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "use_case_id": "sample-use_case_id",
  "primary_actor": "sample-primary_actor",
  "goal": "sample-goal",
  "preconditions": [
    {
      "k": "v"
    }
  ],
  "main_flow": [
    {
      "k": "v"
    }
  ],
  "alternative_flows": [
    {
      "k": "v"
    }
  ],
  "postcondition": "sample-postcondition",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/use-case-mapping.json</item>
    </list>
  </section>
</text>
