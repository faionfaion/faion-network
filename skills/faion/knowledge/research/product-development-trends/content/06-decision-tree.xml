<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Product Development Trends Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="planning-horizon">Planning horizon?</root-question>
      <branch when="horizon &lt; 1_quarter">
        <conclusion ref="skip-this-methodology" verdict="skip; trends are quarterly+"/>
      </branch>
      <branch when="horizon &gt;= 1_quarter">
        <question id="candidate-volume">Candidate trends available?</question>
          <branch when="candidates &lt; 5">
            <conclusion ref="three-source-classes" verdict="halt; broaden source pull first"/>
          </branch>
          <branch when="candidates &gt;= 5">
            <conclusion ref="explicit-bet-monitor-ignore" verdict="score 4 axes; emit bet/monitor/ignore + kills"/>
          </branch>
      </branch>
  </decision-tree>
  <example trace="horizon=quarterly -&gt; candidates=15 -&gt; score 4 axes -&gt; 2 bets + 5 monitor + 8 ignored.">Worked path from root-question to conclusion.</example>
</text>
