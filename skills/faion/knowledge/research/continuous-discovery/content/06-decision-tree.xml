<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Continuous Discovery Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="product-stage">Stage of product?</root-question>
      <branch when="stage == pre_pmf_zero_users">
        <conclusion ref="skip-this-methodology" verdict="skip; use customer-development or JTBD first"/>
      </branch>
      <branch when="stage == enterprise_18mo_cycle">
        <conclusion ref="skip-this-methodology" verdict="skip; discovery cycle misaligned with sales cycle"/>
      </branch>
      <branch when="stage == live_with_users">
        <question id="recruit-infra">Recurring recruit source exists?</question>
          <branch when="recruit == ad_hoc">
            <conclusion ref="six-cadence-levels" verdict="stand up recruiting infra before running cadence"/>
          </branch>
          <branch when="recruit == recurring">
            <question id="team-mode">Crisis / normal?</question>
              <branch when="team_mode == crisis">
                <conclusion ref="skip-this-methodology" verdict="switch to root-cause work first"/>
              </branch>
              <branch when="team_mode == normal">
                <conclusion ref="model-tier-by-cadence" verdict="run full 6-cadence pipeline with Haiku/Sonnet/Opus split"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="stage=live_with_users -&gt; recruit=recurring -&gt; team_mode=normal -&gt; run 6-cadence pipeline.">Worked path from root-question to conclusion.</example>
</text>
