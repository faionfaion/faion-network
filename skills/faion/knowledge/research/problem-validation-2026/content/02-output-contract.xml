<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Problem Validation 2026 Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Problem Validation 2026 output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="hypothesis" type="string" required="true">problem hypothesis under test</field>
      <field name="evidence_ledger" type="array" required="true">≥10 entries sorted by tier with citation + signal_type</field>
      <field name="cold_respondent_count" type="integer" required="true">count of non-network respondents (≥3 tier-1/2 required for validated)</field>
      <field name="verdict" type="string" required="true">one of: validated | hypothesis | invalidated</field>
      <field name="next_revalidation_due" type="date" required="true">ISO date 90 days from last_reviewed</field>
      <field name="owner" type="string" required="true">named researcher</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">verdict == 'validated' AND cold_tier12_count &lt; 3</pattern>
      <pattern id="f2">evidence_ledger length &lt; 10</pattern>
      <pattern id="f3">any ledger entry missing tier or citation</pattern>
      <pattern id="f4">next_revalidation_due &gt; last_reviewed + 90 days</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to demote tier-2 to tier-3 when the cited evidence is not first-person observed.</transformation>
      <transformation>Allowed to promote tier-3 to tier-2 when a follow-up LOI or pre-order is logged.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/problem-validation-2026.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "hypothesis": "sample-hypothesis",
  "evidence_ledger": [
    {
      "k": "v"
    }
  ],
  "cold_respondent_count": 3,
  "verdict": "sample-verdict",
  "next_revalidation_due": "2026-05-23",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/problem-validation-2026.json</item>
    </list>
  </section>
</text>
