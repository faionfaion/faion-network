<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Single Interview Fast Loop Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Single Interview Fast Loop Template output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="loop_id" type="string" required="true">stable id</field>
      <field name="decision_under_test" type="string" required="true">the one decision the loop informs</field>
      <field name="must_asks" type="array" required="true">3–5 past-tense questions</field>
      <field name="interview_at" type="datetime" required="true">ISO datetime</field>
      <field name="synthesis_due_at" type="datetime" required="true">interview_at + ≤36h</field>
      <field name="synthesis_outcome" type="string" required="true">decide-yes | decide-no | park | re-interview</field>
      <field name="citation_path" type="string" required="true">path to transcript in research repo</field>
      <field name="owner" type="string" required="true">named researcher</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">must_asks length &lt; 3 OR &gt; 5</pattern>
      <pattern id="f2">synthesis_due_at &gt; interview_at + 36h</pattern>
      <pattern id="f3">synthesis_outcome ∈ {'interesting', 'tbd', ''}</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to extend synthesis window by +12h ONCE per quarter with logged rationale.</transformation>
      <transformation>Allowed to chain two single loops into a mini-batch when synthesis_outcome of the first is 're-interview'.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/single-interview-fast-loop-template.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "loop_id": "sample-loop_id",
  "decision_under_test": "sample-decision_under_test",
  "must_asks": [
    {
      "k": "v"
    }
  ],
  "interview_at": "2026-05-23T12:00:00Z",
  "synthesis_due_at": "2026-05-23T12:00:00Z",
  "synthesis_outcome": "sample-synthesis_outcome",
  "citation_path": "sample-citation_path",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/single-interview-fast-loop-template.json</item>
    </list>
  </section>
</text>
