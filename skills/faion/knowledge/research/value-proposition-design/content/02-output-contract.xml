<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Value Proposition Design Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Value Proposition Design output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="customer_profile" type="object" required="true">jobs + pains + gains arrays with citations</field>
      <field name="value_map" type="object" required="true">products + pain_relievers + gain_creators arrays</field>
      <field name="alignment_gaps" type="array" required="true">pain/gain ids with no matching reliever/creator</field>
      <field name="value_prop_statement" type="string" required="true">≤140 chars; cites a named job</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">any job without citation</pattern>
      <pattern id="f2">any reliever without referenced pain id</pattern>
      <pattern id="f3">value_prop_statement length &gt; 140 chars</pattern>
      <pattern id="f4">alignment_gaps missing when value_map &lt; customer_profile coverage</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to merge two pains into one when they share a single root cause cited in interviews.</transformation>
      <transformation>Allowed to demote a gain-creator to pain-reliever when interview evidence shows friction-relief framing.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/value-proposition-design.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "customer_profile": {
    "k": "v"
  },
  "value_map": {
    "k": "v"
  },
  "alignment_gaps": [
    {
      "k": "v"
    }
  ],
  "value_prop_statement": "sample-value_prop_statement",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/value-proposition-design.json</item>
    </list>
  </section>
</text>
