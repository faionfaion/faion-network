{
  "__faion_header__": {
    "purpose": "k8s-scaling-availability config skeleton matching the output contract.",
    "consumes": "see content/02-output-contract.xml",
    "produces": "artefact conforming to content/02-output-contract.xml",
    "depends-on": "content/01-core-rules.xml",
    "token-budget-impact": "~400-800 tokens when loaded as context"
  },
  "service": "acme-api",
  "hpa": {
    "api_version": "autoscaling/v2",
    "min_replicas": 3,
    "max_replicas": 20,
    "metrics": [
      {
        "type": "Resource",
        "resource": {
          "name": "cpu",
          "target": {
            "type": "Utilization",
            "averageUtilization": 70
          }
        }
      }
    ],
    "stabilization_window_seconds": 300
  },
  "topology_spread": {
    "topology_key": "topology.kubernetes.io/zone",
    "max_skew": 1
  },
  "pdb": {
    "name": "acme-api-pdb",
    "min_available": "60%"
  },
  "owner": {
    "name": "Olena Boyko",
    "role": "platform lead"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}