<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cloud Run Vpc Access Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-cloud-run-vpc-access.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cloud-run-vpc-access.json",
  "title": "vpc-egress",
  "type": "object",
  "required": [
    "service",
    "egress_mode",
    "connector_or_subnet",
    "egress_setting"
  ],
  "additionalProperties": false,
  "properties": {
    "service": {
      "type": "string",
      "minLength": 1
    },
    "egress_mode": {
      "type": "string",
      "minLength": 1
    },
    "connector_or_subnet": {
      "type": "string",
      "minLength": 1
    },
    "egress_setting": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service": "example-service",
  "egress_mode": "example-egress_mode",
  "connector_or_subnet": "example-connector_or_subnet",
  "egress_setting": "example-egress_setting"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service": 123
}
]]></code>
    <note>Missing required keys and `service` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="service"/>
      <field name="egress_mode"/>
      <field name="connector_or_subnet"/>
      <field name="egress_setting"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-cloud-run-vpc-access.py">Validator script that enforces this schema.</reference>
</text>
