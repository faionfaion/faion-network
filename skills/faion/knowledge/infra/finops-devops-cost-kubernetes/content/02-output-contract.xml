<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Kubernetes Cost Optimisation Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the `report` artefact produced by finops-devops-cost-kubernetes, plus valid / invalid / forbidden examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "slug",
    "period",
    "findings",
    "recommendations"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "period": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "format": "date"
        },
        "to": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "estimated_savings_usd": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "finops-devops-cost-kubernetes",
  "period": {
    "from": "2026-04-01",
    "to": "2026-04-30"
  },
  "findings": [
    {
      "id": "f1",
      "severity": "high",
      "summary": "Over-provisioned m5.4xlarge in api-prod"
    }
  ],
  "recommendations": [
    {
      "id": "r1",
      "action": "downsize to m5.2xlarge",
      "expected_saving_usd": 1280
    }
  ],
  "estimated_savings_usd": 1280
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "finops-devops-cost-kubernetes"
}
]]></code>
    <note>Missing all required fields beyond `slug`; schema rejects on the first missing required key.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Plain prose / markdown output instead of a JSON object</item>
      <item>Placeholder tokens or empty required fields anywhere inside the artefact</item>
      <item>Unbounded arrays whose item schema is missing</item>
    </list>
  </section>

  <reference path="scripts/validate-finops-devops-cost-kubernetes.py">Validator script — exit 0 on pass, 1 on fail.</reference>
</text>
