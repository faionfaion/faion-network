{
  "__faion_header__": {
    "purpose": "Hooks block for settings.json.",
    "consumes": "inputs declared in claude-code-hooks/AGENTS.md Prerequisites table",
    "produces": "artefact matching claude-code-hooks/content/02-output-contract.xml",
    "depends-on": "rules in claude-code-hooks/content/01-core-rules.xml",
    "token-budget-impact": "~200-600 tokens when filled"
  },
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/post-edit-format.sh",
        "matcher": "Edit",
        "timeout": 10000
      },
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/post-edit-format.sh",
        "matcher": "Write",
        "timeout": 10000
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/pre-bash-safety.sh",
        "matcher": "Bash",
        "timeout": 5000
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/tmux-save.sh",
        "timeout": 5000
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/tmux-save.sh",
        "timeout": 5000
      }
    ]
  }
}
