<text id="02-output-contract" title="GCP Cloud Storage Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-storage.json",
  "type": "object",
  "required": [
    "name",
    "location",
    "storage_class",
    "uniform_access",
    "public_access_prevention",
    "lifecycle_rules",
    "owner",
    "produced_at"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,62}[a-z0-9]$"
    },
    "location": {
      "type": "string",
      "minLength": 2
    },
    "storage_class": {
      "enum": [
        "STANDARD",
        "NEARLINE",
        "COLDLINE",
        "ARCHIVE"
      ]
    },
    "uniform_access": {
      "type": "boolean",
      "const": true
    },
    "public_access_prevention": {
      "enum": [
        "enforced",
        "inherited"
      ]
    },
    "lifecycle_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "condition"
        ],
        "properties": {
          "action": {
            "type": "object"
          },
          "condition": {
            "type": "object"
          }
        }
      },
      "minItems": 1
    },
    "cmek_key": {
      "type": "string"
    },
    "versioning_enabled": {
      "type": "boolean"
    },
    "retention_policy_days": {
      "type": "integer",
      "minimum": 0
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "role": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "acme-prod-logs-eu",
  "location": "eu",
  "storage_class": "STANDARD",
  "uniform_access": true,
  "public_access_prevention": "enforced",
  "lifecycle_rules": [
    {
      "action": {
        "type": "SetStorageClass",
        "storageClass": "NEARLINE"
      },
      "condition": {
        "age": 30
      }
    },
    {
      "action": {
        "type": "SetStorageClass",
        "storageClass": "COLDLINE"
      },
      "condition": {
        "age": 90
      }
    },
    {
      "action": {
        "type": "Delete"
      },
      "condition": {
        "age": 730
      }
    }
  ],
  "cmek_key": "projects/acme-kms/locations/eu/keyRings/prod/cryptoKeys/gcs",
  "versioning_enabled": true,
  "retention_policy_days": 30,
  "owner": {
    "name": "Tetiana Lytvyn",
    "role": "platform lead"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": "MyBucket",
  "storage_class": "FAST"
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>`uniform_access: false` on a production bucket.</description>
      <reason>Per-object ACLs defeat bucket-level IAM auditing.</reason>
    </antipattern>
    <antipattern>
      <description>`public_access_prevention: inherited` without an explicit static-website rationale row.</description>
      <reason>Default is over-permissive; risk of data leak via inherited org policy drift.</reason>
    </antipattern>
    <antipattern>
      <description>Empty `lifecycle_rules` array.</description>
      <reason>Hot-class data accumulates unbounded cost.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-gcp-storage.py">Validator script</reference>
</text>
