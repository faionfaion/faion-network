<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gce Autoscaling Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gce-autoscaling.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gce-autoscaling.json",
  "title": "autoscaling-policy",
  "type": "object",
  "required": [
    "mig",
    "metric",
    "target",
    "min_replicas",
    "max_replicas",
    "cool_down_seconds"
  ],
  "additionalProperties": false,
  "properties": {
    "mig": {
      "type": "string",
      "minLength": 1
    },
    "metric": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "min_replicas": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "max_replicas": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "cool_down_seconds": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "mig": "example-mig",
  "metric": "example-metric",
  "target": "example-target",
  "min_replicas": 1,
  "max_replicas": 1,
  "cool_down_seconds": 1
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "mig": 123
}
]]></code>
    <note>Missing required keys and `mig` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="mig"/>
      <field name="metric"/>
      <field name="target"/>
      <field name="min_replicas"/>
      <field name="max_replicas"/>
      <field name="cool_down_seconds"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gce-autoscaling.py">Validator script that enforces this schema.</reference>
</text>
