<text id="05-examples" title="Terraform IaC Examples" version="1.1.0" est_tokens="500" depth="medium">
  <summary>End-to-end worked example showing the artefact this methodology produces.</summary>

  <example valid="true">
    <note>Acme prod IaC layout</note>
    <code lang="json"><![CDATA[
{
  "monorepo": true,
  "workspaces": [
    "prod-network",
    "prod-data",
    "prod-app",
    "staging-network",
    "staging-data",
    "staging-app",
    "dev"
  ],
  "shared_modules": [
    "vpc",
    "ecs-service",
    "rds-postgres"
  ],
  "refactor_policy": "moved-block",
  "blast_radius_docs": "envs/<workspace>/README.md"
}
]]></code>
  </example>
</text>
