<methodology slug="load-balancing-concepts">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>cicd-engineer</domain>
    <summary>Load balancing strategies, algorithms, health checks, session persistence, and L4 vs L7 architecture patterns for high availability and performance.</summary>
    <tags>
      <tag>load-balancing</tag>
      <tag>high-availability</tag>
      <tag>networking</tag>
