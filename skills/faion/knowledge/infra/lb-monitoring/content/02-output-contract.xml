<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="LB Monitoring Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the LB monitoring config this methodology produces. Validator enforces exporter, four-alert presence, per-backend label, log shipping.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lb-monitoring.json",
  "type": "object",
  "required": ["lb_kind", "exporter", "alerts", "per_backend_label", "log_destination", "dashboard_templated"],
  "properties": {
    "lb_kind": {"enum": ["haproxy", "nginx", "kubernetes-ingress"]},
    "exporter": {"enum": ["haproxy-exporter", "nginx-prometheus-exporter", "ingress-controller-builtin"]},
    "alerts": {
      "type": "array",
      "items": {"type": "object", "required": ["name", "for_seconds"], "properties": {"name": {"type": "string"}, "for_seconds": {"type": "integer", "minimum": 60}}},
      "contains": {"properties": {"name": {"const": "BackendDown"}}}
    },
    "per_backend_label": {"type": "boolean", "const": true},
    "log_destination": {"enum": ["loki", "elasticsearch", "s3"]},
    "log_retention_days": {"type": "integer", "minimum": 30},
    "dashboard_templated": {"type": "boolean", "const": true}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "lb_kind": "haproxy",
  "exporter": "haproxy-exporter",
  "alerts": [
    {"name": "BackendDown", "for_seconds": 60},
    {"name": "HighErrorRate", "for_seconds": 300},
    {"name": "HighLatency", "for_seconds": 300},
    {"name": "ConnectionPoolExhausted", "for_seconds": 120}
  ],
  "per_backend_label": true,
  "log_destination": "loki",
  "log_retention_days": 30,
  "dashboard_templated": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "lb_kind": "haproxy",
  "exporter": "",
  "alerts": [],
  "per_backend_label": false,
  "log_destination": "",
  "log_retention_days": 1,
  "dashboard_templated": false
}
]]></code>
    <note>No exporter; no alerts; no per-backend label; no log shipping; bespoke dashboard.</note>
  </example>

  <forbidden>
    <pattern id="f-no-exporter">exporter missing or empty</pattern>
    <pattern id="f-short-for">any alert with for_seconds &lt; 60</pattern>
    <pattern id="f-short-retention">log_retention_days &lt; 30</pattern>
  </forbidden>

  <reference path="scripts/validate-lb-monitoring.py">Validator script</reference>
</text>
