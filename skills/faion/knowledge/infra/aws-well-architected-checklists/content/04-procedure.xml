<text id="04-procedure" title="AWS Well-Architected Framework Checklists (2025-2026) Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>5-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Workload boundaries</input>
      <action>Enumerate AWS services + accounts in scope; tag dependencies.</action>
      <output>Inventory doc</output>
    </step>
    <step n="2" name="compose-per-pillar-checklist">
      <input>Inventory + canonical item bank</input>
      <action>Draft binary items per pillar.</action>
      <output>Draft checklist</output>
      <decision-gate>Apply rule all-6-pillars-evaluated.</decision-gate>
    </step>
    <step n="3" name="map-to-cli">
      <input>Item list</input>
      <action>Add `cli_check` to every item.</action>
      <output>CLI-backed checklist</output>
      <decision-gate>Apply rule cli-verifiable.</decision-gate>
    </step>
    <step n="4" name="run">
      <input>CLI-backed checklist + AWS access</input>
      <action>Execute every CLI check; record pass/fail.</action>
      <output>Result file</output>
    </step>
    <step n="5" name="score-and-remediate">
      <input>Result file + compliance scope</input>
      <action>Assign severity per failed item; create remediation tickets for HIGH; sign off when 0 HIGH remaining.</action>
      <output>Final checklist + gap summary</output>
      <decision-gate>Apply rule gap-severity-ranked.</decision-gate>
    </step>
  </section>
</text>