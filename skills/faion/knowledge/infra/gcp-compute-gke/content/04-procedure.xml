<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Gcp Compute Gke Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply the gcp-compute-gke methodology end-to-end. Each step lists explicit input → action → output and (optionally) a decision-gate.</summary>
  <section title="Procedure">
    <step n="1" name="pick-mode">
      <input>Team ops capacity</input>
      <action>Decide Autopilot vs Standard.</action>
      <output>Mode chosen.</output>
    </step>
    <step n="2" name="design-cluster">
      <input>Workload profile</input>
      <action>Regional, private nodes, Workload Identity, node-pools per workload class.</action>
      <output>Cluster design.</output>
    </step>
    <step n="3" name="provision">
      <input>Design artefact</input>
      <action>Create cluster (Terraform or `gcloud`).</action>
      <output>Cluster live.</output>
    </step>
    <step n="4" name="wire-observability">
      <input>Cluster</input>
      <action>Enable managed Prometheus + Cloud Logging.</action>
      <output>Observability live.</output>
    </step>
    <step n="5" name="validate">
      <input>GKE config artefact</input>
      <action>Run `validate-gcp-compute-gke.py`.</action>
      <output>Validator exit 0.</output>
    </step>
  </section>
</text>
