<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Compute Gke Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gcp-compute-gke.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-compute-gke.json",
  "title": "gke-cluster",
  "type": "object",
  "required": [
    "name",
    "mode",
    "region",
    "node_pools",
    "workload_identity",
    "private_nodes"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "node_pools": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "workload_identity": {
      "type": "boolean"
    },
    "private_nodes": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "example-name",
  "mode": "example-mode",
  "region": "example-region",
  "node_pools": [],
  "workload_identity": true,
  "private_nodes": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": 123
}
]]></code>
    <note>Missing required keys and `name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="name"/>
      <field name="mode"/>
      <field name="region"/>
      <field name="node_pools"/>
      <field name="workload_identity"/>
      <field name="private_nodes"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-compute-gke.py">Validator script that enforces this schema.</reference>
</text>
