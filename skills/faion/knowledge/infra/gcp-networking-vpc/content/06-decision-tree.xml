<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Gcp Networking Vpc Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_networking_vpc_root">Що проєктуєш у VPC?</root-question>
    <branch when="vpc_mode == custom">
      <conclusion ref="custom-vpc-regional-subnets" verdict="custom-mode VPC з regional subnets"/>
    </branch>
    <branch when="firewall_basis == service_account">
      <conclusion ref="sa-based-firewall-rules" verdict="firewall за SA, не за tag-ом"/>
    </branch>
    <branch when="policy_scope == org_or_folder">
      <conclusion ref="hierarchical-firewall-policies" verdict="hierarchical firewall на org/folder"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `vpc_mode == custom` → conclusion `custom-vpc-regional-subnets` from `content/01-core-rules.xml`.
  </example>
</text>
