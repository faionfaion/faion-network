<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="DR Drill Script Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, with valid + invalid examples and a forbidden-pattern list.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/dr-drill-script-template.json",
  "type": "object",
  "required": [
    "drill_id",
    "scenario_id",
    "declaration_time",
    "restore_time",
    "validation_pass",
    "rto_achieved_minutes",
    "rpo_achieved_minutes",
    "rto_target_minutes",
    "rpo_target_minutes",
    "runbook_deviations",
    "gaps_found",
    "gap_tickets",
    "post_mortem_url",
    "post_mortem_published_date"
  ],
  "properties": {
    "drill_id": {
      "type": "string",
      "description": "string (date + scenario_id)"
    },
    "scenario_id": {
      "type": "string",
      "description": "string (matches library)"
    },
    "declaration_time": {
      "type": "string",
      "description": "string (ISO-8601)"
    },
    "restore_time": {
      "type": "string",
      "description": "string (ISO-8601)"
    },
    "validation_pass": {
      "type": "boolean",
      "description": "boolean"
    },
    "rto_achieved_minutes": {
      "type": "integer",
      "description": "integer"
    },
    "rpo_achieved_minutes": {
      "type": "integer",
      "description": "integer"
    },
    "rto_target_minutes": {
      "type": "integer",
      "description": "integer"
    },
    "rpo_target_minutes": {
      "type": "integer",
      "description": "integer"
    },
    "runbook_deviations": {
      "type": "array",
      "description": "array"
    },
    "gaps_found": {
      "type": "array",
      "description": "array"
    },
    "gap_tickets": {
      "type": "array",
      "description": "array"
    },
    "post_mortem_url": {
      "type": "string",
      "description": "string"
    },
    "post_mortem_published_date": {
      "type": "string",
      "description": "string"
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "drill_id": "2026-Q3-sc-04",
  "scenario_id": "sc-04-identity-provider-out",
  "declaration_time": "2026-08-15T14:22:00Z",
  "restore_time": "2026-08-15T15:09:00Z",
  "validation_pass": true,
  "rto_achieved_minutes": 47,
  "rpo_achieved_minutes": 0,
  "rto_target_minutes": 60,
  "rpo_target_minutes": 5,
  "runbook_deviations": [
    "Step 4: secondary IdP creds rotated, used backup credentials from Vault"
  ],
  "gaps_found": [
    "fallback auth path lacked MFA enrollment script"
  ],
  "gap_tickets": [
    "INC-2026-08-15-001"
  ],
  "post_mortem_url": "wiki/postmortems/sc-04-2026-q3.md",
  "post_mortem_published_date": "2026-08-19"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "drill_id": "2026-Q3",
  "scenario_id": "unknown",
  "declaration_time": "",
  "validation_pass": false,
  "rto_achieved_minutes": 999,
  "post_mortem_published_date": ""
}
]]></code>
    <note>Missing required fields and contains forbidden patterns; validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>scenario_id not present in scenario library</item>
      <item>declaration_time empty</item>
      <item>validation_pass == true while gaps_found contains data-integrity issues</item>
      <item>post_mortem_published_date &gt; declaration_time + 7 days</item>
      <item>gap_tickets empty when gaps_found non-empty</item>
    </list>
  </section>

  <reference path="scripts/validate-dr-drill-script-template.py">Validator script enforcing required keys + forbidden patterns</reference>
</text>
