<text id="06-decision-tree" title="Gce Spot Vms Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gce_spot_vms_root">Чи витримує workload переривання?</root-question>
    <branch when="interruptible == true">
      <conclusion ref="spot-with-checkpointing" verdict="Spot VMs + Cloud Storage checkpoint"/>
    </branch>
    <branch when="interruptible == false">
      <conclusion ref="skip-this-methodology" verdict="use standard VMs"/>
    </branch>
    <branch when="burst_pattern == baseline_plus_burst">
      <conclusion ref="mixed-standard-and-spot" verdict="mixed MIG"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `interruptible == true` → conclusion `spot-with-checkpointing` from `content/01-core-rules.xml`.
  </example>
</text>
