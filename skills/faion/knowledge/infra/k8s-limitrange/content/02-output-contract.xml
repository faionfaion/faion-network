<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Kubernetes LimitRange Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/k8s-limitrange.json",
  "type": "object",
  "required": [
    "namespace",
    "tier",
    "container_defaults",
    "container_default_requests",
    "container_max",
    "owner",
    "produced_at"
  ],
  "properties": {
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "tier": {
      "enum": [
        "dev",
        "staging",
        "prod"
      ]
    },
    "container_defaults": {
      "type": "object",
      "required": [
        "cpu",
        "memory"
      ],
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    },
    "container_default_requests": {
      "type": "object",
      "required": [
        "cpu",
        "memory"
      ],
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    },
    "container_max": {
      "type": "object",
      "required": [
        "cpu",
        "memory"
      ],
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        }
      }
    },
    "container_min": {
      "type": "object"
    },
    "max_limit_request_ratio": {
      "type": "object"
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "namespace": "acme-prod",
  "tier": "prod",
  "container_defaults": {
    "cpu": "500m",
    "memory": "512Mi"
  },
  "container_default_requests": {
    "cpu": "100m",
    "memory": "128Mi"
  },
  "container_max": {
    "cpu": "4",
    "memory": "8Gi"
  },
  "container_min": {
    "cpu": "50m",
    "memory": "64Mi"
  },
  "max_limit_request_ratio": {
    "cpu": "10",
    "memory": "4"
  },
  "owner": {
    "name": "Andriy Koval",
    "role": "platform engineer"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "namespace": "Acme",
  "tier": "prod"
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Empty container_default_requests.</description>
      <reason>Pods admit as BestEffort QoS.</reason>
    </antipattern>
    <antipattern>
      <description>tier prod without container_max.</description>
      <reason>Single pod can request whole node.</reason>
    </antipattern>
    <antipattern>
      <description>tier prod without max_limit_request_ratio.</description>
      <reason>Burst unbounded.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-k8s-limitrange.py">Validator script</reference>
</text>
