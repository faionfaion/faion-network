<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Docker Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-docker.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/docker.json",
  "title": "dockerfile",
  "type": "object",
  "required": [
    "base_image",
    "multi_stage",
    "user",
    "healthcheck",
    "pinned_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "base_image": {
      "type": "string",
      "minLength": 1
    },
    "multi_stage": {
      "type": "boolean"
    },
    "user": {
      "type": "string",
      "minLength": 1
    },
    "healthcheck": {
      "type": "string",
      "minLength": 1
    },
    "pinned_digest": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "base_image": "example-base_image",
  "multi_stage": true,
  "user": "example-user",
  "healthcheck": "example-healthcheck",
  "pinned_digest": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "base_image": 123
}
]]></code>
    <note>Missing required keys and `base_image` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="base_image"/>
      <field name="multi_stage"/>
      <field name="user"/>
      <field name="healthcheck"/>
      <field name="pinned_digest"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-docker.py">Validator script that enforces this schema.</reference>
</text>
