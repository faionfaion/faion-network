<text id="06-decision-tree" title="Docker Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="docker_root">Що збираєш у контейнер?</root-question>
    <branch when="workload == compiled_binary">
      <conclusion ref="multi-stage-build" verdict="use multi-stage with distroless final stage"/>
    </branch>
    <branch when="workload == interpreted_app">
      <conclusion ref="non-root-user-and-healthcheck" verdict="set USER, HEALTHCHECK, .dockerignore"/>
    </branch>
    <branch when="workload == one_off_admin_task">
      <conclusion ref="minimal-base-and-pinned-tags" verdict="alpine/distroless + pinned digest"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `workload == compiled_binary` → conclusion `multi-stage-build` from `content/01-core-rules.xml`.
  </example>
</text>
