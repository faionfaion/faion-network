<text id="02-output-contract" title="AWS Service Selection (Compute, Database, Architecture Decisions) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact. Validator script in `scripts/validate-devops-aws-service-selection.py` enforces it.</summary>

  <schema lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/devops-aws-service-selection.json",
  "type": "object",
  "required": [
    "workload",
    "compute",
    "database",
    "wa_pillars_evaluated",
    "gap_list"
  ],
  "properties": {
    "workload": {
      "type": "string",
      "minLength": 1
    },
    "compute": {
      "type": "object",
      "required": [
        "choice",
        "architecture",
        "rationale"
      ],
      "properties": {
        "choice": {
          "enum": [
            "lambda",
            "fargate",
            "eks",
            "ec2"
          ]
        },
        "architecture": {
          "enum": [
            "arm64",
            "x86_64"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "database": {
      "type": "object",
      "required": [
        "choice",
        "rationale"
      ],
      "properties": {
        "choice": {
          "enum": [
            "dynamodb",
            "aurora-serverless-v2",
            "rds",
            "elasticache",
            "opensearch",
            "none"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "wa_pillars_evaluated": {
      "type": "array",
      "items": {
        "enum": [
          "operational_excellence",
          "security",
          "reliability",
          "performance_efficiency",
          "cost_optimization",
          "sustainability"
        ]
      },
      "minItems": 6
    },
    "gap_list": {
      "type": "array"
    }
  }
}
]]></schema>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "workload": "checkout-api",
  "compute": {
    "choice": "lambda",
    "architecture": "arm64",
    "rationale": "Spiky <15min handler; scale-to-zero saves cost."
  },
  "database": {
    "choice": "dynamodb",
    "rationale": "Key-value access pattern; on-demand removes capacity planning."
  },
  "wa_pillars_evaluated": [
    "operational_excellence",
    "security",
    "reliability",
    "performance_efficiency",
    "cost_optimization",
    "sustainability"
  ],
  "gap_list": []
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "workload": "checkout-api",
  "compute": {
    "choice": "lambda",
    "architecture": "x86_64",
    "rationale": ""
  },
  "database": {
    "choice": "dynamodb",
    "rationale": "we wanted"
  },
  "wa_pillars_evaluated": [
    "security"
  ],
  "gap_list": []
}
]]></code>
    <note>x86 with empty rationale; 1 pillar only; rationale too short.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f1">compute.architecture = 'x86_64' AND rationale empty</pattern>
    <pattern id="f2">wa_pillars_evaluated length &lt; 6</pattern>
    <pattern id="f3">compute.choice = 'lambda' for batch jobs &gt; 15 min</pattern>
    <pattern id="f4">database.choice = 'dynamodb' for relational workload</pattern>
    <pattern id="f5">compute.rationale or database.rationale shorter than 20 chars</pattern>
  </section>

  <reference path="scripts/validate-devops-aws-service-selection.py">Validator script</reference>
</text>