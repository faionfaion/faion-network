{
  "sources": [
    {
      "kind": "GitRepository",
      "name": "platform-state",
      "url": "https://github.com/acme/platform-state.git"
    }
  ],
  "kustomizations": [
    {
      "name": "platform",
      "source_ref": "platform-state",
      "path": "./clusters/prod",
      "prune": true
    }
  ],
  "helmreleases": [
    {
      "name": "ingress",
      "chart_ref": "oci://ghcr.io/acme/charts/ingress",
      "image_automation": true
    }
  ],
  "notifications": {
    "provider": "slack",
    "channel": "#platform-flux"
  },
  "tenants": [
    {
      "name": "team-a",
      "namespace": "tenant-a",
      "rbac_ref": "rbac/team-a.yaml"
    }
  ],
  "owner": "platform@team.io",
  "last_reviewed": "2026-05-23",
  "__faion_header__": {
    "purpose": "Flux CD \u2014 Setup and Operation config skeleton",
    "consumes": "Prerequisites bundle (see AGENTS.md)",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends_on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  }
}
