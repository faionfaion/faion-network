<methodology slug="lb-layer-selection">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>cicd-engineer</domain>
    <summary>Choose between L4 (transport) and L7 (application) load balancing based on routing needs, SSL strategy, content inspection, and performance requirements.</summary>
    <tags>
      <tag>load-balancing</tag>
      <tag>networking</tag>
      <tag>l4</tag>
      <tag>l7</tag>
      <tag>infrastructure</tag>
    </tags>
    <category>infra</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-27</created>
    <related>
      <ref slug="lb-algorithms"/>
      <ref slug="lb-health-checks"/>
