<text id="06-decision-tree" title="Gcp Cloud Run Serverless Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_cloud_run_serverless_root">Що деплоїш?</root-question>
    <branch when="workload == http_api">
      <conclusion ref="cloud-run-service-stateless" verdict="Cloud Run Service, stateless"/>
    </branch>
    <branch when="workload == batch_to_completion">
      <conclusion ref="skip-this-methodology" verdict="use Cloud Run Jobs"/>
    </branch>
    <branch when="workload == event_driven">
      <conclusion ref="cloud-run-service-stateless" verdict="Pub/Sub push subscription targeting a stateless Cloud Run Service"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `workload == http_api` → conclusion `cloud-run-service-stateless` from `content/01-core-rules.xml`.
  </example>
</text>
