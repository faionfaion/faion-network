<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="IaC Module Design Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/iac-patterns-module-design.json",
  "type": "object",
  "required": [
    "module_name",
    "module_version",
    "inputs",
    "outputs",
    "examples",
    "owner",
    "produced_at"
  ],
  "properties": {
    "module_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "module_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "required"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "deprecations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "field",
          "removed_in"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "removed_in": {
            "type": "string"
          }
        }
      }
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "module_name": "vpc-network",
  "module_version": "1.4.0",
  "inputs": [
    {
      "name": "region",
      "type": "string",
      "required": true,
      "description": "GCP region for the VPC."
    },
    {
      "name": "subnets",
      "type": "list(object)",
      "required": true,
      "description": "Subnet definitions."
    }
  ],
  "outputs": [
    {
      "name": "network_id",
      "type": "string",
      "description": "VPC network self-link."
    },
    {
      "name": "subnet_ids",
      "type": "list(string)",
      "description": "Subnet self-links keyed by name."
    }
  ],
  "examples": [
    "examples/simple",
    "examples/multi-region"
  ],
  "owner": {
    "name": "Tetiana Lytvyn",
    "role": "platform engineer"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "module_name": "Net",
  "module_version": "v1"
}
]]></code>
    <note>Required fields missing or shape violated; see VIOLATION output from the validator.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Outputs without type or description.</description>
      <reason>Untyped outputs drift silently.</reason>
    </antipattern>
    <antipattern>
      <description>Empty examples.</description>
      <reason>Consumers reverse-engineer usage from tests.</reason>
    </antipattern>
    <antipattern>
      <description>Major rename without deprecation cycle row.</description>
      <reason>Hard break cascades.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-iac-patterns-module-design.py">Validator script</reference>
</text>
