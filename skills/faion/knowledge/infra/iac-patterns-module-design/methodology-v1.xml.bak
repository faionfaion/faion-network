<methodology slug="iac-patterns-module-design">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>infrastructure-engineer</domain>
    <summary>Five IaC module patterns (Base, Wrapper, Facade, Factory, Composite) with design guidelines, file structure, and variable/output conventions for Terraform and OpenTofu.</summary>
    <tags>
