{
  "__faion_header__": {
    "purpose": "Minimum config used by validate-devops-elk-logstash-pipeline.py --self-test",
    "consumes": "inputs declared in AGENTS.md `## Prerequisites`",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends-on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token-budget-impact": "~350 tokens when loaded"
  },
  "pipelines": [
    {
      "id": "heavy",
      "workers": 4,
      "batch_size": 250,
      "dlq_enabled": true
    }
  ],
  "pii_masking": [
    {
      "field": "message",
      "pattern": "credit-card",
      "replacement": "[REDACTED-CC]"
    }
  ],
  "outputs": [
    {
      "target": "elasticsearch",
      "tls": true,
      "auth": true
    }
  ]
}
