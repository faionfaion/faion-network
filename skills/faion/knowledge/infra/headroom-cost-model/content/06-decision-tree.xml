<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Headroom Cost Model Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Includes a skip-this-methodology branch.</summary>

  <decision-tree>
    <root-question id="q-root">Resource headroom %?</root-question>
    <branch when="headroom &lt; 10pct">
      <conclusion ref="r3-70pct-yellow-90pct-red">page on-call + re-provision now</conclusion>
    </branch>
    <branch when="headroom between 10 and 30pct">
      <conclusion ref="r3-70pct-yellow-90pct-red">open re-provision ticket; plan within 2 weeks</conclusion>
    </branch>
    <branch when="headroom between 30 and 60pct">
      <conclusion ref="r5-quarterly-projection">include in quarterly projection; no immediate action</conclusion>
    </branch>
    <branch when="headroom &gt; 60pct">
      <conclusion ref="r2-utilisation-trailing-30d">monitor; consider downscaling if sustained</conclusion>
    </branch>
    <branch when="cost deviation &gt; 30pct vs projection">
      <conclusion ref="r6-anomaly-detection-on-cost">auto-open investigation within 1 business day</conclusion>
    </branch>
    <branch when="preconditions_not_met == true">
      <conclusion ref="r4-cost-per-unit-tracked">skip-this-methodology — preconditions in &quot;Applies If&quot; not satisfied</conclusion>
    </branch>
  </decision-tree>

  <example trace="typical">
    <note>Resource headroom %? → matches branch &quot;headroom &lt; 10pct&quot; → conclusion ref=r3-70pct-yellow-90pct-red</note>
  </example>
</text>
