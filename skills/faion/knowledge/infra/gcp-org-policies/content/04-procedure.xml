<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Gcp Org Policies Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply the gcp-org-policies methodology end-to-end. Each step lists explicit input → action → output and (optionally) a decision-gate.</summary>
  <section title="Procedure">
    <step n="1" name="select-constraints">
      <input>Compliance + threat model</input>
      <action>Pick constraints (SA-keys, locations, services).</action>
      <output>Constraint list.</output>
    </step>
    <step n="2" name="dry-run">
      <input>Constraint list</input>
      <action>Apply in dry-run; collect violations.</action>
      <output>Violation report.</output>
    </step>
    <step n="3" name="remediate">
      <input>Violation report</input>
      <action>Fix violations OR document allow-list.</action>
      <output>Clean dry-run.</output>
    </step>
    <step n="4" name="enforce">
      <input>Clean dry-run</input>
      <action>Switch to enforced mode.</action>
      <output>Constraints enforced.</output>
    </step>
    <step n="5" name="validate">
      <input>Org-policy artefact</input>
      <action>Run `validate-gcp-org-policies.py`.</action>
      <output>Validator exit 0.</output>
    </step>
  </section>
</text>
