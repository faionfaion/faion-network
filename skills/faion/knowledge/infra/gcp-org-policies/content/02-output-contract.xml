<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Org Policies Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-gcp-org-policies.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-org-policies.json",
  "title": "org-policy",
  "type": "object",
  "required": [
    "constraint",
    "level",
    "enforcement",
    "exceptions"
  ],
  "additionalProperties": false,
  "properties": {
    "constraint": {
      "type": "string",
      "minLength": 1
    },
    "level": {
      "type": "string",
      "minLength": 1
    },
    "enforcement": {
      "type": "string",
      "minLength": 1
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "constraint": "example-constraint",
  "level": "example-level",
  "enforcement": "example-enforcement",
  "exceptions": []
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "constraint": 123
}
]]></code>
    <note>Missing required keys and `constraint` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="constraint"/>
      <field name="level"/>
      <field name="enforcement"/>
      <field name="exceptions"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-org-policies.py">Validator script that enforces this schema.</reference>
</text>
