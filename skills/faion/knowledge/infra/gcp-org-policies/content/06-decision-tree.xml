<text id="06-decision-tree" title="Gcp Org Policies Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_org_policies_root">Який constraint застосовуєш?</root-question>
    <branch when="constraint == disable_sa_keys">
      <conclusion ref="constraint-disable-sa-key-creation" verdict="iam.disableServiceAccountKeyCreation"/>
    </branch>
    <branch when="constraint == restrict_regions">
      <conclusion ref="constraint-resource-locations" verdict="gcp.resourceLocations"/>
    </branch>
    <branch when="constraint == restrict_apis">
      <conclusion ref="constraint-allowed-services" verdict="serviceuser.services"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `constraint == disable_sa_keys` → conclusion `constraint-disable-sa-key-creation` from `content/01-core-rules.xml`.
  </example>
</text>
