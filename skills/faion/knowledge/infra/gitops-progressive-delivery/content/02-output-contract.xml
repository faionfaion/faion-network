<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitOps — Progressive Delivery Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gitops-progressive-delivery.json",
  "title": "GitOps \u2014 Progressive Delivery",
  "type": "object",
  "required": [
    "tool",
    "strategy",
    "traffic_split",
    "metrics",
    "rollback_gate",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "enum": [
        "flagger",
        "argo-rollouts"
      ]
    },
    "strategy": {
      "type": "object",
      "required": [
        "type",
        "steps",
        "step_duration"
      ]
    },
    "traffic_split": {
      "type": "object",
      "required": [
        "provider",
        "config_ref"
      ]
    },
    "metrics": {
      "type": "object",
      "required": [
        "success_rate",
        "latency_p95",
        "error_rate"
      ]
    },
    "rollback_gate": {
      "type": "object",
      "required": [
        "thresholds",
        "auto_rollback"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tool": "flagger",
  "strategy": {
    "type": "canary",
    "steps": [
      5,
      25,
      50,
      100
    ],
    "step_duration": "5m"
  },
  "traffic_split": {
    "provider": "istio",
    "config_ref": "manifests/canary.yaml"
  },
  "metrics": {
    "success_rate": {
      "query": "sum(rate(request_success[1m]))",
      "min": 0.99
    },
    "latency_p95": {
      "query": "histogram_quantile(0.95, request_duration)",
      "max_ms": 300
    },
    "error_rate": {
      "query": "sum(rate(request_error[1m]))",
      "max": 0.01
    }
  },
  "rollback_gate": {
    "thresholds": {
      "success_rate_min": 0.99,
      "error_rate_max": 0.01
    },
    "auto_rollback": true
  },
  "owner": "sre@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tool": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-gitops-progressive-delivery.py">Validator script</reference>
</text>
