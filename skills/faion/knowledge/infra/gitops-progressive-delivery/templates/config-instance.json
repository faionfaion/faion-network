{
  "tool": "flagger",
  "strategy": {
    "type": "canary",
    "steps": [
      5,
      25,
      50,
      100
    ],
    "step_duration": "5m"
  },
  "traffic_split": {
    "provider": "istio",
    "config_ref": "manifests/canary.yaml"
  },
  "metrics": {
    "success_rate": {
      "query": "sum(rate(request_success[1m]))",
      "min": 0.99
    },
    "latency_p95": {
      "query": "histogram_quantile(0.95, request_duration)",
      "max_ms": 300
    },
    "error_rate": {
      "query": "sum(rate(request_error[1m]))",
      "max": 0.01
    }
  },
  "rollback_gate": {
    "thresholds": {
      "success_rate_min": 0.99,
      "error_rate_max": 0.01
    },
    "auto_rollback": true
  },
  "owner": "sre@team.io",
  "last_reviewed": "2026-05-23",
  "__faion_header__": {
    "purpose": "GitOps \u2014 Progressive Delivery config skeleton",
    "consumes": "Prerequisites bundle (see AGENTS.md)",
    "produces": "artefact conforming to content/02-output-contract.xml (config)",
    "depends_on": "content/01-core-rules.xml + content/02-output-contract.xml",
    "token_budget_impact": "~200-1000 tokens when loaded as context"
  }
}
