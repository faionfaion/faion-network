<text id="03-failure-modes" title="DORA Metrics Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="vanity-deploys-only" severity="high">
      <symptom>Deploy count high; CFR rising; nobody acts.</symptom>
      <root-cause>Single-metric reporting.</root-cause>
      <fix>Report all 5 metrics together.</fix>
    </antipattern>
    <antipattern id="no-source-of-truth" severity="medium">
      <symptom>Disagreement which dashboard is correct.</symptom>
      <root-cause>Multiple competing sources.</root-cause>
      <fix>Pin single source per metric.</fix>
    </antipattern>
    <antipattern id="review-without-action" severity="medium">
      <symptom>Metrics reviewed; nothing changes.</symptom>
      <root-cause>No documented action.</root-cause>
      <fix>Each review ends with ≥1 committed action.</fix>
    </antipattern>
    <antipattern id="cherry-picking" severity="high">
      <symptom>Only good metrics shown to leadership.</symptom>
      <root-cause>Selective reporting.</root-cause>
      <fix>All 5 always; honest narrative.</fix>
    </antipattern>

  </section>
</text>
