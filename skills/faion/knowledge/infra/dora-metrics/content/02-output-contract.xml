<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="DORA Metrics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/dora-metrics.json",
  "title": "DORA Metrics",
  "type": "object",
  "required": [
    "metrics",
    "data_sources",
    "target_band",
    "review_cadence",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "metrics": {
      "type": "array",
      "minItems": 5,
      "items": {
        "enum": [
          "deployment_frequency",
          "lead_time",
          "cfr",
          "mttr",
          "reliability"
        ]
      }
    },
    "data_sources": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "metric",
          "source"
        ]
      }
    },
    "target_band": {
      "enum": [
        "elite",
        "high",
        "medium",
        "low"
      ]
    },
    "review_cadence": {
      "enum": [
        "weekly",
        "biweekly",
        "monthly",
        "quarterly"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "metrics": [
    "deployment_frequency",
    "lead_time",
    "cfr",
    "mttr",
    "reliability"
  ],
  "data_sources": [
    {
      "metric": "deployment_frequency",
      "source": "argocd_app_events"
    },
    {
      "metric": "lead_time",
      "source": "git_merge_to_prod_event"
    },
    {
      "metric": "mttr",
      "source": "pagerduty_incidents"
    }
  ],
  "target_band": "high",
  "review_cadence": "quarterly",
  "owner": "platform-pm@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "metrics": [
    "deployment_frequency"
  ],
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-dora-metrics.py">Validator script</reference>
</text>
