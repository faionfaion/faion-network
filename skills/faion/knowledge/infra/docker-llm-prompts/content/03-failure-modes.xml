<?xml version="1.0" encoding="UTF-8"?>
<text id="03-failure-modes" title="Docker LLM Prompt Templates Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="freeform-prose" severity="medium">
      <symptom>Output varies wildly between engineers.</symptom>
      <root-cause>Prompt is free chat.</root-cause>
      <fix>Parameterize with named slots.</fix>
    </antipattern>
    <antipattern id="no-output-shape" severity="medium">
      <symptom>Outputs sometimes prose, sometimes Dockerfile.</symptom>
      <root-cause>Output shape unspecified.</root-cause>
      <fix>Explicit shape: dockerfile / json_list / table.</fix>
    </antipattern>
    <antipattern id="no-baseline-injection" severity="high">
      <symptom>Generated Dockerfile is single-stage root user.</symptom>
      <root-cause>Baseline rules not in instruction.</root-cause>
      <fix>Inject baseline rules into every generation prompt.</fix>
    </antipattern>
    <antipattern id="model-promiscuous" severity="low">
      <symptom>Prompt that worked on GPT-4 fails on GPT-3.5.</symptom>
      <root-cause>No model tested.</root-cause>
      <fix>Record model + retest on update.</fix>
    </antipattern>

  </section>
</text>
