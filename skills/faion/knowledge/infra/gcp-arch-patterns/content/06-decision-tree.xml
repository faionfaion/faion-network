<text id="06-decision-tree" title="Gcp Arch Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_arch_patterns_root">Який production pattern застосовуєш?</root-question>
    <branch when="pattern == gke_production">
      <conclusion ref="regional-private-gke" verdict="regional GKE + Workload Identity + private nodes"/>
    </branch>
    <branch when="pattern == cloud_sql_ha">
      <conclusion ref="cloud-sql-regional-pitr" verdict="REGIONAL + PITR + read replicas"/>
    </branch>
    <branch when="pattern == data_pipeline">
      <conclusion ref="pubsub-dataflow-bq" verdict="Pub/Sub → Dataflow → BigQuery"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `pattern == gke_production` → conclusion `regional-private-gke` from `content/01-core-rules.xml`.
  </example>
</text>
