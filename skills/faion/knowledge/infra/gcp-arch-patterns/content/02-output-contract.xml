<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Gcp Arch Patterns Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator: scripts/validate-gcp-arch-patterns.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gcp-arch-patterns.json",
  "title": "architecture-spec",
  "type": "object",
  "required": [
    "pattern",
    "components",
    "rationale",
    "ha_strategy",
    "security_controls"
  ],
  "additionalProperties": false,
  "properties": {
    "pattern": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "ha_strategy": {
      "type": "string",
      "minLength": 1
    },
    "security_controls": {
      "type": "string",
      "minLength": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pattern": "example-pattern",
  "components": [],
  "rationale": "example-rationale",
  "ha_strategy": "example-ha_strategy",
  "security_controls": "example-security_controls"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pattern": 123
}
]]></code>
    <note>Missing required keys and `pattern` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="pattern"/>
      <field name="components"/>
      <field name="rationale"/>
      <field name="ha_strategy"/>
      <field name="security_controls"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-gcp-arch-patterns.py">Validator script that enforces this schema.</reference>
</text>
