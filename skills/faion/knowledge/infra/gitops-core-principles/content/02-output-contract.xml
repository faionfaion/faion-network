<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitOps — Core Principles Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gitops-core-principles.json",
  "title": "GitOps \u2014 Core Principles",
  "type": "object",
  "required": [
    "principles_acknowledged",
    "tool",
    "model",
    "reconciliation_interval_minutes",
    "observability",
    "break_glass",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "principles_acknowledged": {
      "type": "array",
      "minItems": 4
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "rationale"
      ]
    },
    "model": {
      "type": "string",
      "enum": [
        "pull",
        "push"
      ]
    },
    "reconciliation_interval_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "observability": {
      "type": "object",
      "required": [
        "metrics",
        "dashboard_url"
      ]
    },
    "break_glass": {
      "type": "object",
      "required": [
        "procedure_ref",
        "audit_target"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "principles_acknowledged": [
    "declarative",
    "versioned-immutable",
    "pulled-automatically",
    "continuously-reconciled"
  ],
  "tool": {
    "name": "argocd",
    "rationale": "Multi-tenant UI + RBAC fits our 8-team platform"
  },
  "model": "pull",
  "reconciliation_interval_minutes": 3,
  "observability": {
    "metrics": [
      "argocd_app_info",
      "argocd_app_sync_total"
    ],
    "dashboard_url": "https://grafana.acme.com/d/argocd"
  },
  "break_glass": {
    "procedure_ref": "runbooks/break-glass.md",
    "audit_target": "s3://audit/break-glass/"
  },
  "owner": "platform@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "principles_acknowledged": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-gitops-core-principles.py">Validator script</reference>
</text>
