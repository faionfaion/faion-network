<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GitHub Actions — Workflow Structure Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gha-workflow-structure.json",
  "title": "GitHub Actions \u2014 Workflow Structure",
  "type": "object",
  "required": [
    "triggers",
    "jobs",
    "concurrency",
    "environments",
    "scheduled",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "triggers": {
      "type": "object",
      "minProperties": 1
    },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "needs"
        ]
      }
    },
    "concurrency": {
      "type": "object",
      "required": [
        "group",
        "cancel_in_progress"
      ]
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "approvers"
        ]
      }
    },
    "scheduled": {
      "type": "object",
      "required": [
        "cron_utc",
        "manual_dispatch_enabled"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "triggers": {
    "push": {
      "branches": [
        "main"
      ],
      "paths": [
        "src/**",
        "tests/**"
      ]
    },
    "pull_request": {
      "branches": [
        "main"
      ]
    },
    "schedule": [
      {
        "cron": "0 3 * * *"
      }
    ],
    "workflow_dispatch": {}
  },
  "jobs": [
    {
      "name": "build",
      "needs": []
    },
    {
      "name": "test",
      "needs": [
        "build"
      ]
    },
    {
      "name": "deploy-staging",
      "needs": [
        "test"
      ]
    }
  ],
  "concurrency": {
    "group": "${{ github.workflow }}-${{ github.ref }}",
    "cancel_in_progress": true
  },
  "environments": [
    {
      "name": "staging",
      "approvers": []
    },
    {
      "name": "production",
      "approvers": [
        "release-captain@team.io"
      ]
    }
  ],
  "scheduled": {
    "cron_utc": "0 3 * * *",
    "manual_dispatch_enabled": true
  },
  "owner": "ci-lead@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "triggers": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-gha-workflow-structure.py">Validator script</reference>
</text>
