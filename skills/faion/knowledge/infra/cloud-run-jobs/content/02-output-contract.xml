<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cloud Run Jobs Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator: scripts/validate-cloud-run-jobs.py.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cloud-run-jobs.json",
  "title": "cloud-run-job",
  "type": "object",
  "required": [
    "name",
    "image",
    "task_count",
    "parallelism",
    "task_timeout",
    "max_retries",
    "idempotent"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string",
      "minLength": 1
    },
    "task_count": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "parallelism": {
      "type": "string",
      "minLength": 1
    },
    "task_timeout": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "max_retries": {
      "type": [
        "integer",
        "number",
        "string"
      ]
    },
    "idempotent": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "example-name",
  "image": "example-image",
  "task_count": 1,
  "parallelism": "example-parallelism",
  "task_timeout": 1,
  "max_retries": 1,
  "idempotent": true
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": 123
}
]]></code>
    <note>Missing required keys and `name` has wrong type.</note>
  </example>
  <output-contract>
    <required>
      <field name="name"/>
      <field name="image"/>
      <field name="task_count"/>
      <field name="parallelism"/>
      <field name="task_timeout"/>
      <field name="max_retries"/>
      <field name="idempotent"/>
    </required>
    <forbidden>
      <pattern id="extra-keys">Properties not listed in `required` (additionalProperties=false enforces this).</pattern>
      <pattern id="secrets-in-output">Plaintext credentials, tokens, or PII anywhere in the artefact.</pattern>
      <pattern id="placeholder-tokens">Any literal placeholder tokens (the three-letter caps strings the validators reject) in field values.</pattern>
    </forbidden>
  </output-contract>
  <reference path="scripts/validate-cloud-run-jobs.py">Validator script that enforces this schema.</reference>
</text>
