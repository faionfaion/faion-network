<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="FinOps Operating Cycle Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/finops.json",
  "title": "FinOps Operating Cycle",
  "type": "object",
  "required": [
    "phases",
    "tagging_coverage_pct",
    "anomaly_alerts",
    "commitments",
    "per_team_accountability",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "phases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "enum": [
          "inform",
          "optimize",
          "operate"
        ]
      }
    },
    "tagging_coverage_pct": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "anomaly_alerts": {
      "type": "object",
      "required": [
        "enabled",
        "ack_sla_hours"
      ]
    },
    "commitments": {
      "type": "object",
      "required": [
        "strategy",
        "baseline_days"
      ]
    },
    "per_team_accountability": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "phases": [
    "inform",
    "optimize",
    "operate"
  ],
  "tagging_coverage_pct": 92,
  "anomaly_alerts": {
    "enabled": true,
    "ack_sla_hours": 24
  },
  "commitments": {
    "strategy": "savings_plans_70pct_coverage",
    "baseline_days": 90
  },
  "per_team_accountability": true,
  "owner": "finops@acme.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "phases": [
    "optimize"
  ],
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-finops.py">Validator script</reference>
</text>
