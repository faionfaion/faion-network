<text id="03-failure-modes" title="FinOps Operating Cycle Failure Modes" version="1.1.0" est_tokens="800" depth="essential">
  <summary>4 antipatterns from real deployments. Each pairs symptom + root cause + concrete fix.</summary>

  <section title="Antipatterns">

    <antipattern id="rightsizing-without-tagging" severity="high">
      <symptom>Cost cuts hit wrong team; political backlash.</symptom>
      <root-cause>Optimize started before tagging coverage.</root-cause>
      <fix>Hit 90% coverage first; then optimize.</fix>
    </antipattern>
    <antipattern id="anomaly-no-owner" severity="medium">
      <symptom>Alert fires; nobody acts.</symptom>
      <root-cause>No named owner.</root-cause>
      <fix>Each alert routes to a team + 24h ack.</fix>
    </antipattern>
    <antipattern id="speculative-commitment" severity="high">
      <symptom>Bought 3-yr RI; workload disappeared; sunk cost.</symptom>
      <root-cause>Commitment without baseline.</root-cause>
      <fix>Commit only after 90d baseline.</fix>
    </antipattern>
    <antipattern id="central-guilt" severity="medium">
      <symptom>Finance scolds teams quarterly; nothing changes.</symptom>
      <root-cause>No per-team accountability.</root-cause>
      <fix>Per-team dashboards + budget.</fix>
    </antipattern>

  </section>
</text>
