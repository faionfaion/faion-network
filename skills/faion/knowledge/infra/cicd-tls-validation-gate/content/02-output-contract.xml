<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="TLS Validation CI Gate Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cicd-tls-validation-gate.json",
  "type": "object",
  "required": [
    "scanners",
    "required_grade",
    "cipher_profile",
    "hsts_max_age_seconds",
    "gate_blocks_promotion",
    "scan_target"
  ],
  "properties": {
    "scanners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "testssl",
          "sslyze",
          "ssl-labs"
        ]
      }
    },
    "required_grade": {
      "const": "A+"
    },
    "cipher_profile": {
      "enum": [
        "mozilla-intermediate",
        "mozilla-modern"
      ]
    },
    "hsts_max_age_seconds": {
      "type": "integer",
      "minimum": 31536000
    },
    "gate_blocks_promotion": {
      "const": true
    },
    "scan_target": {
      "enum": [
        "staging",
        "pre-prod"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "scanners": [
    "testssl"
  ],
  "required_grade": "A+",
  "cipher_profile": "mozilla-intermediate",
  "hsts_max_age_seconds": 31536000,
  "gate_blocks_promotion": true,
  "scan_target": "staging"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "scanners": null
}
]]></code>
    <note>Required field set to null and other required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>scanners: must match array minItems 1: testssl, sslyze, ssl-labs; otherwise reject.</item>
      <item>required_grade: must match enum: A+, A; otherwise reject.</item>
      <item>cipher_profile: must match enum: mozilla-intermediate, mozilla-modern; otherwise reject.</item>
      <item>hsts_max_age_seconds: must match integer minimum 31536000; otherwise reject.</item>
      <item>gate_blocks_promotion: must match boolean const true; otherwise reject.</item>
      <item>scan_target: must match enum: staging, pre-prod; otherwise reject.</item>
    </list>
  </section>

  <reference path="scripts/validate-cicd-tls-validation-gate.py">Validator script</reference>
</text>
