<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Nomad Async Ops Stack Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from `01-core-rules.xml`. MANDATORY for every methodology — even flat ones — per F-066 DoD.</summary>

  <decision-tree>
      <root-question id="q-async-mode">Operator works async ≥80% of week?</root-question>

      <branch when="applies == false">
        <conclusion ref="skip-this-methodology" verdict="skip"/>
      </branch>
      <branch when="applies == true">
        <question id="q-flaky-wifi">Is wifi uptime &lt;99%?</question>
        <branch when="fit == false">
          <conclusion ref="skip-this-methodology" verdict="skip-misfit"/>
        </branch>
        <branch when="fit == true">
          <conclusion ref="run-the-checklist" verdict="apply"/>
        </branch>
      </branch>
  </decision-tree>

  <example trace="applies=true → fit=true → apply">
    Preconditions hold and the fit check passes → execute the procedure end-to-end.
  </example>
</text>
