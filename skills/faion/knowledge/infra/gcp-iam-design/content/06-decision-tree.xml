<text id="06-decision-tree" title="Gcp Iam Design Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals to a specific rule id in `01-core-rules.xml`.</summary>
  <decision-tree>
    <root-question id="gcp_iam_design_root">Який IAM сценарій?</root-question>
    <branch when="scope == folder_level">
      <conclusion ref="folder-level-bindings" verdict="bind on folder, inherit down"/>
    </branch>
    <branch when="auth == ci_cd_external">
      <conclusion ref="workload-identity-federation" verdict="use WIF — no SA keys"/>
    </branch>
    <branch when="sensitive == true">
      <conclusion ref="conditional-bindings" verdict="add IAM Conditions on resource/time/IP"/>
    </branch>
    <branch when="preconditions == not_met">
      <conclusion ref="skip-this-methodology" verdict="route to adjacent sibling methodology"/>
    </branch>
  </decision-tree>
  <example trace="primary-path">
    Input matches `scope == folder_level` → conclusion `folder-level-bindings` from `content/01-core-rules.xml`.
  </example>
</text>
