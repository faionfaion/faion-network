{
  "__faion_header__": "purpose: finops-devops-cost-tagging config skeleton | consumes: cost-allocation tag standard | produces: SCP-ready tag policy | depends-on: 01-core-rules.xml | token-budget-impact: ~400 tokens",
  "tags": {
    "env": {
      "tag_value": {
        "@@assign": [
          "prod",
          "staging",
          "dev"
        ]
      },
      "enforced_for": {
        "@@assign": [
          "ec2:instance",
          "rds:db"
        ]
      }
    },
    "owner": {
      "tag_value": {
        "@@assign": [
          "@@any"
        ]
      },
      "enforced_for": {
        "@@assign": [
          "ec2:instance",
          "rds:db",
          "s3:bucket"
        ]
      }
    },
    "cost-center": {
      "tag_value": {
        "@@assign": [
          "@@any"
        ]
      },
      "enforced_for": {
        "@@assign": [
          "ec2:instance",
          "rds:db",
          "s3:bucket"
        ]
      }
    },
    "application": {
      "tag_value": {
        "@@assign": [
          "@@any"
        ]
      },
      "enforced_for": {
        "@@assign": [
          "ec2:instance",
          "rds:db",
          "s3:bucket"
        ]
      }
    },
    "terraform": {
      "tag_value": {
        "@@assign": [
          "true",
          "false"
        ]
      },
      "enforced_for": {
        "@@assign": [
          "ec2:instance",
          "rds:db"
        ]
      }
    }
  }
}