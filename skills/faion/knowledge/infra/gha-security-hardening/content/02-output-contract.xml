<text id="02-output-contract" title="GitHub Actions — Security Hardening Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/gha-security-hardening.json",
  "title": "GitHub Actions \u2014 Security Hardening",
  "type": "object",
  "required": [
    "action_pinning",
    "oidc_trust",
    "permissions_default",
    "pull_request_target_audit",
    "actionlint",
    "owner",
    "last_reviewed"
  ],
  "properties": {
    "action_pinning": {
      "type": "object",
      "required": [
        "mode",
        "allowlist"
      ]
    },
    "oidc_trust": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "cloud",
          "subject_pattern",
          "role"
        ]
      }
    },
    "permissions_default": {
      "type": "string",
      "enum": [
        "read-all",
        "write-restricted",
        "explicit-per-job"
      ]
    },
    "pull_request_target_audit": {
      "type": "object",
      "required": [
        "allowed",
        "rule"
      ]
    },
    "actionlint": {
      "type": "object",
      "required": [
        "required_check",
        "config_ref"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "action_pinning": {
    "mode": "sha-only",
    "allowlist": [
      "actions/checkout@a1b2c3d",
      "actions/setup-node@d4e5f6g"
    ]
  },
  "oidc_trust": [
    {
      "cloud": "aws",
      "subject_pattern": "repo:acme/api:ref:refs/heads/main",
      "role": "arn:aws:iam::111:role/gh-deploy"
    }
  ],
  "permissions_default": "explicit-per-job",
  "pull_request_target_audit": {
    "allowed": false,
    "rule": "block-with-actionlint-rule"
  },
  "actionlint": {
    "required_check": true,
    "config_ref": ".github/actionlint.yaml"
  },
  "owner": "security@team.io",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "action_pinning": null,
  "owner": "team"
}
]]></code>
    <note>Missing or empty required fields; placeholder owner ('team'). Validator rejects with explicit violation list.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern>any field with value 'TBD' / 'TODO' / 'FIXME'</pattern>
    <pattern>'team' / 'we' as owner</pattern>
    <pattern>free-form prose where a structured field is required</pattern>
    <pattern>missing required keys per schema</pattern>
  </section>

  <reference path="scripts/validate-gha-security-hardening.py">Validator script</reference>
</text>
