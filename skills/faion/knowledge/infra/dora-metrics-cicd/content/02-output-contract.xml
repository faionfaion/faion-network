<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="DORA + Reliability Metrics Report Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces, with valid + invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/dora-metrics.json",
  "type": "object",
  "required": [
    "deployment_frequency_per_week",
    "lead_time_hours_p50",
    "change_failure_rate_pct",
    "mttr_hours_p50",
    "reliability_slo_attainment_pct",
    "event_schema",
    "window_days"
  ],
  "properties": {
    "deployment_frequency_per_week": {
      "type": "number",
      "minimum": 0
    },
    "lead_time_hours_p50": {
      "type": "number",
      "minimum": 0
    },
    "change_failure_rate_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "mttr_hours_p50": {
      "type": "number",
      "minimum": 0
    },
    "reliability_slo_attainment_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "event_schema": {
      "enum": [
        "cdevents",
        "custom-deploy-event-v1"
      ]
    },
    "window_days": {
      "type": "integer",
      "minimum": 7,
      "maximum": 30
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "deployment_frequency_per_week": 1.0,
  "lead_time_hours_p50": 1.0,
  "change_failure_rate_pct": 1.0,
  "mttr_hours_p50": 1.0,
  "reliability_slo_attainment_pct": 1.0,
  "event_schema": "cdevents",
  "window_days": 7
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "deployment_frequency_per_week": null
}
]]></code>
    <note>Required field set to null and other required fields missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>deployment_frequency_per_week: must match number minimum 0; otherwise reject.</item>
      <item>lead_time_hours_p50: must match number minimum 0; otherwise reject.</item>
      <item>change_failure_rate_pct: must match number minimum 0 maximum 100; otherwise reject.</item>
      <item>mttr_hours_p50: must match number minimum 0; otherwise reject.</item>
      <item>reliability_slo_attainment_pct: must match number minimum 0 maximum 100; otherwise reject.</item>
      <item>event_schema: must match enum: cdevents, custom-deploy-event-v1; otherwise reject.</item>
      <item>window_days: must match integer 7..30; otherwise reject.</item>
    </list>
  </section>

  <reference path="scripts/validate-dora-metrics.py">Validator script</reference>
</text>
