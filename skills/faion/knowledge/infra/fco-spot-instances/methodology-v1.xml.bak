<methodology slug="fco-spot-instances">
  <metadata>
    <tier>pro</tier>
    <group>infra</group>
    <domain>cicd-engineer</domain>
    <summary>Use preemptible/Spot cloud instances for fault-tolerant workloads to achieve 70-90% cost reduction; requires checkpointing, interruption handling, and instance diversification.</summary>
    <tags>
