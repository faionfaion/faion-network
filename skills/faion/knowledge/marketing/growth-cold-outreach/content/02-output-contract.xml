<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cold Outreach Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-cold-outreach.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "campaign_name",
    "prospect_count",
    "sequence_steps",
    "body_max_sentences",
    "daily_throttle",
    "stop_conditions",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "campaign_name": {
      "type": "string"
    },
    "prospect_count": {
      "type": "integer"
    },
    "sequence_steps": {
      "type": "integer"
    },
    "body_max_sentences": {
      "type": "integer"
    },
    "daily_throttle": {
      "type": "integer"
    },
    "stop_conditions": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">prospect_count &gt; 200 — violates r1</pattern>
      <pattern id="f2">sequence_steps &lt; 4 OR sequence_steps &gt; 5 — violates r4</pattern>
      <pattern id="f3">body_max_sentences &gt; 5 — violates r3</pattern>
      <pattern id="f4">&apos;reply&apos; not in stop_conditions — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "growth-cold-outreach-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "campaign_name": "<campaign_name>",
  "prospect_count": 1,
  "sequence_steps": 1,
  "body_max_sentences": 1,
  "daily_throttle": 1,
  "stop_conditions": [],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "campaign_name": "<campaign_name>",
  "prospect_count": 1,
  "sequence_steps": 1,
  "body_max_sentences": 1,
  "daily_throttle": 1,
  "stop_conditions": [],
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-growth-cold-outreach.py">Schema validator (stdlib only).</reference>
</text>
