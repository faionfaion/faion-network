<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Tweet Thread Launch Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Tweet Thread Launch Template output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="launch_id" type="string" required="true">kebab-case slug</field>
      <field name="operator" type="string" required="true">named launcher</field>
      <field name="tweets" type="array" required="true">exactly 7 tweets with id + text + media</field>
      <field name="demo_gif_url" type="string" required="true">&lt;30s gif/mp4 URL</field>
      <field name="hook_variants_tested" type="array" required="true">≥3 variants with pre-launch impressions</field>
      <field name="social_proof_quote" type="object" required="true">{quote, handle, consent_logged_at}</field>
      <field name="scheduled_for" type="date-time" required="true">ISO timestamp</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">tweets count != 7</pattern>
      <pattern id="f2">demo_gif_url empty OR static-image URL</pattern>
      <pattern id="f3">social_proof_quote missing consent_logged_at</pattern>
      <pattern id="f4">hook_variants_tested count &lt; 3</pattern>
      <pattern id="f5">tweet text exceeding platform char limit</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to swap tweet #3 (problem) and #4 (solve) order for narrative variety.</transformation>
      <transformation>Allowed to add a single bonus tweet #8 if it carries a coupon or PH launch link.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/tweet-thread-launch-template.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/tweet-thread-launch-template.json</item>
    </list>
  </section>
</text>
