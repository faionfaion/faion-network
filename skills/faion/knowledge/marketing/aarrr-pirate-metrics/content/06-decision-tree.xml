<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AARRR Pirate Metrics Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-baseline">All 5 stages have metric + baseline?</root-question>

    <branch when="baseline_complete == false">
      <conclusion ref="metric-per-stage-with-baseline" verdict="STOP — populate baselines first"/>
    </branch>

    <branch when="baseline_complete == true">
      <question id="q-upstream">Any stage 1-3 shows &gt;30% unexplained drop vs baseline?</question>
      <branch when="upstream_leak == true">
        <conclusion ref="top-down-read" verdict="bottleneck=upstream-leak; freeze downstream tactics"/>
      </branch>
      <branch when="upstream_leak == false">
        <question id="q-bottleneck">Bottleneck stage explicitly named?</question>
        <branch when="named == false">
          <conclusion ref="bottleneck-named-before-tactic" verdict="STOP — name the bottleneck first"/>
        </branch>
        <branch when="named == true">
          <conclusion ref="tactic-stage-tagged" verdict="queue tactics tagged for the bottleneck stage"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="activation leak">
    baseline_complete=true → upstream_leak=true (activation -18%) → top-down-read → freeze downstream tactics.
  </example>
</text>
