<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Substack-to-Product Funnel Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Substack-to-Product Funnel output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named publication owner</field>
      <field name="publication_url" type="string" required="true">Substack URL</field>
      <field name="paid_tier" type="object" required="true">{name, monthly_price, annual_price, concrete_benefit}</field>
      <field name="recommendation_partners" type="array" required="true">≥3 publications with URL + agreement_at</field>
      <field name="cross_post_cadence" type="object" required="true">{per_month, partner_rotation}</field>
      <field name="welcome_sequence" type="array" required="true">5 emails; email 4 carries the hard-product CTA</field>
      <field name="hard_product_url" type="string" required="true">URL</field>
      <field name="hard_product_cta_text" type="string" required="true">≤140 chars</field>
      <field name="kpi_set" type="object" required="true">{free_subs, paid_subs, hard_product_conversions, recommendation_inflow}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">paid_tier.concrete_benefit absent or 'support the publication'</pattern>
      <pattern id="f2">recommendation_partners count &lt; 3</pattern>
      <pattern id="f3">welcome_sequence missing email 4 OR email 4 lacks hard_product_cta</pattern>
      <pattern id="f4">cross_post_cadence == 0 per month</pattern>
      <pattern id="f5">hard_product_url empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to push hard-product CTA to email 5 IF welcome sequence is 7+ emails.</transformation>
      <transformation>Allowed to rotate recommendation partners quarterly.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/substack-to-product-funnel.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/substack-to-product-funnel.json</item>
    </list>
  </section>
</text>
