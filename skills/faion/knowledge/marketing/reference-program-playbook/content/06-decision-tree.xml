<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Reference Program Playbook Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="do not run this methodology; document skip rationale"/>
    </branch>

    <branch when="preconditions == true">
      <question id="q-readiness">Are all readiness gates green?</question>
      <branch when="delivered_engagements_5plus == false">
        <conclusion ref="skip-this-methodology" verdict="defer — build delivery track first"/>
      </branch>
      <branch when="ask_at_peak == false">
        <conclusion ref="ask-at-peak-not-end" verdict="wire peak-moment trigger into PM workflow"/>
      </branch>
      <branch when="tiered_roster == false">
        <conclusion ref="tier-references-by-strength" verdict="build 3-tier roster, pick per client"/>
      </branch>
      <branch when="outcome_led_studies == false">
        <conclusion ref="case-study-outcome-not-process" verdict="rewrite case studies outcome-first"/>
      </branch>
      <branch when="scripted_calls == false">
        <conclusion ref="peer-call-script-prepped" verdict="produce 3-question approved script per reference"/>
      </branch>
      <branch when="double_opt_in == false">
        <conclusion ref="warm-intro-double-opt-in" verdict="switch intro protocol to double opt-in"/>
      </branch>
      <branch when="all_checks_pass == true">
        <conclusion ref="warm-intro-double-opt-in" verdict="ship playbook; monthly reference-pipeline review"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="happy-path">preconditions=true → readiness gates evaluated → all_checks_pass==true → conclusion ref=warm-intro-double-opt-in</example>
</text>
