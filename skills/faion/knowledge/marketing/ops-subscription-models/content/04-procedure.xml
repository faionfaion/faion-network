<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Subscription Models Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Subscription Models end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="declare-model">
      <input>Founder brief</input>
      <action>Pick exactly one of saas|membership|replenishment|curation.</action>
      <output>model_type.</output>
    </step>

    <step n="2" name="design-tiers">
      <input>Feature inventory + pricing</input>
      <action>Tiers gate features tied to buyer outcomes.</action>
      <output>tiers.</output>
    </step>

    <step n="3" name="instrument-metrics">
      <input>Billing platform</input>
      <action>Wire MRR + gross churn + LTV calculation.</action>
      <output>Metrics live.</output>
    </step>

    <step n="4" name="configure-dunning">
      <input>Billing platform</input>
      <action>Auto-retry ≥3 cycles; manual fallback.</action>
      <output>dunning_config.</output>
    </step>

    <step n="5" name="design-lifecycle">
      <input>Customer journey</input>
      <action>Trial-end + downgrade + cancel + winback flows.</action>
      <output>lifecycle_stages.</output>
    </step>

  </section>
</text>
