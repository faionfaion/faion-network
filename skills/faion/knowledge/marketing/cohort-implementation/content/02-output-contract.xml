<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Cohort Implementation Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the `config` artefact this methodology produces. Validator at scripts/validate-cohort-implementation.py enforces the contract.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cohort-implementation.json",
  "title": "Cohort Implementation config",
  "type": "object",
  "required": [
    "slug",
    "owner",
    "settings",
    "deviation_log_reference"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "const": "cohort-implementation"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "settings": {
      "type": "object",
      "minProperties": 3,
      "additionalProperties": true
    },
    "deviation_log_reference": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "cohort-implementation",
  "owner": "growth ops",
  "settings": {
    "property_id": "G-XXXXXXX",
    "stream": "web",
    "consent_mode": "v2"
  },
  "deviation_log_reference": "ops/deviation-log.md#L120"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "cohort-implementation",
  "settings": {}
}
]]></code>
    <note>settings empty (need &gt;=3 properties), owner and deviation_log_reference missing.</note>
  </example>
  <section title="Forbidden patterns">
    <pattern id="f-no-owner">Artefact MUST NOT omit `owner` — orphan artefacts violate rule `named-owner`.</pattern>
    <pattern id="f-no-schema-conform">Artefact MUST NOT include keys outside the schema — `additionalProperties: false` is binding.</pattern>
    <pattern id="f-tbd">Artefact MUST NOT contain forbidden placeholder tokens in any string value (validator rejects them).</pattern>
  </section>
  <reference path="scripts/validate-cohort-implementation.py">Validator implementing this schema.</reference>
</text>
