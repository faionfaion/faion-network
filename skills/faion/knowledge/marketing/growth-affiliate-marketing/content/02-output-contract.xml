<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Growth Affiliate Marketing Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-affiliate-marketing.json",
  "type": "object",
  "required": [
    "program_id",
    "commission_structure",
    "cookie_window_days",
    "disclosure_policy",
    "fraud_detection",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "program_id": "affiliate-2026",
  "commission_structure": {
    "type": "recurring",
    "pct_year_1": 0.2,
    "pct_lifetime": 0.1,
    "cap_pct_ltv": 0.25
  },
  "cookie_window_days": 60,
  "disclosure_policy": {
    "required": true,
    "audit_rate_pct": 0.1
  },
  "fraud_detection": [
    "cookie_stuffing_monitor",
    "brand_keyword_serp_monitor",
    "self_referral_block"
  ],
  "owner": {
    "name": "Olha Riznyk",
    "role": "head of partnerships"
  },
  "produced_at": "2026-05-23T12:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "program_id": "x",
  "commission_structure": "50%",
  "cookie_window_days": 365
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-growth-affiliate-marketing.py">Validator script</reference>
</text>
