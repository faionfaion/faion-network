<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Churn Prevention Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the playbook-step artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-churn-prevention.json",
  "type": "object",
  "required": [
    "playbook_version",
    "phases",
    "reason_segments",
    "offers",
    "win_back_windows",
    "stop_loss",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "playbook_version": "2026-Q2",
  "phases": [
    "early_intervention",
    "save_offer",
    "win_back"
  ],
  "reason_segments": [
    "price",
    "missing_feature",
    "low_usage",
    "competitor",
    "lifecycle"
  ],
  "offers": [
    {
      "segment": "price",
      "offer": "20pct_3mo",
      "max_cost_pct_ltv": 0.45
    }
  ],
  "win_back_windows": [
    30,
    60,
    90
  ],
  "stop_loss": {
    "metric": "blended_margin",
    "threshold": 0.3,
    "window_days": 28
  },
  "owner": {
    "name": "Tetiana Lytvyn",
    "role": "head of lifecycle"
  },
  "produced_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "phases": "all",
  "offers": "20pct"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-ops-churn-prevention.py">Validator script</reference>
</text>
