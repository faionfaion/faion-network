<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Growth Copywriting Fundamentals Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply Growth Copywriting Fundamentals end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="collect-voc">
      <input>Customer reviews + interviews</input>
      <action>Extract verbatim phrases; tag by jobs-to-be-done.</action>
      <output>VoC corpus.</output>
    </step>

    <step n="2" name="pick-formula">
      <input>Piece type + ICP</input>
      <action>AIDA / PAS / BAB / 4Ps per piece.</action>
      <output>Formula chosen.</output>
    </step>

    <step n="3" name="draft-headlines">
      <input>Formula + VoC</input>
      <action>Write 10 headline variants per piece.</action>
      <output>Headline pool.</output>
    </step>

    <step n="4" name="translate-features">
      <input>Feature list + ICP</input>
      <action>Each feature → benefit_text (outcome + emotion).</action>
      <output>Benefits set.</output>
    </step>

    <step n="5" name="ship-one-cta">
      <input>Sections + benefits</input>
      <action>Each section drives ONE CTA.</action>
      <output>Copy ready.</output>
    </step>

  </section>
</text>
