<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="SERP Intent Classification Rubric Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid SERP Intent Classification Rubric output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="query" type="string" required="true">verbatim target query</field>
      <field name="primary_intent" type="enum" required="true">one of I / C / T / N</field>
      <field name="primary_subtype" type="string" required="true">e.g., I:how-to, C:vs, T:buy, N:brand</field>
      <field name="secondary_intent" type="string|null" required="true">null unless ≥30% of top-10 serve a different class</field>
      <field name="serp_evidence" type="array" required="true">≥2 independent signals with type+value</field>
      <field name="recommendation" type="enum" required="true">SINGLE_BRIEF | SPLIT | AMBIGUOUS_BLOCK</field>
      <field name="classifier" type="string" required="true">named human / agent</field>
      <field name="classified_at" type="date-time" required="true">ISO timestamp</field>
    </required>

    <forbidden>
      <pattern id="f1">primary_intent outside {I,C,T,N}</pattern>
      <pattern id="f2">serp_evidence array has &lt;2 entries</pattern>
      <pattern id="f3">secondary_intent set when &lt;30% of top-10 serves a different class</pattern>
      <pattern id="f4">recommendation=SINGLE_BRIEF when classifier flagged AMBIGUOUS</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Normalize subtype string to lowercase kebab-case.</transformation>
      <transformation>If SERP fetch failed → recommendation=AMBIGUOUS_BLOCK (not SINGLE_BRIEF).</transformation>
    </allowed-transformations>

    <schema-reference path="templates/serp-intent-classification-rubric.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/serp-intent-classification-rubric.json</item>
    </list>
  </section>
</text>
