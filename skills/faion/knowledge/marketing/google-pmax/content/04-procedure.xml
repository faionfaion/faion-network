<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Google Performance Max Procedure" version="1.1.0" est_tokens="950" depth="essential">
  <summary>5-step procedure to apply this methodology end-to-end.</summary>
  <section title="Procedure">
    <step n="1" name="verify-floor">
      <input>Conversion history</input>
      <action>Confirm ≥30 conv/mo + CAPI live + value priority configured.</action>
      <output>Floor-OK.</output>
      <decision-gate>If below floor, STOP.</decision-gate>
    </step>
    <step n="2" name="design-asset-groups">
      <input>Audience + product taxonomy</input>
      <action>Split into ≥3 themed asset groups.</action>
      <output>Asset-group list.</output>
    </step>
    <step n="3" name="attach-audience-signals">
      <input>Existing audiences</input>
      <action>Custom segment + customer match + remarketing per group.</action>
      <output>Signal stack.</output>
    </step>
    <step n="4" name="add-brand-negatives">
      <input>Brand keyword list</input>
      <action>Negative match-type=exact at account level.</action>
      <output>Brand-negative list.</output>
    </step>
    <step n="5" name="set-value-priority">
      <input>Conversion event list</input>
      <action>Priority + value (Purchase &gt; Lead &gt; SignUp).</action>
      <output>Value priority block.</output>
    </step>
  </section>
</text>
