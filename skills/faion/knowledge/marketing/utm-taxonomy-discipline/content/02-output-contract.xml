<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="UTM Taxonomy Discipline Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid UTM Taxonomy Discipline output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named taxonomy owner</field>
      <field name="source_vocabulary" type="array" required="true">≤12 kebab-case values</field>
      <field name="medium_vocabulary" type="array" required="true">≤6 kebab-case values</field>
      <field name="campaign_id_pattern" type="string" required="true">regex (yyyymmdd-asset-slug shape)</field>
      <field name="validation_regex" type="string" required="true">full URL regex</field>
      <field name="link_builder_url" type="string" required="true">tool URL</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">source_vocabulary count &gt; 12 OR mixed-case values</pattern>
      <pattern id="f2">medium_vocabulary count &gt; 6 OR mixed-case values</pattern>
      <pattern id="f3">campaign_id_pattern empty</pattern>
      <pattern id="f4">validation_regex empty</pattern>
      <pattern id="f5">link_builder_url empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to add one source/medium per quarter at review (not ad-hoc).</transformation>
      <transformation>Allowed to deprecate (not delete) a source/medium; deprecated entries remain in audit trail.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/utm-taxonomy-discipline.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/utm-taxonomy-discipline.json</item>
    </list>
  </section>
</text>
