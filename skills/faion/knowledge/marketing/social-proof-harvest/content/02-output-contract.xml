<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Social Proof Harvest Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Social Proof Harvest output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="quote_id" type="string" required="true">stable record id</field>
      <field name="source_url" type="string" required="true">URL of original public mention</field>
      <field name="author_handle" type="string" required="true">platform handle</field>
      <field name="author_display_name" type="string" required="true">name shown on the wall</field>
      <field name="verbatim_quote" type="string" required="true">exact text — no paraphrase</field>
      <field name="captured_at" type="date-time" required="true">ISO timestamp</field>
      <field name="channel" type="enum" required="true">twitter|linkedin|reddit|hn|discord|product-hunt|other</field>
      <field name="consent" type="object" required="true">{requested_at, granted_at, granted_via}</field>
      <field name="status" type="enum" required="true">captured|requested|approved|published|expired</field>
      <field name="publish_surfaces" type="array" required="true">wall|landing-hero|sales-deck|email-signature</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">verbatim_quote differs from source text (paraphrase)</pattern>
      <pattern id="f2">status=='published' AND consent.granted_at missing</pattern>
      <pattern id="f3">source_url empty</pattern>
      <pattern id="f4">quote_id duplicated within the DB</pattern>
      <pattern id="f5">publish_surfaces multiple BUT quote_id not the single source-of-truth</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to trim whitespace + obvious typos (logged in notes); semantic edits forbidden.</transformation>
      <transformation>Allowed to mark broken source_url as 'stale' but never delete the consent log.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/social-proof-harvest.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/social-proof-harvest.json</item>
    </list>
  </section>
</text>
