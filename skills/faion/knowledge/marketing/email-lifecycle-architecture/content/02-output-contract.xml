<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Email Lifecycle Architecture Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/email-lifecycle-architecture.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "lifecycle_map",
    "frequency_cap",
    "suppression_list_id",
    "consent_records",
    "compliance_basis",
    "audit_date",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "lifecycle_map": {
      "type": "array"
    },
    "frequency_cap": {
      "type": "object"
    },
    "suppression_list_id": {
      "type": "string"
    },
    "consent_records": {
      "type": "object"
    },
    "compliance_basis": {
      "type": "array"
    },
    "audit_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">frequency_cap is per-program (not global) — violates r2</pattern>
      <pattern id="f2">suppression list is per-program (not global) — violates r3</pattern>
      <pattern id="f3">consent_records missing source field — violates r4</pattern>
      <pattern id="f4">compliance_basis missing for any program targeting EU/UK/CA — violates r4</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "email-lifecycle-architecture-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "lifecycle_map": [],
  "frequency_cap": {},
  "suppression_list_id": "<suppression_list_id>",
  "consent_records": {},
  "compliance_basis": [],
  "audit_date": "2026-05-23",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "lifecycle_map": [],
  "frequency_cap": {},
  "suppression_list_id": "<suppression_list_id>",
  "consent_records": {},
  "compliance_basis": [],
  "audit_date": "2026-05-23",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-email-lifecycle-architecture.py">Schema validator (stdlib only).</reference>
</text>
