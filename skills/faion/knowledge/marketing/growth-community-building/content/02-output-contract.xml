<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Growth Community Building Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Growth Community Building output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="community_id" type="string" required="true">kebab-case slug</field>
      <field name="host" type="string" required="true">named human accountable for rituals</field>
      <field name="platform" type="enum" required="true">discord|slack|circle|telegram</field>
      <field name="seed_members" type="array" required="true">≥50 entries with name + handle + reason</field>
      <field name="planted_conversations" type="array" required="true">5-10 conversation prompts with author</field>
      <field name="rituals" type="array" required="true">≥3 with cadence + owner + agenda</field>
      <field name="guidelines" type="string" required="true">community guidelines markdown</field>
      <field name="health_targets" type="object" required="true">{dau_mau: 0.25, weekly_active_members_pct: 0.4}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">platform array (multiple) — single platform only</pattern>
      <pattern id="f2">seed_members count &lt; 50</pattern>
      <pattern id="f3">rituals count &lt; 3</pattern>
      <pattern id="f4">host = 'team' / 'community manager' (unnamed)</pattern>
      <pattern id="f5">planted_conversations count &lt; 5</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to start with 30 seed members IF planted_conversations ≥ 10.</transformation>
      <transformation>Allowed to defer monetize stage; the first three stages are mandatory.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/growth-community-building.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/growth-community-building.json</item>
    </list>
  </section>
</text>
