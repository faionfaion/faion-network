<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Churn Basics Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-churn-basics.json",
  "type": "object",
  "required": [
    "report_period",
    "customer_churn_rate",
    "mrr_churn_rate",
    "nrr",
    "voluntary_split",
    "cohort_grid",
    "leading_indicators",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "report_period": "2026-04",
  "customer_churn_rate": 0.042,
  "mrr_churn_rate": 0.031,
  "nrr": 1.08,
  "voluntary_split": {
    "voluntary": 0.028,
    "involuntary": 0.014
  },
  "cohort_grid": [
    {
      "cohort": "2026-01",
      "plan": "starter",
      "churn": 0.09
    }
  ],
  "leading_indicators": [
    "login_freq_drop",
    "feature_usage_delta",
    "support_score"
  ],
  "owner": {
    "name": "Olha Riznyk",
    "role": "head of growth"
  },
  "produced_at": "2026-05-23T09:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "customer_churn_rate": 0.6,
  "nrr": "high"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-ops-churn-basics.py">Validator script</reference>
</text>
