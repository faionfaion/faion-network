<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="A/B Testing Basics Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the spec this methodology produces. Validator enforces the rule-set constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["test_id", "hypothesis", "primary_metric", "secondary_metrics", "mde", "sample_size", "split", "starts_at", "closes_at", "owner"],
  "properties": {
    "test_id": {"type": "string"},
    "hypothesis": {"type": "string", "minLength": 20},
    "primary_metric": {"type": "object", "required": ["name", "baseline"], "properties": {"name": {"type": "string"}, "baseline": {"type": "number"}}},
    "secondary_metrics": {"type": "array", "maxItems": 2, "items": {"type": "object", "required": ["name"], "properties": {"name": {"type": "string"}}}},
    "mde": {"type": "number", "minimum": 0.001},
    "sample_size": {"type": "integer", "minimum": 100},
    "split": {"type": "object", "required": ["control", "treatment"], "properties": {"control": {"type": "number"}, "treatment": {"type": "number"}}},
    "starts_at": {"type": "string", "format": "date"},
    "closes_at": {"type": "string", "format": "date"},
    "owner": {"type": "string"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_id": "EXP-2026-031",
  "hypothesis": "Shortening the hero copy increases primary CTA CTR for cold pricing traffic.",
  "primary_metric": {"name": "cta_ctr", "baseline": 0.062},
  "secondary_metrics": [{"name": "signup_cr"}, {"name": "d7_retention"}],
  "mde": 0.05,
  "sample_size": 12400,
  "split": {"control": 0.5, "treatment": 0.5},
  "starts_at": "2026-05-06",
  "closes_at": "2026-05-20",
  "owner": "@ruslan"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"test_id": "x", "hypothesis": "we test", "secondary_metrics": [{"name": "a"}, {"name": "b"}, {"name": "c"}], "split": {"control": 0.8, "treatment": 0.2}, "owner": "team", "primary_metric": {}, "mde": 0, "sample_size": 0, "starts_at": "2026-05-06", "closes_at": "2026-05-20"}
]]></code>
    <note>Violates one or more of the forbidden patterns listed below.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>hypothesis &lt;20 chars (rule pre-registration-required).</item>
      <item>secondary_metrics length &gt;2 (rule secondary-metrics-pre-registered).</item>
      <item>split with non-50/50 without justification field (rule fifty-fifty-split-or-justify).</item>
      <item>sample_size &lt; 100 (rule pre-registration-required).</item>
      <item>Decision before closes_at (rule no-peeking — validated at close, not pre-reg).</item>
    </list>
  </section>

  <reference path="scripts/validate-ab-testing-basics.py">Validator script</reference>
</text>
