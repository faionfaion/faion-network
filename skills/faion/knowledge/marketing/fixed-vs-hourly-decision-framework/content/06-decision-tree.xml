<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Fixed Vs Hourly Decision Framework Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Tree routes signal scores to fixed / hourly / hybrid; leaves cite rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-scope">scope_clarity?</root-question>

    <branch when="scope_clarity == low">
      <conclusion ref="signal-scored" verdict="chosen=hourly; fixed would require client maturity that low scope rarely has"/>
    </branch>

    <branch when="scope_clarity == medium">
      <question id="q-change">change_rate?</question>
      <branch when="change_rate == high">
        <conclusion ref="kill-criteria-numeric" verdict="chosen=hybrid; fixed base + T&amp;M change-budget"/>
      </branch>
      <branch when="change_rate != high">
        <conclusion ref="kill-criteria-numeric" verdict="chosen=hybrid; small fixed scope + bounded T&amp;M"/>
      </branch>
    </branch>

    <branch when="scope_clarity == high">
      <question id="q-familiarity">domain_familiarity?</question>
      <branch when="domain_familiarity == high">
        <conclusion ref="decision-logged-with-reversal" verdict="chosen=fixed; kill criterion = change-rate spike"/>
      </branch>
      <branch when="domain_familiarity != high">
        <question id="q-maturity">client_maturity?</question>
        <branch when="client_maturity == high">
          <conclusion ref="decision-logged-with-reversal" verdict="chosen=fixed with discovery sprint up front"/>
        </branch>
        <branch when="client_maturity != high">
          <conclusion ref="kill-criteria-numeric" verdict="chosen=hybrid; protect against unknowns"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="clear scope, familiar domain">
    scope_clarity=high → domain_familiarity=high → decision-logged-with-reversal → chosen=fixed.
  </example>
</text>
