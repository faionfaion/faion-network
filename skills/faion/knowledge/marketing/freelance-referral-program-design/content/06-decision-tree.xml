<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelance Referral Program Design Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Decision tree routes observable signals to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-incentive">Is incentive flat_cash or credit?</root-question>

    <branch when="type == percent">
      <conclusion ref="flat-incentive-not-percent" verdict="STOP — switch to flat_cash/credit"/>
    </branch>

    <branch when="type == flat_cash OR type == credit">
      <question id="q-terms">Written terms recorded for every referrer?</question>
      <branch when="terms == false">
        <conclusion ref="written-incentive-per-referrer" verdict="STOP — collect written terms first"/>
      </branch>
      <branch when="terms == true">
        <question id="q-window">attribution_window_days ≤90?</question>
        <branch when="window &gt; 90">
          <conclusion ref="attribution-window-90-days" verdict="STOP — cap window at 90 days"/>
        </branch>
        <branch when="window &lt;= 90">
          <conclusion ref="nda-safe-testimonial-framing" verdict="proceed; ensure testimonial pre-approved per customer"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="valid program">
    type=flat_cash → terms=true → window=90 → nda-safe-testimonial-framing → proceed.
  </example>
</text>
