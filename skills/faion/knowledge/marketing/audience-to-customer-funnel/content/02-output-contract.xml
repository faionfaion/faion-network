<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Audience to Customer Funnel Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/audience-to-customer-funnel.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "stages",
    "data_window_days",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "stages": {
      "type": "array"
    },
    "data_window_days": {
      "type": "integer"
    },
    "provisional": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">stages != [Awareness, Interest, Consideration, Conversion] in that order (r1).</pattern>
      <pattern id="f3">any stage.kpi list with more than one element (r2).</pattern>
      <pattern id="f4">any stage.drop_off_threshold_pct missing OR 0 (r4).</pattern>
      <pattern id="f5">data_window_days &lt; 30 AND provisional == false (r5).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "funnel-faion-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "stages": [
    {
      "name": "Awareness",
      "kpi": "unique_visitors",
      "owner": "@ruslan",
      "drop_off_threshold_pct": 90
    },
    {
      "name": "Interest",
      "kpi": "newsletter_signups",
      "owner": "@ruslan",
      "drop_off_threshold_pct": 80
    },
    {
      "name": "Consideration",
      "kpi": "trial_starts",
      "owner": "@ruslan",
      "drop_off_threshold_pct": 50
    },
    {
      "name": "Conversion",
      "kpi": "paid_subscribers",
      "owner": "@ruslan",
      "drop_off_threshold_pct": 30
    }
  ],
  "data_window_days": 30,
  "provisional": false,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "stages": [
    {
      "name": "Awareness",
      "kpi": "visits"
    }
  ],
  "data_window_days": 7,
  "owner": "team"
}
]]></code>
    <note>stages missing 3 of 4 fixed stages (r1); data_window_days=7 (r5); owner=team; missing artefact_id, version, last_reviewed.</note>
  </example>

  <reference path="scripts/validate-audience-to-customer-funnel.py">Schema validator (stdlib only).</reference>
</text>
