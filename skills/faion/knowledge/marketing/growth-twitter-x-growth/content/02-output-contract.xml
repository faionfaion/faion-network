<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Growth Twitter X Growth Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Growth Twitter X Growth output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named X account owner</field>
      <field name="unique_angle" type="string" required="true">one-sentence positioning</field>
      <field name="daily_post_target" type="integer" required="true">3-5</field>
      <field name="weekly_thread_target" type="integer" required="true">1-2</field>
      <field name="daily_reply_target" type="integer" required="true">20-30 to accounts &gt;5x size</field>
      <field name="reply_target_list" type="array" required="true">≥20 accounts with handle + size_multiple</field>
      <field name="kpi_set" type="object" required="true">{impressions, replies_from_strangers, link_clicks, qualified_follows}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">daily_post_target outside 3..5 band</pattern>
      <pattern id="f2">weekly_thread_target == 0</pattern>
      <pattern id="f3">reply_target_list contains accounts smaller than operator's account</pattern>
      <pattern id="f4">kpi_set headline == 'followers'</pattern>
      <pattern id="f5">unique_angle generic ('helping people grow on X')</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to scale daily_post_target down to 3 during launch weeks.</transformation>
      <transformation>Allowed to substitute one weekly thread with one longer build-in-public update.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/growth-twitter-x-growth.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/growth-twitter-x-growth.json</item>
    </list>
  </section>
</text>
