<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Founder Deal Kill Rule Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Tree mapping trip count + composition to action (killed / kept / escalated). Leaves cite a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-trips">Number of kill conditions tripped on this deal?</root-question>

    <branch when="trips == 0">
      <conclusion ref="numeric-thresholds" verdict="action=kept; no kill condition met"/>
    </branch>

    <branch when="trips == 1">
      <question id="q-which">Which condition tripped?</question>
      <branch when="trip == champion_left">
        <conclusion ref="two-trip-auto-kill" verdict="action=escalated; champion alone needs human review"/>
      </branch>
      <branch when="trip != champion_left">
        <conclusion ref="numeric-thresholds" verdict="action=kept; single soft signal"/>
      </branch>
    </branch>

    <branch when="trips &gt;= 2">
      <question id="q-positive-signals">Are there positive recent signals (meeting scheduled, budget confirmed in last 7d)?</question>
      <branch when="positive_signals == true">
        <conclusion ref="batch-not-debate" verdict="action=escalated; conflicting signals"/>
      </branch>
      <branch when="positive_signals == false">
        <conclusion ref="two-trip-auto-kill" verdict="action=killed; reversal_window=30 days"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="no-reply 25d + last-meeting 35d, no positive">
    trips=2 → positive_signals=false → two-trip-auto-kill → action=killed.
  </example>
</text>
