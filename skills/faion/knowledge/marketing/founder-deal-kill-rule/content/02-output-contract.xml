<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Founder Deal Kill Rule Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for one weekly kill-batch. Validator enforces numeric conditions + auto-kill on 2+ trips + reversal-window field.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/founder-deal-kill-batch.json",
  "type": "object",
  "required": ["batch_id", "run_date", "owner", "thresholds", "deals", "killed", "escalated"],
  "properties": {
    "batch_id": {"type": "string", "pattern": "^kb-\\d{4}-\\d{2}-\\d{2}$"},
    "run_date": {"type": "string", "format": "date"},
    "owner": {"type": "string", "minLength": 3, "not": {"pattern": "(?i)^(team|we|us)$"}},
    "thresholds": {
      "type": "object",
      "required": ["no_reply_days", "last_meeting_days"],
      "properties": {
        "no_reply_days": {"type": "integer", "minimum": 1},
        "last_meeting_days": {"type": "integer", "minimum": 1}
      }
    },
    "deals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["deal_id", "trips", "action"],
        "properties": {
          "deal_id": {"type": "string"},
          "trips": {"type": "array", "items": {"enum": ["no_reply", "last_meeting", "missed_milestone", "budget_unconfirmed", "champion_left"]}},
          "action": {"enum": ["killed", "kept", "escalated"]},
          "reversal_window_days": {"type": "integer", "minimum": 0, "maximum": 30}
        }
      }
    },
    "killed": {"type": "integer", "minimum": 0},
    "escalated": {"type": "integer", "minimum": 0}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "batch_id": "kb-2026-05-23",
  "run_date": "2026-05-23",
  "owner": "@ruslan",
  "thresholds": {"no_reply_days": 21, "last_meeting_days": 30},
  "deals": [
    {"deal_id": "d-101", "trips": ["no_reply", "last_meeting"], "action": "killed", "reversal_window_days": 30},
    {"deal_id": "d-102", "trips": ["budget_unconfirmed"], "action": "kept"},
    {"deal_id": "d-103", "trips": ["champion_left", "no_reply"], "action": "killed", "reversal_window_days": 30},
    {"deal_id": "d-104", "trips": ["missed_milestone", "last_meeting", "champion_left"], "action": "escalated"}
  ],
  "killed": 2,
  "escalated": 1
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{"batch_id": "kb-1", "owner": "team", "thresholds": {"no_reply_days": "stale"}, "deals": []}
]]></code>
    <note>batch_id format; owner="team"; thresholds string not int; deals empty.</note>
  </example>

  <section title="Forbidden">
    <list>
      <item>owner == "team"/"we"/"us" (rule retro-refines-thresholds requires named owner).</item>
      <item>deals[i].trips length &gt;= 2 with action != "killed" or "escalated" (rule two-trip-auto-kill).</item>
      <item>thresholds with non-numeric values (rule numeric-thresholds).</item>
      <item>reversal_window_days &gt; 30 (rule reversible-30-days).</item>
    </list>
  </section>

  <reference path="scripts/validate-founder-deal-kill-rule.py">Validator script</reference>
</text>
