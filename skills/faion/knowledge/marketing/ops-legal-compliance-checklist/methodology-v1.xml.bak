<methodology slug="ops-legal-compliance-checklist">
  <metadata>
    <tier>pro</tier>
    <group>marketing</group>
    <domain>gtm-strategist</domain>
    <summary>Compliance tracker for Day 1 (entity, policies), Month 1 (website, data protection, payment), Year 1 (taxes, employment, insurance), Ongoing (review). Verifies presence, not accuracy.</summary>
    <tags>
      <tag>compliance</tag>
      <tag>checklist</tag>
      <tag>implementation</tag>
      <tag>audit</tag>
      <tag>legal</tag>
    </tags>
    <category>ops</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-28</created>
