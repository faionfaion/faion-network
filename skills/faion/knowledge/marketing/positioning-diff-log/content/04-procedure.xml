<text id="04-procedure" title="Positioning Diff Log Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Positioning Diff Log end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="capture-trigger">
      <input>Trigger event (call, churn, etc.)</input>
      <action>Name the trigger concretely.</action>
      <output>trigger.</output>
    </step>

    <step n="2" name="snapshot-old-and-new">
      <input>Current + new copy</input>
      <action>Capture both verbatim.</action>
      <output>old + new wording.</output>
    </step>

    <step n="3" name="declare-expected-effect">
      <input>Metric + direction + magnitude</input>
      <action>Set falsifiable expectation.</action>
      <output>expected_effect.</output>
    </step>

    <step n="4" name="schedule-checks">
      <input>Calendar</input>
      <action>Schedule 30d + 90d checks on the named metric.</action>
      <output>check_30d / 90d.</output>
    </step>

    <step n="5" name="run-retro">
      <input>Metric data</input>
      <action>Compare actual to expected; capture in the entry.</action>
      <output>check actuals.</output>
    </step>

  </section>
</text>
