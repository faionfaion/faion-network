<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Positioning Diff Log Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/positioning-diff-log.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "trigger",
    "old_wording",
    "new_wording",
    "expected_effect",
    "check_30d",
    "check_90d",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "trigger": {
      "type": "string"
    },
    "old_wording": {
      "type": "string"
    },
    "new_wording": {
      "type": "string"
    },
    "expected_effect": {
      "type": "object"
    },
    "check_30d": {
      "type": "object"
    },
    "check_90d": {
      "type": "object"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">trigger empty OR == &apos;iteration&apos; — violates r2</pattern>
      <pattern id="f2">old_wording == new_wording — violates r3</pattern>
      <pattern id="f3">expected_effect missing metric|direction|magnitude — violates r4</pattern>
      <pattern id="f4">check_30d.scheduled_date missing — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "positioning-diff-log-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "trigger": "<trigger>",
  "old_wording": "<old_wording>",
  "new_wording": "<new_wording>",
  "expected_effect": {},
  "check_30d": {},
  "check_90d": {},
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "trigger": "<trigger>",
  "old_wording": "<old_wording>",
  "new_wording": "<new_wording>",
  "expected_effect": {},
  "check_30d": {},
  "check_90d": {},
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-positioning-diff-log.py">Schema validator (stdlib only).</reference>
</text>
