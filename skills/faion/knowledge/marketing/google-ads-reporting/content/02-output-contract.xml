<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Google Ads Reporting Dashboards Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by google-ads-reporting. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/google-ads-reporting.json",
  "type": "object",
  "required": [
    "columns",
    "views",
    "alerts",
    "segments",
    "action_queue"
  ],
  "properties": {
    "columns": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "string"
      }
    },
    "views": {
      "type": "array",
      "minItems": 3,
      "items": {
        "enum": [
          "operator_weekly",
          "executive_monthly",
          "stakeholder_summary"
        ]
      }
    },
    "alerts": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "metric",
          "operator",
          "threshold"
        ]
      }
    },
    "segments": {
      "type": "array",
      "minItems": 4,
      "items": {
        "enum": [
          "device",
          "network",
          "location",
          "time",
          "audience"
        ]
      }
    },
    "action_queue": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "priority",
          "lever",
          "expected_impact",
          "owner"
        ]
      }
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "columns": [
    "Impressions",
    "Clicks",
    "CTR",
    "Avg CPC",
    "Cost",
    "Conversions",
    "Conv rate",
    "CPA",
    "Conv value",
    "ROAS",
    "Impression share",
    "Quality Score"
  ],
  "views": [
    "operator_weekly",
    "executive_monthly",
    "stakeholder_summary"
  ],
  "alerts": [
    {
      "metric": "CPA",
      "operator": ">",
      "threshold": "target +20%"
    },
    {
      "metric": "IS",
      "operator": "<",
      "threshold": "70%"
    },
    {
      "metric": "conv_rate",
      "operator": "<",
      "threshold": "target -15%"
    },
    {
      "metric": "daily_spend",
      "operator": ">",
      "threshold": "forecast +25%"
    }
  ],
  "segments": [
    "device",
    "network",
    "location",
    "time",
    "audience"
  ],
  "action_queue": [
    {
      "priority": 1,
      "lever": "negative_sweep",
      "expected_impact": "CPA -8%",
      "owner": "ops"
    }
  ]
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "columns": [
    "Clicks"
  ],
  "views": [
    "operator_weekly"
  ],
  "alerts": [],
  "segments": [],
  "action_queue": []
}
    ]]></code>
    <note>Columns short of 12; only 1 view; alerts/segments/actions empty.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-no-segments" severity="medium">
      <description>segments array length &lt; 4.</description>
      <reason>Violates segment-by-default rule.</reason>
    </antipattern>
    <antipattern id="f-no-action-queue" severity="medium">
      <description>action_queue array empty.</description>
      <reason>Violates action-queue-required rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-google-ads-reporting.py">Validator script enforcing this schema</reference>
</text>
