<text id="06-decision-tree" title="Google Ads Reporting Dashboards Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree on observable signals. Every leaf <conclusion ref="..."/> points to a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="q-precond">Account ≥30 days, ≥$1k/mo spend, multi-stakeholder visibility required?</root-question>
    <branch when="preconditions == true">
      <conclusion ref="column-preset-mandatory" verdict="apply google-ads-reporting methodology end-to-end"/>
    </branch>
    <branch when="preconditions == false">
      <conclusion ref="three-views" verdict="skip-this-methodology; defer until preconditions met"/>
    </branch>
  </decision-tree>
  <example trace="saas-q2-dashboard">
    preconds=true → 3 views + alerts + segment-by-default.
  </example>
</text>
