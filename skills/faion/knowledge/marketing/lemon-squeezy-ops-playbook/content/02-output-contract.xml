<text id="02-output-contract" title="Lemon Squeezy Store Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 for a Lemon Squeezy store + variants config plus valid/invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/lemon-squeezy-ops-playbook.json",
  "type": "object",
  "required": ["store", "variants", "dunning", "affiliate", "review"],
  "properties": {
    "store": {
      "type": "object",
      "required": ["store_id", "store_name", "currency", "refund_policy", "uses_mor"],
      "properties": {
        "store_id": {"type": "string", "minLength": 3},
        "store_name": {"type": "string", "minLength": 3},
        "currency": {"type": "string", "enum": ["usd", "eur"]},
        "refund_policy": {"type": "string", "enum": ["no_refunds", "14_day", "30_day"]},
        "uses_mor": {"type": "boolean"}
      }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["variant_id", "name", "amount", "interval", "license_api_enabled"],
        "properties": {
          "variant_id": {"type": "string"},
          "name": {"type": "string", "minLength": 3},
          "amount": {"type": "number", "minimum": 0},
          "interval": {"type": "string", "enum": ["one_time", "monthly", "yearly"]},
          "license_api_enabled": {"type": "boolean"}
        }
      }
    },
    "dunning": {
      "type": "object",
      "required": ["sequence_days"],
      "properties": {
        "sequence_days": {
          "type": "array",
          "items": {"type": "integer", "minimum": 1, "maximum": 30},
          "minItems": 3
        }
      }
    },
    "affiliate": {
      "type": "object",
      "required": ["enabled", "commission_pct"],
      "properties": {
        "enabled": {"type": "boolean"},
        "commission_pct": {"type": "number", "minimum": 0, "maximum": 90}
      }
    },
    "review": {
      "type": "object",
      "required": ["reviewed_at"],
      "properties": {
        "reviewed_at": {"type": "string", "format": "date"},
        "conversion_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "refund_rate": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "store": {"store_id": "ls-store-1", "store_name": "Indie SaaS", "currency": "usd",
            "refund_policy": "14_day", "uses_mor": true},
  "variants": [
    {"variant_id": "v-solo", "name": "Solo", "amount": 19, "interval": "monthly",
     "license_api_enabled": true},
    {"variant_id": "v-pro", "name": "Pro", "amount": 39, "interval": "monthly",
     "license_api_enabled": true}
  ],
  "dunning": {"sequence_days": [1, 4, 8]},
  "affiliate": {"enabled": true, "commission_pct": 40},
  "review": {"reviewed_at": "2026-05-23", "conversion_rate": 0.041, "refund_rate": 0.012}
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "store": {"store_id": "x", "currency": "gbp", "uses_mor": false},
  "variants": [],
  "dunning": {"sequence_days": [1]},
  "affiliate": {"enabled": true, "commission_pct": 95},
  "review": {}
}
]]></code>
    <note>store_id too short, currency not in enum, variants empty (below minItems), dunning sequence too short, commission above max, review missing reviewed_at.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">store.uses_mor=true AND seller also issues a separate VAT invoice (double-tax).</pattern>
      <pattern id="f2">variant with interval IN ('monthly','yearly') has license_api_enabled=false (subscription software without verification).</pattern>
      <pattern id="f3">dunning.sequence_days length &lt; 3 (single-touch dunning).</pattern>
      <pattern id="f4">affiliate.commission_pct outside [30,50] without rationale field.</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Round affiliate.commission_pct to nearest 5%.</transformation>
      <transformation>Hide archived variants from variant_count without deleting.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-lemon-squeezy-ops-playbook.py">Validator script</reference>
</text>
