<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Ops Dashboard Setup Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-dashboard-setup.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "widgets",
    "hosting",
    "owner",
    "next_review"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "widgets": {
      "type": "array"
    },
    "hosting": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "next_review": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">widgets.length &gt; 7 — violates r2</pattern>
      <pattern id="f2">any widget.freshness_sla missing — violates r3</pattern>
      <pattern id="f3">any widget.owner in plural roles — violates r4</pattern>
      <pattern id="f4">any widget.alert_threshold missing — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ops-dashboard-setup-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "widgets": [],
  "hosting": "<hosting>",
  "owner": "@ruslan",
  "next_review": "2026-05-23"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "widgets": [],
  "hosting": "<hosting>",
  "owner": "team",
  "next_review": "2026-05-23"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-ops-dashboard-setup.py">Schema validator (stdlib only).</reference>
</text>
