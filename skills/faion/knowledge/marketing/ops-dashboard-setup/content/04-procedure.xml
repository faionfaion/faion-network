<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Ops Dashboard Setup Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Ops Dashboard Setup end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="list-decisions">
      <input>Review cadence + product goals</input>
      <action>List the 5-7 decisions the dashboard must support.</action>
      <output>Decision list.</output>
    </step>

    <step n="2" name="map-decisions-to-widgets">
      <input>Decision list + data sources</input>
      <action>One widget per decision; max 7.</action>
      <output>Widget skeleton.</output>
    </step>

    <step n="3" name="set-freshness-sla">
      <input>Widget skeleton</input>
      <action>Per-widget freshness SLA (24h ops, 1h incident).</action>
      <output>SLA per widget.</output>
    </step>

    <step n="4" name="assign-owner-and-alert">
      <input>Widget skeleton</input>
      <action>Named owner + alert threshold + channel per widget.</action>
      <output>Owner + alert pairs.</output>
    </step>

    <step n="5" name="schedule-monthly-review">
      <input>Final spec</input>
      <action>Set next_review = today + 30 days.</action>
      <output>next_review set.</output>
    </step>

  </section>
</text>
