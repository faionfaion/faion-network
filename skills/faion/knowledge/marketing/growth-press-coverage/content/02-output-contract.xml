<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Press &amp; PR Coverage Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the playbook-step artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-press-coverage.json",
  "type": "object",
  "required": [
    "campaign_id",
    "journalists",
    "angle",
    "pitch_word_count",
    "followups",
    "assets_offered",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "campaign_id": "launch-2026-Q2",
  "journalists": [
    {
      "name": "Alex K",
      "publication": "RetentionWeek (Tier-3)",
      "beat": "B2B SaaS retention",
      "researched": true,
      "recent_article_ref": "https://retentionweek.com/post-funded-startups-churn"
    }
  ],
  "angle": "data_first",
  "pitch_word_count": 132,
  "followups": [
    {
      "day": 4,
      "kind": "reminder"
    },
    {
      "day": 10,
      "kind": "value_add"
    }
  ],
  "assets_offered": [
    "exec_interview",
    "exclusive_data_table",
    "demo_video"
  ],
  "owner": {
    "name": "Tetiana Lytvyn",
    "role": "founder"
  },
  "produced_at": "2026-05-23T16:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "campaign_id": "x",
  "angle": "we_launched",
  "pitch_word_count": 480
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-growth-press-coverage.py">Validator script</reference>
</text>
