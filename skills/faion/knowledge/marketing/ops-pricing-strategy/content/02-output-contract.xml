<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pricing Strategy Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-pricing-strategy.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "cost_floor_usd",
    "value_ceiling_usd",
    "pricing_model",
    "price_points",
    "test_plan_60d",
    "grandfather_policy",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "cost_floor_usd": {
      "type": "number"
    },
    "value_ceiling_usd": {
      "type": "number"
    },
    "pricing_model": {
      "type": "string",
      "enum": [
        "subscription",
        "usage",
        "hybrid",
        "one-time"
      ]
    },
    "price_points": {
      "type": "array"
    },
    "test_plan_60d": {
      "type": "object"
    },
    "grandfather_policy": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">min(price_points) &lt; cost_floor_usd — violates r1</pattern>
      <pattern id="f2">max(price_points) &gt; value_ceiling_usd — violates r2</pattern>
      <pattern id="f3">test_plan_60d.duration_days &lt; 60 — violates r4</pattern>
      <pattern id="f4">grandfather_policy missing — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ops-pricing-strategy-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "cost_floor_usd": 1.0,
  "value_ceiling_usd": 1.0,
  "pricing_model": "subscription",
  "price_points": [],
  "test_plan_60d": {},
  "grandfather_policy": "<grandfather_policy>",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "cost_floor_usd": 1.0,
  "value_ceiling_usd": 1.0,
  "pricing_model": "subscription",
  "price_points": [],
  "test_plan_60d": {},
  "grandfather_policy": "<grandfather_policy>",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-ops-pricing-strategy.py">Schema validator (stdlib only).</reference>
</text>
