<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Meta Audience Targeting (3-Tier) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema draft-07 for the artefact produced by ads-meta-targeting. Validator enforces required keys and per-field constraints; downstream automation refuses to consume outputs that fail the schema.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ads-meta-targeting.json",
  "type": "object",
  "required": [
    "tiers",
    "exclusions",
    "advantage_plus_allowed"
  ],
  "properties": {
    "tiers": {
      "type": "object",
      "required": [
        "core",
        "custom",
        "lookalike"
      ],
      "properties": {
        "core": {
          "type": "object",
          "required": [
            "interest",
            "size_estimate"
          ]
        },
        "custom": {
          "type": "object",
          "required": [
            "sources"
          ]
        },
        "lookalike": {
          "type": "object",
          "required": [
            "source",
            "source_size",
            "pct"
          ]
        }
      }
    },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "advantage_plus_allowed": {
      "type": "boolean"
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tiers": {
    "core": {
      "interest": [
        "SaaS",
        "Developer tools"
      ],
      "size_estimate": 1200000
    },
    "custom": {
      "sources": [
        "site_visitors_30d",
        "video_75pct_watched"
      ]
    },
    "lookalike": {
      "source": "purchasers_180d",
      "source_size": 4800,
      "pct": 1.0
    }
  },
  "exclusions": [
    "current_customers",
    "subscribers"
  ],
  "advantage_plus_allowed": false
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tiers": {
    "core": {
      "interest": [
        "AI"
      ],
      "size_estimate": 80000
    },
    "lookalike": {
      "source": "tiny",
      "source_size": 200,
      "pct": 1
    }
  },
  "exclusions": [],
  "advantage_plus_allowed": true
}
    ]]></code>
    <note>Core size 80k violates 500K rule; LAL source 200 &lt; 1000; missing custom tier; exclusions empty.</note>
  </example>
  <section title="Forbidden patterns">
    <antipattern id="f-no-exclusions" severity="medium">
      <description>exclusions array empty.</description>
      <reason>Violates exclusion-first rule.</reason>
    </antipattern>
    <antipattern id="f-tiny-lal" severity="medium">
      <description>lookalike.source_size &lt; 1000.</description>
      <reason>Violates lookalike-source-1000 rule.</reason>
    </antipattern>
  </section>
  <reference path="scripts/validate-ads-meta-targeting.py">Validator script enforcing this schema</reference>
</text>
