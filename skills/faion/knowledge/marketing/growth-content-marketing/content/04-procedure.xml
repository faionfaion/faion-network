<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Growth Content Marketing Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply Growth Content Marketing end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="define-pillar-and-cluster">
      <input>ICP + keyword research</input>
      <action>Pick 1 pillar + 3-7 cluster keywords.</action>
      <output>Cluster spec.</output>
    </step>

    <step n="2" name="draft-briefs">
      <input>Cluster spec</input>
      <action>One brief per piece (keyword, intent, outline, competitors).</action>
      <output>Brief set.</output>
    </step>

    <step n="3" name="build-calendar">
      <input>Briefs</input>
      <action>3-month calendar mapped to funnel stages.</action>
      <output>Calendar.</output>
    </step>

    <step n="4" name="distribution-checklist">
      <input>Each piece</input>
      <action>Per-piece distribution checklist (channels, sequences, dates).</action>
      <output>Checklists ready.</output>
    </step>

    <step n="5" name="ship-and-track">
      <input>Calendar + checklists</input>
      <action>Ship per cadence; track KPIs monthly.</action>
      <output>Engine running.</output>
    </step>

  </section>
</text>
