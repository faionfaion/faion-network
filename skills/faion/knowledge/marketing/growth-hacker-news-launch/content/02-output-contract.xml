<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Hacker News Launch Strategy Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-hacker-news-launch.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "hn_account",
    "account_karma",
    "post_title",
    "post_window_utc",
    "demo_url",
    "engagement_owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "hn_account": {
      "type": "string"
    },
    "account_karma": {
      "type": "integer"
    },
    "post_title": {
      "type": "string"
    },
    "post_window_utc": {
      "type": "string"
    },
    "demo_url": {
      "type": "string"
    },
    "engagement_owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">account_karma &lt; 50 — violates r1</pattern>
      <pattern id="f2">post_title contains forbidden hype words — violates r2</pattern>
      <pattern id="f3">post_window_utc outside Tue-Thu 12:00-15:00 UTC — violates r3</pattern>
      <pattern id="f4">demo_url requires auth — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "growth-hacker-news-launch-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "hn_account": "<hn_account>",
  "account_karma": 1,
  "post_title": "<post_title>",
  "post_window_utc": "<post_window_utc>",
  "demo_url": "<demo_url>",
  "engagement_owner": "<engagement_owner>"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "hn_account": "<hn_account>",
  "account_karma": 1,
  "post_title": "<post_title>",
  "post_window_utc": "<post_window_utc>",
  "demo_url": "<demo_url>",
  "engagement_owner": "<engagement_owner>"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-growth-hacker-news-launch.py">Schema validator (stdlib only).</reference>
</text>
