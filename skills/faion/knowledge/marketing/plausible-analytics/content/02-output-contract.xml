<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Plausible Analytics Setup Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/plausible-analytics.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "site_domain",
    "script_host",
    "goals",
    "custom_props",
    "shared_links",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "site_domain": {
      "type": "string"
    },
    "script_host": {
      "type": "string"
    },
    "goals": {
      "type": "array"
    },
    "custom_props": {
      "type": "array"
    },
    "shared_links": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">custom_props contains pii_fields (email|name|user_id|ip) — violates r3</pattern>
      <pattern id="f2">script_host == &apos;plausible.io&apos; AND no_proxy_configured — violates r4</pattern>
      <pattern id="f3">shared_links contains &apos;master_credentials&apos; — violates r5</pattern>
      <pattern id="f4">goals.length == 0 AND site_has_conversion == true — violates r2</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "plausible-analytics-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "site_domain": "<site_domain>",
  "script_host": "<script_host>",
  "goals": [],
  "custom_props": [],
  "shared_links": [],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "site_domain": "<site_domain>",
  "script_host": "<script_host>",
  "goals": [],
  "custom_props": [],
  "shared_links": [],
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-plausible-analytics.py">Schema validator (stdlib only).</reference>
</text>
