<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="First 5 Paying Customers Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/first-5-paying-customers-checklist.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "icp",
    "price_usd_month",
    "channels",
    "weekly_quota",
    "paid_customers",
    "status",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "icp": {
      "type": "string"
    },
    "price_usd_month": {
      "type": "integer"
    },
    "channels": {
      "type": "array"
    },
    "weekly_quota": {
      "type": "object"
    },
    "paid_customers": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "graduated",
        "abandoned"
      ]
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">price_usd_month == 0 — violates r3</pattern>
      <pattern id="f2">channels.length &lt; 2 — violates r2</pattern>
      <pattern id="f3">icp empty or multi-ICP — violates r4</pattern>
      <pattern id="f4">owner in [&apos;team&apos;,&apos;we&apos;,&apos;everyone&apos;,&apos;&apos;] — violates r6</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "first-5-paying-customers-checklist-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "icp": "<icp>",
  "price_usd_month": 1,
  "channels": [],
  "weekly_quota": {},
  "paid_customers": 1,
  "status": "active",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "icp": "<icp>",
  "price_usd_month": 1,
  "channels": [],
  "weekly_quota": {},
  "paid_customers": 1,
  "status": "active",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-first-5-paying-customers-checklist.py">Schema validator (stdlib only).</reference>
</text>
