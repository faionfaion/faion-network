<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Viral Loop Optimization Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the playbook-step artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/viral-optimization.json",
  "type": "object",
  "required": [
    "test_id",
    "leg_tested",
    "variant",
    "k_lift_raw",
    "k_lift_effective",
    "cycles_run",
    "ship_decision",
    "owner",
    "produced_at"
  ],
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "test_id": "invite-landing-v3",
  "leg_tested": "c",
  "variant": "single-cta-headline",
  "k_lift_raw": 0.08,
  "k_lift_effective": 0.06,
  "cycles_run": 3,
  "ship_decision": "ship",
  "owner": {
    "name": "Olha Riznyk",
    "role": "head of growth"
  },
  "produced_at": "2026-05-23T13:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "test_id": "x",
  "leg_tested": "both",
  "ship_decision": "maybe"
}
]]></code>
    <note>Required fields missing or values out of allowed range. Validator rejects.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value &apos;when needed&apos; or &apos;ad-hoc&apos;.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. &apos;@team&apos;, &apos;#oncall&apos;).</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence / inputs array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-viral-optimization.py">Validator script</reference>
</text>
