<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Retention Strategies Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from 01-core-rules.xml. Use when in doubt about which variant to apply.</summary>

  <decision-tree>
    <root-question id="q-preconditions">Do all Applies-If preconditions hold and no Skip-If trigger fires?</root-question>

    <branch when="preconditions == false">
      <conclusion ref="skip-this-methodology" verdict="do not run this methodology; document skip rationale"/>
    </branch>

    <branch when="preconditions == true">
      <question id="q-readiness">Are all readiness gates green?</question>
      <branch when="baseline_measured == false">
        <conclusion ref="skip-this-methodology" verdict="first run retention-metrics"/>
      </branch>
      <branch when="primary_loop_singular == false">
        <conclusion ref="one-loop-not-four" verdict="pick one primary; secondary optional"/>
      </branch>
      <branch when="loop_matches_product == false">
        <conclusion ref="match-loop-to-product-nature" verdict="switch to archetype matching product&apos;s natural use"/>
      </branch>
      <branch when="mechanic_ab_tested == false">
        <conclusion ref="mechanic-tested-before-rollout" verdict="A/B test 4-6 weeks before global rollout"/>
      </branch>
      <branch when="reengagement_within_90 == false">
        <conclusion ref="re-engagement-window-30-90" verdict="cap at 30/60/90 days; &gt; 90 → net-new"/>
      </branch>
      <branch when="variable_ratio == false">
        <conclusion ref="variable-reward-not-fixed" verdict="switch reward schedule to variable-ratio"/>
      </branch>
      <branch when="all_checks_pass == true">
        <conclusion ref="variable-reward-not-fixed" verdict="ship strategy + run monthly retention review"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="happy-path">preconditions=true → readiness gates evaluated → all_checks_pass==true → conclusion ref=variable-reward-not-fixed</example>
</text>
