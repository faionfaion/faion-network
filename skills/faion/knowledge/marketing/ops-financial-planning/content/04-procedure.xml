<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Financial Planning Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Financial Planning end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="snapshot-cash-and-burn">
      <input>Bank + billing export</input>
      <action>Compute cash + monthly burn + runway.</action>
      <output>Snapshot.</output>
    </step>

    <step n="2" name="project-3m-detailed">
      <input>Pipeline + commitments</input>
      <action>Line-item projection by week for next 13 weeks.</action>
      <output>projection_3m.</output>
    </step>

    <step n="3" name="project-12m-directional">
      <input>Trend + assumptions</input>
      <action>Monthly projection for next 12 months.</action>
      <output>projection_12m.</output>
    </step>

    <step n="4" name="set-splits">
      <input>Profit First model</input>
      <action>Declare reserve / reinvest / founder-pay %.</action>
      <output>Splits.</output>
    </step>

    <step n="5" name="schedule-monthly-reconciliation">
      <input>Cadence</input>
      <action>Set next_review = today + 30 days.</action>
      <output>next_review.</output>
    </step>

  </section>
</text>
