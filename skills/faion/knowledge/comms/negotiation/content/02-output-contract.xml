<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Negotiation and Persuasion Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/negotiation.json",
  "type": "object",
  "required": [
    "my_batna",
    "my_reserve",
    "their_reserve_estimate",
    "interests",
    "objective_criteria",
    "cialdini_levers"
  ],
  "properties": {
    "my_batna": {
      "type": "object",
      "required": [
        "name",
        "value"
      ]
    },
    "my_reserve": {
      "type": "number"
    },
    "their_reserve_estimate": {
      "type": "number"
    },
    "interests": {
      "type": "object",
      "required": [
        "mine",
        "theirs"
      ],
      "properties": {
        "mine": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        },
        "theirs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2
        }
      }
    },
    "objective_criteria": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "cialdini_levers": {
      "type": "array",
      "items": {
        "enum": [
          "reciprocity",
          "commitment",
          "social-proof",
          "authority",
          "liking",
          "scarcity"
        ]
      },
      "minItems": 1
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "my_batna": {
    "name": "Continue with current vendor at 8K/mo",
    "value": 96000
  },
  "my_reserve": 110000,
  "their_reserve_estimate": 140000,
  "interests": {
    "mine": [
      "predictable cost",
      "fast onboarding",
      "EU data residency"
    ],
    "theirs": [
      "multi-year commitment",
      "case study right",
      "logo placement"
    ]
  },
  "objective_criteria": [
    {
      "term": "annual price",
      "benchmark": "G2 Compete avg 120K",
      "source": "G2 2025 report"
    }
  ],
  "cialdini_levers": [
    "reciprocity",
    "social-proof"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "my_batna": "walk away",
  "my_reserve": 0
}
]]></code>
    <note>BATNA must be a named alternative + value; missing interests, criteria, levers.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>my_batna as plain string 'walk away'.</item>
      <item>Empty interests on either side.</item>
      <item>objective_criteria without source.</item>
    </list>
  </section>

  <reference path="scripts/validate-negotiation.py">Validator script</reference>
</text>
