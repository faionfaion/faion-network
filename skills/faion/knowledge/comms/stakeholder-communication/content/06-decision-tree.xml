<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Stakeholder Communication Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-goal">session goal type?</root-question>

    <branch when="goal == requirements">
      <conclusion ref="interview-open-questions" verdict="Interview mode + open questions"/>
    </branch>

    <branch when="goal == option-generation">
      <conclusion ref="one-mode-per-session" verdict="Brainstorm mode + brainstorming-techniques"/>
    </branch>

    <branch when="goal == resolve-ambiguity">
      <conclusion ref="one-mode-per-session" verdict="Clarification mode + targeted questions"/>
    </branch>

    <branch when="goal == confirm-understanding">
      <conclusion ref="validation-write-back" verdict="Validation mode + write-back step"/>
    </branch>

    <branch when="goal == probe-assumptions">
      <conclusion ref="validation-not-socratic" verdict="Socratic mode — ensure NOT during Validation"/>
    </branch>
  </decision-tree>

  <example trace="data-dashboard-kickoff">
    goal=requirements → conclusion interview-open-questions → Interview mode + Power/Interest map.
  </example>
</text>
