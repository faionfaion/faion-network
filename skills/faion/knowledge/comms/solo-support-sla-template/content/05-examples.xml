<text id="05-examples" title="Solo Support SLA Template Worked Example" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Worked example: solo SaaS founder publishes 3-tier SLA with canned replies + escalation trigger.</summary>

  <section title="Scenario">
    <p>Founder of a $19/mo SaaS with ~200 users + 5 enterprise pilots sets a sustainable SLA.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "operator_timezone": "Europe/Lisbon"
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "tiers": [
    {
      "name": "community",
      "response_time_h": 72,
      "channels": [
        "email",
        "discord"
      ]
    },
    {
      "name": "paid",
      "response_time_h": 24,
      "channels": [
        "email",
        "in-app"
      ]
    },
    {
      "name": "enterprise",
      "response_time_h": 4,
      "channels": [
        "email",
        "in-app",
        "slack"
      ]
    }
  ],
  "business_hours": {
    "timezone": "Europe/Lisbon",
    "days": [
      "Mon",
      "Tue",
      "Wed",
      "Thu",
      "Fri"
    ],
    "start": "09:00",
    "end": "18:00"
  }
}
]]></code>
  </section>

  <section title="Validator">
    <code lang="text"><![CDATA[
$ python scripts/validate-solo-support-sla-template.py --file output.json
OK
]]></code>
  </section>
</text>
