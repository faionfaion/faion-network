<text id="06-decision-tree" title="Business Storytelling (Pyramid / SCQA / Pixar) Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-goal">narrative goal?</root-question>

    <branch when="goal == decision">
      <conclusion ref="answer-first" verdict="Pyramid + lead with the recommendation"/>
    </branch>

    <branch when="goal == tension">
      <conclusion ref="scqa-tension-explicit" verdict="SCQA + explicit Complication"/>
    </branch>

    <branch when="goal == outcome-story">
      <conclusion ref="pixar-causal-chain" verdict="Pixar 6-block causal chain"/>
    </branch>
  </decision-tree>

  <example trace="acme-case-study">
    goal=outcome-story → conclusion pixar-causal-chain → Pixar 6-block arc.
  </example>
</text>
