<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Solo Testimonial Extraction Script Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-nps">customer NPS &gt;= 7?</root-question>

    <branch when="nps_lt_7 == true">
      <conclusion ref="three-question-structure" verdict="skip-this-methodology — NPS too low; honest testimonial impossible"/>
    </branch>

    <branch when="nps_lt_7 == false">
      <question id="q-recency">milestone age &lt;= 90 days?</question>
      <branch when="recent == false">
        <conclusion ref="three-question-structure" verdict="skip-this-methodology — memory decay; testimonial vague"/>
      </branch>
      <branch when="recent == true">
        <question id="q-consent">explicit consent confirmed?</question>
        <branch when="consent_confirmed == false">
          <conclusion ref="explicit-consent" verdict="halt publication; request consent first"/>
        </branch>
        <branch when="consent_confirmed == true">
          <conclusion ref="anti-recommendation-required" verdict="emit Testimonial JSON; queue for case study"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="shopgrow-testimonial">
    nps_lt_7=false → recent=true (7d) → consent_confirmed=true → conclusion anti-recommendation-required → Testimonial JSON emitted.
  </example>
</text>
