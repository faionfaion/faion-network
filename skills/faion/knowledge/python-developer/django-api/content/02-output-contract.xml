<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-api Output Contract" version="1.1.0" est_tokens="1100" depth="essential">
  <summary>JSON schema for the Django REST API spec.</summary>

  <output-contract>
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artefact_id", "owner", "framework", "django_version", "endpoints", "auth", "throttle", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string"},
    "framework": {"type": "string", "enum": ["drf", "ninja"]},
    "django_version": {"type": "string"},
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["resource", "kind", "methods", "input_serializer", "output_serializer", "permission_classes"],
        "properties": {
          "resource": {"type": "string"},
          "kind": {"type": "string", "enum": ["model-viewset", "apiview", "ninja-router-crud", "ninja-router-action"]},
          "methods": {"type": "array", "items": {"type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]}},
          "input_serializer": {"type": "string"},
          "output_serializer": {"type": "string"},
          "permission_classes": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "throttle_scope": {"type": "string"},
          "pagination": {"type": "string", "enum": ["cursor", "page-number", "none"]}
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["mode", "access_ttl_minutes", "refresh_ttl_days", "rotate_refresh", "blacklist_after_rotation"],
      "properties": {
        "mode": {"type": "string", "enum": ["jwt-simplejwt", "ninja-jwt", "session", "api-key"]},
        "access_ttl_minutes": {"type": "integer", "minimum": 1, "maximum": 60},
        "refresh_ttl_days": {"type": "integer", "minimum": 1, "maximum": 30},
        "rotate_refresh": {"const": true},
        "blacklist_after_rotation": {"const": true},
        "transport": {"type": "string", "enum": ["httponly-cookie", "authorization-header"]}
      }
    },
    "throttle": {
      "type": "object",
      "required": ["scopes"],
      "properties": {
        "scopes": {"type": "array", "minItems": 3, "items": {"type": "string"}}
      }
    },
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></schema>

    <forbidden>
      <pattern id="f1">an endpoint with input_serializer == output_serializer</pattern>
      <pattern id="f2">any serializer name ending in "__all__" or any spec note declaring fields = "__all__"</pattern>
      <pattern id="f3">permission_classes containing "AllowAny" without an explicit public_endpoint=true note</pattern>
      <pattern id="f4">auth.access_ttl_minutes &gt; 15 OR rotate_refresh==false OR blacklist_after_rotation==false</pattern>
      <pattern id="f5">throttle.scopes missing at least one of: anon, user, burst, login</pattern>
      <pattern id="f6">owner equals "team" or empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Sort endpoints alphabetically by resource.</transformation>
    </allowed-transformations>
  </output-contract>

  <example valid="true"><![CDATA[
{
  "artefact_id": "billing-api-spec",
  "owner": "ruslan@faion.net",
  "framework": "drf",
  "django_version": "5.2.1",
  "endpoints": [
    {
      "resource": "Invoice",
      "kind": "model-viewset",
      "methods": ["GET", "POST", "PATCH", "DELETE"],
      "input_serializer": "CreateInvoiceSerializer",
      "output_serializer": "InvoiceDetailSerializer",
      "permission_classes": ["IsAuthenticated", "IsOrganizationMember"],
      "throttle_scope": "user",
      "pagination": "cursor"
    }
  ],
  "auth": {
    "mode": "jwt-simplejwt",
    "access_ttl_minutes": 15,
    "refresh_ttl_days": 7,
    "rotate_refresh": true,
    "blacklist_after_rotation": true,
    "transport": "httponly-cookie"
  },
  "throttle": {"scopes": ["anon", "user", "burst", "login"]},
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

  <example valid="false"><![CDATA[
{
  "artefact_id": "bad",
  "owner": "team",
  "framework": "drf",
  "django_version": "5",
  "endpoints": [
    {"resource": "X", "kind": "apiview", "methods": ["GET"], "input_serializer": "XSerializer", "output_serializer": "XSerializer", "permission_classes": ["AllowAny"]}
  ],
  "auth": {"mode": "jwt-simplejwt", "access_ttl_minutes": 60, "refresh_ttl_days": 30, "rotate_refresh": false, "blacklist_after_rotation": false},
  "throttle": {"scopes": ["user"]},
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>
</text>
