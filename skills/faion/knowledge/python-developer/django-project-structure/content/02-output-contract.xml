<text id="02-output-contract" title="django-project-structure Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON schema for the project structure spec.</summary>

  <output-contract>
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artefact_id", "owner", "project", "django_version", "apps", "core_modules", "config_modules", "test_root", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string"},
    "project": {"type": "string"},
    "django_version": {"type": "string"},
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "files"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "files": {"type": "array", "minItems": 6, "items": {"type": "string"}}
        }
      }
    },
    "core_modules": {"type": "array", "items": {"type": "string"}},
    "config_modules": {"type": "array", "minItems": 4, "items": {"type": "string"}},
    "test_root": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></schema>

    <forbidden>
      <pattern id="f1">an app.name not matching snake_case plural (e.g. PascalCase, singular)</pattern>
      <pattern id="f2">an app missing services.py OR selectors.py OR apis.py in files</pattern>
      <pattern id="f3">config_modules missing any of base.py, dev.py, prod.py, urls.py</pattern>
      <pattern id="f4">core_modules entry that references an apps/ submodule</pattern>
      <pattern id="f5">owner equals "team" or empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Sort apps alphabetically by name.</transformation>
    </allowed-transformations>
  </output-contract>

  <example valid="true"><![CDATA[
{
  "artefact_id": "faion-net-be-layout",
  "owner": "ruslan@faion.net",
  "project": "faion-net-be",
  "django_version": "5.2.1",
  "apps": [
    {"name": "accounts", "files": ["models.py", "services.py", "selectors.py", "apis.py", "serializers.py", "urls.py", "constants.py", "admin.py", "tests/test_models.py", "tests/test_services.py", "tests/test_selectors.py", "tests/test_apis.py"]},
    {"name": "billing",  "files": ["models.py", "services.py", "selectors.py", "apis.py", "serializers.py", "urls.py", "constants.py", "admin.py", "tests/test_models.py", "tests/test_services.py", "tests/test_selectors.py", "tests/test_apis.py"]}
  ],
  "core_modules": ["base_models.py", "exceptions.py", "pagination.py", "permissions.py"],
  "config_modules": ["settings/base.py", "settings/dev.py", "settings/staging.py", "settings/prod.py", "urls.py", "celery.py", "wsgi.py", "asgi.py"],
  "test_root": "tests/",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

  <example valid="false"><![CDATA[
{
  "artefact_id": "bad",
  "owner": "team",
  "project": "x",
  "django_version": "5",
  "apps": [{"name": "Order", "files": ["models.py", "views.py", "serializers.py"]}],
  "core_modules": ["apps.users.helpers"],
  "config_modules": ["settings.py"],
  "test_root": "tests/",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>
</text>
