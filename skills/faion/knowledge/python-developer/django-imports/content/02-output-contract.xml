<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="django-imports Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON schema for the Django imports spec.</summary>

  <output-contract>
    <schema format="json-schema"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artefact_id", "owner", "django_version", "python_version", "apps", "policies", "ruff_config", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "owner": {"type": "string"},
    "django_version": {"type": "string"},
    "python_version": {"type": "string"},
    "apps": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "policies": {
      "type": "object",
      "required": ["section_order", "alias_convention", "fk_reference_style", "type_checking_policy", "wildcard_allowed"],
      "properties": {
        "section_order": {
          "type": "array",
          "minItems": 5,
          "items": {"type": "string", "enum": ["future", "stdlib", "third-party", "first-party", "local"]}
        },
        "alias_convention": {"type": "string"},
        "fk_reference_style": {"type": "string", "enum": ["string-only", "class-only", "string-for-cross-app"]},
        "type_checking_policy": {"type": "string", "enum": ["mandatory-for-cross-app-types", "optional", "forbidden"]},
        "wildcard_allowed": {"const": false},
        "multi_dot_relative_allowed": {"const": false}
      }
    },
    "ruff_config": {
      "type": "object",
      "required": ["known_first_party", "section_order"],
      "properties": {
        "known_first_party": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "section_order": {"type": "array", "items": {"type": "string"}}
      }
    },
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></schema>

    <forbidden>
      <pattern id="f1">policies.wildcard_allowed != false</pattern>
      <pattern id="f2">policies.multi_dot_relative_allowed != false</pattern>
      <pattern id="f3">policies.section_order missing "first-party"</pattern>
      <pattern id="f4">fk_reference_style == "class-only" (always forbidden in multi-app)</pattern>
      <pattern id="f5">owner equals "team" or empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Sort apps alphabetically.</transformation>
    </allowed-transformations>
  </output-contract>

  <example valid="true"><![CDATA[
{
  "artefact_id": "faion-net-be-imports",
  "owner": "ruslan@faion.net",
  "django_version": "5.2.1",
  "python_version": "3.12",
  "apps": ["accounts", "billing", "content", "core"],
  "policies": {
    "section_order": ["future", "stdlib", "third-party", "first-party", "local"],
    "alias_convention": "from apps.<app> import models as <app>_models",
    "fk_reference_style": "string-for-cross-app",
    "type_checking_policy": "mandatory-for-cross-app-types",
    "wildcard_allowed": false,
    "multi_dot_relative_allowed": false
  },
  "ruff_config": {
    "known_first_party": ["apps"],
    "section_order": ["future", "standard-library", "third-party", "first-party", "local-folder"]
  },
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>

  <example valid="false"><![CDATA[
{
  "artefact_id": "bad",
  "owner": "team",
  "django_version": "5",
  "python_version": "3.12",
  "apps": ["a"],
  "policies": {"section_order": ["stdlib"], "alias_convention": "anything", "fk_reference_style": "class-only", "type_checking_policy": "forbidden", "wildcard_allowed": true},
  "ruff_config": {"known_first_party": [], "section_order": []},
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></example>
</text>
