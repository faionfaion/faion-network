<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Freelancer Discovery Call Template Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-section-coverage">all 5 sections covered?</root-question>

    <branch when="coverage_complete == false">
      <conclusion ref="five-section-coverage" verdict="extend call or schedule follow-up; cannot proposal without full coverage"/>
    </branch>

    <branch when="coverage_complete == true">
      <question id="q-talk-share">operator_word_share &lt;= 0.30?</question>
      <branch when="talk_share_ok == false">
        <conclusion ref="listen-70-30" verdict="invalidate call; reschedule with stricter listening"/>
      </branch>
      <branch when="talk_share_ok == true">
        <question id="q-score">scorecard.total &gt;= 12?</question>
        <branch when="score_pass == false">
          <conclusion ref="go-no-go-scorecard" verdict="no-go; polite decline with referral"/>
        </branch>
        <branch when="score_pass == true">
          <conclusion ref="proposal-seed-one-page" verdict="send 1-page proposal within 24h"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="brewlab-discovery">
    coverage_complete=true → talk_share_ok=true (0.22) → score_pass=true (20) → conclusion proposal-seed-one-page → send €4.5K proposal.
  </example>
</text>
