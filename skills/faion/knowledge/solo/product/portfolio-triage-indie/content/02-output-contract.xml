<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Portfolio Triage Indie Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Portfolio Triage Indie output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="iteration_id" type="string" required="true">yyyy-ww or yyyy-mm identifier</field>
      <field name="operator" type="string" required="true">named owner</field>
      <field name="rows" type="array" required="true">per-product rows (name, mode, mrr, traffic, verdict, evidence_link, next_action)</field>
      <field name="outcome_review" type="string" required="true">reference to prior iteration's actions</field>
      <field name="knowledge_space_url" type="string" required="true">where report lives</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">any row missing evidence_link</pattern>
      <pattern id="f2">owner in collapsed plural set</pattern>
      <pattern id="f3">outcome_review empty when iteration_id &gt; 1</pattern>
      <pattern id="f4">next_action == 'monitor'</pattern>
      <pattern id="f5">rows array empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to merge two rows for the same product across mode-transitions with logged note.</transformation>
      <transformation>Allowed to skip outcome_review on iteration 1 only.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/portfolio-triage-indie.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "iteration_id": "sample-iteration_id",
  "operator": "ruslan@faion.net",
  "rows": [
    {
      "k": "v"
    }
  ],
  "outcome_review": "sample-outcome_review",
  "knowledge_space_url": "sample-knowledge_space_url",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/portfolio-triage-indie.json</item>
    </list>
  </section>
</text>
