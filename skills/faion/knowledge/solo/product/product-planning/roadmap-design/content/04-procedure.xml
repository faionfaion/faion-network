<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Roadmap Design Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Roadmap Design end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="assess-uncertainty">
      <input>Horizon + scope</input>
      <action>Score uncertainty low/medium/high.</action>
      <output>Uncertainty label</output>
    </step>

    <step n="2" name="pick-format">
      <input>Uncertainty + audience mix</input>
      <action>Map to format per r1.</action>
      <output>Format chosen</output>
    </step>

    <step n="3" name="draft-internal">
      <input>Format + OKRs</input>
      <action>Author internal source-of-truth roadmap.</action>
      <output>Internal roadmap</output>
    </step>

    <step n="4" name="emit-external">
      <input>Internal roadmap</input>
      <action>Strip metric targets; render external derivative.</action>
      <output>External roadmap</output>
    </step>

    <step n="5" name="schedule-review">
      <input>Both artefacts</input>
      <action>Set monthly internal review + quarterly external publish.</action>
      <output>Cadence locked</output>
    </step>

  </section>
</text>
