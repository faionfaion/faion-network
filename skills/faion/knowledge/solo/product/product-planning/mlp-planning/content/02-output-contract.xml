<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MLP Planning Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mlp-planning.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "wow_moment",
    "critical_path_steps",
    "polish_budget_days",
    "non_polish_scope",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "wow_moment": { "type": "string" },
    "critical_path_steps": { "type": "array" },
    "polish_budget_days": { "type": "number" },
    "non_polish_scope": { "type": "array" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-one-wow</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "mlp-planning-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "wow_moment": "wow_moment value",
  "critical_path_steps": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "polish_budget_days": 1.0,
  "non_polish_scope": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-mlp-planning.py">Schema validator (stdlib only).</reference>
</text>
