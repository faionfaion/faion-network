<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="OKR Setting Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply OKR Setting end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="draft-objectives">
      <input>Strategy doc</input>
      <action>List 5-7 candidate objectives; cut to ≤3.</action>
      <output>Objective draft</output>
    </step>
    <step n="2" name="write-krs">
      <input>Objective draft + analytics</input>
      <action>Per objective, 3 KRs (≥2 leading).</action>
      <output>KR set</output>
    </step>
    <step n="3" name="confidence">
      <input>KR set</input>
      <action>Tag each KR with confidence band.</action>
      <output>OKR doc</output>
    </step>
    <step n="4" name="schedule-checkin">
      <input>OKR doc</input>
      <action>Block weekly slot; first check-in scheduled.</action>
      <output>Cadence in calendar</output>
    </step>

  </section>
</text>
