<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="MVP Scoping Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mvp-scoping.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "riskiest_assumption",
    "minimum_journey",
    "scope_in",
    "scope_out",
    "kill_threshold",
    "ship_date",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "riskiest_assumption": { "type": "string" },
    "minimum_journey": { "type": "array" },
    "scope_in": { "type": "array" },
    "scope_out": { "type": "array" },
    "kill_threshold": { "type": "string" },
    "ship_date": { "type": "string", "format": "date" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-name-the-risk</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "mvp-scoping-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "riskiest_assumption": "riskiest_assumption value",
  "minimum_journey": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "scope_in": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "scope_out": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "kill_threshold": "kill_threshold value",
  "ship_date": "2026-05-23",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-mvp-scoping.py">Schema validator (stdlib only).</reference>
</text>
