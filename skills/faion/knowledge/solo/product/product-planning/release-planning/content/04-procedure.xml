<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Release Planning Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Release Planning end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="set-goal">
      <input>Release scope</input>
      <action>State one-sentence release goal.</action>
      <output>Release goal</output>
    </step>

    <step n="2" name="freeze-contents">
      <input>Release goal + backlog</input>
      <action>Freeze ticket list against the goal.</action>
      <output>Frozen scope</output>
    </step>

    <step n="3" name="readiness-check">
      <input>Frozen scope</input>
      <action>Run readiness checklist; close gaps.</action>
      <output>Readiness green</output>
    </step>

    <step n="4" name="plan-comms">
      <input>Readiness + audience map</input>
      <action>Draft + schedule comms per channel.</action>
      <output>Comms plan</output>
    </step>

    <step n="5" name="execute">
      <input>Plan + runbook</input>
      <action>Ship + activate comms per timeline.</action>
      <output>Release shipped</output>
    </step>

    <step n="6" name="post-review">
      <input>14d telemetry</input>
      <action>Stability + metric review; close release.</action>
      <output>Release retro</output>
    </step>

  </section>
</text>
