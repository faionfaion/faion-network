<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Release Planning Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/release-planning.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "release_name",
    "goal",
    "scope",
    "readiness_checklist",
    "comms_plan",
    "rollback_runbook",
    "ship_date",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "release_name": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "scope": {
      "type": "array"
    },
    "readiness_checklist": {
      "type": "array"
    },
    "comms_plan": {
      "type": "array"
    },
    "rollback_runbook": {
      "type": "string"
    },
    "ship_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "release-planning-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "release_name": "release_name value",
  "goal": "goal value",
  "scope": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "readiness_checklist": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "comms_plan": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "rollback_runbook": "rollback_runbook value",
  "ship_date": "2026-05-23",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-release-planning.py">Schema validator (stdlib only).</reference>
</text>
