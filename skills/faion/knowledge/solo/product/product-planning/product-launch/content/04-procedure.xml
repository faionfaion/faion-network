<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Product Launch Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Product Launch end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="position">
      <input>Segment + product</input>
      <action>Author 1-page positioning (segment, alternative, value).</action>
      <output>Positioning doc</output>
    </step>

    <step n="2" name="plan-channels">
      <input>Positioning + budget</input>
      <action>Map channels (owned/earned/paid) + cadence.</action>
      <output>Channel plan</output>
    </step>

    <step n="3" name="create-assets">
      <input>Channel plan</input>
      <action>Produce landing, email, social, demo, press kit.</action>
      <output>Asset bundle</output>
    </step>

    <step n="4" name="dry-run">
      <input>Asset bundle + runbook</input>
      <action>Walk through day-of timeline with owners.</action>
      <output>Validated runbook</output>
    </step>

    <step n="5" name="execute">
      <input>Runbook</input>
      <action>Ship + activate channels per timeline.</action>
      <output>Launch executed</output>
    </step>

    <step n="6" name="retro">
      <input>Metric data (30d)</input>
      <action>Retro vs success metric; verdict.</action>
      <output>Launch retro report</output>
    </step>

  </section>
</text>
