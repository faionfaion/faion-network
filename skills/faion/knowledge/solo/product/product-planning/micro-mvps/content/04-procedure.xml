<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Micro-MVPs Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Micro-MVPs end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="scope">
      <input>Discovery output + rubric</input>
      <action>Apply cut rubric; final scope ≤5d.</action>
      <output>Locked scope</output>
    </step>
    <step n="2" name="thresholds">
      <input>Locked scope</input>
      <action>Write kill + success thresholds.</action>
      <output>Threshold spec</output>
    </step>
    <step n="3" name="ship">
      <input>Threshold spec</input>
      <action>Build, ship to segment, monitor.</action>
      <output>Live Micro-MVP</output>
    </step>
    <step n="4" name="decide">
      <input>Threshold metrics</input>
      <action>Hit success → continue / scale; hit kill → archive.</action>
      <output>Decision record</output>
    </step>

  </section>
</text>
