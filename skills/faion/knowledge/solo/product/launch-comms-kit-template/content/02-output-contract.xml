<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Launch Comms Kit Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Launch Comms Kit Template output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="launch_name" type="string" required="true">named launch</field>
      <field name="positioning_sentence" type="string" required="true">≤140 chars canonical sentence</field>
      <field name="launch_window" type="object" required="true">ISO start/end</field>
      <field name="channels" type="object" required="true">per-channel draft objects (PH/HN/X/mail/changelog)</field>
      <field name="publish_timeline" type="array" required="true">per-channel publish_at ISO datetimes</field>
      <field name="retro_at" type="string" required="true">ISO datetime for T+7 retro</field>
      <field name="owner" type="string" required="true">named human owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">positioning_sentence empty OR &gt; 140 chars</pattern>
      <pattern id="f2">channels object missing ≥1 required channel</pattern>
      <pattern id="f3">publish_timeline empty</pattern>
      <pattern id="f4">retro_at empty or non-ISO</pattern>
      <pattern id="f5">channel-piece positioning_sentence overlap &lt; 80% with canonical</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to swap one channel (e.g. swap HN for IndieHackers) with logged rationale; the swap is recorded in version log.</transformation>
      <transformation>Allowed to extend launch window by 24h once with rationale; second extension forbidden.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/launch-comms-kit-template.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "launch_name": "sample-launch_name",
  "positioning_sentence": "sample-positioning_sentence",
  "launch_window": {
    "k": "v"
  },
  "channels": {
    "k": "v"
  },
  "publish_timeline": [
    {
      "k": "v"
    }
  ],
  "retro_at": "sample-retro_at",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/launch-comms-kit-template.json</item>
    </list>
  </section>
</text>
