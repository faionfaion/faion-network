<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Roadmap Drift Detection Checklist Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/roadmap-drift-detection-checklist.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "review_period",
    "tagged_ratio",
    "orphan_tickets",
    "decayed_candidates",
    "actions",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "review_period": {
      "type": "string"
    },
    "tagged_ratio": {
      "type": "number"
    },
    "orphan_tickets": {
      "type": "array"
    },
    "decayed_candidates": {
      "type": "array"
    },
    "actions": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "roadmap-drift-detection-checklist-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "review_period": "review_period value",
  "tagged_ratio": 1.0,
  "orphan_tickets": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "decayed_candidates": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "actions": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-roadmap-drift-detection-checklist.py">Schema validator (stdlib only).</reference>
</text>
