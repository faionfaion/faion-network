{
  "__faion_header__": {
    "purpose": "JSON Schema for the Maintain Mode SOPs Solo output contract",
    "consumes": "subagent-produced artefact JSON",
    "produces": "validation verdict (pass/fail with violations)",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "~300 tokens"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.network/schema/maintain-mode-sops-solo.json",
  "title": "Maintain Mode SOPs Solo Output Contract",
  "type": "object",
  "required": [
    "product_name",
    "weekly_check",
    "monthly_reconcile",
    "quarterly_upgrade",
    "on_call_rule",
    "sunset_trigger",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "product_name": {
      "type": "string",
      "description": "named product"
    },
    "weekly_check": {
      "type": "object",
      "description": "tasks + duration"
    },
    "monthly_reconcile": {
      "type": "object",
      "description": "tasks + duration"
    },
    "quarterly_upgrade": {
      "type": "object",
      "description": "tasks + duration"
    },
    "on_call_rule": {
      "type": "object",
      "description": "trigger + max_response_window_hours"
    },
    "sunset_trigger": {
      "type": "string",
      "description": "MRR / churn condition"
    },
    "owner": {
      "type": "string",
      "description": "named human owner"
    },
    "version": {
      "type": "string",
      "description": "semver"
    },
    "last_reviewed": {
      "type": "string",
      "description": "ISO date",
      "format": "date"
    }
  },
  "additionalProperties": true
}
