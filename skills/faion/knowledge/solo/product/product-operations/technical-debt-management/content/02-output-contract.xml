<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Technical Debt Management Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/technical-debt-management.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "register",
    "debt_budget_pct",
    "interest_rate_rubric",
    "sprint_review_cadence",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "register": { "type": "array" },
    "debt_budget_pct": { "type": "number" },
    "interest_rate_rubric": { "type": "object" },
    "sprint_review_cadence": { "type": "string" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-debt-register</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "technical-debt-management-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "register": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "debt_budget_pct": 1.0,
  "interest_rate_rubric": {
    "key": "value"
  },
  "sprint_review_cadence": "sprint_review_cadence value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-technical-debt-management.py">Schema validator (stdlib only).</reference>
</text>
