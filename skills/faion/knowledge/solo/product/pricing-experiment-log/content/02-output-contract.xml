<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pricing Experiment Log — Output Contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>An append-only ledger with a fixed column schema, named cadence review, and explicit retention policy.</summary>

  <section title="Required fields">
    <list>
      <item>entry.id (monotonic)</item>
      <item>entry.ts (ISO)</item>
      <item>entry.owner</item>
      <item>entry.hypothesis_or_event</item>
      <item>entry.evidence_link</item>
      <item>entry.outcome (or `pending`)</item>
      <item>entry.next (next action or `none`)</item>
    </list>
  </section>

  <section title="Forbidden patterns">
    <antipattern>
      <description>edits in place</description>
      <reason>Loses decision trail.</reason>
    </antipattern>
    <antipattern>
      <description>rows without evidence_link</description>
      <reason>Opinion-capture; not learning.</reason>
    </antipattern>
    <antipattern>
      <description>ledger without scheduled review</description>
      <reason>Write-only logs decay.</reason>
    </antipattern>
    <antipattern>
      <description>deletion before retention horizon</description>
      <reason>Destroys institutional memory.</reason>
    </antipattern>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Schema fixed; all entries match.</item>
      <item>Append-only enforced (corrections add rows).</item>
      <item>Each entry has an evidence link.</item>
      <item>Review cadence published and run.</item>
      <item>Retention policy + archival path documented.</item>
    </list>
  </section>
</text>
