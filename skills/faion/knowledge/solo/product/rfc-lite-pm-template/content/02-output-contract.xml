<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rfc Lite Pm Template Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rfc-lite-pm-template.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "problem",
    "evidence",
    "scope_in",
    "scope_out",
    "open_questions",
    "outcome_id",
    "owner",
    "reviewer",
    "review_date"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "problem": {
      "type": "string"
    },
    "evidence": {
      "type": "array"
    },
    "scope_in": {
      "type": "array"
    },
    "scope_out": {
      "type": "array"
    },
    "open_questions": {
      "type": "array"
    },
    "outcome_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "review_date": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "rfc-lite-pm-template-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "problem": "problem value",
  "evidence": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "scope_in": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "scope_out": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "open_questions": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "outcome_id": "outcome_id value",
  "owner": "@solo-founder",
  "reviewer": "@reviewer",
  "review_date": "2026-05-23"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-rfc-lite-pm-template.py">Schema validator (stdlib only).</reference>
</text>
