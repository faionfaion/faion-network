<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="30 Day Post Launch Review Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid 30 Day Post Launch Review Template output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="launch_id" type="string" required="true">named launch</field>
      <field name="launch_comms_kit_id" type="string" required="true">upstream artefact id</field>
      <field name="review_at" type="string" required="true">ISO date (T+30)</field>
      <field name="funnel_by_channel" type="object" required="true">per-channel acquire/activate/retain/revenue counts</field>
      <field name="hypothesis_verdicts" type="array" required="true">≥1 verdict object (hypothesis_id, verdict, evidence)</field>
      <field name="next_bets" type="array" required="true">≥3 ranked bets with budget_usd + budget_hours</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">funnel_by_channel empty</pattern>
      <pattern id="f2">any hypothesis_verdicts entry missing verdict</pattern>
      <pattern id="f3">next_bets count &lt; 3</pattern>
      <pattern id="f4">any next_bet missing budget_usd or budget_hours</pattern>
      <pattern id="f5">launch_comms_kit_id empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to mark a hypothesis 'inconclusive' with logged reason (e.g. window too short).</transformation>
      <transformation>Allowed to bundle two near-duplicate next-bets with logged merge note.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/30-day-post-launch-review-template.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "launch_id": "sample-launch_id",
  "launch_comms_kit_id": "sample-launch_comms_kit_id",
  "review_at": "sample-review_at",
  "funnel_by_channel": {
    "k": "v"
  },
  "hypothesis_verdicts": [
    {
      "k": "v"
    }
  ],
  "next_bets": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/30-day-post-launch-review-template.json</item>
    </list>
  </section>
</text>
