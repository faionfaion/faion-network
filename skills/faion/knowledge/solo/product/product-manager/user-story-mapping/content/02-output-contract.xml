<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="User Story Mapping Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/user-story-mapping.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "persona",
    "backbone",
    "walking_skeleton",
    "release_slices",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "persona": { "type": "string" },
    "backbone": { "type": "array" },
    "walking_skeleton": { "type": "array" },
    "release_slices": { "type": "array" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-backbone-first</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "user-story-mapping-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "persona": "persona value",
  "backbone": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "walking_skeleton": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "release_slices": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-user-story-mapping.py">Schema validator (stdlib only).</reference>
</text>
