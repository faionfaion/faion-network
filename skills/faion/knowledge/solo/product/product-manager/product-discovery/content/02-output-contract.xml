<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Discovery Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/product-discovery.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "cycle_id",
    "risks",
    "experiments",
    "decision",
    "kill_threshold",
    "owner"
  ],
  "properties": {
    "artefact_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "last_reviewed": { "type": "string", "format": "date" },
    "cycle_id": { "type": "string" },
    "risks": { "type": "array" },
    "experiments": { "type": "array" },
    "decision": { "type": "string", "enum": ["proceed", "pivot", "kill", "more-discovery"] },
    "kill_threshold": { "type": "string" },
    "owner": { "type": "string" }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
            <pattern id="f1">missing any required field — violates r1-four-risk-types</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "product-discovery-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "cycle_id": "cycle_id value",
  "risks": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "experiments": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "decision": "proceed",
  "kill_threshold": "kill_threshold value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-product-discovery.py">Schema validator (stdlib only).</reference>
</text>
