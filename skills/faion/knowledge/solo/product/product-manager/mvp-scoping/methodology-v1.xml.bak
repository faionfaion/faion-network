<methodology slug="mvp-scoping">
  <metadata>
    <tier>solo</tier>
    <group>product</group>
    <domain>product-manager</domain>
    <summary>Six-step process to compress a feature backlog into MVP: define problem, identify core value, apply MoSCoW categorization, validate fit, and lock kill signals to prevent unfalsifiable experiments.</summary>
    <category>scoping</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-29</created>
    <tags>
      <tag>mvp</tag>
      <tag>scoping</tag>
      <tag>moscow</tag>
      <tag>product-management</tag>
