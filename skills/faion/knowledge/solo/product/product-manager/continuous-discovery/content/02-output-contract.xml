<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Continuous Discovery Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Continuous Discovery output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="outcome" type="string" required="true">named outcome / KPI</field>
      <field name="touchpoints" type="array" required="true">≥1/week, each with date, customer_id, summary</field>
      <field name="opportunity_tree" type="object" required="true">outcome → opportunities → solutions</field>
      <field name="assumption_tests" type="array" required="true">≥1 per opportunity, each falsifiable</field>
      <field name="decision_log" type="array" required="true">≥1/week, each with rationale + cited touchpoint ids</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">touchpoints per week &lt; 1</pattern>
      <pattern id="f2">opportunity_tree depth &lt; 2</pattern>
      <pattern id="f3">any opportunity without assumption_test</pattern>
      <pattern id="f4">decision_log empty</pattern>
      <pattern id="f5">outcome empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to mark a touchpoint 'low-signal' with reason; counts toward cadence but flagged in audit.</transformation>
      <transformation>Allowed to retire an opportunity (with logged reason) — does not remove it, marks it inactive.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/continuous-discovery.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "outcome": "sample-outcome",
  "touchpoints": [
    {
      "k": "v"
    }
  ],
  "opportunity_tree": {
    "k": "v"
  },
  "assumption_tests": [
    {
      "k": "v"
    }
  ],
  "decision_log": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/continuous-discovery.json</item>
    </list>
  </section>
</text>
