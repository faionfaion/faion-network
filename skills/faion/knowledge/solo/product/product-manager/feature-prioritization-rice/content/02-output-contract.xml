<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Prioritization RICE Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Feature Prioritization RICE output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="scoring_round_id" type="string" required="true">round id (e.g. 2026-Q2)</field>
      <field name="reach_unit" type="string" required="true">named unit</field>
      <field name="effort_unit" type="string" required="true">named unit</field>
      <field name="impact_anchors" type="array" required="true">3 cited examples</field>
      <field name="rows" type="array" required="true">feature objects with reach, impact, confidence, effort, source, rice_score</field>
      <field name="cut_line" type="number" required="true">score threshold</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">any row missing source citation</pattern>
      <pattern id="f2">reach_unit empty</pattern>
      <pattern id="f3">effort_unit mixed across rows</pattern>
      <pattern id="f4">impact_anchors count != 3</pattern>
      <pattern id="f5">cut_line empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to normalise Confidence by source quality (analytics &gt; interview &gt; guess) with logged transform.</transformation>
      <transformation>Allowed to re-score post-experiment with same row id; old score kept in version log.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/feature-prioritization-rice.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "scoring_round_id": "sample-scoring_round_id",
  "reach_unit": "sample-reach_unit",
  "effort_unit": "sample-effort_unit",
  "impact_anchors": [
    {
      "k": "v"
    }
  ],
  "rows": [
    {
      "k": "v"
    }
  ],
  "cut_line": 1,
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/feature-prioritization-rice.json</item>
    </list>
  </section>
</text>
