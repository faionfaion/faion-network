<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Sunset Failed Product Playbook Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/sunset-failed-product-playbook.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "product_name",
    "sunset_date",
    "customer_count",
    "refund_total",
    "migration_targets",
    "retro_url",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "product_name": {
      "type": "string"
    },
    "sunset_date": {
      "type": "string",
      "format": "date"
    },
    "customer_count": {
      "type": "integer"
    },
    "refund_total": {
      "type": "number"
    },
    "migration_targets": {
      "type": "array"
    },
    "retro_url": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">missing any required field — violates the contract</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null</pattern>
      <pattern id="f3">version not semver MAJOR.MINOR.PATCH</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "sunset-failed-product-playbook-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "product_name": "product_name value",
  "sunset_date": "2026-05-23",
  "customer_count": 1,
  "refund_total": 1.0,
  "migration_targets": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "retro_url": "retro_url value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing AND semver violated.</note>
  </example>

  <reference path="scripts/validate-sunset-failed-product-playbook.py">Schema validator (stdlib only).</reference>
</text>
