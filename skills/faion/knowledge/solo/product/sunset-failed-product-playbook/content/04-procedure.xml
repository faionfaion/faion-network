<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Sunset Failed Product Playbook Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Sunset Failed Product Playbook end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="decide">
      <input>Verdict + threshold record</input>
      <action>Founder signs sunset decision.</action>
      <output>Sunset commit</output>
    </step>

    <step n="2" name="notify">
      <input>Customer list</input>
      <action>30-day notice email + in-app + status page.</action>
      <output>Notice sent</output>
    </step>

    <step n="3" name="migrate">
      <input>Customer list + alternatives</input>
      <action>Per-customer migration assistance.</action>
      <output>Migration log</output>
    </step>

    <step n="4" name="refund">
      <input>Subscription data</input>
      <action>Pro-rated refunds processed.</action>
      <output>Refund log</output>
    </step>

    <step n="5" name="archive">
      <input>Domain + assets</input>
      <action>Domain redirect or hold; code archived.</action>
      <output>Archive state</output>
    </step>

    <step n="6" name="retro">
      <input>Whole project</input>
      <action>Public retro post.</action>
      <output>Retro published</output>
    </step>

  </section>
</text>
