<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="PM 1:1 Template (Engineering / Design) Decision Tree" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from `01-core-rules.xml`. MANDATORY for every methodology — even flat ones — per F-066 DoD.</summary>

  <decision-tree>
    <root-question id="q-root">Eng/design teammate ≥4 weeks in engagement?</root-question>
    <branch when="engagement_weeks &gt;= 4 AND role_in [&apos;engineer&apos;,&apos;designer&apos;]">
      <question id="q-sub">Calendar slot + rolling notes doc exist?</question>
      <branch when="calendar_slot_blocked == true AND notes_doc_exists == true">
        <conclusion ref="r1-five-sections-fixed"/>
      </branch>
      <branch when="NOT (calendar_slot_blocked == true AND notes_doc_exists == true)">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="engagement_weeks &lt; 4 OR role_not_eng_or_design">
      <conclusion ref="skip-this-methodology"/>
    </branch>
  </decision-tree>

  <example trace="apply-path">
    All preconditions satisfied → conclusion r1-five-sections-fixed.
  </example>
</text>
