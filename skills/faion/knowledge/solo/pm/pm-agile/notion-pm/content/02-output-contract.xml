<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Notion PM Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/notion-pm.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "workspace_url",
    "tasks_db_id",
    "projects_db_id",
    "sprints_db_id",
    "property_count",
    "integrations",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "workspace_url": {
      "type": "string"
    },
    "tasks_db_id": {
      "type": "string"
    },
    "projects_db_id": {
      "type": "string"
    },
    "sprints_db_id": {
      "type": "string"
    },
    "property_count": {
      "type": "integer",
      "maximum": 20
    },
    "integrations": {
      "type": "object"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">property_count &gt; 20 — violates r3</pattern>
      <pattern id="f2">tasks_db_id empty OR sprints arranged as separate DBs — violates r1</pattern>
      <pattern id="f3">integrations.status_type != &apos;status&apos; — violates r4</pattern>
      <pattern id="f4">integrations missing &apos;pagination_enabled&apos; OR &apos;rate_limit_delay_ms&apos; — violates r5</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "notion-pm-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "workspace_url": "https://notion.so/faion",
  "tasks_db_id": "<tasks_db_id>",
  "projects_db_id": "<projects_db_id>",
  "sprints_db_id": "<sprints_db_id>",
  "property_count": 14,
  "integrations": {
    "status_type": "status",
    "pagination_enabled": true,
    "rate_limit_delay_ms": 350,
    "n8n_workflows": [
      "standup-digest",
      "sprint-closure"
    ]
  },
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "workspace_url": "",
  "tasks_db_id": "",
  "projects_db_id": "",
  "sprints_db_id": "",
  "property_count": 35,
  "integrations": {
    "status_type": "select"
  },
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-notion-pm.py">Schema validator (stdlib only).</reference>
</text>
