<text id="05-examples" title="Trello Kanban Worked Example" version="1.0.0" est_tokens="600" depth="essential">
  <summary>End-to-end worked example showing inputs → procedure → output for a typical instance of Trello Kanban.</summary>

  <example>
    <scenario>Solo founder + VA running customer ops on Trello. Board /b/ops with 5 columns, WIP Ready=8/InProgress=6/Review=5, labels bug/feat/ops/sales/onboarding/billing, Power-Ups calendar + github, Butler rule auto-archives Done after 30d.</scenario>
    <trace>r1-five-canonical-columns → r2-wip-limit-per-column → r3-label-budget → validated artefact</trace>
    <artefact>
      <code lang="json"><![CDATA[
{
  "artefact_id": "trello-kanban-ops-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "board_url": "https://trello.com/b/abc/ops",
  "columns": [
    "Backlog",
    "Ready",
    "In Progress",
    "Review",
    "Done"
  ],
  "wip_limits": {
    "Ready": 8,
    "In Progress": 6,
    "Review": 5
  },
  "labels": [
    "bug",
    "feat",
    "ops",
    "sales",
    "onboarding",
    "billing"
  ],
  "powerups": [
    "calendar",
    "github"
  ],
  "butler_rules": [
    {
      "name": "auto-archive-done-30d",
      "trigger": "card in Done >30d",
      "action": "archive"
    }
  ],
  "owner": "@ruslan"
}
]]></code>
    </artefact>
  </example>
</text>
