{
  "__faion_header__": {
    "purpose": "Skeleton artefact for the Trello Kanban methodology output",
    "consumes": "Inputs declared in AGENTS.md → Prerequisites",
    "produces": "spec",
    "depends-on": "content/01-core-rules.xml, content/02-output-contract.xml",
    "token-budget-impact": "low — single JSON file, ≤300 tokens"
  },
  "artefact_id": "trello-kanban-ops-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "board_url": "https://trello.com/b/abc/ops",
  "columns": [
    "Backlog",
    "Ready",
    "In Progress",
    "Review",
    "Done"
  ],
  "wip_limits": {
    "Ready": 8,
    "In Progress": 6,
    "Review": 5
  },
  "labels": [
    "bug",
    "feat",
    "ops",
    "sales",
    "onboarding",
    "billing"
  ],
  "powerups": [
    "calendar",
    "github"
  ],
  "butler_rules": [
    {
      "name": "auto-archive-done-30d",
      "trigger": "card in Done >30d",
      "action": "archive"
    }
  ],
  "owner": "@ruslan"
}
