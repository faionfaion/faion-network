<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Notion PM Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for notion-pm.</summary>

  <decision-tree>
    <root-question id="q-root">Is Notion the right home for tasks+docs, AND is the workspace configured to the canonical shape?</root-question>

    <branch when="needs_code_traceability == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — use GitHub Projects"/>
    </branch>
    <branch when="active_task_count &gt; 500">
      <conclusion ref="r5-archive-after-90-days" verdict="BLOCK — archive done items first"/>
    </branch>
    <branch when="property_count_per_db &gt; 20">
      <conclusion ref="r2-property-cap-20" verdict="BLOCK — trim properties"/>
    </branch>
    <branch when="uses_select_for_status == true">
      <conclusion ref="r3-status-not-select" verdict="BLOCK — migrate Select to Status"/>
    </branch>
    <branch when="formula_iterates_relation == true">
      <conclusion ref="r4-rollups-not-formulas" verdict="BLOCK — replace with Rollup"/>
    </branch>
    <branch when="rate_limit_per_sec &gt; 3">
      <conclusion ref="r6-rate-limit-3-per-sec" verdict="BLOCK — cap rate"/>
    </branch>
    <branch when="three_db_schema == false">
      <conclusion ref="r1-three-database-schema" verdict="BLOCK — establish 3 db schema"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — notion-pm config ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="notion-pm-happy-path">
    Solo team + tasks+docs need + no code traceability → first branch skipped → 3 db schema present → ≤20 props → Status used → no formula iteration → rate-limit 2.5 r/s → 312 active tasks → APPROVE.
  </example>
</text>
