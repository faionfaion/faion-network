<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Status Report Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for status-report-templates-by-audience.</summary>

  <decision-tree>
    <root-question id="q-root">Does the stakeholder set need ≥2 templates AND does the single-source rule hold?</root-question>

    <branch when="stakeholder_count == 1">
      <conclusion ref="skip-this-methodology" verdict="SKIP — single stakeholder, single template"/>
    </branch>
    <branch when="single_source_verified == false">
      <conclusion ref="r2-single-source-spreadsheet" verdict="BLOCK — generate from one source"/>
    </branch>
    <branch when="audience_template_mismatch == true">
      <conclusion ref="r1-audience-mapped-template" verdict="BLOCK — fix audience map"/>
    </branch>
    <branch when="ceo_line_count &gt; 5">
      <conclusion ref="r3-ceo-5-line-cap" verdict="BLOCK — compress CEO to 5 lines"/>
    </branch>
    <branch when="pmo_rag_position != first">
      <conclusion ref="r4-rag-before-prose" verdict="BLOCK — lead PMO with RAG table"/>
    </branch>
    <branch when="leadership_contains_raw_technical == true">
      <conclusion ref="r5-separate-technical-from-leadership" verdict="BLOCK — translate to business impact"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — deliver"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="status-report-templates-by-audience-happy-path">
    4 stakeholders + single source + 4 templates mapped + CEO 5 lines + PMO RAG-first + Leadership business-impact → APPROVE → deliver via email/Slack/portal.
  </example>
</text>
