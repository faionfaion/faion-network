<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="GitHub Projects Decision Tree" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from `01-core-rules.xml`. MANDATORY for every methodology — even flat ones — per F-066 DoD.</summary>

  <decision-tree>
    <root-question id="q-root">Code in ≥1 GitHub repo AND team size 1-10?</root-question>
    <branch when="github_repos &gt;= 1 AND team_size &gt;= 1 AND team_size &lt;= 10">
      <question id="q-sub">Outcome list defined AND admin access?</question>
      <branch when="outcome_list_defined == true AND admin_access == true">
        <conclusion ref="r1-one-project-per-outcome"/>
      </branch>
      <branch when="NOT (outcome_list_defined == true AND admin_access == true)">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="github_repos &lt; 1 OR team_size &gt; 10">
      <conclusion ref="skip-this-methodology"/>
    </branch>
  </decision-tree>

  <example trace="apply-path">
    All preconditions satisfied → conclusion r1-one-project-per-outcome.
  </example>
</text>
