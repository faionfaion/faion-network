<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="1:1 Question Bank by Tenure Decision Tree" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from `01-core-rules.xml`. MANDATORY for every methodology — even flat ones — per F-066 DoD.</summary>

  <decision-tree>
    <root-question id="q-root">Running 1:1s with ≥1 teammate AND ≥2 tenure brackets represented?</root-question>
    <branch when="teammates_with_1on1 &gt;= 1 AND tenure_brackets_count &gt;= 2">
      <question id="q-sub">1:1 template + tenure data both available?</question>
      <branch when="template_adopted == true AND tenure_data_present == true">
        <conclusion ref="r1-five-tenure-buckets"/>
      </branch>
      <branch when="NOT (template_adopted == true AND tenure_data_present == true)">
        <conclusion ref="skip-this-methodology"/>
      </branch>
    </branch>
    <branch when="teammates_with_1on1 &lt; 1 OR tenure_brackets_count &lt; 2">
      <conclusion ref="skip-this-methodology"/>
    </branch>
  </decision-tree>

  <example trace="apply-path">
    All preconditions satisfied → conclusion r1-five-tenure-buckets.
  </example>
</text>
