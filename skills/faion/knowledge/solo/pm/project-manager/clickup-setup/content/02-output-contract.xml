<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="ClickUp Setup Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/clickup-setup.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "workspace_url",
    "spaces",
    "statuses",
    "automations_count",
    "clickapps",
    "views_per_list",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "workspace_url": {
      "type": "string"
    },
    "spaces": {
      "type": "array",
      "maxItems": 3
    },
    "statuses": {
      "type": "array",
      "maxItems": 7
    },
    "automations_count": {
      "type": "integer",
      "maximum": 10
    },
    "clickapps": {
      "type": "array"
    },
    "views_per_list": {
      "type": "integer",
      "maximum": 5
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">spaces.length &gt; 3 — violates r1</pattern>
      <pattern id="f2">statuses.length &gt; 7 — violates r2</pattern>
      <pattern id="f3">automations_count &gt; 10 — violates r3</pattern>
      <pattern id="f4">clickapps includes ‘Mind Maps’ / ‘Whiteboards’ / other non-essentials without justification — violates r4</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "clickup-setup-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "workspace_url": "https://app.clickup.com/123",
  "spaces": [
    "eng",
    "ops",
    "sales"
  ],
  "statuses": [
    "backlog",
    "todo",
    "in-progress",
    "blocked",
    "review",
    "done",
    "cancelled"
  ],
  "automations_count": 7,
  "clickapps": [
    "time-tracking",
    "custom-fields",
    "dependencies",
    "sprints"
  ],
  "views_per_list": 4,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "workspace_url": "",
  "spaces": [
    "a",
    "b",
    "c",
    "d",
    "e",
    "f"
  ],
  "statuses": [
    "s1",
    "s2",
    "s3",
    "s4",
    "s5",
    "s6",
    "s7",
    "s8",
    "s9"
  ],
  "automations_count": 22,
  "clickapps": [
    "mind-maps",
    "whiteboards",
    "chat",
    "docs",
    "screen-recording"
  ],
  "views_per_list": 9,
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-clickup-setup.py">Schema validator (stdlib only).</reference>
</text>
