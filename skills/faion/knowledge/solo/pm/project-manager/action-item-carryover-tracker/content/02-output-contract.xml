<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Action Item Carryover Tracker Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/action-item-carryover-tracker.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "log_url",
    "stale_threshold",
    "weekly_report_day",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "log_url": {
      "type": "string"
    },
    "stale_threshold": {
      "type": "integer"
    },
    "weekly_report_day": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">stale_threshold != 3 — violates r3</pattern>
      <pattern id="f2">log_url empty — violates r1</pattern>
      <pattern id="f3">weekly_report_day missing — violates r4</pattern>
      <pattern id="f4">status enum missing &apos;archived&apos; — violates r5</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "action-item-tracker-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "log_url": "notion://workspace/action-items",
  "stale_threshold": 3,
  "weekly_report_day": "Friday",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "log_url": "",
  "stale_threshold": 0,
  "weekly_report_day": "",
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-action-item-carryover-tracker.py">Schema validator (stdlib only).</reference>
</text>
