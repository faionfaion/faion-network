<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Solo Launch Day Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for solo-launch-day-runbook.</summary>

  <decision-tree>
    <root-question id="q-root">Are ALL pre-flight gates green AND does the change-freeze hold?</root-question>

    <branch when="smoke_t_minus_2h_status == fail OR smoke_t_minus_2h_at == null">
      <conclusion ref="r1-pre-checked-smoke-tests" verdict="BLOCK — rerun smoke test before announce"/>
    </branch>
    <branch when="product_is_paid == true AND stripe_verify_charge_id == null">
      <conclusion ref="r2-stripe-live-2h-before-announce" verdict="BLOCK — verify a live $1 charge"/>
    </branch>
    <branch when="fallback_content_ready == false">
      <conclusion ref="r3-fallback-content-in-place" verdict="BLOCK — freeze fallback content"/>
    </branch>
    <branch when="rollback_dry_run_at == null OR rollback_path_minutes &gt; 10">
      <conclusion ref="r5-rollback-le-10-min" verdict="BLOCK — rehearse ≤10-min rollback"/>
    </branch>
    <branch when="infra_change_between_t_minus_2h_and_t_plus_12h == true AND not_a_rollback">
      <conclusion ref="r4-no-live-key-changes-mid-launch" verdict="BLOCK — change freeze violated, roll back"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — execute the runbook"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="solo-launch-day-runbook-happy-path">
    T-2h: smoke green, Stripe verify_charge_id filled, fallback ready, rollback 7-min path rehearsed → no infra change drift → APPROVE → announce burst at T+0.
  </example>
</text>
