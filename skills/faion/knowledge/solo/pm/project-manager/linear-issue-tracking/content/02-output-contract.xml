<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Linear Issue Tracking (Project Manager) Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/linear-issue-tracking.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "workspace_url",
    "triage_cadence",
    "ceremonies",
    "status_template_url",
    "velocity_review_date",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "workspace_url": {
      "type": "string"
    },
    "triage_cadence": {
      "type": "string"
    },
    "ceremonies": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3
    },
    "status_template_url": {
      "type": "string"
    },
    "velocity_review_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">triage_cadence != &apos;daily&apos; — violates r1</pattern>
      <pattern id="f2">ceremonies.length != 3 — violates r2</pattern>
      <pattern id="f3">status_template_url empty — violates r4</pattern>
      <pattern id="f4">velocity_review_date &gt; last_reviewed + 90 days — violates r5</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "linear-pm-ops-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "workspace_url": "https://linear.app/faion",
  "triage_cadence": "daily",
  "ceremonies": [
    "planning",
    "mid-cycle-check-in",
    "retro"
  ],
  "status_template_url": "templates/status-update.md",
  "velocity_review_date": "2026-08-15",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "workspace_url": "https://linear.app/x",
  "triage_cadence": "weekly",
  "ceremonies": [
    "planning"
  ],
  "status_template_url": "",
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-linear-issue-tracking.py">Schema validator (stdlib only).</reference>
</text>
