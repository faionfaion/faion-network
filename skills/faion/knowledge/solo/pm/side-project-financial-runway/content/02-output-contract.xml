<text id="02-output-contract" title="Side-Project Financial Runway Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the runway model artefact this methodology produces. Validator enforces before the model drives a leave-job decision.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/side-project-financial-runway.json",
  "type": "object",
  "required": ["burn_personal", "burn_business", "savings_buffer", "mrr_current", "mrr_3mo_growth_pct", "leave_job_trigger", "geo_arbitrage_scenario", "stress_tests", "review_quarter", "owner"],
  "properties": {
    "burn_personal": {"type": "number", "minimum": 0},
    "burn_business": {"type": "number", "minimum": 0},
    "savings_buffer": {"type": "number", "minimum": 0},
    "mrr_current": {"type": "number", "minimum": 0},
    "mrr_3mo_growth_pct": {"type": "number"},
    "leave_job_trigger": {
      "type": "object",
      "required": ["runway_months", "mrr_pct_of_burn", "growth_min"],
      "properties": {
        "runway_months": {"type": "integer", "minimum": 12},
        "mrr_pct_of_burn": {"type": "number", "minimum": 0.3},
        "growth_min": {"type": "number", "minimum": 0}
      }
    },
    "geo_arbitrage_scenario": {
      "type": "object",
      "required": ["target_city", "expected_burn_reduction_pct"],
      "properties": {
        "target_city": {"type": "string", "minLength": 1},
        "expected_burn_reduction_pct": {"type": "number", "minimum": 0, "maximum": 0.8}
      }
    },
    "stress_tests": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["scenario", "runway_at_that_burn"],
        "properties": {
          "scenario": {"type": "string"},
          "runway_at_that_burn": {"type": "number", "minimum": 0}
        }
      }
    },
    "review_quarter": {"type": "string", "pattern": "^[0-9]{4}-Q[1-4]$"},
    "owner": {"type": "string", "minLength": 1},
    "decision_status": {"type": "string", "enum": ["pending", "stay", "leave", "stay-and-prepare"]}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "burn_personal": 6000,
  "burn_business": 1000,
  "savings_buffer": 90000,
  "mrr_current": 2500,
  "mrr_3mo_growth_pct": 0.12,
  "leave_job_trigger": {"runway_months": 12, "mrr_pct_of_burn": 0.36, "growth_min": 0},
  "geo_arbitrage_scenario": {"target_city": "Lisbon", "expected_burn_reduction_pct": 0.45},
  "stress_tests": [
    {"scenario": "flat MRR 12mo", "runway_at_that_burn": 12.8},
    {"scenario": "MRR -20% over 6mo", "runway_at_that_burn": 11.2}
  ],
  "review_quarter": "2026-Q2",
  "owner": "Ruslan",
  "decision_status": "stay-and-prepare"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "burn_personal": 2000,
  "savings_buffer": 12000,
  "mrr_current": 500,
  "leave_job_trigger": {"runway_months": 6, "mrr_pct_of_burn": 0.20, "growth_min": -0.05},
  "stress_tests": [],
  "review_quarter": "next quarter",
  "owner": ""
}
]]></code>
    <note>burn excludes business categories, leave_job_trigger violates runway_months &gt;= 12 and mrr_pct_of_burn &gt;= 0.30, growth_min negative, stress_tests empty (need &gt;=2), review_quarter wrong format, owner missing, no geo_arbitrage_scenario.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">burn excludes major categories (taxes, health, savings)</pattern>
      <pattern id="f2">leave-job decision_status == leave with runway_months &lt; 12 OR mrr_pct_of_burn &lt; 0.30</pattern>
      <pattern id="f3">stress_tests array has fewer than 2 scenarios (flat + declining required)</pattern>
      <pattern id="f4">review skipped &gt; 6 months (review_quarter older than 2 quarters ago)</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Trim narrative fields to &lt;= 500 chars preserving named entities + numeric claims.</transformation>
      <transformation>Promote a 'no decision yet' state to decision_status='pending' rather than fabricating a decision.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-side-project-financial-runway.py">Validator script</reference>
</text>
