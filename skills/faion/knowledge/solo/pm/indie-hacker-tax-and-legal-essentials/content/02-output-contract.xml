<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Indie Hacker Tax and Legal Essentials Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/indie-hacker-tax-and-legal-essentials.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "entity",
    "tax_residency",
    "vat_status",
    "sales_tax_status",
    "customer_contract",
    "privacy_policy",
    "processor_list",
    "next_review_date",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "entity": {
      "type": "object"
    },
    "tax_residency": {
      "type": "string"
    },
    "vat_status": {
      "type": "string"
    },
    "sales_tax_status": {
      "type": "string"
    },
    "customer_contract": {
      "type": "object"
    },
    "privacy_policy": {
      "type": "object"
    },
    "processor_list": {
      "type": "array"
    },
    "next_review_date": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">entity missing OR rationale empty — violates r2</pattern>
      <pattern id="f2">EU customers &gt;0 AND vat_status == &apos;none&apos; — violates r3</pattern>
      <pattern id="f3">customer_contract.terms_url empty OR privacy_policy.url empty — violates r4</pattern>
      <pattern id="f4">next_review_date &gt; last_reviewed + 18 months — violates r5</pattern>
      <pattern id="f5">owner == &apos;team&apos; / &apos;&apos; / null</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "legal-inventory-2026-q2",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "entity": {
    "type": "sole-trader-PT",
    "registration_id": "NIF-XXX",
    "registered_at": "2025-09-10",
    "rationale": "EU resident, <50K rev"
  },
  "tax_residency": "PT",
  "vat_status": "stripe-tax-collected",
  "sales_tax_status": "stripe-tax-collected-US-nexus-states",
  "customer_contract": {
    "terms_url": "https://faion.net/terms",
    "version": "1.2.0"
  },
  "privacy_policy": {
    "url": "https://faion.net/privacy",
    "version": "1.1.0"
  },
  "processor_list": [
    {
      "name": "stripe",
      "purpose": "billing"
    },
    {
      "name": "cloudflare",
      "purpose": "cdn"
    }
  ],
  "next_review_date": "2027-05-23",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "entity": {},
  "tax_residency": "PT",
  "vat_status": "none",
  "sales_tax_status": "none",
  "customer_contract": {
    "terms_url": ""
  },
  "privacy_policy": {
    "url": ""
  },
  "processor_list": [],
  "owner": "team"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. owner=='team').</note>
  </example>

  <reference path="scripts/validate-indie-hacker-tax-and-legal-essentials.py">Schema validator (stdlib only).</reference>
</text>
