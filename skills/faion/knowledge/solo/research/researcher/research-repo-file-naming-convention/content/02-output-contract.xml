<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Research Repo File-Naming Convention Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Research Repo File-Naming Convention output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="repo_root" type="string" required="true">absolute path to research repo</field>
      <field name="folder_tree" type="array" required="true">lifecycle folders: recruit/, run/, tag/, synthesise/, archive/</field>
      <field name="filename_grammar" type="string" required="true">regex for valid filenames</field>
      <field name="manifest_schema" type="object" required="true">JSON Schema for manifest.json</field>
      <field name="anonymisation_policy" type="string" required="true">Pnnn rule + scrub regex</field>
      <field name="owner" type="string" required="true">named researcher</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">filename_grammar regex matches names containing real PII</pattern>
      <pattern id="f2">folder_tree missing any of {recruit, run, tag, synthesise, archive}</pattern>
      <pattern id="f3">manifest_schema empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to add per-study sub-folders under run/ when artefact count exceeds 50.</transformation>
      <transformation>Allowed to localise filename language suffix via ISO-639-1 codes.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/research-repo-file-naming-convention.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "repo_root": "sample-repo_root",
  "folder_tree": [
    {
      "k": "v"
    }
  ],
  "filename_grammar": "sample-filename_grammar",
  "manifest_schema": {
    "k": "v"
  },
  "anonymisation_policy": "sample-anonymisation_policy",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/research-repo-file-naming-convention.json</item>
    </list>
  </section>
</text>
