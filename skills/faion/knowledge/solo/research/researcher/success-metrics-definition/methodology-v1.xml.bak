<methodology slug="success-metrics-definition">
  <metadata>
    <tier>solo</tier>
    <group>research</group>
    <domain>researcher</domain>
    <summary>Quantifiable measures indicating you're achieving goals connected to business outcomes.</summary>
    <category>research</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-26</created>
    <tags>
      <tag>research</tag>
