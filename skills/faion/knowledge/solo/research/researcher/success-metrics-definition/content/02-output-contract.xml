<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Success Metrics Definition Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Success Metrics Definition output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="north_star" type="object" required="true">metric + business outcome link + owner</field>
      <field name="aarrr_kpis" type="array" required="true">≤5 KPIs partitioned across acquisition/activation/retention/referral/revenue</field>
      <field name="baselines" type="object" required="true">current value per KPI</field>
      <field name="targets" type="object" required="true">target value + window per KPI</field>
      <field name="vanity_excluded" type="array" required="true">vanity metrics explicitly excluded</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">aarrr_kpis length &gt; 5</pattern>
      <pattern id="f2">north_star is array</pattern>
      <pattern id="f3">any KPI missing baseline or target</pattern>
      <pattern id="f4">vanity_excluded empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to promote a tier-2 KPI to north-star when a 30-day correlation to revenue is logged.</transformation>
      <transformation>Allowed to relax AARRR partition for usage-based pricing where retention and revenue overlap.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/success-metrics-definition.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "north_star": {
    "k": "v"
  },
  "aarrr_kpis": [
    {
      "k": "v"
    }
  ],
  "baselines": {
    "k": "v"
  },
  "targets": {
    "k": "v"
  },
  "vanity_excluded": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/success-metrics-definition.json</item>
    </list>
  </section>
</text>
