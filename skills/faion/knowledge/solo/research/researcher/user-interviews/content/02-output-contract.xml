<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="User Interviews Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid User Interviews output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="session_id" type="string" required="true">stable id</field>
      <field name="respondent" type="object" required="true">Pnnn + cold/warm flag</field>
      <field name="script_used" type="string" required="true">path to Mom Test script</field>
      <field name="transcript_path" type="string" required="true">path to diarized transcript</field>
      <field name="behavioural_ask_outcome" type="string" required="true">yes-with-evidence | no | pending</field>
      <field name="insights" type="array" required="true">≥1 insight with frequency_count ≥1 and citation</field>
      <field name="owner" type="string" required="true">named researcher</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">any question in script verb ∈ {would, could, might}</pattern>
      <pattern id="f2">behavioural_ask_outcome empty</pattern>
      <pattern id="f3">transcript_path missing OR not diarized</pattern>
      <pattern id="f4">any insight without frequency_count</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to inline a 'tell-me-about' probe replacing a banned hypothetical question.</transformation>
      <transformation>Allowed to merge two near-duplicate insights into one row with summed frequency.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/user-interviews.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "session_id": "sample-session_id",
  "respondent": {
    "k": "v"
  },
  "script_used": "sample-script_used",
  "transcript_path": "sample-transcript_path",
  "behavioural_ask_outcome": "sample-behavioural_ask_outcome",
  "insights": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/user-interviews.json</item>
    </list>
  </section>
</text>
