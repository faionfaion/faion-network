<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Docker Compose (Infrastructure) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/docker-compose.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">DB-tier service on a network without internal: true.</pattern>
      <pattern id="f2">any service missing deploy.resources.limits.</pattern>
      <pattern id="f3">restart: always (override of operator intent).</pattern>
      <pattern id="f4">filename == docker-compose.yml.</pattern>
      <pattern id="f5">bind mount for persistent data.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "docker-compose-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner=team violates the named-owner rule.</note>
  </example>

  <reference path="scripts/validate-docker-compose.py">Schema validator (stdlib only).</reference>
</text>
