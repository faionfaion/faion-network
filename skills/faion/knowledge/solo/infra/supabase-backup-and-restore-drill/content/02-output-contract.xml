<text id="02-output-contract" title="Supabase Backup and Restore Drill Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/supabase-backup-and-restore-drill.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "drill_date",
    "source_snapshot_id",
    "target_project",
    "restore_seconds",
    "row_count_delta",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "drill_date": {
      "type": "string",
      "format": "date"
    },
    "source_snapshot_id": {
      "type": "string"
    },
    "target_project": {
      "type": "string"
    },
    "restore_seconds": {
      "type": "integer"
    },
    "row_count_delta": {
      "type": "integer"
    },
    "checksum_match": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">target_project == production project ID (r2).</pattern>
      <pattern id="f3">row_count_delta != 0 (r3).</pattern>
      <pattern id="f4">checksum_match == false (r3).</pattern>
      <pattern id="f5">drill_date older than today - 90 days (r1).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "drill-2026-05-23",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "drill_date": "2026-05-23",
  "source_snapshot_id": "snap_xyz",
  "target_project": "faion-restore-clone",
  "restore_seconds": 412,
  "row_count_delta": 0,
  "checksum_match": true,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "drill_date": "2026-05-23",
  "source_snapshot_id": "snap_xyz",
  "target_project": "faion-prod",
  "row_count_delta": 7,
  "owner": "team"
}
]]></code>
    <note>target_project=faion-prod (r2 violation); row_count_delta=7 (r3 violation); owner=team; missing artefact_id, version, last_reviewed, restore_seconds, checksum_match.</note>
  </example>

  <reference path="scripts/validate-supabase-backup-and-restore-drill.py">Schema validator (stdlib only).</reference>
</text>
