<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solo Deploy Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/solo-deploy-checklist.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "commit_sha",
    "rollback_plan",
    "tests_green",
    "backup_taken",
    "deploy_window",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "commit_sha": {
      "type": "string"
    },
    "rollback_plan": {
      "type": "string"
    },
    "tests_green": {
      "type": "boolean"
    },
    "backup_taken": {
      "type": "boolean"
    },
    "deploy_window": {
      "type": "string"
    },
    "migration": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">rollback_plan empty OR placeholder text (r1).</pattern>
      <pattern id="f3">migration == true AND backup_taken == false (r2).</pattern>
      <pattern id="f4">tests_green == false AND deploy proceeds (r3).</pattern>
      <pattern id="f5">deploy_window == &apos;friday-evening&apos; AND on_call == false (r5).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "deploy-faion-net-2026-05-23",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "commit_sha": "9f1c2a4",
  "rollback_plan": "git revert + ./deploy-be.sh prev_tag",
  "tests_green": true,
  "backup_taken": true,
  "deploy_window": "tuesday-morning",
  "migration": true,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "commit_sha": "9f1c2a4",
  "rollback_plan": "",
  "tests_green": false,
  "deploy_window": "friday-evening",
  "owner": "team"
}
]]></code>
    <note>rollback_plan empty (r1 violation); tests_green=false (r3 violation); deploy_window=friday-evening (r5 violation); owner=team; missing artefact_id, version, last_reviewed, backup_taken.</note>
  </example>

  <reference path="scripts/validate-solo-deploy-checklist.py">Schema validator (stdlib only).</reference>
</text>
