<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="systemd User Services Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/systemd-user-services.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "unit_name",
    "exec_start",
    "environment_file",
    "restart",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "unit_name": {
      "type": "string"
    },
    "exec_start": {
      "type": "string"
    },
    "environment_file": {
      "type": "string"
    },
    "restart": {
      "type": "string",
      "enum": [
        "on-failure",
        "no",
        "on-abnormal"
      ]
    },
    "memory_high": {
      "type": "string"
    },
    "memory_max": {
      "type": "string"
    },
    "linger_enabled": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">restart not in [on-failure, no, on-abnormal] (r2).</pattern>
      <pattern id="f3">linger_enabled == false (r1).</pattern>
      <pattern id="f4">environment_file empty AND unit consumes secrets (r3).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "faion-net-api",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "unit_name": "faion-net-api.service",
  "exec_start": "/home/faion/Projects/faion-net-be/.venv/bin/uvicorn ...",
  "environment_file": "/etc/faion-net-api.env",
  "restart": "on-failure",
  "memory_high": "1G",
  "memory_max": "2G",
  "linger_enabled": true,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "unit_name": "myapp.service",
  "exec_start": "/usr/bin/myapp",
  "restart": "always",
  "linger_enabled": false,
  "owner": "team"
}
]]></code>
    <note>restart=always (r2 violation, not in enum); linger_enabled=false (r1 violation); owner=team; missing artefact_id, version, last_reviewed, environment_file.</note>
  </example>

  <reference path="scripts/validate-systemd-user-services.py">Schema validator (stdlib only).</reference>
</text>
