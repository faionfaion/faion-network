<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Direnv + Mise for Per-Project Environments Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys plus per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/direnv-mise-versions.json",
  "type": "object",
  "required": [
    "slug",
    "title",
    "owner",
    "trigger",
    "evidence",
    "produced_at",
    "findings",
    "recommendations"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200
    },
    "owner": {
      "type": "object",
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "role": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "trigger": {
      "type": "object",
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "enum": [
            "event",
            "threshold",
            "schedule"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "claim",
          "link"
        ],
        "properties": {
          "claim": {
            "type": "string"
          },
          "link": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "minItems": 1
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "slug": "direnv-mise-versions",
  "title": "Direnv + Mise for Per-Project Environments",
  "owner": {
    "name": "Ruslan Faion",
    "role": "platform lead"
  },
  "trigger": {
    "kind": "schedule",
    "value": "weekly:monday-09:00-utc"
  },
  "last_reviewed": "2026-05-23",
  "evidence": [
    {
      "claim": "configuration verified in dry run",
      "link": "https://wiki.faion.net/runs/2026-05-23"
    }
  ],
  "produced_at": "2026-05-23T10:00:00Z",
  "findings": [
    {
      "id": "f1",
      "summary": "baseline established; no drift detected"
    }
  ],
  "recommendations": [
    "schedule next review at the cadence interval"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "slug": "BAD_SLUG",
  "owner": "someone"
}
]]></code>
    <note>Required fields missing (title, trigger, evidence, produced_at, findings, recommendations). Slug not kebab-case. Owner not an object.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Trigger value 'when needed' or 'ad-hoc'.</description>
      <reason>Fires constantly or never; cadence becomes unenforceable.</reason>
    </antipattern>
    <antipattern>
      <description>Owner = team or channel handle (e.g. '@platform-team', '#oncall').</description>
      <reason>Channel ownership rots; named human required.</reason>
    </antipattern>
    <antipattern>
      <description>Empty evidence array with conclusions filled.</description>
      <reason>Unevidenced conclusions are demoted to hypotheses.</reason>
    </antipattern>
  </section>

  <reference path="scripts/validate-direnv-mise-versions.py">Validator script</reference>
</text>
