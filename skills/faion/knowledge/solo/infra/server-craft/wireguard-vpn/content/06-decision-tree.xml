<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="WireGuard VPN Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable inputs to a rule from `01-core-rules.xml`. MANDATORY for every methodology — even flat ones — per F-066 DoD.</summary>

  <decision-tree>
      <root-question id="q-need-vpn">Does the operator need access to VPS-internal services NOT exposed publicly?</root-question>

      <branch when="needs_internal_access == false">
        <conclusion ref="skip-this-methodology" verdict="skip-use-ssh-tunnel"/>
      </branch>
      <branch when="needs_internal_access == true">
        <question id="q-peer-role">What is the primary peer role?</question>
        <branch when="role == split-tunnel">
          <conclusion ref="r1-allowedips-defines-routing" verdict="wg0-client-split"/>
        </branch>
        <branch when="role == full-tunnel">
          <conclusion ref="r1-allowedips-defines-routing" verdict="wg0-client-full"/>
        </branch>
        <branch when="role == site-to-site">
          <conclusion ref="r1-allowedips-defines-routing" verdict="wg0-home-gateway"/>
        </branch>
        <branch when="role == mobile">
          <conclusion ref="r5-keepalive-for-mobile" verdict="wg0-client-mobile"/>
        </branch>
      </branch>
  </decision-tree>

  <example trace="needs_internal_access=true → role=split-tunnel → wg0-client-split">
    Dev laptop needs Postgres on the VPS → render split-tunnel client with AllowedIPs=10.66.66.0/24.
  </example>
</text>
