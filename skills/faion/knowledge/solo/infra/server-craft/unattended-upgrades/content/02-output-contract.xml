<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Unattended Upgrades Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/unattended-upgrades.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "allowed_origins",
    "auto_reboot",
    "reboot_time",
    "mail_to",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "allowed_origins": {
      "type": "array"
    },
    "auto_reboot": {
      "type": "boolean"
    },
    "reboot_time": {
      "type": "string"
    },
    "mail_to": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">allowed_origins contains &apos;-updates&apos; or &apos;-backports&apos; (r1).</pattern>
      <pattern id="f3">reboot_time == &apos;now&apos; OR empty (r2).</pattern>
      <pattern id="f4">mail_to empty AND auto_reboot == true (r3).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "upgrades-faion-net-01",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "allowed_origins": [
    "${distro_id}:${distro_codename}-security",
    "${distro_id}ESMApps:${distro_codename}-apps-security"
  ],
  "auto_reboot": true,
  "reboot_time": "04:00",
  "mail_to": "ops@faion.net",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "allowed_origins": [
    "${distro_id}:${distro_codename}-updates"
  ],
  "auto_reboot": true,
  "reboot_time": "now",
  "owner": "team"
}
]]></code>
    <note>allowed_origins includes -updates (r1 violation); reboot_time=now (r2 violation); owner=team; missing artefact_id, version, last_reviewed, mail_to.</note>
  </example>

  <reference path="scripts/validate-unattended-upgrades.py">Schema validator (stdlib only).</reference>
</text>
