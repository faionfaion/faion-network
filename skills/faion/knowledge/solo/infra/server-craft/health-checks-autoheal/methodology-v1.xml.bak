<methodology slug="health-checks-autoheal">
  <metadata>
    <tier>solo</tier>
    <group>infra</group>
    <domain>server-craft</domain>
    <summary>Health monitoring and automatic recovery for multi-service platforms: HTTP /health endpoints, systemd watchdog, auto-heal watcher with restart throttling and Telegram alerts.</summary>
    <tags>
      <tag>health-checks</tag>
      <tag>monitoring</tag>
      <tag>systemd</tag>
      <tag>auto-heal</tag>
      <tag>ubuntu</tag>
    </tags>
