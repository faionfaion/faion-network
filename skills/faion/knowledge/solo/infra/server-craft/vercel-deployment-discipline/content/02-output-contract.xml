<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Vercel Deployment Discipline Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/vercel-deployment-discipline.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "project_id",
    "commit_sha",
    "target_env",
    "env_audit_pass",
    "edge_violations",
    "go_no_go",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "project_id": {
      "type": "string"
    },
    "commit_sha": {
      "type": "string"
    },
    "target_env": {
      "type": "string",
      "enum": [
        "production",
        "preview-staging",
        "preview-pr"
      ]
    },
    "env_audit_pass": {
      "type": "boolean"
    },
    "edge_violations": {
      "type": "array"
    },
    "isr_paths": {
      "type": "array"
    },
    "rollback_plan": {
      "type": "object"
    },
    "go_no_go": {
      "type": "string",
      "enum": [
        "go",
        "hold-fix",
        "abort"
      ]
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">go_no_go == &apos;go&apos; AND edge_violations non-empty (r2).</pattern>
      <pattern id="f3">go_no_go == &apos;go&apos; AND env_audit_pass == false (r1/r5).</pattern>
      <pattern id="f4">rollback_plan.prior_deployment_id empty OR verify_url empty (r4).</pattern>
      <pattern id="f5">Env var with scopes [dev, preview, prod] AND name contains [SECRET, KEY, PASSWORD, TOKEN, DSN] (r1).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "deploy-faion-net-2026-05-23",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "project_id": "prj_abc123",
  "commit_sha": "9f1c2a4",
  "target_env": "production",
  "env_audit_pass": true,
  "edge_violations": [],
  "isr_paths": [],
  "rollback_plan": {
    "prior_deployment_id": "dpl_xyz",
    "verify_url": "/_vercel/info"
  },
  "go_no_go": "go",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "project_id": "prj_abc123",
  "target_env": "production",
  "env_audit_pass": false,
  "edge_violations": [
    "app/api/upload/route.ts uses fs"
  ],
  "go_no_go": "go",
  "owner": "team"
}
]]></code>
    <note>go_no_go=go with env_audit_pass=false AND edge_violations present (r1+r2 violations); owner=team; missing artefact_id, version, last_reviewed, commit_sha, rollback_plan.</note>
  </example>

  <reference path="scripts/validate-vercel-deployment-discipline.py">Schema validator (stdlib only).</reference>
</text>
