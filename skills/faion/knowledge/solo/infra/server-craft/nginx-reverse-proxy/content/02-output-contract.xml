<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="nginx Reverse Proxy Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nginx-reverse-proxy.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "domain",
    "backend_upstream",
    "tls_mode",
    "websocket",
    "rate_limit_zone",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "domain": {
      "type": "string"
    },
    "backend_upstream": {
      "type": "string"
    },
    "tls_mode": {
      "type": "string",
      "enum": [
        "cloudflare-origin",
        "letsencrypt",
        "self-signed"
      ]
    },
    "websocket": {
      "type": "boolean"
    },
    "rate_limit_zone": {
      "type": "string"
    },
    "security_headers": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">tls_mode not in enum [cloudflare-origin, letsencrypt, self-signed].</pattern>
      <pattern id="f3">rate_limit_zone empty AND domain serves /api/.</pattern>
      <pattern id="f4">websocket == true AND `$connection_upgrade` map not declared in http context.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "nginx-app01",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "domain": "app.example.com",
  "backend_upstream": "127.0.0.1:8100",
  "tls_mode": "cloudflare-origin",
  "websocket": true,
  "rate_limit_zone": "api_general",
  "security_headers": [
    "HSTS",
    "X-Content-Type-Options",
    "Referrer-Policy"
  ],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "domain": "app.example.com",
  "backend_upstream": "127.0.0.1:8100",
  "tls_mode": "wildcard",
  "websocket": true,
  "owner": "team"
}
]]></code>
    <note>tls_mode value `wildcard` not in enum; owner=`team` (forbidden plural); missing artefact_id, version, last_reviewed, rate_limit_zone.</note>
  </example>

  <reference path="scripts/validate-nginx-reverse-proxy.py">Schema validator (stdlib only).</reference>
</text>
