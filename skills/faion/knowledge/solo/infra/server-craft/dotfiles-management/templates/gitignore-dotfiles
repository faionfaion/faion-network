# .gitignore for dotfiles repository
# Prevents accidental commit of secrets, keys, and machine-specific state

# SSH keys — NEVER commit (only .ssh/config is safe)
ssh/.ssh/id_*
ssh/.ssh/known_hosts
ssh/.ssh/authorized_keys

# Shell history (may contain passwords, API tokens in curl commands)
bash/.bash_history
bash/.zsh_history
.bash_history
.zsh_history

# Secrets and environment files
*.secret
*.key
*.pem
.env
.env.*

# Claude Code project configs (machine-specific, may reference credentials)
claude/.claude/projects/

# GPG private keys
.gnupg/

# 1Password CLI session data
.op/

# Editor state (machine-local)
vim/.vim/undo/
vim/.vim/swap/
vim/.viminfo

# OS files
.DS_Store
Thumbs.db

# Local cache and state
.local/share/
.cache/
