<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Claude Code &amp; Cursor at Solo Tier Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/claude-code-and-cursor-at-solo-tier.json",
  "type": "object",
  "required": [
    "repo",
    "primary_tool",
    "model_routing",
    "context_budget_tokens",
    "spec_before_code"
  ],
  "properties": {
    "repo": {
      "type": "string"
    },
    "primary_tool": {
      "enum": [
        "claude-code",
        "cursor"
      ]
    },
    "secondary_tool": {
      "enum": [
        "claude-code",
        "cursor",
        "none"
      ]
    },
    "model_routing": {
      "type": "object",
      "required": [
        "design",
        "routine",
        "mechanical"
      ],
      "properties": {
        "design": {
          "enum": [
            "opus",
            "sonnet"
          ]
        },
        "routine": {
          "enum": [
            "opus",
            "sonnet"
          ]
        },
        "mechanical": {
          "enum": [
            "sonnet",
            "haiku"
          ]
        }
      }
    },
    "context_budget_tokens": {
      "type": "integer",
      "maximum": 2000
    },
    "convention_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "spec_before_code": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "repo": "github.com/operator/saas-app",
  "primary_tool": "claude-code",
  "secondary_tool": "cursor",
  "model_routing": {
    "design": "opus",
    "routine": "sonnet",
    "mechanical": "haiku"
  },
  "context_budget_tokens": 1800,
  "convention_files": [
    "CLAUDE.md",
    "AGENTS.md",
    "CONVENTIONS.md"
  ],
  "spec_before_code": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "repo": "x",
  "primary_tool": "copilot",
  "spec_before_code": false
}
]]></code>
    <note>primary_tool outside enum; spec_before_code must be true; model_routing missing.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>primary_tool other than claude-code / cursor.</item>
      <item>context_budget_tokens &gt; 2000.</item>
      <item>spec_before_code = false.</item>
    </list>
  </section>

  <reference path="scripts/validate-claude-code-and-cursor-at-solo-tier.py">Validator script</reference>
</text>
