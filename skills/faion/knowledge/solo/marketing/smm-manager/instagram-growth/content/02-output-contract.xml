<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Instagram Growth Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Instagram Growth output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named account owner</field>
      <field name="pillar" type="object" required="true">{niche, icp, voice_attributes}</field>
      <field name="reel_batch" type="array" required="true">≥28 scripts with hook + payoff + CTA</field>
      <field name="stories_cadence" type="object" required="true">{daily_count, dm_cta_frequency}</field>
      <field name="dm_trigger" type="object" required="true">{phrase, lead_magnet_url}</field>
      <field name="engagement_block" type="string" required="true">30-min daily slot with criterion</field>
      <field name="kpi_set" type="object" required="true">{reach, profile_visits, dm_starts, qualified_dms}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">pillar split into 3+ niches</pattern>
      <pattern id="f2">reel_batch count &lt; 28</pattern>
      <pattern id="f3">DM trigger missing lead_magnet_url</pattern>
      <pattern id="f4">engagement_block &lt; 20 minutes</pattern>
      <pattern id="f5">kpi_set headline == 'followers'</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to substitute one Reel with one carousel/week as variety.</transformation>
      <transformation>Allowed to batch Reels weekly (7 in one shoot) but daily-post cadence is mandatory.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/instagram-growth.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/instagram-growth.json</item>
    </list>
  </section>
</text>
