<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Growth LinkedIn Strategy Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Growth LinkedIn Strategy output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named LinkedIn account owner</field>
      <field name="positioning" type="object" required="true">{icp, pain, outcome}</field>
      <field name="post_rotation" type="array" required="true">≥3 typed posts (story/how-to/carousel) for the next week</field>
      <field name="daily_engagement_quota" type="integer" required="true">≥10 strangers-replied-to per day</field>
      <field name="dm_trigger" type="string" required="true">exact trigger phrase + CTA</field>
      <field name="kpi_set" type="object" required="true">{profile_visits, qualified_dms, inbound_calls, conversion_rate}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">post_rotation count &lt; 3 per week</pattern>
      <pattern id="f2">daily_engagement_quota &lt; 10</pattern>
      <pattern id="f3">operator = 'team' / generic page</pattern>
      <pattern id="f4">positioning missing any of {icp, pain, outcome}</pattern>
      <pattern id="f5">kpi_set tracking followers as headline metric</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to swap one weekly post type for a video if equivalent length.</transformation>
      <transformation>Allowed to batch engagement into 2x15-min windows instead of one 30-min block.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/growth-linkedin-strategy.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/growth-linkedin-strategy.json</item>
    </list>
  </section>
</text>
