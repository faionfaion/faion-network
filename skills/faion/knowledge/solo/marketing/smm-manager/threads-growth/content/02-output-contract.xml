<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Threads Growth Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Threads Growth output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named account owner</field>
      <field name="daily_post_target" type="integer" required="true">≥5</field>
      <field name="daily_reply_target" type="integer" required="true">≥10 to larger accounts</field>
      <field name="adaptation_log" type="array" required="true">X/IG source → Threads adapted text</field>
      <field name="voice_register" type="enum" required="true">casual|playful (formal rejected)</field>
      <field name="kpi_set" type="object" required="true">{impressions, replies_from_strangers, profile_visits, qualified_follows}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">daily_post_target &lt; 5</pattern>
      <pattern id="f2">voice_register == 'formal'</pattern>
      <pattern id="f3">adaptation_log contains identical text from source (copy-paste)</pattern>
      <pattern id="f4">kpi_set headline == 'followers'</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to substitute up to 2 of the 5 daily posts with replies-as-posts (long reply quoted).</transformation>
      <transformation>Allowed to skip a day in the first 4 weeks while voice is being calibrated.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/threads-growth.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/threads-growth.json</item>
    </list>
  </section>
</text>
