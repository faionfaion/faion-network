<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Growth Social Media Strategy Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Growth Social Media Strategy output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named owner of the strategy</field>
      <field name="primary_platforms" type="array" required="true">≤2 platforms with fit-score + audience size</field>
      <field name="atomization_loop" type="object" required="true">{seed_type, weekly_cuts, channel_mapping}</field>
      <field name="weekly_time_budget_hours" type="integer" required="true">≤10 for solo</field>
      <field name="engagement_quota" type="object" required="true">per-platform replies/day</field>
      <field name="kpi_set" type="object" required="true">{audience_growth, qualified_engagement, pipeline_added}</field>
      <field name="review_cadence_weeks" type="integer" required="true">default 12</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">primary_platforms count &gt; 2</pattern>
      <pattern id="f2">weekly_time_budget_hours &gt; 10 (not solo-realistic)</pattern>
      <pattern id="f3">atomization_loop.weekly_cuts &lt; 3</pattern>
      <pattern id="f4">kpi_set headline == 'followers'</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to shrink to 1 platform when time_budget ≤ 4 hours/week.</transformation>
      <transformation>Allowed to swap seed type (blog→podcast→video) at 12-week review.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/growth-social-media-strategy.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/growth-social-media-strategy.json</item>
    </list>
  </section>
</text>
