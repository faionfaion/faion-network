<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Shutdown Customer Email Pack Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Shutdown Customer Email Pack output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="artefact_id" type="string" required="true">kebab-case slug for the shutdown sequence</field>
      <field name="owner" type="string" required="true">named human signing the emails</field>
      <field name="service_off_date" type="date" required="true">ISO date the product stops</field>
      <field name="announce_email" type="object" required="true">subject + body + send_date (T-30)</field>
      <field name="refund_email" type="object" required="true">subject + body + send_date (T-14) + refund_terms</field>
      <field name="final_thanks_email" type="object" required="true">subject + body + send_date (T+1)</field>
      <field name="real_reason_sentence" type="string" required="true">one honest sentence on cause</field>
      <field name="refund_or_migration" type="object" required="true">{type: refund|migrate, terms: string}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">from-line set to noreply@ or generic team alias</pattern>
      <pattern id="f2">announce_email.send_date within 30 days of service_off_date</pattern>
      <pattern id="f3">refund_or_migration missing (no remedy = abandonment)</pattern>
      <pattern id="f4">real_reason_sentence containing corporate-speak ('exciting new chapter', 'evolving in a new direction')</pattern>
      <pattern id="f5">sequence count != 3</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Auto-fill T+1 thanks date relative to service_off_date.</transformation>
      <transformation>Allowed to swap refund → credit-to-future-product if customer accepts.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/shutdown-customer-email-pack.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/shutdown-customer-email-pack.json</item>
    </list>
  </section>
</text>
