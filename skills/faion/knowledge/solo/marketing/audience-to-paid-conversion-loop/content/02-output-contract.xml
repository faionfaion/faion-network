<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Audience to Paid Conversion Loop Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/audience-to-paid-conversion-loop.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "loop_id",
    "cohort_size",
    "window_days",
    "variant",
    "conversion_rate",
    "decision",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "loop_id": {
      "type": "string"
    },
    "cohort_size": {
      "type": "integer"
    },
    "window_days": {
      "type": "integer"
    },
    "variant": {
      "type": "string"
    },
    "conversion_rate": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "keep",
        "drop",
        "iterate",
        "log-only"
      ]
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">variant string contains &apos;+&apos; or &apos;,&apos; (more than one change — r2).</pattern>
      <pattern id="f3">cohort_size &lt; 50 AND decision != &apos;log-only&apos; (r3).</pattern>
      <pattern id="f4">window_days &lt; 1 OR window_days &gt; 90 (out of range).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "loop-2026-w20",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "loop_id": "LOOP-2026-W20",
  "cohort_size": 312,
  "window_days": 7,
  "variant": "subject-line-emoji",
  "conversion_rate": "4.8%",
  "decision": "keep",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "loop_id": "LOOP-X",
  "cohort_size": 30,
  "window_days": 7,
  "variant": "subject + price + cta",
  "decision": "keep",
  "owner": "team"
}
]]></code>
    <note>cohort_size=30 &lt; 50 (r3 → log-only); variant contains 3 changes (r2 violation); owner=team; missing artefact_id, version, last_reviewed, conversion_rate.</note>
  </example>

  <reference path="scripts/validate-audience-to-paid-conversion-loop.py">Schema validator (stdlib only).</reference>
</text>
