<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Build-in-Public Content Engine Procedure" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Step-by-step procedure to apply Build-in-Public Content Engine end-to-end. Each step names its input, action, output, and (where relevant) a decision-gate.</summary>

  <section title="Procedure">

    <step n="1" name="collect-weekly-inputs">
      <input>Product-work log</input>
      <action>Fill weekly-input-log.md with 4 fields.</action>
      <output>Inputs ready.</output>
    </step>

    <step n="2" name="draft-posts">
      <input>Inputs + format menu</input>
      <action>Produce 3 short + 1 long post draft.</action>
      <output>Draft set.</output>
    </step>

    <step n="3" name="hook-variants">
      <input>Draft set</input>
      <action>Per post: ≥3 hook variants; pick one.</action>
      <output>Posts ready.</output>
    </step>

    <step n="4" name="atomize-and-ship">
      <input>Long-form post</input>
      <action>Atomize into X + LinkedIn; ship per cadence.</action>
      <output>Posts shipped.</output>
    </step>

    <step n="5" name="monthly-review">
      <input>Metric history</input>
      <action>Aggregate followers/list/inbound; decide reconfig.</action>
      <output>Review record.</output>
    </step>

  </section>
</text>
