{
  "__faion_header__": {
    "purpose": "JSON Schema for the Substack-to-Product Funnel output contract",
    "consumes": "subagent-produced artefact JSON",
    "produces": "validation verdict (pass/fail with violations)",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "~250 tokens"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.network/schema/substack-to-product-funnel.json",
  "title": "Substack-to-Product Funnel Output Contract",
  "type": "object",
  "required": [
    "operator",
    "publication_url",
    "paid_tier",
    "recommendation_partners",
    "cross_post_cadence",
    "welcome_sequence",
    "hard_product_url",
    "hard_product_cta_text",
    "kpi_set",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "operator": {
      "type": "string",
      "description": "named publication owner"
    },
    "publication_url": {
      "type": "string",
      "description": "Substack URL"
    },
    "paid_tier": {
      "type": "object",
      "description": "{name, monthly_price, annual_price, concrete_benefit}"
    },
    "recommendation_partners": {
      "type": "array",
      "description": "\u22653 publications with URL + agreement_at",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "cross_post_cadence": {
      "type": "object",
      "description": "{per_month, partner_rotation}"
    },
    "welcome_sequence": {
      "type": "array",
      "description": "5 emails; email 4 carries the hard-product CTA",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "hard_product_url": {
      "type": "string",
      "description": "URL"
    },
    "hard_product_cta_text": {
      "type": "string",
      "description": "\u2264140 chars"
    },
    "kpi_set": {
      "type": "object",
      "description": "{free_subs, paid_subs, hard_product_conversions, recommendation_inflow}"
    },
    "version": {
      "type": "string",
      "description": "semver"
    },
    "last_reviewed": {
      "type": "string",
      "description": "ISO date",
      "format": "date"
    }
  },
  "additionalProperties": true
}
