<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solo Niche Disqualifier Checklist Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Solo Niche Disqualifier Checklist output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named freelancer</field>
      <field name="specialisation_statement" type="string" required="true">1-line</field>
      <field name="floor_rate" type="object" required="true">{value, unit}</field>
      <field name="hard_no_list" type="array" required="true">≥5 named industries/project shapes</field>
      <field name="disqualifier_signals" type="array" required="true">exactly 5 signal definitions</field>
      <field name="rejection_reply_template" type="string" required="true">≤60 words</field>
      <field name="max_eval_minutes" type="integer" required="true">≤5</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">disqualifier_signals count != 5</pattern>
      <pattern id="f2">hard_no_list count &lt; 5</pattern>
      <pattern id="f3">rejection_reply_template &gt; 80 words</pattern>
      <pattern id="f4">max_eval_minutes &gt; 5</pattern>
      <pattern id="f5">rejection_reply contains counter-offer phrases ('but if you bump to', 'happy to do smaller scope')</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to extend rejection_reply by up to 20 words to add a referral alternative.</transformation>
      <transformation>Allowed to expand hard_no_list to 10 items; trimming below 5 forbidden.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/solo-niche-disqualifier-checklist.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/solo-niche-disqualifier-checklist.json</item>
    </list>
  </section>
</text>
