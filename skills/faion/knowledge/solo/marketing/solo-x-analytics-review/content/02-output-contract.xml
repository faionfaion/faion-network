<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solo X Analytics Review Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Solo X Analytics Review output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named X account owner</field>
      <field name="week_iso" type="string" required="true">ISO week tag</field>
      <field name="metrics" type="object" required="true">{impressions, profile_visits, net_followers, replies_from_strangers, link_clicks}</field>
      <field name="trailing_4w_median" type="object" required="true">median per metric</field>
      <field name="outliers" type="array" required="true">posts where impressions ≥3x median</field>
      <field name="top_post" type="object" required="true">{url, hook, variable_observed}</field>
      <field name="bottom_post" type="object" required="true">{url, hook}</field>
      <field name="qualified_follower_pct" type="number" required="true">0..1</field>
      <field name="next_week_experiment" type="object" required="true">{hypothesis, variable, success_metric}</field>
      <field name="time_spent_min" type="integer" required="true">≤20</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">metrics keys != exact 5-key set</pattern>
      <pattern id="f2">next_week_experiment missing hypothesis OR variable OR success_metric</pattern>
      <pattern id="f3">outliers includes posts &lt;3x median</pattern>
      <pattern id="f4">qualified_follower_pct missing when net_followers &gt; 0</pattern>
      <pattern id="f5">time_spent_min &gt; 20</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to mark 'no outlier this week' if zero posts hit 3x median.</transformation>
      <transformation>Allowed to defer next_week_experiment one week IF current experiment is mid-test.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/solo-x-analytics-review.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/solo-x-analytics-review.json</item>
    </list>
  </section>
</text>
