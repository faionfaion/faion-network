<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="In-Issue Ad Format Library Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema draft-07 for the ad-format library + rotation plan + benchmark block plus valid/invalid examples and forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/in-issue-ad-format-library.json",
  "type": "object",
  "required": ["library", "baseline", "rotation_plan", "review"],
  "properties": {
    "library": {
      "type": "object",
      "required": ["top_banner", "soft_ps", "mid_issue_case", "dedicated_send"],
      "additionalProperties": false,
      "properties": {
        "top_banner": {"type": "object", "required": ["max_per_issue"]},
        "soft_ps": {"type": "object", "required": ["max_per_4_issues"]},
        "mid_issue_case": {"type": "object", "required": ["max_per_2_issues"]},
        "dedicated_send": {"type": "object", "required": ["max_per_6_issues"]}
      }
    },
    "baseline": {
      "type": "object",
      "required": ["ctr_pct", "cvr_pct", "computed_at"],
      "properties": {
        "ctr_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "cvr_pct": {"type": "number", "minimum": 0, "maximum": 100},
        "computed_at": {"type": "string", "format": "date"}
      }
    },
    "rotation_plan": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["issue_n", "format", "cta_destination"],
        "properties": {
          "issue_n": {"type": "integer", "minimum": 1},
          "format": {"type": "string",
            "enum": ["top_banner", "soft_ps", "mid_issue_case", "dedicated_send", "none"]},
          "cta_destination": {"type": "string",
            "enum": ["product_paywall", "waitlist", "lead_magnet", "feature_announcement", "none"]}
        }
      }
    },
    "review": {
      "type": "object",
      "required": ["reviewed_at"],
      "properties": {
        "reviewed_at": {"type": "string", "format": "date"},
        "promoted_format": {"type": "string"},
        "demoted_format": {"type": "string"}
      }
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "library": {
    "top_banner": {"max_per_issue": 1},
    "soft_ps": {"max_per_4_issues": 3},
    "mid_issue_case": {"max_per_2_issues": 1},
    "dedicated_send": {"max_per_6_issues": 1}
  },
  "baseline": {"ctr_pct": 3.2, "cvr_pct": 0.6, "computed_at": "2026-05-23"},
  "rotation_plan": [
    {"issue_n": 1, "format": "top_banner", "cta_destination": "product_paywall"},
    {"issue_n": 2, "format": "soft_ps", "cta_destination": "lead_magnet"},
    {"issue_n": 3, "format": "mid_issue_case", "cta_destination": "product_paywall"},
    {"issue_n": 4, "format": "none", "cta_destination": "none"},
    {"issue_n": 5, "format": "soft_ps", "cta_destination": "waitlist"},
    {"issue_n": 6, "format": "dedicated_send", "cta_destination": "product_paywall"}
  ],
  "review": {"reviewed_at": "2026-05-23", "promoted_format": "mid_issue_case", "demoted_format": "dedicated_send"}
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "library": {"top_banner": {"max_per_issue": 5}, "soft_ps": {}, "mid_issue_case": {},
              "dedicated_send": {}, "footer_micro": {}},
  "baseline": {"ctr_pct": 200, "cvr_pct": -1, "computed_at": "later"},
  "rotation_plan": [{"issue_n": 1, "format": "popup", "cta_destination": "mixed"}],
  "review": {}
}
]]></code>
    <note>library has unauthorised format (footer_micro), missing required caps, baseline values out of range, rotation_plan uses unknown format + mixed CTA destination, review missing reviewed_at.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">library contains a format not in {top_banner, soft_ps, mid_issue_case, dedicated_send}.</pattern>
      <pattern id="f2">rotation_plan exceeds per-format cadence cap across any 6-issue window.</pattern>
      <pattern id="f3">6-issue window contains zero 'none' issues (trust-reset gap missing).</pattern>
      <pattern id="f4">cta_destination='mixed' OR plan has issue with multiple ads same format same destination.</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Mark an issue as 'none' format / 'none' destination to enforce trust-reset gap.</transformation>
      <transformation>Carry baseline forward unchanged if computed_at &lt; 30 days ago.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-in-issue-ad-format-library.py">Validator script</reference>
</text>
