<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Email Preflight Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/email-preflight-checklist.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "send_id",
    "items",
    "pass_rate",
    "owner",
    "decision"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "send_id": {
      "type": "string"
    },
    "items": {
      "type": "array"
    },
    "pass_rate": {
      "type": "number"
    },
    "owner": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "go",
        "hold",
        "abort"
      ]
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">items[].status == &apos;done&apos; AND items[].evidence empty — violates r6</pattern>
      <pattern id="f2">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; — violates r3</pattern>
      <pattern id="f3">items.length &lt; 12 (silent skip) — violates r1</pattern>
      <pattern id="f4">decision == &apos;go&apos; AND any items[].status == &apos;red&apos; — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "email-preflight-checklist-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "send_id": "<send_id>",
  "items": [],
  "pass_rate": 1.0,
  "owner": "@ruslan",
  "decision": "go"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "send_id": "<send_id>",
  "items": [],
  "pass_rate": 1.0,
  "owner": "team",
  "decision": "go"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-email-preflight-checklist.py">Schema validator (stdlib only).</reference>
</text>
