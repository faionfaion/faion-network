<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="IndieHackers Build-in-Public Strategy Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-indiehackers-strategy.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "ih_handle",
    "give_first_weeks",
    "monthly_update_topics",
    "kpis",
    "stop_condition",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "ih_handle": {
      "type": "string"
    },
    "give_first_weeks": {
      "type": "integer"
    },
    "monthly_update_topics": {
      "type": "array"
    },
    "kpis": {
      "type": "object"
    },
    "stop_condition": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">give_first_weeks &lt; 2 — violates r1</pattern>
      <pattern id="f2">monthly_update_topics.length &lt; 3 — violates r2</pattern>
      <pattern id="f3">kpis missing &apos;signups_per_month&apos; OR &apos;replies_per_post&apos; — violates r5</pattern>
      <pattern id="f4">owner in plural roles — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "growth-indiehackers-strategy-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "ih_handle": "<ih_handle>",
  "give_first_weeks": 1,
  "monthly_update_topics": [],
  "kpis": {},
  "stop_condition": "<stop_condition>",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "ih_handle": "<ih_handle>",
  "give_first_weeks": 1,
  "monthly_update_topics": [],
  "kpis": {},
  "stop_condition": "<stop_condition>",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-growth-indiehackers-strategy.py">Schema validator (stdlib only).</reference>
</text>
