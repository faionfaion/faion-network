<methodology slug="growth-indiehackers-strategy">
  <metadata>
    <tier>solo</tier>
    <group>marketing</group>
    <domain>gtm-strategist</domain>
    <summary>Give-first strategy for IndieHackers: spend 2–4 weeks helping others, then build audience through transparent build-in-public updates (monthly revenue, wins, losses).</summary>
    <category>growth</category>
    <difficulty>intermediate</difficulty>
    <created>2026-04-26</created>
    <tags>
      <tag>indiehackers</tag>
      <tag>build-in-public</tag>
      <tag>community-marketing</tag>
      <tag>solopreneur</tag>
      <tag>bootstrapping</tag>
    </tags>
