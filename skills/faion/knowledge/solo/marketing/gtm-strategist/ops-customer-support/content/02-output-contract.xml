<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Customer Support Ops Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-customer-support.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "self_serve_assets",
    "sla_by_tier",
    "canned_reply_count",
    "review_cadence",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "self_serve_assets": {
      "type": "array"
    },
    "sla_by_tier": {
      "type": "object"
    },
    "canned_reply_count": {
      "type": "integer"
    },
    "review_cadence": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">self_serve_assets.length == 0 — violates r1</pattern>
      <pattern id="f2">sla_by_tier missing free|paid|enterprise — violates r2</pattern>
      <pattern id="f3">canned_reply_coverage_pct &lt; 60 — violates r3</pattern>
      <pattern id="f4">owner in plural roles — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ops-customer-support-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "self_serve_assets": [],
  "sla_by_tier": {},
  "canned_reply_count": 1,
  "review_cadence": "<review_cadence>",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "self_serve_assets": [],
  "sla_by_tier": {},
  "canned_reply_count": 1,
  "review_cadence": "<review_cadence>",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-ops-customer-support.py">Schema validator (stdlib only).</reference>
</text>
