<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Product Hunt Launch System Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-product-hunt-launch.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "pre_list_size",
    "hunter",
    "hunter_followers",
    "launch_datetime_pt",
    "assets",
    "engagement_sla_minutes",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "pre_list_size": {
      "type": "integer"
    },
    "hunter": {
      "type": "string"
    },
    "hunter_followers": {
      "type": "integer"
    },
    "launch_datetime_pt": {
      "type": "string"
    },
    "assets": {
      "type": "object"
    },
    "engagement_sla_minutes": {
      "type": "integer"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">pre_list_size &lt; 500 — violates r1</pattern>
      <pattern id="f2">hunter_followers &lt; 1000 — violates r2</pattern>
      <pattern id="f3">launch_datetime_pt outside Tue-Thu 00:01-02:00 PT — violates r3</pattern>
      <pattern id="f4">engagement_sla_minutes &gt; 60 — violates r4</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "growth-product-hunt-launch-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "pre_list_size": 1,
  "hunter": "<hunter>",
  "hunter_followers": 1,
  "launch_datetime_pt": "<launch_datetime_pt>",
  "assets": {},
  "engagement_sla_minutes": 1,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pre_list_size": 1,
  "hunter": "<hunter>",
  "hunter_followers": 1,
  "launch_datetime_pt": "<launch_datetime_pt>",
  "assets": {},
  "engagement_sla_minutes": 1,
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-growth-product-hunt-launch.py">Schema validator (stdlib only).</reference>
</text>
