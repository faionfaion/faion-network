<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Financial Planning Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-financial-planning.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "cash_balance_usd",
    "monthly_burn_usd",
    "runway_months",
    "projection_3m",
    "projection_12m",
    "reserve_pct",
    "reinvestment_pct",
    "founder_pay_pct",
    "tax_rate_pct",
    "next_review",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "cash_balance_usd": {
      "type": "number"
    },
    "monthly_burn_usd": {
      "type": "number"
    },
    "runway_months": {
      "type": "number"
    },
    "projection_3m": {
      "type": "array"
    },
    "projection_12m": {
      "type": "array"
    },
    "reserve_pct": {
      "type": "number"
    },
    "reinvestment_pct": {
      "type": "number"
    },
    "founder_pay_pct": {
      "type": "number"
    },
    "tax_rate_pct": {
      "type": "number"
    },
    "next_review": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">projection_3m.length != 3 — violates r1</pattern>
      <pattern id="f2">projection_12m.length != 12 — violates r1</pattern>
      <pattern id="f3">reserve_pct &lt; 20 — violates r3</pattern>
      <pattern id="f4">tax_rate_pct == 0 AND jurisdiction != &apos;tax_free&apos; — violates r6</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ops-financial-planning-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "cash_balance_usd": 1.0,
  "monthly_burn_usd": 1.0,
  "runway_months": 1.0,
  "projection_3m": [],
  "projection_12m": [],
  "reserve_pct": 1.0,
  "reinvestment_pct": 1.0,
  "founder_pay_pct": 1.0,
  "tax_rate_pct": 1.0,
  "next_review": "2026-05-23",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "cash_balance_usd": 1.0,
  "monthly_burn_usd": 1.0,
  "runway_months": 1.0,
  "projection_3m": [],
  "projection_12m": [],
  "reserve_pct": 1.0,
  "reinvestment_pct": 1.0,
  "founder_pay_pct": 1.0,
  "tax_rate_pct": 1.0,
  "next_review": "2026-05-23",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-ops-financial-planning.py">Schema validator (stdlib only).</reference>
</text>
