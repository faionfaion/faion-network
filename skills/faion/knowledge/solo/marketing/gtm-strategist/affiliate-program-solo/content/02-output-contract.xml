<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solo-Scale Affiliate Program Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/affiliate-program-solo.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "platform",
    "commission_pct",
    "cookie_days",
    "payout_cap_usd_month",
    "refund_clawback_days",
    "fraud_rules",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "platform": {
      "type": "string",
      "enum": [
        "lemonsqueezy",
        "gumroad",
        "rewardful",
        "stripe"
      ]
    },
    "commission_pct": {
      "type": "number"
    },
    "cookie_days": {
      "type": "integer"
    },
    "payout_cap_usd_month": {
      "type": "integer"
    },
    "refund_clawback_days": {
      "type": "integer"
    },
    "fraud_rules": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">commission_pct &gt; product_margin_pct — violates r2</pattern>
      <pattern id="f2">cookie_days &lt; 30 OR cookie_days &gt; 90 — violates r3</pattern>
      <pattern id="f3">fraud_rules.length == 0 — violates r4</pattern>
      <pattern id="f4">payout_cap_usd_month missing — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "affiliate-program-solo-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "platform": "lemonsqueezy",
  "commission_pct": 1.0,
  "cookie_days": 1,
  "payout_cap_usd_month": 1,
  "refund_clawback_days": 1,
  "fraud_rules": [],
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "platform": "lemonsqueezy",
  "commission_pct": 1.0,
  "cookie_days": 1,
  "payout_cap_usd_month": 1,
  "refund_clawback_days": 1,
  "fraud_rules": [],
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-affiliate-program-solo.py">Schema validator (stdlib only).</reference>
</text>
