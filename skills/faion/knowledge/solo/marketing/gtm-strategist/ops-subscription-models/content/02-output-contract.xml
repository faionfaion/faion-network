<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Subscription Models Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ops-subscription-models.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "model_type",
    "tiers",
    "metrics_instrumented",
    "dunning_config",
    "lifecycle_stages",
    "grandfather_months",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "model_type": {
      "type": "string",
      "enum": [
        "saas",
        "membership",
        "replenishment",
        "curation"
      ]
    },
    "tiers": {
      "type": "array"
    },
    "metrics_instrumented": {
      "type": "array"
    },
    "dunning_config": {
      "type": "object"
    },
    "lifecycle_stages": {
      "type": "array"
    },
    "grandfather_months": {
      "type": "integer"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">model_type missing OR not in enum — violates r1</pattern>
      <pattern id="f2">metrics_instrumented missing any of (mrr, churn_pct, ltv) — violates r3</pattern>
      <pattern id="f3">dunning_config.auto_retries &lt; 3 — violates r4</pattern>
      <pattern id="f4">grandfather_months &lt; 6 — violates r6</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "ops-subscription-models-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "model_type": "saas",
  "tiers": [],
  "metrics_instrumented": [],
  "dunning_config": {},
  "lifecycle_stages": [],
  "grandfather_months": 1,
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "model_type": "saas",
  "tiers": [],
  "metrics_instrumented": [],
  "dunning_config": {},
  "lifecycle_stages": [],
  "grandfather_months": 1,
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-ops-subscription-models.py">Schema validator (stdlib only).</reference>
</text>
