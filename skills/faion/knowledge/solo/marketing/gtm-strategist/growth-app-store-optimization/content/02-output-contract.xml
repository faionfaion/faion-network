<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="App Store Optimization (ASO) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/growth-app-store-optimization.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "app_id",
    "store",
    "keywords",
    "title",
    "subtitle",
    "screenshots_order",
    "review_prompt_trigger",
    "next_review",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "app_id": {
      "type": "string"
    },
    "store": {
      "type": "string",
      "enum": [
        "apple",
        "google"
      ]
    },
    "keywords": {
      "type": "array"
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "screenshots_order": {
      "type": "array"
    },
    "review_prompt_trigger": {
      "type": "string"
    },
    "next_review": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">keywords.length &lt; 5 OR keywords.length &gt; 10 — violates r2</pattern>
      <pattern id="f2">title does not start with highest-volume keyword — violates r3</pattern>
      <pattern id="f3">screenshots_order.length &lt; 3 — violates r4</pattern>
      <pattern id="f4">review_prompt_trigger == &apos;on_open&apos; — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "growth-app-store-optimization-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "app_id": "<app_id>",
  "store": "apple",
  "keywords": [],
  "title": "<title>",
  "subtitle": "<subtitle>",
  "screenshots_order": [],
  "review_prompt_trigger": "<review_prompt_trigger>",
  "next_review": "2026-05-23",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "app_id": "<app_id>",
  "store": "apple",
  "keywords": [],
  "title": "<title>",
  "subtitle": "<subtitle>",
  "screenshots_order": [],
  "review_prompt_trigger": "<review_prompt_trigger>",
  "next_review": "2026-05-23",
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-growth-app-store-optimization.py">Schema validator (stdlib only).</reference>
</text>
