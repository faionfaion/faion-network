<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Sunset Customer Comms Template Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Sunset Customer Comms Template output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="artefact_id" type="string" required="true">kebab-case slug</field>
      <field name="owner" type="string" required="true">named human</field>
      <field name="cause_sentence" type="string" required="true">one honest line</field>
      <field name="timeline" type="object" required="true">{announce_date, migration_window_days, v1_off_date}</field>
      <field name="migration_path" type="object" required="true">{primary: v2|competitor|refund, terms}</field>
      <field name="communication_channels" type="array" required="true">email + in-app + status-page</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">cause_sentence matches r'(exciting|new chapter|evolving|journey)' (case-insensitive)</pattern>
      <pattern id="f2">owner = 'team' / 'we'</pattern>
      <pattern id="f3">migration_path.primary missing</pattern>
      <pattern id="f4">timeline.migration_window_days &lt; 30</pattern>
      <pattern id="f5">communication_channels empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to mark migration_path.primary='hybrid' if v2 + competitor are both offered.</transformation>
      <transformation>Allowed to extend migration_window_days beyond 30 with no upper bound.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/sunset-customer-comms-template.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/sunset-customer-comms-template.json</item>
    </list>
  </section>
</text>
