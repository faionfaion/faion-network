<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="ICP Fit Scorecard Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routing tree mapping customer count, persona availability, signal coverage, and authority-to-act to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-root">Does the operator have ≥30 active customers, an ICP persona, and authority to act?</root-question>

    <branch when="customer_count &lt; 30 OR persona_missing == true OR authority_to_act == false">
      <conclusion ref="skip-this-methodology" verdict="SKIP — iterate qualitatively first"/>
    </branch>
    <branch when="signal_with_missing_evidence_count &gt; 0">
      <conclusion ref="r3-evidence-per-signal" verdict="BLOCK — attach evidence per signal"/>
    </branch>
    <branch when="row_total_mismatches_sum == true">
      <conclusion ref="r1-five-weighted-signals" verdict="BLOCK — total != sum of 5 signals"/>
    </branch>
    <branch when="any_row band='keep' AND total &lt; 70">
      <conclusion ref="r2-band-thresholds-fixed" verdict="BLOCK — band drift"/>
    </branch>
    <branch when="remove_rows_without_scheduled_action_count &gt; 0">
      <conclusion ref="r5-remove-action-executed" verdict="BLOCK — schedule sunset within 30 days"/>
    </branch>
    <branch when="histogram_missing == true">
      <conclusion ref="r6-histogram-published" verdict="BLOCK — publish histogram + median"/>
    </branch>
    <branch when="scored_at OLDER THAN 100 days">
      <conclusion ref="r4-quarterly-re-score" verdict="BLOCK — re-score book"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — scorecard ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — Applies-If preconditions not satisfied"/>
    </branch>
  </decision-tree>

  <example trace="icp-scorecard-happy-path">
    80 customers + persona doc + authority → all signals evidenced → totals correct → bands consistent → removes scheduled → histogram published → scored 30 days ago → APPROVE.
  </example>
</text>
