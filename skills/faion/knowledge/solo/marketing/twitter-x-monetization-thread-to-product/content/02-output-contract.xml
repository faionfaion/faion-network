<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Twitter X Monetization Thread To Product Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Twitter X Monetization Thread To Product output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="operator" type="string" required="true">named funnel owner</field>
      <field name="audience_signal" type="object" required="true">{evidence_urls, avg_impressions, validated_topic}</field>
      <field name="thread" type="object" required="true">7-tweet shape with email-gate CTA in tweet 7</field>
      <field name="email_gate_offer" type="object" required="true">{type, url, value_one_liner}</field>
      <field name="welcome_sequence" type="array" required="true">≥5 emails with day-offset</field>
      <field name="paid_product" type="object" required="true">{url, sku, price}</field>
      <field name="kpi_set" type="object" required="true">{thread_impressions, email_signups, paid_conversions, ltv}</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">audience_signal.evidence_urls count &lt; 3</pattern>
      <pattern id="f2">thread shape != funnel-mode 7-tweet</pattern>
      <pattern id="f3">email_gate_offer missing url</pattern>
      <pattern id="f4">welcome_sequence count &lt; 5</pattern>
      <pattern id="f5">paid_product missing OR price == 0</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to substitute pre-order URL for paid_product when product is mid-build.</transformation>
      <transformation>Allowed to extend welcome sequence beyond 5 emails.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/twitter-x-monetization-thread-to-product.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/twitter-x-monetization-thread-to-product.json</item>
    </list>
  </section>
</text>
