<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Launch Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/feature-launch-checklist.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "feature_name",
    "launch_date",
    "items",
    "channels",
    "success_metric",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "feature_name": {
      "type": "string"
    },
    "launch_date": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array"
    },
    "channels": {
      "type": "array"
    },
    "success_metric": {
      "type": "object"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">items.length &lt; 20 — violates r1</pattern>
      <pattern id="f2">owner in [&apos;team&apos;,&apos;we&apos;,&apos;everyone&apos;,&apos;&apos;] — violates r2</pattern>
      <pattern id="f3">channels.length &lt; 3 — violates r4</pattern>
      <pattern id="f4">success_metric.target empty OR success_metric.check_date missing — violates r5</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "feature-launch-checklist-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "feature_name": "<feature_name>",
  "launch_date": "2026-05-23",
  "items": [],
  "channels": [],
  "success_metric": {},
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "feature_name": "<feature_name>",
  "launch_date": "2026-05-23",
  "items": [],
  "channels": [],
  "success_metric": {},
  "owner": "team"
}
]]></code>
    <note>Invalid — owner is plural role and required fields stripped, demonstrating the forbidden patterns.</note>
  </example>

  <reference path="scripts/validate-feature-launch-checklist.py">Schema validator (stdlib only).</reference>
</text>
