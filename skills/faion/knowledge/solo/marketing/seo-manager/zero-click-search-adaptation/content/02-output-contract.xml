<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Zero-Click Search Adaptation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Zero-Click Search Adaptation output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="page_url" type="string" required="true">the canonical URL receiving the citation spec</field>
      <field name="target_query" type="string" required="true">the head query the page targets</field>
      <field name="owner" type="string" required="true">single named accountable owner (handle/email)</field>
      <field name="jsonld_article" type="object" required="true">valid schema.org Article JSON-LD</field>
      <field name="jsonld_faq" type="object" required="true">valid schema.org FAQPage JSON-LD (≥4 Q/A pairs)</field>
      <field name="lede_rewrite" type="string" required="true">40-60 word direct answer, first paragraph</field>
      <field name="original_data_points" type="array" required="true">≥3 stats with value+year+source</field>
      <field name="kpi_set" type="object" required="true">impressions, branded_queries, ai_citation_rate, on_serp_actions</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO-8601 date</field>
    </required>

    <forbidden>
      <pattern id="f1">owner is 'team' / 'we' / 'us' / empty</pattern>
      <pattern id="f2">kpi_set contains only 'sessions'</pattern>
      <pattern id="f3">FAQ JSON-LD references questions not visible in rendered DOM</pattern>
      <pattern id="f4">lede outside 40-60 word band</pattern>
      <pattern id="f5">data points without year + source</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Trim lede to ≤60 words preserving the direct answer.</transformation>
      <transformation>Allowed to mark a page status='research-only' if original_data_points empty.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/zero-click-search-adaptation.json"/>
  </output-contract>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/zero-click-search-adaptation.json</item>
    </list>
  </section>
</text>
