<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Daily Ship Rubric Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Daily Ship Rubric output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="date" type="date" required="true">ISO date</field>
      <field name="operator" type="string" required="true">named human</field>
      <field name="backlog_item" type="string" required="true">task id</field>
      <field name="gates" type="object" required="true">5 binary gates: spec/code/tests/deploy/customer_visible</field>
      <field name="verdict" type="string" required="true">ship | no-ship</field>
      <field name="note" type="string" required="true">≤200 char free-text</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">gates length != 5</pattern>
      <pattern id="f2">any gate value not in {true, false}</pattern>
      <pattern id="f3">operator ∈ {me, we, us, team}</pattern>
      <pattern id="f4">verdict not in {ship, no-ship}</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to flag a day as 'maintenance' (rubric not applied) up to twice per week.</transformation>
      <transformation>Allowed to substitute deploy gate with 'preview-environment-live' for FE-only ships.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/daily-ship-rubric.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "date": "2026-05-23",
  "operator": "sample-operator",
  "backlog_item": "sample-backlog_item",
  "gates": {
    "k": "v"
  },
  "verdict": "sample-verdict",
  "note": "sample-note",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/daily-ship-rubric.json</item>
    </list>
  </section>
</text>
