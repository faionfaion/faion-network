<text id="04-procedure" title="Writing Implementation Plans Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Writing Implementation Plans end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="walk-design">
      <input>design.md</input>
      <action>Walk AD-X list; allocate task rows per AD.</action>
      <output>Draft rows</output>
    </step>

    <step n="2" name="size-and-route">
      <input>Draft rows</input>
      <action>Estimate est_tokens + assign owner-model.</action>
      <output>Sized rows</output>
    </step>

    <step n="3" name="acceptance-criteria">
      <input>Sized rows</input>
      <action>Add AC per row.</action>
      <output>Rows with AC</output>
    </step>

    <step n="4" name="wave-grouping">
      <input>Rows with AC</input>
      <action>Run task-creation-parallelization rules to assign waves.</action>
      <output>Waved rows</output>
    </step>

    <step n="5" name="budget-check">
      <input>Waved rows</input>
      <action>Sum est_tokens; ensure ≤ cap.</action>
      <output>Budget OK</output>
    </step>

    <step n="6" name="validate">
      <input>Full plan</input>
      <action>Run scripts/validate-writing-implementation-plans.py.</action>
      <output>Validated impl-plan.md</output>
    </step>

  </section>
</text>
