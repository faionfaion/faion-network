<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Docs at Big Tech Companies Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Design Docs at Big Tech Companies output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="doc_format" type="string" required="true">RFC | ERD | 6-Pager | ADR | Custom</field>
      <field name="scope" type="string" required="true">small | team | cross-org</field>
      <field name="audience" type="array" required="true">named roles</field>
      <field name="page_budget" type="integer" required="true">1..10</field>
      <field name="review_deadline" type="date" required="true">ISO date</field>
      <field name="alternatives" type="array" required="true">≥2 including 'do nothing'</field>
      <field name="owner" type="string" required="true">named author</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">doc_format not in allowed set</pattern>
      <pattern id="f2">alternatives missing 'do nothing'</pattern>
      <pattern id="f3">page_budget &gt; 10 OR &lt; 1</pattern>
      <pattern id="f4">review_deadline missing</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to chain ADRs out of a heavyweight RFC once decisions are accepted.</transformation>
      <transformation>Allowed to extend page budget by +2 pages when cross-org review surfaces unanticipated dependencies.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/design-docs-big-tech.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "doc_format": "sample-doc_format",
  "scope": "sample-scope",
  "audience": [
    {
      "k": "v"
    }
  ],
  "page_budget": 3,
  "review_deadline": "2026-05-23",
  "alternatives": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/design-docs-big-tech.json</item>
    </list>
  </section>
</text>
