<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Backlog Grooming and Roadmapping Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Backlog Grooming and Roadmapping output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="backlog_items" type="array" required="true">≥10 with score + rationale + status</field>
      <field name="p0_items" type="array" required="true">≤3</field>
      <field name="scoring_framework" type="string" required="true">RICE | MoSCoW</field>
      <field name="now_items" type="array" required="true">currently in flight</field>
      <field name="next_items" type="array" required="true">next horizon</field>
      <field name="later_items" type="array" required="true">later horizon</field>
      <field name="last_groomed_at" type="datetime" required="true">ISO datetime</field>
      <field name="owner" type="string" required="true">named PM</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">p0_items length &gt; 3</pattern>
      <pattern id="f2">any backlog item without rationale</pattern>
      <pattern id="f3">AI-generated score without [estimate] flag</pattern>
      <pattern id="f4">any item with explicit date instead of Now/Next/Later horizon</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to demote a P0 to P1 when capacity is unavailable for the cycle.</transformation>
      <transformation>Allowed to merge two adjacent backlog items when they share acceptance criteria and owner.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/backlog-grooming-roadmapping.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "backlog_items": [
    {
      "k": "v"
    }
  ],
  "p0_items": [
    {
      "k": "v"
    }
  ],
  "scoring_framework": "sample-scoring_framework",
  "now_items": [
    {
      "k": "v"
    }
  ],
  "next_items": [
    {
      "k": "v"
    }
  ],
  "later_items": [
    {
      "k": "v"
    }
  ],
  "last_groomed_at": "2026-05-23T12:00:00Z",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/backlog-grooming-roadmapping.json</item>
    </list>
  </section>
</text>
