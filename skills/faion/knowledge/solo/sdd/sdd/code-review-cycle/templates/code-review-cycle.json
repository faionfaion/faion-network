{
  "__faion_header__": {
    "purpose": "JSON Schema for the Code Review Cycle output contract",
    "consumes": "subagent-produced artefact JSON",
    "produces": "validation verdict (pass/fail with violations)",
    "depends-on": "content/02-output-contract.xml",
    "token-budget-impact": "~300 tokens"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.network/schema/code-review-cycle.json",
  "title": "Code Review Cycle Output Contract",
  "type": "object",
  "required": [
    "pr_id",
    "prescreen_findings",
    "reviewer_findings",
    "merged_findings",
    "block_count",
    "reflexion_writeback",
    "verdict",
    "owner",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "pr_id": {
      "type": "string",
      "description": "PR or branch id"
    },
    "prescreen_findings": {
      "type": "array",
      "description": "AI pre-screen list",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "reviewer_findings": {
      "type": "array",
      "description": "parallel reviewer findings",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "merged_findings": {
      "type": "array",
      "description": "deduplicated unified list",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "block_count": {
      "type": "integer",
      "description": "count of BLOCK findings"
    },
    "reflexion_writeback": {
      "type": "array",
      "description": "{file, entry} pairs written to memory",
      "items": {
        "type": "object"
      },
      "minItems": 1
    },
    "verdict": {
      "type": "string",
      "description": "merge-ready | block-on-human"
    },
    "owner": {
      "type": "string",
      "description": "named human reviewer"
    },
    "version": {
      "type": "string",
      "description": "semver"
    },
    "last_reviewed": {
      "type": "string",
      "description": "ISO date",
      "format": "date"
    }
  },
  "additionalProperties": true
}
