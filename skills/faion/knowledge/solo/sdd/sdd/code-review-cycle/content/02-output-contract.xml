<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Code Review Cycle Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Code Review Cycle output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="pr_id" type="string" required="true">PR or branch id</field>
      <field name="prescreen_findings" type="array" required="true">AI pre-screen list</field>
      <field name="reviewer_findings" type="array" required="true">parallel reviewer findings</field>
      <field name="merged_findings" type="array" required="true">deduplicated unified list</field>
      <field name="block_count" type="integer" required="true">count of BLOCK findings</field>
      <field name="reflexion_writeback" type="array" required="true">{file, entry} pairs written to memory</field>
      <field name="verdict" type="string" required="true">merge-ready | block-on-human</field>
      <field name="owner" type="string" required="true">named human reviewer</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">verdict == merge-ready AND block_count &gt; 0</pattern>
      <pattern id="f2">any finding without severity OR line ref</pattern>
      <pattern id="f3">reflexion_writeback empty when novel findings exist</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to downgrade WARN to NOTE when finding cites a pattern already in patterns.md with confidence ≥0.8.</transformation>
      <transformation>Allowed to defer reflexion writeback by ≤24h when memory file is locked by another session.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/code-review-cycle.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "pr_id": "sample-pr_id",
  "prescreen_findings": [
    {
      "k": "v"
    }
  ],
  "reviewer_findings": [
    {
      "k": "v"
    }
  ],
  "merged_findings": [
    {
      "k": "v"
    }
  ],
  "block_count": 3,
  "reflexion_writeback": [
    {
      "k": "v"
    }
  ],
  "verdict": "sample-verdict",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/code-review-cycle.json</item>
    </list>
  </section>
</text>
