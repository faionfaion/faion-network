<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mistake Memory Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Mistake Memory output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="mistake_id" type="string" required="true">stable id (MM-001..)</field>
      <field name="severity" type="string" required="true">low | medium | high | critical</field>
      <field name="what_happened" type="string" required="true">≤500 chars</field>
      <field name="five_whys" type="array" required="true">≥3 levels</field>
      <field name="prevention" type="string" required="true">concrete action</field>
      <field name="ci_rule_created" type="boolean" required="true">true on second occurrence</field>
      <field name="occurrence_count" type="integer" required="true">≥1</field>
      <field name="owner" type="string" required="true">named author</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">five_whys length &lt; 3</pattern>
      <pattern id="f2">prevention matches /be careful|pay attention|remember/i</pattern>
      <pattern id="f3">occurrence_count &gt; 1 AND ci_rule_created == false</pattern>
      <pattern id="f4">severity not in allowed set</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to merge two mistakes when root causes share the same Why-3 layer.</transformation>
      <transformation>Allowed to mark a mistake as superseded when its CI rule has prevented occurrence for 90 days.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/mistake-memory.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "mistake_id": "sample-mistake_id",
  "severity": "sample-severity",
  "what_happened": "sample-what_happened",
  "five_whys": [
    {
      "k": "v"
    }
  ],
  "prevention": "sample-prevention",
  "ci_rule_created": true,
  "occurrence_count": 3,
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/mistake-memory.json</item>
    </list>
  </section>
</text>
