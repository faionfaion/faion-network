<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="API-First Development Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid API-First Development output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="openapi_spec_path" type="string" required="true">path to openapi.yaml</field>
      <field name="openapi_version" type="string" required="true">must start with 3.1</field>
      <field name="endpoints" type="array" required="true">list of {path, method, op_id}</field>
      <field name="mock_server_url" type="string" required="true">Prism mock URL</field>
      <field name="contract_test_config" type="string" required="true">path to schemathesis.yaml or equivalent</field>
      <field name="version" type="string" required="true">semver of the API itself</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">openapi_version not starting with '3.1'</pattern>
      <pattern id="f2">endpoints empty</pattern>
      <pattern id="f3">contract_test_config missing</pattern>
      <pattern id="f4">mock_server_url empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to inline small examples into the spec where the schema is non-obvious.</transformation>
      <transformation>Allowed to mark endpoints as x-faion-internal when not shipped to public clients.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/api-first-development.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "openapi_spec_path": "sample-openapi_spec_path",
  "openapi_version": "sample-openapi_version",
  "endpoints": [
    {
      "k": "v"
    }
  ],
  "mock_server_url": "sample-mock_server_url",
  "contract_test_config": "sample-contract_test_config",
  "version": "1.1.0",
  "owner": "ruslan@faion.net",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/api-first-development.json</item>
    </list>
  </section>
</text>
