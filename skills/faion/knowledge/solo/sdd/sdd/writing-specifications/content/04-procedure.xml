<text id="04-procedure" title="Writing Specifications (SDD core) Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Writing Specifications (SDD core) end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="load-context">
      <input>Constitution + done specs</input>
      <action>Read constitution + 3 done specs for pattern.</action>
      <output>Context</output>
    </step>

    <step n="2" name="problem-statement">
      <input>Stakeholder input</input>
      <action>Author one-paragraph WHO/WHAT/WHY/IMPACT.</action>
      <output>Problem statement</output>
    </step>

    <step n="3" name="personas">
      <input>Research notes</input>
      <action>Author ≥2 personas.</action>
      <output>Personas</output>
    </step>

    <step n="4" name="user-stories">
      <input>Personas</input>
      <action>Author story map; assign US-X ids.</action>
      <output>Story map</output>
    </step>

    <step n="5" name="requirements">
      <input>Story map</input>
      <action>Author FR-X (SMART) + NFR-X rows.</action>
      <output>Requirements</output>
    </step>

    <step n="6" name="acs">
      <input>Requirements</input>
      <action>Add Given-When-Then AC-X for every FR.</action>
      <output>ACs</output>
    </step>

    <step n="7" name="scope">
      <input>Requirements + ACs</input>
      <action>Author explicit In-scope + Out-of-scope.</action>
      <output>Scope</output>
    </step>

    <step n="8" name="validate">
      <input>Full spec</input>
      <action>Run scripts/validate-writing-specifications.py.</action>
      <output>Validated spec.md</output>
    </step>

  </section>
</text>
