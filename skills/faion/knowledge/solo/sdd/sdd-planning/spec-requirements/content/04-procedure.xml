<text id="04-procedure" title="Spec Requirements Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Spec Requirements end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="extract-from-discovery">
      <input>Discovery output</input>
      <action>Pull candidate requirements.</action>
      <output>Raw list</output>
    </step>
    <step n="2" name="number-and-classify">
      <input>Raw list + FR/NFR taxonomy</input>
      <action>Assign FR-NNN or NFR-NNN.</action>
      <output>Numbered list</output>
    </step>
    <step n="3" name="split-multi-sentence">
      <input>Numbered list</input>
      <action>Atomic single-sentence requirements.</action>
      <output>Atomic list</output>
    </step>
    <step n="4" name="add-verification">
      <input>Atomic list + verification catalogue</input>
      <action>Attach verification method per requirement.</action>
      <output>Verifiable list</output>
    </step>
    <step n="5" name="set-priority">
      <input>Verifiable list + MoSCoW rubric</input>
      <action>Priority per requirement.</action>
      <output>Prioritised list</output>
    </step>
    <step n="6" name="lint-vague">
      <input>Prioritised list + vague-token list</input>
      <action>Rewrite vague language.</action>
      <output>Lint-clean list</output>
    </step>
    <step n="7" name="publish">
      <input>Lint-clean list</input>
      <action>Emit artefact JSON.</action>
      <output>Final requirements</output>
    </step>

  </section>
</text>
