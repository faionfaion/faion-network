<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Spec Requirements Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spec-requirements.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "requirements",
    "frs_count",
    "nfrs_count",
    "vague_tokens_found",
    "orphan_requirements",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "requirements": {
      "type": "array"
    },
    "frs_count": {
      "type": "integer"
    },
    "nfrs_count": {
      "type": "integer"
    },
    "vague_tokens_found": {
      "type": "array"
    },
    "orphan_requirements": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">any requirement without id (FR-NNN or NFR-NNN).</pattern>
      <pattern id="f2">any requirement without verification_method.</pattern>
      <pattern id="f3">vague_tokens_found non-empty AND artefact submitted as final.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "spec-requirements-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "requirements": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "frs_count": 1,
  "nfrs_count": 1,
  "vague_tokens_found": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "orphan_requirements": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-spec-requirements.py">Schema validator (stdlib only).</reference>
</text>
