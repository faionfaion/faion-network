<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Doc Structure Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-doc-structure.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "spec_path",
    "context",
    "design",
    "alternatives",
    "risks",
    "rollout",
    "adrs_cited",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "spec_path": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "design": {
      "type": "string"
    },
    "alternatives": {
      "type": "array"
    },
    "risks": {
      "type": "array"
    },
    "rollout": {
      "type": "object"
    },
    "adrs_cited": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">any of context/design/alternatives/risks/rollout is empty string or empty array.</pattern>
      <pattern id="f2">alternatives has 0 entries — must be ≥1 (with rejection) or explicit N/A.</pattern>
      <pattern id="f3">risks entry without mitigation field.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-doc-structure-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "spec_path": "spec_path value",
  "context": "context value",
  "design": "design value",
  "alternatives": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "risks": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "rollout": {
    "key": "value"
  },
  "adrs_cited": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-design-doc-structure.py">Schema validator (stdlib only).</reference>
</text>
