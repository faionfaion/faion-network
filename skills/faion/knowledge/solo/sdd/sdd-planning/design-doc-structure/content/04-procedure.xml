<text id="04-procedure" title="Design Doc Structure Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Design Doc Structure end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="read-upstream">
      <input>spec.md + ADRs</input>
      <action>Extract context, decisions, and constraints.</action>
      <output>Notes</output>
    </step>
    <step n="2" name="draft-context">
      <input>Notes</input>
      <action>Write context section with problem statement.</action>
      <output>Context section</output>
    </step>
    <step n="3" name="draft-design">
      <input>Notes + ADR citations</input>
      <action>Write proposed design with AD-X references.</action>
      <output>Design section</output>
    </step>
    <step n="4" name="draft-alternatives">
      <input>Brainstorm shortlist</input>
      <action>Write ≥1 alternative with rejection reason.</action>
      <output>Alternatives section</output>
    </step>
    <step n="5" name="draft-risks">
      <input>Threat-model + ops constraints</input>
      <action>Each risk + mitigation OR accept-risk owner.</action>
      <output>Risks section</output>
    </step>
    <step n="6" name="draft-rollout">
      <input>Ops SLO + rollback budget</input>
      <action>Steps + rollback OR &apos;no rollback&apos; rationale.</action>
      <output>Rollout section</output>
    </step>
    <step n="7" name="review-and-sign">
      <input>Full draft + reviewer list</input>
      <action>Reviewer signs off; artefact JSON emitted.</action>
      <output>Signed design doc</output>
    </step>

  </section>
</text>
