<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Impl Plan 100k Rule Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Impl Plan 100k Rule end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="read-task">
      <input>TASK_*.md</input>
      <action>Parse inputs and intended outputs.</action>
      <output>Task context</output>
    </step>
    <step n="2" name="estimate">
      <input>Task context + formula</input>
      <action>Compute est_tokens.</action>
      <output>Estimate</output>
    </step>
    <step n="3" name="check-cap">
      <input>Estimate</input>
      <action>Compare against 100k cap.</action>
      <output>Cap status</output>
    </step>
    <step n="4" name="split-if-over">
      <input>Oversized task</input>
      <action>Decompose into ≤100k atomic tasks.</action>
      <output>Sub-tasks</output>
    </step>
    <step n="5" name="record">
      <input>Estimates + cap status</input>
      <action>Update front-matter and emit artefact JSON.</action>
      <output>Updated TASK files</output>
    </step>

  </section>
</text>
