<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Impl Plan 100k Rule Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/impl-plan-100k-rule.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "task_id",
    "est_tokens",
    "cap_exceeded",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "task_id": {
      "type": "string"
    },
    "est_tokens": {
      "type": "integer"
    },
    "actual_tokens": {
      "type": "integer"
    },
    "cap_exceeded": {
      "type": "boolean"
    },
    "split_into": {
      "type": "array"
    },
    "exception_reason": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">est_tokens &gt; 100000 AND exception_reason != &apos;deep-research&apos;.</pattern>
      <pattern id="f2">est_tokens missing — required field.</pattern>
      <pattern id="f3">cap_exceeded == true AND split_into is empty.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "impl-plan-100k-rule-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "task_id": "task_id value",
  "est_tokens": 1,
  "actual_tokens": 1,
  "cap_exceeded": true,
  "split_into": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "exception_reason": "exception_reason value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-impl-plan-100k-rule.py">Schema validator (stdlib only).</reference>
</text>
