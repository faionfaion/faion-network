<methodology slug="design-doc-advanced-patterns">
  <metadata>
    <tier>solo</tier>
    <group>sdd</group>
    <domain>sdd-planning</domain>
    <summary>Advanced design sections: component hierarchy, dependencies, security, performance, test pyramid, migrations. Each section traces back to spec requirements.</summary>
    <tags>
      <tag>design-doc</tag>
      <tag>architecture</tag>
      <tag>advanced-patterns</tag>
      <tag>security</tag>
      <tag>performance</tag>
    </tags>
    <category>design</category>
