<text id="04-procedure" title="Impl Plan Components Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Impl Plan Components end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Repo structure</input>
      <action>List every component (file, module, service).</action>
      <output>Components list</output>
    </step>
    <step n="2" name="map-tasks">
      <input>TASK files + components</input>
      <action>Map each TASK to one primary component.</action>
      <output>Task-component map</output>
    </step>
    <step n="3" name="dependency-edges">
      <input>Task-component map</input>
      <action>List upstream-component edges per task.</action>
      <output>Edge list</output>
    </step>
    <step n="4" name="build-graph">
      <input>Edge list</input>
      <action>Construct adjacency list; check for cycles.</action>
      <output>Graph + cycle report</output>
    </step>
    <step n="5" name="assign-owners">
      <input>Components + team</input>
      <action>Each component gets ≥1 owner.</action>
      <output>Owner map</output>
    </step>
    <step n="6" name="emit">
      <input>All previous outputs</input>
      <action>Produce artefact JSON.</action>
      <output>Components plan</output>
    </step>

  </section>
</text>
