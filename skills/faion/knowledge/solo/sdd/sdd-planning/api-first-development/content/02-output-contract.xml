<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="API-First Development Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/api-first-development.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "spec_path",
    "openapi_version",
    "operation_ids",
    "lint_status",
    "breaking_changes",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "spec_path": {
      "type": "string"
    },
    "openapi_version": {
      "type": "string"
    },
    "operation_ids": {
      "type": "array"
    },
    "lint_status": {
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "mock_server_url": {
      "type": "string"
    },
    "breaking_changes": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">openapi_version starts with &apos;3.0&apos; — methodology mandates 3.1+.</pattern>
      <pattern id="f2">operation_ids array is empty OR contains duplicate entries.</pattern>
      <pattern id="f3">lint_status == &apos;fail&apos; AND artefact submitted as final.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "api-first-development-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "spec_path": "spec_path value",
  "openapi_version": "openapi_version value",
  "operation_ids": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "lint_status": "pass",
  "mock_server_url": "mock_server_url value",
  "breaking_changes": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-api-first-development.py">Schema validator (stdlib only).</reference>
</text>
