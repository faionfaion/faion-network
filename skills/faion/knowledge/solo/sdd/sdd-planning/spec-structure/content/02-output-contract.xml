<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Spec Structure Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spec-structure.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "problem",
    "users",
    "goals",
    "non_goals",
    "requirements",
    "acceptance_criteria",
    "open_questions",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "problem": {
      "type": "string"
    },
    "users": {
      "type": "array"
    },
    "goals": {
      "type": "array"
    },
    "non_goals": {
      "type": "array"
    },
    "requirements": {
      "type": "array"
    },
    "acceptance_criteria": {
      "type": "array"
    },
    "open_questions": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">non_goals array has &lt; 2 entries.</pattern>
      <pattern id="f2">open_questions is empty — must contain ≥1 entry or explicit &apos;none&apos;.</pattern>
      <pattern id="f3">any required field empty string or empty array (except open_questions can be [&apos;none&apos;]).</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "spec-structure-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "problem": "problem value",
  "users": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "goals": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "non_goals": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "requirements": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "acceptance_criteria": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "open_questions": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-spec-structure.py">Schema validator (stdlib only).</reference>
</text>
