<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Spec Structure Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Spec Structure end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="copy-skeleton">
      <input>templates/spec.md</input>
      <action>Start from skeleton.</action>
      <output>Empty spec</output>
    </step>
    <step n="2" name="draft-problem-users">
      <input>Discovery output + persona</input>
      <action>Fill Problem + Users.</action>
      <output>Top sections</output>
    </step>
    <step n="3" name="draft-goals-non-goals">
      <input>Discovery + business context</input>
      <action>Fill Goals + ≥2 Non-goals.</action>
      <output>Goals section</output>
    </step>
    <step n="4" name="draft-requirements">
      <input>Discovery + spec-requirements format</input>
      <action>Numbered FR/NFR list.</action>
      <output>Requirements section</output>
    </step>
    <step n="5" name="draft-ac">
      <input>Requirements + AC rubric</input>
      <action>Binary AC per requirement.</action>
      <output>AC section</output>
    </step>
    <step n="6" name="draft-open-questions">
      <input>Outstanding ambiguity</input>
      <action>≥1 question or &apos;none&apos;.</action>
      <output>Open Questions</output>
    </step>
    <step n="7" name="lint-and-cap">
      <input>Full spec + one-page rule</input>
      <action>Validate length + sections.</action>
      <output>Final spec</output>
    </step>

  </section>
</text>
