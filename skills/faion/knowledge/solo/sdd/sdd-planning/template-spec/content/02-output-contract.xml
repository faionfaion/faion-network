<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Template Spec Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/template-spec.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "template_path",
    "sections_locked",
    "lint_status",
    "quarterly_review_date",
    "back_compat_window_days",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "template_path": {
      "type": "string"
    },
    "sections_locked": {
      "type": "array"
    },
    "lint_status": {
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "quarterly_review_date": {
      "type": "string",
      "format": "date"
    },
    "back_compat_window_days": {
      "type": "integer"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">lint_status == &apos;fail&apos; AND template shipped.</pattern>
      <pattern id="f2">back_compat_window_days &lt; 30 on a major bump.</pattern>
      <pattern id="f3">quarterly_review_date older than 100 days.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "template-spec-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "template_path": "template_path value",
  "sections_locked": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "lint_status": "pass",
  "quarterly_review_date": "2026-05-23",
  "back_compat_window_days": 1,
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-template-spec.py">Schema validator (stdlib only).</reference>
</text>
