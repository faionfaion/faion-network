<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Architecture Decision Records Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/architecture-decision-records.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "adr_number",
    "title",
    "status",
    "context",
    "decision",
    "alternatives",
    "consequences",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "adr_number": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "Proposed",
        "Accepted",
        "Deprecated",
        "Superseded"
      ]
    },
    "context": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "alternatives": {
      "type": "array"
    },
    "consequences": {
      "type": "object"
    },
    "related_adrs": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">alternatives.length &lt; 2 — methodology requires ≥2 considered alternatives.</pattern>
      <pattern id="f2">status not in {Proposed, Accepted, Deprecated, Superseded}.</pattern>
      <pattern id="f3">consequences object missing any of positive/negative/neutral keys.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "architecture-decision-records-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "adr_number": 1,
  "title": "title value",
  "status": "Proposed",
  "context": "context value",
  "decision": "decision value",
  "alternatives": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "consequences": {
    "key": "value"
  },
  "related_adrs": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-architecture-decision-records.py">Schema validator (stdlib only).</reference>
</text>
