<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Doc Writing Process Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-doc-writing-process.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "doc_path",
    "passes_completed",
    "reviewer",
    "review_sla_hours",
    "comments_total",
    "comments_resolved",
    "sign_off",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "doc_path": {
      "type": "string"
    },
    "passes_completed": {
      "type": "array"
    },
    "reviewer": {
      "type": "string"
    },
    "review_sla_hours": {
      "type": "integer"
    },
    "comments_total": {
      "type": "integer"
    },
    "comments_resolved": {
      "type": "integer"
    },
    "sign_off": {
      "type": "object"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">passes_completed does not contain all of {skeleton, draft, review, sign-off}.</pattern>
      <pattern id="f2">comments_resolved &lt; comments_total — open comments block sign-off.</pattern>
      <pattern id="f3">sign_off object missing author or reviewer handle.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-doc-writing-process-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "doc_path": "doc_path value",
  "passes_completed": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "reviewer": "reviewer value",
  "review_sla_hours": 1,
  "comments_total": 1,
  "comments_resolved": 1,
  "sign_off": {
    "key": "value"
  },
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-design-doc-writing-process.py">Schema validator (stdlib only).</reference>
</text>
