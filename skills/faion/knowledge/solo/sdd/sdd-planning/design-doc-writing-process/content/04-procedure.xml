<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Design Doc Writing Process Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Design Doc Writing Process end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="assign-reviewer">
      <input>Reviewer list</input>
      <action>Assign reviewer + SLA at start.</action>
      <output>Reviewer assignment</output>
    </step>
    <step n="2" name="pass1-skeleton">
      <input>templates/design-doc.md</input>
      <action>Insert headings + section stubs.</action>
      <output>Skeleton draft</output>
    </step>
    <step n="3" name="pass2-draft">
      <input>Skeleton + spec.md + ADRs</input>
      <action>Fill sections.</action>
      <output>Full draft</output>
    </step>
    <step n="4" name="pass3-review">
      <input>Full draft + reviewer</input>
      <action>Reviewer adds comments inline.</action>
      <output>Reviewed draft</output>
    </step>
    <step n="5" name="pass4-resolve">
      <input>Reviewed draft + comments</input>
      <action>Resolve every comment; emit final artefact JSON.</action>
      <output>Signed design doc</output>
    </step>

  </section>
</text>
