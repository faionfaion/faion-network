<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Task Creation Principles Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Task Creation Principles end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="read-task">
      <input>TASK_*.md</input>
      <action>Parse front-matter + body.</action>
      <output>Task context</output>
    </step>
    <step n="2" name="check-atomic">
      <input>Task context</input>
      <action>Verify primary component.</action>
      <output>Atomic pass/fail</output>
    </step>
    <step n="3" name="check-testable">
      <input>Acceptance section</input>
      <action>Verify ≥1 binary check.</action>
      <output>Testable pass/fail</output>
    </step>
    <step n="4" name="check-owned">
      <input>Front-matter</input>
      <action>Verify owner handle.</action>
      <output>Owned pass/fail</output>
    </step>
    <step n="5" name="check-estimated">
      <input>Front-matter</input>
      <action>Verify est_tokens populated and ≤ 100k.</action>
      <output>Estimated pass/fail</output>
    </step>
    <step n="6" name="emit-rubric">
      <input>All checks</input>
      <action>Produce artefact JSON.</action>
      <output>Rubric artefact</output>
    </step>

  </section>
</text>
