<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Impl Plan Task Format Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/impl-plan-task-format.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "task_id",
    "task_slug",
    "est_tokens",
    "status",
    "component",
    "depends_on",
    "acceptance",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "task_id": {
      "type": "string"
    },
    "task_slug": {
      "type": "string"
    },
    "est_tokens": {
      "type": "integer"
    },
    "status": {
      "enum": [
        "todo",
        "in-progress",
        "done",
        "blocked"
      ]
    },
    "component": {
      "type": "string"
    },
    "depends_on": {
      "type": "array"
    },
    "acceptance": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">task_slug contains capital letters or spaces.</pattern>
      <pattern id="f2">acceptance is empty array — must have ≥1 binary check.</pattern>
      <pattern id="f3">est_tokens missing or &gt; 100000.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "impl-plan-task-format-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "task_id": "task_id value",
  "task_slug": "task_slug value",
  "est_tokens": 1,
  "status": "todo",
  "component": "component value",
  "depends_on": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "acceptance": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-impl-plan-task-format.py">Schema validator (stdlib only).</reference>
</text>
