<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Impl Plan Task Format Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Impl Plan Task Format end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="copy-skeleton">
      <input>templates/TASK_skeleton.md</input>
      <action>Copy and rename TASK_NNN-slug.md.</action>
      <output>Empty TASK</output>
    </step>
    <step n="2" name="fill-front-matter">
      <input>Empty TASK + impl-plan</input>
      <action>Fill id, est_tokens, status, depends_on, owner, component.</action>
      <output>Front-matter complete</output>
    </step>
    <step n="3" name="draft-body">
      <input>Front-matter + design.md</input>
      <action>Fill Goal/Inputs/Steps/Acceptance/Notes.</action>
      <output>Body draft</output>
    </step>
    <step n="4" name="lint">
      <input>Body draft + lint script</input>
      <action>Run validator; fix any rejections.</action>
      <output>Linted TASK</output>
    </step>
    <step n="5" name="commit">
      <input>Linted TASK</input>
      <action>Add to impl-plan directory.</action>
      <output>Committed TASK</output>
    </step>

  </section>
</text>
