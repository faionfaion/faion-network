<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Negotiation and Persuasion Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-batna">BATNA concrete (name + value)?</root-question>

    <branch when="batna_concrete == false">
      <conclusion ref="batna-computed" verdict="halt — define BATNA before any negotiation"/>
    </branch>

    <branch when="batna_concrete == true">
      <question id="q-zopa">ZOPA positive (their_reserve >= my_reserve)?</question>
      <branch when="zopa_positive == false">
        <conclusion ref="zopa-checked" verdict="change scope or walk; no deal possible at current reserves"/>
      </branch>
      <branch when="zopa_positive == true">
        <question id="q-criteria">objective criteria cited?</question>
        <branch when="criteria_cited == false">
          <conclusion ref="objective-criteria" verdict="find external benchmark before anchoring"/>
        </branch>
        <branch when="criteria_cited == true">
          <conclusion ref="cialdini-honest" verdict="select honest levers + rehearse anchor"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="saas-renewal-prep">
    batna_concrete=true → zopa_positive=true → criteria_cited=true → conclusion cialdini-honest → prep brief validated.
  </example>
</text>
