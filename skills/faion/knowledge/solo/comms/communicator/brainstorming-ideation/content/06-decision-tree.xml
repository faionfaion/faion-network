<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Brainstorming Ideation (Agentic Pipeline) Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-personas">personas.count >= 3?</root-question>

    <branch when="persona_count_ok == false">
      <conclusion ref="persona-injection-3-to-5" verdict="add personas until count >=3 before generating; halt pipeline"/>
    </branch>

    <branch when="persona_count_ok == true">
      <question id="q-raw-count">raw_count >= 30 after divergence?</question>
      <branch when="raw_count_ok == false">
        <conclusion ref="persona-injection-3-to-5" verdict="add another branch (Reverse) or persona and rerun divergence"/>
      </branch>
      <branch when="raw_count_ok == true">
        <question id="q-cluster-band">cluster count in [3..7]?</question>
        <branch when="cluster_count_in_band == false">
          <conclusion ref="cluster-3-to-7" verdict="recluster with k=3..7"/>
        </branch>
        <branch when="cluster_count_in_band == true">
          <conclusion ref="impact-effort-score" verdict="score shortlist + emit with provenance"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-inbox-pipeline">
    persona_count_ok=true (3 personas) → raw_count_ok=true (78) → cluster_count_in_band=true (4 themes) → conclusion impact-effort-score → emit shortlist.
  </example>
</text>
