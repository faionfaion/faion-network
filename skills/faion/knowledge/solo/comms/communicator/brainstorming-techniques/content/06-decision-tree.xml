<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Brainstorming Techniques Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-shape">problem shape == generate-broadly or risk-surface?</root-question>

    <branch when="shape == risk-surface">
      <conclusion ref="technique-fit" verdict="use Reverse Brainstorming — invert the question"/>
    </branch>

    <branch when="shape == generate-broadly">
      <question id="q-dominance">Dominance risk in group?</question>

      <branch when="dominance_risk == true">
        <question id="q-written-comfortable">Group comfortable writing in silence?</question>
        <branch when="written_comfortable == true">
          <conclusion ref="technique-fit" verdict="use Brainwriting 6-3-5 — silence eliminates dominance"/>
        </branch>
        <branch when="written_comfortable == false">
          <conclusion ref="technique-fit" verdict="use Round Robin — enforced turns equalize voice"/>
        </branch>
      </branch>

      <branch when="dominance_risk == false">
        <conclusion ref="technique-fit" verdict="use Classic Brainstorming — fastest for 4-8 extroverts"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="activation-time-session">
    shape=generate-broadly → dominance_risk=true → written_comfortable=true → conclusion technique-fit → use 6-3-5 → session plan with 90 idea target.
  </example>
</text>
