      <template path="templates/interview-template.md" purpose="Full interview script with four phases and example probes"/>
      <template path="templates/signal-classifier.py" purpose="Keyword-based signal classifier for post-interview note processing"/>
      <template path="templates/prompt-question-gen.txt" purpose="Prompt for generating Mom Test-compliant interview questions"/>
      <template path="templates/prompt-transcript-analysis.txt" purpose="Prompt for classifying interview transcript statements by signal type"/>
    </templates>
  </content>
</methodology>
