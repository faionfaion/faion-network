<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Conflict Resolution Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-stakes-rel">stakes × relationship?</root-question>

    <branch when="stakes == high AND relationship == high">
      <conclusion ref="mode-fit-stakes-and-relationship" verdict="Collaborating + NVC message"/>
    </branch>

    <branch when="stakes == high AND relationship == low">
      <conclusion ref="mode-fit-stakes-and-relationship" verdict="Competing + clear NVC observation + request"/>
    </branch>

    <branch when="stakes == low AND relationship == high">
      <conclusion ref="mode-fit-stakes-and-relationship" verdict="Accommodating + short NVC acknowledgement"/>
    </branch>

    <branch when="stakes == low AND relationship == low">
      <conclusion ref="mode-fit-stakes-and-relationship" verdict="Avoiding + skip-this-methodology"/>
    </branch>

    <branch when="stakes == medium AND relationship == medium">
      <conclusion ref="mode-fit-stakes-and-relationship" verdict="Compromising + NVC with explicit trade ask"/>
    </branch>
  </decision-tree>

  <example trace="late-deploy-approval">
    stakes=high, relationship=high → conclusion mode-fit → Collaborating + NVC → 4-line message validated.
  </example>
</text>
