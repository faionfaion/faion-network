<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Selling Ideas Procedure" version="1.1.0" est_tokens="700" depth="essential">
  <summary>5-step procedure to apply the methodology end-to-end.</summary>

  <section title="Procedure">

    <step n="1" name="research-audience">
      <input>Audience identity</input>
      <action>Profile role + likely pain + decision power.</action>
      <output>Audience profile</output>
      
    </step>

    <step n="2" name="frame-challenger-insight">
      <input>Research + own data</input>
      <action>Write a 1-2 sentence teach insight grounded in data.</action>
      <output>challenger_insight string</output>
      
    </step>

    <step n="3" name="compose-spin">
      <input>Audience profile + insight</input>
      <action>Draft SPIN in order; cap Need-payoff to 1 sentence.</action>
      <output>spin JSON</output>
      <decision-gate>If S/P/I/N order broken, restructure.</decision-gate>
    </step>

    <step n="4" name="draft-cta">
      <input>Goal of the pitch</input>
      <action>One concrete next step + date.</action>
      <output>cta string</output>
      <decision-gate>If vague, rewrite.</decision-gate>
    </step>

    <step n="5" name="validate-and-rehearse">
      <input>Pitch JSON + validator</input>
      <action>Run `validate-selling-ideas.py`. Rehearse aloud 3x.</action>
      <output>Validated artefact</output>
      
    </step>

  </section>
</text>
