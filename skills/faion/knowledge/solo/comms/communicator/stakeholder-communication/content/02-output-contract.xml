<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Communication Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-communication.json",
  "type": "object",
  "required": [
    "session_mode",
    "stakeholders",
    "channel",
    "goal"
  ],
  "properties": {
    "session_mode": {
      "enum": [
        "interview",
        "brainstorm",
        "clarification",
        "validation",
        "socratic"
      ]
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "role",
          "power",
          "interest"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "power": {
            "enum": [
              "high",
              "low"
            ]
          },
          "interest": {
            "enum": [
              "high",
              "low"
            ]
          },
          "cadence": {
            "type": "string"
          },
          "channel_preferred": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "channel": {
      "enum": [
        "live-voice",
        "live-video",
        "async-text",
        "async-doc"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 10
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "session_mode": "interview",
  "stakeholders": [
    {
      "name": "Anna (VP Eng)",
      "role": "decision-maker",
      "power": "high",
      "interest": "high",
      "cadence": "weekly 30 min",
      "channel_preferred": "live-video"
    },
    {
      "name": "Ben (data-eng lead)",
      "role": "implementer",
      "power": "low",
      "interest": "high",
      "cadence": "biweekly async",
      "channel_preferred": "async-doc"
    }
  ],
  "channel": "live-video",
  "goal": "Gather requirements for the data-quality dashboard."
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "session_mode": "everything",
  "stakeholders": []
}
]]></code>
    <note>session_mode outside enum; stakeholders empty.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>Mixing Socratic with Validation in the same session.</item>
      <item>Stakeholder without power+interest placement.</item>
      <item>Validation session without written write-back step.</item>
    </list>
  </section>

  <reference path="scripts/validate-stakeholder-communication.py">Validator script</reference>
</text>
