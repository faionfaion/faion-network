<text id="05-examples" title="Stakeholder Communication Worked Example" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Worked example: interview-mode session with two stakeholders, written write-back the next day.</summary>

  <section title="Scenario">
    <p>PM kicks off a data-quality-dashboard project. Two key stakeholders: VP Eng (high power, high interest), data-eng lead (low power, high interest).</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "session_mode": "interview",
  "goal": "Gather requirements for the data-quality dashboard."
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "stakeholders": [
    {
      "name": "Anna (VP Eng)",
      "role": "decision-maker",
      "power": "high",
      "interest": "high",
      "cadence": "weekly 30 min",
      "channel_preferred": "live-video"
    },
    {
      "name": "Ben (data-eng lead)",
      "role": "implementer",
      "power": "low",
      "interest": "high",
      "cadence": "biweekly async",
      "channel_preferred": "async-doc"
    }
  ],
  "channel": "live-video"
}
]]></code>
  </section>

  <section title="Validator">
    <code lang="text"><![CDATA[
$ python scripts/validate-stakeholder-communication.py --file output.json
OK
]]></code>
  </section>
</text>
