<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Heuristic Eval Severity Rubric Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/heuristic-eval-severity-rubric.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "heuristic_source",
    "levels",
    "drift_threshold"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "heuristic_source": {
      "type": "string"
    },
    "levels": {
      "type": "array"
    },
    "drift_threshold": {
      "type": "integer"
    },
    "pair_ratings": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">levels array length != 5.</pattern>
      <pattern id="f2">any level missing anchored_example.</pattern>
      <pattern id="f3">drift_threshold &gt; 2 (rubric is too loose).</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "heuristic-eval-severity-rubric-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "heuristic_source": "heuristic_source value",
  "levels": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "drift_threshold": 1,
  "pair_ratings": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-heuristic-eval-severity-rubric.py">Stdlib-only validator implementing this schema.</reference>
</text>
