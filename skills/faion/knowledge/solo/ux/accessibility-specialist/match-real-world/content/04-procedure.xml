<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Match Between System and Real World Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Match Between System and Real World end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>UI copy</input>
      <action>Extract all UI strings.</action>
      <output>String list</output>
    </step>

    <step n="2" name="map-to-audience">
      <input>String list + glossary</input>
      <action>Map each string to audience term.</action>
      <output>Glossary</output>
    </step>

    <step n="3" name="score">
      <input>Glossary</input>
      <action>Score each screen against r1..r5.</action>
      <output>Score per screen</output>
    </step>

    <step n="4" name="remediate">
      <input>Scores</input>
      <action>Author remediation list.</action>
      <output>Remediation</output>
    </step>

    <step n="5" name="validate">
      <input>Full rubric</input>
      <action>Run scripts/validate-match-real-world.py.</action>
      <output>Validated rubric</output>
    </step>

  </section>
</text>
