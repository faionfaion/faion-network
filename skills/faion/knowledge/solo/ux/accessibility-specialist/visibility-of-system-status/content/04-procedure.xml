<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Visibility of System Status Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Visibility of System Status end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Action inventory</input>
      <action>List async actions + expected latency.</action>
      <output>Action list</output>
    </step>

    <step n="2" name="score">
      <input>Action list + screens</input>
      <action>Score each against r1..r5.</action>
      <output>Score per action</output>
    </step>

    <step n="3" name="remediate">
      <input>Scores</input>
      <action>Author remediation list.</action>
      <output>Remediation</output>
    </step>

    <step n="4" name="validate">
      <input>Full rubric</input>
      <action>Run scripts/validate-visibility-of-system-status.py.</action>
      <output>Validated rubric</output>
    </step>

  </section>
</text>
