<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Recognition Rather Than Recall Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Recognition Rather Than Recall end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Workflow map</input>
      <action>List multi-step flows.</action>
      <output>Flow list</output>
    </step>

    <step n="2" name="score">
      <input>Flow list + screens</input>
      <action>Score each flow against r1..r5.</action>
      <output>Score table</output>
    </step>

    <step n="3" name="remediate">
      <input>Score table</input>
      <action>Author remediation list.</action>
      <output>Remediation</output>
    </step>

    <step n="4" name="validate">
      <input>Full rubric</input>
      <action>Run scripts/validate-recognition-over-recall.py.</action>
      <output>Validated rubric</output>
    </step>

  </section>
</text>
