<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Flexibility and Efficiency of Use Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Flexibility and Efficiency of Use end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="inventory">
      <input>Workflow inventory</input>
      <action>List workflows + frequency per persona.</action>
      <output>Workflow table</output>
    </step>

    <step n="2" name="score-accelerators">
      <input>Workflow table</input>
      <action>Score each workflow against r1; flag gaps.</action>
      <output>Accelerator score</output>
    </step>

    <step n="3" name="score-paths">
      <input>Screen + workflows</input>
      <action>Count distinct paths per critical goal; flag &lt;2.</action>
      <output>Path score</output>
    </step>

    <step n="4" name="remediate">
      <input>Scores</input>
      <action>Author remediation list per gap.</action>
      <output>Remediation list</output>
    </step>

    <step n="5" name="validate">
      <input>Full rubric</input>
      <action>Run scripts/validate-flexibility-efficiency.py.</action>
      <output>Validated rubric</output>
    </step>

  </section>
</text>
