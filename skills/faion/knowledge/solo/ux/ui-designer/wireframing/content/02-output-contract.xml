<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Wireframing Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/wireframing.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "screen_name",
    "information_hierarchy",
    "layout_grid",
    "primary_actions",
    "content_slots",
    "fidelity_level"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "screen_name": {
      "type": "string"
    },
    "information_hierarchy": {
      "type": "array"
    },
    "layout_grid": {
      "type": "object"
    },
    "primary_actions": {
      "type": "array"
    },
    "content_slots": {
      "type": "array"
    },
    "fidelity_level": {
      "type": "string",
      "enum": [
        "wireframe",
        "mid",
        "high"
      ]
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">fidelity_level is not &apos;wireframe&apos; for this artefact.</pattern>
      <pattern id="f2">any primary_actions entry is generic (&apos;Submit&apos; / &apos;OK&apos; / &apos;Click here&apos;).</pattern>
      <pattern id="f3">information_hierarchy array empty.</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "wireframing-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "screen_name": "screen_name value",
  "information_hierarchy": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "layout_grid": {
    "key": "value"
  },
  "primary_actions": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "content_slots": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "fidelity_level": "wireframe"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-wireframing.py">Stdlib-only validator implementing this schema.</reference>
</text>
