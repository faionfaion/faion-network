<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Tailwind Design Tokens Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/tailwind-design-tokens.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "tokens_json_path",
    "tailwind_config_path",
    "dark_mode_strategy",
    "arbitrary_value_count",
    "ci_lint_status"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "tokens_json_path": {
      "type": "string"
    },
    "tailwind_config_path": {
      "type": "string"
    },
    "dark_mode_strategy": {
      "type": "string",
      "enum": [
        "class",
        "media",
        "none"
      ]
    },
    "arbitrary_value_count": {
      "type": "integer"
    },
    "ci_lint_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">arbitrary_value_count &gt; 0 in production files.</pattern>
      <pattern id="f2">dark_mode_strategy is &apos;media&apos; for token-driven project.</pattern>
      <pattern id="f3">tailwind_config_path edited manually (no generator script in repo).</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "tailwind-design-tokens-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "tokens_json_path": "tokens_json_path value",
  "tailwind_config_path": "tailwind_config_path value",
  "dark_mode_strategy": "class",
  "arbitrary_value_count": 1,
  "ci_lint_status": "pass"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-tailwind-design-tokens.py">Stdlib-only validator implementing this schema.</reference>
</text>
