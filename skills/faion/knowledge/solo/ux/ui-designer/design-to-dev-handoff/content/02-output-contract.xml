<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design-to-Dev Handoff Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-to-dev-handoff.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "component_or_flow",
    "spec_link",
    "video_link",
    "acceptance_criteria",
    "sync_date",
    "eng_owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "component_or_flow": {
      "type": "string"
    },
    "spec_link": {
      "type": "string"
    },
    "video_link": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array"
    },
    "sync_date": {
      "type": "string",
      "format": "date"
    },
    "eng_owner": {
      "type": "string"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">spec_link OR video_link empty.</pattern>
      <pattern id="f2">acceptance_criteria array length &lt; 3.</pattern>
      <pattern id="f3">eng_owner is a plural pronoun or empty.</pattern>
      <pattern id="f4">sync_date in the past with no sign-off captured.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-to-dev-handoff-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "component_or_flow": "component_or_flow value",
  "spec_link": "spec_link value",
  "video_link": "video_link value",
  "acceptance_criteria": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "sync_date": "2026-05-23",
  "eng_owner": "eng_owner value"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-design-to-dev-handoff.py">Stdlib-only validator implementing this schema.</reference>
</text>
