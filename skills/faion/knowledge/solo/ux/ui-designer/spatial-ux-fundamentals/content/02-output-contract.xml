<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Spatial UX Fundamentals Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spatial-ux-fundamentals.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "device_target",
    "field_of_view_deg",
    "zones",
    "affordance_method",
    "motion_velocity_cap_mps",
    "session_duration_minutes"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "device_target": {
      "type": "string"
    },
    "field_of_view_deg": {
      "type": "integer"
    },
    "zones": {
      "type": "object"
    },
    "affordance_method": {
      "type": "string",
      "enum": [
        "depth",
        "parallax",
        "occlusion",
        "color",
        "shape"
      ]
    },
    "motion_velocity_cap_mps": {
      "type": "number"
    },
    "session_duration_minutes": {
      "type": "integer"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">zones object missing any of {inner, middle, outer}.</pattern>
      <pattern id="f2">affordance_method is &apos;color&apos; or &apos;shape&apos; as the PRIMARY cue.</pattern>
      <pattern id="f3">motion_velocity_cap_mps &gt; 0.5 for elements within 1m.</pattern>
      <pattern id="f4">field_of_view_deg &gt; 180 OR &lt; 30.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "spatial-ux-fundamentals-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "device_target": "device_target value",
  "field_of_view_deg": 1,
  "zones": {
    "key": "value"
  },
  "affordance_method": "depth",
  "motion_velocity_cap_mps": 1.0,
  "session_duration_minutes": 1
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-spatial-ux-fundamentals.py">Stdlib-only validator implementing this schema.</reference>
</text>
