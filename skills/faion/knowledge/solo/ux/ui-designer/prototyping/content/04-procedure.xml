<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Prototyping Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Prototyping end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="frame-hypothesis">
      <input>Insight or open question</input>
      <action>Write a falsifiable IF / THEN hypothesis.</action>
      <output>hypothesis populated.</output>
    </step>
    <step n="2" name="pick-smallest-variant">
      <input>Hypothesis + tool</input>
      <action>Pick the smallest artefact that can test the hypothesis.</action>
      <output>variant scope decided.</output>
    </step>
    <step n="3" name="build-variant">
      <input>Variant scope + tool</input>
      <action>Ship the variant inside the time-box.</action>
      <output>variant_link populated.</output>
    </step>
    <step n="4" name="collect-evidence">
      <input>Variant + test plan</input>
      <action>Run the test; pin evidence_link.</action>
      <output>evidence_link populated.</output>
    </step>
    <step n="5" name="decide-outcome">
      <input>Evidence</input>
      <action>Pick kept / rolled-back / shipped-with-changes.</action>
      <output>outcome populated.</output>
    </step>
    <step n="6" name="log-row">
      <input>All previous outputs</input>
      <action>Create row via prototype-iteration-log-template.</action>
      <output>log_row_id populated.</output>
    </step>

  </section>
</text>
