<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Prototyping Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/prototyping.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "iteration_id",
    "hypothesis",
    "variant_link",
    "evidence_link",
    "outcome",
    "log_row_id",
    "time_box_hours"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "iteration_id": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "variant_link": {
      "type": "string"
    },
    "evidence_link": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "kept",
        "rolled-back",
        "shipped-with-changes"
      ]
    },
    "log_row_id": {
      "type": "string"
    },
    "time_box_hours": {
      "type": "integer"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">hypothesis does not contain &apos;IF&apos; AND &apos;THEN&apos;.</pattern>
      <pattern id="f2">evidence_link empty.</pattern>
      <pattern id="f3">outcome not in {kept, rolled-back, shipped-with-changes}.</pattern>
      <pattern id="f4">time_box_hours &gt; 8 OR &lt; 1.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "prototyping-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "iteration_id": "iteration_id value",
  "hypothesis": "hypothesis value",
  "variant_link": "variant_link value",
  "evidence_link": "evidence_link value",
  "outcome": "kept",
  "log_row_id": "log_row_id value",
  "time_box_hours": 1
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-prototyping.py">Stdlib-only validator implementing this schema.</reference>
</text>
