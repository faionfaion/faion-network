<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Edge-Case Checklist Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/edge-case-checklist.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "component_name",
    "answers",
    "handoff_status"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "component_name": {
      "type": "string"
    },
    "answers": {
      "type": "object"
    },
    "debt_accepted": {
      "type": "array"
    },
    "handoff_status": {
      "type": "string",
      "enum": [
        "ready",
        "blocked"
      ]
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">answers object missing any of the 10 canonical case keys.</pattern>
      <pattern id="f2">any case value not in {YES, NO, N/A}.</pattern>
      <pattern id="f3">any N/A answer without a reason.</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "edge-case-checklist-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "component_name": "component_name value",
  "answers": {
    "key": "value"
  },
  "debt_accepted": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "handoff_status": "ready"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-edge-case-checklist.py">Stdlib-only validator implementing this schema.</reference>
</text>
