<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Insight-to-Design-Ticket Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/insight-to-design-ticket.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "ticket_id",
    "insight",
    "evidence_link",
    "hypothesis",
    "success_metric",
    "design_constraints",
    "draft_acceptance_criteria"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "ticket_id": {
      "type": "string"
    },
    "insight": {
      "type": "string"
    },
    "evidence_link": {
      "type": "string"
    },
    "hypothesis": {
      "type": "string"
    },
    "success_metric": {
      "type": "string"
    },
    "design_constraints": {
      "type": "array"
    },
    "draft_acceptance_criteria": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">hypothesis does not contain &apos;IF&apos; AND &apos;THEN&apos;.</pattern>
      <pattern id="f2">evidence_link empty.</pattern>
      <pattern id="f3">design_constraints array length &lt; 2.</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "insight-to-design-ticket-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "ticket_id": "ticket_id value",
  "insight": "insight value",
  "evidence_link": "evidence_link value",
  "hypothesis": "hypothesis value",
  "success_metric": "success_metric value",
  "design_constraints": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "draft_acceptance_criteria": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-insight-to-design-ticket.py">Stdlib-only validator implementing this schema.</reference>
</text>
