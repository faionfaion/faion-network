<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Voice UI Basics Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/voice-ui-basics.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "platform",
    "intents",
    "prompts",
    "error_matrix",
    "destructive_intents_confirmed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "platform": {
      "type": "string",
      "enum": [
        "alexa",
        "google-assistant",
        "siri",
        "custom"
      ]
    },
    "intents": {
      "type": "array"
    },
    "prompts": {
      "type": "array"
    },
    "error_matrix": {
      "type": "object"
    },
    "destructive_intents_confirmed": {
      "type": "boolean"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">intents array length &gt; 20.</pattern>
      <pattern id="f2">any prompt longer than 15 words.</pattern>
      <pattern id="f3">error_matrix missing any of {no-input, no-match, fallback}.</pattern>
      <pattern id="f4">destructive_intents_confirmed is false AND destructive intents exist.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "voice-ui-basics-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "platform": "alexa",
  "intents": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "prompts": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "error_matrix": {
    "key": "value"
  },
  "destructive_intents_confirmed": true
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-voice-ui-basics.py">Stdlib-only validator implementing this schema.</reference>
</text>
