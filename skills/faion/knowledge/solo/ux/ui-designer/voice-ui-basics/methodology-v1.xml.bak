<methodology slug="voice-ui-basics">
  <metadata>
    <tier>solo</tier>
    <group>ux</group>
    <domain>ui-designer</domain>
    <summary>Design voice user interfaces by writing dialogues first, then extracting intent schemas, designing prompts under 20 words, and validating with Wizard of Oz testing before NLU training.</summary>
    <tags>
      <tag>voice-ui</tag>
      <tag>conversational-design</tag>
      <tag>nlu</tag>
      <tag>dialogue-design</tag>
