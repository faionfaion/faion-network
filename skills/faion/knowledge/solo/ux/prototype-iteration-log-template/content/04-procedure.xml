<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="Prototype Iteration Log Template Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Prototype Iteration Log Template end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="frame-problem-and-hypothesis">
      <input>Prototype context + product theme</input>
      <action>Write problem statement + IF-THEN hypothesis.</action>
      <output>problem + hypothesis populated.</output>
    </step>
    <step n="2" name="ship-variant">
      <input>Hypothesis + design tool</input>
      <action>Build the variant to test.</action>
      <output>variant link populated.</output>
    </step>
    <step n="3" name="collect-evidence">
      <input>Variant + test plan</input>
      <action>Run the test; pin evidence_link.</action>
      <output>evidence_link populated.</output>
    </step>
    <step n="4" name="pick-outcome">
      <input>Evidence</input>
      <action>Pick kept / rolled-back / shipped-with-changes.</action>
      <output>outcome populated.</output>
    </step>
    <step n="5" name="write-next">
      <input>Outcome</input>
      <action>Name the next iteration or the graduation path.</action>
      <output>next populated.</output>
    </step>
    <step n="6" name="validate-and-store">
      <input>Filled row</input>
      <action>Run validator; append to the log.</action>
      <output>Stored row.</output>
    </step>

  </section>
</text>
