<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stakeholder Walkthrough Script Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stakeholder-walkthrough-script.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "session_id",
    "decision_ask",
    "options_presented",
    "signed_decision",
    "parked_rows"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "session_id": {
      "type": "string"
    },
    "decision_ask": {
      "type": "string"
    },
    "options_presented": {
      "type": "array"
    },
    "signed_decision": {
      "type": "string"
    },
    "parked_rows": {
      "type": "array"
    },
    "recap_link": {
      "type": "string"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">options_presented array length &lt; 2 OR &gt; 4.</pattern>
      <pattern id="f2">signed_decision is empty AND meeting ended.</pattern>
      <pattern id="f3">owner is a plural pronoun or empty.</pattern>
      <pattern id="f4">decision_ask longer than 280 characters (too verbose to be a single ask).</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "stakeholder-walkthrough-script-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "session_id": "session_id value",
  "decision_ask": "decision_ask value",
  "options_presented": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "signed_decision": "signed_decision value",
  "parked_rows": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "recap_link": "recap_link value"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-stakeholder-walkthrough-script.py">Stdlib-only validator implementing this schema.</reference>
</text>
