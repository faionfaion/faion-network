<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Handoff Spec Template Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) pinning the shape of a valid artefact, plus one valid example, one invalid example, and a closed list of forbidden patterns the validator rejects.</summary>

  <section title="JSON Schema (draft-07)">
    <schema format="json-schema-draft-07">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/handoff-spec-template.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "component_name",
    "figma_url",
    "code_map",
    "states",
    "tokens_used",
    "motion",
    "accessibility",
    "edge_cases"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "component_name": {
      "type": "string"
    },
    "figma_url": {
      "type": "string"
    },
    "code_map": {
      "type": "object"
    },
    "states": {
      "type": "object"
    },
    "tokens_used": {
      "type": "array"
    },
    "motion": {
      "type": "array"
    },
    "accessibility": {
      "type": "object"
    },
    "edge_cases": {
      "type": "array"
    }
  }
}
]]></code>
    </schema>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">any state&apos;s color/spacing value is a raw hex/px string instead of a token reference.</pattern>
      <pattern id="f2">states object missing any of the 8 canonical state keys without an N/A reason.</pattern>
      <pattern id="f3">motion entries lacking duration_ms or easing.</pattern>
      <pattern id="f4">owner is a plural pronoun or empty.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "handoff-spec-template-example",
  "owner": "@solo-founder",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "component_name": "component_name value",
  "figma_url": "figma_url value",
  "code_map": {
    "key": "value"
  },
  "states": {
    "key": "value"
  },
  "tokens_used": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "motion": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "accessibility": {
    "key": "value"
  },
  "edge_cases": [
    "item-1",
    "item-2",
    "item-3"
  ]
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing OR forbidden patterns matched (e.g. version not semver).</note>
  </example>

  <reference path="scripts/validate-handoff-spec-template.py">Stdlib-only validator implementing this schema.</reference>
</text>
