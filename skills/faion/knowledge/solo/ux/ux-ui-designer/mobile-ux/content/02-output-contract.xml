<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Mobile UX Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid mobile-audit artefact. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/mobile-ux.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "platforms", "vitals", "findings"],
  "properties": {
    "artefact_id": {"type": "string", "minLength": 3},
    "owner": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "platforms": {"type": "array", "minItems": 1, "items": {"type": "string", "enum": ["ios", "android", "mobile-web"]}},
    "vitals": {
      "type": "object",
      "required": ["lcp_s", "cls", "tti_s"],
      "properties": {
        "lcp_s": {"type": "number"},
        "fid_ms": {"type": "number"},
        "cls": {"type": "number"},
        "tti_s": {"type": "number"}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["screen", "element", "category", "observed", "threshold", "platform", "fix_direction"],
        "properties": {
          "screen": {"type": "string"},
          "element": {"type": "string"},
          "category": {"type": "string", "enum": ["touch-target", "thumb-zone", "nav-pattern", "input-type", "vitals", "platform-gesture", "accessibility", "primary-action"]},
          "observed": {"type": "string"},
          "threshold": {"type": "string"},
          "platform": {"type": "string", "enum": ["ios", "android", "mobile-web"]},
          "fix_direction": {"type": "string"}
        }
      }
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "mobile-audit-checkout-2026-05-23",
  "owner": "Maria Yuskiv <maria@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "platforms": ["mobile-web"],
  "vitals": {"lcp_s": 2.1, "cls": 0.08, "tti_s": 4.4},
  "findings": [
    {
      "screen": "/checkout",
      "element": "button.pay-now",
      "category": "touch-target",
      "observed": "36x36pt",
      "threshold": "44x44pt",
      "platform": "ios",
      "fix_direction": "Increase target to 44x44pt; add 8px spacing from coupon link"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "we",
  "platforms": [],
  "vitals": {"lcp_s": 5.0},
  "findings": [{"screen": "/x", "category": "magic"}]
}
]]></code>
    <note>Owner plural; platforms empty; vitals missing cls/tti; finding missing required + category not in enum.</note>
  </example>

  <forbidden>
    <pattern id="vitals-above-threshold-untagged">`vitals.lcp_s &gt;= 2.5` or `cls &gt;= 0.1` without a corresponding `category=vitals` finding.</pattern>
    <pattern id="touch-target-below">finding with category `touch-target` whose `observed` numeric value is at or above threshold (contradiction).</pattern>
    <pattern id="platform-mismatch">finding with `platform` not present in top-level `platforms`.</pattern>
  </forbidden>

  <reference path="scripts/validate-mobile-ux.py">Stdlib-only validator implementing this schema.</reference>
</text>
