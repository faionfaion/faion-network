<?xml version="1.0" encoding="UTF-8"?>
<text id="05-examples" title="Tailwind Design Tokens Worked Example" version="1.1.0" est_tokens="500" depth="medium">
  <summary>Worked example: brand colour primitives + semantic mapping + dark-mode + opacity-ready RGB channel colours.</summary>

  <section title="Example: brand colour bridge (Tailwind v3)">
    <example title="tokens.css">
      <p>:root { --color-blue-500: 26 115 232; --space-4: 1rem; }</p>
      <p>[data-theme="dark"] { --color-action-primary: 96 165 250; }</p>
    </example>
    <example title="tailwind.config.js theme block">
      <p>colors: { action: { primary: 'rgb(var(--color-blue-500) / &lt;alpha-value&gt;)' } }, spacing: { md: 'var(--space-4)' }</p>
    </example>
    <example title="safelist">
      <p>safelist: ['bg-action-primary', 'bg-action-primary/50']</p>
    </example>
  </section>

  <section title="Example: v4 @theme block">
    <example title="globals.css">
      <p>@theme { --color-action-primary: rgb(var(--color-blue-500) / &lt;alpha-value&gt;); --spacing-md: var(--space-4); }</p>
    </example>
  </section>
</text>
