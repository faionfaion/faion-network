<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Flag Core Implementation Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the code artefact this methodology produces. Validator in scripts/validate-feature-flags-core-implementation.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/feature-flags-core-implementation.json",
  "type": "object",
  "title": "Feature flag registration",
  "required": [
    "name",
    "description",
    "default"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "default": {
      "type": "boolean"
    },
    "rollout_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 0
    },
    "targeting": {
      "type": "object"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "new-checkout-flow",
  "description": "Enables redesigned checkout flow.",
  "default": false,
  "rollout_percent": 25,
  "targeting": {
    "country": [
      "US"
    ]
  }
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": "NewCheckout",
  "default": "yes"
}
]]></code>
    <note>Forbidden traits: name pattern violation; default must be boolean; missing description.</note>
  </example>
  <reference path="scripts/validate-feature-flags-core-implementation.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
