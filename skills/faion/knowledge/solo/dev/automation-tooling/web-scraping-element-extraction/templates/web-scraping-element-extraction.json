{
  "__faion_header__": {
    "purpose": "JSON Schema for the per-row extraction artefact",
    "consumes": "row object emitted by the extractor module",
    "produces": "validated row gated by normalizer-applied check",
    "depends-on": "draft-07 JSON Schema validator",
    "token-budget-impact": "~400 tokens when loaded as context"
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/web-scraping-element-extraction.json",
  "type": "object",
  "required": ["artefact_id", "source", "row_index", "fields", "normalizers_applied", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^wsx-[a-z0-9-]{6,}$"},
    "source":      {"type": "string", "minLength": 1},
    "row_index":   {"type": "integer", "minimum": 0},
    "fields":      {"type": "object", "additionalProperties": {"type": ["string", "number", "integer", "boolean", "null"]}},
    "normalizers_applied": {
      "type": "array",
      "minItems": 1,
      "items": {"enum": ["text-trim", "text-collapse-ws", "text-strip-nonprintable", "price-to-float", "date-to-iso", "table-shape-check"]}
    },
    "parse_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "reason"],
        "properties": {"field": {"type": "string"}, "reason": {"type": "string"}}
      }
    },
    "verdict":      {"enum": ["approve", "block-no-normalizer", "block-wrong-api"]},
    "version":      {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed":{"type": "string", "format": "date"}
  }
}
