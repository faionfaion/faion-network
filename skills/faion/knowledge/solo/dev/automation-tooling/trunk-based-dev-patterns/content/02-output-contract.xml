<text id="02-output-contract" title="Trunk-Based Development Patterns Output Contract" version="2.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the playbook-step artefact this methodology produces. Validator enforces required keys + per-field constraints + forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/trunk-based-dev-patterns.json",
  "type": "object",
  "required": [
    "branch_lifetime_hours",
    "flag_name",
    "cleanup_ticket_id",
    "dark_launch_steps",
    "auto_revert_configured"
  ],
  "properties": {
    "branch_lifetime_hours": {
      "type": "number",
      "maximum": 24
    },
    "flag_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$"
    },
    "cleanup_ticket_id": {
      "type": "string"
    },
    "dark_launch_steps": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 3
    },
    "ci_p95_minutes": {
      "type": "number",
      "maximum": 10
    },
    "auto_revert_configured": {
      "type": "boolean",
      "const": true
    },
    "linear_history": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "branch_lifetime_hours": 6.5,
  "flag_name": "billing.use_stripe_v2",
  "cleanup_ticket_id": "OPS-148",
  "dark_launch_steps": [
    0.5,
    5,
    25,
    100
  ],
  "ci_p95_minutes": 7.3,
  "auto_revert_configured": true,
  "linear_history": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "branch_lifetime_hours": 96,
  "flag_name": "disable_legacy"
}
]]></code>
    <note>Branch lives 4 days; negative-named flag; missing cleanup ticket; ramps direct to 100%; no auto-revert.</note>
  </example>

  <section title="Forbidden patterns">
    <pattern id="f-long-branch">
      <description>Plan with branch_lifetime_hours &gt; 24</description>
      <why>Violates branch-lifetime-lt-24h.</why>
    </pattern>
    <pattern id="f-negative-flag">
      <description>Flag name starting with disable_ / no_ / not_</description>
      <why>Violates positive-flag-naming; inversion risk.</why>
    </pattern>
    <pattern id="f-direct-100">
      <description>Single ramp step [100]</description>
      <why>Violates dark-launch-lt-1pct-diurnal; masks bugs.</why>
    </pattern>
  </section>

  <reference path="scripts/validate-trunk-based-dev-patterns.py">Validator script</reference>
</text>
