<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Continuous Delivery (Index) Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact this methodology produces. Validator in scripts/validate-continuous-delivery.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/continuous-delivery.json",
  "type": "object",
  "title": "CD routing decision",
  "required": [
    "next_methodology",
    "reason"
  ],
  "additionalProperties": false,
  "properties": {
    "next_methodology": {
      "enum": [
        "cd-basics",
        "cd-pipelines",
        "skip"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 5
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "next_methodology": "cd-basics",
  "reason": "IaC missing; prereqs not met"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "next_methodology": "cd-future"
}
]]></code>
    <note>Forbidden traits: next_methodology enum violation; missing reason.</note>
  </example>
  <reference path="scripts/validate-continuous-delivery.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
