# .npmrc — strict pnpm configuration
# Copy to project root and adjust registry as needed

# Strict peer dependencies (error on peer dep conflicts)
strict-peer-dependencies=true

# Auto-install missing peer dependencies
auto-install-peers=true

# Do not hoist packages to root node_modules (strict phantom-dep prevention)
# Exception: set node-linker=hoisted for native add-ons that require flat layout
shamefully-hoist=false

# Enforce Node.js version from engines field in package.json
engine-strict=true

# Always use lockfile; fail CI if lockfile would change
lockfile=true
prefer-frozen-lockfile=true

# Public registry (override per-scope for private packages)
registry=https://registry.npmjs.org/

# Example private scope:
# @mycompany:registry=https://npm.mycompany.com/
