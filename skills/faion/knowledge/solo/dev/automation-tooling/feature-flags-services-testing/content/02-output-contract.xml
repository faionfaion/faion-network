<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Flag Services, Testing, and Agentic Workflow Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-feature-flags-services-testing.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/feature-flags-services-testing.json",
  "type": "object",
  "title": "Flag service + testing spec",
  "required": [
    "service",
    "test_strategy",
    "audit"
  ],
  "additionalProperties": false,
  "properties": {
    "service": {
      "enum": [
        "openfeature",
        "launchdarkly",
        "growthbook",
        "statsig",
        "internal"
      ]
    },
    "test_strategy": {
      "type": "object",
      "required": [
        "both_branches"
      ],
      "properties": {
        "both_branches": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "audit": {
      "type": "object",
      "required": [
        "stale_window_days"
      ],
      "properties": {
        "stale_window_days": {
          "type": "integer",
          "minimum": 30,
          "maximum": 365
        }
      }
    },
    "cleanup_agent": {
      "type": "boolean"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service": "openfeature",
  "test_strategy": {
    "both_branches": true
  },
  "audit": {
    "stale_window_days": 90
  },
  "cleanup_agent": true
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service": "custom",
  "test_strategy": {
    "both_branches": false
  }
}
]]></code>
    <note>Forbidden traits: service enum violation; both_branches must be const true; missing audit.</note>
  </example>
  <reference path="scripts/validate-feature-flags-services-testing.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
