<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Internationalization (i18n) Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-internationalization.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/internationalization.json",
  "type": "object",
  "title": "i18n adoption spec",
  "required": [
    "locales",
    "library",
    "ci_key_drift"
  ],
  "additionalProperties": false,
  "properties": {
    "locales": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
      }
    },
    "library": {
      "enum": [
        "react-intl",
        "formatjs",
        "i18next",
        "babel",
        "django-i18n"
      ]
    },
    "fallback_chain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rtl_support": {
      "type": "boolean"
    },
    "ci_key_drift": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "locales": [
    "en",
    "es",
    "ar"
  ],
  "library": "react-intl",
  "fallback_chain": [
    "en-US",
    "en"
  ],
  "rtl_support": true,
  "ci_key_drift": true
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "locales": [
    "english"
  ],
  "library": "google-translate",
  "ci_key_drift": false
}
]]></code>
    <note>Forbidden traits: locales pattern violation; library enum violation; ci_key_drift must be const true.</note>
  </example>
  <reference path="scripts/validate-internationalization.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
