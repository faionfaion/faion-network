<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Monorepo Setup with Turborepo Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the config artefact this methodology produces. Validator in scripts/validate-monorepo-turborepo.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/monorepo-turborepo.json",
  "type": "object",
  "title": "Turborepo monorepo spec",
  "required": [
    "layout",
    "package_manager",
    "remote_cache",
    "task_graph"
  ],
  "additionalProperties": false,
  "properties": {
    "layout": {
      "type": "object",
      "required": [
        "apps_dir",
        "packages_dir"
      ],
      "properties": {
        "apps_dir": {
          "type": "string"
        },
        "packages_dir": {
          "type": "string"
        }
      }
    },
    "package_manager": {
      "const": "pnpm"
    },
    "remote_cache": {
      "type": "boolean",
      "const": true
    },
    "task_graph": {
      "type": "object",
      "required": [
        "build",
        "test",
        "lint"
      ],
      "properties": {
        "build": {
          "type": "object",
          "required": [
            "inputs",
            "outputs"
          ]
        },
        "test": {
          "type": "object"
        },
        "lint": {
          "type": "object"
        }
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "layout": {
    "apps_dir": "apps/",
    "packages_dir": "packages/"
  },
  "package_manager": "pnpm",
  "remote_cache": true,
  "task_graph": {
    "build": {
      "inputs": [
        "src/**",
        "tsconfig.json",
        "package.json"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "outputs": []
    }
  }
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "layout": {
    "apps_dir": "apps/"
  },
  "package_manager": "npm",
  "remote_cache": false
}
]]></code>
    <note>Forbidden traits: package_manager must be const pnpm; remote_cache must be const true; missing task_graph.</note>
  </example>
  <reference path="scripts/validate-monorepo-turborepo.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
