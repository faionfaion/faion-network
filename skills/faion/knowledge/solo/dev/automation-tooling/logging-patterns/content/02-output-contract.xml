<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Logging Patterns Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-logging-patterns.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/logging-patterns.json",
  "type": "object",
  "title": "Logging baseline spec",
  "required": [
    "format",
    "request_id",
    "redaction"
  ],
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "json"
    },
    "request_id": {
      "type": "boolean",
      "const": true
    },
    "redaction": {
      "type": "object",
      "required": [
        "enabled",
        "patterns"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "const": true
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "perf_fields": {
      "type": "array",
      "items": {
        "enum": [
          "duration_ms",
          "db_query_count",
          "cache_hit_count"
        ]
      }
    },
    "sink": {
      "enum": [
        "loki",
        "cloudwatch",
        "elastic",
        "datadog",
        "stdout"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "format": "json",
  "request_id": true,
  "redaction": {
    "enabled": true,
    "patterns": [
      "email",
      "phone",
      "card_like"
    ]
  },
  "perf_fields": [
    "duration_ms",
    "db_query_count",
    "cache_hit_count"
  ],
  "sink": "loki"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "format": "text",
  "request_id": false
}
]]></code>
    <note>Forbidden traits: format must be const json; request_id must be const true; missing redaction.</note>
  </example>
  <reference path="scripts/validate-logging-patterns.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
