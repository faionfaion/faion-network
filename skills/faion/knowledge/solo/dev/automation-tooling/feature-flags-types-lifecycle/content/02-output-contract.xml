<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Flag Types and Lifecycle Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-feature-flags-types-lifecycle.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/feature-flags-types-lifecycle.json",
  "type": "object",
  "title": "Flag classification record",
  "required": [
    "name",
    "kind",
    "owner",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "kind": {
      "enum": [
        "release",
        "experiment",
        "ops",
        "permission"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "retire_by": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "cleanup_criteria": {
      "type": "string"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "name": "new-checkout-flow",
  "kind": "release",
  "owner": "checkout-team",
  "created_at": "2026-05-01",
  "retire_by": "2026-06-01",
  "cleanup_criteria": "100% rollout for 14 days, no rollback"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "name": "X",
  "kind": "rollout"
}
]]></code>
    <note>Forbidden traits: name pattern violation; kind enum violation; missing owner and created_at.</note>
  </example>
  <reference path="scripts/validate-feature-flags-types-lifecycle.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
