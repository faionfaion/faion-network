<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Feature Flag Rollout and Targeting Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-feature-flags-rollout-targeting.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/feature-flags-rollout-targeting.json",
  "type": "object",
  "title": "Flag rollout/targeting spec",
  "required": [
    "flag_name",
    "rollout_percent",
    "user_id_strategy"
  ],
  "additionalProperties": false,
  "properties": {
    "flag_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "rollout_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "targeting": {
      "type": "object"
    },
    "ramp_steps": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100
      }
    },
    "observation_window_minutes": {
      "type": "integer",
      "minimum": 10
    },
    "user_id_strategy": {
      "enum": [
        "account_id",
        "device_id",
        "hashed_email"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "flag_name": "new-checkout-flow",
  "rollout_percent": 25,
  "targeting": {
    "country": [
      "US",
      "CA"
    ]
  },
  "ramp_steps": [
    1,
    5,
    25,
    50,
    100
  ],
  "observation_window_minutes": 60,
  "user_id_strategy": "account_id"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "flag_name": "X",
  "rollout_percent": 150,
  "user_id_strategy": "ip_address"
}
]]></code>
    <note>Forbidden traits: flag_name pattern violation; rollout_percent maximum=100; user_id_strategy enum violation.</note>
  </example>
  <reference path="scripts/validate-feature-flags-rollout-targeting.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
