<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Continuous Delivery Basics Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-cd-basics.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/cd-basics.json",
  "type": "object",
  "title": "CD adoption plan",
  "required": [
    "prereqs_passed",
    "stages",
    "feature_flag_service"
  ],
  "additionalProperties": false,
  "properties": {
    "prereqs_passed": {
      "type": "boolean",
      "const": true
    },
    "stages": {
      "type": "array",
      "minItems": 4,
      "items": {
        "enum": [
          "build",
          "unit",
          "integration",
          "staging",
          "e2e",
          "production"
        ]
      }
    },
    "feature_flag_service": {
      "enum": [
        "openfeature",
        "launchdarkly",
        "growthbook",
        "split",
        "internal"
      ]
    },
    "iac_tool": {
      "enum": [
        "terraform",
        "pulumi",
        "cdk",
        "ansible"
      ]
    },
    "dora_emit": {
      "type": "boolean",
      "const": true
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "prereqs_passed": true,
  "stages": [
    "build",
    "unit",
    "integration",
    "staging",
    "e2e",
    "production"
  ],
  "feature_flag_service": "openfeature",
  "iac_tool": "terraform",
  "dora_emit": true
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "prereqs_passed": false,
  "stages": [
    "build",
    "deploy"
  ]
}
]]></code>
    <note>Forbidden traits: prereqs_passed must be const true; stages minItems=4; missing feature_flag_service and dora_emit.</note>
  </example>
  <reference path="scripts/validate-cd-basics.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
