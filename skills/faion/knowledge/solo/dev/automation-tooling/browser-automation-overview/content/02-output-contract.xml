<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Browser Automation Overview Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the decision-record artefact this methodology produces. Validator in scripts/validate-browser-automation-overview.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/browser-automation-overview.json",
  "type": "object",
  "title": "Browser automation tool decision",
  "required": [
    "tool",
    "language",
    "reasons",
    "next_methodology"
  ],
  "additionalProperties": false,
  "properties": {
    "tool": {
      "enum": [
        "playwright",
        "puppeteer",
        "none"
      ]
    },
    "language": {
      "enum": [
        "typescript",
        "javascript",
        "python",
        "dotnet",
        "java"
      ]
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "next_methodology": {
      "type": "string"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "tool": "playwright",
  "language": "typescript",
  "reasons": [
    "multi-browser",
    "auto-wait",
    "trace viewer"
  ],
  "next_methodology": "playwright-automation"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "tool": "selenium",
  "language": "ruby"
}
]]></code>
    <note>Forbidden traits: tool enum violation; language enum violation; missing reasons and next_methodology.</note>
  </example>
  <reference path="scripts/validate-browser-automation-overview.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
