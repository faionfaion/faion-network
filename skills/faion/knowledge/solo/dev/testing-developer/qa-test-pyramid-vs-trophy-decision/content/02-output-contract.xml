<text id="02-output-contract" title="Test Pyramid vs Testing Trophy: Per-Module Decision Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/qa-test-pyramid-vs-trophy-decision.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f2">modules.length &lt; 1.</pattern>
      <pattern id="f3">any module missing diagnostic.q1..q5.</pattern>
      <pattern id="f4">shape not in {pyramid,trophy,hybrid}.</pattern>
      <pattern id="f5">next_review_date &gt; today + 90 days.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "qa-test-pyramid-vs-trophy-decision-2026-q2",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23",
  "owner": "@ruslan"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team"
}
]]></code>
    <note>Missing required fields; owner=team violates the named-owner rule.</note>
  </example>

  <reference path="scripts/validate-qa-test-pyramid-vs-trophy-decision.py">Schema validator (stdlib only).</reference>
</text>
