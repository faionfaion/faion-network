<text id="06-decision-tree" title="Diff-Coverage Decision Tree" version="1.1.0" est_tokens="700" depth="essential">
  <summary>Routing tree mapping observable inputs onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="instrumentation-healthy">Is coverage instrumentation working AND does CI run tests per PR?</root-question>
    <branch when="instrumentation_healthy == false OR per_pr_tests == false">
      <conclusion ref="skip-this-methodology" verdict="skip; fix the upstream instrumentation first"/>
    </branch>
    <branch when="instrumentation_healthy == true AND per_pr_tests == true">
      <question id="baseline-coverage">Does main have non-zero baseline coverage?</question>
      <branch when="baseline_coverage == 0">
        <conclusion ref="skip-this-methodology" verdict="skip; invest in baseline first"/>
      </branch>
      <branch when="baseline_coverage &gt; 0">
        <question id="policy-form">Does coverage-diff.yml use default_threshold &gt; 0 AND every override has a `reason`?</question>
        <branch when="policy_invalid == true">
          <conclusion ref="r5-exclusion-list-disciplined" verdict="block; fix the policy file"/>
        </branch>
        <branch when="policy_invalid == false">
          <question id="headline-metric">Is the PR comment's headline metric the diff-coverage number (not whole-repo)?</question>
          <branch when="headline_metric != diff_coverage_percent">
            <conclusion ref="r3-no-full-repo-deception" verdict="block; rewrite the PR-comment template"/>
          </branch>
          <branch when="headline_metric == diff_coverage_percent">
            <conclusion ref="r2-per-file-threshold-not-aggregate" verdict="apply per-file gate + dashboard update"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>
  <example trace="instrumentation_healthy=true -> baseline_coverage&gt;0 -> policy_invalid=false -> headline_metric=diff_coverage_percent -> r2-per-file-threshold-not-aggregate.">Worked path from root question to the per-file-gate conclusion.</example>
</text>
