<text id="06-decision-tree" title="Page Object Pattern at Scale (Playwright / Cypress) Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="suite-size">Does the E2E suite have &gt;=10 tests covering &gt;=3 user flows?</root-question>
      <branch when="scale == no">
        <conclusion ref="skip-this-methodology" verdict="Investment not warranted yet."/>
      </branch>
      <branch when="scale == yes">
        <question id="locator-debt">Are &gt;30% of selectors xpath/css today?</question>
          <branch when="locator_debt == yes">
            <conclusion ref="skip-this-methodology" verdict="Migrate to role + test-id first."/>
          </branch>
          <branch when="locator_debt == no">
          <question id="ownership">Does the team have authority to refactor the test layer?</question>
            <branch when="owns == yes">
              <conclusion ref="skip-this-methodology" verdict="Run procedure; produce spec."/>
            </branch>
            <branch when="owns == no">
              <conclusion ref="skip-this-methodology" verdict="Block; surface ownership gap."/>
            </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="scale=yes -&gt; locator_debt=no -&gt; owns=yes -&gt; run-procedure">Worked path from root-question to conclusion.</example>
</text>
