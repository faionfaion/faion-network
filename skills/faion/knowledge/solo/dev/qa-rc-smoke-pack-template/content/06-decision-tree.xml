<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="QA Release Candidate Smoke Pack Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Does the team promote release candidates to production with no consistent smoke gate?</root-question>
    <branch when="e2e_under_5min_gate == true">
      <conclusion ref="skip-this-methodology" verdict="skip — E2E gates already"/>
    </branch>
    <branch when="no_rc_stage == true">
      <conclusion ref="skip-this-methodology" verdict="skip — continuous deploy"/>
    </branch>
    <branch when="step_count &gt; 10">
      <conclusion ref="max-10-steps" verdict="trim to ≤10"/>
    </branch>
    <branch when="wall_clock_seconds &gt; 300">
      <conclusion ref="five-min-wall-clock" verdict="shorten steps or split"/>
    </branch>
    <branch when="missing_critical_path == true">
      <conclusion ref="critical-path-coverage" verdict="add required path"/>
    </branch>
    <branch when="step_failed AND waiver_policy == null">
      <conclusion ref="fail-blocks-promotion" verdict="block until fixed or waiver added"/>
    </branch>
  </decision-tree>
</text>
