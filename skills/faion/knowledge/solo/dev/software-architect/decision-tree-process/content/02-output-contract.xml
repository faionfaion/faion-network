<text id="02-output-contract" title="Architecture Decision Process Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the report artefact this methodology produces. Validator in scripts/validate-decision-tree-process.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/decision-tree-process.json",
  "type": "object",
  "title": "Architecture decision report",
  "required": [
    "report_id",
    "question",
    "reversibility",
    "options",
    "matrix_total_weight",
    "recommended",
    "adr_ref",
    "review_trigger",
    "review_date",
    "version",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^dec-[a-z0-9-]+$"
    },
    "question": {
      "type": "string",
      "minLength": 10
    },
    "reversibility": {
      "enum": [
        "one_way",
        "two_way"
      ]
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "matrix_total_weight": {
      "type": "integer",
      "minimum": 100,
      "maximum": 100
    },
    "recommended": {
      "type": "string",
      "minLength": 1
    },
    "poc_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "adr_ref": {
      "type": "string",
      "minLength": 5
    },
    "review_trigger": {
      "type": "string",
      "minLength": 10
    },
    "review_date": {
      "type": "string",
      "format": "date"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "report_id": "dec-tenant-store-2026-05",
  "question": "Do we adopt Postgres or Mongo for tenant data?",
  "reversibility": "one_way",
  "options": [
    "postgres",
    "mongo",
    "postgres_jsonb",
    "do_nothing_sqlite",
    "cockroachdb"
  ],
  "matrix_total_weight": 100,
  "recommended": "postgres_jsonb",
  "poc_ref": "poc/postgres-jsonb-7day",
  "adr_ref": "adr-data-014",
  "review_trigger": "Tenant table exceeds 5M rows OR p95 read latency > 80ms.",
  "review_date": "2027-05-23",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "report_id": "dec 1",
  "question": "what?",
  "reversibility": "maybe",
  "options": [
    "postgres"
  ],
  "matrix_total_weight": 80,
  "recommended": "postgres_jsonb",
  "adr_ref": "",
  "review_trigger": "",
  "review_date": "soon",
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>Forbidden traits: report_id pattern violation; question too short; reversibility not in enum; &lt;2 options; matrix not 100%; adr_ref empty; review_trigger empty; review_date / version not ISO/semver.</note>
  </example>
  <forbidden>
    <pattern id="report-id-pattern">`report_id` does not match the documented pattern.</pattern>
    <pattern id="question-too-short">`question` shorter than the minimum length.</pattern>
    <pattern id="reversibility-not-enum">`reversibility` not in {two_way_door, partial_two_way, one_way_door_costly, one_way_door_irrevocable}.</pattern>
    <pattern id="options-too-few">`options` array has fewer than 2 entries.</pattern>
    <pattern id="matrix-weight-not-100">`matrix_total_weight` not equal to 100.</pattern>
    <pattern id="adr-ref-empty">`adr_ref` empty.</pattern>
    <pattern id="review-trigger-empty">`review_trigger` empty.</pattern>
    <pattern id="version-malformed">`version` not semver or `review_date`/`last_reviewed` not ISO date.</pattern>
  </forbidden>
  <reference path="scripts/validate-decision-tree-process.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
