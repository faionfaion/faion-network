<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Creational Design Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid spec artefact for creational-patterns. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/creational-patterns.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "construction_hotspot", "pattern", "di_scope"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "construction_hotspot": {
    "type": "string",
    "minLength": 3
  },
  "pattern": {
    "type": "string",
    "enum": [
      "FactoryMethod",
      "AbstractFactory",
      "Builder",
      "Prototype",
      "Singleton",
      "ObjectPool",
      "DI"
    ]
  },
  "di_scope": {
    "type": "string",
    "enum": [
      "request",
      "app",
      "singleton",
      "transient"
    ]
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "creational-pattern-payment-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "construction_hotspot": "payments.create_processor",
  "pattern": "AbstractFactory",
  "di_scope": "request"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "pattern": "Magic",
  "di_scope": "global"
}
]]></code>
    <note>Owner plural; pattern not in enum; di_scope not in enum.</note>
  </example>

  <forbidden>
    <pattern id="pattern-not-enum">`pattern` not in the documented 7-pattern enum.</pattern>
    <pattern id="singleton-as-default">`pattern == Singleton` AND construction_hotspot type lacks justification (shared mutable state alarm).</pattern>
    <pattern id="missing-di-scope">`pattern == DI` AND `di_scope` empty.</pattern>
  </forbidden>

  <reference path="scripts/validate-creational-patterns.py">Stdlib-only validator implementing this schema.</reference>
</text>
