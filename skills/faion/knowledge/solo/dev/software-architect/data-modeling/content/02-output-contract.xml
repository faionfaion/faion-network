<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Data Modeling Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid spec artefact for data-modeling. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/data-modeling.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "engine", "conceptual", "logical", "physical", "migration_plan"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "engine": {
    "type": "string",
    "minLength": 3
  },
  "conceptual": {
    "type": "array",
    "minItems": 1
  },
  "logical": {
    "type": "array",
    "minItems": 1
  },
  "physical": {
    "type": "array",
    "minItems": 1
  },
  "migration_plan": {
    "type": "object",
    "required": [
      "ddl_path",
      "rollback"
    ]
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "schema-orders-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "engine": "postgres 16",
  "conceptual": [
    {
      "entity": "Order"
    },
    {
      "entity": "LineItem"
    }
  ],
  "logical": [
    {
      "entity": "Order",
      "attrs": [
        "id",
        "customer_id",
        "total"
      ]
    }
  ],
  "physical": [
    {
      "table": "orders",
      "ddl": "CREATE TABLE orders ..."
    }
  ],
  "migration_plan": {
    "ddl_path": "migrations/2026-05-23-orders.sql",
    "rollback": "drop + restore"
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "conceptual": [],
  "physical": [
    {
      "table": "orders"
    }
  ],
  "migration_plan": {}
}
]]></code>
    <note>Owner plural; conceptual empty (skipped pass 1); migration_plan missing rollback.</note>
  </example>

  <forbidden>
    <pattern id="skip-conceptual">`conceptual` empty — schema MUST start with the conceptual pass.</pattern>
    <pattern id="no-rollback">`migration_plan.rollback` empty — no migration without rollback plan.</pattern>
    <pattern id="ddl-without-indexes">`physical[].ddl` contains CREATE TABLE but no CREATE INDEX for the top-3 query patterns.</pattern>
  </forbidden>

  <reference path="scripts/validate-data-modeling.py">Stdlib-only validator implementing this schema.</reference>
</text>
