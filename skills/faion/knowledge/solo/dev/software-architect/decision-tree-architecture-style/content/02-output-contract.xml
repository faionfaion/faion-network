<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Architecture Style Decision Tree Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid decision-record artefact for decision-tree-architecture-style. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/decision-tree-architecture-style.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "adr_id", "choice", "inputs", "alternatives_rejected", "reversibility"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "adr_id": {
    "type": "string"
  },
  "choice": {
    "type": "string",
    "enum": [
      "monolith",
      "modular-monolith",
      "microservices"
    ]
  },
  "inputs": {
    "type": "object",
    "required": [
      "team_size",
      "deploy_frequency",
      "devops_maturity"
    ]
  },
  "alternatives_rejected": {
    "type": "array",
    "minItems": 1
  },
  "reversibility": {
    "type": "string",
    "enum": [
      "partial_two_way",
      "one_way_door_costly",
      "one_way_door_irrevocable"
    ]
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "architecture-style-shop-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "adr_id": "041",
  "choice": "modular-monolith",
  "inputs": {
    "team_size": 6,
    "deploy_frequency": "1/week",
    "devops_maturity": "medium"
  },
  "alternatives_rejected": [
    {
      "option": "microservices",
      "reason": "team size + DevOps maturity insufficient"
    }
  ],
  "reversibility": "partial_two_way"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "choice": "magic",
  "inputs": {},
  "alternatives_rejected": [],
  "reversibility": "two_way_door"
}
]]></code>
    <note>Owner plural; choice not in enum; inputs missing required fields; reversibility too lenient.</note>
  </example>

  <forbidden>
    <pattern id="choice-not-enum">`choice` not in `[monolith, modular-monolith, microservices]`.</pattern>
    <pattern id="reversibility-two-way">`reversibility == two_way_door` for an architecture style choice — never two-way.</pattern>
    <pattern id="inputs-missing">`inputs` missing one of team_size / deploy_frequency / devops_maturity.</pattern>
  </forbidden>

  <reference path="scripts/validate-decision-tree-architecture-style.py">Stdlib-only validator implementing this schema.</reference>
</text>
