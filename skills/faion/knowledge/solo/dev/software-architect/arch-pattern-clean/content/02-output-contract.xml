<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Clean Architecture Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid spec artefact for arch-pattern-clean. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/arch-pattern-clean.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "rings", "dependency_rule_enforced"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "rings": {
    "type": "array",
    "minItems": 4,
    "maxItems": 4,
    "items": {
      "type": "object",
      "required": [
        "name",
        "modules"
      ]
    }
  },
  "dependency_rule_enforced": {
    "type": "boolean"
  },
  "lint_tool": {
    "type": "string"
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "clean-layout-acme-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "rings": [
    {
      "name": "entities",
      "modules": [
        "domain"
      ]
    },
    {
      "name": "use-cases",
      "modules": [
        "application"
      ]
    },
    {
      "name": "adapters",
      "modules": [
        "adapters"
      ]
    },
    {
      "name": "frameworks",
      "modules": [
        "infrastructure"
      ]
    }
  ],
  "dependency_rule_enforced": true,
  "lint_tool": "importlinter"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "rings": [
    {
      "name": "entities"
    }
  ],
  "dependency_rule_enforced": false
}
]]></code>
    <note>Owner plural; rings has fewer than 4 entries; dependency_rule_enforced false.</note>
  </example>

  <forbidden>
    <pattern id="rings-wrong-count">`rings` does not contain exactly 4 entries.</pattern>
    <pattern id="dependency-rule-not-enforced">`dependency_rule_enforced` is false — Clean without enforcement drifts in weeks.</pattern>
    <pattern id="missing-lint-tool">`dependency_rule_enforced: true` AND `lint_tool` empty.</pattern>
  </forbidden>

  <reference path="scripts/validate-arch-pattern-clean.py">Stdlib-only validator implementing this schema.</reference>
</text>
