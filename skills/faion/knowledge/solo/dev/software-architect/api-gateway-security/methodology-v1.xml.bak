<methodology slug="api-gateway-security">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>software-architect</domain>
    <summary>Implement authentication, authorization, TLS termination, WAF, CORS, header sanitization, and request validation at the API gateway layer to defend against abuse and data leakage.</summary>
