<text id="02-output-contract" title="Monolith Architecture Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-monolith-architecture.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/monolith-architecture.json",
  "type": "object",
  "title": "Monolith spec",
  "required": [
    "spec_id",
    "internal_layout",
    "single_pipeline",
    "transaction_strategy",
    "scale_plan",
    "extraction_triggers",
    "version",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^mono-[a-z0-9-]+$"
    },
    "internal_layout": {
      "enum": [
        "vertical_slice",
        "layered"
      ]
    },
    "single_pipeline": {
      "type": "boolean",
      "const": true
    },
    "transaction_strategy": {
      "enum": [
        "acid_default",
        "documented_exceptions"
      ]
    },
    "scale_plan": {
      "type": "object",
      "required": [
        "scale_up_budget",
        "scale_out_trigger"
      ],
      "properties": {
        "scale_up_budget": {
          "type": "string",
          "minLength": 5
        },
        "scale_out_trigger": {
          "type": "string",
          "minLength": 10
        }
      }
    },
    "extraction_triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spec_id": "mono-shop-mvp-2026-05",
  "internal_layout": "vertical_slice",
  "single_pipeline": true,
  "transaction_strategy": "acid_default",
  "scale_plan": {
    "scale_up_budget": "Up to 8 vCPU / 16 GB RAM on a single instance.",
    "scale_out_trigger": "Sustained > 70% CPU for 7 days OR p95 latency > 200ms."
  },
  "extraction_triggers": [
    "Checkout traffic > 10x rest of system for 30 days.",
    "Independent team owns checkout with conflicting release cadence."
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "spec_id": "mono 1",
  "internal_layout": "horizontal",
  "single_pipeline": false,
  "transaction_strategy": "saga_by_default",
  "scale_plan": {
    "scale_up_budget": "",
    "scale_out_trigger": ""
  },
  "extraction_triggers": [],
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>Forbidden traits: spec_id pattern violation; internal_layout not in enum; single_pipeline false; transaction_strategy not in enum; empty scale_plan fields; empty extraction_triggers; version + date malformed.</note>
  </example>
  <forbidden>
    <pattern id="spec-id-pattern">`spec_id` does not match the documented pattern.</pattern>
    <pattern id="internal-layout-not-enum">`internal_layout` not in {vertical-slice, layered, hybrid}.</pattern>
    <pattern id="single-pipeline-false">`single_pipeline` is false (multi-pipeline breaks monolith-first contract).</pattern>
    <pattern id="transaction-strategy-not-enum">`transaction_strategy` not in the documented enum.</pattern>
    <pattern id="scale-plan-empty">`scale_plan` has empty required sub-fields.</pattern>
    <pattern id="extraction-triggers-empty">`extraction_triggers` array empty (no documented exit path).</pattern>
    <pattern id="version-malformed">`version` not semver or `last_reviewed` not ISO date.</pattern>
  </forbidden>
  <reference path="scripts/validate-monolith-architecture.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
