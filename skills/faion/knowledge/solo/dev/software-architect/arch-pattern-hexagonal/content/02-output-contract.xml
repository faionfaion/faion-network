<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Hexagonal Architecture (Ports and Adapters) Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid spec artefact for arch-pattern-hexagonal. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/arch-pattern-hexagonal.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "driving_ports", "driven_ports", "adapters", "lint_enforced"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "driving_ports": {
    "type": "array",
    "minItems": 1
  },
  "driven_ports": {
    "type": "array",
    "minItems": 1
  },
  "adapters": {
    "type": "array",
    "minItems": 1
  },
  "lint_enforced": {
    "type": "boolean"
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "hex-layout-shop-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "driving_ports": [
    {
      "name": "OrderInputPort"
    }
  ],
  "driven_ports": [
    {
      "name": "OrderRepositoryPort"
    },
    {
      "name": "PaymentPort"
    }
  ],
  "adapters": [
    {
      "port": "OrderInputPort",
      "adapter": "HttpOrderController",
      "kind": "driving"
    }
  ],
  "lint_enforced": true
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "driving_ports": [],
  "lint_enforced": false
}
]]></code>
    <note>Owner plural; driving_ports empty; lint not enforced.</note>
  </example>

  <forbidden>
    <pattern id="no-driving-port">`driving_ports` empty — hex without inbound port is just layered architecture.</pattern>
    <pattern id="no-driven-port">`driven_ports` empty — hex without outbound port has no swap surface.</pattern>
    <pattern id="lint-not-enforced">`lint_enforced` false — pattern decays in weeks without CI lint.</pattern>
  </forbidden>

  <reference path="scripts/validate-arch-pattern-hexagonal.py">Stdlib-only validator implementing this schema.</reference>
</text>
