<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="API Gateway Patterns &amp; Technology Selection Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid decision-record artefact for api-gateway-patterns. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/api-gateway-patterns.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "adr_id", "pattern", "product", "alternatives_rejected"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "adr_id": {
    "type": "string"
  },
  "pattern": {
    "type": "string",
    "enum": [
      "edge",
      "bff",
      "per-service",
      "none"
    ]
  },
  "product": {
    "type": "string",
    "enum": [
      "kong",
      "traefik",
      "envoy",
      "aws-apigw",
      "apollo-router",
      "tyk",
      "krakend"
    ]
  },
  "alternatives_rejected": {
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "object",
      "required": [
        "option",
        "reason"
      ]
    }
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "api-gateway-patterns-acme-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "adr_id": "017",
  "pattern": "bff",
  "product": "kong",
  "alternatives_rejected": [
    {
      "option": "envoy",
      "reason": "no managed UX; team has no Envoy operator"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "pattern": "custom",
  "alternatives_rejected": []
}
]]></code>
    <note>Owner plural; pattern not in enum; alternatives_rejected empty.</note>
  </example>

  <forbidden>
    <pattern id="pattern-not-enum">`pattern` not in `[edge, bff, per-service, none]`.</pattern>
    <pattern id="product-not-enum">`product` not in the documented enum.</pattern>
    <pattern id="no-alternatives">`alternatives_rejected` empty — every selection must document at least one rejected option.</pattern>
  </forbidden>

  <reference path="scripts/validate-api-gateway-patterns.py">Stdlib-only validator implementing this schema.</reference>
</text>
