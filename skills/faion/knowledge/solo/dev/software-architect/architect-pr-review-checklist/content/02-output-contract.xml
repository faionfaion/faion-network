<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Architect PR Review Checklist Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid report artefact for architect-pr-review-checklist. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/architect-pr-review-checklist.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "pr_url", "verdict", "sections"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "pr_url": {
    "type": "string",
    "minLength": 5
  },
  "verdict": {
    "type": "string",
    "enum": [
      "ship",
      "block",
      "escalate"
    ]
  },
  "sections": {
    "type": "object",
    "required": [
      "contract",
      "dependency_direction",
      "error_model",
      "observability",
      "security",
      "adr_conformance"
    ]
  },
  "time_spent_minutes": {
    "type": "integer",
    "minimum": 0,
    "maximum": 60
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "architect-pr-review-acme-431",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "pr_url": "https://github.com/acme/api/pull/431",
  "verdict": "block",
  "sections": {
    "contract": "ok",
    "dependency_direction": "violation",
    "error_model": "ok",
    "observability": "ok",
    "security": "ok",
    "adr_conformance": "violation"
  },
  "time_spent_minutes": 14
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "verdict": "lgtm",
  "sections": {}
}
]]></code>
    <note>Owner plural; verdict not in enum; sections empty.</note>
  </example>

  <forbidden>
    <pattern id="verdict-lgtm">`verdict` not in `[ship, block, escalate]` (no 'lgtm', 'ok', 'approve').</pattern>
    <pattern id="missing-section">`sections` is missing one of the six mandatory sections.</pattern>
    <pattern id="time-over-cap">`time_spent_minutes` &gt; 60 — review should have been escalated or split.</pattern>
  </forbidden>

  <reference path="scripts/validate-architect-pr-review-checklist.py">Stdlib-only validator implementing this schema.</reference>
</text>
