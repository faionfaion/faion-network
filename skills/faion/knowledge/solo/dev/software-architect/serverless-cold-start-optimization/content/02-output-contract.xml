<text id="02-output-contract" title="Serverless Cold Start Optimization Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-serverless-cold-start-optimization.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/serverless-cold-start-optimization.json",
  "type": "object",
  "title": "Cold-start optimisation spec",
  "required": [
    "spec_id",
    "baseline",
    "budget_p99_ms",
    "mitigations",
    "post_fix",
    "cost_delta_pct",
    "version",
    "last_reviewed"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^cs-[a-z0-9-]+$"
    },
    "baseline": {
      "type": "object",
      "required": [
        "cold_p99_ms",
        "warm_p99_ms",
        "rps"
      ],
      "properties": {
        "cold_p99_ms": {
          "type": "integer",
          "minimum": 1
        },
        "warm_p99_ms": {
          "type": "integer",
          "minimum": 1
        },
        "rps": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "budget_p99_ms": {
      "type": "integer",
      "minimum": 1
    },
    "mitigations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "bundle_trim",
          "lazy_imports",
          "memory_tune",
          "runtime_swap",
          "snapstart",
          "provisioned_concurrency",
          "container_migration"
        ]
      }
    },
    "post_fix": {
      "type": "object",
      "required": [
        "cold_p99_ms",
        "warm_p99_ms"
      ],
      "properties": {
        "cold_p99_ms": {
          "type": "integer",
          "minimum": 1
        },
        "warm_p99_ms": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cost_delta_pct": {
      "type": "number"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spec_id": "cs-checkout-2026-05",
  "baseline": {
    "cold_p99_ms": 1800,
    "warm_p99_ms": 80,
    "rps": 25
  },
  "budget_p99_ms": 300,
  "mitigations": [
    "bundle_trim",
    "snapstart",
    "memory_tune"
  ],
  "post_fix": {
    "cold_p99_ms": 280,
    "warm_p99_ms": 70
  },
  "cost_delta_pct": 6.5,
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "spec_id": "cs 1",
  "baseline": {
    "cold_p99_ms": 0,
    "warm_p99_ms": 0,
    "rps": 0
  },
  "budget_p99_ms": 0,
  "post_fix": {
    "cold_p99_ms": 0,
    "warm_p99_ms": 0
  },
  "cost_delta_pct": "n/a",
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>Forbidden traits: spec_id pattern violation; baseline / budget / post_fix zeros; empty mitigations; cost_delta_pct not numeric; version + date malformed.</note>
  </example>
  <reference path="scripts/validate-serverless-cold-start-optimization.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
