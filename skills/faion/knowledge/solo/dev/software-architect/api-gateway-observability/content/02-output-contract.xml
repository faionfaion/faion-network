<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="API Gateway Observability Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid config artefact for api-gateway-observability. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/api-gateway-observability.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "gateway", "metrics", "logging", "tracing"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "gateway": {
    "type": "object",
    "required": [
      "product",
      "version"
    ]
  },
  "metrics": {
    "type": "object",
    "required": [
      "prometheus"
    ]
  },
  "logging": {
    "type": "object",
    "required": [
      "format",
      "fields"
    ]
  },
  "tracing": {
    "type": "object",
    "required": [
      "otlp"
    ]
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "api-gateway-observability-acme-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "gateway": {
    "product": "kong",
    "version": "3.6"
  },
  "metrics": {
    "prometheus": {
      "enabled": true,
      "listen": "0.0.0.0:9090"
    }
  },
  "logging": {
    "format": "json",
    "fields": [
      "correlation_id",
      "consumer_id"
    ]
  },
  "tracing": {
    "otlp": {
      "endpoint": "http://tempo:4317",
      "propagator": "tracecontext"
    }
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "metrics": {},
  "logging": {
    "format": "plain"
  }
}
]]></code>
    <note>Owner plural; metrics empty; logging format not 'json'; missing required fields.</note>
  </example>

  <forbidden>
    <pattern id="plaintext-logs">`logging.format` is not `json`.</pattern>
    <pattern id="no-correlation-id">`logging.fields` does not contain `correlation_id`.</pattern>
    <pattern id="owner-plural">`owner` is a plural pronoun.</pattern>
  </forbidden>

  <reference path="scripts/validate-api-gateway-observability.py">Stdlib-only validator implementing this schema.</reference>
</text>
