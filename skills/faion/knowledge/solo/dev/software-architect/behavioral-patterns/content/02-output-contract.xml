<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Behavioral Design Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid spec artefact for behavioral-patterns. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/behavioral-patterns.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "variance_hotspot", "pattern", "refactor_sketch"],
  "properties": {
  "artefact_id": {
    "type": "string",
    "minLength": 3
  },
  "owner": {
    "type": "string",
    "minLength": 3
  },
  "version": {
    "type": "string",
    "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
  },
  "last_reviewed": {
    "type": "string",
    "format": "date"
  },
  "variance_hotspot": {
    "type": "string",
    "minLength": 3
  },
  "pattern": {
    "type": "string",
    "enum": [
      "Strategy",
      "Observer",
      "Command",
      "State",
      "Chain of Responsibility",
      "Template Method",
      "Mediator",
      "Iterator",
      "Visitor"
    ]
  },
  "refactor_sketch": {
    "type": "object",
    "required": [
      "abstract",
      "concrete"
    ]
  }
}
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "behavioral-pattern-shipping-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "variance_hotspot": "shipping.calculate_cost",
  "pattern": "Strategy",
  "refactor_sketch": {
    "abstract": "ShippingStrategy",
    "concrete": [
      "DhlStrategy",
      "UpsStrategy"
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "pattern": "Magic",
  "refactor_sketch": {}
}
]]></code>
    <note>Owner plural; pattern not in enum; refactor_sketch missing required keys.</note>
  </example>

  <forbidden>
    <pattern id="pattern-not-enum">`pattern` not in the documented 9-pattern enum.</pattern>
    <pattern id="missing-sketch">`refactor_sketch.abstract` or `refactor_sketch.concrete` missing/empty.</pattern>
    <pattern id="pattern-misuse-strategy-vs-state">`pattern == Strategy` but variance is per-object lifecycle stage (use State).</pattern>
  </forbidden>

  <reference path="scripts/validate-behavioral-patterns.py">Stdlib-only validator implementing this schema.</reference>
</text>
