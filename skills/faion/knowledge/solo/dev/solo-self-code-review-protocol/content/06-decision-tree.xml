<text id="06-decision-tree" title="Solo Self Code Review Protocol Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="peer-available">Is a human peer reviewer available for this PR?</root-question>
      <branch when="peer == yes">
        <conclusion ref="skip-this-methodology" verdict="use peer-review methodology instead"/>
      </branch>
      <branch when="peer == no">
        <question id="risk-flagged">Does the diff touch any risk-flag path?</question>
          <branch when="risk == yes">
            <conclusion ref="twenty-four-hour-cooloff-risky" verdict="mark RISKY; 24h cool-off mandatory"/>
          </branch>
          <branch when="risk == no">
            <question id="ai-review-done">Has AI second-reviewer pass been done?</question>
              <branch when="ai == missing">
                <conclusion ref="ai-second-reviewer-required" verdict="run AI prompt + paste output"/>
              </branch>
              <branch when="ai == done">
                <conclusion ref="ci-green-or-revert" verdict="verify CI green; merge"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="peer=no -&amp;gt; risk=no -&amp;gt; ai=done -&amp;gt; ci-green-or-revert.">Worked path from root-question to conclusion.</example>
</text>
