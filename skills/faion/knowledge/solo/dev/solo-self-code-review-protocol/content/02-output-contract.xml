<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Solo Self Code Review Protocol Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/solo-self-code-review-protocol.json",
  "type": "object",
  "required": [
    "pr_id",
    "checklist_passed",
    "ai_review_present",
    "risk_flags_hit",
    "ci_status"
  ],
  "properties": {
    "pr_id": {
      "type": "string"
    },
    "checklist_passed": {
      "type": "object",
      "required": [
        "items_total",
        "items_passed"
      ]
    },
    "ai_review_present": {
      "type": "boolean"
    },
    "risk_flags_hit": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cooloff_start": {
      "type": "string"
    },
    "cooloff_end": {
      "type": "string"
    },
    "ci_status": {
      "type": "string",
      "enum": [
        "green",
        "red",
        "yellow"
      ]
    },
    "merge_decision": {
      "type": "string",
      "enum": [
        "merge",
        "revert",
        "hold"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pr_id": "PR-142",
  "checklist_passed": {
    "items_total": 10,
    "items_passed": 10
  },
  "ai_review_present": true,
  "risk_flags_hit": [
    "db_migration"
  ],
  "cooloff_start": "2026-05-22T11:00:00Z",
  "cooloff_end": "2026-05-23T11:00:00Z",
  "ci_status": "green",
  "merge_decision": "merge"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pr_id": "",
  "checklist_passed": {
    "items_total": 5,
    "items_passed": 5
  },
  "ai_review_present": false,
  "risk_flags_hit": [
    "db_migration"
  ],
  "ci_status": "yellow",
  "merge_decision": "merge"
}
]]></code>
    <note>pr_id empty; checklist &lt;10 items; ai_review_present=false; risk-flagged PR merged without cooloff; ci_status=yellow not green; merge_decision=merge on yellow forbidden.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="skip-checklist-fast-merge">Migration shipped 12 minutes after coding; failed in production due to unrelated FK constraint at 2 AM.</pattern>
      <pattern id="ai-review-absent">Edge case slipped to production; engineer would have caught it with AI prompt 'enumerate edge cases'.</pattern>
      <pattern id="ci-yellow-merge">Solo merged with CI=yellow ('flaky test'); main went red 30 minutes later; fix-forward took 3 hours.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-solo-self-code-review-protocol.py">Validator script (see scripts/).</reference>
</text>
