<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Test as Living Documentation Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/test-as-living-documentation.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "ac_corpus_link",
    "framework",
    "docs_url",
    "ac_coverage_pct",
    "version",
    "last_reviewed"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "ac_corpus_link": {
      "type": "string",
      "minLength": 1
    },
    "framework": {
      "type": "string",
      "enum": [
        "cucumber",
        "behave",
        "specflow",
        "pytest-bdd",
        "custom"
      ]
    },
    "docs_url": {
      "type": "string",
      "minLength": 1
    },
    "ac_coverage_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "stakeholder_review_date": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed": {
      "type": "string",
      "minLength": 1
    }
  }
}
    ]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "tld-2026-q2",
  "owner": "olena@faion.net",
  "ac_corpus_link": "https://linear.app/faion/team/eng",
  "framework": "pytest-bdd",
  "docs_url": "https://docs.faion.net/bdd/",
  "ac_coverage_pct": 84.0,
  "stakeholder_review_date": "2026-05-20",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
    ]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "",
  "owner": "team",
  "ac_corpus_link": "",
  "framework": "junit",
  "docs_url": "",
  "ac_coverage_pct": 30,
  "version": "",
  "last_reviewed": ""
}
    ]]></code>
    <note>Violates required-field presence / forbidden-pattern constraints above.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="framework-not-bdd">framework is unit/integration test only, not BDD</pattern>
      <pattern id="docs-not-published">docs_url empty or 404</pattern>
      <pattern id="ac-coverage-below-80">ac_coverage_pct &lt; 80</pattern>
    </list>
  </section>
  <reference path="scripts/validate-test-as-living-documentation.py">Validator script (see scripts/).</reference>
</text>
