      <link href="https://www.prisma.io/docs"/>
    </see-also>
    <templates>
      <template path="templates/errors.ts" purpose="Full AppError hierarchy with NotFoundError, ConflictError, UnauthorizedError, ValidationError"/>
      <template path="templates/error-handler.ts" purpose="Express error handler middleware (ZodError + AppError + fallback)"/>
      <template path="templates/container.ts" purpose="Manual DI container wiring Prisma → repositories → services → controllers"/>
      <template path="templates/layer-violation-check.sh" purpose="Grep script to detect Prisma in services, direct DB in controllers, res.status in services"/>
    </templates>
  </content>
</methodology>
