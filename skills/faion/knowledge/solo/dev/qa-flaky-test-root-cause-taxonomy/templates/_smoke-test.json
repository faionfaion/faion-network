{
  "__faion_header__": {
    "purpose": "Minimum viable filled-in artefact for sanity-checking the schema.",
    "consumes": "see content/02-output-contract.xml",
    "produces": "rubric",
    "depends_on": "content/01-core-rules.xml#closed-enum",
    "token_budget_impact": "~150 tokens when loaded"
  },
  "taxonomy_version": "1.0.0",
  "categories": [
    {
      "id": "time",
      "label": "Time-sensitive",
      "detectors": [
        "assert .* in .* sleep",
        "now\\(\\) compared"
      ],
      "fix_family": "freezegun + monotonic clock"
    },
    {
      "id": "order",
      "label": "Order-dependent",
      "detectors": [
        "passes alone, fails in suite"
      ],
      "fix_family": "explicit setup/teardown + pytest-randomly"
    }
  ],
  "default_unknown_window_days": 7,
  "mask_window_days": 30
}