<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Outsource PR Etiquette Decision Tree" version="1.0.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable signals to a rule from content/01-core-rules.xml. The skip-this-methodology branch is always reachable.</summary>
  <decision-tree>
    <root-question id="q-root">Is the reviewer outsourced or timezone-shifted such that round-trips cost ≥1 working day?</root-question>
    <branch when="reviewer_colocated == true AND review_sync == true">
      <conclusion ref="skip-this-methodology" verdict="skip — synchronous review is cheaper"/>
    </branch>
    <branch when="pr_intent_count &gt; 1">
      <conclusion ref="single-intent" verdict="split PR by intent before applying the rest"/>
    </branch>
    <branch when="diff_loc &gt; 400 AND waiver_reason == null">
      <conclusion ref="size-cap-400" verdict="split or set explicit waiver"/>
    </branch>
    <branch when="reviewer_outsourced == true AND repro_steps_present == false">
      <conclusion ref="repro-block" verdict="add Repro section"/>
    </branch>
    <branch when="reviewer_outsourced == true AND evidence_present == false">
      <conclusion ref="before-after-evidence" verdict="attach before/after evidence"/>
    </branch>
  </decision-tree>
</text>
