<text id="04-procedure" title="Release QA Cycle Template Procedure" version="1.0.0" est_tokens="900" depth="essential">
  <summary>7-step procedure applying the release-qa-cycle-template methodology end-to-end. Each step lists inputs, action, output, and optional decision gate.</summary>
  <section title="Procedure">
    <step n="1" name="kickoff">
      <input>release notes</input>
      <action>Confirm release id, scope, stakeholders; open cycle record.</action>
      <output>cycle stub</output>
    </step>
    <step n="2" name="run-strategy">
      <input>scope + risks</input>
      <action>Apply qa-test-strategy-template; owner signs off.</action>
      <output>strategy.md</output>
    </step>
    <step n="3" name="run-smoke">
      <input>RC env + pack</input>
      <action>Apply qa-rc-smoke-pack-template; outcome pass/fail.</action>
      <output>smoke result</output>
    </step>
    <step n="4" name="run-bug-bash">
      <input>RC + personas</input>
      <action>Apply qa-bug-bash-runbook; commit ledger.</action>
      <output>ledger</output>
    </step>
    <step n="5" name="run-perf">
      <input>perf CI</input>
      <action>Apply qa-perf-run-verdict-template; verdict pass/fail.</action>
      <output>verdict</output>
    </step>
    <step n="6" name="lock-triggers">
      <input>ops + canon</input>
      <action>Apply qa-rollback-trigger-canon; commit canon.</action>
      <output>canon</output>
    </step>
    <step n="7" name="go-no-go">
      <input>all stage outcomes</input>
      <action>Approver makes go/no-go decision; record + retro.</action>
      <output>cycle record + retro_note</output>
    </step>
  </section>
</text>
