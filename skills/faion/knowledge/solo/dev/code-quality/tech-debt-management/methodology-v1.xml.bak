<methodology slug="tech-debt-management">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>code-quality</domain>
    <summary>Prioritize tech debt with Impact x Risk x Interest / Cost score, pick payoff strategy (Boy Scout / feature-attached / sprint / Strangler Fig), prevent accumulation via CI gates.</summary>
    <tags>
      <tag>tech-debt</tag>
      <tag>refactoring</tag>
      <tag>prioritization</tag>
      <tag>strangler-fig</tag>
      <tag>quality-gates</tag>
    </tags>
    <difficulty>intermediate</difficulty>
    <created>2026-04-27</created>
    <applies-to>both</applies-to>
