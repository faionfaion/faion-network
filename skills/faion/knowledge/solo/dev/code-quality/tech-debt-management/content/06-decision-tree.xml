<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Tech Debt Management Decision Tree" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Routes per-item by score band → strategy → exit + gate present. Branches name observable plan features.</summary>

  <decision-tree>
    <root-question id="q-prereqs">Are prerequisites satisfied: scored register, CI infra, threshold, owner-assignable?</root-question>

    <branch when="prereqs_met == false">
      <conclusion ref="skip-this-methodology" verdict="abort"/>
    </branch>

    <branch when="prereqs_met == true">
      <question id="q-score">Is the debt item's score above threshold?</question>

      <branch when="score_below_threshold == true">
        <conclusion ref="r1-strategy-by-score" verdict="block-low-score-skip"/>
      </branch>

      <branch when="score_below_threshold == false">
        <question id="q-strategy">Is strategy assigned AND consistent with score band per r1?</question>

        <branch when="strategy_inconsistent == true">
          <conclusion ref="r1-strategy-by-score" verdict="block-no-exit-criteria"/>
        </branch>

        <branch when="strategy_inconsistent == false">
          <question id="q-exit">Is exit_criterion observable (not "ongoing" / "continuous")?</question>

          <branch when="exit_unobservable == true">
            <conclusion ref="r2-exit-criteria" verdict="block-no-exit-criteria"/>
          </branch>

          <branch when="exit_unobservable == false">
            <question id="q-gate">Is gate.kind mechanical (not checklist/review/docs)?</question>

            <branch when="gate_non_mechanical == true">
              <conclusion ref="r3-gate-the-fix" verdict="block-no-gate"/>
            </branch>

            <branch when="gate_non_mechanical == false">
              <conclusion ref="run-the-checklist" verdict="adopt-plan"/>
            </branch>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="strangler-fig-plan">
    prereqs_met=true → score=80 above threshold 30 → strategy=strangler-fig matches broad-high → exit_criterion="100% traffic switched for 2 weeks" observable → gate.kind=loc-cap mechanical → verdict=adopt-plan (ref run-the-checklist).
  </example>
</text>
