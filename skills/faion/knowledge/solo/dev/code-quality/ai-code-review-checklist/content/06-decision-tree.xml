<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="AI Code Review Checklist Decision Tree" version="1.0.0" est_tokens="500" depth="essential">
  <summary>Routes a 12-check trace to aggregate verdict. Branches name observable check outcomes; leaves reference rules.</summary>

  <decision-tree>
    <root-question id="q-prereqs">Are prerequisites satisfied: AI markers present, lockfile + conventions in repo, protected branch?</root-question>

    <branch when="prereqs_met == false">
      <conclusion ref="skip-this-methodology" verdict="abort"/>
    </branch>

    <branch when="prereqs_met == true">
      <question id="q-coverage">Are all 12 checks evaluated (no unset values)?</question>

      <branch when="checks_unevaluated == true">
        <conclusion ref="run-the-checklist" verdict="block"/>
      </branch>

      <branch when="checks_unevaluated == false">
        <question id="q-block-tier">Does any check have value "block"?</question>

        <branch when="any_block == true">
          <conclusion ref="c01-hallucinated-imports" verdict="block"/>
        </branch>

        <branch when="any_block == false">
          <question id="q-request-changes">Does any check have value "request-changes"?</question>

          <branch when="any_request_changes == true">
            <conclusion ref="c03-convention-drift" verdict="request-changes"/>
          </branch>

          <branch when="any_request_changes == false">
            <conclusion ref="run-the-checklist" verdict="approve"/>
          </branch>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="approve-with-note">
    prereqs_met=true → all 12 evaluated → no block → no request-changes → verdict=approve (ref run-the-checklist).
  </example>
</text>
