<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Code Review Checklist Output Contract" version="1.0.0" est_tokens="800" depth="essential">
  <summary>JSON Schema for the per-PR review-decision artefact. Pre-merge bot rejects without a valid record.</summary>

  <section title="JSON Schema (draft-07)">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-code-review-checklist.json",
  "type": "object",
  "required": ["artefact_id", "pr_ref", "ai_pct_lines", "checks", "verdict", "reviewer_email", "version", "last_reviewed"],
  "properties": {
    "artefact_id":   {"type": "string", "pattern": "^aicr-[a-z0-9-]{6,}$"},
    "pr_ref":        {"type": "string", "minLength": 1},
    "ai_pct_lines":  {"type": "integer", "minimum": 0, "maximum": 100},
    "checks": {
      "type": "object",
      "required": ["c01-hallucinated-imports", "c02-silent-skip-tests", "c03-convention-drift", "c04-supply-chain", "c05-secret-exposure", "c06-deferred-debt", "c07-error-handling-coverage", "c08-overscoped-changes", "c09-test-quality", "c10-perf-regression", "c11-deferred-impl", "c12-ai-disclosure"],
      "additionalProperties": {"enum": ["approve", "approve-with-note", "request-changes", "block"]}
    },
    "verdict":       {"enum": ["approve", "request-changes", "block"]},
    "block_reason":  {"type": ["string", "null"]},
    "reviewer_email":{"type": "string", "format": "email"},
    "version":       {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "last_reviewed": {"type": "string", "format": "date"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "aicr-pr-483",
  "pr_ref": "https://github.com/org/repo/pull/483",
  "ai_pct_lines": 62,
  "checks": {
    "c01-hallucinated-imports": "approve",
    "c02-silent-skip-tests": "approve",
    "c03-convention-drift": "approve-with-note",
    "c04-supply-chain": "approve",
    "c05-secret-exposure": "approve",
    "c06-deferred-debt": "approve",
    "c07-error-handling-coverage": "approve",
    "c08-overscoped-changes": "approve",
    "c09-test-quality": "approve",
    "c10-perf-regression": "approve",
    "c11-deferred-impl": "approve",
    "c12-ai-disclosure": "approve"
  },
  "verdict": "approve",
  "reviewer_email": "ruslan@faion.net",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "pr483",
  "pr_ref": "pr 483",
  "ai_pct_lines": 80,
  "checks": {"c01-hallucinated-imports": "block"},
  "verdict": "approve",
  "reviewer_email": "team@",
  "version": "1.0",
  "last_reviewed": "today"
}
]]></code>
    <note>artefact_id missing aicr- prefix; checks has only 1 of 12 (run-the-checklist violation); reviewer is team alias; c01=block but verdict=approve is contradiction; version + last_reviewed malformed.</note>
  </example>

  <section title="Forbidden patterns">
    <antipattern>
      <description>Any check has value not in the verdict enum.</description>
      <reason>Mechanical enforcement — non-canonical verdicts make the artefact unusable downstream.</reason>
    </antipattern>
    <antipattern>
      <description>Any check is "block" but the artefact-level verdict is "approve" or "request-changes".</description>
      <reason>Block tier checks override; aggregate verdict must be "block".</reason>
    </antipattern>
    <antipattern>
      <description>verdict="approve" without all 12 checks present with valid values.</description>
      <reason>run-the-checklist requires full coverage.</reason>
    </antipattern>
  </section>

  <reference path="templates/ai-code-review-checklist.json">Schema canonical location.</reference>
  <reference path="scripts/validate-ai-code-review-checklist.py">Validator that enforces this contract.</reference>
</text>
