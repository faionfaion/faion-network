<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Extreme Programming Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/xp-extreme-programming.json",
  "type": "object",
  "required": [
    "adoption_order",
    "practices",
    "ci_max_minutes",
    "release_cadence_days",
    "customer_access"
  ],
  "properties": {
    "adoption_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "practices": {
      "type": "object",
      "required": [
        "tdd",
        "pairing",
        "trunk_based",
        "refactoring",
        "small_releases"
      ]
    },
    "ci_max_minutes": {
      "type": "integer",
      "maximum": 10
    },
    "release_cadence_days": {
      "type": "integer",
      "maximum": 14
    },
    "customer_access": {
      "type": "object",
      "required": [
        "named_person",
        "sla_hours"
      ]
    },
    "metrics": {
      "type": "object"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "adoption_order": [
    "green_ci",
    "tdd",
    "trunk_based",
    "pairing",
    "small_releases",
    "refactor",
    "customer"
  ],
  "practices": {
    "tdd": true,
    "pairing": true,
    "trunk_based": true,
    "refactoring": true,
    "small_releases": true
  },
  "ci_max_minutes": 8,
  "release_cadence_days": 7,
  "customer_access": {
    "named_person": "Pat",
    "sla_hours": 24
  },
  "metrics": {
    "test_coverage": 0.85,
    "ci_pass_rate": 0.95,
    "release_cadence_days_actual": 7
  }
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "adoption_order": [],
  "practices": {
    "tdd": true
  },
  "ci_max_minutes": 30,
  "release_cadence_days": 60,
  "customer_access": {
    "sla_hours": 72
  }
}
]]></code>
    <note>adoption_order empty; practices missing keys; ci_max_minutes&gt;10 forbidden; release_cadence_days&gt;14 forbidden; customer_access missing named_person.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="tdd-without-fast-ci">Team adopts TDD; CI takes 30 minutes; pair switches context 5 times per cycle.</pattern>
      <pattern id="deferred-refactor">Backlog of 'refactor tickets'; each takes 3 days; tests get skipped during the refactor.</pattern>
      <pattern id="long-branches">Feature branch lives 3 weeks; merge conflict on every file; CI red on rebase.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-xp-extreme-programming.py">Validator script (see scripts/).</reference>
</text>
