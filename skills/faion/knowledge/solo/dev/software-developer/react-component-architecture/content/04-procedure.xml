<text id="04-procedure" title="React Component Architecture Procedure" version="1.1.0" est_tokens="900" depth="essential">
  <summary>Step-by-step procedure to apply React Component Architecture end-to-end. Each step lists input, action, output, and an optional decision gate.</summary>
  <section title="Procedure">
    <step n="1" name="pick-routing">
      <input>Framework choice + RSC needs.</input>
      <action>Pick routing model; declare in spec.</action>
      <output>routing field.</output>
      <decision-gate>Reject non-canonical names.</decision-gate>
    </step>
    <step n="2" name="design-folders">
      <input>Feature inventory.</input>
      <action>Declare features/&lt;name&gt;/ + components/ui/ paths.</action>
      <output>folder_layout block.</output>
      <decision-gate>Reject missing primitives or features.</decision-gate>
    </step>
    <step n="3" name="establish-primitive-layer">
      <input>Design tokens + base components.</input>
      <action>Pick shadcn vendoring or library; document import boundary.</action>
      <output>primitive_layer field.</output>
      <decision-gate>Reject business imports in components/ui/*.</decision-gate>
    </step>
    <step n="4" name="scope-state">
      <input>State map.</input>
      <action>Map state to global (Context) vs feature (store) vs local; declare per scope.</action>
      <output>state_strategy block.</output>
      <decision-gate>Reject Context for non-global state.</decision-gate>
    </step>
    <step n="5" name="memoisation-policy">
      <input>Profiler runs.</input>
      <action>Declare profiler_only or memoised_child_only; document.</action>
      <output>memoisation_policy field.</output>
      <decision-gate>Reject 'blanket'.</decision-gate>
    </step>
  </section>
</text>
