<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Go Project Structure Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for go-project-structure.</summary>

  <decision-tree>
    <root-question id="q-root">Is this a Go module project that ships &gt;=1 binary and warrants the layout?</root-question>

    <branch when="library_only OR single_file_experiment">
      <conclusion ref="skip-this-methodology" verdict="SKIP — layout overhead exceeds payoff"/>
    </branch>
    <branch when="project_size &lt; 1kloc AND author_count == 1">
      <conclusion ref="skip-this-methodology" verdict="SKIP — flat layout is fine at this scale"/>
    </branch>
    <branch when="main_contains_business_logic == true">
      <conclusion ref="r1-cmd-is-entry-points-only" verdict="BLOCK — move logic into internal/"/>
    </branch>
    <branch when="internal_pkg_in_pkg_dir == true">
      <conclusion ref="r3-pkg-only-for-public-api" verdict="BLOCK — move to internal/"/>
    </branch>
    <branch when="cycles_detected &gt; 0">
      <conclusion ref="r4-no-cyclic-dependencies" verdict="BLOCK — invert dependency via interface"/>
    </branch>
    <branch when="top_level_loose_files &gt; 0">
      <conclusion ref="r6-no-top-level-loose-files" verdict="BLOCK — move into cmd/ or internal/ or delete"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — layout ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="go-project-structure-happy-path">
    Module + 2 binaries + 11 internal packages → first two branches do not match → main is thin → no internal-in-pkg → no cycles → clean top level → APPROVE.
  </example>
</text>
