<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="API Documentation Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-sections">all 6 sections present?</root-question>
    <branch when="sections_missing">
      <conclusion ref="six-section-coverage" verdict="verdict=fail; add missing sections"/>
    </branch>
    <branch when="sections_all">
      <question id="q-curl">quick_start_curl_count &gt;= 1?</question>
      <branch when="curl_missing">
        <conclusion ref="quick-start-curl" verdict="verdict=fail; add runnable curl"/>
      </branch>
      <branch when="curl_ok">
        <question id="q-examples-source">examples_source == openapi?</question>
        <branch when="hand_examples">
          <conclusion ref="examples-from-spec" verdict="verdict=fail; wire examples to spec.examples"/>
        </branch>
        <branch when="openapi_examples">
          <conclusion ref="changelog-per-version" verdict="verdict=pass; publish docs bundle"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="docs-public-api">
    6 sections present → curl=3 → examples_source=openapi → conclusion changelog-per-version → pass.
  </example>
</text>
