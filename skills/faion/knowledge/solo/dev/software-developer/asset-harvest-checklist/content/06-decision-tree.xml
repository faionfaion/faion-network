<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Asset Harvest Checklist Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-coverage">all 5 categories present?</root-question>
    <branch when="category_missing">
      <conclusion ref="five-category-coverage" verdict="no-go; add missing categories"/>
    </branch>
    <branch when="categories_complete">
      <question id="q-sources">every item has a concrete source (no TBD)?</question>
      <branch when="tbd_present">
        <conclusion ref="every-item-has-source" verdict="no-go; replace TBD with concrete source"/>
      </branch>
      <branch when="sources_ok">
        <question id="q-required-missing">any required_by_launch=true item still missing?</question>
        <branch when="required_missing">
          <conclusion ref="required-by-launch-gate" verdict="no-go; complete required items first"/>
        </branch>
        <branch when="all_required_done">
          <conclusion ref="og-and-favicon-not-optional" verdict="go; launch checklist clears"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="ah-landing-q2">
    5 categories present → all sources non-TBD → all required items done → conclusion og-and-favicon-not-optional → go.
  </example>
</text>
