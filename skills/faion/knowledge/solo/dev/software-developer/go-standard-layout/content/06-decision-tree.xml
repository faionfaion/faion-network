<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Go Standard Layout Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for go-standard-layout.</summary>

  <decision-tree>
    <root-question id="q-root">Does the feature have non-trivial business logic AND persistence AND service-level test target?</root-question>

    <branch when="architecture == cqrs OR architecture == hexagonal">
      <conclusion ref="skip-this-methodology" verdict="SKIP — adapt to alternate architecture"/>
    </branch>
    <branch when="business_logic_count &lt;= 1 AND persistence == none">
      <conclusion ref="skip-this-methodology" verdict="SKIP — thin CRUD doesn't need layering"/>
    </branch>
    <branch when="handler_logic_lines &gt; 50">
      <conclusion ref="r1-handler-decodes-encodes-only" verdict="BLOCK — extract logic into service"/>
    </branch>
    <branch when="service_imports_http == true">
      <conclusion ref="r4-no-http-types-in-service" verdict="BLOCK — extract primitives at handler"/>
    </branch>
    <branch when="handler_imports_db == true">
      <conclusion ref="r3-repo-owns-sql-and-orm" verdict="BLOCK — add repo method"/>
    </branch>
    <branch when="interface_declared_at_repo == true">
      <conclusion ref="r5-interfaces-at-consumer" verdict="BLOCK — move interfaces to service"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — layered feature ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="go-standard-layout-happy-path">
    Orders feature + 6 operations + PostgreSQL → first two branches do not match → handler thin → no HTTP in service → no DB in handler → consumer-side interfaces → APPROVE.
  </example>
</text>
