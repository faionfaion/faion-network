<text id="06-decision-tree" title="AI-Generated Test Validation Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by mutation-survival + static-rule rejections to a rule in 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-mutation">mutation_survival &gt;= 0.70?</root-question>

    <branch when="mutation_survival &lt; 0.70">
      <conclusion ref="mutation-survival-floor" verdict="verdict=rework; remove or fix tests until kill-rate clears"/>
    </branch>

    <branch when="mutation_survival &gt;= 0.70">
      <question id="q-static">any static-rule rejection?</question>
      <branch when="static_rejections &gt; 0">
        <conclusion ref="no-mirror-test" verdict="verdict=rework; delete/rewrite rejected tests; re-run"/>
      </branch>
      <branch when="static_rejections == 0">
        <question id="q-assertion-drift">any test survives every mutation?</question>
        <branch when="assertion_drift &gt; 0">
          <conclusion ref="assertion-must-fail-once" verdict="verdict=rework; tighten assertions on drifters"/>
        </branch>
        <branch when="assertion_drift == 0">
          <conclusion ref="behavioural-assertion" verdict="verdict=pass; ship AI tests"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="tvr-pricing">
    mutation_survival=0.78 &gt;= 0.70 → static_rejections=7 &gt; 0 → conclusion no-mirror-test → verdict=rework, then re-run pass.
  </example>
</text>
