<text id="02-output-contract" title="Node.js Service Layer Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nodejs-service-layer.json",
  "type": "object",
  "required": ["feature_path", "controller_present", "service_present", "repo_present", "http_imports_in_service", "orm_imports_in_controller"],
  "properties": {
    "feature_path": {"type": "string", "minLength": 3},
    "controller_present": {"type": "boolean"},
    "service_present": {"type": "boolean"},
    "repo_present": {"type": "boolean"},
    "http_imports_in_service": {"type": "integer", "minimum": 0, "maximum": 0},
    "orm_imports_in_controller": {"type": "integer", "minimum": 0, "maximum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "feature_path": "src/features/orders",
  "controller_present": true,
  "service_present": true,
  "repo_present": true,
  "http_imports_in_service": 0,
  "orm_imports_in_controller": 0,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "feature_path": "x",
  "controller_present": true,
  "service_present": false,
  "http_imports_in_service": 3,
  "orm_imports_in_controller": 5
}
]]></code>
    <note>feature_path too short, service missing, http_imports_in_service and orm_imports_in_controller above 0 (both must be 0).</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Controller importing Prisma/Drizzle/Knex/pg</pattern>
      <pattern id="f2">Service importing express/fastify/koa/hono</pattern>
      <pattern id="f3">Controller branching on business rules instead of delegating to service</pattern>
      <pattern id="f4">Interface declared at repo side instead of service side</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Auto-format with Prettier.</transformation>
      <transformation>Sort imports per ESLint convention.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-nodejs-service-layer.py">Validator script</reference>
</text>
