<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Rate Limiting Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rate-limiting.json",
  "type": "object",
  "required": [
    "classes",
    "key_strategy",
    "storage",
    "headers",
    "fail_mode"
  ],
  "properties": {
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "algorithm",
          "rps",
          "burst"
        ]
      }
    },
    "key_strategy": {
      "type": "string",
      "enum": [
        "user_id",
        "tenant_id",
        "ip",
        "api_key",
        "composite"
      ]
    },
    "storage": {
      "type": "object",
      "required": [
        "backend",
        "ttl_seconds"
      ]
    },
    "headers": {
      "type": "object",
      "required": [
        "retry_after",
        "ratelimit_remaining"
      ]
    },
    "fail_mode": {
      "type": "string",
      "enum": [
        "open",
        "closed"
      ]
    },
    "bypass_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "classes": [
    {
      "name": "auth",
      "algorithm": "token_bucket",
      "rps": 5,
      "burst": 10
    },
    {
      "name": "read",
      "algorithm": "sliding_window_counter",
      "rps": 100,
      "burst": 0
    }
  ],
  "key_strategy": "user_id",
  "storage": {
    "backend": "redis",
    "ttl_seconds": 120
  },
  "headers": {
    "retry_after": true,
    "ratelimit_remaining": true
  },
  "fail_mode": "open",
  "bypass_paths": [
    "/healthz",
    "/metrics"
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "classes": [
    {
      "name": "all",
      "algorithm": "guess"
    }
  ],
  "key_strategy": "random",
  "storage": {
    "backend": "redis"
  },
  "headers": {},
  "fail_mode": "maybe"
}
]]></code>
    <note>class missing rps + burst; algorithm not in enum; key_strategy not in enum; storage missing ttl_seconds; headers empty; fail_mode not in enum.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="fixed-window-cliff">At 14:59:59 attacker burns 100 req; at 15:00:01 burns another 100 - effective 200 in 2 seconds.</pattern>
      <pattern id="per-ip-nat-block">Office of 200 employees all blocked together; one user shared egress IP.</pattern>
      <pattern id="no-retry-after-thundering">Clients hit 429 and retry every 100ms; service stays at 100% CPU.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-rate-limiting.py">Validator script (see scripts/).</reference>
</text>
