<?xml version="1.0" encoding="UTF-8"?>
<text id="05-examples" title="REST API Design Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: REST-ORDERS-V1 defines /orders, /orders/{id}, /orders/{id}/items with idempotency-key on POSTs and HATEOAS on stateful resources.</summary>

  <section title="Scenario">
    <p>New e-commerce order API; needs to survive client retries on /orders POST without duplicate orders.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "resources": [
    "order",
    "order-item"
  ]
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "spec_id": "REST-ORDERS-V1",
  "resources": [
    {
      "path": "/orders",
      "methods": [
        "GET",
        "POST"
      ],
      "idempotent": [
        "GET"
      ],
      "hateoas_links": true,
      "idempotency_key": true
    },
    {
      "path": "/orders/{id}",
      "methods": [
        "GET",
        "PUT",
        "DELETE"
      ],
      "idempotent": [
        "GET",
        "PUT",
        "DELETE"
      ],
      "hateoas_links": true
    },
    {
      "path": "/orders/{id}/items",
      "methods": [
        "GET",
        "POST"
      ],
      "idempotent": [
        "GET"
      ],
      "idempotency_key": true
    }
  ],
  "status_codes_used": [
    200,
    201,
    204,
    400,
    401,
    404,
    409,
    422,
    429,
    500
  ]
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-api-rest-design.py --file artefact.json
OK
]]></code>
  </section>
</text>
