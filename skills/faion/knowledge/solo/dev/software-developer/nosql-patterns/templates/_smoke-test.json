{
  "__faion_header__": {
    "purpose": "Minimum viable filled-in nosql-patterns artefact for smoke testing the validator.",
    "consumes": "see content/02-output-contract.xml inputs for nosql-patterns",
    "produces": "artefact conforming to content/02-output-contract.xml",
    "depends_on": "scripts/validate-nosql-patterns.py --self-test",
    "token_budget_impact": "~200-400 tokens when loaded as context"
  },
  "store_class": "document",
  "access_patterns": [
    {"name": "get_user_profile_by_id", "qps": 1200, "latency_ms_p95": 30}
  ],
  "model": {
    "entities": ["user"],
    "embed_or_reference": {"preferences": "embed", "orders": "reference"}
  },
  "ttl_policy": [
    {"prefix": "auth:session", "ttl_seconds": 3600}
  ],
  "indexes": [
    {"collection_or_label": "users", "fields": ["email"]}
  ],
  "partition_key": {"key": "tenant_id", "primary_query": "list users where tenant_id=?"}
}
