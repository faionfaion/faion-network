<text id="06-decision-tree" title="NoSQL Patterns Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="relational-invariants">Does the workload require strong multi-row relational invariants (ledger, inventory)?</root-question>
      <branch when="relational_invariants == true">
        <conclusion ref="skip-this-methodology" verdict="halt; use Postgres + database-design instead"/>
      </branch>
      <branch when="relational_invariants == false">
        <question id="access-register">Is the access-pattern register documented (≥1 entry)?</question>
          <branch when="access_register == empty">
            <conclusion ref="access-pattern-first" verdict="halt; produce access-pattern register first"/>
          </branch>
          <branch when="access_register == present">
            <question id="store-shape">Which shape dominates: aggregate / cache / time-series / traversal?</question>
              <branch when="shape == cache">
                <conclusion ref="ttl-on-every-cache-key" verdict="store_class=key_value; author ttl_policy"/>
              </branch>
              <branch when="shape == time_series">
                <conclusion ref="partition-key-frozen" verdict="store_class=wide_column; partition_key=(entity_id, time_bucket)"/>
              </branch>
              <branch when="shape == aggregate">
                <conclusion ref="bounded-embed-rule" verdict="store_class=document; embed bounded, reference unbounded"/>
              </branch>
              <branch when="shape == traversal">
                <conclusion ref="indexes-match-predicates" verdict="store_class=graph; index every node property in MATCH"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="relational_invariants=false -&gt; access_register=present -&gt; shape=aggregate -&gt; bounded-embed-rule.">Worked path from root-question to conclusion.</example>
</text>
