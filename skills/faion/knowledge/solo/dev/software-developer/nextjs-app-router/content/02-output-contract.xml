<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Next.js App Router Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/nextjs-app-router.json",
  "type": "object",
  "required": ["app_dir", "server_components_count", "client_components_count", "server_actions_count", "fetch_in_client_components", "api_routes_for_mutations"],
  "properties": {
    "app_dir": {"type": "string", "minLength": 1},
    "server_components_count": {"type": "integer", "minimum": 1},
    "client_components_count": {"type": "integer", "minimum": 0},
    "server_actions_count": {"type": "integer", "minimum": 0},
    "fetch_in_client_components": {"type": "integer", "minimum": 0, "maximum": 0},
    "api_routes_for_mutations": {"type": "integer", "minimum": 0, "maximum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "app_dir": "app/",
  "server_components_count": 42,
  "client_components_count": 11,
  "server_actions_count": 8,
  "fetch_in_client_components": 0,
  "api_routes_for_mutations": 0,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "app_dir": "",
  "server_components_count": 0,
  "fetch_in_client_components": 14,
  "api_routes_for_mutations": 5
}
]]></code>
    <note>app_dir empty, server_components_count below minimum, fetch_in_client_components and api_routes_for_mutations above 0 (must be 0).</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">'use client' at a page or top-layout level</pattern>
      <pattern id="f2">fetch() inside a client component on mount (without explicit justification)</pattern>
      <pattern id="f3">API route handling a form submit instead of a server action</pattern>
      <pattern id="f4">Data read without an explicit revalidate / tags / static declaration</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Auto-format with Prettier.</transformation>
      <transformation>Sort 'use client' directives at the top of each file.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-nextjs-app-router.py">Validator script</reference>
</text>
