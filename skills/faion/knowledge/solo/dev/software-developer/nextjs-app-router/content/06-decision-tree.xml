<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Next.js App Router Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for nextjs-app-router.</summary>

  <decision-tree>
    <root-question id="q-root">Is the project Next.js &gt;=14 with App Router enabled AND has server runtime?</root-question>

    <branch when="nextjs_version &lt; 14 OR pages_router_locked == true">
      <conclusion ref="skip-this-methodology" verdict="SKIP — Pages Router methodology applies"/>
    </branch>
    <branch when="deployment == static_export_only">
      <conclusion ref="skip-this-methodology" verdict="SKIP — server features unavailable"/>
    </branch>
    <branch when="use_client_at_top == true">
      <conclusion ref="r2-explicit-use-client-boundary" verdict="BLOCK — move directive to leaf"/>
    </branch>
    <branch when="fetch_in_client_component == true">
      <conclusion ref="r5-no-fetch-in-client-components" verdict="BLOCK — fetch on server"/>
    </branch>
    <branch when="api_route_for_mutation == true">
      <conclusion ref="r3-server-actions-for-mutations" verdict="BLOCK — migrate to server action"/>
    </branch>
    <branch when="no_revalidate_declared == true">
      <conclusion ref="r6-explicit-revalidate-strategy" verdict="BLOCK — declare cache strategy"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — App Router patterns ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="nextjs-app-router-happy-path">
    Next.js 14 + dynamic deploy → first two branches do not match → use-client at leaves → server-side fetches → server actions → revalidate annotated → APPROVE.
  </example>
</text>
