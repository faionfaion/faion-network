<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Python Async Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/python-async-patterns.json",
  "type": "object",
  "required": [
    "runtime",
    "async_drivers",
    "timeout_policy",
    "fanout_caps",
    "sync_offload_pattern"
  ],
  "properties": {
    "runtime": {
      "type": "string",
      "enum": [
        "asyncio",
        "asyncio+uvloop"
      ]
    },
    "async_drivers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "timeout_policy": {
      "type": "object",
      "required": [
        "default_ms"
      ]
    },
    "fanout_caps": {
      "type": "object",
      "required": [
        "max_parallel",
        "mechanism"
      ]
    },
    "sync_offload_pattern": {
      "type": "string",
      "enum": [
        "to_thread",
        "executor_pool",
        "none"
      ]
    },
    "lint_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "runtime": "asyncio+uvloop",
  "async_drivers": [
    "httpx",
    "asyncpg",
    "aioboto3"
  ],
  "timeout_policy": {
    "default_ms": 3000
  },
  "fanout_caps": {
    "max_parallel": 50,
    "mechanism": "TaskGroup+Semaphore"
  },
  "sync_offload_pattern": "to_thread",
  "lint_rules": [
    "ruff:ASYNC",
    "no-requests-on-hot-path"
  ]
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "runtime": "thread-pool",
  "async_drivers": [],
  "timeout_policy": {},
  "fanout_caps": {
    "mechanism": "gather"
  },
  "sync_offload_pattern": "inline"
}
]]></code>
    <note>runtime not in enum; async_drivers empty; timeout_policy missing default_ms; fanout_caps missing max_parallel; sync_offload_pattern not in enum.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="requests-on-hot-path">FastAPI worker stalls under load; CPU low, latency high.</pattern>
      <pattern id="unbounded-gather">OOMKilled after 30 minutes of high traffic.</pattern>
      <pattern id="no-timeout-await">Worker pool exhausted after one upstream hang; service goes 503.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-python-async-patterns.py">Validator script (see scripts/).</reference>
</text>
