<text id="02-output-contract" title="PWA Development Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/pwa-development.json",
  "type": "object",
  "required": [
    "manifest",
    "service_worker",
    "cache_plan",
    "update_strategy"
  ],
  "properties": {
    "manifest": {
      "type": "object",
      "required": [
        "name",
        "short_name",
        "start_url",
        "display",
        "icons"
      ]
    },
    "service_worker": {
      "type": "object",
      "required": [
        "scope",
        "skip_waiting",
        "clients_claim"
      ]
    },
    "cache_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "route",
          "strategy",
          "ttl_seconds",
          "max_entries"
        ]
      }
    },
    "update_strategy": {
      "type": "object",
      "required": [
        "user_prompt",
        "auto_reload"
      ]
    },
    "offline_page": {
      "type": "string"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "manifest": {
    "name": "Acme",
    "short_name": "Acme",
    "start_url": "/",
    "display": "standalone",
    "icons": [
      {
        "src": "/i192.png",
        "sizes": "192x192"
      },
      {
        "src": "/i512.png",
        "sizes": "512x512"
      }
    ]
  },
  "service_worker": {
    "scope": "/",
    "skip_waiting": true,
    "clients_claim": true
  },
  "cache_plan": [
    {
      "route": "/api/static/*",
      "strategy": "cache-first",
      "ttl_seconds": 86400,
      "max_entries": 100
    },
    {
      "route": "/",
      "strategy": "network-first",
      "ttl_seconds": 60,
      "max_entries": 1
    }
  ],
  "update_strategy": {
    "user_prompt": true,
    "auto_reload": false
  },
  "offline_page": "/offline.html"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "manifest": {
    "name": "Acme"
  },
  "service_worker": {
    "scope": "/",
    "skip_waiting": false,
    "clients_claim": false
  },
  "cache_plan": [
    {
      "route": "/",
      "strategy": "cache-first"
    }
  ],
  "update_strategy": {
    "user_prompt": false,
    "auto_reload": true
  }
}
]]></code>
    <note>manifest missing short_name/start_url/display/icons; SW lifecycle wrong; shell is cache-first (forbidden); update strategy silent.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="missing-icons">Install prompt never shows on Android; Lighthouse PWA score 30.</pattern>
      <pattern id="cache-first-shell">New deploy ships; users keep seeing 3-week-old build forever.</pattern>
      <pattern id="silent-update">Engineers see new code in incognito; users on installed PWA see old code for weeks.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-pwa-development.py">Validator script (see scripts/).</reference>
</text>
