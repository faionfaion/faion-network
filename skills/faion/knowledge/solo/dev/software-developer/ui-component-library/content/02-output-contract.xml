<text id="02-output-contract" title="UI Component Library Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ui-component-library.json",
  "type": "object",
  "required": [
    "layers",
    "storybook",
    "a11y",
    "visual_regression",
    "release_process"
  ],
  "properties": {
    "layers": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "enum": [
          "tokens",
          "primitives",
          "patterns",
          "templates"
        ]
      }
    },
    "storybook": {
      "type": "object",
      "required": [
        "enabled",
        "states_required"
      ]
    },
    "a11y": {
      "type": "object",
      "required": [
        "tool",
        "gate"
      ]
    },
    "visual_regression": {
      "type": "object",
      "required": [
        "tool",
        "gate"
      ]
    },
    "release_process": {
      "type": "object",
      "required": [
        "semver",
        "changelog"
      ]
    },
    "deprecation_window_minors": {
      "type": "integer",
      "minimum": 1
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "layers": [
    "tokens",
    "primitives",
    "patterns",
    "templates"
  ],
  "storybook": {
    "enabled": true,
    "states_required": [
      "default",
      "hover",
      "focus",
      "disabled",
      "loading",
      "empty",
      "error"
    ]
  },
  "a11y": {
    "tool": "axe-core",
    "gate": "block_merge"
  },
  "visual_regression": {
    "tool": "chromatic",
    "gate": "block_merge"
  },
  "release_process": {
    "semver": true,
    "changelog": "CHANGELOG.md"
  },
  "deprecation_window_minors": 2
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "layers": [
    "all"
  ],
  "storybook": {
    "enabled": false
  },
  "a11y": {
    "tool": "manual"
  },
  "visual_regression": {},
  "release_process": {
    "semver": false
  }
}
]]></code>
    <note>layers wrong shape; storybook disabled; a11y missing gate; visual_regression empty; release_process semver=false forbidden.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="missing-states">Library Button has only `default` story; loading + disabled + error states broken in prod.</pattern>
      <pattern id="manual-a11y-only">Library passes manual review; deploy fails WCAG audit on contrast + role.</pattern>
      <pattern id="no-visual-regression">Token change in `--primary` accidentally flips Button text colour; nobody noticed for two weeks.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-ui-component-library.py">Validator script (see scripts/).</reference>
</text>
