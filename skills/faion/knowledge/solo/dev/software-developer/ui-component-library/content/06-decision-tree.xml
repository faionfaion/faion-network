<text id="06-decision-tree" title="UI Component Library Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="library-needed">Are there multiple consumers OR sustained growth justifying a library?</root-question>
      <branch when="needed == no">
        <conclusion ref="skip-this-methodology" verdict="skip; inline components"/>
      </branch>
      <branch when="needed == yes">
        <question id="story-coverage">Does each component have stories for all required states?</question>
          <branch when="stories == incomplete">
            <conclusion ref="story-per-component-all-states" verdict="author missing states first"/>
          </branch>
          <branch when="stories == complete">
            <question id="release-discipline">Is release process semver + changelog?</question>
              <branch when="release == ad_hoc">
                <conclusion ref="semver-and-changelog" verdict="adopt changesets + semver"/>
              </branch>
              <branch when="release == disciplined">
                <conclusion ref="visual-regression-gate" verdict="wire visual regression on PR"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="needed=yes -&amp;gt; stories=complete -&amp;gt; release=disciplined -&amp;gt; visual-regression-gate.">Worked path from root-question to conclusion.</example>
</text>
