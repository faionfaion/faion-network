{
  "__faion_header__": {
    "purpose": "Minimum viable filled-in api-rate-limiting artefact for validator round-trip",
    "consumes": "n/a",
    "produces": "smoke-test fixture",
    "depends_on": "templates/output-schema.json",
    "token_budget_impact": "~150 tokens when loaded"
  },
  "policy_id": "RL-PUBLIC-API",
  "algorithm": "sliding-window",
  "key_source": "jwt-sub",
  "tiers": {
    "free": {
      "per_second": 5,
      "per_minute": 60,
      "per_hour": 1000
    },
    "paid": {
      "per_second": 20,
      "per_minute": 600,
      "per_hour": 20000
    },
    "partner": {
      "per_second": 50,
      "per_minute": 1500,
      "per_hour": 60000
    }
  },
  "envelope_type_uri": "https://api.example.com/errors/rate-limited",
  "metrics_emitted": [
    "rate_limit_hits_total",
    "rate_limit_rejected_total",
    "rate_limit_latency_ms"
  ]
}
