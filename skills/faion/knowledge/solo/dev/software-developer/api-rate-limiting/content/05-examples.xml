<text id="05-examples" title="API Rate Limiting Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: RL-PUBLIC-API enforces sliding-window per JWT sub across free / paid / partner tiers.</summary>

  <section title="Scenario">
    <p>Public API; AUTH-PUBLIC-V1 issues JWT to all callers; tier resolved from claims.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "auth_id": "AUTH-PUBLIC-V1",
  "tiers": [
    "free",
    "paid",
    "partner"
  ]
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "policy_id": "RL-PUBLIC-API",
  "algorithm": "sliding-window",
  "key_source": "jwt-sub",
  "tiers": {
    "free": {
      "per_second": 5,
      "per_minute": 60,
      "per_hour": 1000
    },
    "paid": {
      "per_second": 20,
      "per_minute": 600,
      "per_hour": 20000
    },
    "partner": {
      "per_second": 50,
      "per_minute": 1500,
      "per_hour": 60000
    }
  },
  "envelope_type_uri": "https://api.example.com/errors/rate-limited",
  "metrics_emitted": [
    "rate_limit_hits_total",
    "rate_limit_rejected_total",
    "rate_limit_latency_ms"
  ]
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-api-rate-limiting.py --file artefact.json
OK
]]></code>
  </section>
</text>
