<methodology slug="caching-strategy">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>software-developer</domain>
    <summary>Multi-level caching (CDN to app in-memory to Redis/Valkey to DB) with explicit pattern selection and mandatory per-key TTL, invalidation trigger, and hit-rate monitoring.</summary>
    <difficulty>intermediate</difficulty>
    <created>2026-04-29</created>
    <tags>
