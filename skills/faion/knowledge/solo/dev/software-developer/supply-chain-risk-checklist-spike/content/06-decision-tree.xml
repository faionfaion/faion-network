<text id="06-decision-tree" title="Supply Chain Risk Checklist Spike Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="production-path">Will the library land on a production or build path?</root-question>
      <branch when="production == false">
        <conclusion ref="skip-this-methodology" verdict="skip; not worth the spike"/>
      </branch>
      <branch when="production == true">
        <question id="all-signals-fresh">Are all 7 signals retrievable AND fresh within 24h?</question>
          <branch when="signals == incomplete_or_stale">
            <conclusion ref="data-fresh-24h" verdict="halt; refresh data before scoring"/>
          </branch>
          <branch when="signals == fresh">
            <question id="license-class">Is the license custom / SSPL / BUSL?</question>
              <branch when="license == blocked">
                <conclusion ref="license-closed-list" verdict="score 3; require legal sign-off"/>
              </branch>
              <branch when="license == allowed">
                <conclusion ref="seven-signals-coverage" verdict="score all 7 + verdict + remediation"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="production=true -&amp;gt; signals=fresh -&amp;gt; license=allowed -&amp;gt; seven-signals-coverage.">Worked path from root-question to conclusion.</example>
</text>
