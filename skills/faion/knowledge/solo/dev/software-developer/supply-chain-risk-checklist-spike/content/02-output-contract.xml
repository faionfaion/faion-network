<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Supply Chain Risk Checklist Spike Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/supply-chain-risk-checklist-spike.json",
  "type": "object",
  "required": [
    "library",
    "ecosystem",
    "signals",
    "aggregate_score",
    "verdict",
    "remediation",
    "decay_date"
  ],
  "properties": {
    "library": {
      "type": "string"
    },
    "ecosystem": {
      "type": "string",
      "enum": [
        "npm",
        "pypi",
        "crates",
        "maven",
        "rubygems",
        "go"
      ]
    },
    "signals": {
      "type": "object",
      "required": [
        "license",
        "maintainer_count",
        "last_release_age",
        "cve_history_12mo",
        "stars_to_downloads",
        "transitive_depth",
        "vendor_lock_in"
      ]
    },
    "aggregate_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 21
    },
    "verdict": {
      "type": "string",
      "enum": [
        "green",
        "yellow",
        "red"
      ]
    },
    "remediation": {
      "type": "string",
      "enum": [
        "adopt",
        "pin-and-monitor",
        "fork",
        "replace",
        "decline"
      ]
    },
    "decay_date": {
      "type": "string"
    },
    "data_freshness": {
      "type": "string",
      "enum": [
        "fresh",
        "stale"
      ]
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "library": "react",
  "ecosystem": "npm",
  "signals": {
    "license": 0,
    "maintainer_count": 0,
    "last_release_age": 0,
    "cve_history_12mo": 0,
    "stars_to_downloads": 0,
    "transitive_depth": 1,
    "vendor_lock_in": 0
  },
  "aggregate_score": 1,
  "verdict": "green",
  "remediation": "adopt",
  "decay_date": "2026-08-23",
  "data_freshness": "fresh"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "library": "x",
  "ecosystem": "npm",
  "signals": {
    "license": 0
  },
  "aggregate_score": 30,
  "verdict": "ok",
  "remediation": "maybe",
  "decay_date": ""
}
]]></code>
    <note>signals missing 6 of 7; aggregate_score&gt;21; verdict not in enum; remediation not in enum; decay_date empty.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="stars-only-eval">Library has 18k stars - adopted; xz-utils-style backdoor missed.</pattern>
      <pattern id="stale-cve-data">Audit returned clean Monday; xz CVE published Wednesday; team unaware until Friday.</pattern>
      <pattern id="custom-license-adopted">SSPL'd dep blocked SaaS launch; rip-and-replace cost two weeks.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-supply-chain-risk-checklist-spike.py">Validator script (see scripts/).</reference>
</text>
