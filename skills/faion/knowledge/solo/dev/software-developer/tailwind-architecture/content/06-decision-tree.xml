<text id="06-decision-tree" title="Tailwind Architecture Decision Tree" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Routing tree mapping observable input signals onto a conclusion that references a rule id from 01-core-rules.xml.</summary>
  <decision-tree>
    <root-question id="tailwind-stack">Is the codebase using Tailwind (v3 or v4) actively?</root-question>
      <branch when="tailwind == no">
        <conclusion ref="skip-this-methodology" verdict="skip; different styling system"/>
      </branch>
      <branch when="tailwind == yes">
        <question id="arbitrary-values">Does the code use arbitrary values widely?</question>
          <branch when="arbitrary == widespread">
            <conclusion ref="tokens-in-config-only" verdict="migrate to config tokens + ban via lint"/>
          </branch>
          <branch when="arbitrary == minimal">
            <question id="cn-shape">Is conditional composition through tailwind-merge?</question>
              <branch when="cn == raw_clsx">
                <conclusion ref="cn-wraps-clsx-and-merge" verdict="switch to project cn() + tailwind-merge"/>
              </branch>
              <branch when="cn == merge_aware">
                <conclusion ref="prettier-plugin-class-order" verdict="ensure prettier-plugin-tailwindcss is installed"/>
              </branch>
          </branch>
      </branch>
  </decision-tree>
  <example trace="tailwind=yes -&amp;gt; arbitrary=minimal -&amp;gt; cn=merge_aware -&amp;gt; prettier-plugin-class-order.">Worked path from root-question to conclusion.</example>
</text>
