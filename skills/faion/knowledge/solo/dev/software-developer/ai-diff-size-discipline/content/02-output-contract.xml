<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Diff Size Discipline Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the ai-diff-size-discipline artefact. Validator enforces the listed required fields + cross-field checks.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-diff-size-discipline.json",
  "type": "object",
  "required": [
    "pr_id",
    "loc_touched",
    "files_touched",
    "semantic_units",
    "verdict"
  ],
  "properties": {
    "pr_id": {
      "type": "string",
      "pattern": "^PR-[0-9]{1,7}$"
    },
    "loc_touched": {
      "type": "integer",
      "minimum": 0
    },
    "loc_test_touched": {
      "type": "integer",
      "minimum": 0
    },
    "files_touched": {
      "type": "integer",
      "minimum": 0
    },
    "semantic_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "feature",
          "refactor",
          "fix",
          "docs",
          "test",
          "build"
        ]
      }
    },
    "split_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slice_id",
          "summary",
          "acceptance"
        ]
      }
    },
    "override": {
      "type": "object",
      "properties": {
        "reviewer": {
          "type": "string"
        },
        "justification": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "split",
        "fail"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "pr_id": "PR-1432",
  "loc_touched": 142,
  "loc_test_touched": 88,
  "files_touched": 5,
  "semantic_units": [
    "feature"
  ],
  "verdict": "pass"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "pr_id": "x",
  "loc_touched": 820,
  "files_touched": 24,
  "semantic_units": [
    "feature",
    "refactor"
  ],
  "verdict": "pass"
}
]]></code>
    <note>pr_id pattern fails; loc/files/units all over cap; verdict=pass while caps breached and split_plan absent; multi-unit violates single-unit.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>verdict=pass with loc_touched &gt; 200.</item>
      <item>verdict=pass with files_touched &gt; 8.</item>
      <item>semantic_units length &gt; 1 (multi-unit).</item>
      <item>verdict=split without split_plan array populated.</item>
    </list>
  </section>

  <reference path="scripts/validate-ai-diff-size-discipline.py">Validator script</reference>
</text>
