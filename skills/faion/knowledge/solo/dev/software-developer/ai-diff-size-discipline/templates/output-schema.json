{
  "__faion_header__": {
    "purpose": "JSON Schema (draft-07) for the ai-diff-size-discipline artefact",
    "consumes": "raw diff + repo caps + PR description",
    "produces": "validated ai-diff-size-discipline artefact",
    "depends_on": "content/02-output-contract.xml",
    "token_budget_impact": "~200 tokens when loaded"
  },
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/ai-diff-size-discipline.json",
  "type": "object",
  "required": [
    "pr_id",
    "loc_touched",
    "files_touched",
    "semantic_units",
    "verdict"
  ],
  "properties": {
    "pr_id": {
      "type": "string",
      "pattern": "^PR-[0-9]{1,7}$"
    },
    "loc_touched": {
      "type": "integer",
      "minimum": 0
    },
    "loc_test_touched": {
      "type": "integer",
      "minimum": 0
    },
    "files_touched": {
      "type": "integer",
      "minimum": 0
    },
    "semantic_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "feature",
          "refactor",
          "fix",
          "docs",
          "test",
          "build"
        ]
      }
    },
    "split_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slice_id",
          "summary",
          "acceptance"
        ]
      }
    },
    "override": {
      "type": "object",
      "properties": {
        "reviewer": {
          "type": "string"
        },
        "justification": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "split",
        "fail"
      ]
    }
  }
}
