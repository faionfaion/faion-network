<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Contract-First Development Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the contract-first spec artefact metadata. The validator script enforces this contract before the spec is accepted into trunk.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/contract-first-development.json",
  "type": "object",
  "required": ["spec_id", "openapi_version", "info_version", "paths_count", "schemas_count", "lint_passed", "diff_check"],
  "properties": {
    "spec_id": {"type": "string", "minLength": 3},
    "openapi_version": {"type": "string", "pattern": "^3\\.[0-9]+\\.[0-9]+$"},
    "info_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "paths_count": {"type": "integer", "minimum": 1},
    "schemas_count": {"type": "integer", "minimum": 1},
    "lint_passed": {"type": "boolean"},
    "diff_check": {
      "type": "object",
      "required": ["breaking", "additive"],
      "properties": {
        "breaking": {"type": "integer", "minimum": 0},
        "additive": {"type": "integer", "minimum": 0}
      }
    },
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spec_id": "payments-api",
  "openapi_version": "3.1.0",
  "info_version": "1.4.0",
  "paths_count": 12,
  "schemas_count": 18,
  "lint_passed": true,
  "diff_check": {"breaking": 0, "additive": 2},
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "spec_id": "payments-api",
  "openapi_version": "3.1.0",
  "info_version": "1.4",
  "paths_count": 0,
  "lint_passed": false
}
]]></code>
    <note>Missing required fields (schemas_count, diff_check), info_version not semver, paths_count below minimum.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Inline schema in path operation (must use $ref to components/schemas)</pattern>
      <pattern id="f2">Missing operationId on any operation</pattern>
      <pattern id="f3">Breaking-diff ERR-level without BREAKING-CHANGE token in commit body</pattern>
      <pattern id="f4">Hand-edited generated SDK / stub committed alongside spec</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Normalise YAML key ordering deterministically for diff hygiene.</transformation>
      <transformation>Auto-bump PATCH info.version on editorial-only changes.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-contract-first-development.py">Validator script</reference>
</text>
