<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Browser Automation Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-sleeps">sleep_calls == 0?</root-question>
    <branch when="sleeps_present">
      <conclusion ref="no-sleep-only-waits" verdict="verdict=fail; replace every sleep with explicit assertion"/>
    </branch>
    <branch when="sleeps_zero">
      <question id="q-selectors">selector_strategy.primary == "data-test-id"?</question>
      <branch when="selectors_weak">
        <conclusion ref="selector-priority" verdict="verdict=fail; switch to data-test-id-first"/>
      </branch>
      <branch when="selectors_strong">
        <question id="q-flake">flake_budget_pct &lt;= 2?</question>
        <branch when="flake_over">
          <conclusion ref="flake-budget-enforced" verdict="verdict=fail; reduce flake_rate below 2%"/>
        </branch>
        <branch when="flake_under">
          <conclusion ref="page-object-isolation" verdict="verdict=pass; ship automation-spec"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="ba-onboarding-e2e">
    sleep_calls=0 → primary=data-test-id → flake_budget=1.5 &lt;= 2 → conclusion page-object-isolation → pass.
  </example>
</text>
