<text id="05-examples" title="Browser Automation Worked Example" version="1.1.0" est_tokens="600" depth="essential">
  <summary>Worked example: BA-ONBOARDING-E2E uses Playwright + 3 Page Objects + data-test-id-first selectors + 1.5% flake budget.</summary>

  <section title="Scenario">
    <p>Onboarding e2e suite went from 0% to 8% flake; team adopts this methodology to recover.</p>
  </section>

  <section title="Inputs">
    <code lang="json"><![CDATA[
{
  "target": "onboarding flow",
  "framework": "playwright"
}
]]></code>
  </section>

  <section title="Output">
    <code lang="json"><![CDATA[
{
  "spec_id": "BA-ONBOARDING-E2E",
  "target_url": "https://staging.example.com",
  "framework": "playwright",
  "page_objects": [
    "pages/SignUpPage.ts",
    "pages/CheckoutPage.ts",
    "pages/AccountPage.ts"
  ],
  "selector_strategy": {
    "primary": "data-test-id",
    "fallback_order": [
      "role",
      "text",
      "css"
    ]
  },
  "flake_budget_pct": 1.5,
  "sleep_calls": 0,
  "extract_module": "lib/extract.ts",
  "interact_module": "lib/page-object.ts"
}
]]></code>
  </section>

  <section title="Validator run">
    <code lang="text"><![CDATA[
$ python scripts/validate-browser-automation.py --file artefact.json
OK
]]></code>
  </section>
</text>
