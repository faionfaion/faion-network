{
  "__faion_header__": {
    "purpose": "Minimum viable filled-in browser-automation artefact for validator round-trip",
    "consumes": "n/a",
    "produces": "smoke-test fixture",
    "depends_on": "templates/output-schema.json",
    "token_budget_impact": "~150 tokens when loaded"
  },
  "spec_id": "BA-ONBOARDING-E2E",
  "target_url": "https://staging.example.com",
  "framework": "playwright",
  "page_objects": [
    "pages/SignUpPage.ts",
    "pages/CheckoutPage.ts",
    "pages/AccountPage.ts"
  ],
  "selector_strategy": {
    "primary": "data-test-id",
    "fallback_order": [
      "role",
      "text",
      "css"
    ]
  },
  "flake_budget_pct": 1.5,
  "sleep_calls": 0,
  "extract_module": "lib/extract.ts",
  "interact_module": "lib/page-object.ts"
}
