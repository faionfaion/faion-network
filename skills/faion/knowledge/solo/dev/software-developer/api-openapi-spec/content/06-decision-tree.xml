<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="OpenAPI Spec Authoring Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by the observables defined in 02-output-contract.xml to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-lint">spectral_errors == 0?</root-question>
    <branch when="errors_present">
      <conclusion ref="spectral-clean" verdict="verdict=fail; fix lint errors before any other rule"/>
    </branch>
    <branch when="lint_clean">
      <question id="q-dupes">duplicate_schemas == 0?</question>
      <branch when="dupes_present">
        <conclusion ref="no-inline-duplicate-schema" verdict="verdict=fail; extract duplicates into components.schemas"/>
      </branch>
      <branch when="dupes_clean">
        <question id="q-versioning">info_x_versioning has scheme + window?</question>
        <branch when="versioning_missing">
          <conclusion ref="x-versioning-declared" verdict="verdict=fail; declare scheme + deprecation window"/>
        </branch>
        <branch when="versioning_present">
          <conclusion ref="security-block-aligned" verdict="verdict=pass; ship spec"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="oas-public-api">
    spectral_errors=0 → duplicates=0 → x-versioning present (url-path, 180d) → conclusion security-block-aligned → pass.
  </example>
</text>
