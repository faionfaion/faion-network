<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="OpenAPI Spec Authoring Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the api-openapi-spec artefact. Validator enforces the listed required fields + cross-field checks.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/api-openapi-spec.json",
  "type": "object",
  "required": [
    "spec_id",
    "openapi_version",
    "info_x_versioning",
    "spectral_errors",
    "duplicate_schemas",
    "verdict"
  ],
  "properties": {
    "spec_id": {
      "type": "string",
      "pattern": "^OAS-[A-Z0-9-]{2,40}$"
    },
    "openapi_version": {
      "type": "string",
      "enum": [
        "3.0",
        "3.0.1",
        "3.0.2",
        "3.0.3",
        "3.1.0"
      ]
    },
    "info_x_versioning": {
      "type": "object",
      "required": [
        "scheme",
        "deprecation_window_days"
      ]
    },
    "spectral_errors": {
      "type": "integer",
      "minimum": 0
    },
    "spectral_warnings": {
      "type": "integer",
      "minimum": 0
    },
    "duplicate_schemas": {
      "type": "integer",
      "minimum": 0
    },
    "security_aligned_with_auth_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    }
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "spec_id": "OAS-PUBLIC-API-V1",
  "openapi_version": "3.1.0",
  "info_x_versioning": {
    "scheme": "url-path",
    "deprecation_window_days": 180,
    "breaking_change_policy": "major-bump-required"
  },
  "spectral_errors": 0,
  "spectral_warnings": 3,
  "duplicate_schemas": 0,
  "security_aligned_with_auth_id": "AUTH-PARTNER-API",
  "verdict": "pass"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "spec_id": "x",
  "openapi_version": "3.1.0",
  "info_x_versioning": {},
  "spectral_errors": 5,
  "duplicate_schemas": 4,
  "verdict": "pass"
}
]]></code>
    <note>spec_id pattern fails; info_x_versioning empty; spectral_errors &gt; 0; duplicates present.</note>
  </example>

  <section title="Forbidden patterns">
    <list>
      <item>spectral_errors &gt; 0 with verdict=pass.</item>
      <item>duplicate_schemas &gt; 0 with verdict=pass.</item>
      <item>info_x_versioning missing scheme OR deprecation_window_days.</item>
    </list>
  </section>

  <reference path="scripts/validate-api-openapi-spec.py">Validator script</reference>
</text>
