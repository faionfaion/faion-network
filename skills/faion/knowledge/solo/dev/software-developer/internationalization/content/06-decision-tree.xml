<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Internationalization Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for internationalization.</summary>

  <decision-tree>
    <root-question id="q-root">Does the product surface user-facing text AND target &gt;=2 locales?</root-question>

    <branch when="locales_count &lt;= 1 AND no_plans_for_more">
      <conclusion ref="skip-this-methodology" verdict="SKIP — premature"/>
    </branch>
    <branch when="ui_surface == backend_only">
      <conclusion ref="skip-this-methodology" verdict="SKIP — no user-facing strings"/>
    </branch>
    <branch when="hardcoded_strings &gt; 0">
      <conclusion ref="r1-no-hardcoded-user-strings" verdict="BLOCK — externalise strings"/>
    </branch>
    <branch when="concat_plural_pattern_present == true">
      <conclusion ref="r2-icu-message-format-for-plurals-and-gender" verdict="BLOCK — migrate to ICU"/>
    </branch>
    <branch when="manual_number_format == true">
      <conclusion ref="r3-intl-for-numbers-dates-currencies" verdict="BLOCK — switch to Intl"/>
    </branch>
    <branch when="physical_css_in_layout == true">
      <conclusion ref="r4-logical-css-for-rtl" verdict="BLOCK — migrate to logical CSS"/>
    </branch>
    <branch when="pseudo_loc_in_ci == false">
      <conclusion ref="r5-pseudo-loc-in-ci" verdict="BLOCK — wire pseudo-loc gate"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — i18n setup ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="internationalization-happy-path">
    4 locales + UI + externalised → first two branches do not match → no hardcoded → ICU plurals → Intl numbers → logical CSS → pseudo-loc CI → APPROVE.
  </example>
</text>
