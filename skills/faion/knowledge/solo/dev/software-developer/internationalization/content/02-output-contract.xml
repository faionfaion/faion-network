<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Internationalization Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/internationalization.json",
  "type": "object",
  "required": ["catalogue_path", "locales_count", "keys_count", "hardcoded_strings", "physical_css_props", "pseudo_loc_in_ci"],
  "properties": {
    "catalogue_path": {"type": "string", "minLength": 3},
    "locales_count": {"type": "integer", "minimum": 2},
    "keys_count": {"type": "integer", "minimum": 1},
    "hardcoded_strings": {"type": "integer", "minimum": 0, "maximum": 0},
    "physical_css_props": {"type": "integer", "minimum": 0},
    "pseudo_loc_in_ci": {"type": "boolean"},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "catalogue_path": "locales/",
  "locales_count": 4,
  "keys_count": 312,
  "hardcoded_strings": 0,
  "physical_css_props": 2,
  "pseudo_loc_in_ci": true,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "catalogue_path": "x",
  "locales_count": 1,
  "hardcoded_strings": 14,
  "pseudo_loc_in_ci": false
}
]]></code>
    <note>catalogue_path too short, locales_count below minimum, hardcoded_strings above 0, missing keys_count + physical_css_props.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">String literal in user-facing template instead of t(key)</pattern>
      <pattern id="f2">Plural built by concatenation instead of ICU MessageFormat</pattern>
      <pattern id="f3">Manual number/date format using a custom format string instead of Intl</pattern>
      <pattern id="f4">Physical left/right CSS property in a layout container</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Lowercase locale codes (en-US not en_US).</transformation>
      <transformation>Sort catalogue keys alphabetically for diff hygiene.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-internationalization.py">Validator script</reference>
</text>
