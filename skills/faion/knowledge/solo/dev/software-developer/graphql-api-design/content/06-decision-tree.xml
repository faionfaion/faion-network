<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="GraphQL API Design Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for graphql-api-design.</summary>

  <decision-tree>
    <root-question id="q-root">Is the schema multi-aggregate (&gt;=5 types) AND needs payload-shape consistency?</root-question>

    <branch when="protocol != graphql">
      <conclusion ref="skip-this-methodology" verdict="SKIP — not GraphQL"/>
    </branch>
    <branch when="types_count &lt; 5 AND auth_model == flat">
      <conclusion ref="skip-this-methodology" verdict="SKIP — conventions overhead exceeds value"/>
    </branch>
    <branch when="mutation_returns_scalar == true">
      <conclusion ref="r1-mutation-returns-payload-type" verdict="BLOCK — emit Payload type"/>
    </branch>
    <branch when="resolver_has_inline_auth == true">
      <conclusion ref="r3-authorization-via-directives" verdict="BLOCK — move to @auth directive"/>
    </branch>
    <branch when="paginated_list_not_connection == true">
      <conclusion ref="r4-naming-conventions-enforced" verdict="BLOCK — wrap in Connection/Edge"/>
    </branch>
    <branch when="relation_uses_scalar_id == true">
      <conclusion ref="r5-no-scalar-ids-for-relations" verdict="BLOCK — wrap in opaque ID"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — design spec ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="graphql-api-design-happy-path">
    18 types + 12 mutations + payload + auth → first two branches do not match → no scalar returns → directives in place → Connection used → opaque IDs → APPROVE.
  </example>
</text>
