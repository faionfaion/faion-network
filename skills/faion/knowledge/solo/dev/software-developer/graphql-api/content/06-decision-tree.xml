<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="GraphQL API Decision Tree" version="1.1.0" est_tokens="500" depth="essential">
  <summary>Routing tree mapping observable signals from inputs to a rule from 01-core-rules.xml for graphql-api.</summary>

  <decision-tree>
    <root-question id="q-root">Is the chosen protocol GraphQL with multi-client payload shaping?</root-question>

    <branch when="protocol != graphql">
      <conclusion ref="skip-this-methodology" verdict="SKIP — use REST or gRPC methodology"/>
    </branch>
    <branch when="single_consumer AND no_payload_shaping">
      <conclusion ref="skip-this-methodology" verdict="SKIP — REST simpler at this scale"/>
    </branch>
    <branch when="one_to_n_resolver_without_dataloader == true">
      <conclusion ref="r3-dataloader-for-every-1-to-n" verdict="BLOCK — add DataLoader"/>
    </branch>
    <branch when="depth_limit_unset OR complexity_limit_unset">
      <conclusion ref="r4-depth-and-complexity-caps" verdict="BLOCK — configure caps"/>
    </branch>
    <branch when="paginated_list_using_offset == true">
      <conclusion ref="r5-cursor-pagination-relay" verdict="BLOCK — migrate to cursor pagination"/>
    </branch>
    <branch when="breaking_change_without_gate == true">
      <conclusion ref="r6-schema-diff-gate-in-ci" verdict="BLOCK — wire diff gate"/>
    </branch>
    <branch when="all_gates_green == true">
      <conclusion ref="run-the-checklist" verdict="APPROVE — GraphQL API ready"/>
    </branch>
    <branch when="preconditions_unmet == true">
      <conclusion ref="skip-this-methodology" verdict="skip — preconditions in Applies-If not met"/>
    </branch>
  </decision-tree>

  <example trace="graphql-api-happy-path">
    GraphQL BFF + 3 clients + 7 DataLoaders → first two branches do not match → depth 7 + complexity 1000 → cursor pagination → diff gate enabled → all_gates_green=true → APPROVE.
  </example>
</text>
