<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="GraphQL API Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/graphql-api.json",
  "type": "object",
  "required": ["schema_path", "types_count", "queries_count", "mutations_count", "dataloader_count", "depth_limit", "complexity_limit", "diff_gate_enabled"],
  "properties": {
    "schema_path": {"type": "string", "minLength": 3},
    "types_count": {"type": "integer", "minimum": 1},
    "queries_count": {"type": "integer", "minimum": 1},
    "mutations_count": {"type": "integer", "minimum": 0},
    "dataloader_count": {"type": "integer", "minimum": 0},
    "depth_limit": {"type": "integer", "minimum": 3, "maximum": 12},
    "complexity_limit": {"type": "integer", "minimum": 100},
    "diff_gate_enabled": {"type": "boolean"},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "schema_path": "src/schema.graphql",
  "types_count": 24,
  "queries_count": 12,
  "mutations_count": 6,
  "dataloader_count": 7,
  "depth_limit": 7,
  "complexity_limit": 1000,
  "diff_gate_enabled": true,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "schema_path": "x",
  "types_count": 0,
  "queries_count": 0,
  "depth_limit": 1
}
]]></code>
    <note>schema_path too short, types_count and queries_count below minimum, depth_limit below minimum, missing required fields.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">1:N relation resolver calling repo without DataLoader</pattern>
      <pattern id="f2">Paginated list using offset+limit instead of cursor</pattern>
      <pattern id="f3">Schema deployed without depth or complexity cap</pattern>
      <pattern id="f4">Breaking schema change merged without diff gate run</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Sort SDL types alphabetically for diff hygiene.</transformation>
      <transformation>Default complexity_limit to 1000 when omitted.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-graphql-api.py">Validator script</reference>
</text>
