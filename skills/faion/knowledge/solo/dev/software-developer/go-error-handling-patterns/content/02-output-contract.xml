<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Go Error Handling Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the artefact this methodology produces. The validator script enforces this contract before the artefact is accepted.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/go-error-handling-patterns.json",
  "type": "object",
  "required": ["apperror_package", "sentinel_count", "unwrapped_boundaries", "type_assertion_count", "edge_translator_count", "control_flow_panics"],
  "properties": {
    "apperror_package": {"type": "string", "minLength": 3},
    "sentinel_count": {"type": "integer", "minimum": 1},
    "unwrapped_boundaries": {"type": "integer", "minimum": 0, "maximum": 0},
    "type_assertion_count": {"type": "integer", "minimum": 0, "maximum": 0},
    "edge_translator_count": {"type": "integer", "minimum": 1, "maximum": 1},
    "control_flow_panics": {"type": "integer", "minimum": 0, "maximum": 0},
    "validated_at": {"type": "string", "format": "date-time"}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "apperror_package": "internal/apperror",
  "sentinel_count": 5,
  "unwrapped_boundaries": 0,
  "type_assertion_count": 0,
  "edge_translator_count": 1,
  "control_flow_panics": 0,
  "validated_at": "2026-05-23T10:00:00Z"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "apperror_package": "x",
  "sentinel_count": 0,
  "unwrapped_boundaries": 4,
  "type_assertion_count": 7,
  "edge_translator_count": 3
}
]]></code>
    <note>apperror_package too short, sentinel_count below minimum, unwrapped_boundaries and type_assertion_count above 0 (must be 0), edge_translator_count above maximum.</note>
  </example>

  <output-contract>
    <forbidden>
      <pattern id="f1">Error wrapped with `errors.New("prefix: " + err.Error())` instead of `%w` (chain lost)</pattern>
      <pattern id="f2">Type assertion `err.(*MyError)` instead of errors.As</pattern>
      <pattern id="f3">Panic used to signal a domain error (not-found, conflict)</pattern>
      <pattern id="f4">Two or more places translating domain errors to HTTP status codes</pattern>
    </forbidden>
    <allowed-transformations>
      <transformation>Auto-format with gofmt before review.</transformation>
      <transformation>Sort sentinel declarations alphabetically in apperror package.</transformation>
    </allowed-transformations>
  </output-contract>

  <reference path="scripts/validate-go-error-handling-patterns.py">Validator script</reference>
</text>
