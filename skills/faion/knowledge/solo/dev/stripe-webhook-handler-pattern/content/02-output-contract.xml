<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Stripe Webhook Handler Pattern Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. The validator script enforces required keys plus per-field constraints; forbidden patterns enumerate shapes the agent must never emit.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/stripe-webhook-handler-pattern.json",
  "type": "object",
  "required": [
    "event_types",
    "verification_method",
    "idempotency_store",
    "processing_path",
    "dead_letter_url",
    "replay_safety_test",
    "owner"
  ],
  "properties": {
    "event_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "verification_method": {
      "type": "string",
      "enum": [
        "stripe-sdk",
        "manual-hmac"
      ]
    },
    "idempotency_store": {
      "type": "string",
      "enum": [
        "postgres-unique-index",
        "redis-setnx",
        "dynamodb-conditional-put"
      ]
    },
    "processing_path": {
      "type": "string",
      "enum": [
        "sync",
        "queue",
        "both"
      ]
    },
    "dead_letter_url": {
      "type": "string"
    },
    "replay_safety_test": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "event_types": [
    "invoice.paid",
    "checkout.session.completed"
  ],
  "verification_method": "stripe-sdk",
  "idempotency_store": "postgres-unique-index",
  "processing_path": "queue",
  "dead_letter_url": "sqs://billing-dlq",
  "replay_safety_test": "tests/test_invoice_paid_replay.py::test_replay_idempotent",
  "owner": "ruslan@faion.net"
}
]]></code>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "event_types": [],
  "verification_method": "manual-string-compare",
  "idempotency_store": "in-memory-set",
  "processing_path": "sync-30s",
  "dead_letter_url": "",
  "replay_safety_test": "",
  "owner": "team"
}
]]></code>
    <note>event_types empty (minItems=1); verification_method not in enum; idempotency_store not in enum; processing_path not in enum; dead_letter_url empty; replay_safety_test empty; owner is plural.</note>
  </example>
  <section title="Forbidden patterns">
    <list>
      <pattern id="no-verification">endpoint skips signature verification (temporary debugging that becomes permanent).</pattern>
      <pattern id="no-idempotency">handler relies on Stripe retries without dedup; double-charges on retry.</pattern>
      <pattern id="slow-sync-handler">synchronous processing >5s; Stripe times out and retries.</pattern>
      <pattern id="no-dead-letter">fail path is bare 5xx without a place for failed events to land.</pattern>
    </list>
  </section>
  <reference path="scripts/validate-stripe-webhook-handler-pattern.py">Validator script (see scripts/).</reference>
</text>
