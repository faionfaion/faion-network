<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Doc Advanced Patterns Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/design-doc-advanced-patterns.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "base_doc_path",
    "triggers_fired",
    "blocks_included",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "base_doc_path": {
      "type": "string"
    },
    "triggers_fired": {
      "type": "array"
    },
    "blocks_included": {
      "type": "array"
    },
    "capacity_sources": {
      "type": "array"
    },
    "mttr_minutes": {
      "type": "object"
    },
    "rollback_budget_minutes": {
      "type": "integer"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">triggers_fired non-empty AND blocks_included does not cover every trigger.</pattern>
      <pattern id="f2">capacity block present AND capacity_sources empty.</pattern>
      <pattern id="f3">migration block present AND rollback_budget_minutes missing.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "design-doc-advanced-patterns-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "base_doc_path": "base_doc_path value",
  "triggers_fired": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "blocks_included": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "capacity_sources": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "mttr_minutes": {
    "key": "value"
  },
  "rollback_budget_minutes": 1,
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-design-doc-advanced-patterns.py">Schema validator (stdlib only).</reference>
</text>
