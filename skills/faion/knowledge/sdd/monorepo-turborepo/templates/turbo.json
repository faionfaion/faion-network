{
  "__faion_header__": {
    "purpose": "Turborepo task graph: build / lint / test with cache",
    "consumes": "see content/02-output-contract.xml",
    "produces": "config",
    "depends_on": "content/01-core-rules.xml#two-tier-workspaces",
    "token_budget_impact": "~150 tokens when loaded"
  },
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "inputs": [
        "src/**",
        "tsconfig.json",
        "package.json"
      ]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
