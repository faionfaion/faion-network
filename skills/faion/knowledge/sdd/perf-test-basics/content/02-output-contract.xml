<text id="02-output-contract" title="Performance Testing Basics Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the spec artefact this methodology produces. Validator in scripts/validate-perf-test-basics.py enforces required keys, enum bounds, and pattern constraints.</summary>
  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/perf-test-basics.json",
  "type": "object",
  "title": "Perf-test baseline spec",
  "required": [
    "service",
    "baselines",
    "tool",
    "ci_gate"
  ],
  "additionalProperties": false,
  "properties": {
    "service": {
      "type": "string"
    },
    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "endpoint",
          "p95_ms",
          "p99_ms",
          "rps"
        ],
        "properties": {
          "endpoint": {
            "type": "string",
            "pattern": "^/"
          },
          "p95_ms": {
            "type": "integer",
            "minimum": 1
          },
          "p99_ms": {
            "type": "integer",
            "minimum": 1
          },
          "rps": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "tool": {
      "enum": [
        "k6",
        "locust"
      ]
    },
    "ci_gate": {
      "type": "object",
      "required": [
        "regression_pct_threshold"
      ],
      "properties": {
        "regression_pct_threshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        }
      }
    }
  }
}
]]></code>
  </section>
  <example valid="true">
    <code lang="json"><![CDATA[
{
  "service": "checkout-api",
  "baselines": [
    {
      "endpoint": "/api/v1/checkout",
      "p95_ms": 250,
      "p99_ms": 450,
      "rps": 50
    }
  ],
  "tool": "k6",
  "ci_gate": {
    "regression_pct_threshold": 10
  }
}
]]></code>
    <note>All required keys present; enums and patterns satisfied.</note>
  </example>
  <example valid="false">
    <code lang="json"><![CDATA[
{
  "service": "checkout-api",
  "baselines": [
    {
      "endpoint": "checkout"
    }
  ],
  "tool": "jmeter"
}
]]></code>
    <note>Forbidden traits: endpoint must start with /; missing p95_ms/p99_ms/rps; tool enum violation.</note>
  </example>
  <reference path="scripts/validate-perf-test-basics.py">Validator script (stdlib-only, --help + --self-test).</reference>
</text>
