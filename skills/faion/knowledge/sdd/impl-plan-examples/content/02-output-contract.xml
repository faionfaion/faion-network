<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Impl Plan Examples Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/impl-plan-examples.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "archetype",
    "example_path",
    "tasks_adapted",
    "tasks_kept",
    "draft_plan_path",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "archetype": {
      "enum": [
        "greenfield",
        "refactor",
        "migration",
        "infra",
        "none"
      ]
    },
    "example_path": {
      "type": "string"
    },
    "tasks_adapted": {
      "type": "integer"
    },
    "tasks_kept": {
      "type": "integer"
    },
    "draft_plan_path": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">archetype &apos;none&apos; AND tasks_kept &gt; 0.</pattern>
      <pattern id="f2">tasks_adapted + tasks_kept &lt; 3 — too thin to be a real adaptation.</pattern>
      <pattern id="f3">example_path does not point to one of the four canonical examples.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "impl-plan-examples-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "archetype": "greenfield",
  "example_path": "example_path value",
  "tasks_adapted": 1,
  "tasks_kept": 1,
  "draft_plan_path": "draft_plan_path value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-impl-plan-examples.py">Schema validator (stdlib only).</reference>
</text>
