<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Task Creation Principles Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/task-creation-principles.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "task_id",
    "atomic_pass",
    "testable_pass",
    "owned_pass",
    "estimated_pass",
    "rubric_score",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "task_id": {
      "type": "string"
    },
    "atomic_pass": {
      "type": "boolean"
    },
    "testable_pass": {
      "type": "boolean"
    },
    "owned_pass": {
      "type": "boolean"
    },
    "estimated_pass": {
      "type": "boolean"
    },
    "rubric_score": {
      "type": "integer"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">any of atomic_pass/testable_pass/owned_pass/estimated_pass == false AND task queued.</pattern>
      <pattern id="f2">rubric_score &lt; 4 — all four principles must pass.</pattern>
      <pattern id="f3">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
      <pattern id="f4">task_id does not match TASK_NNN-slug pattern.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "task-creation-principles-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "task_id": "task_id value",
  "atomic_pass": true,
  "testable_pass": true,
  "owned_pass": true,
  "estimated_pass": true,
  "rubric_score": 1,
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-task-creation-principles.py">Schema validator (stdlib only).</reference>
</text>
