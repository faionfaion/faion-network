<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Client Style Guide Importer Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of a valid config artefact. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/client-style-guide-importer.json",
  "type": "object",
  "required": [
    "artefact_id",
    "owner",
    "version",
    "last_reviewed",
    "inputs_used",
    "entries"
  ],
  "properties": {
    "artefact_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 100
    },
    "owner": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "inputs_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "source"
        ]
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "key",
          "value",
          "source"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {},
          "source": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "client-style-guide-importer-config-2026-05-23",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "inputs_used": [
    {
      "name": "client-style-guide",
      "source": "docs/style-guide.md#sec-4"
    }
  ],
  "entries": [
    {
      "key": "lint.import-order",
      "value": "alphabetical",
      "source": "docs/style-guide.md#sec-4.2"
    }
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "entries": []
}
]]></code>
    <note>Owner is plural pronoun (or generic group); required fields empty or missing.</note>
  </example>

  <forbidden>
    <pattern id="owner-plural">`owner` is a plural pronoun (`team`, `we`, `us`, `everyone`, `engineering`) or empty string</pattern>
    <pattern id="inputs-empty">`inputs_used` is empty</pattern>
    <pattern id="version-not-semver">`version` does not match `^[0-9]+\.[0-9]+\.[0-9]+$`</pattern>
  </forbidden>

  <reference path="scripts/validate-client-style-guide-importer.py">Stdlib-only validator implementing this schema.</reference>
</text>
