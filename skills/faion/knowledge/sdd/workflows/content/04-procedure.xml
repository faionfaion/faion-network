<?xml version="1.0" encoding="UTF-8"?>
<text id="04-procedure" title="SDD Workflows Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply SDD Workflows end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="enumerate-workflows">
      <input>Phase model</input>
      <action>List required workflows (spec/design/impl/review).</action>
      <output>Workflow list</output>
    </step>

    <step n="2" name="define-each">
      <input>Workflow list</input>
      <action>For each, list inputs, outputs, steps, agents, gate.</action>
      <output>Workflow definitions</output>
    </step>

    <step n="3" name="validate-catalog">
      <input>Workflow definitions</input>
      <action>Run validator against catalog schema.</action>
      <output>Validated workflows.json</output>
    </step>

    <step n="4" name="publish">
      <input>Validated catalog</input>
      <action>Publish to pool config; mark version.</action>
      <output>Live catalog</output>
    </step>

  </section>
</text>
