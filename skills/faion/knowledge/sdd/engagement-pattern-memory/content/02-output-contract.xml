<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Engagement Pattern Memory Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Engagement Pattern Memory output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="engagement_id" type="string" required="true">client / repo identifier</field>
      <field name="memory_file_path" type="string" required="true">path to memory.md</field>
      <field name="repo_conventions" type="object" required="true">linting / naming / commit format</field>
      <field name="reviewer_preferences" type="object" required="true">per-named-reviewer preferences</field>
      <field name="deploy_quirks" type="array" required="true">non-obvious deploy gotchas</field>
      <field name="recurring_traps" type="array" required="true">≥1 trap with detector + fix</field>
      <field name="glossary" type="object" required="true">client-specific terms</field>
      <field name="resolved_questions" type="array" required="true">questions + resolution dates</field>
      <field name="owner" type="string" required="true">named contractor</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">engagement_id shared across files</pattern>
      <pattern id="f2">memory_file_path missing</pattern>
      <pattern id="f3">any section absent</pattern>
      <pattern id="f4">client PII beyond engagement_id</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to archive a memory file when engagement ends; archive MUST be tagged with end date.</transformation>
      <transformation>Allowed to extract glossary entries into a shared cross-engagement file when terminology is industry-standard.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/engagement-pattern-memory.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "engagement_id": "sample-engagement_id",
  "memory_file_path": "sample-memory_file_path",
  "repo_conventions": {
    "k": "v"
  },
  "reviewer_preferences": {
    "k": "v"
  },
  "deploy_quirks": [
    {
      "k": "v"
    }
  ],
  "recurring_traps": [
    {
      "k": "v"
    }
  ],
  "glossary": {
    "k": "v"
  },
  "resolved_questions": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/engagement-pattern-memory.json</item>
    </list>
  </section>
</text>
