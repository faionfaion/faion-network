<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Task Creation Template Guide Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/task-creation-template-guide.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "task_id",
    "fill_steps_completed",
    "rubric_score",
    "sections_present",
    "component_in_map",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "task_id": {
      "type": "string"
    },
    "fill_steps_completed": {
      "type": "array"
    },
    "rubric_score": {
      "type": "integer"
    },
    "sections_present": {
      "type": "array"
    },
    "component_in_map": {
      "type": "boolean"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">fill_steps_completed missing any of {front-matter, goal, inputs, steps, acceptance, notes}.</pattern>
      <pattern id="f2">component_in_map == false — methodology requires component from impl-plan-components.</pattern>
      <pattern id="f3">rubric_score &lt; 4 — must pass all four principles.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "task-creation-template-guide-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "task_id": "task_id value",
  "fill_steps_completed": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "rubric_score": 1,
  "sections_present": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "component_in_map": true,
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-task-creation-template-guide.py">Schema validator (stdlib only).</reference>
</text>
