<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Key Trends Summary 2025-2026 Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Key Trends Summary 2025-2026 output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="report_id" type="string" required="true">stable id</field>
      <field name="trends" type="array" required="true">exactly 6 trends with name + source + implication</field>
      <field name="loaded_at" type="datetime" required="true">ISO datetime</field>
      <field name="next_refresh_due" type="date" required="true">loaded_at + 90 days</field>
      <field name="audience" type="array" required="true">named roles</field>
      <field name="owner" type="string" required="true">named author</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">trends length != 6</pattern>
      <pattern id="f2">any trend without source OR implication</pattern>
      <pattern id="f3">next_refresh_due &gt; loaded_at + 90 days</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to replace one trend per refresh cycle when a new shift overtakes a stale one.</transformation>
      <transformation>Allowed to extend implications when a planning session surfaces a new architectural impact.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/key-trends-summary.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "report_id": "sample-report_id",
  "trends": [
    {
      "k": "v"
    }
  ],
  "loaded_at": "2026-05-23T12:00:00Z",
  "next_refresh_due": "2026-05-23",
  "audience": [
    {
      "k": "v"
    }
  ],
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/key-trends-summary.json</item>
    </list>
  </section>
</text>
