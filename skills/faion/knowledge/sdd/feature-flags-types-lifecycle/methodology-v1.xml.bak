<methodology slug="feature-flags-types-lifecycle">
  <metadata>
    <tier>solo</tier>
    <group>dev</group>
    <domain>automation-tooling</domain>
    <summary>Five feature flag categories (release, experiment, ops, permission, kill-switch) with distinct lifespans, ownership, and a mandatory cleanup lifecycle to prevent flag debt.</summary>
    <tags>
      <tag>feature-flags</tag>
      <tag>progressive-rollout</tag>
