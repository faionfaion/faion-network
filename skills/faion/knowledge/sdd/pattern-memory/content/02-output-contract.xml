<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Pattern Memory Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Pattern Memory output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="pattern_id" type="string" required="true">stable id (PM-001..)</field>
      <field name="title" type="string" required="true">pattern name</field>
      <field name="confidence" type="number" required="true">0.5..0.95</field>
      <field name="contexts_used" type="array" required="true">≥2 with citation</field>
      <field name="rationale" type="string" required="true">why it works</field>
      <field name="synced_to_claude_md" type="boolean" required="true">true when confidence ≥0.8</field>
      <field name="occurrence_count" type="integer" required="true">≥2</field>
      <field name="owner" type="string" required="true">named author</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">contexts_used length &lt; 2</pattern>
      <pattern id="f2">confidence &lt; 0.5 OR confidence &gt; 0.95</pattern>
      <pattern id="f3">confidence &gt;= 0.8 AND synced_to_claude_md == false</pattern>
      <pattern id="f4">rationale empty</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to demote confidence by -0.1 after a logged failure of the pattern.</transformation>
      <transformation>Allowed to merge two near-duplicate patterns into one when rationale aligns.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/pattern-memory.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "pattern_id": "sample-pattern_id",
  "title": "sample-title",
  "confidence": 0.7,
  "contexts_used": [
    {
      "k": "v"
    }
  ],
  "rationale": "sample-rationale",
  "synced_to_claude_md": true,
  "occurrence_count": 3,
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/pattern-memory.json</item>
    </list>
  </section>
</text>
