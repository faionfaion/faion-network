<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Architecture Decision Records Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Architecture Decision Records output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="adr_id" type="string" required="true">stable id (ADR-001..)</field>
      <field name="title" type="string" required="true">decision title</field>
      <field name="status" type="string" required="true">Proposed | Accepted | Deprecated | Superseded</field>
      <field name="context" type="string" required="true">background paragraph</field>
      <field name="decision" type="string" required="true">what was decided</field>
      <field name="alternatives" type="array" required="true">≥2 with rationale</field>
      <field name="consequences" type="object" required="true">{positive: [...], negative: [...]}</field>
      <field name="supersedes" type="string" required="true">ADR id this replaces (or null)</field>
      <field name="owner" type="string" required="true">named author</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">status not in allowed set</pattern>
      <pattern id="f2">alternatives length &lt; 2</pattern>
      <pattern id="f3">consequences.positive empty OR consequences.negative empty</pattern>
      <pattern id="f4">edits to ADR with status==Accepted</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to update an Accepted ADR's status to Deprecated/Superseded without editing the body.</transformation>
      <transformation>Allowed to backfill ADRs for pre-existing decisions when the rationale can still be reconstructed.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/architecture-decision-records.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "adr_id": "sample-adr_id",
  "title": "sample-title",
  "status": "sample-status",
  "context": "sample-context",
  "decision": "sample-decision",
  "alternatives": [
    {
      "k": "v"
    }
  ],
  "consequences": {
    "k": "v"
  },
  "supersedes": "sample-supersedes",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/architecture-decision-records.json</item>
    </list>
  </section>
</text>
