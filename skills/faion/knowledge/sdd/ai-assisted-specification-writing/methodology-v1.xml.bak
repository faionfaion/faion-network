      <link href="https://aclanthology.org/2025.acl-srw.31.pdf">LLMs in Software Requirements Specifications (ACL 2025)</link>
      <link href="https://gojko.net/books/specification-by-example/">Specification by Example (book)</link>
      <link href="https://www.iaria.org/conferences2013/filesICCGI13/ICCGI_2013_Tutorial_Mavin.pdf">EARS notation for requirements</link>
    </see-also>
    <templates>
      <template path="templates/spec-md.md" purpose="Feature specification template (FR-X, edge cases, ACs, dependencies, risks)"/>
      <template path="templates/api-spec.md" purpose="API specification template (endpoints, request/response, error codes)"/>
      <template path="templates/prompt-generate.txt" purpose="LLM prompt for initial spec generation with context structure"/>
      <template path="templates/prompt-review.txt" purpose="LLM prompt for spec review: completeness, conflicts, testability"/>
    </templates>
  </content>
</methodology>
