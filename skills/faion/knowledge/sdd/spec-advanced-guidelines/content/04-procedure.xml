<text id="04-procedure" title="Spec Advanced Guidelines Procedure" version="1.0.0" est_tokens="700" depth="essential">
  <summary>Step-by-step procedure to apply Spec Advanced Guidelines end-to-end. Each step names its input, action, and output.</summary>

  <section title="Procedure">

    <step n="1" name="check-triggers">
      <input>Base spec + change description</input>
      <action>Determine which triggers fire.</action>
      <output>Trigger list</output>
    </step>
    <step n="2" name="nfr-block">
      <input>NFR catalogue + base spec</input>
      <action>Add NFR table with thresholds + verification.</action>
      <output>NFR block</output>
    </step>
    <step n="3" name="ac-rubric-block">
      <input>AC list + rubric</input>
      <action>Score every AC; rewrite below-threshold.</action>
      <output>Scored AC</output>
    </step>
    <step n="4" name="glossary-block">
      <input>Terms list</input>
      <action>Define each term once.</action>
      <output>Glossary</output>
    </step>
    <step n="5" name="versioning-block">
      <input>Revision history</input>
      <action>Append revision record.</action>
      <output>Versioning block</output>
    </step>
    <step n="6" name="source-of-truth-pointer">
      <input>content_id</input>
      <action>Add or update content_id in front-matter.</action>
      <output>Stable pointer</output>
    </step>
    <step n="7" name="publish">
      <input>All blocks</input>
      <action>Emit artefact JSON.</action>
      <output>Final spec</output>
    </step>

  </section>
</text>
