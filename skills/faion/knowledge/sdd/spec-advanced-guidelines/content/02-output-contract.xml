<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Spec Advanced Guidelines Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/spec-advanced-guidelines.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "base_spec_path",
    "triggers_fired",
    "blocks_included",
    "versioning",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "base_spec_path": {
      "type": "string"
    },
    "triggers_fired": {
      "type": "array"
    },
    "blocks_included": {
      "type": "array"
    },
    "nfrs": {
      "type": "array"
    },
    "ac_rubric_score": {
      "type": "number"
    },
    "glossary_terms": {
      "type": "array"
    },
    "versioning": {
      "type": "object"
    },
    "content_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">triggers_fired non-empty AND blocks_included missing a triggered block.</pattern>
      <pattern id="f2">NFR block present AND any NFR without threshold + verification method.</pattern>
      <pattern id="f3">AC block present AND ac_rubric_score below team threshold.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "spec-advanced-guidelines-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "base_spec_path": "base_spec_path value",
  "triggers_fired": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "blocks_included": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "nfrs": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "ac_rubric_score": 1.0,
  "glossary_terms": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "versioning": {
    "key": "value"
  },
  "content_id": "content_id value",
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-spec-advanced-guidelines.py">Schema validator (stdlib only).</reference>
</text>
