<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Design Docs Patterns Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Design Docs Patterns output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="doc_id" type="string" required="true">stable id</field>
      <field name="title" type="string" required="true">doc title</field>
      <field name="scope" type="string" required="true">small | team | cross-org</field>
      <field name="format" type="string" required="true">Google-lite | Amazon-6-pager | Uber-RFC | Stripe-ERD</field>
      <field name="sections" type="object" required="true">required sections populated</field>
      <field name="non_goals" type="array" required="true">≥1 non-goal</field>
      <field name="alternatives" type="array" required="true">≥2 genuine</field>
      <field name="review_deadline" type="date" required="true">ISO date</field>
      <field name="owner" type="string" required="true">named author</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">sections missing any of {context, goals, non-goals, proposed, alternatives, open-questions}</pattern>
      <pattern id="f2">alternatives length &lt; 2</pattern>
      <pattern id="f3">non_goals empty</pattern>
      <pattern id="f4">review_deadline missing</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to merge open-questions into context when all questions have been resolved.</transformation>
      <transformation>Allowed to escalate scope from team to cross-org when a reviewer surfaces a cross-cutting dependency.</transformation>
    </allowed-transformations>

    <schema-reference path="templates/design-docs-patterns.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "doc_id": "sample-doc_id",
  "title": "sample-title",
  "scope": "sample-scope",
  "format": "sample-format",
  "sections": {
    "k": "v"
  },
  "non_goals": [
    {
      "k": "v"
    }
  ],
  "alternatives": [
    {
      "k": "v"
    }
  ],
  "review_deadline": "2026-05-23",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/design-docs-patterns.json</item>
    </list>
  </section>
</text>
