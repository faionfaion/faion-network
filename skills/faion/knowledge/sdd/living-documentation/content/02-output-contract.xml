<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Living Documentation Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>Pins the shape of a valid Living Documentation output. Subagent must satisfy this before returning to the caller.</summary>

  <output-contract>
    <required>
      <field name="docs_root" type="string" required="true">absolute path to docs/</field>
      <field name="docs_framework" type="string" required="true">Hugo | Docusaurus | MkDocs | other</field>
      <field name="auto_generated_sections" type="array" required="true">list of {file, generator, source}</field>
      <field name="hand_authored_sections" type="array" required="true">list of {file, owner}</field>
      <field name="ci_checks" type="object" required="true">link-validation + spec-diff + build-success flags</field>
      <field name="changelog_source" type="string" required="true">commits | manual (only commits allowed)</field>
      <field name="owner" type="string" required="true">named owner</field>
      <field name="version" type="string" required="true">semver</field>
      <field name="last_reviewed" type="date" required="true">ISO date</field>
    </required>

    <forbidden>
      <pattern id="f1">docs_root outside source repo</pattern>
      <pattern id="f2">any auto-generated section without AUTO-GENERATED marker</pattern>
      <pattern id="f3">changelog_source == 'manual'</pattern>
      <pattern id="f4">ci_checks.link_validation != true</pattern>
    </forbidden>

    <allowed-transformations>
      <transformation>Allowed to add a docs-only sub-repo when monorepo size demands it (markers still required).</transformation>
      <transformation>Allowed to mirror generated reference to a CDN for publish-time speed (source remains in repo).</transformation>
    </allowed-transformations>

    <schema-reference path="templates/living-documentation.json"/>
  </output-contract>

  <section title="Valid example">
    <example valid="true">
      <code lang="json"><![CDATA[
{
  "docs_root": "sample-docs_root",
  "docs_framework": "sample-docs_framework",
  "auto_generated_sections": [
    {
      "k": "v"
    }
  ],
  "hand_authored_sections": [
    {
      "k": "v"
    }
  ],
  "ci_checks": {
    "k": "v"
  },
  "changelog_source": "sample-changelog_source",
  "owner": "ruslan@faion.net",
  "version": "1.1.0",
  "last_reviewed": "2026-05-23"
}
]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example valid="false">
      <code lang="json"><![CDATA[
{
  "missing": "required fields"
}
]]></code>
      <note>Missing required keys — validator returns non-zero with violation list.</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>Every required field populated with a typed value</item>
      <item>No forbidden pattern matches the output</item>
      <item>Transformations applied where applicable</item>
      <item>Output validates against templates/living-documentation.json</item>
    </list>
  </section>
</text>
