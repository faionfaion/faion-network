<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Backlog Grooming and Roadmapping Output Contract" version="1.0.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces, plus one valid and one invalid example, and a closed list of forbidden patterns the validator must reject.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/backlog-grooming-roadmapping.json",
  "type": "object",
  "required": [
    "artefact_id",
    "version",
    "last_reviewed",
    "grooming_date",
    "items_total",
    "items_promoted",
    "items_culled",
    "horizons",
    "theme_orphans",
    "owner"
  ],
  "properties": {
    "artefact_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date"
    },
    "grooming_date": {
      "type": "string",
      "format": "date"
    },
    "items_total": {
      "type": "integer"
    },
    "items_promoted": {
      "type": "integer"
    },
    "items_culled": {
      "type": "integer"
    },
    "horizons": {
      "type": "object"
    },
    "theme_orphans": {
      "type": "array"
    },
    "owner": {
      "type": "string"
    }
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <pattern id="f1">items_total &lt; items_promoted + items_culled (math error).</pattern>
      <pattern id="f2">horizons object missing any of the keys &apos;h1m&apos;, &apos;h3m&apos;, &apos;h12m&apos;.</pattern>
      <pattern id="f3">theme_orphans is null — must be empty array if none.</pattern>
      <pattern id="f4">owner == &apos;team&apos; / &apos;we&apos; / &apos;&apos; / null.</pattern>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "backlog-grooming-roadmapping-example",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "grooming_date": "2026-05-23",
  "items_total": 1,
  "items_promoted": 1,
  "items_culled": 1,
  "horizons": {
    "key": "value"
  },
  "theme_orphans": [
    "item-1",
    "item-2",
    "item-3"
  ],
  "owner": "@solo-founder"
}
]]></code>
    <note>Minimum viable conformant output — every required field present, no forbidden pattern matched.</note>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "not-semver"
}
]]></code>
    <note>Invalid — required fields missing or forbidden patterns matched (e.g. semver violation).</note>
  </example>

  <reference path="scripts/validate-backlog-grooming-roadmapping.py">Schema validator (stdlib only).</reference>
</text>
