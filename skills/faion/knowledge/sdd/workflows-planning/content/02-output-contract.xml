<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="SDD Workflows Navigation Hub Output Contract" version="1.1.0" est_tokens="800" depth="essential">
  <summary>JSON Schema (draft-07) that pins the shape of the route-record artefact for the workflows navigation hub. Subagents validate against this before returning.</summary>

  <section title="Schema (JSON Schema draft-07)">
    <schema format="json-schema-draft-07">
      <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/sdd-workflows-route.json",
  "type": "object",
  "required": ["artefact_id", "owner", "version", "last_reviewed", "feature_dir", "active_phase", "next_methodology", "phase_statuses"],
  "properties": {
    "artefact_id": {"type": "string", "minLength": 3},
    "owner": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "last_reviewed": {"type": "string", "format": "date"},
    "feature_dir": {"type": "string", "minLength": 5},
    "active_phase": {"type": "string", "enum": ["spec", "design", "plan", "execution", "done", "blocked"]},
    "next_methodology": {"type": "string", "minLength": 5},
    "phase_statuses": {
      "type": "object",
      "required": ["spec", "design", "plan"],
      "properties": {
        "spec": {"type": "string", "enum": ["missing", "Draft", "Accepted"]},
        "design": {"type": "string", "enum": ["missing", "Draft", "Accepted"]},
        "plan": {"type": "string", "enum": ["missing", "Draft", "Accepted"]}
      }
    },
    "blocker": {"type": ["string", "null"]}
  }
}
]]></code>
    </schema>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "route-jwt-refresh",
  "owner": "Ruslan Faion <ruslan@faion.net>",
  "version": "1.0.0",
  "last_reviewed": "2026-05-23",
  "feature_dir": ".aidocs/features/in-progress/jwt-refresh/",
  "active_phase": "design",
  "next_methodology": "solo/sdd/sdd-planning/workflow-design-phase",
  "phase_statuses": {"spec": "Accepted", "design": "missing", "plan": "missing"},
  "blocker": null
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "owner": "team",
  "active_phase": "unknown",
  "next_methodology": "tbd/path",
  "phase_statuses": {}
}
]]></code>
    <note>Owner plural; active_phase not in enum; next_methodology is stub; phase_statuses empty.</note>
  </example>

  <forbidden>
    <pattern id="stub-next-methodology">`next_methodology` is a placeholder string or any path that does not resolve on disk.</pattern>
    <pattern id="missing-phase-statuses">`phase_statuses` does not include all three of spec / design / plan keys.</pattern>
    <pattern id="vague-blocker">`active_phase: blocked` with `blocker: null` — must name the specific blocker.</pattern>
    <pattern id="route-contains-spec-body">The record carries spec / design / plan body content (router does not author).</pattern>
  </forbidden>

  <reference path="scripts/validate-workflows.py">Stdlib-only validator implementing this schema.</reference>
</text>
