<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="RAG Corpus Discovery Interview Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes SME count + consent state + audit recency to run / skip.</summary>

  <decision-tree>
    <root-question id="q-prior-audit">Recent (≤6 months) corpus audit already exists?</root-question>
    <branch when="prior_audit_recent == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="prior_audit_recent == false">
      <question id="q-five-smes">≥5 SMEs available with signed consent?</question>
      <branch when="sme_count &lt; 5 OR consent_signed == false">
        <conclusion ref="r1-five-interview-min"/>
      </branch>
      <branch when="sme_count &gt;= 5 AND consent_signed == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-bot-q2-2026">
    prior_audit_recent=false → sme_count=7 → consent_signed=true → run-the-checklist.
  </example>
</text>
