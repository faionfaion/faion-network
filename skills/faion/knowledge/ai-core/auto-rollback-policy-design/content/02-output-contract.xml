<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Auto Rollback Policy Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the config artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/auto-rollback-policy-design.json",
  "type": "object",
  "required": ["feature_id", "thresholds", "window", "canary", "manual_override", "runbook"],
  "properties": {
    "feature_id": {"type": "string"},
    "thresholds": {"type": "object", "required": ["outcome_drop_pp", "trajectory_drop_pp", "resources_cost_pct"], "properties": {"outcome_drop_pp": {"type": "number", "minimum": 2, "maximum": 20}, "trajectory_drop_pp": {"type": "number", "minimum": 2, "maximum": 30}, "resources_cost_pct": {"type": "number", "minimum": 10, "maximum": 200}}},
    "window": {"type": "object", "required": ["min_inferences", "min_seconds"], "properties": {"min_inferences": {"type": "integer", "minimum": 100}, "min_seconds": {"type": "integer", "minimum": 300}}},
    "canary": {"type": "object", "required": ["ratios", "hold_seconds"], "properties": {"ratios": {"type": "array", "items": {"type": "number", "minimum": 0, "maximum": 1}, "minItems": 2}, "hold_seconds": {"type": "integer", "minimum": 3600}}},
    "manual_override": {"type": "object", "required": ["enabled", "log_required"], "properties": {"enabled": {"type": "boolean", "const": true}, "log_required": {"type": "boolean", "const": true}}},
    "runbook": {"type": "array", "minItems": 4}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "feature_id": "summarize-news-v1",
  "thresholds": {
    "outcome_drop_pp": 5,
    "trajectory_drop_pp": 10,
    "resources_cost_pct": 50
  },
  "window": {
    "min_inferences": 200,
    "min_seconds": 600
  },
  "canary": {
    "ratios": [
      0.05,
      0.25,
      1.0
    ],
    "hold_seconds": 21600
  },
  "manual_override": {
    "enabled": true,
    "log_required": true
  },
  "runbook": [
    "capture-state",
    "notify-owner",
    "freeze-deploys",
    "schedule-postmortem"
  ]
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "feature_id": "x"
}
]]></code>
    <note>Missing thresholds, window, canary, manual_override, runbook.</note>
  </example>

  <reference path="scripts/validate-auto-rollback-policy-design.py">Validator script</reference>
</text>
