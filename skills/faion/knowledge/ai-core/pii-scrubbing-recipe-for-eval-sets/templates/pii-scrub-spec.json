{
  "__faion_header__": {
    "purpose": "pii-scrub-spec artefact skeleton for eval-harness build",
    "consumes": "production traffic sample + consent dict + retention policy",
    "produces": "validated pii-scrub-spec conforming to 02-output-contract.xml",
    "depends_on": "content/01-core-rules.xml r1-r5",
    "token_budget_impact": "0 LLM tokens; declarative artefact"
  },
  "artefact_id": "eval-set-<project>-<period>",
  "owner": "<handle-or-role>@faion.net",
  "scrub_strategy": {
    "mode": "regex_plus_ml",
    "rules": ["email", "phone", "credit_card", "ml-ner-person"]
  },
  "consent_label_field": "user.consent.eval_v1",
  "retention_days": 365,
  "inputs_used": [
    {"name": "traffic_sample", "source": "warehouse://<table>#<sample_id>"},
    {"name": "consent_dict", "source": "git://<repo>/consent.yaml@<sha>"}
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
