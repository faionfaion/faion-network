<text id="06-decision-tree" title="Fine-tune vs prompt decision tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>Eval set exists AND four axes (quality/cost/latency/maintenance) scored 1-5?</root-question>
    <branch when="eval_set == null OR any_axis_missing == true">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="eval_set != null AND all_axes_scored == true">
      <question>How many axes scored ≤ 2 (below target)?</question>
      <branch when="axes_below_target == 0">
        <conclusion ref="r1"/>
      </branch>
      <branch when="axes_below_target == 1">
        <question>Did any tried alternative clear the axis gap?</question>
        <branch when="best_alt_lift &gt;= gap">
          <conclusion ref="r3"/>
        </branch>
        <branch when="best_alt_lift &lt; gap">
          <conclusion ref="r3"/>
        </branch>
      </branch>
      <branch when="axes_below_target &gt;= 2">
        <question>Have all four alternatives been tried, with FT cost-benefit positive?</question>
        <branch when="all_alts_tried == true AND ft_benefit_positive == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
        <branch when="all_alts_tried == false OR ft_benefit_positive == false">
          <conclusion ref="r2"/>
        </branch>
      </branch>
    </branch>
    <example trace="chat-classifier, axes 3/2/4/4, 1 axis below — routing cleared cost gap -> r3 (routing recommendation)"/>
  </decision-tree>
</text>
