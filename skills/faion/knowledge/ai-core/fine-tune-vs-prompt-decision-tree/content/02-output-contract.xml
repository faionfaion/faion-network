<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="Fine-tune vs prompt decision tree — output contract" version="1.0.0" est_tokens="700" depth="essential">
  <summary>JSON Schema + examples for the 4-axis decision artefact.</summary>

  <section title="JSON Schema">
    <code lang="json"><![CDATA[{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ft-vs-prompt-decision-tree",
  "type": "object",
  "required": ["workload", "owner", "created_at", "axes", "alternatives_tried", "recommendation", "revisit_triggers"],
  "properties": {
    "workload": {"type": "string"},
    "owner": {"type": "string", "not": {"enum": ["team", "everyone", "TBD"]}},
    "created_at": {"type": "string", "format": "date"},
    "axes": {
      "type": "object",
      "required": ["quality", "cost", "latency", "maintenance"],
      "properties": {
        "quality":     {"type": "object", "required": ["score", "note"], "properties": {"score": {"type": "integer", "minimum": 1, "maximum": 5}, "note": {"type": "string", "minLength": 5}}},
        "cost":        {"type": "object", "required": ["score", "note"], "properties": {"score": {"type": "integer", "minimum": 1, "maximum": 5}, "note": {"type": "string", "minLength": 5}}},
        "latency":     {"type": "object", "required": ["score", "note"], "properties": {"score": {"type": "integer", "minimum": 1, "maximum": 5}, "note": {"type": "string", "minLength": 5}}},
        "maintenance": {"type": "object", "required": ["score", "note"], "properties": {"score": {"type": "integer", "minimum": 1, "maximum": 5}, "note": {"type": "string", "minLength": 5}}}
      }
    },
    "alternatives_tried": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["alt", "lift", "status"],
        "properties": {
          "alt": {"enum": ["prompt-improve", "rag", "routing", "distillation"]},
          "lift": {"type": ["number", "null"]},
          "status": {"enum": ["tried", "untried", "skipped"]}
        }
      }
    },
    "recommendation": {"enum": ["no-change", "prompt-improve", "rag", "routing", "distillation", "fine-tune", "hybrid"]},
    "revisit_triggers": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 10}}
  }
}]]></code>
  </section>

  <section title="Valid example">
    <example type="good">
      <code lang="json"><![CDATA[{
  "workload": "support-classifier",
  "owner": "alice@example.com",
  "created_at": "2026-05-22",
  "axes": {
    "quality":     {"score": 3, "note": "F1 0.78, target 0.82"},
    "cost":        {"score": 2, "note": "$/req 1.5c, target 0.8c"},
    "latency":     {"score": 4, "note": "p95 280ms, target 400ms — fine"},
    "maintenance": {"score": 3, "note": "two prompts, no FT yet"}
  },
  "alternatives_tried": [
    {"alt": "prompt-improve", "lift": 0.02, "status": "tried"},
    {"alt": "rag", "lift": 0.0, "status": "tried"},
    {"alt": "routing", "lift": 0.03, "status": "tried"},
    {"alt": "distillation", "lift": null, "status": "untried"}
  ],
  "recommendation": "routing",
  "revisit_triggers": ["volume crosses 100k req/day", "Sonnet 4.6 ships at -50% price", "F1 falls below 0.74 for 2 days"]
}]]></code>
    </example>
  </section>

  <section title="Invalid example">
    <example type="bad">
      <code lang="json"><![CDATA[{
  "workload": "x",
  "owner": "team",
  "created_at": "2026-05-22",
  "axes": {
    "quality": {"score": 2, "note": "bad"}
  },
  "alternatives_tried": [],
  "recommendation": "fine-tune",
  "revisit_triggers": []
}]]></code>
      <note>Missing axes (r1), owner=team (r5), no alternatives_tried (r2), no triggers (r4), recommendation FT despite missing data (r3).</note>
    </example>
  </section>

  <section title="Self-check checklist">
    <list>
      <item>axes has quality + cost + latency + maintenance, each with score and note.</item>
      <item>alternatives_tried has all four entries.</item>
      <item>revisit_triggers.length ≥ 2.</item>
      <item>owner is a person, not a team alias.</item>
    </list>
  </section>
</text>
