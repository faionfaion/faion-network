<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Claude Code &amp; Cursor at Solo Tier Decision Tree" version="1.1.0" est_tokens="400" depth="essential">
  <summary>Routes by observable signal to a rule from 01-core-rules.xml.</summary>

  <decision-tree>
    <root-question id="q-convention">CLAUDE.md / AGENTS.md present?</root-question>

    <branch when="convention_present == false">
      <conclusion ref="repo-conventions-mandatory" verdict="halt — add convention files first"/>
    </branch>

    <branch when="convention_present == true">
      <question id="q-task-type">task type?</question>
      <branch when="task == design_or_cross_file">
        <conclusion ref="model-routing" verdict="route to Opus + spec-before-code"/>
      </branch>
      <branch when="task == routine">
        <conclusion ref="model-routing" verdict="route to Sonnet + 2K context budget"/>
      </branch>
      <branch when="task == mechanical">
        <conclusion ref="model-routing" verdict="route to Haiku"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="solo-saas-onboard">
    convention_present=true → task=design → conclusion model-routing → Opus + spec.
  </example>
</text>
