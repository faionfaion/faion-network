<text id="06-decision-tree" title="LLM Drift Daily Triage Decision Tree" version="1.0.0" est_tokens="400">
  <decision-tree>
    <root-question>What is the largest of: |eval_score_pp|, |refusal_rate_pp|, |cost_pct|?</root-question>
    <branch when="max_delta &lt; 2pp AND cost_pct &lt; 10">
      <conclusion ref="run-the-checklist"/>
    </branch>
    <branch when="max_delta &gt;= 2pp AND max_delta &lt; 5pp OR (cost_pct &gt;= 10 AND cost_pct &lt; 25)">
      <question>Is the cause a known change (deploy, prompt edit, model upgrade) within the last 24h?</question>
      <branch when="cause.known == true">
        <conclusion ref="r4"/>
      </branch>
      <branch when="cause.known == false">
        <conclusion ref="r4"/>
      </branch>
    </branch>
    <branch when="max_delta &gt;= 5pp OR cost_pct &gt;= 25">
      <conclusion ref="r4"/>
    </branch>
    <example trace="eval -1.2pp, refusal +0.5pp, cost +3% → max &lt; 2pp → run-the-checklist (decision=continue)"/>
  </decision-tree>
</text>
