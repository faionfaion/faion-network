<text id="02-output-contract" title="Prompt Portability Across Providers Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the portability-spec artefact + valid/invalid examples + forbidden patterns.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/prompt-portability-across-providers.json",
  "type": "object",
  "required": ["artefact_id", "owner", "providers", "abstraction_layer", "tool_schema_adapter", "refusal_policy_ref", "inputs_used", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]{3,64}$"},
    "owner": {"type": "string", "minLength": 3, "not": {"enum": ["team", "we", "us", "engineering"]}},
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "model", "docs_url"],
        "properties": {
          "name": {"enum": ["anthropic", "openai", "google", "azure", "mistral", "groq"]},
          "model": {"type": "string", "minLength": 2},
          "docs_url": {"type": "string", "pattern": "^https?://"}
        }
      },
      "minItems": 2
    },
    "abstraction_layer": {"enum": ["tool_schema_only", "system_prompt_only", "tool_and_system", "full_adapter"]},
    "tool_schema_adapter": {"type": "string", "minLength": 3},
    "refusal_policy_ref": {"type": "string", "minLength": 3},
    "inputs_used": {"type": "array", "items": {"type": "object", "required": ["name", "source"]}, "minItems": 2},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "last_reviewed": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">providers array has &lt;2 entries (single-provider invalidates the methodology)</item>
      <item id="f2">tool_schema_adapter missing or empty when abstraction_layer includes tool</item>
      <item id="f3">refusal_policy_ref empty</item>
      <item id="f4">owner forbidden value</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "portability-support-bot-2026q2",
  "owner": "ruslan@faion.net",
  "providers": [
    {"name": "anthropic", "model": "claude-opus-4-7", "docs_url": "https://docs.anthropic.com/en/api/messages"},
    {"name": "openai", "model": "gpt-5-pro", "docs_url": "https://platform.openai.com/docs/api-reference/chat"}
  ],
  "abstraction_layer": "tool_and_system",
  "tool_schema_adapter": "faion.adapters.tools.universal_v2",
  "refusal_policy_ref": "git://faion/safety/refusal.md@a1b2c3d",
  "inputs_used": [
    {"name": "current_prompts", "source": "git://faion/prompts/support-bot.yaml"},
    {"name": "provider_matrix", "source": "git://faion/platform/providers.yaml"}
  ],
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "providers": [{"name": "anthropic", "model": "claude-opus-4-7", "docs_url": "https://docs.anthropic.com"}],
  "abstraction_layer": "tool_and_system",
  "tool_schema_adapter": "",
  "refusal_policy_ref": "",
  "inputs_used": [],
  "version": "v1",
  "last_reviewed": "yesterday"
}
]]></code>
    <note>single provider (f1); adapter empty (f2); refusal_policy empty (f3); owner=team (f4); inputs empty.</note>
  </example>

  <reference path="scripts/validate-prompt-portability-across-providers.py">Validator script</reference>
</text>
