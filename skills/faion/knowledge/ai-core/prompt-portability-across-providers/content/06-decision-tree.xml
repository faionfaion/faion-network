<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Prompt Portability Across Providers Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes provider matrix size to abstraction layer or skip.</summary>

  <decision-tree>
    <root-question id="q-provider-count">Provider matrix has ≥2 entries (current or planned within quarter)?</root-question>
    <branch when="provider_count &lt; 2">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="provider_count &gt;= 2">
      <question id="q-divergence">Tool schemas differ AND/OR system-prompt roles differ?</question>
      <branch when="tools_diverge == true AND roles_diverge == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
      <branch when="tools_diverge == false AND roles_diverge == false">
        <conclusion ref="r2-bounded-output"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-bot-q2-2026">
    provider_count=2 → tools_diverge=true AND roles_diverge=true → run-the-checklist (abstraction_layer=tool_and_system).
  </example>
</text>
