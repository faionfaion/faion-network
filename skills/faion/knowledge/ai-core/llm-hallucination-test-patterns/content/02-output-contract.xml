<text id="02-output-contract" title="LLM Hallucination Test Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema (draft-07) for the artefact this methodology produces. Validator script enforces required keys, types, and per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/llm-hallucination-test-patterns.json",
  "title": "LLM Hallucination Test Patterns",
  "type": "object",
  "required": [
    "suite_version",
    "patterns",
    "per_pattern_cases",
    "rubric_refs",
    "gold_authors",
    "results"
  ],
  "properties": {
    "suite_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "patterns": {
      "type": "array",
      "items": {
        "enum": [
          "fact_probes",
          "grounding_required",
          "refusal_correctness",
          "citation_verification",
          "contradiction_tests",
          "off_topic_rejection"
        ]
      },
      "minItems": 6
    },
    "per_pattern_cases": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 10
      }
    },
    "rubric_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "gold_authors": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "passed",
          "failed",
          "n"
        ]
      }
    }
  },
  "additionalProperties": false
}
]]></code>
  </section>

