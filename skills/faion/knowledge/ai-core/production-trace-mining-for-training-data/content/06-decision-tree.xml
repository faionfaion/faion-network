<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Production Trace Mining Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes traffic volume + label confidence + scrub-state to mining strategy.</summary>

  <decision-tree>
    <root-question id="q-scrub-ready">Is a PII-scrub recipe committed and fresh (last_reviewed &lt;90 days)?</root-question>
    <branch when="scrub_spec_ready == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="scrub_spec_ready == true">
      <question id="q-cadence">Recurring trigger on the operating cadence (monthly / quarterly)?</question>
      <branch when="cadence == ad_hoc OR cadence == none">
        <conclusion ref="r1-explicit-trigger"/>
      </branch>
      <branch when="cadence == recurring">
        <question id="q-owner">Named accountable owner exists?</question>
        <branch when="named_owner == false">
          <conclusion ref="r4-named-owner"/>
        </branch>
        <branch when="named_owner == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-bot-q2-2026">
    scrub_spec_ready=true → cadence=monthly → named_owner=true → run-the-checklist.
  </example>
</text>
