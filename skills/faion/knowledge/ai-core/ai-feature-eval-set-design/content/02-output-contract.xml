<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Feature Eval Set Design Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the spec artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-feature-eval-set-design.json",
  "type": "object",
  "required": ["eval_set_id", "version", "rows", "judge", "ci_gate"],
  "properties": {
    "eval_set_id": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "rows": {"type": "object", "required": ["gold", "adversarial", "drift"], "properties": {"gold": {"type": "integer", "minimum": 30}, "adversarial": {"type": "integer", "minimum": 10}, "drift": {"type": "integer", "minimum": 5}}},
    "judge": {"type": "object", "required": ["kind", "model_or_rule"], "properties": {"kind": {"enum": ["llm-as-judge", "rule-based"]}, "model_or_rule": {"type": "string"}, "rubric_schema_uri": {"type": "string"}}},
    "ci_gate": {"type": "object", "required": ["regression_threshold_pp", "axes"], "properties": {"regression_threshold_pp": {"type": "number", "minimum": 0.5, "maximum": 10}, "axes": {"type": "array", "items": {"enum": ["gold_accuracy", "adversarial_robustness", "drift_accuracy"]}, "minItems": 1}}}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "eval_set_id": "summarize-news-v1",
  "version": "1.4.0",
  "rows": {
    "gold": 35,
    "adversarial": 12,
    "drift": 8
  },
  "judge": {
    "kind": "llm-as-judge",
    "model_or_rule": "claude-sonnet-4-7",
    "rubric_schema_uri": "schemas/judge-rubric.json"
  },
  "ci_gate": {
    "regression_threshold_pp": 2.0,
    "axes": [
      "gold_accuracy",
      "adversarial_robustness",
      "drift_accuracy"
    ]
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "version": "1.0"
}
]]></code>
    <note>Missing eval_set_id, rows, judge, ci_gate; version not semver.</note>
  </example>

  <reference path="scripts/validate-ai-feature-eval-set-design.py">Validator script</reference>
</text>
