<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="AI Trust Disclosure Patterns Output Contract" version="1.1.0" est_tokens="900" depth="essential">
  <summary>JSON Schema for the checklist artefact this methodology produces. Validator enforces required keys + per-field constraints.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://faion.net/schemas/ai-trust-disclosure-patterns.json",
  "type": "object",
  "required": ["feature_id", "disclosure_axes", "review_signoffs"],
  "properties": {
    "feature_id": {"type": "string"},
    "disclosure_axes": {"type": "object", "required": ["model_identity_visible", "uncertainty_signal", "source_citation", "opt_out_path", "error_report_path"], "additionalProperties": {"type": "boolean"}},
    "jurisdictions": {"type": "array", "items": {"type": "string"}},
    "review_signoffs": {"type": "object", "required": ["legal", "design", "engineering"], "additionalProperties": {"type": "object", "required": ["reviewer", "date"], "properties": {"reviewer": {"type": "string"}, "date": {"type": "string", "format": "date"}}}}
  }
}
]]></code>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "feature_id": "copilot-v2",
  "disclosure_axes": {
    "model_identity_visible": true,
    "uncertainty_signal": true,
    "source_citation": true,
    "opt_out_path": true,
    "error_report_path": true
  },
  "jurisdictions": [
    "EU",
    "US",
    "UK"
  ],
  "review_signoffs": {
    "legal": {
      "reviewer": "j.lopez",
      "date": "2026-05-20"
    },
    "design": {
      "reviewer": "k.brown",
      "date": "2026-05-19"
    },
    "engineering": {
      "reviewer": "m.singh",
      "date": "2026-05-21"
    }
  }
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "feature_id": "copilot-v2",
  "disclosure_axes": {
    "model_identity_visible": true
  }
}
]]></code>
    <note>Missing review_signoffs; disclosure_axes missing 4 of 5 required keys.</note>
  </example>

  <reference path="scripts/validate-ai-trust-disclosure-patterns.py">Validator script</reference>
</text>
