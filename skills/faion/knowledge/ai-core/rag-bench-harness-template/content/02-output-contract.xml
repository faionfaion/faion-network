<?xml version="1.0" encoding="UTF-8"?>
<text id="02-output-contract" title="RAG Bench Harness Template Output Contract" version="1.1.0" est_tokens="700" depth="essential">
  <summary>JSON Schema for the rag-bench-spec artefact + valid/invalid examples.</summary>

  <section title="Schema">
    <code lang="json"><![CDATA[
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://faion.net/schemas/rag-bench-harness-template.json",
  "type": "object",
  "required": ["artefact_id", "owner", "corpus", "query_set", "runners", "metrics", "leaderboard_path", "version", "last_reviewed"],
  "properties": {
    "artefact_id": {"type": "string", "pattern": "^[a-z0-9-]{3,64}$"},
    "owner": {"type": "string", "minLength": 3, "not": {"enum": ["team", "we", "us", "engineering"]}},
    "corpus": {
      "type": "object",
      "required": ["path", "sha", "doc_count"],
      "properties": {
        "path": {"type": "string", "minLength": 3},
        "sha": {"type": "string", "minLength": 7},
        "doc_count": {"type": "integer", "minimum": 1}
      }
    },
    "query_set": {
      "type": "object",
      "required": ["path", "gold_labels", "size"],
      "properties": {
        "path": {"type": "string"},
        "gold_labels": {"type": "boolean", "const": true},
        "size": {"type": "integer", "minimum": 10}
      }
    },
    "runners": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "config_hash"],
        "properties": {
          "name": {"type": "string"},
          "version": {"type": "string"},
          "config_hash": {"type": "string", "minLength": 7}
        }
      },
      "minItems": 1
    },
    "metrics": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "leaderboard_path": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "last_reviewed": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
  }
}
]]></code>
  </section>

  <section title="Forbidden patterns">
    <list>
      <item id="f1">corpus.sha missing or live corpus (rule r1)</item>
      <item id="f2">query_set.gold_labels=false (rule r2)</item>
      <item id="f3">runner without config_hash (rule r3)</item>
      <item id="f4">end-to-end RAG bench without faithfulness metric (rule r4)</item>
    </list>
  </section>

  <example valid="true">
    <code lang="json"><![CDATA[
{
  "artefact_id": "rag-bench-chunking-2026q2",
  "owner": "ruslan@faion.net",
  "corpus": {"path": "warehouse://kb_snapshot_2026q2", "sha": "a1b2c3d4e5f", "doc_count": 50000},
  "query_set": {"path": "git://faion/eval/queries-2026q2.jsonl", "gold_labels": true, "size": 800},
  "runners": [
    {"name": "bm25", "version": "rank_bm25-0.2.2", "config_hash": "9f8e7d6"},
    {"name": "dense-bge", "version": "bge-large-en-v1.5", "config_hash": "1a2b3c4"},
    {"name": "hybrid-rrf", "version": "v1.3", "config_hash": "5e6f7a8"}
  ],
  "metrics": ["Recall@10", "MRR", "faithfulness"],
  "leaderboard_path": "git://faion/leaderboards/rag-2026q2.json",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
]]></code>
  </example>

  <example valid="false">
    <code lang="json"><![CDATA[
{
  "artefact_id": "x",
  "owner": "team",
  "corpus": {"path": "live", "sha": "", "doc_count": 0},
  "query_set": {"path": "x", "gold_labels": false, "size": 3},
  "runners": [{"name": "bm25"}],
  "metrics": [],
  "leaderboard_path": "",
  "version": "v1",
  "last_reviewed": "yesterday"
}
]]></code>
    <note>owner=team; corpus.sha empty (f1); gold_labels=false (f2); runner missing config_hash (f3); metrics empty (f4).</note>
  </example>

  <reference path="scripts/validate-rag-bench-harness-template.py">Validator script</reference>
</text>
