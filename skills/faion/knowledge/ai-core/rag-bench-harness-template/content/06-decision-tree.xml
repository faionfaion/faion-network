<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="RAG Bench Harness Template Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes recurrence + corpus state + gold labels to run / skip.</summary>

  <decision-tree>
    <root-question id="q-recurring">Recurring bench on the operating cadence?</root-question>
    <branch when="recurring == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="recurring == true">
      <question id="q-corpus-committable">Corpus snapshot can be committed (license + size permit)?</question>
      <branch when="corpus_committable == false">
        <conclusion ref="r1-corpus-pinned"/>
      </branch>
      <branch when="corpus_committable == true">
        <question id="q-gold">Query set has gold labels?</question>
        <branch when="gold_labels == false">
          <conclusion ref="r2-query-set-gold"/>
        </branch>
        <branch when="gold_labels == true">
          <conclusion ref="run-the-checklist"/>
        </branch>
      </branch>
    </branch>
  </decision-tree>

  <example trace="kb-snapshot-q2-2026">
    recurring=true → corpus_committable=true → gold_labels=true → run-the-checklist.
  </example>
</text>
