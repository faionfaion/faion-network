{
  "__faion_header__": {
    "purpose": "rag-bench-spec artefact skeleton",
    "consumes": "corpus snapshot + query set + runner catalog + metric definitions",
    "produces": "validated bench spec conforming to 02-output-contract.xml",
    "depends_on": "content/02-output-contract.xml schema",
    "token_budget_impact": "0 LLM tokens; declarative"
  },
  "artefact_id": "rag-bench-<task>-<period>",
  "owner": "<handle>@faion.net",
  "corpus": {"path": "warehouse://<table>", "sha": "<sha>", "doc_count": 50000},
  "query_set": {"path": "git://<repo>/eval/queries.jsonl", "gold_labels": true, "size": 800},
  "runners": [
    {"name": "bm25", "version": "rank_bm25-0.2.2", "config_hash": "<hash>"},
    {"name": "dense", "version": "<model-name>", "config_hash": "<hash>"},
    {"name": "hybrid", "version": "<v>", "config_hash": "<hash>"}
  ],
  "metrics": ["Recall@10", "MRR", "faithfulness"],
  "leaderboard_path": "git://<repo>/leaderboards/<file>.json",
  "version": "1.0.0",
  "last_reviewed": "2026-05-22"
}
