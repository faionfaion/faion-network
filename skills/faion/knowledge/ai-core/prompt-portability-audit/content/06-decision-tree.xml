<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Prompt Portability Audit Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes audit need + scope state to run / skip / criterion-tagging conclusion.</summary>

  <decision-tree>
    <root-question id="q-migration-planned">Migration to another provider/model-generation planned in next 2 quarters OR quarterly health check due?</root-question>
    <branch when="migration_planned == false AND health_check_due == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="migration_planned == true OR health_check_due == true">
      <question id="q-scope-frozen">Scope paths pinned with git sha?</question>
      <branch when="scope_frozen == false">
        <conclusion ref="r1-bounded-scope"/>
      </branch>
      <branch when="scope_frozen == true">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-bot-q2-2026">
    migration_planned=true → scope_frozen=true → run-the-checklist.
  </example>
</text>
