<?xml version="1.0" encoding="UTF-8"?>
<text id="06-decision-tree" title="Prompt PR Review Checklist Decision Tree" version="1.1.0" est_tokens="500">
  <summary>Routes prompt-PR risk to checklist mode.</summary>

  <decision-tree>
    <root-question id="q-prompt-pr-flow">Does the repo use prompt PRs (vs live console edits)?</root-question>
    <branch when="prompt_pr_flow == false">
      <conclusion ref="skip-this-methodology"/>
    </branch>
    <branch when="prompt_pr_flow == true">
      <question id="q-risk">PR touches prompts with prod traffic exposure ≥10k/day OR safety-critical refusal style?</question>
      <branch when="prod_traffic &gt;= 10000 OR safety_critical == true">
        <conclusion ref="r4-mode-explicit"/>
      </branch>
      <branch when="prod_traffic &lt; 10000 AND safety_critical == false">
        <conclusion ref="run-the-checklist"/>
      </branch>
    </branch>
  </decision-tree>

  <example trace="support-bot-pr-1234">
    prompt_pr_flow=true → prod_traffic=14000 → r4-mode-explicit (mark mode=DO-CONFIRM).
  </example>
</text>
