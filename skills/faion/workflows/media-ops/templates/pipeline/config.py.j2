"""Pipeline configuration: paths, models, constants."""

from pathlib import Path

# Project root
ROOT = Path(__file__).resolve().parent.parent

# Directories
CONTENT_DIR = ROOT / "content"
STATE_DIR = ROOT / "state"
SCRIPTS_DIR = ROOT / "scripts"
GATSBY_DIR = ROOT / "gatsby"
IMAGES_DIR = GATSBY_DIR / "static" / "images"

# Site
SITE_BASE_URL = "{{ site_url }}"

# Models per stage — customize per budget
# Options: "opus" (best quality), "sonnet" (fast + cheap)
MODEL_EDITORIAL = "{{ model_editorial | default('opus') }}"
MODEL_RESEARCH = "{{ model_research | default('opus') }}"
MODEL_GENERATE = "{{ model_generate | default('opus') }}"
MODEL_REVIEW = "{{ model_review | default('opus') }}"
MODEL_REVISE = "{{ model_revise | default('opus') }}"
MODEL_TG = "{{ model_tg | default('sonnet') }}"

# SDK retry config (exponential backoff with jitter)
RETRY_MAX_ATTEMPTS = 3
RETRY_BASE_DELAY = 5.0     # seconds
RETRY_MAX_DELAY = 60.0     # seconds cap

# Review loop limits
MAX_REVIEW_CYCLES = 3       # article review: min 1, max 3
MAX_TG_REVIEW_CYCLES = 2    # TG post review: max 2

# Telegram
TG_CHANNEL_ID = "{{ tg_channel_id }}"
TG_CHANNEL_USERNAME = "{{ tg_channel_username }}"
MAX_TG_CAPTION = 900

# Schedule (UTC hours)
GENERATE_HOUR = {{ generate_hour | default(7) }}
TG_PUBLISH_HOURS = {{ tg_publish_hours | default([9, 12, 15, 18]) }}
DIGEST_HOUR = {{ digest_hour | default(20) }}

# Content types with word limits
CONTENT_TYPES = {
{%- for type_name, limits in content_types.items() %}
    "{{ type_name }}": {"min_words": {{ limits.min }}, "max_words": {{ limits.max }}},
{%- endfor %}
}

# Languages
PRIMARY_LANGUAGE = "{{ primary_language | default('en') }}"
{%- if languages | length > 1 %}
TRANSLATE_LANGUAGES = {{ translate_languages | default([]) }}
{%- endif %}

# RSS feeds (if applicable)
RSS_FEEDS = {
{%- for feed in rss_feeds | default([]) %}
    "{{ feed.name }}": "{{ feed.url }}",
{%- endfor %}
}

# Topics
TOPICS = {{ topics | default([]) }}

# Author
AUTHOR_NAME = "{{ author_name }}"
