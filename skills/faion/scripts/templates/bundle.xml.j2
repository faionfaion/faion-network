<faion_knowledge>
  <summary files="{{ files|length }}" total_words="{{ total_words }}" budget="{{ word_budget }}"/>

{% for doc in documents %}
{% if doc.inline %}
  {{ doc.content }}
{% else %}
  <document path="{{ doc.path }}"{% if doc.reason %} reason="{{ doc.reason | e }}"{% endif %} words="{{ doc.words }}">
<![CDATA[
{{ doc.content }}
]]>
  </document>
{% endif %}

{% endfor %}
</faion_knowledge>
