slug: "security-review-new-dependency-v2"
title: "Security review for new dependency"
tier: "geek"
group: "product-team"
persona: "p6-product-dev-team"
complexity: "medium"
version: "1.0.0"
status: "draft"
last_reviewed: 2026-05-20
maintainers:
  - "faion-network"
summary: |
  Engineer wants to add a new lib / SDK. Before merge: AI runs SBOM diff, supply-chain scan, license check; security-conscious engineer reviews the diff + alternatives. Decision recorded as a lightweight ADR. Auto-applied for ultra-trivial bumps via Renovate handoff.
content_id: "cdec53015ee26be6"
tier_min: "geek"
context:
  - "team"
intent: |
  Engineer wants to add a new lib / SDK. Before merge: AI runs SBOM diff, supply-chain scan, license check; security-conscious engineer reviews the diff + alternatives. Decision recorded as a lightweight ADR. Auto-applied for ultra-trivial bumps via Renovate handoff.
scope: |
  Engineer wants to add a new lib / SDK. Before merge: AI runs SBOM diff, supply-chain scan, license check; security-conscious engineer reviews the diff + alternatives. Decision recorded as a lightweight ADR. Auto-applied for ultra-trivial bumps via Renovate handoff.
success_criteria:
  - "All 4 stages have written outputs in the project record"
  - "Each stage's decision gate was answered before advancing (yes / no in writing)"
  - "Final stage produced the required written decision artifact"
  - "Every methodology reference loaded cleanly via `faion get-content`"
methodology_refs:
  - "gov-approval-token-signed-jwt"
  - "gov-license-compliance-scan"
  - "mr-renovate-ai-handoff"
  - "sec-trivy-pinned-supply-chain-scan"
  - "security-container-scanning"
  - "security-supply-chain"
  - "architecture-decision-records"
  - "security-architecture"
  - "architecture-decision-records"
  - "architecture-decision-records"
stages:
  - name: "Justify the Dependency"
    intent: "Why this one, why now."
    tasks:
      - "Document the use case and alternatives considered"
      - "Confirm we can't build it cheaply in-house"
      - "Note licence implications"
    methodologies:
      - slug: "gov-approval-token-signed-jwt"
        path: "geek/sdlc-ai/gov-approval-token-signed-jwt"
        required: true
        tier_gate: "geek"
      - slug: "gov-license-compliance-scan"
        path: "geek/sdlc-ai/gov-license-compliance-scan"
        required: true
        tier_gate: "geek"
    outputs:
      - "use-case + alternatives memo"
      - "build-or-buy note"
      - "licence note"
    decision_gate: "Advance only when the justification is on paper."
  - name: "Inspect the Package"
    intent: "Look before you import."
    tasks:
      - "Pin the version; review release notes and CHANGELOG"
      - "Run SCA (e.g., Snyk / Trivy) for known CVEs"
      - "Check maintainer activity and download trend"
    methodologies:
      - slug: "mr-renovate-ai-handoff"
        path: "geek/sdlc-ai/mr-renovate-ai-handoff"
        required: true
        tier_gate: "geek"
      - slug: "sec-trivy-pinned-supply-chain-scan"
        path: "geek/sdlc-ai/sec-trivy-pinned-supply-chain-scan"
        required: true
        tier_gate: "geek"
    outputs:
      - "pinned version"
      - "SCA report"
      - "maintainer activity notes"
    decision_gate: "Advance only when no critical CVE is open and maintainer signal is healthy."
  - name: "Sandbox & Surface Risk"
    intent: "What does it actually touch."
    tasks:
      - "Enumerate what it reads, writes, and sends over the network"
      - "Check transitive deps for risky packages"
      - "Run it in a sandboxed environment for behaviour"
    methodologies:
      - slug: "security-container-scanning"
        path: "pro/infra/cicd-engineer/security-container-scanning"
        required: true
        tier_gate: "geek"
      - slug: "security-supply-chain"
        path: "pro/infra/cicd-engineer/security-supply-chain"
        required: true
        tier_gate: "geek"
    outputs:
      - "surface enumeration"
      - "transitive-dep review"
      - "sandbox log"
    decision_gate: "Advance only when surface is acceptable and behaviour is clean."
  - name: "Decide & Document"
    intent: "Approve / reject with a written trail."
    tasks:
      - "Write the security review decision: approve / reject / approve-with-controls"
      - "Add to the approved-deps registry with the trail"
      - "Set the review cadence (e.g., quarterly)"
    methodologies:
      - slug: "architecture-decision-records"
        path: "solo/dev/software-architect/architecture-decision-records"
        required: true
        tier_gate: "geek"
      - slug: "security-architecture"
        path: "solo/dev/software-architect/security-architecture"
        required: true
        tier_gate: "geek"
      - slug: "architecture-decision-records"
        path: "solo/sdd/sdd-planning/architecture-decision-records"
        required: true
        tier_gate: "geek"
      - slug: "architecture-decision-records"
        path: "solo/sdd/sdd/architecture-decision-records"
        required: true
        tier_gate: "geek"
    outputs:
      - "decision doc"
      - "registry entry"
      - "review cadence"
    decision_gate: "Required output: a signed-off security decision in the registry."
token_budget_estimate: 18000
