# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #14
# =============================================================================

slug: adr-write-up-client-architecture
title: "ADR write-up for client architecture decision"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 75a9c0a8e67f4700

tier_min: pro
complexity: medium
context: [outsource, team]
persona_hints: [P4]

intent: |
  Capture one architecture decision so the client ARB accepts it, AI agents can replay it, and the next dev finds it in 18 months.

scope: |
  Atomic doc task: one architecture decision committed to an ADR ready for client architecture review board. Output: ADR + decision-driver chain + tradeoff frame + AI-replayable summary. Used 1-3 times per sprint on a typical engagement.

non_goals:
  - "Full design document — single decision in focus"
  - "Architecture spike — work happens elsewhere"
  - "Sprint planning — separate ceremony"

prerequisites:
  - "Decision is made or near-final"
  - "Client ADR template accepted"
  - "Quality attributes / NFRs documented"

success_criteria:
  - "ADR follows client template"
  - "Decision driver chain explicit"
  - "Tradeoffs surfaced with named alternatives"
  - "Quality-attributes impact captured"
  - "AI-agent-friendly summary block included"
  - "Indexed in the living-documentation system"

stages:
  - name: "Frame decision"
    intent: "Make the decision before you write the doc."
    tasks:
      - "Walk the decision driver chain (what triggered it)"
      - "List alternatives considered"
      - "Map to quality attributes (perf, sec, availability, cost)"
      - "Trace to requirements / business goals"
    methodologies:
      - slug: requirements-traceability
        path: pro/ba/business-analyst/requirements-traceability
        required: true
        tier_gate: pro
      - slug: quality-attributes-analysis
        path: pro/dev/software-architect/quality-attributes-analysis
        required: true
        tier_gate: pro
    outputs:
      - "Decision draft notes"
      - "Alternatives shortlist"
    decision_gate: |
      Advance only when ≥2 alternatives were honestly considered.
  - name: "Write ADR"
    intent: "Convert the decision into a doc the ARB accepts."
    tasks:
      - "Use the architecture-decision-records pattern"
      - "Storytelling: context → decision → consequences"
      - "Selling-ideas: defend the choice without overselling"
      - "Capture stakeholder context for ARB review"
    methodologies:
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: architecture-decision-records
        path: solo/sdd/sdd/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: stakeholder-engagement
        path: pro/pm/pm-traditional/stakeholder-engagement
        required: true
        tier_gate: pro
      - slug: business-storytelling
        path: solo/comms/communicator/business-storytelling
        required: true
        tier_gate: solo
      - slug: selling-ideas
        path: solo/comms/communicator/selling-ideas
        required: true
        tier_gate: solo
      - slug: adr-for-client-arb-review-template
        path: pro/_gap/adr-for-client-arb-review-template
        required: true
        tier_gate: pro
    outputs:
      - "ADR draft"
    decision_gate: |
      Advance only when the ADR is self-contained (a stranger reads it without context).
  - name: "Tradeoff + AI-replayable summary"
    intent: "Make the doc resilient for AI agents and future devs."
    tasks:
      - "Frame stack-mandate tradeoffs explicitly"
      - "Write the AI-agent-replayable summary block"
      - "Index in living-documentation"
      - "File with the client ARB"
    methodologies:
      - slug: living-documentation
        path: solo/sdd/sdd/living-documentation
        required: true
        tier_gate: solo
      - slug: stack-mandate-tradeoff-frame
        path: pro/_gap/stack-mandate-tradeoff-frame
        required: true
        tier_gate: pro
    outputs:
      - "Final ADR"
      - "AI-replayable summary"
      - "ARB submission record"
    decision_gate: |
      Done when ADR is indexed AND an AI-agent can answer 'why this choice' from the doc alone.

common_pitfalls:
  - "Writing the ADR after the decision is forgotten — drift between doc and intent"
  - "Skipping alternatives — looks defensive at ARB"
  - "No AI-replayable summary — agents reinvent the decision next sprint"

quality_checklist:
  - "Could the next dev find this ADR via repo search?"
  - "Did the ARB ratify it without rewrites?"
  - "Does the AI summary survive a context-free read?"

related_playbooks:
  - jira-ticket-scoping-session
  - compliance-grade-feature-delivery

token_budget_estimate: 8000
cli_invocations:
  human:  "faion get-content adr-write-up-client-architecture --format md"
  agent:  "faion get-content adr-write-up-client-architecture --format context"
  json:   "faion get-content adr-write-up-client-architecture --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, atomic angle"

gaps:
  - methodology_slug: adr-for-client-arb-review-template
    expected_tier: pro
    blocks_stage: 2
    note: "Referenced by stage 2; not yet materialised as a methodology."
  - methodology_slug: stack-mandate-tradeoff-frame
    expected_tier: pro
    blocks_stage: 3
    note: "Referenced by stage 3; not yet materialised as a methodology."
