# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #8
# =============================================================================

slug: reputation-referral-pipeline-ramp
title: "Reputation + referral pipeline ramp (90-day flywheel)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: a32f7b646f375bd0

tier_min: pro
complexity: medium
context: [solo]
persona_hints: [P3]

intent: |
  Build a system that compounds: every closed engagement produces a testimonial + a referral + a public artefact, so by day 90 inbound covers >=50% of new pipeline and outbound effort drops.

scope: |
  Build a system that compounds: every closed engagement produces a testimonial + a referral + a public artefact, so by day 90 inbound covers >=50% of new pipeline and outbound effort drops.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Define the loop stage complete: Loop diagram"
  - "Build harvest SOPs stage complete: 3 SOPs"
  - "Distribute proof stage complete: Case study live"
  - "Referral + partner stage complete: Referral program doc"

stages:
  - name: "Define the loop"
    intent: "Map the loop: every closed engagement → testimonial + referral + artefact."
    tasks:
      - "Sketch the 3-output loop diagram"
      - "Define triggers + handoffs"
      - "Identify automation points"
    methodologies:
      - slug: funnel-basics-framework
        path: pro/marketing/conversion-optimizer/funnel-basics-framework
        required: true
        tier_gate: pro
      - slug: funnel-tactics-advanced
        path: pro/marketing/conversion-optimizer/funnel-tactics-advanced
        required: true
        tier_gate: pro
      - slug: aarrr-pirate-metrics
        path: pro/marketing/growth-marketer/aarrr-pirate-metrics
        required: true
        tier_gate: pro
      - slug: growth-viral-loops
        path: pro/marketing/growth-marketer/growth-viral-loops
        required: true
        tier_gate: pro
    outputs:
      - "Loop diagram"
      - "Trigger / handoff doc"
    decision_gate: |
      Advance once loop is documented and at least one past engagement has been retrofitted.
  - name: "Build harvest SOPs"
    intent: "Turn the loop into repeatable SOPs."
    tasks:
      - "Write testimonial-harvest script"
      - "Write referral-ask script"
      - "Write public-artefact (case study) checklist"
    methodologies:
      - slug: elicitation-techniques
        path: pro/ba/business-analyst/elicitation-techniques
        required: true
        tier_gate: pro
      - slug: growth-referral-programs
        path: pro/marketing/growth-marketer/growth-referral-programs
        required: true
        tier_gate: pro
      - slug: ops-upselling-cross-selling
        path: pro/marketing/gtm-strategist/ops-upselling-cross-selling
        required: true
        tier_gate: pro
      - slug: business-storytelling
        path: solo/marketing/content-marketer/business-storytelling
        required: true
        tier_gate: solo
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: solo
      - slug: testimonial-harvest-sop
        path: pro/_gap/testimonial-harvest-sop
        required: true
        tier_gate: pro
    outputs:
      - "3 SOPs"
      - "Template library"
    decision_gate: |
      Advance once SOPs run end-to-end on one closed engagement.
  - name: "Distribute proof"
    intent: "Surface testimonials + case studies where buyers look."
    tasks:
      - "Publish case study + LinkedIn version + newsletter version"
      - "Add testimonials to landing page above the fold"
      - "Schedule social-rotation of evergreen artefacts"
    methodologies:
      - slug: ops-customer-success-metrics
        path: pro/marketing/gtm-strategist/ops-customer-success-metrics
        required: true
        tier_gate: pro
      - slug: growth-linkedin-strategy
        path: pro/marketing/smm-manager/growth-linkedin-strategy
        required: true
        tier_gate: pro
      - slug: product-analytics
        path: pro/product/product-manager/product-analytics
        required: true
        tier_gate: pro
      - slug: ops-automation-workflow
        path: solo/dev/automation-tooling/ops-automation-workflow
        required: true
        tier_gate: solo
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
      - slug: search-everywhere-optimization
        path: solo/marketing/content-marketer/search-everywhere-optimization
        required: true
        tier_gate: solo
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
      - slug: topical-authority
        path: solo/marketing/seo-manager/topical-authority
        required: true
        tier_gate: solo
      - slug: zero-click-search-adaptation
        path: solo/marketing/seo-manager/zero-click-search-adaptation
        required: true
        tier_gate: solo
    outputs:
      - "Case study live"
      - "Testimonials on landing"
      - "Social rotation calendar"
    decision_gate: |
      Advance once distribution surface covers landing + LinkedIn + newsletter.
  - name: "Referral + partner"
    intent: "Activate referral incentive + partner swaps."
    tasks:
      - "Design referral incentive (cash, hours, or trade)"
      - "Identify 5 swap partners (non-competing peers)"
      - "Set up intake qualification for inbound"
    methodologies:
      - slug: ops-partnership-strategy
        path: pro/marketing/gtm-strategist/ops-partnership-strategy
        required: true
        tier_gate: pro
      - slug: freelance-referral-program-design
        path: pro/_gap/freelance-referral-program-design
        required: true
        tier_gate: pro
      - slug: inbound-intake-qualification
        path: pro/_gap/inbound-intake-qualification
        required: true
        tier_gate: pro
      - slug: partner-swap-deal-template
        path: pro/_gap/partner-swap-deal-template
        required: true
        tier_gate: pro
    outputs:
      - "Referral program doc"
      - "Partner swap agreements"
      - "Inbound intake form"
    decision_gate: |
      Advance once inbound covers ≥50% of new pipeline over 30 days.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  []

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content reputation-referral-pipeline-ramp --format md"
  agent:  "faion get-content reputation-referral-pipeline-ramp --format context"
  json:   "faion get-content reputation-referral-pipeline-ramp --format json"

