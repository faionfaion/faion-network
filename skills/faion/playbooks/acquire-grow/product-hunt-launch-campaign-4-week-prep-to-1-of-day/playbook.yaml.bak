slug: product-hunt-launch-campaign-4-week-prep-to-1-of-day
title: "Product Hunt launch campaign: 4-week prep to #1-of-day"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: da1838c3d540de71

tier_min: solo
complexity: medium
context: [solo]
persona_hints: [P2]

intent: |
  Run a structured 4-week campaign that takes a shipping product to a top-3 Product Hunt launch, with measurable signup + revenue lift, then converts the spike into retained subscribers and audience.

scope: |
  Run a structured 4-week campaign that takes a shipping product to a top-3 Product Hunt launch, with measurable signup + revenue lift, then converts the spike into retained subscribers and audience.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Pre-launch checklist (T-4 weeks)"
    intent: "Pick the date, prep the assets."
    tasks:
      - "Reserve the launch date (avoid major collisions)"
      - "Draft the listing copy + visuals"
      - "Line up the maker bio + comments plan"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: growth-cold-outreach
        path: solo/marketing/gtm-strategist/growth-cold-outreach
        required: true
        tier_gate: solo
    outputs:
      - "Launch date reserved"
      - "Listing draft"
      - "Maker assets"
    decision_gate: "Advance only when listing draft is reviewed by 3 outsiders."
  - name: "Audience warm-up (T-3 weeks)"
    intent: "Tell the people who already follow you."
    tasks:
      - "Send a save-the-date to newsletter and audience"
      - "Run build-in-public posts that tease the launch"
      - "Identify 20 hunters/upvoters likely to engage"
    methodologies:
      - slug: growth-copywriting-fundamentals
        path: solo/marketing/content-marketer/growth-copywriting-fundamentals
        required: true
        tier_gate: solo
      - slug: growth-indiehackers-strategy
        path: solo/marketing/gtm-strategist/growth-indiehackers-strategy
        required: true
        tier_gate: solo
    outputs:
      - "Save-the-date email"
      - "Tease posts log"
      - "Engagement target list"
    decision_gate: "Advance only with >=20 confirmed early-supporters."
  - name: "Hunter + maker DMs (T-2 weeks)"
    intent: "Pre-load the maker comments and supporter pings."
    tasks:
      - "DM 20-50 makers with a friendly heads-up"
      - "Pre-write the first 5 maker comments"
      - "Confirm hunter relationships"
    methodologies:
      - slug: growth-email-marketing
        path: solo/marketing/content-marketer/growth-email-marketing
        required: true
        tier_gate: solo
      - slug: growth-product-hunt-launch
        path: solo/marketing/gtm-strategist/growth-product-hunt-launch
        required: true
        tier_gate: solo
    outputs:
      - "DM log"
      - "Pre-written comments"
      - "Hunter confirmation"
    decision_gate: "Advance only when DMs have answered yes I will engage."
  - name: "Asset polish (T-1 week)"
    intent: "Make the listing un-skippable."
    tasks:
      - "Finalize images / gif / video"
      - "Lock the tagline + first comment"
      - "Test mobile previews"
    methodologies:
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
    outputs:
      - "Final assets"
      - "Final tagline"
      - "Mobile preview screenshots"
    decision_gate: "Advance only when assets are locked >=24h before launch."
  - name: "Launch day execution"
    intent: "Run the day with discipline."
    tasks:
      - "Post at the optimal hour"
      - "Reply to every comment within minutes"
      - "Push warm channels for upvotes (without begging)"
    methodologies:
      - slug: growth-onboarding-emails
        path: solo/marketing/content-marketer/growth-onboarding-emails
        required: true
        tier_gate: solo
    outputs:
      - "Launch post live"
      - "Comment reply log"
      - "Channel push log"
    decision_gate: "Advance only when first 6 hours hit the target upvote pace."
  - name: "Post-launch drip (T+1 week)"
    intent: "Convert the spike into customers."
    tasks:
      - "Send a thanks + onboarding drip to new signups"
      - "Capture verbatim feedback from new users"
      - "Push a recap post to all channels"
    methodologies:
      - slug: growth-reddit-marketing
        path: solo/marketing/content-marketer/growth-reddit-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Drip sequence"
      - "Verbatim feedback bank"
      - "Recap post"
    decision_gate: "Advance only when drip converts >=20% of new signups to active."
  - name: "Lessons + #1-of-day post-mortem"
    intent: "Lock the learnings for the next launch."
    tasks:
      - "Compile the launch metrics"
      - "Write a post-mortem with what to repeat"
      - "Update the launch playbook with deltas"
    methodologies:
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
    outputs:
      - "Metrics report"
      - "Post-mortem doc"
      - "Updated playbook"
    decision_gate: "Cycle closes when post-mortem is committed."

token_budget_estimate: 12000

cli_invocations:
  human:  "faion get-content product-hunt-launch-campaign-4-week-prep-to-1-of-day --format md"
  agent:  "faion get-content product-hunt-launch-campaign-4-week-prep-to-1-of-day --format context"
  json:   "faion get-content product-hunt-launch-campaign-4-week-prep-to-1-of-day --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
