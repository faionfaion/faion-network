# =============================================================================
# PLAYBOOK — Synthesis: Launch-week orchestration for an AI-feature release
# tier=pro group=role-growth-marketing complexity=deep
# =============================================================================

slug: synthesis-launch-week-orchestration-for-an-ai-feature-release
title: "Synthesis: Launch-week orchestration for an AI-feature release"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 23c4758f213710f3

tier_min: pro
complexity: deep
context: [solo, team]
persona: ["solo-founder", "growth-marketer"]

intent: |
  Coordinate a single product release across PH/HN/Reddit/LinkedIn/X/email/paid in one
  shared timeline, with role/owner per surface and a post-mortem ledger

scope: |
  Coordinate a single product release across PH/HN/Reddit/LinkedIn/X/email/paid in one
  shared timeline, with role/owner per surface and a post-mortem ledger

summary: |
  Coordinate a single product release across PH/HN/Reddit/LinkedIn/X/email/paid in one
  shared timeline, with role/owner per surface and a post-mortem ledger

methodology_refs:
  - pro/marketing/gtm-strategist/growth-brand-positioning
  - solo/marketing/gtm-strategist/growth-hacker-news-launch
  - solo/marketing/gtm-strategist/growth-product-hunt-launch

success_criteria:
  - "Compound thesis + signal documented before any cycle runs"
  - "3+ consecutive cycles executed at the agreed cadence"
  - "Signal trajectory shows the discipline is paying off (or audit kills it)"
  - "Scaffold + cadence promoted into the official ops doc, owner trained"

stages:
  - name: "Hypothesis"
    intent: "State the compound discipline you want to install and why it compounds."
    tasks:
      - "Write the explicit thesis: what compounding behaviour you are installing"
      - "List the prior interventions this builds on"
      - "Set a measurable signal that says the discipline is taking hold"
    methodologies:
      - slug: ai-feature-positioning-framework
        path: pro/role-growth-marketing/ai-feature-positioning-framework
        required: true
        tier_gate: pro
    outputs:
      - "One-page thesis doc"
    decision_gate: "Advance only with a written compound thesis and signal."
  - name: "Scaffolding"
    intent: "Set up the templates, dashboards, and rituals before any output."
    tasks:
      - "Build the template/ledger/dashboard once"
      - "Define the cadence (daily / weekly / per-event)"
      - "Pre-stage the inputs you will need each cycle"
    methodologies:
      - slug: growth-brand-positioning
        path: pro/marketing/gtm-strategist/growth-brand-positioning
        required: true
        tier_gate: pro
    outputs:
      - "Templates + cadence committed to repo/wiki"
    decision_gate: "Advance only after the scaffold survives a dry-run cycle."
  - name: "First cycle"
    intent: "Run the first cycle exactly as specified; capture friction without fixing it yet."
    tasks:
      - "Run the cycle end-to-end without optimising"
      - "Capture every friction point in the ledger"
      - "Resist the urge to redesign the scaffold mid-cycle"
    methodologies:
      - slug: growth-hacker-news-launch
        path: solo/marketing/gtm-strategist/growth-hacker-news-launch
        required: true
        tier_gate: solo
    outputs:
      - "First-cycle output + friction log"
    decision_gate: "Advance only when the cycle produced its intended output, even if ugly."
  - name: "Variant test"
    intent: "Try one structural variant of the scaffold and pick the winner on evidence."
    tasks:
      - "Identify one variable in the scaffold worth testing"
      - "Run cycles in both variants in parallel or AB"
      - "Pick the winner with a written rationale"
    methodologies:
      - slug: growth-product-hunt-launch
        path: solo/marketing/gtm-strategist/growth-product-hunt-launch
        required: true
        tier_gate: solo
    outputs:
      - "Variant test readout"
    decision_gate: "Advance only with a written winner-pick; do not run both forever."
  - name: "Reduce friction"
    intent: "Fix the top 3 friction points so the next cycle is faster, not just cleaner."
    tasks:
      - "Rank friction points by cost per cycle"
      - "Fix the top 3; leave the rest documented"
      - "Update the scaffold templates with the fixes"
    methodologies:
      - slug: launch-postmortem-template
        path: pro/role-growth-marketing/launch-postmortem-template
        required: true
        tier_gate: pro
    outputs:
      - "Updated scaffold + friction-reduction log"
    decision_gate: "Advance only after each fix has a 'why this saves time per cycle' rationale."
  - name: "Repeat"
    intent: "Run cycles back-to-back to prove the discipline compounds, not just executes once."
    tasks:
      - "Run 3-5 cycles in a row at the agreed cadence"
      - "Track output + friction + signal each cycle"
      - "Do not skip cycles to make the dashboard look good"
    methodologies:
      - slug: launch-warroom-protocol
        path: pro/role-growth-marketing/launch-warroom-protocol
        required: true
        tier_gate: pro
    outputs:
      - "Cycle ledger with N entries"
    decision_gate: "Advance only when 3+ consecutive cycles show the signal moving the right way."
  - name: "Counter-pressure"
    intent: "Pressure-test the discipline against the failure modes that historically killed it."
    tasks:
      - "List the historical failure modes for this kind of cadence"
      - "Stress-test the scaffold against each one"
      - "Patch the scaffold against the failure mode that lands"
    methodologies:
      - slug: post-launch-content-drip
        path: pro/role-growth-marketing/post-launch-content-drip
        required: true
        tier_gate: pro
    outputs:
      - "Stress-test memo + patches"
    decision_gate: "Advance only after every historical failure mode has a documented mitigation."
  - name: "Audit"
    intent: "Step outside the cadence and ask: is this discipline actually paying off?"
    tasks:
      - "Compare signal trajectory vs the hypothesis"
      - "Interview anyone running cycles for what's still painful"
      - "Write the verdict: keep / change / kill the discipline"
    methodologies:
      - slug: waitlist-warmup-sequence
        path: pro/role-growth-marketing/waitlist-warmup-sequence
        required: true
        tier_gate: pro
    outputs:
      - "Audit memo with verdict"
    decision_gate: "Required output: a written verdict, never \"let's keep going and reassess\"."
  - name: "Institutionalize"
    intent: "If the discipline pays off, embed it so it survives founder/team turnover."
    tasks:
      - "Promote scaffold + cadence into the official ops doc"
      - "Train the next owner to run it from the doc alone"
      - "Add the metric to the rolling team review"
    methodologies:
      - slug: ai-feature-positioning-framework
        path: pro/role-growth-marketing/ai-feature-positioning-framework
        required: true
        tier_gate: pro
    outputs:
      - "Discipline lives in the ops doc + review"
    decision_gate: "Advance only after the next owner runs one full cycle solo."

token_budget_estimate: 12000

cli_invocations:
  human: "faion get-content synthesis-launch-week-orchestration-for-an-ai-feature-release --format md"
  agent: "faion get-content synthesis-launch-week-orchestration-for-an-ai-feature-release --format context"
  json:  "faion get-content synthesis-launch-week-orchestration-for-an-ai-feature-release --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook from F-059-063 chunk-09."

