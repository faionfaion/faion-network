# =============================================================================
# Audience-to-customer conversion sprint
# Persona: P2 Indie Hacker — F-064
# =============================================================================

slug: audience-to-customer-conversion-sprint
title: "Audience-to-customer conversion sprint"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: ae7c4d5a4d42d8b9

tier_min: solo
complexity: medium
context: [solo]
persona_hints: [P2]

intent: |
  Engaged audience → paying signups in a single-day sprint.

scope: |
  Once-a-month one-day sprint that wrings paid signups from an existing audience: tightens the conversion funnel, runs a soft promo, instruments one CTA, and ends with measurable paid conversions.

non_goals:
  - "Cold acquisition — existing audience only"
  - "Pricing redesign — single CTA tweak"
  - "Cross-product promotion — one product at a time"

prerequisites:
  - "Engaged audience on at least one channel"
  - "A product with a paid path live"

success_criteria:
  - "One CTA tested in isolation"
  - "Documented conversion delta vs baseline"
  - "≥10 paid signups in the sprint window"
  - "Updated audience-to-paid conversion loop"

stages:
  - name: "Audit"
    intent: "Know exactly where the funnel leaks."
    tasks:
      - "Map the audience → landing → checkout flow"
      - "Pull recent conversion data per stage"
      - "Pick the one stage with the worst drop-off"
    methodologies:
      - slug: plausible-analytics
        path: solo/marketing/growth-marketer/plausible-analytics
        required: true
        tier_gate: solo
      - slug: vanity-metrics-audit
        path: solo/product/vanity-metrics-audit
        required: true
        tier_gate: solo
    outputs:
      - "Funnel map with leak called out"
    decision_gate: |
      Advance once the priority leak is named.
  - name: "Stage CTA"
    intent: "One CTA fix wired to the leakiest stage."
    tasks:
      - "Rewrite the landing copy to address the leak"
      - "Add one testimonial above the CTA"
      - "Confirm checkout works end-to-end"
    methodologies:
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: solo
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
    outputs:
      - "Updated landing"
      - "Testimonial in place"
    decision_gate: |
      Advance once a stranger completes the flow on first try.
  - name: "Promo"
    intent: "Soft promo across owned channels in one day."
    tasks:
      - "Tweet thread with proof and CTA"
      - "Email blast referencing the audience signal"
      - "Cross-post to IndieHackers with personal angle"
    methodologies:
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
      - slug: growth-email-marketing
        path: solo/marketing/content-marketer/growth-email-marketing
        required: true
        tier_gate: solo
      - slug: growth-indiehackers-strategy
        path: solo/marketing/gtm-strategist/growth-indiehackers-strategy
        required: true
        tier_gate: solo
    outputs:
      - "Promo posts live"
      - "Email blast sent"
    decision_gate: |
      Advance once all channels have shipped within the sprint day.
  - name: "Measure"
    intent: "Compare conversion before and after the CTA change."
    tasks:
      - "Pull conversion data 24h after promo"
      - "Compare against pre-sprint baseline"
      - "Document the verdict and update the loop"
    methodologies:
      - slug: vanity-metrics-audit
        path: solo/product/vanity-metrics-audit
        required: true
        tier_gate: solo
      - slug: audience-to-paid-conversion-loop
        path: solo/marketing/audience-to-paid-conversion-loop
        required: true
        tier_gate: solo
    outputs:
      - "Conversion delta report"
    decision_gate: |
      Keep CTA only if uplift is ≥15%; otherwise rollback.

common_pitfalls:
  - "Treating the playbook as a checklist instead of a decision tree"
  - "Skipping decision gates when intermediate progress feels good"
  - "Letting tools or platforms replace the founder's own judgement"

quality_checklist:
  - "Did each stage produce its named output or get explicitly skipped with a note?"
  - "Were decision gates respected or quietly bypassed?"
  - "Is the evidence trail strong enough to defend the verdict externally?"

related_playbooks:
  - solo-idea-to-validated-mvp
token_budget_estimate: 18000
cli_invocations:
  human:  "faion get-content audience-to-customer-conversion-sprint --format md"
  agent:  "faion get-content audience-to-customer-conversion-sprint --format context"
  json:   "faion get-content audience-to-customer-conversion-sprint --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft from brainstorm-2026-05-17, persona P2 (indie hacker)"

gaps:
  - methodology_slug: social-proof-harvest
    expected_tier: solo
    blocks_stage: 2
    note: "Stage CTA needs a social proof harvest pipeline"
