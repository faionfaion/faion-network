# =============================================================================
# PLAYBOOK v2 — Distressed-project rescue (six-week turnaround)
# Group: role-project-manager | Tier: geek | Complexity: deep
# =============================================================================

slug: distressed-project-rescue-six-week-turnaround
title: "Distressed-project rescue (six-week turnaround)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 7b345416c5a136f0

tier_min: geek
complexity: deep
context: ['outsource']
persona: role-project-manager
group: role-project-manager

summary: "Take over or stabilise a project that has missed two consecutive milestones, lost client trust, or has red on cost/schedule/quality. Exit with a credible recovery plan executing for 3+ weeks."

intent: |
  Take over or stabilise a project that has missed two consecutive milestones, lost client trust, or has red on cost/schedule/quality. Exit with a credible recovery plan executing for 3+ weeks.

scope: |
  Take over or stabilise a project that has missed two consecutive milestones, lost client trust, or has red on cost/schedule/quality. Exit with a credible recovery plan executing for 3+ weeks.

methodology_refs:
  - pro/pm/pm-agile/agile-hybrid-approaches
  - pro/pm/pm-agile/kanban-scaled-agile-ceremonies
  - pro/pm/pm-agile/reporting-basics
  - pro/pm/pm-agile/team-development
  - pro/pm/pm-agile/value-stream-management
  - pro/pm/pm-traditional/benefits-realization
  - pro/pm/pm-traditional/change-control
  - pro/pm/pm-traditional/communications-management
  - pro/pm/pm-traditional/earned-value-management
  - pro/pm/pm-traditional/lessons-learned
  - pro/pm/pm-traditional/quality-management
  - pro/pm/pm-traditional/resource-management
  - pro/pm/pm-traditional/risk-register
  - pro/pm/pm-traditional/scope-management
  - pro/pm/pm-traditional/stakeholder-engagement-advanced
  - pro/pm/project-manager/jira-workflow-management
  - pro/pm/project-manager/raci-matrix

success_criteria:
  - "Top-3 root causes named with evidence"
  - "Client confirms accurate understanding of state"
  - "Rebaselined plan signed"
  - "3+ consecutive weeks of positive trend"
  - "Documented hand-back to steady-state PM"

stages:
  - name: "Diagnose week 1"
    intent: "Find the root cause(s) within 5 working days."
    tasks:
      - "Interview client, team, and outgoing PM"
      - "Audit schedule, cost (EVM), and quality data"
      - "Write a 1-page diagnosis with top 3 root causes"
    methodologies:
      - slug: earned-value-management
        path: pro/pm/pm-traditional/earned-value-management
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement-advanced
        path: pro/pm/pm-traditional/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
      - slug: quality-management
        path: pro/pm/pm-traditional/quality-management
        required: true
        tier_gate: pro
    outputs:
      - "Diagnosis 1-pager"
    decision_gate: "Advance when 3 root causes are named with evidence, not speculation."
  - name: "Stabilise comms"
    intent: "Stop the trust bleed."
    tasks:
      - "Send a candid, factual update to the client"
      - "Schedule a daily check-in for the first 2 weeks"
      - "Acknowledge known issues without overpromising"
    methodologies:
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement-advanced
        path: pro/pm/pm-traditional/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
    outputs:
      - "First candid update"
      - "Daily client check-in cadence"
    decision_gate: "Advance when the client confirms they understand the situation."
  - name: "Rebaseline scope"
    intent: "Cut scope honestly before promising recovery."
    tasks:
      - "Identify cuttable scope without breaking client value"
      - "Rebaseline scope + schedule + cost"
      - "Get written sign-off on the new baseline"
    methodologies:
      - slug: scope-management
        path: pro/pm/pm-traditional/scope-management
        required: true
        tier_gate: pro
      - slug: change-control
        path: pro/pm/pm-traditional/change-control
        required: true
        tier_gate: pro
      - slug: benefits-realization
        path: pro/pm/pm-traditional/benefits-realization
        required: true
        tier_gate: pro
    outputs:
      - "New baselined scope + plan"
    decision_gate: "Advance when the new baseline is signed by the client."
  - name: "Re-team"
    intent: "Adjust the team for the rescue, not the original plan."
    tasks:
      - "Identify capability gaps"
      - "Swap or add team members where critical"
      - "Re-run team-development rituals to reset chemistry"
    methodologies:
      - slug: resource-management
        path: pro/pm/pm-traditional/resource-management
        required: true
        tier_gate: pro
      - slug: team-development
        path: pro/pm/pm-agile/team-development
        required: true
        tier_gate: pro
      - slug: raci-matrix
        path: pro/pm/project-manager/raci-matrix
        required: true
        tier_gate: pro
    outputs:
      - "Re-teamed roster + reset rituals"
    decision_gate: "Advance when the new team has worked one full cycle together."
  - name: "Execute weeks 2-5"
    intent: "Run the rescue with daily ops and weekly client demos."
    tasks:
      - "Daily standup + weekly demo to client"
      - "Track via kanban or value-stream board"
      - "Burn down rebaselined backlog visibly"
    methodologies:
      - slug: kanban-scaled-agile-ceremonies
        path: pro/pm/pm-agile/kanban-scaled-agile-ceremonies
        required: true
        tier_gate: pro
      - slug: jira-workflow-management
        path: pro/pm/project-manager/jira-workflow-management
        required: true
        tier_gate: pro
      - slug: value-stream-management
        path: pro/pm/pm-agile/value-stream-management
        required: true
        tier_gate: pro
    outputs:
      - "Weekly demos + burn-down chart"
    decision_gate: "Advance when 3+ consecutive weeks show positive trend."
  - name: "Earned trust check"
    intent: "Reconfirm trust before declaring recovery."
    tasks:
      - "Run a candid trust check with the client"
      - "Document trust signals (renewed scope, references, follow-on work)"
      - "Decide rescue continue, hand back, or sunset"
    methodologies:
      - slug: stakeholder-engagement-advanced
        path: pro/pm/pm-traditional/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
    outputs:
      - "Trust check note + decision"
    decision_gate: "Required: a written trust verdict at week 6."
  - name: "Lessons + handover"
    intent: "Capture the rescue lessons before exiting."
    tasks:
      - "Run a structured lessons-learned with the team"
      - "Write a recovery playbook for the org"
      - "Hand the project back to a steady-state PM"
    methodologies:
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
      - slug: raci-matrix
        path: pro/pm/project-manager/raci-matrix
        required: true
        tier_gate: pro
    outputs:
      - "Lessons-learned doc"
      - "Steady-state handover note"
    decision_gate: "Required: a documented hand-back with steady-state PM named."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content distressed-project-rescue-six-week-turnaround --format md"
  agent:  "faion get-content distressed-project-rescue-six-week-turnaround --format context"
  json:   "faion get-content distressed-project-rescue-six-week-turnaround --format json"

changelog:
