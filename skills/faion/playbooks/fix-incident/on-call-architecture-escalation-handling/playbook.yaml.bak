# =============================================================================
# faion playbook manifest — chunk-06 (role-software-architect)
# =============================================================================

slug: on-call-architecture-escalation-handling
title: "On-call architecture escalation handling"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 3ee0e49e171f06c4

tier_min: geek
complexity: deep
context: [solo, team]
persona: "software architect"
group: role-software-architect

intent: |
  Take an software architect from the trigger condition described in this playbook to the documented outcome, with every decision gate met in writing.

scope: |
  Done = an architecture escalation during an incident is resolved without short-circuiting the IC: architect provides options + trade-offs in writing, IC chooses, decision is logged and links into the postmortem; no irreversible decisions are made on a phone call without a 2-line written summary.

summary: "Done = an architecture escalation during an incident is resolved without short-circuiting the IC: architect provides options + trade-offs in writing, IC chooses, decision is logged and links into the postmortem; no irreversible decisions are made on a phone call without a 2-line written summary."

success_criteria:
  - "On-call architecture escalation handling ships with written success criteria met and evidence attached"
  - "Baseline → post-change metric delta recorded against the relevant quality attribute"
  - "Rollback path rehearsed at least once and documented in the runbook"
  - "Decision doc (continue / iterate / revert) signed off by named owner"

methodology_refs:
  - geek/sdlc-ai/inc-postmortem-auto-draft-no-publish
  - geek/sdlc-ai/inc-read-only-investigation-default
  - pro/dev/software-architect/reliability-architecture
  - solo/dev/software-architect/architecture-decision-records
  - solo/dev/software-architect/trade-off-decision-methods
  - solo/dev/software-architect/trade-off-stakeholder-communication

stages:
  - name: "Frame"
    intent: "Name the problem in writing and set explicit success criteria."
    tasks:
      - "Write a one-paragraph problem statement tied to a quality attribute or user outcome"
      - "List concrete success criteria (measurable, observable, time-bounded)"
      - "Identify the smallest credible scope that still moves the needle"
    methodologies:
      - slug: inc-postmortem-auto-draft-no-publish
        path: geek/sdlc-ai/inc-postmortem-auto-draft-no-publish
        required: true
        tier_gate: geek
    outputs:
      - "Problem brief"
      - "Success-criteria list"
      - "Scope boundary"
    decision_gate: |
      Advance only after a peer can restate the problem in their own words and agree the criteria are testable.
  - name: "Assess"
    intent: "Inventory current state vs target with evidence, not opinion."
    tasks:
      - "Run a structured assessment of the affected system (code, tests, docs, ops surface)"
      - "Capture baseline metrics that the work will need to beat"
      - "List the top 5 risks and one mitigation per risk"
    methodologies:
      - slug: inc-read-only-investigation-default
        path: geek/sdlc-ai/inc-read-only-investigation-default
        required: true
        tier_gate: geek
    outputs:
      - "Current-state inventory"
      - "Baseline metrics"
      - "Risk register"
    decision_gate: |
      Advance only when baselines are recorded and risks have owners.
  - name: "Plan"
    intent: "Decompose into a sequenced backlog with explicit decision points."
    tasks:
      - "Break the work into tasks of ≤1 day each, with dependencies named"
      - "Mark reversible vs irreversible (one-way-door) decisions"
      - "Define rollback / kill conditions for each major step"
    methodologies:
      - slug: reliability-architecture
        path: pro/dev/software-architect/reliability-architecture
        required: true
        tier_gate: pro
    outputs:
      - "Task plan"
      - "Decision log skeleton"
      - "Rollback playbook"
    decision_gate: |
      Advance only when every task has a definition-of-done and the plan fits on one page.
  - name: "Pilot"
    intent: "Prove the approach on a small, reversible slice before committing the full budget."
    tasks:
      - "Pick the lowest-blast-radius slice that exercises the riskiest assumption"
      - "Run the slice end-to-end, including verification and rollback rehearsal"
      - "Write up what changed vs the plan and update the rollback playbook"
    methodologies:
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: solo
    outputs:
      - "Pilot result"
      - "Updated rollback playbook"
    decision_gate: |
      Advance only if the pilot meets its success criteria; otherwise re-plan or kill.
  - name: "Execute"
    intent: "Ship the change behind safe deployment controls."
    tasks:
      - "Implement the plan in small, individually shippable steps"
      - "Keep all changes behind feature flags or branch-by-abstraction where reversible"
      - "Update tests + docs in the same change set, never as a follow-up"
    methodologies:
      - slug: trade-off-decision-methods
        path: solo/dev/software-architect/trade-off-decision-methods
        required: true
        tier_gate: solo
    outputs:
      - "Shipped change set"
      - "Updated tests + docs"
    decision_gate: |
      Advance only when CI is green, the change is observable in staging, and rollback was rehearsed at least once.
  - name: "Verify"
    intent: "Prove the change cleared the success criteria with evidence."
    tasks:
      - "Run targeted tests + smoke on the most-trafficked surfaces"
      - "Compare post-change metrics against the baseline captured earlier"
      - "Capture user / operator feedback within the first 48 hours"
    methodologies:
      - slug: trade-off-stakeholder-communication
        path: solo/dev/software-architect/trade-off-stakeholder-communication
        required: true
        tier_gate: solo
    outputs:
      - "Verification report"
      - "Metric delta vs baseline"
    decision_gate: |
      Advance only when metrics meet the criteria and no regression alerts are open.
  - name: "Roll out"
    intent: "Expand the change from pilot scope to full target audience."
    tasks:
      - "Increase rollout percentage in measured steps with explicit pause points"
      - "Watch SLO / error budgets on each step; halt if any breach"
      - "Communicate progress + rollback option to all affected stakeholders"
    methodologies:
      - slug: inc-postmortem-auto-draft-no-publish
        path: geek/sdlc-ai/inc-postmortem-auto-draft-no-publish
        required: true
        tier_gate: geek
    outputs:
      - "Rollout log"
      - "Stakeholder update"
    decision_gate: |
      Advance only after 100% rollout has been stable for the agreed soak period.
  - name: "Close"
    intent: "Lock in the gain: documentation, learnings, and a single decision artifact."
    tasks:
      - "Write the decision / outcome doc (continue / iterate / revert) with evidence trail"
      - "Update ADRs, runbooks, and pattern memory with what changed"
      - "Schedule the next review checkpoint or archive the workstream"
    methodologies:
      - slug: inc-postmortem-auto-draft-no-publish
        path: geek/sdlc-ai/inc-postmortem-auto-draft-no-publish
        required: true
        tier_gate: geek
    outputs:
      - "Decision doc"
      - "Updated ADR / runbook / memory entry"
    decision_gate: |
      Done when the decision doc is single-link shareable and the team can name the next checkpoint.

common_pitfalls:
  - "Skipping the Frame stage and starting work without written success criteria"
  - "Treating the rollback as a doc, not a rehearsed action"
  - "Cutting the Close / decision-doc stage when the work feels obvious — that is when memory rots fastest"

quality_checklist:
  - "Can a peer restate the problem, criteria, and decision rule without me in the room?"
  - "Are the baseline metrics recorded somewhere I can grep, not just in chat?"
  - "Did we actually rehearse the rollback, or did we just talk about it?"

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content on-call-architecture-escalation-handling --format md"
  agent:  "faion get-content on-call-architecture-escalation-handling --format context"
  json:   "faion get-content on-call-architecture-escalation-handling --format json"

