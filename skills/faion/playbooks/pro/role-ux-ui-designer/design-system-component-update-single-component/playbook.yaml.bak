slug: design-system-component-update-single-component
title: "Design-system component update (single component)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 33d36a8bbcabe4b4

tier: pro
tier_min: pro
group: role-ux-ui-designer
persona: Designer or DS engineer shipping an update to one component
complexity: medium
context: [solo, team]

summary: |
  One component shipped: spec updated, tokens aligned, variants regression-checked, code-connect map refreshed, changelog entry posted.

intent: |
  Stale component -> updated spec + tokens + variants + code-connect + changelog.

scope: |
  Designer or DS engineer ships an update to a single component. Includes spec refresh, token alignment, variant regression check, code-connect refresh, and changelog publication to consumers. Done when consumers have been notified and the new version is on the registry.

success_criteria:
  - "Spec updated and reviewed"
  - "Tokens aligned (no off-token values)"
  - "Variants pass regression check"
  - "Code-connect map refreshed"
  - "Changelog entry posted to consumers"

methodology_refs:
  - faion/knowledge/pro/ux/accessibility-specialist/wcag-22-compliance
  - faion/knowledge/pro/ux/ui-designer/cross-platform-token-distribution
  - faion/knowledge/pro/ux/ui-designer/design-system-success-factors
  - faion/knowledge/pro/ux/ui-designer/semantic-tokens-and-modes
  - faion/knowledge/pro/ux/ui-designer/token-organization
  - faion/knowledge/pro/ux/ui-designer/w3c-design-tokens-standard
  - faion/knowledge/solo/ux/ui-designer/design-tokens-fundamentals

stages:
  - name: "Spec refresh"
    intent: "Update the source of truth."
    tasks:
      - "Rewrite spec to reflect changes"
      - "Document breaking vs additive changes"
      - "Note migration steps"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
      - slug: token-organization
        path: pro/ux/ui-designer/token-organization
        required: true
        tier_gate: pro
    outputs:
      - "Updated component spec"
    decision_gate: |
      Advance only after a peer review.
  - name: "Token alignment"
    intent: "No off-token values escape."
    tasks:
      - "Map every value to a semantic token"
      - "Add new tokens only if necessary, with rationale"
      - "Run token-lint on the component"
    methodologies:
      - slug: semantic-tokens-and-modes
        path: pro/ux/ui-designer/semantic-tokens-and-modes
        required: true
        tier_gate: pro
      - slug: w3c-design-tokens-standard
        path: pro/ux/ui-designer/w3c-design-tokens-standard
        required: true
        tier_gate: pro
      - slug: design-tokens-fundamentals
        path: solo/ux/ui-designer/design-tokens-fundamentals
        required: true
        tier_gate: solo
    outputs:
      - "Token-aligned component"
    decision_gate: |
      Advance only when token-lint passes.
  - name: "Variant regression"
    intent: "Variants stay stable across modes + states."
    tasks:
      - "Run visual regression in Storybook"
      - "Test each variant in light + dark modes"
      - "Run a11y regression on flagship variants"
    methodologies:
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "Regression report"
    decision_gate: |
      Advance only with green regression on flagship variants.
  - name: "Code-connect refresh"
    intent: "Figma <-> code stays mapped."
    tasks:
      - "Update Code Connect mappings"
      - "Validate prop drift between design + code"
      - "Publish updated bindings"
    methodologies:
      - slug: cross-platform-token-distribution
        path: pro/ux/ui-designer/cross-platform-token-distribution
        required: true
        tier_gate: pro
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "Refreshed Code Connect bindings"
    decision_gate: |
      Advance only when bindings validate.
  - name: "Ship + changelog"
    intent: "Consumers know what changed before they hit it."
    tasks:
      - "Cut a version per semver"
      - "Publish changelog entry with migration notes"
      - "Notify consumers in the DS channel"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "New version + changelog entry"
    decision_gate: |
      Done when consumers have acknowledged.

common_pitfalls:
  - "Hidden off-token values -> drift creeps in"
  - "Skipping regression on rare variants -> production breakage"
  - "No changelog -> consumers find out by getting paged"

quality_checklist:
  - "Is token-lint green?"
  - "Did regression pass on every variant?"
  - "Did consumers read the changelog?"

related_playbooks:
  - design-system-v1-to-v2-migration-12-weeks
  - design-debt-remediation-sprint-2-weeks

token_budget_estimate: 3500
cli_invocations:
  human:  "faion get-content design-system-component-update-single-component --format md"
  agent:  "faion get-content design-system-component-update-single-component --format context"
  json:   "faion get-content design-system-component-update-single-component --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
  - methodology_slug: design-system-changelog-template
    expected_tier: pro
    blocks_stage: 5
    note: "Changelog template not yet authored."
  - methodology_slug: breaking-change-deprecation-policy
    expected_tier: pro
    blocks_stage: 1
    note: "Breaking-change deprecation policy not yet authored."
