slug: pivot-from-failed-v1-to-v2
title: "Pivot from failed v1 to v2"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 7a7ea7fdbfcd96c5

tier_min: pro
complexity: deep
context: [solo]
persona_hints: [P1]

intent: |
  v1 is not working: retention flat, growth stalled, founder energy bleeding.

scope: |
  v1 is not working: retention flat, growth stalled, founder energy bleeding. Decide and execute a structured pivot (segment / feature / model / sunset) without burning the brand or the customer trust.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Honest diagnosis"
    intent: "Name what failed and why - no euphemisms."
    tasks:
      - "Compile retention, growth, and energy data"
      - "Interview self + top 3 advisors"
      - "Write a 1-page failure post-mortem"
    methodologies:
      - slug: ops-churn-basics
        path: pro/marketing/growth-marketer/ops-churn-basics
        required: true
        tier_gate: pro
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: pro
    outputs:
      - "Failure post-mortem"
      - "Energy/burnout audit"
      - "Top-3 contributing causes"
    decision_gate: "Advance only with a written cause, not a vibe."
  - name: "Pivot vs quit decision"
    intent: "Use a decision template before the heart picks for you."
    tasks:
      - "Walk the pivot-vs-quit template"
      - "List 3 candidate pivot vectors (segment / feature / model / sunset)"
      - "Score each against runway, energy, and evidence"
    methodologies:
      - slug: retention-metrics
        path: pro/marketing/growth-marketer/retention-metrics
        required: true
        tier_gate: pro
      - slug: product-launch
        path: solo/product/product-manager/product-launch
        required: true
        tier_gate: pro
    outputs:
      - "Decision template filled"
      - "Scored vector table"
      - "Chosen vector OR sunset call"
    decision_gate: "Advance only if one vector has clearly higher score AND positive energy signal."
  - name: "Re-validation interviews"
    intent: "Confirm the new direction with the same rigor as v1."
    tasks:
      - "Run 10 Mom-test interviews in the new niche"
      - "Test the new JTBD framing"
      - "Tag severity + willingness-to-pay"
    methodologies:
      - slug: competitive-intelligence
        path: pro/research/market-researcher/competitive-intelligence
        required: true
        tier_gate: pro
      - slug: spec-writing
        path: solo/product/product-manager/spec-writing
        required: true
        tier_gate: pro
    outputs:
      - "10 interview transcripts"
      - "Validated JTBD v2"
      - "Pricing signal v2"
    decision_gate: "Advance only with >=5/10 strong painpoint matches. Else revisit vector."
  - name: "Customer comms plan"
    intent: "Protect trust with existing v1 customers."
    tasks:
      - "Segment current customers (migrate / refund / sunset)"
      - "Draft difficult-conversation comms per segment"
      - "Schedule the announcement window"
    methodologies:
      - slug: market-analysis
        path: pro/research/market-researcher/market-analysis
        required: true
        tier_gate: pro
      - slug: niche-evaluation
        path: solo/research/market-researcher/niche-evaluation
        required: true
        tier_gate: pro
    outputs:
      - "Customer segmentation"
      - "Comms templates per segment"
      - "Refund/migration policy"
    decision_gate: "Advance only when comms templates are reviewed by one outside reader."
  - name: "Tech-debt audit"
    intent: "Decide what code to keep, refactor, or burn."
    tasks:
      - "Inventory the v1 codebase with ADRs"
      - "Mark each module: reuse / refactor / kill"
      - "Write a migration plan with explicit cuts"
    methodologies:
      - slug: difficult-conversations
        path: solo/comms/communicator/difficult-conversations
        required: true
        tier_gate: pro
      - slug: jobs-to-be-done
        path: solo/research/researcher/jobs-to-be-done
        required: true
        tier_gate: pro
    outputs:
      - "Code inventory"
      - "Migration plan"
      - "Updated ADRs"
    decision_gate: "Advance only when reuse % is clearly justified (or honestly accept a rewrite)."
  - name: "v2 spec + scope cut"
    intent: "Write a deliberately small v2 spec."
    tasks:
      - "Write a 1-page v2 spec"
      - "List explicit non-goals"
      - "Map acceptance criteria per feature"
    methodologies:
      - slug: stakeholder-communication
        path: solo/comms/communicator/stakeholder-communication
        required: true
        tier_gate: pro
      - slug: pain-point-research
        path: solo/research/researcher/pain-point-research
        required: true
        tier_gate: pro
    outputs:
      - "spec-v2.md"
      - "Non-goals list"
      - "Acceptance criteria table"
    decision_gate: "Advance only if v2 spec is smaller than v1 spec at equivalent stage."
  - name: "Launch v2 quietly"
    intent: "Ship to a small, friendly audience first."
    tasks:
      - "Migrate or refund v1 users on schedule"
      - "Soft-launch v2 to design partners"
      - "Hold off a public re-launch until retention curve forms"
    methodologies:
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: pro
      - slug: mistake-memory
        path: solo/sdd/sdd/mistake-memory
        required: true
        tier_gate: pro
    outputs:
      - "Migration log"
      - "v2 soft-launch announcement"
      - "Early retention chart"
    decision_gate: "Advance when first cohort hits week-4 retention threshold."
  - name: "Brand-trust audit"
    intent: "Check trust signals before going wide."
    tasks:
      - "Pull sentiment from socials, reviews, and inbox"
      - "Surface any open trust debt from v1 sunset"
      - "Address each item publicly or privately"
    methodologies:
      - slug: technical-debt
        path: solo/dev/software-developer/technical-debt
        required: true
        tier_gate: pro
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: pro
    outputs:
      - "Trust audit report"
      - "Resolved-issue list"
      - "Public follow-up post (if needed)"
    decision_gate: "Advance only when no open public trust debt remains."
  - name: "Pattern + mistake memory"
    intent: "Lock the lesson so v2 does not repeat v1."
    tasks:
      - "Write a reflexion doc"
      - "Update pattern memory with what saved time"
      - "Update mistake memory with traps that bled v1"
    methodologies:
      - slug: growth-email-marketing
        path: solo/marketing/content-marketer/growth-email-marketing
        required: true
        tier_gate: pro
      - slug: writing-specifications
        path: solo/sdd/sdd/writing-specifications
        required: true
        tier_gate: pro
    outputs:
      - "Reflexion doc"
      - "Pattern memory delta"
      - "Mistake memory delta"
    decision_gate: "Cycle closes when memories are committed and reviewed."

token_budget_estimate: 22000

cli_invocations:
  human:  "faion get-content pivot-from-failed-v1-to-v2 --format md"
  agent:  "faion get-content pivot-from-failed-v1-to-v2 --format context"
  json:   "faion get-content pivot-from-failed-v1-to-v2 --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
