slug: project-kickoff-to-handover-typical-6-12-week-engagement
title: "Project kickoff to handover (typical 6-12 week engagement)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 90952d3b7115c6e2

tier_min: pro
complexity: deep
context: [solo]
persona_hints: [P3]

intent: |
  From signed SOW to client-accepted final deliverable, with the freelancer running solo across discovery, build, and ship — no scope creep, weekly invoices paid on time, written handover + warranty period defined.

scope: |
  From signed SOW to client-accepted final deliverable, with the freelancer running solo across discovery, build, and ship — no scope creep, weekly invoices paid on time, written handover + warranty period defined.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Kickoff + stakeholder map"
    intent: "Set the working contract on day one."
    tasks:
      - "Run a 60-minute kickoff with all stakeholders"
      - "Map decision-makers and reviewers"
      - "Lock comms channels + cadence"
    methodologies:
      - slug: acceptance-criteria
        path: pro/ba/business-analyst/acceptance-criteria
        required: true
        tier_gate: pro
      - slug: ops-customer-success-basics
        path: pro/marketing/gtm-strategist/ops-customer-success-basics
        required: true
        tier_gate: pro
    outputs:
      - "Kickoff notes"
      - "Stakeholder map"
      - "Comms cadence"
    decision_gate: "Advance only when stakeholder map is signed off."
  - name: "Discovery + requirements"
    intent: "Capture requirements properly, no vibes."
    tasks:
      - "Run elicitation interviews + workshops"
      - "Document requirements with traceability"
      - "Define acceptance criteria per requirement"
    methodologies:
      - slug: elicitation-techniques
        path: pro/ba/business-analyst/elicitation-techniques
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance-checklist
        path: pro/marketing/gtm-strategist/ops-legal-compliance-checklist
        required: true
        tier_gate: pro
    outputs:
      - "Requirements doc"
      - "Traceability matrix"
      - "Acceptance criteria"
    decision_gate: "Advance only when client signs the requirements doc."
  - name: "Architecture + risks"
    intent: "Pick the tech path and name the risks."
    tasks:
      - "Map quality attributes (perf, security, scale)"
      - "Choose architecture and document decisions"
      - "Surface top-5 risks with mitigations"
    methodologies:
      - slug: requirements-documentation
        path: pro/ba/business-analyst/requirements-documentation
        required: true
        tier_gate: pro
      - slug: stakeholder-communication
        path: solo/comms/communicator/stakeholder-communication
        required: true
        tier_gate: pro
    outputs:
      - "Architecture diagram"
      - "ADRs"
      - "Risk register"
    decision_gate: "Advance only when risks have named mitigations."
  - name: "Build sprints"
    intent: "Ship increments behind acceptance criteria."
    tasks:
      - "Run 1-week sprints with weekly demos"
      - "Maintain CI/CD with health checks + logging"
      - "Update the traceability matrix per sprint"
    methodologies:
      - slug: requirements-traceability
        path: pro/ba/business-analyst/requirements-traceability
        required: true
        tier_gate: pro
      - slug: api-documentation
        path: solo/dev/api-developer/api-documentation
        required: true
        tier_gate: pro
    outputs:
      - "Sprint demos"
      - "CI/CD pipeline"
      - "Updated matrix"
    decision_gate: "Advance only when every sprint ends with a working demo."
  - name: "Scope-creep firewall"
    intent: "Block creep before it ruins the project."
    tasks:
      - "Log every change request"
      - "Score impact on scope + timeline"
      - "Either accept with a change order OR defer"
    methodologies:
      - slug: requirements-validation
        path: pro/ba/business-analyst/requirements-validation
        required: true
        tier_gate: pro
      - slug: framework-decomposition-patterns
        path: solo/dev/code-quality/framework-decomposition-patterns
        required: true
        tier_gate: pro
    outputs:
      - "Change-request log"
      - "Change-order docs"
      - "Defer list"
    decision_gate: "Advance only when no change is silently absorbed."
  - name: "Weekly invoicing + cashflow"
    intent: "Money lands on time, every week."
    tasks:
      - "Send invoices on the agreed cadence"
      - "Chase any overdue within 24h"
      - "Reconcile against escrow / milestones"
    methodologies:
      - slug: stakeholder-analysis
        path: pro/ba/business-analyst/stakeholder-analysis
        required: true
        tier_gate: pro
      - slug: testing-developer
        path: solo/dev/testing-developer
        required: true
        tier_gate: pro
    outputs:
      - "Invoice log"
      - "Chase log"
      - "Reconciliation note"
    decision_gate: "Advance only when no invoice is overdue by >7 days."
  - name: "UAT + acceptance"
    intent: "Client validates against acceptance criteria."
    tasks:
      - "Run UAT sessions with the client"
      - "Resolve UAT findings in priority order"
      - "Get written acceptance"
    methodologies:
      - slug: quality-attributes-analysis
        path: pro/dev/software-architect/quality-attributes-analysis
        required: true
        tier_gate: pro
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: pro
    outputs:
      - "UAT log"
      - "Resolution PRs"
      - "Acceptance email"
    decision_gate: "Advance only with written client acceptance."
  - name: "Handover pack"
    intent: "Leave behind a project that runs without you."
    tasks:
      - "Compile the handover package (docs, runbooks, credentials)"
      - "Train the client team"
      - "Define the warranty period + scope"
    methodologies:
      - slug: api-monitoring-health-checks
        path: pro/dev/software-developer/api-monitoring-health-checks
        required: true
        tier_gate: pro
      - slug: linear-issue-tracking
        path: solo/pm/pm-agile/linear-issue-tracking
        required: true
        tier_gate: pro
    outputs:
      - "Handover package"
      - "Training session log"
      - "Warranty SOP"
    decision_gate: "Advance only when client team can operate without you."
  - name: "Testimonial + referral ask"
    intent: "Convert delivery into the next pipeline."
    tasks:
      - "Capture a written testimonial"
      - "Ask for a referral to 2 similar buyers"
      - "Close the engagement formally"
    methodologies:
      - slug: api-monitoring-logging
        path: pro/dev/software-developer/api-monitoring-logging
        required: true
        tier_gate: pro
      - slug: notion-pm
        path: solo/pm/pm-agile/notion-pm
        required: true
        tier_gate: pro
    outputs:
      - "Testimonial captured"
      - "Referral list"
      - "Engagement closed"
    decision_gate: "Cycle closes when testimonial + referrals are committed."

token_budget_estimate: 22000

cli_invocations:
  human:  "faion get-content project-kickoff-to-handover-typical-6-12-week-engagement --format md"
  agent:  "faion get-content project-kickoff-to-handover-typical-6-12-week-engagement --format context"
  json:   "faion get-content project-kickoff-to-handover-typical-6-12-week-engagement --format json"

changelog:
