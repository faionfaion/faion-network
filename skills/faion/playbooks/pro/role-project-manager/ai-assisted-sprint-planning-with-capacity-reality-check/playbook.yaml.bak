slug: ai-assisted-sprint-planning-with-capacity-reality-check
title: "AI-assisted sprint planning with capacity reality-check"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 460bb0db9d60a7cf

tier: pro
tier_min: pro
group: role-project-manager
persona: PM/Scrum Master running sprint planning with AI assistance
complexity: medium
context: [solo, team]

summary: |
  Each sprint produces a committable plan the team actually finishes, based on observed capacity, not nominal.

intent: |
  Sprint planning chaos -> committable plan with >=0.85 commitment-to-completion ratio over rolling 4 sprints.

scope: |
  PM runs sprint planning across an Agile team. This playbook embeds an AI assistant in the loop: pre-grooming readiness check, observed-capacity calculation, must-vs-stretch split, and predictive risk callouts. Done when the rolling 4-sprint commitment-to-completion ratio holds >=0.85.

success_criteria:
  - "Definition-of-Ready check completed for every committed item"
  - "Observed (not nominal) capacity used in commitment math"
  - "Must vs stretch split visible in the plan"
  - "Rolling 4-sprint commitment-to-completion ratio >=0.85"

methodology_refs:
  - faion/knowledge/geek/pm/pm-agile/ai-in-project-management
  - faion/knowledge/pro/pm/pm-agile/scrum-ceremonies
  - faion/knowledge/pro/pm/pm-traditional/resource-management
  - faion/knowledge/pro/pm/pm-traditional/scope-management
  - faion/knowledge/pro/pm/project-manager/agile-ceremonies-setup
  - faion/knowledge/pro/pm/project-manager/predictive-analytics-pm

stages:
  - name: "Pre-flight readiness"
    intent: "No item enters planning if it is not Ready."
    tasks:
      - "Run an automated DoR check on candidate items"
      - "Flag items missing acceptance criteria or unsized"
      - "Push unready items back to refinement"
    methodologies:
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
      - slug: agile-ceremonies-setup
        path: pro/pm/project-manager/agile-ceremonies-setup
        required: true
        tier_gate: pro
    outputs:
      - "List of Ready items only, with confidence scores"
    decision_gate: |
      Advance only with all candidate items marked Ready.
  - name: "Observed capacity"
    intent: "Plan against the team you actually have, not the team on paper."
    tasks:
      - "Calculate effective capacity using last 4 sprints' completion ratio"
      - "Apply known leave / on-call deductions"
      - "Reserve buffer for unplanned work (15-20%)"
    methodologies:
      - slug: resource-management
        path: pro/pm/pm-traditional/resource-management
        required: true
        tier_gate: pro
      - slug: predictive-analytics-pm
        path: pro/pm/project-manager/predictive-analytics-pm
        required: true
        tier_gate: pro
    outputs:
      - "Effective capacity number for the sprint"
    decision_gate: |
      Advance with one numeric capacity figure everyone agreed to.
  - name: "Must vs stretch"
    intent: "Separate what we will finish from what we hope to."
    tasks:
      - "Define the Must set that fits within 70-80% of capacity"
      - "Define a Stretch set for the remaining 20-30%"
      - "Mark each item must/stretch explicitly in the tracker"
    methodologies:
      - slug: scope-management
        path: pro/pm/pm-traditional/scope-management
        required: true
        tier_gate: pro
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
    outputs:
      - "Plan with Must/Stretch tags"
    decision_gate: |
      Advance when the team commits to Must out loud.
  - name: "AI risk callouts"
    intent: "Surface predictable failure modes before commit."
    tasks:
      - "Run AI risk scan over commit set"
      - "Flag dependency conflicts, sizing outliers, and capacity hotspots"
      - "Drop or de-risk items the team cannot defend"
    methodologies:
      - slug: ai-in-project-management
        path: geek/pm/pm-agile/ai-in-project-management
        required: true
        tier_gate: geek
      - slug: predictive-analytics-pm
        path: pro/pm/project-manager/predictive-analytics-pm
        required: true
        tier_gate: pro
    outputs:
      - "Risk-callout list + adjustments"
    decision_gate: |
      Advance only when all high-severity risks are accepted or mitigated.
  - name: "Commit + log"
    intent: "Record commitments so retros can compare reality."
    tasks:
      - "Lock the sprint commit in the tracker"
      - "Snapshot the Must + Stretch sets"
      - "Append commit set to the predictive analytics log"
    methodologies:
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
      - slug: predictive-analytics-pm
        path: pro/pm/project-manager/predictive-analytics-pm
        required: true
        tier_gate: pro
    outputs:
      - "Sprint commitment locked + logged"
    decision_gate: |
      Done when commitment is locked and the log is updated.

common_pitfalls:
  - "Using nominal capacity from FTE math -> chronic over-commit"
  - "Letting unready items into planning to fill slots -> mid-sprint thrash"
  - "Skipping must/stretch split -> retro cannot tell what counts as failure"

quality_checklist:
  - "Did every committed item pass DoR?"
  - "Did we plan against observed, not nominal, capacity?"
  - "Is the commitment-to-completion ratio trending toward 0.85?"

related_playbooks:
  - async-cross-timezone-delivery-cadence-p4-outsource
  - run-a-30-minute-resource-allocation-review

token_budget_estimate: 5500
cli_invocations:
  human:  "faion get-content ai-assisted-sprint-planning-with-capacity-reality-check --format md"
  agent:  "faion get-content ai-assisted-sprint-planning-with-capacity-reality-check --format context"
  json:   "faion get-content ai-assisted-sprint-planning-with-capacity-reality-check --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

