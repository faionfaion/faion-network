# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #6
# =============================================================================

slug: year-end-tax-legal-cashflow-close
title: "Year-end tax, legal, and cash-flow close"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: a471b223cb95b2ad

tier_min: pro
complexity: medium
context: [solo]
persona_hints: [P3]

intent: |
  Across 4-6 weeks at year-end: close books, file taxes / VAT correctly across jurisdictions, refresh contracts + insurance, and publish a yearly retrospective that doubles as a marketing asset.

scope: |
  Across 4-6 weeks at year-end: close books, file taxes / VAT correctly across jurisdictions, refresh contracts + insurance, and publish a yearly retrospective that doubles as a marketing asset.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Close books stage complete: Reconciled P&L"
  - "Taxes + VAT stage complete: Tax computation worksheet"
  - "Contracts + insurance stage complete: Updated MSAs"
  - "Year-in-review as marketing stage complete: Published retrospective post"

stages:
  - name: "Close books"
    intent: "Reconcile every invoice + expense for the calendar year."
    tasks:
      - "Pull bank + Stripe + invoice ledger"
      - "Reconcile against P&L"
      - "Categorise expenses for tax"
    methodologies:
      - slug: data-analysis
        path: pro/ba/business-analyst/data-analysis
        required: true
        tier_gate: pro
      - slug: ops-financial-basics
        path: pro/marketing/gtm-strategist/ops-financial-basics
        required: true
        tier_gate: pro
      - slug: ops-financial-planning
        path: solo/marketing/growth-marketer/ops-financial-planning
        required: true
        tier_gate: solo
    outputs:
      - "Reconciled P&L"
      - "Expense categories spreadsheet"
    decision_gate: |
      Advance only after books reconcile to the cent.
  - name: "Taxes + VAT"
    intent: "File correctly across every jurisdiction with no surprises."
    tasks:
      - "Confirm tax residency + obligations"
      - "Compute estimated tax + VAT/GST"
      - "Engage accountant for review"
    methodologies:
      - slug: ops-tax-basics
        path: pro/marketing/gtm-strategist/ops-tax-basics
        required: true
        tier_gate: pro
      - slug: ops-tax-compliance
        path: pro/marketing/gtm-strategist/ops-tax-compliance
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance
        path: pro/marketing/gtm-strategist/ops-legal-compliance
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance-checklist
        path: pro/marketing/gtm-strategist/ops-legal-compliance-checklist
        required: true
        tier_gate: pro
      - slug: cross-border-tax-cheatsheet
        path: pro/_gap/cross-border-tax-cheatsheet
        required: true
        tier_gate: pro
    outputs:
      - "Tax computation worksheet"
      - "Accountant review note"
      - "Filings submitted"
    decision_gate: |
      Advance only after filings are submitted, not just drafted.
  - name: "Contracts + insurance"
    intent: "Refresh client contracts + liability/E&O insurance for the new year."
    tasks:
      - "Audit each active contract for outdated terms"
      - "Renew or shop insurance policies"
      - "Send revised MSA to long-term clients"
    methodologies:
      - slug: ops-legal-basics
        path: pro/marketing/gtm-strategist/ops-legal-basics
        required: true
        tier_gate: pro
      - slug: ops-contractor-management
        path: pro/marketing/gtm-strategist/ops-contractor-management
        required: true
        tier_gate: pro
      - slug: ops-partnership-strategy
        path: pro/marketing/gtm-strategist/ops-partnership-strategy
        required: true
        tier_gate: pro
      - slug: freelance-insurance-buyers-guide
        path: pro/_gap/freelance-insurance-buyers-guide
        required: true
        tier_gate: pro
      - slug: freelancer-year-end-checklist
        path: pro/_gap/freelancer-year-end-checklist
        required: true
        tier_gate: pro
    outputs:
      - "Updated MSAs"
      - "Renewed insurance"
      - "Compliance checklist signed"
    decision_gate: |
      Advance once all contracts are current. No expired terms carrying into new year.
  - name: "Year-in-review as marketing"
    intent: "Publish a transparent annual retrospective; turn close into a marketing asset."
    tasks:
      - "Draft retrospective: revenue, lessons, projects shipped"
      - "Edit for narrative + share-worthy hooks"
      - "Publish on blog + newsletter + LinkedIn"
    methodologies:
      - slug: ops-annual-planning-templates
        path: pro/marketing/gtm-strategist/ops-annual-planning-templates
        required: true
        tier_gate: pro
      - slug: portfolio-strategy
        path: pro/product/product-manager/portfolio-strategy
        required: true
        tier_gate: pro
      - slug: okr-setting
        path: pro/product/product-planning/okr-setting
        required: true
        tier_gate: pro
      - slug: business-storytelling
        path: solo/marketing/content-marketer/business-storytelling
        required: true
        tier_gate: solo
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
      - slug: growth-indiehackers-strategy
        path: solo/marketing/growth-marketer/growth-indiehackers-strategy
        required: true
        tier_gate: solo
      - slug: year-in-review-as-marketing
        path: pro/_gap/year-in-review-as-marketing
        required: true
        tier_gate: pro
    outputs:
      - "Published retrospective post"
      - "Newsletter sent"
      - "Social distribution"
    decision_gate: |
      Required artifact: published post. Internal-only retros don't count.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  []

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content year-end-tax-legal-cashflow-close --format md"
  agent:  "faion get-content year-end-tax-legal-cashflow-close --format context"
  json:   "faion get-content year-end-tax-legal-cashflow-close --format json"

