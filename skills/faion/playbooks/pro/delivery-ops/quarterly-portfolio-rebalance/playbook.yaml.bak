# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #5
# =============================================================================

slug: quarterly-portfolio-rebalance
title: "Quarterly portfolio rebalance (cash, clients, capacity)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 71285efadf6a1bda

tier_min: pro
complexity: medium
context: [solo]
persona_hints: [P3]

intent: |
  End of every quarter: drop the worst client, raise rates on the rest, fill the freed slot with a higher-rate engagement, and lock the next quarter's revenue target and capacity allocation.

scope: |
  End of every quarter: drop the worst client, raise rates on the rest, fill the freed slot with a higher-rate engagement, and lock the next quarter's revenue target and capacity allocation.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Audit current portfolio stage complete: Client scorecard"
  - "Drop & raise stage complete: Drop letter sent"
  - "Fill capacity stage complete: Reactivation outreach sent"
  - "Lock next quarter stage complete: Q+1 plan doc"

stages:
  - name: "Audit current portfolio"
    intent: "Score every active client on rate, stress, growth, strategic value."
    tasks:
      - "Pull client roster + last-quarter $/hour realized"
      - "Score each on 4 axes"
      - "Flag bottom-quartile clients"
    methodologies:
      - slug: decision-analysis
        path: pro/ba/business-analyst/decision-analysis
        required: true
        tier_gate: pro
      - slug: ops-customer-success-basics
        path: pro/marketing/gtm-strategist/ops-customer-success-basics
        required: true
        tier_gate: pro
      - slug: ops-customer-success-metrics
        path: pro/marketing/gtm-strategist/ops-customer-success-metrics
        required: true
        tier_gate: pro
      - slug: ops-financial-basics
        path: pro/marketing/gtm-strategist/ops-financial-basics
        required: true
        tier_gate: pro
      - slug: portfolio-strategy
        path: pro/product/product-manager/portfolio-strategy
        required: true
        tier_gate: pro
      - slug: freelancer-client-scorecard
        path: pro/_gap/freelancer-client-scorecard
        required: true
        tier_gate: pro
    outputs:
      - "Client scorecard"
      - "Bottom-quartile flag list"
    decision_gate: |
      Advance only with a written ranked list. No subjective vibes.
  - name: "Drop & raise"
    intent: "Drop the worst client; raise rates on the rest."
    tasks:
      - "Write a graceful end-of-engagement note to bottom client"
      - "Draft personalised rate-rise notes to the rest"
      - "Schedule the conversations within one week"
    methodologies:
      - slug: ops-contractor-basics
        path: pro/marketing/gtm-strategist/ops-contractor-basics
        required: true
        tier_gate: pro
      - slug: ops-contractor-management
        path: pro/marketing/gtm-strategist/ops-contractor-management
        required: true
        tier_gate: pro
      - slug: difficult-conversations
        path: solo/comms/communicator/difficult-conversations
        required: true
        tier_gate: solo
      - slug: negotiation
        path: solo/comms/communicator/negotiation
        required: true
        tier_gate: solo
      - slug: ops-pricing-strategy
        path: solo/marketing/growth-marketer/ops-pricing-strategy
        required: true
        tier_gate: solo
      - slug: rate-increase-notice-template
        path: pro/_gap/rate-increase-notice-template
        required: true
        tier_gate: pro
    outputs:
      - "Drop letter sent"
      - "Rate-rise notes drafted"
      - "Calendar invites set"
    decision_gate: |
      Required: at least one client dropped + one rate-rise sent. No exceptions.
  - name: "Fill capacity"
    intent: "Refill the freed slot at a higher rate."
    tasks:
      - "Reactivate dormant warm leads"
      - "Publish a 'capacity opens X date' post"
      - "Run targeted outreach to upper-band prospects"
    methodologies:
      - slug: funnel-tactics-basics
        path: pro/marketing/conversion-optimizer/funnel-tactics-basics
        required: true
        tier_gate: pro
      - slug: ops-upselling-cross-selling
        path: pro/marketing/gtm-strategist/ops-upselling-cross-selling
        required: true
        tier_gate: pro
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: growth-cold-outreach
        path: solo/marketing/growth-marketer/growth-cold-outreach
        required: true
        tier_gate: solo
      - slug: dormant-lead-reactivation
        path: pro/_gap/dormant-lead-reactivation
        required: true
        tier_gate: pro
    outputs:
      - "Reactivation outreach sent"
      - "Public capacity announcement"
      - "1+ new engagement booked"
    decision_gate: |
      Advance once freed capacity is booked at ≥ new-rate-floor. Stay if booking at old rate.
  - name: "Lock next quarter"
    intent: "Set explicit revenue target + capacity allocation for next 90 days."
    tasks:
      - "Write Q+1 revenue target with realistic floor + stretch"
      - "Allocate weekly hours across delivery / sales / growth / rest"
      - "Set check-in dates"
    methodologies:
      - slug: ops-annual-planning-process
        path: pro/marketing/gtm-strategist/ops-annual-planning-process
        required: true
        tier_gate: pro
      - slug: ops-tax-basics
        path: pro/marketing/gtm-strategist/ops-tax-basics
        required: true
        tier_gate: pro
      - slug: ops-tax-compliance
        path: pro/marketing/gtm-strategist/ops-tax-compliance
        required: true
        tier_gate: pro
      - slug: ops-legal-basics
        path: pro/marketing/gtm-strategist/ops-legal-basics
        required: true
        tier_gate: pro
      - slug: okr-setting
        path: pro/product/product-planning/okr-setting
        required: true
        tier_gate: pro
      - slug: ops-financial-planning
        path: solo/marketing/growth-marketer/ops-financial-planning
        required: true
        tier_gate: solo
      - slug: freelance-capacity-model
        path: pro/_gap/freelance-capacity-model
        required: true
        tier_gate: pro
    outputs:
      - "Q+1 plan doc"
      - "Capacity allocation table"
    decision_gate: |
      Quarter closes only when plan is written. Verbal intent doesn't count.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  []

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content quarterly-portfolio-rebalance --format md"
  agent:  "faion get-content quarterly-portfolio-rebalance --format context"
  json:   "faion get-content quarterly-portfolio-rebalance --format json"

