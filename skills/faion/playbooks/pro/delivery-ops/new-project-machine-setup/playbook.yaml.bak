# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #15
# =============================================================================

slug: new-project-machine-setup
title: "New-project machine setup (laptop + desktop)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: ffa4dc91a177fe0b

tier_min: pro
complexity: medium
context: [outsource, team]
persona_hints: [P4]

intent: |
  Multi-machine senior gets a new engagement → both machines productive on client stack within a half-day, no credential leakage between engagements.

scope: |
  Half-day setup ceremony when a new outsource engagement starts. Output: laptop + desktop (+ optionally a client-issued VDI) productive on the client stack, with isolated credentials per engagement and dotfiles synced. Avoids credential mixing between concurrent engagements.

non_goals:
  - "Choosing the stack — client mandate"
  - "Provisioning new hardware — uses what you own"
  - "VPN policy debate — work within what client allows"

prerequisites:
  - "Client stack identified (language, package manager, IDE)"
  - "Credential vault tooling in place (1Password, Bitwarden, etc.)"
  - "Dotfiles repo exists"

success_criteria:
  - "Laptop + desktop both build the client repo green"
  - "Credentials isolated per engagement (no cross-leak)"
  - "VDI decision documented (use vs not)"
  - "Dotfiles synced between machines"
  - "30-day onboarding rituals scheduled"

stages:
  - name: "Stack provision"
    intent: "Install the language + package manager the client demands."
    tasks:
      - "Read client language/framework guide"
      - "Install per the language-framework-guide methodology"
      - "Set up Python via Poetry if applicable"
      - "Verify on both laptop and desktop"
    methodologies:
      - slug: language-framework-guide
        path: free/dev/software-developer/language-framework-guide
        required: true
        tier_gate: free
      - slug: python-poetry-setup
        path: free/dev/software-developer/python-poetry-setup
        required: true
        tier_gate: free
    outputs:
      - "Stack installed both machines"
      - "Hello-world build green"
    decision_gate: |
      Advance only when both machines build the client hello-world.
  - name: "Credential isolation"
    intent: "Stop one client's keys leaking into another's repo."
    tasks:
      - "Adopt per-client credential isolation pattern"
      - "Use trunk-based branching with branch-by-abstraction where applicable"
      - "Document onboarding rituals for new credential rotation"
      - "Decide VDI vs BYOD per VDI-vs-BYOD matrix"
    methodologies:
      - slug: onboarding-30-day
        path: pro/comms/hr-recruiter/onboarding-30-day
        required: true
        tier_gate: pro
      - slug: trunk-based-branch-by-abstraction
        path: solo/dev/automation-tooling/trunk-based-branch-by-abstraction
        required: true
        tier_gate: solo
      - slug: per-client-credential-isolation-pattern
        path: pro/_gap/per-client-credential-isolation-pattern
        required: true
        tier_gate: pro
      - slug: vdi-vs-byod-decision-matrix
        path: pro/_gap/vdi-vs-byod-decision-matrix
        required: true
        tier_gate: pro
    outputs:
      - "Per-client vault entries"
      - "VDI decision logged"
    decision_gate: |
      Advance only when credentials cannot cross between engagements.
  - name: "Sync + bootstrap"
    intent: "Make the second machine identical to the first."
    tasks:
      - "Adopt dotfiles-management workflow"
      - "Bootstrap second machine from dotfiles"
      - "Adopt living-documentation for engagement-specific tooling"
      - "Document the bootstrap script for next engagement"
    methodologies:
      - slug: dotfiles-management
        path: solo/infra/server-craft/dotfiles-management
        required: true
        tier_gate: solo
      - slug: living-documentation
        path: solo/sdd/sdd/living-documentation
        required: true
        tier_gate: solo
      - slug: multi-machine-outsource-dev-env-bootstrap
        path: pro/_gap/multi-machine-outsource-dev-env-bootstrap
        required: true
        tier_gate: pro
    outputs:
      - "Dotfiles bootstrap script"
      - "Both machines synced"
      - "Engagement-specific tooling doc"
    decision_gate: |
      Done when both machines pass the same build + lint.

common_pitfalls:
  - "Using global credentials by accident — breaks isolation"
  - "Skipping dotfiles sync — second machine drifts in week 2"
  - "Treating VDI/BYOD as a personal preference — it's a security policy decision"

quality_checklist:
  - "Could I onboard a third machine in half the time using my doc?"
  - "Did I isolate every credential per engagement?"
  - "Did I match the client stack exactly, not approximately?"

related_playbooks:
  - foreign-client-engagement-bootstrap
  - foreign-client-project-kickoff

token_budget_estimate: 8000
cli_invocations:
  human:  "faion get-content new-project-machine-setup --format md"
  agent:  "faion get-content new-project-machine-setup --format context"
  json:   "faion get-content new-project-machine-setup --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, atomic angle"

gaps:
