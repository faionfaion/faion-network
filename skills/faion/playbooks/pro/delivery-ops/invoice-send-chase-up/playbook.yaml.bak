# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #14
# =============================================================================

slug: invoice-send-chase-up
title: "Invoice send + chase-up"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: b8c92a7a125e2311

tier_min: pro
complexity: medium
context: [solo]
persona_hints: [P3]

intent: |
  Monthly invoice run. Done = invoices out by 1st, payment received by 15th, late ones escalated by 30th without burning the relationship.

scope: |
  Monthly invoice run. Done = invoices out by 1st, payment received by 15th, late ones escalated by 30th without burning the relationship.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Send stage complete: Invoices sent log"
  - "Track + nudge stage complete: Chase-up log"
  - "Escalate stage complete: Late fee invoice"

stages:
  - name: "Send"
    intent: "Invoices out by the 1st of the month."
    tasks:
      - "Generate invoices from time tracker / milestones"
      - "Verify VAT / tax fields"
      - "Send via preferred channel"
    methodologies:
      - slug: ops-financial-basics
        path: pro/marketing/gtm-strategist/ops-financial-basics
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance
        path: pro/marketing/gtm-strategist/ops-legal-compliance
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance-checklist
        path: pro/marketing/gtm-strategist/ops-legal-compliance-checklist
        required: true
        tier_gate: pro
      - slug: ops-tax-basics
        path: pro/marketing/gtm-strategist/ops-tax-basics
        required: true
        tier_gate: pro
    outputs:
      - "Invoices sent log"
    decision_gate: |
      Advance only when all active clients invoiced by EOD on the 1st.
  - name: "Track + nudge"
    intent: "Friendly day-7 nudge; firm day-15 reminder."
    tasks:
      - "Set day-7 + day-15 reminders per invoice"
      - "Send polite chase-up on day-7"
      - "Send firmer reminder on day-15"
    methodologies:
      - slug: difficult-conversations
        path: solo/comms/communicator/difficult-conversations
        required: true
        tier_gate: solo
      - slug: freelancer-payment-chase-script-library
        path: pro/_gap/freelancer-payment-chase-script-library
        required: true
        tier_gate: pro
    outputs:
      - "Chase-up log"
    decision_gate: |
      Advance once payment received OR escalation triggered.
  - name: "Escalate"
    intent: "Day-30 escalation without burning the relationship."
    tasks:
      - "Apply late fee per contract"
      - "Pause new work until paid (per clause)"
      - "Log incident in client scorecard"
    methodologies:
      - slug: lessons-learned
        path: pro/pm/project-manager/lessons-learned
        required: true
        tier_gate: pro
      - slug: negotiation
        path: solo/comms/communicator/negotiation
        required: true
        tier_gate: solo
      - slug: solo-late-fee-and-pause-clause-template
        path: pro/_gap/solo-late-fee-and-pause-clause-template
        required: true
        tier_gate: pro
    outputs:
      - "Late fee invoice"
      - "Pause notice"
      - "Lesson logged"
    decision_gate: |
      Escalation closes only when paid OR engagement formally suspended.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  []

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content invoice-send-chase-up --format md"
  agent:  "faion get-content invoice-send-chase-up --format context"
  json:   "faion get-content invoice-send-chase-up --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P3 technical-freelancer persona, atomic angle"

gaps:
  - methodology_slug: freelancer-payment-chase-script-library
    expected_tier: pro
    blocks_stage: 2
    note: "Stage 2 (Track + nudge) references this; no methodology exists yet."
  - methodology_slug: solo-late-fee-and-pause-clause-template
    expected_tier: pro
    blocks_stage: 3
    note: "Stage 3 (Escalate) references this; no methodology exists yet."
