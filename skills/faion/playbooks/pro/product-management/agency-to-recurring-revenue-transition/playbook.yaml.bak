# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: agency-to-recurring-revenue-transition
title: "Agency-to-recurring-revenue transition (6 months)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: e219f123bca64c33

tier_min: pro
complexity: deep
context: [solo, team]
persona_hints: [P5]

intent: |
  Project-heavy revenue mix to at least 50% recurring revenue and 40% less founder delivery time in 6 months.

scope: |
  Move the agency from majority project-based revenue to majority retainer/productized recurring revenue. Outcome: at least 50% MRR-style recurring by month 6, founder time spent on delivery cut by 40%, customer concentration at or below 30% per logo. Exit artifact: revenue-mix audit + transition decision pack.

non_goals:
  - "Spinning up a SaaS product - separate playbook"
  - "Hiring full-time team to scale projects - out of scope"

prerequisites:
  - "Steady project revenue across 12+ months"
  - "At least 2 recurring patterns identified in past work"

success_criteria:
  - "Revenue-mix audit complete (project vs retainer vs productized)"
  - "2 productized offers live with intake + delivery SOPs"
  - "50%+ recurring revenue by month 6"
  - "Founder delivery hours cut by 40%+"
  - "Customer concentration at or below 30% per logo"
  - "Annual plan refreshed against new mix"

stages:
  - name: "Audit the mix"
    intent: "Honest revenue + time + risk view today."
    tasks:
      - "Tag last 12 months revenue by type"
      - "Map founder hours per revenue line"
      - "Score customer concentration risk"
    methodologies:
      - slug: aarrr-pirate-metrics
        path: pro/marketing/growth-marketer/aarrr-pirate-metrics
        required: true
        tier_gate: pro
      - slug: cohort-implementation
        path: pro/marketing/growth-marketer/cohort-implementation
        required: true
        tier_gate: pro
      - slug: ops-metrics-basics
        path: pro/marketing/growth-marketer/ops-metrics-basics
        required: true
        tier_gate: pro
      - slug: ops-financial-basics
        path: pro/marketing/gtm-strategist/ops-financial-basics
        required: true
        tier_gate: pro
      - slug: business-model-research
        path: pro/research/market-researcher/business-model-research
        required: true
        tier_gate: pro
      - slug: risk-assessment
        path: pro/research/market-researcher/risk-assessment
        required: true
        tier_gate: pro
    outputs:
      - "Revenue-mix audit"
      - "Founder time-by-line table"
    decision_gate: |
      Advance with baseline + transition target documented.
  - name: "Productize 2"
    intent: "Two productized offers to anchor recurring revenue."
    tasks:
      - "Pick top-2 patterns from audit"
      - "Productize using productize-a-service-offering chain"
      - "Launch landings + intake forms"
    methodologies:
      - slug: minimum-product-frameworks
        path: pro/product/product-manager/minimum-product-frameworks
        required: true
        tier_gate: pro
      - slug: mlp-planning
        path: pro/product/product-manager/mlp-planning
        required: true
        tier_gate: pro
      - slug: release-planning
        path: pro/product/product-manager/release-planning
        required: true
        tier_gate: pro
      - slug: competitive-positioning
        path: pro/product/product-planning/competitive-positioning
        required: true
        tier_gate: pro
      - slug: growth-brand-positioning
        path: pro/marketing/gtm-strategist/growth-brand-positioning
        required: true
        tier_gate: pro
      - slug: growth-gtm-strategy
        path: pro/marketing/gtm-strategist/growth-gtm-strategy
        required: true
        tier_gate: pro
      - slug: growth-free-trial-optimization
        path: pro/marketing/conversion-optimizer/growth-free-trial-optimization
        required: true
        tier_gate: pro
      - slug: plg-implementation-guide
        path: pro/marketing/conversion-optimizer/plg-implementation-guide
        required: true
        tier_gate: pro
    outputs:
      - "2 productized landings live"
      - "Delivery SOPs"
    decision_gate: |
      Advance once each productized offer has shipped 1 paid run.
  - name: "Convert + retain"
    intent: "Pull existing project clients into retainer / productized."
    tasks:
      - "Send retainer pitch to top 10 accounts"
      - "Convert 3+ to retainer"
      - "Stand up retention ops"
    methodologies:
      - slug: north-star-metric
        path: pro/marketing/growth-marketer/north-star-metric
        required: true
        tier_gate: pro
      - slug: retention-strategies
        path: pro/marketing/growth-marketer/retention-strategies
        required: true
        tier_gate: pro
      - slug: growth-affiliate-marketing
        path: pro/marketing/gtm-strategist/growth-affiliate-marketing
        required: true
        tier_gate: pro
      - slug: ops-customer-success-basics
        path: pro/marketing/gtm-strategist/ops-customer-success-basics
        required: true
        tier_gate: pro
      - slug: ops-upselling-cross-selling
        path: pro/marketing/gtm-strategist/ops-upselling-cross-selling
        required: true
        tier_gate: pro
      - slug: ops-partnership-strategy
        path: pro/marketing/gtm-strategist/ops-partnership-strategy
        required: true
        tier_gate: pro
    outputs:
      - "Retainer conversion ledger"
      - "Retention SOP"
    decision_gate: |
      Advance when 3+ accounts converted to recurring.
  - name: "De-risk delivery"
    intent: "Founder cuts hands-on hours: contractor coverage + ops."
    tasks:
      - "Hand 2 deliverables to contractors"
      - "Stand up product-ops cadence"
      - "Build founder-time dashboard"
    methodologies:
      - slug: onboarding-30-day
        path: pro/comms/hr-recruiter/onboarding-30-day
        required: true
        tier_gate: pro
      - slug: onboarding-60-90-day
        path: pro/comms/hr-recruiter/onboarding-60-90-day
        required: true
        tier_gate: pro
      - slug: ops-contractor-management
        path: pro/marketing/gtm-strategist/ops-contractor-management
        required: true
        tier_gate: pro
      - slug: resource-management
        path: pro/pm/project-manager/resource-management
        required: true
        tier_gate: pro
      - slug: product-operations
        path: pro/product/product-operations/product-operations
        required: true
        tier_gate: pro
      - slug: portfolio-strategy
        path: pro/product/product-manager/portfolio-strategy
        required: true
        tier_gate: pro
      - slug: portfolio-strategy
        path: pro/product/product-planning/portfolio-strategy
        required: true
        tier_gate: pro
    outputs:
      - "Contractor coverage SOP"
      - "Founder-time dashboard"
    decision_gate: |
      Advance once founder delivery hours fall to or below 60% of baseline.
  - name: "Plan + decide"
    intent: "Annual plan against new mix; commit or roll back."
    tasks:
      - "Run annual planning ritual against new mix"
      - "Forecast next 12 months"
      - "Write commitment or rollback decision"
    methodologies:
      - slug: ops-annual-planning-process
        path: pro/marketing/gtm-strategist/ops-annual-planning-process
        required: true
        tier_gate: pro
      - slug: ops-annual-planning-templates
        path: pro/marketing/gtm-strategist/ops-annual-planning-templates
        required: true
        tier_gate: pro
      - slug: business-model-planning
        path: pro/research/market-researcher/business-model-planning
        required: true
        tier_gate: pro
      - slug: trend-analysis
        path: pro/research/market-researcher/trend-analysis
        required: true
        tier_gate: pro
    outputs:
      - "Annual plan v2"
      - "Transition decision doc"
    decision_gate: |
      Required: written decision. Continue, double down, or roll back to project-led.

common_pitfalls:
  - "Productizing without selling - landing pages without buyers do not move the mix"
  - "Cutting founder hours before delivery SOPs are tested - quality drops, churn rises"
  - "Treating month-3 revenue dip as failure - recurring revenue lags the work"

quality_checklist:
  - "Did I measure founder hours, not just revenue?"
  - "Are the productized offers actually selling, not just live?"
  - "Is concentration risk down or just hidden under retainers?"

related_playbooks:
  - productize-a-service-offering
  - annual-planning-and-financial-close

token_budget_estimate: 26000
cli_invocations:
  human:  "faion get-content agency-to-recurring-revenue-transition --format md"
  agent:  "faion get-content agency-to-recurring-revenue-transition --format context"
  json:   "faion get-content agency-to-recurring-revenue-transition --format json"

