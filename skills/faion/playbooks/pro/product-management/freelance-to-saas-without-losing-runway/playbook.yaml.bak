# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #22
# =============================================================================

slug: freelance-to-saas-without-losing-runway
title: "Freelancer-to-SaaS transition without losing the runway"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 726cb01c10c9a3c2

tier_min: pro
complexity: deep
context: [solo]
persona_hints: [P3]

intent: |
  From a stable freelance income, validate and ship a SaaS product on the side, then taper client work month-by-month according to MRR triggers — without dropping below 6-month runway at any point.

scope: |
  From a stable freelance income, validate and ship a SaaS product on the side, then taper client work month-by-month according to MRR triggers — without dropping below 6-month runway at any point.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Runway baseline stage complete: Runway dashboard"
  - "Validate + scope stage complete: Validated pain note"
  - "Dual-track ship stage complete: Weekly time-allocation log"
  - "Taper stage complete: MRR / runway / client-roster log per month"

stages:
  - name: "Runway baseline"
    intent: "Set the minimum acceptable runway; never cross it."
    tasks:
      - "Calculate current runway"
      - "Set floor (e.g. 6 months)"
      - "Define MRR triggers for each taper step"
    methodologies:
      - slug: freelance-to-saas-runway-gates
        path: pro/_gap/freelance-to-saas-runway-gates
        required: true
        tier_gate: pro
      - slug: minimum-acceptable-rate-floor
        path: pro/_gap/minimum-acceptable-rate-floor
        required: true
        tier_gate: pro
    outputs:
      - "Runway dashboard"
      - "Floor + triggers doc"
    decision_gate: |
      Advance only with explicit floor + trigger rules written.
  - name: "Validate + scope"
    intent: "Confirm the SaaS pain is real and scope is tight."
    tasks:
      - "Use Mom Test interviews on 10 prospects"
      - "Run idea-validation landing page"
      - "Cut scope to ugliest first version"
    methodologies:
      []
    outputs:
      - "Validated pain note"
      - "Landing page conversion data"
      - "Cut scope doc"
    decision_gate: |
      Advance only when landing converts ≥5% AND interviews confirm pain.
  - name: "Dual-track ship"
    intent: "Ship SaaS in fixed weekly hours; keep client cadence intact."
    tasks:
      - "Set fixed time-box per week for product work"
      - "Move repeat clients to retainer to stabilize"
      - "Ship v1 to first design partners"
    methodologies:
      - slug: dual-track-context-switching-discipline
        path: pro/_gap/dual-track-context-switching-discipline
        required: true
        tier_gate: pro
      - slug: time-allocation-ratio-by-runway
        path: pro/_gap/time-allocation-ratio-by-runway
        required: true
        tier_gate: pro
      - slug: retainer-conversion-from-project-client
        path: pro/_gap/retainer-conversion-from-project-client
        required: true
        tier_gate: pro
    outputs:
      - "Weekly time-allocation log"
      - "Retainer conversions"
      - "v1 deployed"
    decision_gate: |
      Advance only when product time-box held for 8 straight weeks without missed client deliverables.
  - name: "Taper"
    intent: "Drop client hours as MRR hits triggers; keep runway above floor."
    tasks:
      - "Hit MRR trigger 1: drop 1 client"
      - "Hit MRR trigger 2: drop another or shift to retainer-only"
      - "Each step: verify runway still above floor"
    methodologies:
      - slug: mrr-trigger-client-taper-plan
        path: pro/_gap/mrr-trigger-client-taper-plan
        required: true
        tier_gate: pro
    outputs:
      - "MRR / runway / client-roster log per month"
    decision_gate: |
      Never cross the runway floor. If approaching, pause taper and ramp client work back.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  - runway-calc
  - idea-validation-landing-page
  - is-this-a-real-problem
  - mom-test-customer-interview
  - mvp-scope-cutting
  - ugly-first-version

token_budget_estimate: 19000
cli_invocations:
  human:  "faion get-content freelance-to-saas-without-losing-runway --format md"
  agent:  "faion get-content freelance-to-saas-without-losing-runway --format context"
  json:   "faion get-content freelance-to-saas-without-losing-runway --format json"

