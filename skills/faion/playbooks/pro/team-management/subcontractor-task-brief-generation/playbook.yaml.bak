# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: subcontractor-task-brief-generation
title: "Subcontractor task brief generation"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 95cef585348bf9b8

tier_min: pro
complexity: light
context: [team, outsource]
persona_hints: [P5]

intent: |
  New task to self-contained contractor brief with context, definition of done, deliverable format, escalation path.

scope: |
  Founder produces a self-contained brief for each new task handed to a contractor. Output: brief with context, definition of done, deliverable format, escalation path. Exit artifact: brief pinned in shared workspace + accepted by contractor in writing.

non_goals:
  - "Full project plan - task-level brief only"
  - "Long-form spec - concise, structured brief"

prerequisites:
  - "Contractor signed + onboarded"
  - "Brief template pinned in shared workspace"

success_criteria:
  - "Brief includes context, AC, deliverable format, escalation"
  - "Contractor accepts brief in writing"
  - "Definition of done explicit (verifiable)"
  - "Brief fits one screen"

stages:
  - name: "Frame context"
    intent: "Why now, where it fits, what the client cares about."
    tasks:
      - "Write 3-line context"
      - "Link parent project + sponsor"
      - "Flag any constraints (budget, brand, legal)"
    methodologies:
      - slug: ops-contractor-basics
        path: pro/marketing/gtm-strategist/ops-contractor-basics
        required: true
        tier_gate: pro
      - slug: ops-contractor-management
        path: pro/marketing/gtm-strategist/ops-contractor-management
        required: true
        tier_gate: pro
    outputs:
      - "Context block"
    decision_gate: |
      Advance once context fits 3 lines without losing meaning.
  - name: "Definition of done"
    intent: "Verifiable acceptance criteria."
    tasks:
      - "Write 3-7 acceptance criteria"
      - "Specify deliverable format + location"
      - "Specify review cadence"
    methodologies:
      - slug: acceptance-criteria
        path: pro/ba/business-analyst/acceptance-criteria
        required: true
        tier_gate: pro
      - slug: requirements-documentation
        path: pro/ba/business-analyst/requirements-documentation
        required: true
        tier_gate: pro
    outputs:
      - "AC list"
      - "Deliverable format spec"
    decision_gate: |
      Advance only if AC are testable by someone else.
  - name: "RACI + escalation"
    intent: "Owner + decision rights + when to escalate."
    tasks:
      - "Tag responsible + accountable"
      - "Define decision authority"
      - "Set escalation trigger"
    methodologies:
      - slug: raci-matrix
        path: pro/pm/project-manager/raci-matrix
        required: true
        tier_gate: pro
      - slug: team-development
        path: pro/pm/project-manager/team-development
        required: true
        tier_gate: pro
    outputs:
      - "RACI line"
      - "Escalation path"
    decision_gate: |
      Advance with named owner + escalation written.
  - name: "Hand over + log"
    intent: "Contractor accepts in writing; brief logged."
    tasks:
      - "Share brief in agreed channel"
      - "Ask contractor to confirm in writing"
      - "Log brief in task tracker"
    methodologies:
      - slug: feedback
        path: solo/comms/communicator/feedback
        required: true
        tier_gate: solo
    outputs:
      - "Acceptance comment"
      - "Logged brief"
    decision_gate: |
      Required: written acceptance before work begins.

common_pitfalls:
  - "Briefing via Slack DM with no AC - rework guaranteed"
  - "Skipping escalation rules - contractor sits on blockers"
  - "Letting briefs balloon past one screen - nobody reads it"

quality_checklist:
  - "Could a different contractor execute this brief without me?"
  - "Are AC testable by someone else?"
  - "Did I get a written acceptance?"

related_playbooks:
  - daily-contractor-standup
  - hire-and-onboard-a-new-contractor

token_budget_estimate: 6000
cli_invocations:
  human:  "faion get-content subcontractor-task-brief-generation --format md"
  agent:  "faion get-content subcontractor-task-brief-generation --format context"
  json:   "faion get-content subcontractor-task-brief-generation --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: contractor-brief-template-self-contained
    expected_tier: pro
    blocks_stage: 1
    note: "Frame-context stage needs a self-contained brief template"
  - methodology_slug: definition-of-done-library
    expected_tier: pro
    blocks_stage: 2
    note: "Definition-of-done stage needs a reusable AC library by deliverable type"
