# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #16
# =============================================================================

slug: senior-promotion-case-prep
title: "Senior promotion case prep (every 6 months)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 67d2e54aa8d55e2b

tier_min: pro
complexity: medium
context: [outsource, team, solo]
persona_hints: [P4]

intent: |
  Half-day reflective task before promotion cycle → written case mapping last 6 months at the shop to senior/lead competency rubric, with evidence reviewer can verify.

scope: |
  Atomic half-day ceremony repeated each promotion cycle. Output: a written case that maps the last 6 months to the senior/lead competency rubric, with evidence the reviewer can verify without you in the room. Used at outsource shops where promotion is calibrated against an internal rubric.

non_goals:
  - "Salary negotiation — that's a separate conversation"
  - "Building a new portfolio — uses what already exists"
  - "Reviewer politics — focused on evidence, not games"

prerequisites:
  - "Competency rubric accessible from HR"
  - "Last 6 months of engagement artifacts retrievable"
  - "Peer-feedback pool willing to be contacted"

success_criteria:
  - "Every rubric line has at least one evidence link"
  - "STAR-formatted highlights for top 3 stories"
  - "30-60-90 day next-stretch plan included"
  - "Peer feedback collected from ≥3 sources"
  - "Case is self-contained for an off-engagement reviewer"

stages:
  - name: "Inventory + rubric mapping"
    intent: "Match what you did to what HR scores you on."
    tasks:
      - "Pull the rubric from HR"
      - "List engagements over the last 6 months"
      - "Map evidence to each rubric line"
      - "Build a 30-60-90 forward plan to show direction"
    methodologies:
      - slug: 30-60-90-day-plan
        path: pro/comms/hr-recruiter/30-60-90-day-plan
        required: true
        tier_gate: pro
      - slug: competency-rubric-evidence-matrix
        path: pro/_gap/competency-rubric-evidence-matrix
        required: true
        tier_gate: pro
    outputs:
      - "Evidence matrix"
      - "30-60-90 forward plan"
    decision_gate: |
      Advance only when every rubric line has evidence or an honest 'gap' note.
  - name: "STAR stories"
    intent: "Tell 3 stories that survive a reviewer's stress-test."
    tasks:
      - "Pick 3 high-impact moments"
      - "Frame each in STAR (Situation, Task, Action, Result)"
      - "Apply storytelling patterns to keep them readable"
      - "Lessons-learned style: what you'd do differently"
    methodologies:
      - slug: star-interview-method
        path: pro/comms/hr-recruiter/star-interview-method
        required: true
        tier_gate: pro
      - slug: star-interview-framework
        path: pro/comms/hr-recruiter/star-interview-framework
        required: true
        tier_gate: pro
      - slug: star-interview-examples
        path: pro/comms/hr-recruiter/star-interview-examples
        required: true
        tier_gate: pro
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
      - slug: business-storytelling
        path: solo/comms/communicator/business-storytelling
        required: true
        tier_gate: solo
      - slug: selling-ideas
        path: solo/comms/communicator/selling-ideas
        required: true
        tier_gate: solo
      - slug: senior-promotion-case-template-outsource-shop
        path: pro/_gap/senior-promotion-case-template-outsource-shop
        required: true
        tier_gate: pro
    outputs:
      - "3 STAR stories"
    decision_gate: |
      Advance only when stories land impact in numbers, not adjectives.
  - name: "Peer feedback + filing"
    intent: "Triangulate the self-narrative with external voices."
    tasks:
      - "Solicit feedback from ≥3 peers using a tested script"
      - "Apply feedback patterns to integrate critique"
      - "Compile final case"
      - "File with HR + your manager before the deadline"
    methodologies:
      - slug: feedback
        path: solo/comms/communicator/feedback
        required: true
        tier_gate: solo
      - slug: peer-feedback-solicitation-script
        path: pro/_gap/peer-feedback-solicitation-script
        required: true
        tier_gate: pro
    outputs:
      - "Peer feedback collated"
      - "Final case doc"
      - "Filed with HR"
    decision_gate: |
      Done when case is filed AND each peer quote is verifiable.

common_pitfalls:
  - "Self-narrative without peer triangulation — reviewer discounts it"
  - "Adjectives instead of metrics — stories evaporate at panel review"
  - "Filing without a forward plan — reviewers want direction, not just history"

quality_checklist:
  - "Could a reviewer verify every claim without me in the room?"
  - "Did I show a stretch goal, not just achievements?"
  - "Did I solicit feedback from people who'd push back?"

related_playbooks:
  - pre-handover-documentation-pack

token_budget_estimate: 9000
cli_invocations:
  human:  "faion get-content senior-promotion-case-prep --format md"
  agent:  "faion get-content senior-promotion-case-prep --format context"
  json:   "faion get-content senior-promotion-case-prep --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, atomic angle"

