# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: hire-and-onboard-a-new-contractor
title: "Hire and onboard a new contractor (3-5 weeks)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: d9fee02a751b95b7

tier_min: pro
complexity: medium
context: [team, outsource]
persona_hints: [P5]

intent: |
  Identified delivery bottleneck to contractor sourced, signed, onboarded, and shipping billable work in week 3.

scope: |
  Identify a recurring delivery bottleneck, scope a contractor role, source 5-10 candidates, pick one, sign a contractor agreement, and run them through onboarding so they ship billable work in week 3. Exit artifact: contractor producing acceptable client-facing output with a 30-60-90 plan and clear escalation path.

non_goals:
  - "W-2 employee hires - this is contractor-only"
  - "Founding-team co-founder search - distinct playbook"

prerequisites:
  - "At least one recurring engagement type the contractor can absorb"
  - "Bank + invoicing system set up for contractor payments"

success_criteria:
  - "Documented role brief with deliverables + escalation path"
  - "5-10 candidates screened"
  - "Paid audition completed by 1-3 finalists"
  - "Signed contractor agreement on file (IP + NDA terms locked)"
  - "30-60-90 day plan delivered to contractor"
  - "Contractor shipping billable client work by week 3"

stages:
  - name: "Define the role"
    intent: "Specify the bottleneck and the deliverable shape, not a vague 'helper' role."
    tasks:
      - "Map process bottleneck producing the need"
      - "List 3-5 concrete deliverables for the role"
      - "Define escalation + decision authority"
    methodologies:
      - slug: business-process-analysis
        path: pro/ba/business-analyst/business-process-analysis
        required: true
        tier_gate: pro
      - slug: ops-contractor-basics
        path: pro/marketing/gtm-strategist/ops-contractor-basics
        required: true
        tier_gate: pro
      - slug: ops-contractor-management
        path: pro/marketing/gtm-strategist/ops-contractor-management
        required: true
        tier_gate: pro
      - slug: resource-management
        path: pro/pm/project-manager/resource-management
        required: true
        tier_gate: pro
    outputs:
      - "Role brief doc"
      - "Bottleneck map"
    decision_gate: |
      Advance once a stranger could read the role brief and describe the daily work.
  - name: "Source + screen"
    intent: "Get 5-10 plausible candidates into the funnel quickly."
    tasks:
      - "Post role in 3 channels (network, niche board, referrals)"
      - "Screen on portfolio + take-home willingness"
      - "Shortlist 3-5 for paid audition"
    methodologies:
      - slug: employee-value-proposition
        path: pro/comms/hr-recruiter/employee-value-proposition
        required: true
        tier_gate: pro
      - slug: employer-branding
        path: pro/comms/hr-recruiter/employer-branding
        required: true
        tier_gate: pro
      - slug: recruiting-process
        path: pro/comms/hr-recruiter/recruiting-process
        required: true
        tier_gate: pro
      - slug: recruitment-funnel-optimization
        path: pro/comms/hr-recruiter/recruitment-funnel-optimization
        required: true
        tier_gate: pro
    outputs:
      - "Pipeline of 5-10 candidates"
      - "Shortlist of 3-5"
    decision_gate: |
      Advance when shortlist has 3+ candidates above the bar.
  - name: "Audition"
    intent: "Paid trial that mirrors actual work; written feedback per candidate."
    tasks:
      - "Issue paid take-home task (4-8h)"
      - "Score against a published rubric"
      - "Run 30-min synthesis interview with top-2"
    methodologies:
      - slug: interview-methods
        path: pro/comms/hr-recruiter/interview-methods
        required: true
        tier_gate: pro
      - slug: star-interview-framework
        path: pro/comms/hr-recruiter/star-interview-framework
        required: true
        tier_gate: pro
      - slug: star-interview-method
        path: pro/comms/hr-recruiter/star-interview-method
        required: true
        tier_gate: pro
      - slug: structured-interview-design
        path: pro/comms/hr-recruiter/structured-interview-design
        required: true
        tier_gate: pro
    outputs:
      - "Audition rubric scores"
      - "Hire decision doc"
    decision_gate: |
      Hire if rubric score above threshold AND finalist comms feel low-friction.
  - name: "Contract + comply"
    intent: "Paper everything before the first task; misclassification kills agencies."
    tasks:
      - "Sign contractor agreement with IP + NDA + termination clauses"
      - "Register tax IDs / W-9 / VAT equivalents"
      - "Set up payment + invoicing channel"
    methodologies:
      - slug: retention-compliance
        path: pro/comms/hr-recruiter/retention-compliance
        required: true
        tier_gate: pro
      - slug: ops-legal-basics
        path: pro/marketing/gtm-strategist/ops-legal-basics
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance
        path: pro/marketing/gtm-strategist/ops-legal-compliance
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance-checklist
        path: pro/marketing/gtm-strategist/ops-legal-compliance-checklist
        required: true
        tier_gate: pro
      - slug: ops-tax-compliance
        path: pro/marketing/gtm-strategist/ops-tax-compliance
        required: true
        tier_gate: pro
    outputs:
      - "Executed agreement"
      - "Tax + payment paperwork on file"
    decision_gate: |
      No work begins until all paperwork cleared.
  - name: "Onboard + ship"
    intent: "30-60-90 plan + week-3 billable output."
    tasks:
      - "Deliver 30-60-90 plan + access kit on day 1"
      - "Pair on first deliverable in week 1"
      - "Hand contractor an independent client task by week 3"
    methodologies:
      - slug: 30-60-90-day-plan
        path: pro/comms/hr-recruiter/30-60-90-day-plan
        required: true
        tier_gate: pro
      - slug: onboarding
        path: pro/comms/hr-recruiter/onboarding
        required: true
        tier_gate: pro
      - slug: onboarding-30-day
        path: pro/comms/hr-recruiter/onboarding-30-day
        required: true
        tier_gate: pro
      - slug: team-development
        path: pro/pm/project-manager/team-development
        required: true
        tier_gate: pro
    outputs:
      - "30-60-90 plan doc"
      - "Week-3 billable deliverable"
    decision_gate: |
      Required output: contractor ships acceptable client-facing work by week 3 OR documented re-trial / release.

common_pitfalls:
  - "Hiring on 'gut' without a paid audition - fixes the wrong problem"
  - "Skipping the contractor-vs-employee classification check - regulators do not forgive ignorance"
  - "Onboarding by Slack DM - no documented 30-60-90 = no clear ramp"

quality_checklist:
  - "Did the paid audition simulate actual client work?"
  - "Is the paperwork done before any client-facing task?"
  - "Does the contractor have a written 30-60-90 plan they can self-check?"

related_playbooks:
  - hiring-screen-contractor-audition
  - subcontractor-task-brief-generation

token_budget_estimate: 16000
cli_invocations:
  human:  "faion get-content hire-and-onboard-a-new-contractor --format md"
  agent:  "faion get-content hire-and-onboard-a-new-contractor --format context"
  json:   "faion get-content hire-and-onboard-a-new-contractor --format json"

