tier_min: pro
complexity: medium
context: [solo, team]
persona: role-ba
group: business-analyst
angle: atomic
persona_hints: [role-ba]

intent: |
  One review meeting with mixed stakeholders ends with explicit approvals per requirement, parked
  items routed, and minutes published within an hour.

scope: |
  One review meeting with mixed stakeholders ends with explicit approvals per requirement, parked
  items routed, and minutes published within an hour.

summary: |
  One review meeting with mixed stakeholders ends with explicit approvals per requirement, parked
  items routed, and minutes published within an hour.

methodology_refs:
  - "elicitation-techniques"
  - "requirements-documentation"
  - "requirements-validation"
  - "stakeholder-analysis"

success_criteria:
  - "Prep stage complete with written artifact and decision-gate note"
  - "Frame stage complete with written artifact and decision-gate note"
  - "Execute stage complete with written artifact and decision-gate note"
  - "Capture stage complete with written artifact and decision-gate note"
  - "Decide stage complete with written artifact and decision-gate note"

stages:
  - name: "Prep"
    intent: "Get inputs, environment, and prior context lined up before the session starts."
    tasks:
      - "Read the assigned methodology references and reconcile them with this stage's goal."
      - "Produce the stage artifact named in 'outputs' and store it where the next stage can read it."
      - "Re-check the decision gate before advancing; loop within this stage if it fails."
    methodologies:
      - slug: elicitation-techniques
        path: pro/ba/ba-core/elicitation-techniques
        required: true
        tier_gate: pro
    outputs:
      - "Written artifact for stage 1 (Prep) named per the project's docs convention"
      - "Decision-gate note (advance / iterate / kill) appended to the playbook log"
    decision_gate: "Advance when the stage 1 artifact exists in writing AND the methodology chain assigned to this stage has been applied. Iterate or escalate otherwise."
  - name: "Frame"
    intent: "Name the single outcome and the boundaries; lock the inputs in writing."
    tasks:
      - "Read the assigned methodology references and reconcile them with this stage's goal."
      - "Produce the stage artifact named in 'outputs' and store it where the next stage can read it."
      - "Re-check the decision gate before advancing; loop within this stage if it fails."
    methodologies:
      - slug: requirements-documentation
        path: pro/ba/ba-core/requirements-documentation
        required: true
        tier_gate: pro
    outputs:
      - "Written artifact for stage 2 (Frame) named per the project's docs convention"
      - "Decision-gate note (advance / iterate / kill) appended to the playbook log"
    decision_gate: "Advance when the stage 2 artifact exists in writing AND the methodology chain assigned to this stage has been applied. Iterate or escalate otherwise."
  - name: "Execute"
    intent: "Run the core activity end-to-end without context switches."
    tasks:
      - "Read the assigned methodology references and reconcile them with this stage's goal."
      - "Produce the stage artifact named in 'outputs' and store it where the next stage can read it."
      - "Re-check the decision gate before advancing; loop within this stage if it fails."
    methodologies:
      - slug: requirements-validation
        path: pro/ba/ba-core/requirements-validation
        required: true
        tier_gate: pro
    outputs:
      - "Written artifact for stage 3 (Execute) named per the project's docs convention"
      - "Decision-gate note (advance / iterate / kill) appended to the playbook log"
    decision_gate: "Advance when the stage 3 artifact exists in writing AND the methodology chain assigned to this stage has been applied. Iterate or escalate otherwise."
  - name: "Capture"
    intent: "Write the outputs down in a form a teammate can read later."
    tasks:
      - "Read the assigned methodology references and reconcile them with this stage's goal."
      - "Produce the stage artifact named in 'outputs' and store it where the next stage can read it."
      - "Re-check the decision gate before advancing; loop within this stage if it fails."
    methodologies:
