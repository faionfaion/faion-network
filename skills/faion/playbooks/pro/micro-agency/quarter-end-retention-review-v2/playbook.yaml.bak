stages:
  - name: "Score Account Health"
    intent: "Quantify churn risk across the active book."
    tasks:
      - "Pull engagement, payment, and feedback signals per account"
      - "Score every account on the 5-criteria health rubric"
      - "Tag accounts: green / yellow / red"
    methodologies:
      - slug: "cohort-implementation"
        path: "pro/marketing/growth-marketer/cohort-implementation"
        required: true
        tier_gate: "pro"
      - slug: "ops-churn-basics"
        path: "pro/marketing/growth-marketer/ops-churn-basics"
        required: true
        tier_gate: "pro"
      - slug: "ops-churn-prevention"
        path: "pro/marketing/growth-marketer/ops-churn-prevention"
        required: true
        tier_gate: "pro"
    outputs:
      - "account-health table"
      - "scored rubric"
      - "red/yellow watchlist"
    decision_gate: "Advance once every active account has a current health score."
  - name: "Prep QBR Decks"
    intent: "One deck per account, outcome-led."
    tasks:
      - "For every active account, build the QBR deck from the template"
      - "Pre-fill metrics, wins, risks, and proposed next-quarter plan"
      - "Tee up upsell or graceful-offboard for red/yellow accounts"
    methodologies:
      - slug: "retention-metrics"
        path: "pro/marketing/growth-marketer/retention-metrics"
        required: true
        tier_gate: "pro"
      - slug: "retention-strategies"
        path: "pro/marketing/growth-marketer/retention-strategies"
        required: true
        tier_gate: "pro"
      - slug: "ops-annual-planning-process"
        path: "pro/marketing/gtm-strategist/ops-annual-planning-process"
        required: true
        tier_gate: "pro"
    outputs:
      - "QBR decks"
      - "per-account next-quarter plan"
      - "upsell/offboard tee-ups"
    decision_gate: "Advance when every active account has a tailored deck ready for delivery."
  - name: "Run QBRs"
    intent: "Deliver the reviews and collect signal."
    tasks:
      - "Schedule and run a 60-min QBR per account"
      - "Capture: renewal posture, expansion appetite, reference willingness"
      - "Note any churn intent or red flag as it surfaces"
    methodologies:
      - slug: "ops-annual-planning-templates"
        path: "pro/marketing/gtm-strategist/ops-annual-planning-templates"
        required: true
        tier_gate: "pro"
      - slug: "ops-customer-success-basics"
        path: "pro/marketing/gtm-strategist/ops-customer-success-basics"
        required: true
        tier_gate: "pro"
      - slug: "ops-customer-success-metrics"
        path: "pro/marketing/gtm-strategist/ops-customer-success-metrics"
        required: true
        tier_gate: "pro"
    outputs:
      - "QBR meeting notes"
      - "renewal/expansion notes"
      - "red-flag log"
    decision_gate: "Advance when ≥80% of active accounts have been seen this quarter."
  - name: "Upsell, Reference, Offboard"
    intent: "Convert the signal into actions."
    tasks:
      - "Send 3 upsell proposals to qualified expansion accounts"
      - "Send 2 reference-program asks to advocates"
      - "Run 1 graceful offboard for an account that should not renew"
    methodologies:
      - slug: "ops-upselling-cross-selling"
        path: "pro/marketing/gtm-strategist/ops-upselling-cross-selling"
        required: true
        tier_gate: "pro"
      - slug: "benefits-realization"
        path: "pro/pm/project-manager/benefits-realization"
        required: true
        tier_gate: "pro"
      - slug: "project-closure"
        path: "pro/pm/project-manager/project-closure"
        required: true
        tier_gate: "pro"
    outputs:
      - "3 upsell proposals"
      - "2 reference asks"
      - "1 offboard script run"
    decision_gate: "Advance only when at least 5 of these 6 actions are out the door."
  - name: "Quarterly Plan"
    intent: "Convert QBR outputs into next-quarter delivery."
    tasks:
      - "Refresh the per-account plan for the new quarter"
      - "Rebalance delivery capacity around expansion vs churn-defense"
      - "Log learnings about which signals predicted renewal vs churn"
    methodologies:
      - slug: "stakeholder-engagement-advanced"
        path: "pro/pm/project-manager/stakeholder-engagement-advanced"
        required: true
        tier_gate: "pro"
      - slug: "stakeholder-register"
        path: "pro/pm/project-manager/stakeholder-register"
        required: true
        tier_gate: "pro"
      - slug: "feedback-management"
        path: "pro/product/product-manager/feedback-management"
        required: true
        tier_gate: "pro"
      - slug: "portfolio-strategy"
        path: "pro/product/product-manager/portfolio-strategy"
        required: true
        tier_gate: "pro"
      - slug: "portfolio-strategy"
        path: "pro/product/product-planning/portfolio-strategy"
        required: true
        tier_gate: "pro"
      - slug: "growth-customer-testimonials"
        path: "solo/marketing/content-marketer/growth-customer-testimonials"
        required: true
        tier_gate: "pro"
    outputs:
      - "next-quarter plans"
      - "capacity plan"
      - "signal-to-outcome learnings"
    decision_gate: "Required output: written next-quarter plan per active account."
