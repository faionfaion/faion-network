slug: "hire-and-onboard-a-new-contractor-v2"
title: "Hire and onboard a new contractor (3–5 weeks)"
tier: "pro"
group: "micro-agency"
persona: "p5-micro-agency-founder"
complexity: "medium"
version: "1.0.0"
status: "draft"
last_reviewed: 2026-05-20
maintainers:
  - "faion-network"
summary: |
  Identify a recurring delivery bottleneck, scope a contractor role, source 5–10 candidates, pick one, sign a contractor agreement, and run them through onboarding so they ship billable work in week 3.
content_id: "bfdf60873587b53b"
tier_min: "pro"
context:
  - "team"
intent: |
  Identify a recurring delivery bottleneck, scope a contractor role, source 5–10 candidates, pick one, sign a contractor agreement, and run them through onboarding so they ship billable work in week 3.
scope: |
  Identify a recurring delivery bottleneck, scope a contractor role, source 5–10 candidates, pick one, sign a contractor agreement, and run them through onboarding so they ship billable work in week 3.
success_criteria:
  - "All 6 stages have written outputs in the project record"
  - "Each stage's decision gate was answered before advancing (yes / no in writing)"
  - "Final stage produced the required written decision artifact"
  - "Every methodology reference loaded cleanly via `faion get-content`"
methodology_refs:
  - "business-process-analysis"
  - "30-60-90-day-plan"
  - "employee-value-proposition"
  - "employer-branding"
  - "interview-methods"
  - "onboarding"
  - "onboarding-30-day"
  - "recruiting-process"
  - "recruitment-funnel-optimization"
  - "retention-compliance"
  - "star-interview-framework"
  - "star-interview-method"
  - "structured-interview-design"
  - "ops-contractor-basics"
  - "ops-contractor-management"
  - "ops-legal-basics"
  - "ops-legal-compliance"
  - "ops-legal-compliance-checklist"
  - "ops-tax-compliance"
  - "resource-management"
  - "team-development"
stages:
  - name: "Diagnose Bottleneck"
    intent: "Identify the recurring delivery bottleneck a contractor will solve."
    tasks:
      - "Map the last 3 projects' time logs to find repeated overflow tasks"
      - "Quantify hours-per-month lost to the bottleneck"
      - "Decide: contractor vs automation vs decline-the-work"
    methodologies:
      - slug: "business-process-analysis"
        path: "pro/ba/business-analyst/business-process-analysis"
        required: true
        tier_gate: "pro"
      - slug: "30-60-90-day-plan"
        path: "pro/comms/hr-recruiter/30-60-90-day-plan"
        required: true
        tier_gate: "pro"
      - slug: "employee-value-proposition"
        path: "pro/comms/hr-recruiter/employee-value-proposition"
        required: true
        tier_gate: "pro"
    outputs:
      - "bottleneck analysis"
      - "hours/month figure"
      - "hire-or-not memo"
    decision_gate: "Advance only if ≥40 hrs/month is consistently lost and contractor is the chosen lever."
  - name: "Scope Role"
    intent: "Write a tight contractor role that the bench can deliver against."
    tasks:
      - "Draft a 1-page contractor job description with outputs not duties"
      - "Set a fixed monthly engagement envelope and rate band"
      - "Define the paid test task and its scoring rubric"
    methodologies:
      - slug: "employer-branding"
        path: "pro/comms/hr-recruiter/employer-branding"
        required: true
        tier_gate: "pro"
      - slug: "interview-methods"
        path: "pro/comms/hr-recruiter/interview-methods"
        required: true
        tier_gate: "pro"
      - slug: "onboarding"
        path: "pro/comms/hr-recruiter/onboarding"
        required: true
        tier_gate: "pro"
    outputs:
      - "contractor JD"
      - "rate band"
      - "test-task brief + rubric"
    decision_gate: "Advance when JD fits on one page AND test task is reproducible across candidates."
  - name: "Source 5-10"
    intent: "Run a small structured sourcing batch."
    tasks:
      - "Post in 2 channels + ask 5 trusted contacts for referrals"
      - "Screen for portfolio match and timezone fit before any interview"
      - "Send the paid test task to top 3-5 candidates"
    methodologies:
      - slug: "onboarding-30-day"
        path: "pro/comms/hr-recruiter/onboarding-30-day"
        required: true
        tier_gate: "pro"
      - slug: "recruiting-process"
        path: "pro/comms/hr-recruiter/recruiting-process"
        required: true
        tier_gate: "pro"
      - slug: "recruitment-funnel-optimization"
        path: "pro/comms/hr-recruiter/recruitment-funnel-optimization"
        required: true
        tier_gate: "pro"
    outputs:
      - "sourcing log"
      - "screening notes"
      - "paid-test results"
    decision_gate: "Advance if ≥2 candidates cleared the test task with a score above the rubric bar."
  - name: "Interview & Decide"
    intent: "Pick one, sign legally clean."
    tasks:
      - "Run a 30-min structured interview using the STAR framework"
      - "Reference-check at least one past client"
      - "Sign a contractor agreement matching jurisdiction"
    methodologies:
      - slug: "retention-compliance"
        path: "pro/comms/hr-recruiter/retention-compliance"
        required: true
        tier_gate: "pro"
      - slug: "star-interview-framework"
        path: "pro/comms/hr-recruiter/star-interview-framework"
        required: true
        tier_gate: "pro"
      - slug: "star-interview-method"
        path: "pro/comms/hr-recruiter/star-interview-method"
        required: true
        tier_gate: "pro"
    outputs:
      - "interview notes"
      - "reference summary"
      - "signed contractor agreement"
    decision_gate: "Advance only when contract is countersigned and start date is on calendar."
  - name: "Onboard"
    intent: "First week sets the tone; ship billable work in week 3."
    tasks:
      - "Run the onboarding runbook: access, docs, comms norms, weekly cadence"
      - "Pair on one real piece of work in week 1"
      - "Assign the first billable deliverable for week 3"
    methodologies:
      - slug: "structured-interview-design"
        path: "pro/comms/hr-recruiter/structured-interview-design"
        required: true
        tier_gate: "pro"
      - slug: "ops-contractor-basics"
        path: "pro/marketing/gtm-strategist/ops-contractor-basics"
        required: true
        tier_gate: "pro"
      - slug: "ops-contractor-management"
        path: "pro/marketing/gtm-strategist/ops-contractor-management"
        required: true
        tier_gate: "pro"
    outputs:
      - "onboarding checklist completed"
      - "pairing notes"
      - "week-3 deliverable"
    decision_gate: "Advance when contractor ships the week-3 deliverable to a client without rework."
  - name: "30-day Review"
    intent: "Lock or unwind the engagement on evidence."
    tasks:
      - "Score the contractor against the JD outputs at day 30"
      - "Run a frank 1:1 on what's working and what isn't"
      - "Decide: continue / change scope / end engagement"
    methodologies:
      - slug: "ops-legal-basics"
        path: "pro/marketing/gtm-strategist/ops-legal-basics"
        required: true
        tier_gate: "pro"
      - slug: "ops-legal-compliance"
        path: "pro/marketing/gtm-strategist/ops-legal-compliance"
        required: true
        tier_gate: "pro"
      - slug: "ops-legal-compliance-checklist"
        path: "pro/marketing/gtm-strategist/ops-legal-compliance-checklist"
        required: true
        tier_gate: "pro"
      - slug: "ops-tax-compliance"
        path: "pro/marketing/gtm-strategist/ops-tax-compliance"
        required: true
        tier_gate: "pro"
      - slug: "resource-management"
        path: "pro/pm/project-manager/resource-management"
        required: true
        tier_gate: "pro"
      - slug: "team-development"
        path: "pro/pm/project-manager/team-development"
        required: true
        tier_gate: "pro"
    outputs:
      - "30-day scorecard"
      - "1:1 notes"
      - "continue/change/end decision"
    decision_gate: "Required output: a written continue / change / end decision."
token_budget_estimate: 18000
