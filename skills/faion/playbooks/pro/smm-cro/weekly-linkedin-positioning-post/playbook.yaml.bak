# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: weekly-linkedin-positioning-post
title: "Weekly LinkedIn positioning post"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 662a111e8c245cdf

tier_min: pro
complexity: light
context: [solo]
persona_hints: [P5]

intent: |
  One post per week to reinforce agency niche + earn 1-2 inbound replies per post.

scope: |
  Founder publishes one LinkedIn / X post per week that reinforces agency niche + earns 1-2 inbound replies. Output: post drafted, scheduled, engagement plan. Exit artifact: published post + reply log + 1 follow-up DM.

non_goals:
  - "Daily posting cadence - weekly only"
  - "Paid LinkedIn ads - separate playbook"

prerequisites:
  - "ICP one-pager + 3-4 content pillars defined"
  - "Personal LinkedIn / X profile aligned with agency positioning"

success_criteria:
  - "Post published each week"
  - "Post anchored to a defined content pillar"
  - "1+ qualified reply within 72h"
  - "1 inbound DM sent as follow-up"

stages:
  - name: "Pick the angle"
    intent: "Pillar + insight + audience pain."
    tasks:
      - "Pick the content pillar for the week"
      - "Surface 1 concrete insight from recent work"
      - "Map to ICP's stated pain"
    methodologies:
      - slug: growth-brand-positioning
        path: pro/marketing/gtm-strategist/growth-brand-positioning
        required: true
        tier_gate: pro
      - slug: growth-influencer-marketing
        path: pro/marketing/gtm-strategist/growth-influencer-marketing
        required: true
        tier_gate: pro
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Angle note"
    decision_gate: |
      Advance once angle ties to a real pillar + lived insight.
  - name: "Draft"
    intent: "Hook + payoff + ask in 200 words or less."
    tasks:
      - "Write hook (15 words or less)"
      - "Build payoff (insight, story, or number)"
      - "End with an explicit ask or CTA"
    methodologies:
      - slug: business-storytelling
        path: solo/comms/communicator/business-storytelling
        required: true
        tier_gate: solo
      - slug: storytelling
        path: solo/comms/communicator/storytelling
        required: true
        tier_gate: solo
      - slug: growth-copywriting-fundamentals
        path: solo/marketing/content-marketer/growth-copywriting-fundamentals
        required: true
        tier_gate: solo
      - slug: instagram-basics
        path: pro/marketing/smm-manager/instagram-basics
        required: true
        tier_gate: pro
    outputs:
      - "Draft post"
    decision_gate: |
      Advance only when hook stands alone without context.
  - name: "Schedule + engage"
    intent: "Publish at peak slot, reply to every comment for 24h."
    tasks:
      - "Schedule for peak slot"
      - "Reply to comments in first 24h"
      - "Send 1 thoughtful DM to a high-signal reply"
    methodologies: []
    outputs:
      - "Published post"
      - "Engagement log"
    decision_gate: |
      Required: 1+ qualified reply + 1 follow-up DM logged.

common_pitfalls:
  - "Posting generic 'thought leadership' - invisible to ICP"
  - "Skipping reply cadence - kills algorithmic distribution"
  - "Treating likes as success - measure replies + DMs"

quality_checklist:
  - "Does the post embarrass me with how on-niche it is?"
  - "Did I reply to every comment within 24h?"
  - "Did I send the inbound DM, or just admire it?"

related_playbooks:
  - bi-weekly-case-study-testimonial-capture
  - monday-lead-pipeline-review

token_budget_estimate: 6000
cli_invocations:
  human:  "faion get-content weekly-linkedin-positioning-post --format md"
  agent:  "faion get-content weekly-linkedin-positioning-post --format context"
  json:   "faion get-content weekly-linkedin-positioning-post --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: linkedin-founder-post-template
    expected_tier: pro
    blocks_stage: 2
    note: "Draft stage needs a tested founder-post template (hook + payoff + ask)"
  - methodology_slug: agency-content-pillars-niche
    expected_tier: pro
    blocks_stage: 1
    note: "Pick-the-angle stage needs a content-pillars worksheet tied to niche"
