# =============================================================================
# faion playbook manifest — P1 solo SaaS builder
# Generated for F-064 from playbook-index.json entry #2
# =============================================================================

slug: bootstrap-to-4k-mrr
title: "$0 to $4K MRR bootstrap journey"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 6a0812cdbb829fcf

tier_min: pro
complexity: deep
context: [solo]
persona_hints: [P1, P2]

intent: |
  Shipped MVP at $0 MRR → ramen-profitable $4K MRR / quit-day-job threshold without VC.

scope: |
  Solo dev with shipped MVP grinds to ramen-profitable ($4K MRR / quit-day-job threshold) without VC. Combines a single-channel distribution flywheel, retention defense, and runway accounting until either MRR target hit or honest sunset. Exit artifact is a quit-day-job decision contract or written sunset note.

non_goals:
  - "Multi-channel paid acquisition — single-channel bet only"
  - "Hiring or outsourcing — solo operator throughout"

prerequisites:
  - "MVP live and processing real payments"
  - "At least 5 paying customers (Stage 6 of idea-to-validated-mvp complete)"

success_criteria:
  - "Single-channel acquisition bet chosen and documented"
  - "Activation rate >40% on signup-to-paid funnel"
  - "Net revenue churn <3% monthly"
  - "MRR dashboard live and reviewed weekly"
  - "$4K MRR reached OR documented sunset decision"

stages:
  - name: "Pick channel"
    intent: "Choose one acquisition channel and commit for 90 days."
    tasks:
      - "Score 5 candidate channels"
      - "Pick one and write 90-day commitment"
      - "Define minimum viable cadence"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: growth-cold-outreach
        path: solo/marketing/gtm-strategist/growth-cold-outreach
        required: true
        tier_gate: solo
      - slug: search-everywhere-optimization
        path: solo/marketing/content-marketer/search-everywhere-optimization
        required: true
        tier_gate: solo
    outputs:
      - "Channel bet doc"
      - "90-day cadence calendar"
    decision_gate: |
      Advance once channel is chosen. Refuse to advance with 'I'll try a few' — single bet only.
  - name: "Activate"
    intent: "Fix the signup-to-paid funnel before pouring traffic in."
    tasks:
      - "Map current activation drop-offs"
      - "Ship onboarding email sequence"
      - "Add in-app activation nudges"
    methodologies:
      - slug: onboarding-flows
        path: pro/marketing/conversion-optimizer/onboarding-flows
        required: true
        tier_gate: pro
      - slug: activation-framework
        path: pro/marketing/growth-marketer/activation-framework
        required: true
        tier_gate: pro
      - slug: growth-onboarding-emails
        path: solo/marketing/content-marketer/growth-onboarding-emails
        required: true
        tier_gate: solo
    outputs:
      - "Activation funnel doc"
      - "Onboarding email sequence live"
    decision_gate: |
      Advance when activation rate >40%. Stay if leaking.
  - name: "Retain"
    intent: "Defend revenue: churn prevention before growth."
    tasks:
      - "Identify top 3 churn reasons"
      - "Ship 1 retention lever per reason"
      - "Set churn alert thresholds"
    methodologies:
      - slug: ops-churn-prevention
        path: pro/marketing/growth-marketer/ops-churn-prevention
        required: true
        tier_gate: pro
      - slug: retention-strategies
        path: pro/marketing/growth-marketer/retention-strategies
        required: true
        tier_gate: pro
      - slug: ops-metrics-basics
        path: pro/marketing/growth-marketer/ops-metrics-basics
        required: true
        tier_gate: pro
    outputs:
      - "Churn cause doc"
      - "3 retention levers shipped"
    decision_gate: |
      Advance when monthly net revenue churn <3%. Stay if revenue leaking faster than acquisition fills.
  - name: "Scale channel"
    intent: "Compound the chosen channel: loops, referrals, content velocity."
    tasks:
      - "Build 1 growth loop on the chosen channel"
      - "Add referral incentive"
      - "Double content cadence"
    methodologies:
      - slug: growth-loops
        path: pro/marketing/growth-marketer/growth-loops
        required: true
        tier_gate: pro
      - slug: growth-referral-programs
        path: pro/marketing/growth-marketer/growth-referral-programs
        required: true
        tier_gate: pro
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
    outputs:
      - "Growth loop live"
      - "Referral mechanic"
    decision_gate: |
      Advance when MoM growth >15% for 2 consecutive months.
  - name: "Price"
    intent: "Optimise pricing for revenue-per-customer not signups."
    tasks:
      - "Audit current pricing tiers"
      - "Run 1 price experiment"
      - "Decide on subscription model"
    methodologies:
      - slug: ops-pricing-strategy
        path: solo/marketing/gtm-strategist/ops-pricing-strategy
        required: true
        tier_gate: solo
      - slug: ops-subscription-models
        path: solo/marketing/gtm-strategist/ops-subscription-models
        required: true
        tier_gate: solo
      - slug: pricing-research
        path: solo/research/market-researcher/pricing-research
        required: true
        tier_gate: solo
    outputs:
      - "Pricing decision doc"
      - "1 experiment result"
    decision_gate: |
      Advance if price experiment improves revenue/customer ≥10% OR is conclusively rejected.
  - name: "Operate"
    intent: "Customer support + financial planning to sustain solo cadence."
    tasks:
      - "Set support SLA"
      - "Build runway calculation"
      - "Set MRR dashboard alerts"
    methodologies:
      - slug: ops-customer-support
        path: solo/marketing/gtm-strategist/ops-customer-support
        required: true
        tier_gate: solo
      - slug: ops-financial-planning
        path: solo/marketing/gtm-strategist/ops-financial-planning
        required: true
        tier_gate: solo
      - slug: portfolio-strategy
        path: pro/product/product-planning/portfolio-strategy
        required: true
        tier_gate: pro
    outputs:
      - "Support SLA doc"
      - "Runway calculation"
      - "MRR dashboard"
    decision_gate: |
      Advance when ops cadence is sustainable (no operator burnout).
  - name: "Decide"
    intent: "$4K MRR hit OR honest sunset."
    tasks:
      - "Compile MRR trajectory + runway"
      - "Write quit-day-job contract or sunset note"
    methodologies:
      []
    outputs:
      - "Decision doc"
    decision_gate: |
      Required output: written decision. $4K reached = quit-day-job. Plateau = sunset or pivot.

common_pitfalls:
  - "Spreading across 4 channels because none works after a month — usually means 90 days hadn't passed"
  - "Treating $4K as quitting moment without runway buffer — keep 6 months runway in the contract"

quality_checklist:
  - "Did I actually commit to ONE channel, or did I just write that I would?"
  - "Is the MRR dashboard checked weekly, or only when I feel anxious?"

related_playbooks:
  - solo-idea-to-validated-mvp
  - pmf-hunt-post-mvp

token_budget_estimate: 18000
cli_invocations:
  human:  "faion get-content bootstrap-to-4k-mrr --format md"
  agent:  "faion get-content bootstrap-to-4k-mrr --format context"
  json:   "faion get-content bootstrap-to-4k-mrr --format json"

changelog:
