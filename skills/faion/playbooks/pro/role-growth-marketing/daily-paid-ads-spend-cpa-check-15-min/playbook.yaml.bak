    expected_tier: pro
    blocks_stage: 1
    note: "Methodology stub referenced by daily-paid-ads-spend-cpa-check-15-min; author under knowledge/pro/..."
  - methodology_slug: cross-channel-cpa-rollup
    expected_tier: pro
    blocks_stage: 1
    note: "Methodology stub referenced by daily-paid-ads-spend-cpa-check-15-min; author under knowledge/pro/..."
