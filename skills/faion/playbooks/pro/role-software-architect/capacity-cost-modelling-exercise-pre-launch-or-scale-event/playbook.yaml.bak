# =============================================================================
# faion playbook manifest — chunk-06 (role-software-architect)
# =============================================================================

slug: capacity-cost-modelling-exercise-pre-launch-or-scale-event
title: "Capacity + cost-modelling exercise (pre-launch or scale-event)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 3b13bbdc0a00845a

tier_min: pro
complexity: medium
context: [solo, team]
persona: "software architect"
group: role-software-architect

intent: |
  Take an software architect from the trigger condition described in this playbook to the documented outcome, with every decision gate met in writing.

scope: |
  Build a defensible capacity + cost projection ahead of a launch / migration / scale event. Done = capacity model with 3 traffic scenarios, cost model tied to cloud price sheet, recommended rightsizing actions, and a finance sign-off.

summary: "Build a defensible capacity + cost projection ahead of a launch / migration / scale event. Done = capacity model with 3 traffic scenarios, cost model tied to cloud price sheet, recommended rightsizing actions, and a finance sign-off."

success_criteria:
  - "Capacity + cost-modelling exercise (pre-launch or scale-event) ships with written success criteria met and evidence attached"
  - "Baseline → post-change metric delta recorded against the relevant quality attribute"
  - "Rollback path rehearsed at least once and documented in the runbook"
  - "Decision doc (continue / iterate / revert) signed off by named owner"

methodology_refs:
  - pro/dev/software-architect/quality-attributes-analysis
  - pro/dev/software-architect/reliability-architecture
  - pro/infra/cicd-engineer/finops-cost-visibility
  - pro/infra/devops-engineer/finops
  - pro/infra/devops-engineer/finops-devops-cost-alerts
  - pro/infra/devops-engineer/finops-devops-cost-commitments
  - pro/infra/devops-engineer/finops-devops-cost-rightsizing
  - pro/infra/devops-engineer/finops-devops-cost-tagging
  - pro/infra/infrastructure-engineer/aws-cost-optimization
  - pro/infra/infrastructure-engineer/aws-well-architected-framework
  - pro/infra/infrastructure-engineer/k8s-scaling-availability
  - solo/dev/software-architect/architecture-decision-records
  - solo/dev/software-architect/caching-architecture
  - solo/dev/software-architect/performance-architecture
  - solo/dev/software-architect/trade-off-build-vs-buy

stages:
  - name: "Frame"
    intent: "Name the problem in writing and set explicit success criteria."
    tasks:
      - "Write a one-paragraph problem statement tied to a quality attribute or user outcome"
      - "List concrete success criteria (measurable, observable, time-bounded)"
      - "Identify the smallest credible scope that still moves the needle"
    methodologies:
      - slug: quality-attributes-analysis
        path: pro/dev/software-architect/quality-attributes-analysis
        required: true
        tier_gate: pro
      - slug: finops-devops-cost-rightsizing
        path: pro/infra/devops-engineer/finops-devops-cost-rightsizing
        required: true
        tier_gate: pro
      - slug: caching-architecture
        path: solo/dev/software-architect/caching-architecture
        required: true
        tier_gate: solo
    outputs:
      - "Problem brief"
      - "Success-criteria list"
      - "Scope boundary"
    decision_gate: |
      Advance only after a peer can restate the problem in their own words and agree the criteria are testable.
  - name: "Assess"
    intent: "Inventory current state vs target with evidence, not opinion."
    tasks:
      - "Run a structured assessment of the affected system (code, tests, docs, ops surface)"
      - "Capture baseline metrics that the work will need to beat"
      - "List the top 5 risks and one mitigation per risk"
    methodologies:
      - slug: reliability-architecture
        path: pro/dev/software-architect/reliability-architecture
        required: true
        tier_gate: pro
      - slug: finops-devops-cost-tagging
        path: pro/infra/devops-engineer/finops-devops-cost-tagging
        required: true
        tier_gate: pro
      - slug: performance-architecture
        path: solo/dev/software-architect/performance-architecture
        required: true
        tier_gate: solo
    outputs:
      - "Current-state inventory"
      - "Baseline metrics"
      - "Risk register"
    decision_gate: |
      Advance only when baselines are recorded and risks have owners.
  - name: "Plan"
    intent: "Decompose into a sequenced backlog with explicit decision points."
    tasks:
      - "Break the work into tasks of ≤1 day each, with dependencies named"
      - "Mark reversible vs irreversible (one-way-door) decisions"
      - "Define rollback / kill conditions for each major step"
    methodologies:
      - slug: finops-cost-visibility
        path: pro/infra/cicd-engineer/finops-cost-visibility
        required: true
        tier_gate: pro
      - slug: aws-cost-optimization
        path: pro/infra/infrastructure-engineer/aws-cost-optimization
        required: true
        tier_gate: pro
      - slug: trade-off-build-vs-buy
        path: solo/dev/software-architect/trade-off-build-vs-buy
        required: true
        tier_gate: solo
    outputs:
      - "Task plan"
      - "Decision log skeleton"
      - "Rollback playbook"
    decision_gate: |
      Advance only when every task has a definition-of-done and the plan fits on one page.
  - name: "Execute"
    intent: "Ship the change behind safe deployment controls."
    tasks:
      - "Implement the plan in small, individually shippable steps"
      - "Keep all changes behind feature flags or branch-by-abstraction where reversible"
      - "Update tests + docs in the same change set, never as a follow-up"
    methodologies:
      - slug: finops
        path: pro/infra/devops-engineer/finops
        required: true
        tier_gate: pro
      - slug: aws-well-architected-framework
        path: pro/infra/infrastructure-engineer/aws-well-architected-framework
        required: true
        tier_gate: pro
    outputs:
      - "Shipped change set"
      - "Updated tests + docs"
    decision_gate: |
      Advance only when CI is green, the change is observable in staging, and rollback was rehearsed at least once.
  - name: "Verify"
    intent: "Prove the change cleared the success criteria with evidence."
    tasks:
      - "Run targeted tests + smoke on the most-trafficked surfaces"
      - "Compare post-change metrics against the baseline captured earlier"
      - "Capture user / operator feedback within the first 48 hours"
    methodologies:
      - slug: finops-devops-cost-alerts
        path: pro/infra/devops-engineer/finops-devops-cost-alerts
        required: true
        tier_gate: pro
      - slug: k8s-scaling-availability
        path: pro/infra/infrastructure-engineer/k8s-scaling-availability
        required: true
        tier_gate: pro
    outputs:
      - "Verification report"
      - "Metric delta vs baseline"
    decision_gate: |
      Advance only when metrics meet the criteria and no regression alerts are open.
  - name: "Close"
    intent: "Lock in the gain: documentation, learnings, and a single decision artifact."
    tasks:
      - "Write the decision / outcome doc (continue / iterate / revert) with evidence trail"
      - "Update ADRs, runbooks, and pattern memory with what changed"
      - "Schedule the next review checkpoint or archive the workstream"
    methodologies:
      - slug: finops-devops-cost-commitments
        path: pro/infra/devops-engineer/finops-devops-cost-commitments
        required: true
        tier_gate: pro
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: solo
    outputs:
      - "Decision doc"
      - "Updated ADR / runbook / memory entry"
    decision_gate: |
      Done when the decision doc is single-link shareable and the team can name the next checkpoint.

common_pitfalls:
  - "Skipping the Frame stage and starting work without written success criteria"
  - "Treating the rollback as a doc, not a rehearsed action"
  - "Cutting the Close / decision-doc stage when the work feels obvious — that is when memory rots fastest"

quality_checklist:
  - "Can a peer restate the problem, criteria, and decision rule without me in the room?"
  - "Are the baseline metrics recorded somewhere I can grep, not just in chat?"
  - "Did we actually rehearse the rollback, or did we just talk about it?"

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content capacity-cost-modelling-exercise-pre-launch-or-scale-event --format md"
  agent:  "faion get-content capacity-cost-modelling-exercise-pre-launch-or-scale-event --format context"
  json:   "faion get-content capacity-cost-modelling-exercise-pre-launch-or-scale-event --format json"

