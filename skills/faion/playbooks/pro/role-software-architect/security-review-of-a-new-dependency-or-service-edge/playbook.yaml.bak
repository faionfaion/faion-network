# =============================================================================
# faion playbook manifest — chunk-06 (role-software-architect)
# =============================================================================

slug: security-review-of-a-new-dependency-or-service-edge
title: "Security review of a new dependency or service edge"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: e39247d08fbb0153

tier_min: pro
complexity: medium
context: [solo, team]
persona: "software architect"
group: role-software-architect

intent: |
  Take an software architect from the trigger condition described in this playbook to the documented outcome, with every decision gate met in writing.

scope: |
  Done = a new external surface (lib, integration, public endpoint) is reviewed for STRIDE-style threats, secret-handling, authn/z model, and supply-chain provenance; either ships with mitigations + owner or is blocked.

summary: "Done = a new external surface (lib, integration, public endpoint) is reviewed for STRIDE-style threats, secret-handling, authn/z model, and supply-chain provenance; either ships with mitigations + owner or is blocked."

success_criteria:
  - "Security review of a new dependency or service edge ships with written success criteria met and evidence attached"
  - "Baseline → post-change metric delta recorded against the relevant quality attribute"
  - "Rollback path rehearsed at least once and documented in the runbook"
  - "Decision doc (continue / iterate / revert) signed off by named owner"

methodology_refs:
  - geek/sdlc-ai/sec-codeql-autofix-on-pr
  - geek/sdlc-ai/sec-secrets-defense-in-depth
  - geek/sdlc-ai/sec-trivy-pinned-supply-chain-scan
  - solo/dev/software-architect/security-architecture

stages:
  - name: "Frame"
    intent: "Name the problem in writing and set explicit success criteria."
    tasks:
      - "Write a one-paragraph problem statement tied to a quality attribute or user outcome"
      - "List concrete success criteria (measurable, observable, time-bounded)"
      - "Identify the smallest credible scope that still moves the needle"
    methodologies:
      - slug: sec-codeql-autofix-on-pr
        path: geek/sdlc-ai/sec-codeql-autofix-on-pr
        required: true
        tier_gate: geek
    outputs:
      - "Problem brief"
      - "Success-criteria list"
      - "Scope boundary"
    decision_gate: |
      Advance only after a peer can restate the problem in their own words and agree the criteria are testable.
  - name: "Assess"
    intent: "Inventory current state vs target with evidence, not opinion."
    tasks:
      - "Run a structured assessment of the affected system (code, tests, docs, ops surface)"
      - "Capture baseline metrics that the work will need to beat"
      - "List the top 5 risks and one mitigation per risk"
    methodologies:
      - slug: sec-secrets-defense-in-depth
        path: geek/sdlc-ai/sec-secrets-defense-in-depth
        required: true
        tier_gate: geek
    outputs:
      - "Current-state inventory"
      - "Baseline metrics"
      - "Risk register"
    decision_gate: |
      Advance only when baselines are recorded and risks have owners.
  - name: "Plan"
    intent: "Decompose into a sequenced backlog with explicit decision points."
    tasks:
      - "Break the work into tasks of ≤1 day each, with dependencies named"
      - "Mark reversible vs irreversible (one-way-door) decisions"
      - "Define rollback / kill conditions for each major step"
    methodologies:
      - slug: sec-trivy-pinned-supply-chain-scan
        path: geek/sdlc-ai/sec-trivy-pinned-supply-chain-scan
        required: true
        tier_gate: geek
    outputs:
      - "Task plan"
      - "Decision log skeleton"
      - "Rollback playbook"
    decision_gate: |
      Advance only when every task has a definition-of-done and the plan fits on one page.
  - name: "Execute"
    intent: "Ship the change behind safe deployment controls."
    tasks:
      - "Implement the plan in small, individually shippable steps"
      - "Keep all changes behind feature flags or branch-by-abstraction where reversible"
      - "Update tests + docs in the same change set, never as a follow-up"
    methodologies:
      - slug: security-architecture
        path: solo/dev/software-architect/security-architecture
        required: true
        tier_gate: solo
    outputs:
      - "Shipped change set"
      - "Updated tests + docs"
    decision_gate: |
      Advance only when CI is green, the change is observable in staging, and rollback was rehearsed at least once.
  - name: "Verify"
    intent: "Prove the change cleared the success criteria with evidence."
    tasks:
      - "Run targeted tests + smoke on the most-trafficked surfaces"
      - "Compare post-change metrics against the baseline captured earlier"
      - "Capture user / operator feedback within the first 48 hours"
    methodologies:
      - slug: sec-codeql-autofix-on-pr
        path: geek/sdlc-ai/sec-codeql-autofix-on-pr
        required: true
        tier_gate: geek
    outputs:
      - "Verification report"
      - "Metric delta vs baseline"
    decision_gate: |
      Advance only when metrics meet the criteria and no regression alerts are open.
  - name: "Close"
    intent: "Lock in the gain: documentation, learnings, and a single decision artifact."
    tasks:
      - "Write the decision / outcome doc (continue / iterate / revert) with evidence trail"
      - "Update ADRs, runbooks, and pattern memory with what changed"
      - "Schedule the next review checkpoint or archive the workstream"
    methodologies:
      - slug: sec-codeql-autofix-on-pr
        path: geek/sdlc-ai/sec-codeql-autofix-on-pr
        required: true
        tier_gate: geek
    outputs:
      - "Decision doc"
      - "Updated ADR / runbook / memory entry"
    decision_gate: |
      Done when the decision doc is single-link shareable and the team can name the next checkpoint.

common_pitfalls:
  - "Skipping the Frame stage and starting work without written success criteria"
  - "Treating the rollback as a doc, not a rehearsed action"
  - "Cutting the Close / decision-doc stage when the work feels obvious — that is when memory rots fastest"

quality_checklist:
  - "Can a peer restate the problem, criteria, and decision rule without me in the room?"
  - "Are the baseline metrics recorded somewhere I can grep, not just in chat?"
  - "Did we actually rehearse the rollback, or did we just talk about it?"

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content security-review-of-a-new-dependency-or-service-edge --format md"
  agent:  "faion get-content security-review-of-a-new-dependency-or-service-edge --format context"
  json:   "faion get-content security-review-of-a-new-dependency-or-service-edge --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059-063 chunk-06 for role-software-architect (atomic angle)."

