# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: proposal-customization-from-base-template
title: "Proposal customization from base template"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 37caa2402eece84f

tier_min: pro
complexity: medium
context: [solo, team]
persona_hints: [P5]

intent: |
  Qualified discovery call to scoped proposal + SOW + price, sent within one working day of decision.

scope: |
  Founder turns a qualified discovery call into a sent proposal. Output: scoped proposal + SOW + price, sent within working day of decision. Exit artifact: signed-or-pending proposal in the deal record.

non_goals:
  - "Multi-vendor RFP responses - separate workflow"
  - "Free 'spec work' proposals - never offered"

prerequisites:
  - "Discovery verdict = 'propose'"
  - "Versioned base proposal template"

success_criteria:
  - "Proposal personalized to lead's pain map"
  - "Outcome-anchored pricing (not hours)"
  - "SOW non-goals explicit"
  - "Sent within 24h of discovery verdict"
  - "Objection FAQ block included"

stages:
  - name: "Scope shaping"
    intent: "Convert pain map into priced outcomes."
    tasks:
      - "Prioritize must-have outcomes"
      - "Score solution options against value"
      - "Lock 3 explicit non-goals"
    methodologies:
      - slug: requirements-prioritization
        path: pro/ba/business-analyst/requirements-prioritization
        required: true
        tier_gate: pro
      - slug: solution-assessment
        path: pro/ba/business-analyst/solution-assessment
        required: true
        tier_gate: pro
    outputs:
      - "Scope decision doc"
    decision_gate: |
      Advance with scope on one page + non-goals.
  - name: "Price"
    intent: "Outcome-anchored, defensible price."
    tasks:
      - "Pick fixed / tiered / retainer model"
      - "Set price against value not hours"
      - "Add an upsell tier intentionally"
    methodologies:
      - slug: ops-upselling-cross-selling
        path: pro/marketing/gtm-strategist/ops-upselling-cross-selling
        required: true
        tier_gate: pro
      - slug: ops-pricing-strategy
        path: solo/marketing/gtm-strategist/ops-pricing-strategy
        required: true
        tier_gate: solo
    outputs:
      - "Price card + tiers"
    decision_gate: |
      Advance when price is defensible without quoting hours.
  - name: "Customize template"
    intent: "Personalize hero, results section, FAQ to this lead."
    tasks:
      - "Adapt hero + summary to lead's words"
      - "Drop 2 case studies in same niche"
      - "Add objection FAQ block"
    methodologies:
      - slug: business-storytelling
        path: solo/comms/communicator/business-storytelling
        required: true
        tier_gate: solo
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: solo
    outputs:
      - "Customized proposal doc"
    decision_gate: |
      Advance once draft passes 'a stranger could follow this' test.
  - name: "Send + log"
    intent: "Within 24h of discovery verdict; calendar the follow-up."
    tasks:
      - "Send via email + sales tool"
      - "Calendar follow-up call in 3 days"
      - "Log in pipeline with stage + reason"
    methodologies: []
    outputs:
      - "Sent proposal"
      - "Follow-up call booked"
    decision_gate: |
      Required: sent within 24h. If late, flag root cause.

common_pitfalls:
  - "Padding the scope because the proposal feels 'too short'"
  - "Quoting hours - invites scope creep and locks margin"
  - "Sending without an explicit follow-up plan"

quality_checklist:
  - "Is the proposal personalized in the lead's language?"
  - "Does the price defend itself without hours?"
  - "Did I send within 24h, or did I drift?"

related_playbooks:
  - discovery-call-run-45-min
  - inbound-lead-to-signed-retainer

token_budget_estimate: 8000
cli_invocations:
  human:  "faion get-content proposal-customization-from-base-template --format md"
  agent:  "faion get-content proposal-customization-from-base-template --format context"
  json:   "faion get-content proposal-customization-from-base-template --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: proposal-template-micro-agency-tiered
    expected_tier: pro
    blocks_stage: 3
    note: "Customize-template stage needs a tiered proposal template"
  - methodology_slug: objection-faq-library
    expected_tier: pro
    blocks_stage: 3
    note: "Customize-template stage needs a reusable objection FAQ library"
  - methodology_slug: scoping-workshop
    expected_tier: pro
    blocks_stage: 1
    note: "Scope-shaping stage references scoping-workshop playbook not yet ported to v2 manifest"
  - methodology_slug: statement-of-work
    expected_tier: pro
    blocks_stage: 2
    note: "Price stage references statement-of-work playbook not yet ported to v2 manifest"
