# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: quarter-end-retention-review
title: "Quarter-end retention review (QBR cycle, 4 weeks)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 49d9987e2e0d682c

tier_min: pro
complexity: medium
context: [solo, team]
persona_hints: [P5]

intent: |
  End of quarter to per-account next-quarter plan, 3 upsell targets, churn-risk list with mitigation, and a refreshed reference pool.

scope: |
  Across the active book of clients, run a structured quarterly business review that surfaces churn risk, upsell, and reference opportunities. Outputs: per-account next-quarter plan, three upsell targets, churn-risk list with mitigation, and a refreshed reference pool. Exit artifact: QBR pack per account + portfolio dashboard row updated for the quarter.

non_goals:
  - "Annual planning - separate playbook"
  - "New-business pipeline review - distinct cadence"

prerequisites:
  - "Active retainer + project book of 3+ clients"
  - "Basic delivery + outcome metrics already captured per account"

success_criteria:
  - "Account health scored for every active client"
  - "Churn-risk list with mitigation owner per account"
  - "3 upsell targets with concrete next step"
  - "Refreshed reference pool"
  - "Per-account next-quarter plan signed by client"
  - "Portfolio dashboard updated"

stages:
  - name: "Score health"
    intent: "Cohort + outcome data to account health score per client."
    tasks:
      - "Pull cohort + retention data"
      - "Score each account on health rubric"
      - "Tag risk + upsell candidates"
    methodologies:
      - slug: cohort-implementation
        path: pro/marketing/growth-marketer/cohort-implementation
        required: true
        tier_gate: pro
      - slug: ops-churn-basics
        path: pro/marketing/growth-marketer/ops-churn-basics
        required: true
        tier_gate: pro
      - slug: retention-metrics
        path: pro/marketing/growth-marketer/retention-metrics
        required: true
        tier_gate: pro
      - slug: ops-customer-success-metrics
        path: pro/marketing/gtm-strategist/ops-customer-success-metrics
        required: true
        tier_gate: pro
    outputs:
      - "Account-health table"
      - "Risk + upsell tags"
    decision_gate: |
      Advance once every account has a numeric health score.
  - name: "Prep QBR pack"
    intent: "Per-account: results, risks, options, asks."
    tasks:
      - "Draft QBR slides per account"
      - "Capture wins + benefits realized"
      - "List 3 next-quarter options"
    methodologies:
      - slug: benefits-realization
        path: pro/pm/project-manager/benefits-realization
        required: true
        tier_gate: pro
      - slug: feedback-management
        path: pro/product/product-manager/feedback-management
        required: true
        tier_gate: pro
      - slug: ops-customer-success-basics
        path: pro/marketing/gtm-strategist/ops-customer-success-basics
        required: true
        tier_gate: pro
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: solo
    outputs:
      - "QBR pack per account"
    decision_gate: |
      Advance when every active account has a draft QBR pack.
  - name: "Run reviews"
    intent: "45-min QBR per account; capture renewal + upsell signal."
    tasks:
      - "Schedule QBR with each sponsor"
      - "Run 45-min meeting against pack"
      - "Capture next-quarter commitments in writing"
    methodologies:
      - slug: stakeholder-register
        path: pro/pm/project-manager/stakeholder-register
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement-advanced
        path: pro/pm/project-manager/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
      - slug: ops-upselling-cross-selling
        path: pro/marketing/gtm-strategist/ops-upselling-cross-selling
        required: true
        tier_gate: pro
    outputs:
      - "Per-account next-quarter plan"
      - "Upsell + reference signals"
    decision_gate: |
      Advance once every QBR meeting held OR formally declined.
  - name: "Plan + close out"
    intent: "Portfolio view: who renews, who churns, who upsells."
    tasks:
      - "Mitigate churn risks with owners"
      - "Schedule upsell follow-ups"
      - "Refresh reference pool"
    methodologies:
      - slug: ops-churn-prevention
        path: pro/marketing/growth-marketer/ops-churn-prevention
        required: true
        tier_gate: pro
      - slug: retention-strategies
        path: pro/marketing/growth-marketer/retention-strategies
        required: true
        tier_gate: pro
      - slug: ops-annual-planning-process
        path: pro/marketing/gtm-strategist/ops-annual-planning-process
        required: true
        tier_gate: pro
      - slug: ops-annual-planning-templates
        path: pro/marketing/gtm-strategist/ops-annual-planning-templates
        required: true
        tier_gate: pro
      - slug: project-closure
        path: pro/pm/project-manager/project-closure
        required: true
        tier_gate: pro
      - slug: portfolio-strategy
        path: pro/product/product-manager/portfolio-strategy
        required: true
        tier_gate: pro
      - slug: portfolio-strategy
        path: pro/product/product-planning/portfolio-strategy
        required: true
        tier_gate: pro
    outputs:
      - "Portfolio dashboard updated"
      - "Churn-mitigation actions live"
    decision_gate: |
      Required output: written next-quarter plan per account + portfolio dashboard refreshed.

common_pitfalls:
  - "Treating QBR as a status report instead of a renewal + upsell conversation"
  - "Skipping the QBR for 'happy' accounts - those are the ones to upsell"
  - "No written next-quarter plan = no contract for the next 90 days"

quality_checklist:
  - "Does every account have a numeric health score?"
  - "Did I leave each QBR with at least one client commitment?"
  - "Is the reference pool refreshed every quarter?"

related_playbooks:
  - quarterly-retainer-review-per-client
  - annual-planning-and-financial-close

token_budget_estimate: 16000
cli_invocations:
  human:  "faion get-content quarter-end-retention-review --format md"
  agent:  "faion get-content quarter-end-retention-review --format context"
  json:   "faion get-content quarter-end-retention-review --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

