    expected_tier: pro
    blocks_stage: 2
    note: "Prep-QBR-pack stage needs a default deck template for services QBR"
  - methodology_slug: account-health-scoring-model
    expected_tier: pro
    blocks_stage: 1
    note: "Score-health stage needs an explicit numeric scoring model"
  - methodology_slug: graceful-offboard-script
    expected_tier: pro
    blocks_stage: 4
    note: "Plan-and-close-out stage needs a script for graceful churn offboarding"
  - methodology_slug: reference-program-playbook
    expected_tier: pro
