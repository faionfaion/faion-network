# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: discovery-call-run-45-min
title: "Discovery call run (45 min)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: c0cf3fc3c0a38ca8

tier_min: pro
complexity: medium
context: [solo, team]
persona_hints: [P5]

intent: |
  Qualified lead to 45-min discovery call yielding qualified-or-disqualified verdict + pain map + budget signal + proposal go/no-go.

scope: |
  Founder runs a structured first call with a qualified lead. Output: qualified-or-disqualified decision, pain map, budget signal, proposal go/no-go. Exit artifact: discovery notes + verdict + next action booked.

non_goals:
  - "Full requirements elicitation - happens post-signature"
  - "Demo / pitch deck - distinct call type"

prerequisites:
  - "Lead passed triage with ICP fit signal"
  - "Pre-call form returned with 3 baseline questions"

success_criteria:
  - "45-min run-of-show followed"
  - "Pain map captured in 3 layers (symptom, cause, cost)"
  - "Budget signal explicit (not 'depends')"
  - "Decision-maker + signoff path identified"
  - "Verdict written: proposal / kill / clarify"

stages:
  - name: "Open + frame"
    intent: "5 min - set the agenda, the rules, the time."
    tasks:
      - "State call objective + time"
      - "Confirm decision context"
      - "Ask what success looks like at end of call"
    methodologies:
      - slug: active-listening
        path: solo/comms/communicator/active-listening
        required: true
        tier_gate: solo
    outputs:
      - "Confirmed agenda"
    decision_gate: |
      Advance once lead confirms agenda and timing.
  - name: "Pain map"
    intent: "25 min - symptom, cause, cost, history."
    tasks:
      - "Use Mom-Test framing"
      - "Map symptom to cause to cost"
      - "Surface workarounds + prior attempts"
    methodologies:
      - slug: elicitation-techniques
        path: pro/ba/business-analyst/elicitation-techniques
        required: true
        tier_gate: pro
      - slug: stakeholder-analysis
        path: pro/ba/business-analyst/stakeholder-analysis
        required: true
        tier_gate: pro
      - slug: mom-test
        path: solo/comms/communicator/mom-test
        required: true
        tier_gate: solo
    outputs:
      - "Pain map notes"
    decision_gate: |
      Advance if dominant pain is clearly articulated with cost.
  - name: "Budget + decision"
    intent: "10 min - concrete budget + signoff path."
    tasks:
      - "Ask budget range explicitly"
      - "Identify decision-maker + influencers"
      - "Surface alternative solutions considered"
    methodologies:
      - slug: growth-gtm-strategy
        path: pro/marketing/gtm-strategist/growth-gtm-strategy
        required: true
        tier_gate: pro
      - slug: competitive-intelligence
        path: pro/research/market-researcher/competitive-intelligence
        required: true
        tier_gate: pro
      - slug: selling-ideas
        path: solo/comms/communicator/selling-ideas
        required: true
        tier_gate: solo
    outputs:
      - "Budget signal"
      - "Decision-maker map"
    decision_gate: |
      Advance only with explicit budget range AND signoff path.
  - name: "Verdict + next step"
    intent: "5 min - propose / kill / clarify, in writing same day."
    tasks:
      - "Score against qualification rubric"
      - "Book next step OR send polite decline"
      - "Log verdict in pipeline"
    methodologies: []
    outputs:
      - "Verdict doc"
      - "Next step booked"
    decision_gate: |
      Required: written verdict + sent follow-up within same day.

common_pitfalls:
  - "Pitching during discovery - converts learning into selling and breaks rapport"
  - "Skipping budget because 'it is awkward' - bites at proposal time"
  - "Not writing the verdict same day - memory degrades fast"

quality_checklist:
  - "Did I learn or did I sell?"
  - "Is the pain map sourced from the lead's words, not my framing?"
  - "Did I write a verdict before opening Slack?"

related_playbooks:
  - proposal-customization-from-base-template
  - inbound-lead-to-signed-retainer

token_budget_estimate: 8000
cli_invocations:
  human:  "faion get-content discovery-call-run-45-min --format md"
  agent:  "faion get-content discovery-call-run-45-min --format context"
  json:   "faion get-content discovery-call-run-45-min --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: agency-discovery-call-scorecard
    expected_tier: pro
    blocks_stage: 4
    note: "Verdict stage needs a scorecard for proposal/kill decision"
  - methodology_slug: founder-led-qualification-rubric
    expected_tier: pro
    blocks_stage: 4
    note: "Verdict stage needs an explicit qualification rubric"
  - methodology_slug: discovery-call-structure
    expected_tier: pro
    blocks_stage: 2
    note: "Pain-map stage references discovery-call-structure playbook not yet ported to v2 manifest"
