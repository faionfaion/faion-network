# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #11
# =============================================================================

slug: proposal-from-discovery-notes
title: "Proposal draft from discovery notes"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: f05b65565e425fbc

tier_min: pro
complexity: medium
context: [solo]
persona_hints: [P3]

intent: |
  From a qualified-yes discovery, produce a short proposal (1-3 pages) the client can sign within a week. Done = proposal sent, follow-up cadence scheduled, win/loss reason recorded.

scope: |
  From a qualified-yes discovery, produce a short proposal (1-3 pages) the client can sign within a week. Done = proposal sent, follow-up cadence scheduled, win/loss reason recorded.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Structure stage complete: Proposal outline"
  - "Price + risk stage complete: Pricing breakdown"
  - "Send + follow-up stage complete: Proposal sent log"

stages:
  - name: "Structure"
    intent: "Translate discovery notes into proposal sections."
    tasks:
      - "Extract 3 acceptance criteria from discovery"
      - "Pick proposal length (1, 2, or 3 pages)"
      - "Sketch sections: problem, scope, price, timeline, terms"
    methodologies:
      - slug: acceptance-criteria
        path: pro/ba/business-analyst/acceptance-criteria
        required: true
        tier_gate: pro
      - slug: scope-management
        path: pro/pm/project-manager/scope-management
        required: true
        tier_gate: pro
      - slug: wbs-creation
        path: pro/pm/project-manager/wbs-creation
        required: true
        tier_gate: pro
    outputs:
      - "Proposal outline"
    decision_gate: |
      Advance only when outline maps to specific discovery quotes.
  - name: "Price + risk"
    intent: "Set price using rate floor + risk uplift; surface terms upfront."
    tasks:
      - "Calculate cost estimate (fixed or T&M)"
      - "Add risk uplift per identified unknown"
      - "Define payment terms + deposit"
    methodologies:
      - slug: ops-legal-basics
        path: pro/marketing/gtm-strategist/ops-legal-basics
        required: true
        tier_gate: pro
      - slug: cost-estimation
        path: pro/pm/project-manager/cost-estimation
        required: true
        tier_gate: pro
      - slug: risk-management
        path: pro/pm/project-manager/risk-management
        required: true
        tier_gate: pro
      - slug: freelancer-proposal-template-fixed-vs-tm
        path: pro/_gap/freelancer-proposal-template-fixed-vs-tm
        required: true
        tier_gate: pro
      - slug: solo-rate-floor-calculator
        path: pro/_gap/solo-rate-floor-calculator
        required: true
        tier_gate: pro
    outputs:
      - "Pricing breakdown"
      - "Terms section drafted"
    decision_gate: |
      Advance only when price ≥ rate floor and terms include deposit.
  - name: "Send + follow-up"
    intent: "Send within 48h, schedule follow-up, record outcome."
    tasks:
      - "Send proposal with read-receipt or doc analytics"
      - "Schedule follow-up day-3 and day-7"
      - "Record win/loss reason regardless of outcome"
    methodologies:
      - slug: selling-ideas
        path: solo/comms/communicator/selling-ideas
        required: true
        tier_gate: solo
    outputs:
      - "Proposal sent log"
      - "Follow-up calendar"
      - "Win/loss note"
    decision_gate: |
      Cycle closes only when win/loss reason recorded.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  []

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content proposal-from-discovery-notes --format md"
  agent:  "faion get-content proposal-from-discovery-notes --format context"
  json:   "faion get-content proposal-from-discovery-notes --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P3 technical-freelancer persona, atomic angle"

gaps:
  - methodology_slug: freelancer-proposal-template-fixed-vs-tm
    expected_tier: pro
    blocks_stage: 2
    note: "Stage 2 (Price + risk) references this; no methodology exists yet."
  - methodology_slug: solo-rate-floor-calculator
    expected_tier: pro
    blocks_stage: 2
    note: "Stage 2 (Price + risk) references this; no methodology exists yet."
