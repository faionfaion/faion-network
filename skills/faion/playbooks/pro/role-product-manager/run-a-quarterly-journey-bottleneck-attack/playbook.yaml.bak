# =============================================================================
# PLAYBOOK v2 — Run a quarterly journey-bottleneck attack
# Group: role-product-manager | Tier: pro | Complexity: medium
# =============================================================================

slug: run-a-quarterly-journey-bottleneck-attack
title: "Run a quarterly journey-bottleneck attack"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 9ae00fdf080c0e85

tier_min: pro
complexity: medium
context: ['solo', 'team']
persona: role-product-manager
group: role-product-manager

summary: "Instead of a roadmap drift through 'features stakeholders shouted loudest about', PM picks one customer journey, finds the worst bottleneck via funnel plus qualitative data, and runs a one-quarter focused attack."

intent: |
  Instead of a roadmap drift through 'features stakeholders shouted loudest about', PM picks one customer journey, finds the worst bottleneck via funnel plus qualitative data, and runs a one-quarter focused attack. Faion has no journey-mapping or bottleneck-prioritization methodology — this is a major team-PM gap.

scope: |
  Instead of a roadmap drift through 'features stakeholders shouted loudest about', PM picks one customer journey, finds the worst bottleneck via funnel plus qualitative data, and runs a one-quarter focused attack. Faion has no journey-mapping or bottleneck-prioritization methodology — this is a major team-PM gap.

methodology_refs:
  - pro/product/product-manager/continuous-discovery-habits
  - pro/product/product-manager/experimentation-at-scale
  - pro/product/product-manager/product-analytics
  - solo/product/product-manager/feature-prioritization-rice

success_criteria:
  - "One journey explicitly chosen; rest deprioritised"
  - "Quant bottleneck named with rate + absolute loss"
  - "Qual report converging on the cause"
  - "Quarter-end verdict on bottleneck conversion change"

stages:
  - name: "Pick the journey"
    intent: "Choose the single journey the quarter will attack."
    tasks:
      - "List 3-5 candidate journeys (activation, retention, expansion, etc.)"
      - "Pick the one tied to the active OKR"
      - "Lock the choice for the quarter"
    methodologies:
      - slug: product-analytics
        path: pro/product/product-manager/product-analytics
        required: true
        tier_gate: pro
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
    outputs:
      - "Chosen journey statement"
    decision_gate: "Advance when one journey is picked and the rest are explicitly deprioritised."
  - name: "Funnel scan"
    intent: "Find the quantitative bottleneck."
    tasks:
      - "Build the journey funnel with stage-by-stage conversion"
      - "Identify the lowest-converting stage"
      - "Confirm the stage matters (size × drop)"
    methodologies:
      - slug: product-analytics
        path: pro/product/product-manager/product-analytics
        required: true
        tier_gate: pro
    outputs:
      - "Funnel diagnostic"
    decision_gate: "Advance when the worst stage is named with both rate + absolute loss."
  - name: "Qual layer"
    intent: "Find the qualitative why behind the drop."
    tasks:
      - "Interview 5+ users who dropped at the bottleneck stage"
      - "Tag drop-off causes"
      - "Compare quant drop to qual causes for consistency"
    methodologies:
      - slug: continuous-discovery-habits
        path: pro/product/product-manager/continuous-discovery-habits
        required: true
        tier_gate: pro
    outputs:
      - "Qual report at the bottleneck stage"
    decision_gate: "Advance when 3+ users converge on the same cause."
  - name: "Attack design"
    intent: "Design the quarter's experiments."
    tasks:
      - "List 3-5 candidate interventions for the bottleneck"
      - "Rank by RICE"
      - "Schedule them as sequenced experiments across the quarter"
    methodologies:
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
      - slug: experimentation-at-scale
        path: pro/product/product-manager/experimentation-at-scale
        required: true
        tier_gate: pro
    outputs:
      - "Attack plan with sequenced experiments"
    decision_gate: "Advance when the attack plan has 3-5 ranked experiments with start dates."
  - name: "Read + decide"
    intent: "End the quarter with a verdict."
    tasks:
      - "Compare bottleneck conversion before vs after"
      - "Tag interventions as win / no-op / negative"
      - "Decide whether the journey gets a second quarter or releases attention"
    methodologies:
      - slug: product-analytics
        path: pro/product/product-manager/product-analytics
        required: true
        tier_gate: pro
      - slug: experimentation-at-scale
        path: pro/product/product-manager/experimentation-at-scale
        required: true
        tier_gate: pro
    outputs:
      - "Bottleneck attack verdict"
    decision_gate: "Required: a written verdict at quarter end."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content run-a-quarterly-journey-bottleneck-attack --format md"
  agent:  "faion get-content run-a-quarterly-journey-bottleneck-attack --format context"
  json:   "faion get-content run-a-quarterly-journey-bottleneck-attack --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
