slug: usability-test-cycle-end-to-end-3-weeks
title: "Usability test cycle, end-to-end (3 weeks)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 066234ac486ace97

tier: solo
tier_min: solo
group: role-ux-ui-designer
persona: Designer running a focused usability cycle on a defined feature
complexity: light
context: [solo, team]

summary: |
  Single round of moderated + unmoderated usability testing on a defined feature -> severity-ranked findings + design fixes scoped + follow-up validation plan.

intent: |
  Open usability question on a feature -> severity-ranked findings + scoped fixes + follow-up plan.

scope: |
  Designer runs one usability cycle across 3 weeks. Includes script + recruit, moderated + unmoderated sessions (5-6 each), AI-assisted analysis, severity-ranked findings, and a scoped fix list with follow-up plan. Done when fixes are queued with engineering and a follow-up test is planned for the next iteration.

success_criteria:
  - "5+ moderated + 5+ unmoderated sessions completed"
  - "Findings severity-ranked with rubric"
  - "Critical fixes scoped + queued with engineering"
  - "Follow-up validation plan written"

methodology_refs:
  - faion/knowledge/geek/ux/user-researcher/ai-interview-analysis
  - faion/knowledge/pro/ux/user-researcher/audience-segmentation
  - faion/knowledge/pro/ux/user-researcher/persona-building
  - faion/knowledge/solo/ux/user-researcher/success-metrics-definition
  - faion/knowledge/solo/ux/user-researcher/user-interviews-methods
  - faion/knowledge/solo/ux/ux-ui-designer/ab-testing
  - faion/knowledge/solo/ux/ux-ui-designer/heuristic-evaluation
  - faion/knowledge/solo/ux/ux-ui-designer/usability-testing
  - faion/knowledge/solo/ux/ux-ui-designer/user-interviews

stages:
  - name: "Plan"
    intent: "Lock the test plan before recruiting."
    tasks:
      - "Define test goals + success metrics"
      - "Build screener from audience segments + personas"
      - "Write test scripts per flow"
    methodologies:
      - slug: success-metrics-definition
        path: solo/ux/user-researcher/success-metrics-definition
        required: true
        tier_gate: solo
      - slug: audience-segmentation
        path: pro/ux/user-researcher/audience-segmentation
        required: true
        tier_gate: pro
      - slug: persona-building
        path: pro/ux/user-researcher/persona-building
        required: true
        tier_gate: pro
    outputs:
      - "Test plan + scripts"
    decision_gate: |
      Advance when plan + script are reviewed.
  - name: "Recruit"
    intent: "Recruit the right participants in time."
    tasks:
      - "Recruit 5-6 moderated participants"
      - "Launch unmoderated study with 8-10 panel users"
      - "Confirm consent + compensation"
    methodologies:
      - slug: audience-segmentation
        path: pro/ux/user-researcher/audience-segmentation
        required: true
        tier_gate: pro
    outputs:
      - "Recruited cohort + consent records"
    decision_gate: |
      Advance when target sample is locked.
  - name: "Moderated sessions"
    intent: "Talk-aloud sessions for depth."
    tasks:
      - "Run 5-6 moderated sessions"
      - "Capture task success/fail + observations"
      - "Same-day hot-take note per session"
    methodologies:
      - slug: usability-testing
        path: solo/ux/ux-ui-designer/usability-testing
        required: true
        tier_gate: solo
      - slug: user-interviews-methods
        path: solo/ux/user-researcher/user-interviews-methods
        required: true
        tier_gate: solo
      - slug: user-interviews
        path: solo/ux/ux-ui-designer/user-interviews
        required: true
        tier_gate: solo
    outputs:
      - "Session notes + hot takes"
    decision_gate: |
      Advance only when sessions are completed.
  - name: "Unmoderated study"
    intent: "Volume + behavior data."
    tasks:
      - "Run unmoderated study with timed tasks"
      - "Optional A/B on a contested decision"
      - "Cross-reference with heuristic evaluation"
    methodologies:
      - slug: usability-testing
        path: solo/ux/ux-ui-designer/usability-testing
        required: true
        tier_gate: solo
      - slug: ab-testing
        path: solo/ux/ux-ui-designer/ab-testing
        required: true
        tier_gate: solo
      - slug: heuristic-evaluation
        path: solo/ux/ux-ui-designer/heuristic-evaluation
        required: true
        tier_gate: solo
    outputs:
      - "Unmoderated results + A/B output"
    decision_gate: |
      Advance once unmoderated study is complete.
  - name: "AI-assisted analysis"
    intent: "Speed up coding without losing signal."
    tasks:
      - "Run AI transcript analysis"
      - "Human-validate codes"
      - "Apply severity rubric to findings"
    methodologies:
      - slug: ai-interview-analysis
        path: geek/ux/user-researcher/ai-interview-analysis
        required: true
        tier_gate: geek
    outputs:
      - "Severity-ranked findings list"
    decision_gate: |
      Advance only when severities are validated by a second eye.
  - name: "Scope fixes"
    intent: "Decide what gets fixed now vs later."
    tasks:
      - "Pair with engineering on fix scoping"
      - "Queue critical fixes in the backlog"
      - "Park lower-severity items with rationale"
    methodologies:
      - slug: usability-testing
        path: solo/ux/ux-ui-designer/usability-testing
        required: true
        tier_gate: solo
    outputs:
      - "Scoped fix list + parked items log"
    decision_gate: |
      Advance only when criticals are queued with engineering.
  - name: "Follow-up plan"
    intent: "Close the loop with a next test."
    tasks:
      - "Define the follow-up validation plan"
      - "Schedule the next test post-fix"
      - "Communicate findings to stakeholders"
    methodologies:
      - slug: success-metrics-definition
        path: solo/ux/user-researcher/success-metrics-definition
        required: true
        tier_gate: solo
    outputs:
      - "Follow-up plan filed + scheduled"
    decision_gate: |
      Done when next test is on the calendar.

common_pitfalls:
  - "Test script too long -> participants fatigue, signal drops"
  - "No severity rubric -> all findings feel equally urgent"
  - "No follow-up test -> fixes ship blind"

quality_checklist:
  - "Did critical findings get into the backlog?"
  - "Is the next test scheduled?"
  - "Did stakeholders hear the findings, not just read them?"

related_playbooks:
  - usability-test-moderation-single-session
  - heuristic-evaluation-on-a-new-screen-1hr

token_budget_estimate: 7000
cli_invocations:
  human:  "faion get-content usability-test-cycle-end-to-end-3-weeks --format md"
  agent:  "faion get-content usability-test-cycle-end-to-end-3-weeks --format context"
  json:   "faion get-content usability-test-cycle-end-to-end-3-weeks --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
