slug: inspiration-patterns-capture-30minweek
title: "Inspiration + patterns capture (30min/week)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 6ece9064ed7900a9

tier: solo
tier_min: solo
group: role-ux-ui-designer
persona: Designer maintaining a personal pattern bank
complexity: light
context: [solo, team]

summary: |
  Weekly intake of design patterns, competitor moves, new component libraries; filed by problem-space; one usable pattern queued for application this sprint.

intent: |
  Stale pattern bank -> 30-min weekly intake + filed + one usable pattern queued.

scope: |
  Designer runs a weekly 30-minute pattern capture. Includes browsing, evaluating, tagging, filing, and queuing a usable pattern for this sprint. Done when at least one pattern is filed with rationale and queued for application.

success_criteria:
  - "At least 1 new pattern filed with tags"
  - "Anti-patterns flagged with rationale"
  - "One usable pattern queued for this sprint"
  - "Pattern bank still findable (no junk drawer)"

methodology_refs:
  - faion/knowledge/geek/ux/ui-designer/figma-ai-ecosystem
  - faion/knowledge/solo/ux/ux-researcher/competitive-analysis
  - faion/knowledge/solo/ux/ux-ui-designer/aesthetic-minimalist
  - faion/knowledge/solo/ux/ux-ui-designer/competitive-analysis

stages:
  - name: "Browse"
    intent: "Cast the net but stay focused."
    tasks:
      - "Skim 3-5 inspiration sources"
      - "Note competitor moves"
      - "Capture screenshots of candidates"
    methodologies:
      - slug: competitive-analysis
        path: solo/ux/ux-researcher/competitive-analysis
        required: true
        tier_gate: solo
      - slug: competitive-analysis
        path: solo/ux/ux-ui-designer/competitive-analysis
        required: true
        tier_gate: solo
      - slug: figma-ai-ecosystem
        path: geek/ux/ui-designer/figma-ai-ecosystem
        required: true
        tier_gate: geek
    outputs:
      - "Candidate list"
    decision_gate: |
      Advance only with candidates captured.
  - name: "Evaluate"
    intent: "Decide what is signal vs noise."
    tasks:
      - "Filter candidates against problem-space tags"
      - "Note anti-patterns explicitly"
      - "Pick at most 3 to file"
    methodologies:
      - slug: aesthetic-minimalist
        path: solo/ux/ux-ui-designer/aesthetic-minimalist
        required: true
        tier_gate: solo
    outputs:
      - "Filtered shortlist"
    decision_gate: |
      Advance only when shortlist is <=3.
  - name: "File"
    intent: "Build a queryable bank."
    tasks:
      - "Tag each pattern by problem-space"
      - "Add a 1-line rationale"
      - "Link source + screenshot"
    methodologies:
      - slug: competitive-analysis
        path: solo/ux/ux-ui-designer/competitive-analysis
        required: true
        tier_gate: solo
    outputs:
      - "Filed pattern entries"
    decision_gate: |
      Advance only after tags are applied.
  - name: "Queue one"
    intent: "Inspiration becomes work."
    tasks:
      - "Pick the pattern most useful this sprint"
      - "Open a design ticket to apply it"
      - "Set a check-in for the result"
    methodologies:
      - slug: competitive-analysis
        path: solo/ux/ux-ui-designer/competitive-analysis
        required: true
        tier_gate: solo
    outputs:
      - "Queued ticket"
    decision_gate: |
      Done when ticket exists.

common_pitfalls:
  - "Capturing without tagging -> junk drawer"
  - "Capturing without applying -> no impact on work"
  - "Missing anti-patterns -> repeat them in your own work"

quality_checklist:
  - "Are tags consistent across entries?"
  - "Is one pattern actually applied this sprint?"
  - "Are anti-patterns flagged, not just admired?"

related_playbooks:
  - weekly-design-review-meeting-1hr

token_budget_estimate: 1800
cli_invocations:
  human:  "faion get-content inspiration-patterns-capture-30minweek --format md"
  agent:  "faion get-content inspiration-patterns-capture-30minweek --format context"
  json:   "faion get-content inspiration-patterns-capture-30minweek --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
  - methodology_slug: pattern-bank-tagging-schema
    expected_tier: solo
    blocks_stage: 3
    note: "Tagging schema template not yet authored."
  - methodology_slug: anti-pattern-rationale-template
    expected_tier: solo
    blocks_stage: 2
    note: "Anti-pattern rationale template not yet authored."
