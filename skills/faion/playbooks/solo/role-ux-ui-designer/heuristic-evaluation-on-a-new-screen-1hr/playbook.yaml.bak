slug: heuristic-evaluation-on-a-new-screen-1hr
title: "Heuristic evaluation on a new screen (1hr)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 16dba3e45e8f37c1

tier: solo
tier_min: solo
group: role-ux-ui-designer
persona: Designer running a heuristic eval on a new or changed screen
complexity: medium
context: [solo, team]

summary: |
  One screen scored against Nielsen's 10 heuristics plus a11y rules; severity-rated issue list ready for engineering and design follow-up.

intent: |
  New screen with no review -> severity-rated heuristic issues + ready for engineering follow-up.

scope: |
  Designer runs a 1-hour heuristic evaluation on one screen. Walks each of Nielsen's 10 heuristics + project a11y rules, captures issues with severity, and queues follow-ups. Done when the issue list has severities and the top-severity items are queued.

success_criteria:
  - "All 10 heuristics walked"
  - "Issues severity-rated with rubric"
  - "Top-severity items queued with engineering or design"
  - "Issue list filed in the repo"

methodology_refs:
  - faion/knowledge/pro/ux/ux-researcher/cog-walk-process
  - faion/knowledge/solo/ux/ux-ui-designer/aesthetic-minimalist
  - faion/knowledge/solo/ux/ux-ui-designer/consistency-standards
  - faion/knowledge/solo/ux/ux-ui-designer/error-prevention
  - faion/knowledge/solo/ux/ux-ui-designer/error-recovery
  - faion/knowledge/solo/ux/ux-ui-designer/flexibility-efficiency
  - faion/knowledge/solo/ux/ux-ui-designer/help-documentation
  - faion/knowledge/solo/ux/ux-ui-designer/heuristic-evaluation
  - faion/knowledge/solo/ux/ux-ui-designer/match-real-world
  - faion/knowledge/solo/ux/ux-ui-designer/recognition-over-recall
  - faion/knowledge/solo/ux/ux-ui-designer/user-control-freedom
  - faion/knowledge/solo/ux/ux-ui-designer/visibility-of-system-status

stages:
  - name: "Set context"
    intent: "Know the screen's purpose before grading."
    tasks:
      - "Note user role + task on this screen"
      - "Capture entry + exit points"
      - "Identify project-specific a11y rules to check"
    methodologies:
      - slug: heuristic-evaluation
        path: solo/ux/ux-ui-designer/heuristic-evaluation
        required: true
        tier_gate: solo
      - slug: cog-walk-process
        path: pro/ux/ux-researcher/cog-walk-process
        required: true
        tier_gate: pro
    outputs:
      - "Context note"
    decision_gate: |
      Advance only with context written.
  - name: "Walk core heuristics"
    intent: "Visibility, match, user-control, consistency."
    tasks:
      - "Check visibility of system status"
      - "Check match between system and real world"
      - "Check user control + freedom"
      - "Check consistency + standards"
    methodologies:
      - slug: visibility-of-system-status
        path: solo/ux/ux-ui-designer/visibility-of-system-status
        required: true
        tier_gate: solo
      - slug: match-real-world
        path: solo/ux/ux-ui-designer/match-real-world
        required: true
        tier_gate: solo
      - slug: user-control-freedom
        path: solo/ux/ux-ui-designer/user-control-freedom
        required: true
        tier_gate: solo
      - slug: consistency-standards
        path: solo/ux/ux-ui-designer/consistency-standards
        required: true
        tier_gate: solo
    outputs:
      - "Core heuristic notes"
    decision_gate: |
      Advance only after all 4 are walked.
  - name: "Walk error + memory heuristics"
    intent: "Prevention, recognition, flexibility."
    tasks:
      - "Check error prevention"
      - "Check recognition over recall"
      - "Check flexibility + efficiency"
      - "Check error recovery"
    methodologies:
      - slug: error-prevention
        path: solo/ux/ux-ui-designer/error-prevention
        required: true
        tier_gate: solo
      - slug: recognition-over-recall
        path: solo/ux/ux-ui-designer/recognition-over-recall
        required: true
        tier_gate: solo
      - slug: flexibility-efficiency
        path: solo/ux/ux-ui-designer/flexibility-efficiency
        required: true
        tier_gate: solo
      - slug: error-recovery
        path: solo/ux/ux-ui-designer/error-recovery
        required: true
        tier_gate: solo
    outputs:
      - "Error + memory notes"
    decision_gate: |
      Advance only after all 4 are walked.
  - name: "Walk aesthetic + help"
    intent: "Minimalism + help paths."
    tasks:
      - "Check aesthetic + minimalist design"
      - "Check help + documentation"
      - "Flag content + microcopy issues"
    methodologies:
      - slug: aesthetic-minimalist
        path: solo/ux/ux-ui-designer/aesthetic-minimalist
        required: true
        tier_gate: solo
      - slug: help-documentation
        path: solo/ux/ux-ui-designer/help-documentation
        required: true
        tier_gate: solo
    outputs:
      - "Aesthetic + help notes"
    decision_gate: |
      Advance only after both heuristics are walked.
  - name: "Score severity"
    intent: "Rank what needs to ship."
    tasks:
      - "Apply 0-4 severity rubric per issue"
      - "Add evidence references (screenshots / quotes)"
      - "Sort by severity"
    methodologies:
      - slug: heuristic-evaluation
        path: solo/ux/ux-ui-designer/heuristic-evaluation
        required: true
        tier_gate: solo
    outputs:
      - "Severity-ranked issue list"
    decision_gate: |
      Advance only when severities are assigned.
  - name: "Queue + file"
    intent: "Push top severities into the build queue."
    tasks:
      - "Open tickets for top-severity items"
      - "Tag pattern issues for design-system follow-up"
      - "File issue list in the repo"
    methodologies:
      - slug: heuristic-evaluation
        path: solo/ux/ux-ui-designer/heuristic-evaluation
        required: true
        tier_gate: solo
      - slug: consistency-standards
        path: solo/ux/ux-ui-designer/consistency-standards
        required: true
        tier_gate: solo
    outputs:
      - "Tickets + filed list"
    decision_gate: |
      Done when top-severity items have tickets.

common_pitfalls:
  - "Skipping context -> heuristic violations without purpose"
  - "All-issues-equal severity -> nothing is shipped"
  - "No ticket -> findings rot in a doc"

quality_checklist:
  - "Did every heuristic get a pass/fail with evidence?"
  - "Are the top severities ticketed?"
  - "Did design-system patterns get flagged?"

related_playbooks:
  - a11y-audit-on-one-screen-1hr
  - weekly-design-review-meeting-1hr

token_budget_estimate: 2500
cli_invocations:
  human:  "faion get-content heuristic-evaluation-on-a-new-screen-1hr --format md"
  agent:  "faion get-content heuristic-evaluation-on-a-new-screen-1hr --format context"
  json:   "faion get-content heuristic-evaluation-on-a-new-screen-1hr --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
  - methodology_slug: heuristic-eval-severity-rubric
    expected_tier: solo
    blocks_stage: 5
    note: "Severity rubric template not yet authored."
  - methodology_slug: pattern-flag-followup-template
    expected_tier: solo
    blocks_stage: 6
    note: "Pattern flag follow-up template not yet authored."
