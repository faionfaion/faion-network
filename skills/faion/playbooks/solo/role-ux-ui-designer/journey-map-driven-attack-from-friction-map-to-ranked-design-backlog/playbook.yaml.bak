slug: journey-map-driven-attack-from-friction-map-to-ranked-design-backlog
title: "Journey-map-driven attack: from friction map to ranked design-backlog"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 320c022d533099d6

tier: solo
tier_min: solo
group: role-ux-ui-designer
persona: Designer taking a journey map and converting friction into a backlog
complexity: medium
context: [solo, team]

summary: |
  Existing or new journey map in hand; ends with a ranked list of design-debt + design-bet tickets pushed into the product backlog with traceable rationale.

intent: |
  Journey map of friction -> ranked design-debt + design-bet tickets in backlog.

scope: |
  Designer takes a journey map and converts friction into a prioritized backlog. Includes friction audit, debt vs bet split, RICE scoring, ticket creation, and rationale traceability. Done when ranked tickets are in the backlog and traceable to journey-map evidence.

success_criteria:
  - "Friction points itemized with evidence"
  - "Each item split into design-debt vs design-bet"
  - "Items scored with RICE-for-design"
  - "Tickets in the product backlog with journey-map links"

methodology_refs:
  - faion/knowledge/solo/ux/ux-ui-designer/journey-mapping

stages:
  - name: "Read the map"
    intent: "Find the friction."
    tasks:
      - "Walk each journey stage"
      - "Note pain points + delight gaps"
      - "Capture evidence per friction"
    methodologies:
      - slug: journey-mapping
        path: solo/ux/ux-ui-designer/journey-mapping
        required: true
        tier_gate: solo
    outputs:
      - "Friction inventory"
    decision_gate: |
      Advance only when each friction has evidence.
  - name: "Service blueprint"
    intent: "Show the system behind the journey."
    tasks:
      - "Map front-stage + back-stage actions"
      - "Identify dependencies + failure points"
      - "Tag system-level frictions"
    methodologies:
      - slug: journey-mapping
        path: solo/ux/ux-ui-designer/journey-mapping
        required: true
        tier_gate: solo
    outputs:
      - "Service blueprint"
    decision_gate: |
      Advance only with blueprint reviewed.
  - name: "Debt vs bet split"
    intent: "Sort known fixes vs experimental bets."
    tasks:
      - "Mark each item as debt or bet"
      - "Document the difference live with team"
      - "Park ambiguous items for refinement"
    methodologies:
      - slug: journey-mapping
        path: solo/ux/ux-ui-designer/journey-mapping
        required: true
        tier_gate: solo
    outputs:
      - "Split list"
    decision_gate: |
      Advance only when every item has a label.
  - name: "RICE-for-design"
    intent: "Rank with a consistent rubric."
    tasks:
      - "Score reach + impact + confidence + effort"
      - "Apply design-specific RICE adjustments"
      - "Order by score"
    methodologies:
      - slug: journey-mapping
        path: solo/ux/ux-ui-designer/journey-mapping
        required: true
        tier_gate: solo
    outputs:
      - "Ranked list"
    decision_gate: |
      Advance only with ranked list reviewed.
  - name: "Tickets + trace"
    intent: "Push to backlog with rationale."
    tasks:
      - "Open backlog tickets per item"
      - "Link each ticket to journey-map evidence"
      - "Communicate the new ranked queue"
    methodologies:
      - slug: journey-mapping
        path: solo/ux/ux-ui-designer/journey-mapping
        required: true
        tier_gate: solo
    outputs:
      - "Backlog tickets with journey links"
    decision_gate: |
      Done when tickets are linked and the queue is shared.

common_pitfalls:
  - "Bets disguised as debt -> sprint over-commits"
  - "RICE without consistent rubric -> ranking is theatre"
  - "Tickets without trace -> rationale lost in two months"

quality_checklist:
  - "Are debt vs bet labels honest?"
  - "Is the RICE rubric documented?"
  - "Can a new team-mate trace any ticket back to the map?"

related_playbooks:
  - usability-test-cycle-end-to-end-3-weeks
  - research-insight-synthesis-2hrweek

token_budget_estimate: 4000
cli_invocations:
  human:  "faion get-content journey-map-driven-attack-from-friction-map-to-ranked-design-backlog --format md"
  agent:  "faion get-content journey-map-driven-attack-from-friction-map-to-ranked-design-backlog --format context"
  json:   "faion get-content journey-map-driven-attack-from-friction-map-to-ranked-design-backlog --format json"

changelog:
