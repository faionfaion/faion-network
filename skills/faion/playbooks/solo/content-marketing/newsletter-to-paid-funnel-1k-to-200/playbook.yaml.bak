# =============================================================================
# Newsletter to paid product funnel: convert 1K free readers into 200 customers
# Persona: P2 Indie Hacker — F-064
# =============================================================================

slug: newsletter-to-paid-funnel-1k-to-200
title: "Newsletter to paid product funnel: convert 1K free readers into 200 customers"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: bbf59d7ec0767b3d

tier_min: solo
complexity: deep
context: [solo]
persona_hints: [P2]

intent: |
  1K free newsletter readers → 200 paying customers at $20 average ($4K MRR).

scope: |
  Engineer a documented funnel that turns a 1K-subscriber free newsletter into roughly 200 paying customers at $20 average through low-friction email-driven conversion, hitting $4K MRR with no paid traffic.

non_goals:
  - "Cold acquisition — funnel uses existing list only"
  - "Enterprise sales — single-seat self-serve"
  - "Free-forever model — explicit paid conversion"

prerequisites:
  - "Newsletter with ≥1000 active subscribers (open rate ≥30%)"
  - "A paid product or service tier ready to charge"

success_criteria:
  - "Documented funnel stages with conversion rates per stage"
  - "Live segmentation in the ESP"
  - "Onboarding sequence active for new subscribers"
  - "Pricing experiment toggle ready"
  - "≥200 paying customers and ≥$4K MRR within 90 days"

stages:
  - name: "Audit"
    intent: "Know which issues, segments, and CTAs already convert."
    tasks:
      - "Pull last 90 days of opens, clicks, and replies by issue"
      - "Tag every CTA by intent and outcome"
      - "Identify the 3 highest-converting topics"
    methodologies:
      - slug: product-analytics
        path: solo/product/product-operations/product-analytics
        required: true
        tier_gate: solo
      - slug: growth-social-media-strategy
        path: solo/marketing/smm-manager/growth-social-media-strategy
        required: true
        tier_gate: solo
      - slug: vanity-metrics-audit
        path: solo/product/vanity-metrics-audit
        required: true
        tier_gate: solo
    outputs:
      - "90-day analytics snapshot"
      - "Top-3 converting topics list"
    decision_gate: |
      Advance when CTA performance has been segmented and ranked.
  - name: "Offer"
    intent: "A paid offer tied to the top-converting topic."
    tasks:
      - "Define the paid product framing (job + price + format)"
      - "Write the offer page with proof and pricing"
      - "Pick a single pricing hypothesis ($X for Y format)"
    methodologies:
      - slug: ops-pricing-strategy
        path: solo/marketing/gtm-strategist/ops-pricing-strategy
        required: true
        tier_gate: solo
      - slug: ops-subscription-models
        path: solo/marketing/gtm-strategist/ops-subscription-models
        required: true
        tier_gate: solo
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
    outputs:
      - "Offer landing page"
      - "Pricing hypothesis brief"
    decision_gate: |
      Advance when 3 readers describe the offer back unaided.
  - name: "Drip"
    intent: "An onboarding sequence makes the first paid pitch."
    tasks:
      - "Write a 5-email onboarding sequence ending in CTA"
      - "Insert in-issue ads in regular sends"
      - "Tag click-to-CTA users for a follow-up nudge"
    methodologies:
      - slug: growth-onboarding-emails
        path: solo/marketing/content-marketer/growth-onboarding-emails
        required: true
        tier_gate: solo
      - slug: growth-email-marketing
        path: solo/marketing/content-marketer/growth-email-marketing
        required: true
        tier_gate: solo
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
      - slug: growth-onboarding-emails
        path: solo/marketing/content-marketer/growth-onboarding-emails
        required: true
        tier_gate: solo
      - slug: newsletter-to-paid-funnel-template
        path: solo/marketing/newsletter-to-paid-funnel-template
        required: true
        tier_gate: solo
      - slug: in-issue-ad-format-library
        path: solo/marketing/in-issue-ad-format-library
        required: true
        tier_gate: solo
    outputs:
      - "Active 5-email drip"
      - "In-issue ad slot calendar"
    decision_gate: |
      Advance when 3 paid customers from the drip have closed.
  - name: "Convert"
    intent: "Run paid pushes that respect the list."
    tasks:
      - "Quarterly launch push (≤1 per quarter)"
      - "Monthly soft promo woven into normal issues"
      - "Personal outreach to engaged-non-buyers"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: ops-customer-support
        path: solo/marketing/gtm-strategist/ops-customer-support
        required: true
        tier_gate: solo
      - slug: pricing-experiment-log
        path: solo/product/pricing-experiment-log
        required: true
        tier_gate: solo
    outputs:
      - "Push calendar"
      - "Personal outreach log"
    decision_gate: |
      Advance when conversion rate stabilises ≥2% per push.
  - name: "Retain"
    intent: "Keep buyers paying month over month."
    tasks:
      - "Send a paid-only weekly digest"
      - "Trigger churn-save sequence on cancel intent"
      - "Quarterly OKR review of LTV, churn, and ARPU"
    methodologies:
      - slug: okr-setting
        path: solo/product/product-planning/okr-setting
        required: true
        tier_gate: solo
      - slug: outcome-based-roadmaps
        path: solo/product/product-planning/outcome-based-roadmaps
        required: true
        tier_gate: solo
      - slug: churn-save-email-pack-indie
        path: solo/marketing/churn-save-email-pack-indie
        required: true
        tier_gate: solo
      - slug: weekly-pm-async-broadcast-template
        path: solo/product/weekly-pm-async-broadcast-template
        required: true
        tier_gate: solo
      - slug: churn-save-email-pack-indie
        path: solo/marketing/churn-save-email-pack-indie
        required: true
        tier_gate: solo
    outputs:
      - "Paid-tier weekly digest"
      - "Churn-save sequence live"
    decision_gate: |
      Maintain only if 90-day churn ≤5%; otherwise re-spec offer.

common_pitfalls:
  - "Treating the playbook as a checklist instead of a decision tree"
  - "Skipping decision gates when intermediate progress feels good"
  - "Letting tools or platforms replace the founder's own judgement"

quality_checklist:
  - "Did each stage produce its named output or get explicitly skipped with a note?"
  - "Were decision gates respected or quietly bypassed?"
  - "Is the evidence trail strong enough to defend the verdict externally?"

related_playbooks:
  - solo-idea-to-validated-mvp
token_budget_estimate: 19500
cli_invocations:
  human:  "faion get-content newsletter-to-paid-funnel-1k-to-200 --format md"
  agent:  "faion get-content newsletter-to-paid-funnel-1k-to-200 --format context"
  json:   "faion get-content newsletter-to-paid-funnel-1k-to-200 --format json"

