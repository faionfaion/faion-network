<playbook id="01-playbook" slug="feature-from-spec-to-production-3-weeks-p4-client-rules-edition" goal="TBD" complexity="medium">
  <intent>Client AC -&gt; tagged production release on client repo, inside client conventions.</intent>
  <scope>Outsource developer ships a single feature on a client's codebase across 3 weeks. Covers conventions intake, spec draft, test plan, implementation, code review, contract + integration testing, observability, and release. Done when the feature is tagged in the client's repo and a post-deploy verification check has passed.</scope>
  <success-criteria>
    <criterion>Client conventions intake completed</criterion>
    <criterion>Test plan signed off</criterion>
    <criterion>Code review passes per client rules</criterion>
    <criterion>Feature deployed + verified in production</criterion>
    <criterion>Tagged release on client repo with changelog</criterion>
  </success-criteria>
  <stages>
    <stage n="1" name="Intake client conventions">
      <intent>Speak the client's code before writing.</intent>
      <tasks>
        <task>Read existing AGENTS.md / CONTRIBUTING / style guides</task>
        <task>Capture review process + sign-off authority</task>
        <task>Document the convention pyramid</task>
      </tasks>
      <methodologies>
        <ref slug="kb-agents-md-context-pyramid" />
        <ref slug="language-framework-guide" />
      </methodologies>
      <outputs>
        <output>Conventions intake doc</output>
      </outputs>
      <decision-gate>Advance only when conventions are written down.</decision-gate>
    </stage>
    <stage n="2" name="Spec + test plan">
      <intent>Agree on what + how to verify before coding.</intent>
      <tasks>
        <task>Draft spec from AC (task-agent-drafts-spec-before-coding)</task>
        <task>Write test plan tied to AC</task>
        <task>Get client sign-off</task>
      </tasks>
      <methodologies>
        <ref slug="task-agent-drafts-spec-before-coding" />
        <ref slug="writing-specifications" />
        <ref slug="writing-design-documents" />
        <ref slug="task-creation-template-guide" />
        <ref slug="writing-implementation-plans" />
      </methodologies>
      <outputs>
        <output>Spec + test plan signed off</output>
      </outputs>
      <decision-gate>Advance only after client sign-off.</decision-gate>
    </stage>
    <stage n="3" name="Contract-first">
      <intent>Lock API contracts early.</intent>
      <tasks>
        <task>Write API contracts + versioning notes</task>
        <task>Add contract tests</task>
        <task>Document with API docs</task>
      </tasks>
      <methodologies>
        <ref slug="contract-first-development" />
        <ref slug="api-versioning" />
        <ref slug="api-documentation" />
        <ref slug="api-first-development" />
      </methodologies>
      <outputs>
        <output>Contract + tests</output>
      </outputs>
      <decision-gate>Advance only when contract tests are green.</decision-gate>
    </stage>
    <stage n="4" name="Implement TDD">
      <intent>Tests lead the code.</intent>
      <tasks>
        <task>Red-green-refactor per task</task>
        <task>Stage lint only on changed files</task>
        <task>Surface decomposition risks early</task>
      </tasks>
      <methodologies>
        <ref slug="tdd-workflow" />
        <ref slug="code-decomposition-patterns" />
        <ref slug="lint-staged-only-not-whole-tree" />
        <ref slug="lint-precommit-floor" />
        <ref slug="error-handling" />
      </methodologies>
      <outputs>
        <output>Implementation with green tests</output>
      </outputs>
      <decision-gate>Advance only when tests are green on changed surface.</decision-gate>
    </stage>
    <stage n="5" name="Test layers">
      <intent>Unit + integration + e2e covered.</intent>
      <tasks>
        <task>Add integration tests</task>
        <task>Add e2e tests for critical flows</task>
        <task>Update API docs + ADRs as needed</task>
      </tasks>
      <methodologies>
        <ref slug="integration-testing" />
        <ref slug="e2e-testing" />
        <ref slug="architecture-decision-records" />
        <ref slug="living-documentation" />
      </methodologies>
      <outputs>
        <output>Multi-layer test suite green</output>
      </outputs>
      <decision-gate>Advance only when integration + e2e are green.</decision-gate>
    </stage>
    <stage n="6" name="Client code review">
      <intent>Pass review per client rules.</intent>
      <tasks>
        <task>Open MR with graph context (not raw diff)</task>
        <task>Follow client review etiquette</task>
        <task>Iterate on review notes</task>
      </tasks>
      <methodologies>
        <ref slug="code-review-process" />
        <ref slug="code-review" />
        <ref slug="mr-graph-vs-diff-reviewer" />
        <ref slug="code-review-cycle" />
        <ref slug="quality-gates-confidence" />
      </methodologies>
      <outputs>
        <output>MR approved per client process</output>
      </outputs>
      <decision-gate>Advance only after explicit approval.</decision-gate>
    </stage>
    <stage n="7" name="Ship + verify">
      <intent>Tagged release + production verified.</intent>
      <tasks>
        <task>Merge behind feature flag if available</task>
        <task>Trigger CD pipeline + verify</task>
        <task>Tag the release + post changelog</task>
      </tasks>
      <methodologies>
        <ref slug="cd-pipelines" />
        <ref slug="continuous-delivery" />
        <ref slug="feature-flags" />
        <ref slug="trunk-based-development" />
        <ref slug="api-monitoring-logging" />
        <ref slug="api-monitoring-metrics" />
      </methodologies>
      <outputs>
        <output>Tagged production release + verified</output>
      </outputs>
      <decision-gate>Advance only when production verification passes.</decision-gate>
    </stage>
    <stage n="8" name="Memory + retro">
      <intent>Carry forward what worked.</intent>
      <tasks>
        <task>Capture engagement patterns in memory</task>
        <task>Note mistakes for future avoidance</task>
        <task>Run a lightweight reflexion pass</task>
      </tasks>
      <methodologies>
        <ref slug="pattern-memory" />
        <ref slug="mistake-memory" />
        <ref slug="reflexion-learning" />
        <ref slug="task-creation-parallelization" />
      </methodologies>
      <outputs>
        <output>Memory entries + reflexion note</output>
      </outputs>
      <decision-gate>Done when memory is updated.</decision-gate>
    </stage>
  </stages>
  <gaps>
    <gap slug="client-conventions-intake" expected-tier="solo" />
    <gap slug="engagement-pattern-memory" expected-tier="solo" />
    <gap slug="outsource-pr-etiquette" expected-tier="solo" />
  </gaps>
  <extra key="context" value="[outsource]" />
  <extra key="common_pitfalls" value="[Skipping conventions intake -&gt; review pushback eats sprint, Tests written after code -&gt; regressions appear in week 2, No memory update -&gt; next engagement repeats the same mistakes]" />
  <extra key="quality_checklist" value="['Did the MR pass client review on first or second pass?', 'Are tests green at unit + integration + e2e?', 'Is the release tagged + verified in production?']" />
  <extra key="related_playbooks" value="[greenfield-service-from-scaffold-to-first-production-deploy-8-weeks-p6-product-t]" />
  <extra key="token_budget_estimate" value="11000" />
