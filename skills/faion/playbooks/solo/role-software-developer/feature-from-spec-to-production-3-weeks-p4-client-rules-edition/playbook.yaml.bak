slug: feature-from-spec-to-production-3-weeks-p4-client-rules-edition
title: "Feature from spec to production (3 weeks, P4 client-rules edition)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 6846f7881fc759f2

tier: solo
tier_min: solo
group: role-software-developer
persona: Outsource developer shipping a client-issued ticket end-to-end on the client's repo
complexity: medium
context: [outsource]

summary: |
  Outsource dev takes a client ticket from AC to tagged release on the client's repo, inside the client's conventions, review, and audit trail.

intent: |
  Client AC -> tagged production release on client repo, inside client conventions.

scope: |
  Outsource developer ships a single feature on a client's codebase across 3 weeks. Covers conventions intake, spec draft, test plan, implementation, code review, contract + integration testing, observability, and release. Done when the feature is tagged in the client's repo and a post-deploy verification check has passed.

success_criteria:
  - "Client conventions intake completed"
  - "Test plan signed off"
  - "Code review passes per client rules"
  - "Feature deployed + verified in production"
  - "Tagged release on client repo with changelog"

methodology_refs:
  - faion/knowledge/free/dev/code-quality/code-decomposition-patterns
  - faion/knowledge/free/dev/code-quality/code-review-process
  - faion/knowledge/free/dev/software-developer/code-review
  - faion/knowledge/free/dev/software-developer/e2e-testing
  - faion/knowledge/free/dev/software-developer/error-handling
  - faion/knowledge/free/dev/software-developer/integration-testing
  - faion/knowledge/free/dev/software-developer/language-framework-guide
  - faion/knowledge/free/dev/software-developer/tdd-workflow
  - faion/knowledge/geek/sdlc-ai/kb-agents-md-context-pyramid
  - faion/knowledge/geek/sdlc-ai/lint-precommit-floor
  - faion/knowledge/geek/sdlc-ai/lint-staged-only-not-whole-tree
  - faion/knowledge/geek/sdlc-ai/mr-graph-vs-diff-reviewer
  - faion/knowledge/geek/sdlc-ai/task-agent-drafts-spec-before-coding
  - faion/knowledge/pro/dev/software-developer/api-monitoring-logging
  - faion/knowledge/pro/dev/software-developer/api-monitoring-metrics
  - faion/knowledge/solo/dev/automation-tooling/cd-pipelines
  - faion/knowledge/solo/dev/automation-tooling/continuous-delivery
  - faion/knowledge/solo/dev/software-architect/architecture-decision-records
  - faion/knowledge/solo/dev/software-developer/api-documentation
  - faion/knowledge/solo/dev/software-developer/api-versioning
  - faion/knowledge/solo/dev/software-developer/contract-first-development
  - faion/knowledge/solo/dev/software-developer/feature-flags
  - faion/knowledge/solo/dev/software-developer/trunk-based-development
  - faion/knowledge/solo/sdd/sdd-planning/task-creation-template-guide
  - faion/knowledge/solo/sdd/sdd-planning/writing-implementation-plans
  - faion/knowledge/solo/sdd/sdd/api-first-development
  - faion/knowledge/solo/sdd/sdd/code-review-cycle
  - faion/knowledge/solo/sdd/sdd/living-documentation
  - faion/knowledge/solo/sdd/sdd/mistake-memory
  - faion/knowledge/solo/sdd/sdd/pattern-memory
  - faion/knowledge/solo/sdd/sdd/quality-gates-confidence
  - faion/knowledge/solo/sdd/sdd/reflexion-learning
  - faion/knowledge/solo/sdd/sdd/task-creation-parallelization
  - faion/knowledge/solo/sdd/sdd/writing-design-documents
  - faion/knowledge/solo/sdd/sdd/writing-specifications

stages:
  - name: "Intake client conventions"
    intent: "Speak the client's code before writing."
    tasks:
      - "Read existing AGENTS.md / CONTRIBUTING / style guides"
      - "Capture review process + sign-off authority"
      - "Document the convention pyramid"
    methodologies:
      - slug: kb-agents-md-context-pyramid
        path: geek/sdlc-ai/kb-agents-md-context-pyramid
        required: true
        tier_gate: geek
      - slug: language-framework-guide
        path: free/dev/software-developer/language-framework-guide
        required: true
        tier_gate: free
    outputs:
      - "Conventions intake doc"
    decision_gate: |
      Advance only when conventions are written down.
  - name: "Spec + test plan"
    intent: "Agree on what + how to verify before coding."
    tasks:
      - "Draft spec from AC (task-agent-drafts-spec-before-coding)"
      - "Write test plan tied to AC"
      - "Get client sign-off"
    methodologies:
      - slug: task-agent-drafts-spec-before-coding
        path: geek/sdlc-ai/task-agent-drafts-spec-before-coding
        required: true
        tier_gate: geek
      - slug: writing-specifications
        path: solo/sdd/sdd/writing-specifications
        required: true
        tier_gate: solo
      - slug: writing-design-documents
        path: solo/sdd/sdd/writing-design-documents
        required: true
        tier_gate: solo
      - slug: task-creation-template-guide
        path: solo/sdd/sdd-planning/task-creation-template-guide
        required: true
        tier_gate: solo
      - slug: writing-implementation-plans
        path: solo/sdd/sdd-planning/writing-implementation-plans
        required: true
        tier_gate: solo
    outputs:
      - "Spec + test plan signed off"
    decision_gate: |
      Advance only after client sign-off.
  - name: "Contract-first"
    intent: "Lock API contracts early."
    tasks:
      - "Write API contracts + versioning notes"
      - "Add contract tests"
      - "Document with API docs"
    methodologies:
      - slug: contract-first-development
        path: solo/dev/software-developer/contract-first-development
        required: true
        tier_gate: solo
      - slug: api-versioning
        path: solo/dev/software-developer/api-versioning
        required: true
        tier_gate: solo
      - slug: api-documentation
        path: solo/dev/software-developer/api-documentation
        required: true
        tier_gate: solo
      - slug: api-first-development
        path: solo/sdd/sdd/api-first-development
        required: true
        tier_gate: solo
    outputs:
      - "Contract + tests"
    decision_gate: |
      Advance only when contract tests are green.
  - name: "Implement TDD"
    intent: "Tests lead the code."
    tasks:
      - "Red-green-refactor per task"
      - "Stage lint only on changed files"
      - "Surface decomposition risks early"
    methodologies:
      - slug: tdd-workflow
        path: free/dev/software-developer/tdd-workflow
        required: true
        tier_gate: free
      - slug: code-decomposition-patterns
        path: free/dev/code-quality/code-decomposition-patterns
        required: true
        tier_gate: free
      - slug: lint-staged-only-not-whole-tree
        path: geek/sdlc-ai/lint-staged-only-not-whole-tree
        required: true
        tier_gate: geek
      - slug: lint-precommit-floor
        path: geek/sdlc-ai/lint-precommit-floor
        required: true
        tier_gate: geek
      - slug: error-handling
        path: free/dev/software-developer/error-handling
        required: true
        tier_gate: free
    outputs:
      - "Implementation with green tests"
    decision_gate: |
      Advance only when tests are green on changed surface.
  - name: "Test layers"
    intent: "Unit + integration + e2e covered."
    tasks:
      - "Add integration tests"
      - "Add e2e tests for critical flows"
      - "Update API docs + ADRs as needed"
    methodologies:
      - slug: integration-testing
        path: free/dev/software-developer/integration-testing
        required: true
        tier_gate: free
      - slug: e2e-testing
        path: free/dev/software-developer/e2e-testing
        required: true
        tier_gate: free
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: living-documentation
        path: solo/sdd/sdd/living-documentation
        required: true
        tier_gate: solo
    outputs:
      - "Multi-layer test suite green"
    decision_gate: |
      Advance only when integration + e2e are green.
  - name: "Client code review"
    intent: "Pass review per client rules."
    tasks:
      - "Open MR with graph context (not raw diff)"
      - "Follow client review etiquette"
      - "Iterate on review notes"
    methodologies:
      - slug: code-review-process
        path: free/dev/code-quality/code-review-process
        required: true
        tier_gate: free
      - slug: code-review
        path: free/dev/software-developer/code-review
        required: true
        tier_gate: free
      - slug: mr-graph-vs-diff-reviewer
        path: geek/sdlc-ai/mr-graph-vs-diff-reviewer
        required: true
        tier_gate: geek
      - slug: code-review-cycle
        path: solo/sdd/sdd/code-review-cycle
        required: true
        tier_gate: solo
      - slug: quality-gates-confidence
        path: solo/sdd/sdd/quality-gates-confidence
        required: true
        tier_gate: solo
    outputs:
      - "MR approved per client process"
    decision_gate: |
      Advance only after explicit approval.
  - name: "Ship + verify"
    intent: "Tagged release + production verified."
    tasks:
      - "Merge behind feature flag if available"
      - "Trigger CD pipeline + verify"
      - "Tag the release + post changelog"
    methodologies:
      - slug: cd-pipelines
        path: solo/dev/automation-tooling/cd-pipelines
        required: true
        tier_gate: solo
      - slug: continuous-delivery
        path: solo/dev/automation-tooling/continuous-delivery
        required: true
        tier_gate: solo
      - slug: feature-flags
        path: solo/dev/software-developer/feature-flags
        required: true
        tier_gate: solo
      - slug: trunk-based-development
        path: solo/dev/software-developer/trunk-based-development
        required: true
        tier_gate: solo
      - slug: api-monitoring-logging
        path: pro/dev/software-developer/api-monitoring-logging
        required: true
        tier_gate: pro
      - slug: api-monitoring-metrics
        path: pro/dev/software-developer/api-monitoring-metrics
        required: true
        tier_gate: pro
    outputs:
      - "Tagged production release + verified"
    decision_gate: |
      Advance only when production verification passes.
  - name: "Memory + retro"
    intent: "Carry forward what worked."
    tasks:
      - "Capture engagement patterns in memory"
      - "Note mistakes for future avoidance"
      - "Run a lightweight reflexion pass"
    methodologies:
      - slug: pattern-memory
        path: solo/sdd/sdd/pattern-memory
        required: true
        tier_gate: solo
      - slug: mistake-memory
        path: solo/sdd/sdd/mistake-memory
        required: true
        tier_gate: solo
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: solo
      - slug: task-creation-parallelization
        path: solo/sdd/sdd/task-creation-parallelization
        required: true
        tier_gate: solo
    outputs:
      - "Memory entries + reflexion note"
    decision_gate: |
      Done when memory is updated.

common_pitfalls:
  - "Skipping conventions intake -> review pushback eats sprint"
  - "Tests written after code -> regressions appear in week 2"
  - "No memory update -> next engagement repeats the same mistakes"

quality_checklist:
  - "Did the MR pass client review on first or second pass?"
  - "Are tests green at unit + integration + e2e?"
  - "Is the release tagged + verified in production?"

related_playbooks:
  - greenfield-service-from-scaffold-to-first-production-deploy-8-weeks-p6-product-t

token_budget_estimate: 11000
cli_invocations:
  human:  "faion get-content feature-from-spec-to-production-3-weeks-p4-client-rules-edition --format md"
  agent:  "faion get-content feature-from-spec-to-production-3-weeks-p4-client-rules-edition --format context"
  json:   "faion get-content feature-from-spec-to-production-3-weeks-p4-client-rules-edition --format json"

