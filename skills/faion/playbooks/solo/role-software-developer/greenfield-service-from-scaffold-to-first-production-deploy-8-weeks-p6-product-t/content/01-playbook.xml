<playbook id="01-playbook" slug="greenfield-service-from-scaffold-to-first-production-deploy-8-weeks-p6-product-t" goal="TBD" complexity="deep">
  <intent>Empty repo -&gt; first user-facing deploy with conventions, infra, and observability live.</intent>
  <scope>In-house dev or small squad ships a greenfield service across 8 weeks. Covers scaffold + AGENTS.md, architecture, contracts, infra, security, tests, observability, and first deploy. Done when the service is live with metrics + health checks and a published changelog.</scope>
  <success-criteria>
    <criterion>Repo scaffolded with AGENTS.md + CLAUDE.md per module</criterion>
    <criterion>Architecture decisions captured in ADRs</criterion>
    <criterion>Contract tests + integration tests + perf smoke green</criterion>
    <criterion>Observability stack live (metrics + logs + health checks)</criterion>
    <criterion>First user-facing deploy verified</criterion>
  </success-criteria>
  <stages>
    <stage n="1" name="Scaffold + AGENTS">
      <intent>Set up for LLM-friendly + human-friendly contributions.</intent>
      <tasks>
        <task>Bootstrap the repo with standard structure</task>
        <task>Add AGENTS.md + CLAUDE.md per module</task>
        <task>Wire pnpm catalogs / pyproject single source</task>
      </tasks>
      <methodologies>
        <ref slug="github-repo-bootstrap" />
        <ref slug="claude-md-creation" />
        <ref slug="llm-friendly-architecture" />
        <ref slug="pnpm-catalogs" />
        <ref slug="pyproject-single-source" />
      </methodologies>
      <outputs>
        <output>Scaffolded repo with AGENTS</output>
      </outputs>
      <decision-gate>Advance only when scaffold builds clean.</decision-gate>
    </stage>
    <stage n="2" name="Architecture + ADRs">
      <intent>Decide before coding.</intent>
      <tasks>
        <task>Pick architecture pattern (hexagonal / onion)</task>
        <task>Make build-vs-buy + stack decisions explicit</task>
        <task>Capture ADRs</task>
      </tasks>
      <methodologies>
        <ref slug="arch-pattern-hexagonal" />
        <ref slug="arch-pattern-onion" />
        <ref slug="decision-tree-tech-stack" />
        <ref slug="decision-tree-build-vs-buy" />
        <ref slug="trade-off-decision-matrix" />
        <ref slug="database-selection" />
        <ref slug="clean-architecture" />
      </methodologies>
      <outputs>
        <output>ADRs filed</output>
      </outputs>
      <decision-gate>Advance only when ADRs cover the major decisions.</decision-gate>
    </stage>
    <stage n="3" name="Contract + API">
      <intent>API contract first, no surprises later.</intent>
      <tasks>
        <task>Draft OpenAPI spec</task>
        <task>Add contract tests</task>
        <task>Define rate limiting + auth</task>
      </tasks>
      <methodologies>
        <ref slug="api-contract-first" />
        <ref slug="api-openapi-spec" />
        <ref slug="api-rest-design" />
        <ref slug="api-rate-limiting" />
        <ref slug="api-authentication" />
      </methodologies>
      <outputs>
        <output>OpenAPI spec + contracts</output>
      </outputs>
      <decision-gate>Advance only when contract tests are green.</decision-gate>
    </stage>
    <stage n="4" name="Domain model + DB">
      <intent>Codify the domain explicitly.</intent>
      <tasks>
        <task>Model aggregates + value objects + repositories</task>
        <task>Design DB schema</task>
        <task>Optimize critical queries</task>
      </tasks>
      <methodologies>
        <ref slug="ddd-aggregates" />
        <ref slug="ddd-repositories" />
        <ref slug="ddd-value-objects" />
        <ref slug="database-design" />
        <ref slug="sql-optimization" />
        <ref slug="sql-optimization" />
        <ref slug="nosql-redis-patterns" />
        <ref slug="go-layout-directory-structure" />
        <ref slug="go-project-structure" />
      </methodologies>
      <outputs>
        <output>Domain model + schema</output>
      </outputs>
      <decision-gate>Advance only when domain model is reviewed.</decision-gate>
    </stage>
    <stage n="5" name="Tests + perf">
      <intent>Layers of testing + a perf smoke.</intent>
      <tasks>
        <task>Unit + integration tests via TDD</task>
        <task>Add test fixtures + factories</task>
        <task>Run a perf smoke test</task>
        <task>Split TDD red-green between agents</task>
      </tasks>
      <methodologies>
        <ref slug="tdd-workflow" />
        <ref slug="unit-testing" />
        <ref slug="integration-testing" />
        <ref slug="test-fixtures" />
        <ref slug="performance-testing" />
        <ref slug="perf-test-tools" />
        <ref slug="test-tdd-red-green-split-agents" />
      </methodologies>
      <outputs>
        <output>Test suite + perf smoke green</output>
      </outputs>
      <decision-gate>Advance only when perf smoke passes.</decision-gate>
    </stage>
    <stage n="6" name="Security">
      <intent>Bake security in.</intent>
      <tasks>
        <task>Wire CodeQL autofix on PRs</task>
        <task>Run Trivy supply-chain scans on pinned deps</task>
        <task>Apply secrets defense-in-depth</task>
        <task>Add security-focused tests</task>
        <task>Add circuit breakers for downstream services</task>
      </tasks>
      <methodologies>
        <ref slug="sec-codeql-autofix-on-pr" />
        <ref slug="sec-trivy-pinned-supply-chain-scan" />
        <ref slug="sec-secrets-defense-in-depth" />
        <ref slug="security-testing" />
        <ref slug="microservices-circuit-breaker" />
      </methodologies>
      <outputs>
        <output>Security gates green</output>
      </outputs>
      <decision-gate>Advance only when scans pass.</decision-gate>
    </stage>
    <stage n="7" name="Observability">
      <intent>You can see the service from outside.</intent>
      <tasks>
        <task>Wire metrics + logs + traces</task>
        <task>Add health checks + alerts</task>
        <task>Wire docker-compose for local + smoke</task>
      </tasks>
      <methodologies>
        <ref slug="api-monitoring-metrics" />
        <ref slug="api-monitoring-logging" />
        <ref slug="api-monitoring-health-checks" />
        <ref slug="api-monitoring-alerting" />
        <ref slug="docker-compose" />
      </methodologies>
      <outputs>
        <output>Observability live</output>
      </outputs>
      <decision-gate>Advance only when health checks + metrics + alerts are wired.</decision-gate>
    </stage>
    <stage n="8" name="First deploy">
      <intent>Ship to users.</intent>
      <tasks>
        <task>Wire CD pipeline + tagged release</task>
        <task>Deploy behind feature flag for a small audience</task>
        <task>Verify post-deploy with smoke + alerts</task>
      </tasks>
      <methodologies>
        <ref slug="cd-pipelines" />
        <ref slug="continuous-delivery" />
      </methodologies>
      <outputs>
        <output>First deploy verified</output>
      </outputs>
      <decision-gate>Done when deploy is verified and changelog is published.</decision-gate>
    </stage>
  </stages>
  <gaps>
    <gap slug="service-bootstrap-checklist" expected-tier="solo" />
    <gap slug="service-launch-readiness-review" expected-tier="solo" />
    <gap slug="agents-md-per-module-bootstrap" expected-tier="geek" />
  </gaps>
  <extra key="context" value="[team]" />
  <extra key="common_pitfalls" value="[Skipping ADRs -&gt; decisions get re-fought in week 5, Tests added last -&gt; security + perf bugs ship, Observability deferred -&gt; first incident is blind]" />
  <extra key="quality_checklist" value="['Does the repo build clean from scratch?', 'Are metrics + logs + alerts live?', 'Did the first deploy verify cleanly?']" />
