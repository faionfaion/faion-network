slug: daily-sdd-spec-vibe-code-review-cycle
title: "Daily SDD spec → vibe-code → review cycle"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 25265efa5eb69f22

tier_min: solo
complexity: medium
context: [solo]
persona_hints: [P1]

intent: |
  One feature slice shipped to staging in a single focused day: spec written, code generated against acceptance, self-review pass complete, PR merged, deploy verified.

scope: |
  One feature slice shipped to staging in a single focused day: spec written, code generated against acceptance, self-review pass complete, PR merged, deploy verified.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Spec the slice"
    intent: "Write the spec before touching code."
    tasks:
      - "Write a tight one-feature spec with acceptance criteria"
      - "List explicit non-goals for this slice"
      - "Identify the smallest staging-deployable unit"
    methodologies:
      - slug: code-review
        path: free/dev/code-quality/code-review
        required: true
        tier_gate: solo
      - slug: impl-plan-100k-rule
        path: solo/sdd/sdd-planning/impl-plan-100k-rule
        required: true
        tier_gate: solo
      - slug: writing-specifications
        path: solo/sdd/sdd/writing-specifications
        required: true
        tier_gate: solo
    outputs:
      - "slice-spec.md"
      - "Non-goals list"
      - "Acceptance criteria table"
    decision_gate: "Advance only when spec fits one screen AND every AC is testable."
  - name: "Generate against acceptance"
    intent: "Use the AI agent with the spec as the brief, not vibes."
    tasks:
      - "Feed the spec + relevant context to the coding agent"
      - "Constrain the diff size to one logical change"
      - "Ask for tests against the acceptance criteria first"
    methodologies:
      - slug: code-review-process
        path: free/dev/code-quality/code-review-process
        required: true
        tier_gate: solo
      - slug: impl-plan-task-format
        path: solo/sdd/sdd-planning/impl-plan-task-format
        required: true
        tier_gate: solo
    outputs:
      - "Generated diff"
      - "Generated tests"
      - "Agent transcript log"
    decision_gate: "Advance only when diff is reviewable in <=10 minutes and tests cover all AC."
  - name: "Self-code review"
    intent: "Solo PR review using a written rubric, not gut."
    tasks:
      - "Walk the self-code-review rubric line by line"
      - "Tag any debt deferral explicitly"
      - "Re-run lint, types, and the relevant test scope"
    methodologies:
      - slug: error-handling
        path: free/dev/software-developer/error-handling
        required: true
        tier_gate: solo
      - slug: spec-requirements
        path: solo/sdd/sdd-planning/spec-requirements
        required: true
        tier_gate: solo
    outputs:
      - "Review checklist filled"
      - "Debt-deferral notes"
      - "Green CI on the branch"
    decision_gate: "Advance only when all rubric items are green or explicitly deferred with a ticket."
  - name: "Ship to staging"
    intent: "Push the slice behind a flag where risky."
    tasks:
      - "Deploy to staging with the feature flag default-off"
      - "Run the staging smoke checks"
      - "Verify the AC manually against staging"
    methodologies:
      - slug: tdd-workflow
        path: free/dev/software-developer/tdd-workflow
        required: true
        tier_gate: solo
      - slug: api-first-development
        path: solo/sdd/sdd/api-first-development
        required: true
        tier_gate: solo
    outputs:
      - "Staging deploy URL"
      - "Smoke check log"
      - "AC verification notes"
    decision_gate: "Advance only when all AC pass on staging."
  - name: "Merge + production gate"
    intent: "Merge with a clear deploy decision."
    tasks:
      - "Squash-merge to main with a tight commit message"
      - "Decide flag rollout strategy (canary / all-users / off)"
      - "Trigger production deploy"
    methodologies:
      - slug: unit-testing
        path: free/dev/testing-developer/unit-testing
        required: true
        tier_gate: solo
      - slug: code-review-cycle
        path: solo/sdd/sdd/code-review-cycle
        required: true
        tier_gate: solo
    outputs:
      - "Merged PR"
      - "Deploy decision note"
      - "Production health snapshot"
    decision_gate: "Advance only when production health is green for 15 minutes post-deploy."
  - name: "Daily-ship rubric"
    intent: "Close the day with a one-line ship verdict."
    tasks:
      - "Score the day against the daily-ship rubric"
      - "Log what slipped or got cut"
      - "Pick tomorrows first slice while context is hot"
    methodologies:
      - slug: cd-basics
        path: solo/dev/automation-tooling/cd-basics
        required: true
        tier_gate: solo
      - slug: quality-gates-confidence
        path: solo/sdd/sdd/quality-gates-confidence
        required: true
        tier_gate: solo
    outputs:
      - "Daily ship score"
      - "Slip log"
      - "Tomorrows first-slice brief"
    decision_gate: "Cycle closes when daily score is written and the next slice is named."

token_budget_estimate: 12000

cli_invocations:
  human:  "faion get-content daily-sdd-spec-vibe-code-review-cycle --format md"
  agent:  "faion get-content daily-sdd-spec-vibe-code-review-cycle --format context"
  json:   "faion get-content daily-sdd-spec-vibe-code-review-cycle --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
