slug: solo-prod-incident-response-no-team-safety-net
title: "Solo prod incident response (no team safety net)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 7a0c5ebd66360c58

tier_min: solo
complexity: deep
context: [solo]
persona_hints: [P1]

intent: |
  From alert ping at 3am to root-caused, mitigated, postmortem-documented incident — designed for one person, not a SRE rotation.

scope: |
  From alert ping at 3am to root-caused, mitigated, postmortem-documented incident — designed for one person, not a SRE rotation.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Alert triage"
    intent: "Decide in 60 seconds: real or noise."
    tasks:
      - "Read the alert payload and recent deploys"
      - "Cross-check status page + health endpoint"
      - "Tag the incident: P0 / P1 / noise"
    methodologies:
      - slug: cd-pipelines
        path: solo/dev/automation-tooling/cd-pipelines
        required: true
        tier_gate: solo
    outputs:
      - "Triage call"
      - "Health endpoint snapshot"
      - "Initial severity tag"
    decision_gate: "Advance only if confirmed real. If noise: silence alert, return to bed."
  - name: "Stop the bleed"
    intent: "Mitigate now, root-cause later."
    tasks:
      - "Flip the kill switch / disable bad flag / roll back"
      - "Confirm error rate drops"
      - "Post a public status update"
    methodologies:
      - slug: feature-flags-rollout-targeting
        path: solo/dev/automation-tooling/feature-flags-rollout-targeting
        required: true
        tier_gate: solo
    outputs:
      - "Mitigation action taken"
      - "Error rate delta"
      - "Status page update"
    decision_gate: "Advance only when error rate is below alert threshold."
  - name: "Containment + customer comms"
    intent: "Keep trust while you investigate."
    tasks:
      - "Send a quick we know we are on it message"
      - "Set a follow-up time commitment"
      - "Identify any affected paying customers for direct contact"
    methodologies:
      - slug: health-checks-autoheal
        path: solo/infra/server-craft/health-checks-autoheal
        required: true
        tier_gate: solo
    outputs:
      - "Public message"
      - "Follow-up window"
      - "Affected customer list"
    decision_gate: "Advance only when comms are posted with a time commitment."
  - name: "Root cause"
    intent: "Find the why, not just the what."
    tasks:
      - "Replay logs around the incident window"
      - "Check recent deploys, config changes, traffic spikes"
      - "Write a 5-whys for the root cause"
    methodologies:
      - slug: monitoring-logging
        path: solo/infra/server-craft/monitoring-logging
        required: true
        tier_gate: solo
    outputs:
      - "Log replay notes"
      - "Change correlation"
      - "5-whys doc"
    decision_gate: "Advance only with a named root cause."
  - name: "Permanent fix + monitor"
    intent: "Ship the real fix and prove it sticks."
    tasks:
      - "Ship the code fix with tests"
      - "Add a regression test or monitor"
      - "Verify in production over the next cohort"
    methodologies:
      - slug: mistake-memory
        path: solo/sdd/sdd/mistake-memory
        required: true
        tier_gate: solo
    outputs:
      - "Fix commit"
      - "New monitor or test"
      - "Production verification"
    decision_gate: "Advance only when the fix is live AND the new monitor would have caught it."
  - name: "Blameless postmortem"
    intent: "Write the doc even when you are the only blamer."
    tasks:
      - "Fill the blameless postmortem template"
      - "Capture timeline, contributing factors, lessons"
      - "Schedule follow-up backlog items"
    methodologies:
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: solo
    outputs:
      - "Postmortem doc"
      - "Follow-up backlog"
      - "Updated alerting noise budget"
    decision_gate: "Cycle closes when postmortem is committed and follow-ups are scheduled."

token_budget_estimate: 22000

cli_invocations:
  human:  "faion get-content solo-prod-incident-response-no-team-safety-net --format md"
  agent:  "faion get-content solo-prod-incident-response-no-team-safety-net --format context"
  json:   "faion get-content solo-prod-incident-response-no-team-safety-net --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
