slug: sunday-roadmap-week-shaping-ritual
title: "Sunday roadmap & week-shaping ritual"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 91aa643aa2353721

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P1]

intent: |
  Friday-clear backlog: top 3 outcomes for the week chosen, single-tasked file/board updated, no-go items deferred, Monday-morning first task primed with prompt + acceptance.

scope: |
  Friday-clear backlog: top 3 outcomes for the week chosen, single-tasked file/board updated, no-go items deferred, Monday-morning first task primed with prompt + acceptance.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Inbox + backlog sweep"
    intent: "Clear the noise so signal is visible."
    tasks:
      - "Triage inbox and tracker into one place"
      - "Drop everything older than 30 days that nobody has chased"
      - "Tag remaining items with revenue-relevance"
    methodologies:
      - slug: feature-prioritization-moscow
        path: solo/product/product-manager/feature-prioritization-moscow
        required: true
        tier_gate: solo
      - slug: pattern-memory
        path: solo/sdd/sdd/pattern-memory
        required: true
        tier_gate: solo
    outputs:
      - "Triaged backlog"
      - "Dropped-item log"
      - "Revenue-relevance tags"
    decision_gate: "Advance only when inbox is empty and backlog has <=20 active items."
  - name: "Pick top 3 outcomes"
    intent: "Force ranking. Three or fewer outcomes per week."
    tasks:
      - "List candidate outcomes from backlog"
      - "Score by RICE for one-person"
      - "Commit to the top 3 with explicit non-goals"
    methodologies:
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: solo
    outputs:
      - "Top 3 outcomes"
      - "Non-goals list"
      - "RICE score sheet"
    decision_gate: "Advance only with exactly 3 named outcomes. No and also."
  - name: "Prime Monday"
    intent: "Remove all friction from Monday morning startup."
    tasks:
      - "Open the first task file with prompt + acceptance criteria"
      - "Cue any external dependencies (data pulls, replies awaited)"
      - "Set the calendar block for first deep work session"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-operations/backlog-management
        required: true
        tier_gate: solo
      - slug: writing-specifications
        path: solo/sdd/sdd/writing-specifications
        required: true
        tier_gate: solo
    outputs:
      - "Monday-ready task file"
      - "Calendar block"
      - "Pre-fetched dependencies"
    decision_gate: "Advance when first task can start without any look-up at 9am Monday."
  - name: "Deferred & dropped log"
    intent: "Make trade-offs visible so they do not haunt."
    tasks:
      - "Move non-top-3 candidates to backlog or dropped"
      - "Note the why for each defer"
      - "Set a re-evaluation date if relevant"
    methodologies:
      - slug: outcome-based-roadmaps
        path: solo/product/product-planning/outcome-based-roadmaps
        required: true
        tier_gate: solo
    outputs:
      - "Deferred log"
      - "Dropped log"
      - "Re-evaluation reminders"
    decision_gate: "Advance only when every candidate has a written disposition."
  - name: "Friday-clear handshake"
    intent: "Promise yourself the week ends on Friday."
    tasks:
      - "Set a Friday checkpoint slot on the calendar"
      - "List the acceptance criteria for this week is shipped"
      - "Pre-commit to no work on Saturday unless emergency"
    methodologies:
      - slug: mistake-memory
        path: solo/sdd/sdd/mistake-memory
        required: true
        tier_gate: solo
    outputs:
      - "Friday checkpoint slot"
      - "Weekly acceptance criteria"
      - "Boundary contract with self"
    decision_gate: "Closes when the ritual file is saved and dated."

token_budget_estimate: 6000

cli_invocations:
  human:  "faion get-content sunday-roadmap-week-shaping-ritual --format md"
  agent:  "faion get-content sunday-roadmap-week-shaping-ritual --format context"
  json:   "faion get-content sunday-roadmap-week-shaping-ritual --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
