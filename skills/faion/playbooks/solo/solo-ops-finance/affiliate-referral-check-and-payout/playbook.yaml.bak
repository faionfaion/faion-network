# =============================================================================
# Affiliate / referral check and payout
# Persona: P2 Indie Hacker — F-064
# =============================================================================

slug: affiliate-referral-check-and-payout
title: "Affiliate / referral check and payout"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 1b082c0c4310985c

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P2]

intent: |
  Affiliate dashboard noise → monthly clean payouts and a message to top referrers.

scope: |
  Monthly one-hour ritual: pull affiliate and referral stats, approve commissions, process payouts, and send a personal thank-you message to top referrers so the program compounds.

non_goals:
  - "Designing the affiliate program from scratch"
  - "Negotiating with individual affiliates"
  - "Building dashboards — using existing data only"

prerequisites:
  - "An affiliate or referral program live"
  - "A payout method (Stripe, PayPal, bank transfer)"

success_criteria:
  - "Monthly payout completed without delay"
  - "Top 5 referrers personally thanked"
  - "Updated referral ledger"
  - "Payouts reconciled against revenue"

stages:
  - name: "Pull"
    intent: "All referral and affiliate stats in one table."
    tasks:
      - "Pull data from referral platform"
      - "Cross-reference with Stripe payouts"
      - "Flag anomalies (no signups but high traffic, etc.)"
    methodologies:
      - slug: ops-dashboard-setup
        path: solo/marketing/growth-marketer/ops-dashboard-setup
        required: true
        tier_gate: solo
      - slug: ops-financial-planning
        path: solo/marketing/gtm-strategist/ops-financial-planning
        required: true
        tier_gate: solo
      - slug: affiliate-program-solo
        path: solo/marketing/gtm-strategist/affiliate-program-solo
        required: true
        tier_gate: solo
    outputs:
      - "Monthly referral stats table"
    decision_gate: |
      Advance once stats reconcile against revenue.
  - name: "Pay"
    intent: "Payouts processed within the month."
    tasks:
      - "Approve commissions in the platform"
      - "Trigger payouts via Stripe or bank"
      - "Log each payout in the runway calculator"
    methodologies:
      - slug: ops-financial-planning
        path: solo/marketing/gtm-strategist/ops-financial-planning
        required: true
        tier_gate: solo
      - slug: ops-financial-planning
        path: solo/marketing/gtm-strategist/ops-financial-planning
        required: true
        tier_gate: solo
      - slug: referral-ledger
        path: solo/marketing/referral-ledger
        required: true
        tier_gate: solo
    outputs:
      - "Payouts executed"
      - "Runway update"
    decision_gate: |
      Advance only after all payouts are confirmed.
  - name: "Thank"
    intent: "Top referrers feel personally seen."
    tasks:
      - "Pick top 5 referrers by paid revenue driven"
      - "Send a personal message with stats"
      - "Invite them to share testimonials"
    methodologies:
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: solo
      - slug: growth-community-building
        path: solo/marketing/smm-manager/growth-community-building
        required: true
        tier_gate: solo
    outputs:
      - "Personal thank-you messages sent"
      - "Testimonial pipeline updates"
    decision_gate: |
      Done once all 5 receive a personal note.

common_pitfalls:
  - "Treating the playbook as a checklist instead of a decision tree"
  - "Skipping decision gates when intermediate progress feels good"
  - "Letting tools or platforms replace the founder's own judgement"

quality_checklist:
  - "Did each stage produce its named output or get explicitly skipped with a note?"
  - "Were decision gates respected or quietly bypassed?"
  - "Is the evidence trail strong enough to defend the verdict externally?"

related_playbooks:
  - solo-idea-to-validated-mvp
token_budget_estimate: 16500
cli_invocations:
  human:  "faion get-content affiliate-referral-check-and-payout --format md"
  agent:  "faion get-content affiliate-referral-check-and-payout --format context"
  json:   "faion get-content affiliate-referral-check-and-payout --format json"

changelog:
