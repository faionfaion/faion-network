# =============================================================================
# PLAYBOOK — Keyword research session for a new topic (deep, 2-3 hrs)
# tier=solo group=role-growth-marketing complexity=deep
# =============================================================================

slug: keyword-research-session-for-a-new-topic-deep-2-3-hrs
title: "Keyword research session for a new topic (deep, 2-3 hrs)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 113b1a6bd3545f9c

tier_min: solo
complexity: deep
context: [solo, team]
persona: ["solo-founder", "growth-marketer"]

intent: |
  From a fuzzy topic to a vetted cluster: pillar query + 8-15 supporting queries, intent-
  tagged, with difficulty + SERP feature notes. Output is a brief ready to hand to a writer
  (or yourself).

scope: |
  From a fuzzy topic to a vetted cluster: pillar query + 8-15 supporting queries, intent-
  tagged, with difficulty + SERP feature notes. Output is a brief ready to hand to a writer
  (or yourself).

summary: |
  From a fuzzy topic to a vetted cluster: pillar query + 8-15 supporting queries, intent-
  tagged, with difficulty + SERP feature notes. Output is a brief ready to hand to a writer
  (or yourself).

methodology_refs:
  - geek/marketing/seo-manager/google-ai-overviews-optimization
  - solo/marketing/content-marketer/growth-content-marketing
  - solo/marketing/content-marketer/growth-copywriting-fundamentals
  - solo/marketing/seo-manager/growth-seo-fundamentals
  - solo/marketing/seo-manager/seo-basics

success_criteria:
  - "One-line verdict posted to team channel/dashboard for this cycle"
  - "Act-now items either executed and verified, or explicitly handed off"
  - "Cadence ledger updated so the next run starts in under 5 minutes"
  - "No silent-drop: every anomaly resolved or queued with an owner"

stages:
  - name: "Pre-flight"
    intent: "Confirm inputs, dashboards, access, and yesterday's open items."
    tasks:
      - "Verify required dashboards/logs are reachable and current"
      - "Re-open yesterday's deferred items list"
      - "Set a hard time-box for this run"
    methodologies:
      - slug: google-ai-overviews-optimization
        path: geek/marketing/seo-manager/google-ai-overviews-optimization
        required: true
        tier_gate: geek
    outputs:
      - "Pre-flight checklist signed off"
    decision_gate: "Advance once every required surface is green; otherwise resolve the access/data gap first."
  - name: "Scan"
    intent: "Read the surface in one pass; capture anomalies without acting."
    tasks:
      - "Walk through every required panel/chart/feed once"
      - "Log anomalies and outliers in a single scratchpad"
      - "Do not act on anything yet"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Anomaly scratchpad with timestamps"
    decision_gate: "Advance once the scan is complete; if scan reveals an incident, branch to incident response."
  - name: "Reproduce"
    intent: "Reproduce the worst anomaly locally before acting."
    tasks:
      - "Pull a minimal repro from production data"
      - "Confirm the anomaly is real, not a dashboard artifact"
      - "Capture the repro for the eval set or test suite"
    methodologies:
      - slug: growth-copywriting-fundamentals
        path: solo/marketing/content-marketer/growth-copywriting-fundamentals
        required: true
        tier_gate: solo
    outputs:
      - "Repro snippet or fixture saved"
    decision_gate: "Advance once the anomaly is confirmed real; if dashboard artifact, fix the dashboard."
  - name: "Triage"
    intent: "Score and bucket anomalies into act-now / investigate / ignore."
    tasks:
      - "Score each anomaly by severity and reversibility"
      - "Bucket into act-now / investigate / ignore"
      - "Pick at most 1-3 act-now items for this cycle"
    methodologies:
      - slug: growth-seo-fundamentals
        path: solo/marketing/seo-manager/growth-seo-fundamentals
        required: true
        tier_gate: solo
    outputs:
      - "Triage table with verdicts"
    decision_gate: "Advance with no more than 1-3 act-now items; if more, raise the bar."
  - name: "Verify"
    intent: "Verify each act-now item landed and didn't regress neighbours."
    tasks:
      - "Run targeted check on the act-now item"
      - "Run the regression sniff-test on adjacent surfaces"
      - "Roll back any item that regressed something else"
    methodologies:
      - slug: seo-basics
        path: solo/marketing/seo-manager/seo-basics
        required: true
        tier_gate: solo
    outputs:
      - "Verification table per item"
    decision_gate: "Advance only on clean verification; rollback otherwise."
  - name: "Act"
    intent: "Execute the chosen act-now items end-to-end."
    tasks:
      - "Execute each act-now item with an explicit owner and rollback plan"
      - "Capture before/after evidence"
      - "Hand off anything that exceeds the time-box"
    methodologies:
      - slug: topical-authority
        path: solo/marketing/seo-manager/topical-authority
        required: true
        tier_gate: solo
    outputs:
      - "Action log with before/after evidence"
    decision_gate: "Advance once every act-now item is either done or explicitly handed off; never silent-drop."
  - name: "Close"
    intent: "Post the one-line verdict, queue follow-ups, and end the loop."
    tasks:
      - "Post a one-line verdict to the team channel/dashboard"
      - "Queue follow-ups in the appropriate backlog"
      - "Update the cadence ledger so future runs see the trend"
    methodologies:
      - slug: zero-click-search-adaptation
        path: solo/marketing/seo-manager/zero-click-search-adaptation
        required: true
        tier_gate: solo
    outputs:
      - "One-line verdict posted"
      - "Follow-ups queued"
    decision_gate: "Required output: a written verdict; no \"see how it goes\"."
  - name: "Document"
    intent: "Promote learnings into runbook, eval set, or rule."
    tasks:
      - "Update runbook for the failure mode"
      - "Add the failing example to the eval set"
      - "Open a rule/lint PR if the pattern is systemic"
    methodologies:
      - slug: google-ai-overviews-optimization
        path: geek/marketing/seo-manager/google-ai-overviews-optimization
        required: true
        tier_gate: geek
    outputs:
      - "Runbook delta"
      - "Eval set delta"
    decision_gate: "Advance once learnings live outside this scratchpad."
  - name: "Cadence handoff"
    intent: "Hand state to the next cycle so it starts faster."
    tasks:
      - "Pin open items to tomorrow's pre-flight"
      - "Update on-call notes if any"
      - "Close this run's loop with a timestamp"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Tomorrow's pre-flight seeded"
    decision_gate: "Required: next run can start in <5 min; if not, the handoff is broken."

token_budget_estimate: 12000

cli_invocations:
  human: "faion get-content keyword-research-session-for-a-new-topic-deep-2-3-hrs --format md"
  agent: "faion get-content keyword-research-session-for-a-new-topic-deep-2-3-hrs --format context"
  json:  "faion get-content keyword-research-session-for-a-new-topic-deep-2-3-hrs --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook from F-059-063 chunk-09."

