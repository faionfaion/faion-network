# =============================================================================
# PLAYBOOK v2 — Run sprint review + retrospective back-to-back
# Group: role-project-manager | Tier: solo | Complexity: medium
# =============================================================================

slug: run-sprint-review-retrospective-back-to-back
title: "Run sprint review + retrospective back-to-back"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 772453d7d659dccb

tier_min: solo
complexity: medium
context: ['solo', 'team']
persona: role-project-manager
group: role-project-manager

summary: "Two ceremonies at sprint close: review (showcase plus stakeholder feedback) and retro (team-internal improvement). Exit with a reviewed increment plus 1-3 concrete action items owned by named people."

intent: |
  Two ceremonies at sprint close: review (showcase plus stakeholder feedback) and retro (team-internal improvement). Exit with a reviewed increment plus 1-3 concrete action items owned by named people.

scope: |
  Two ceremonies at sprint close: review (showcase plus stakeholder feedback) and retro (team-internal improvement). Exit with a reviewed increment plus 1-3 concrete action items owned by named people.

methodology_refs:
  - pro/pm/pm-agile/scrum-ceremonies
  - pro/pm/pm-traditional/communications-management
  - pro/pm/pm-traditional/lessons-learned
  - pro/pm/pm-traditional/quality-management
  - pro/pm/pm-traditional/stakeholder-engagement
  - pro/pm/project-manager/team-development
  - solo/pm/pm-agile/notion-pm

success_criteria:
  - "Demo path passes a dry run"
  - "Stakeholder feedback captured against framing questions"
  - "1-3 action items with named owners"
  - "Actions visible in next sprint board"

stages:
  - name: "Review prep"
    intent: "Bring the right artifact to demo."
    tasks:
      - "Pick the smallest end-to-end slice to demo"
      - "Test the demo path on staging once"
      - "Prepare a 3-question framing for stakeholder feedback"
    methodologies:
      - slug: quality-management
        path: pro/pm/pm-traditional/quality-management
        required: true
        tier_gate: pro
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
    outputs:
      - "Demo path + framing questions"
    decision_gate: "Advance when demo path passes a dry run."
  - name: "Run the review"
    intent: "Showcase the increment + capture feedback."
    tasks:
      - "Demo the increment live (not slides)"
      - "Probe stakeholders with the framing questions"
      - "Capture feedback in a structured doc"
    methodologies:
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement
        path: pro/pm/pm-traditional/stakeholder-engagement
        required: true
        tier_gate: pro
    outputs:
      - "Review session feedback"
    decision_gate: "Advance when feedback is captured against the framing questions."
  - name: "Switch context to retro"
    intent: "Reset the room for team-internal work."
    tasks:
      - "Release client/stakeholder attendees"
      - "Re-frame the next hour as team-internal"
      - "Open with a quick energy check"
    methodologies:
      - slug: team-development
        path: pro/pm/project-manager/team-development
        required: true
        tier_gate: pro
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
    outputs:
      - "Retro setup"
    decision_gate: "Advance when the room is team-only and energy-checked."
  - name: "Rotate retro format"
    intent: "Use a different lens each cycle."
    tasks:
      - "Pick a retro format (mad-sad-glad, start-stop-continue, 4Ls)"
      - "Run timeboxed gather + group + decide"
      - "Capture themes, not raw items"
    methodologies:
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
      - slug: team-development
        path: pro/pm/project-manager/team-development
        required: true
        tier_gate: pro
    outputs:
      - "Retro themes"
    decision_gate: "Advance when 3-5 themes are surfaced (not raw vent)."
  - name: "Pick action items"
    intent: "End with 1-3 concrete actions, not 10."
    tasks:
      - "Pick 1-3 actions the team will actually do"
      - "Assign each to a named owner"
      - "Carry over only actions that survived from last retro"
    methodologies:
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
    outputs:
      - "Action item list (1-3)"
    decision_gate: "Advance when each action has a named owner + check-back."
  - name: "Publish + carry forward"
    intent: "Make the actions visible."
    tasks:
      - "Post the actions to the team channel"
      - "Add them to the next sprint as visible items"
      - "Log review feedback for product/PM follow-up"
    methodologies:
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
      - slug: notion-pm
        path: solo/pm/pm-agile/notion-pm
        required: true
        tier_gate: solo
    outputs:
      - "Published action items"
    decision_gate: "Required: actions visible in the next sprint's board."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content run-sprint-review-retrospective-back-to-back --format md"
  agent:  "faion get-content run-sprint-review-retrospective-back-to-back --format context"
  json:   "faion get-content run-sprint-review-retrospective-back-to-back --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
