slug: distribution-first-idea-validation-audience-before-product
title: "Distribution-First Idea Validation (audience before product)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 633baf9dbe82ae69

tier_min: solo
complexity: medium
context: [solo]
persona_hints: [P2]

intent: |
  Pick the next product by mining an audience you already own (or are growing), not by guessing market need.

scope: |
  Pick the next product by mining an audience you already own (or are growing), not by guessing market need. Done = signed waitlist + paying pre-orders before line 1 of code.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Mine the audience"
    intent: "Pull demand straight from your own people."
    tasks:
      - "Read 100 recent replies, DMs, support tickets"
      - "Cluster pains into 3-5 themes"
      - "Pick the densest theme"
    methodologies:
      - slug: mom-test
        path: solo/comms/communicator/mom-test
        required: true
        tier_gate: solo
      - slug: micro-mvps
        path: solo/product/product-planning/micro-mvps
        required: true
        tier_gate: solo
    outputs:
      - "Reply review log"
      - "Pain themes"
      - "Top theme"
    decision_gate: "Advance only when one theme has >=10 distinct demand signals."
  - name: "Frame the bet"
    intent: "Write a one-liner the audience will repeat."
    tasks:
      - "Write the bet as a tweet-length one-liner"
      - "Test it in a private DM round"
      - "Iterate until repeatable"
    methodologies:
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
    outputs:
      - "Bet one-liner"
      - "DM feedback"
      - "Iteration log"
    decision_gate: "Advance only when 3 friends can repeat the one-liner."
  - name: "Public hypothesis tweet"
    intent: "Float the bet publicly to widen signal."
    tasks:
      - "Post the bet as a hypothesis tweet"
      - "Tag the segment"
      - "Track replies, follows, and likes by ICP"
    methodologies:
      - slug: growth-reddit-marketing
        path: solo/marketing/content-marketer/growth-reddit-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Public hypothesis post"
      - "Signal counts"
      - "ICP-tagged engagement"
    decision_gate: "Advance only with >=20 ICP signals."
  - name: "Pre-sell page"
    intent: "Ask for money before code."
    tasks:
      - "Build a single-page Stripe pre-order"
      - "Position price for early-bird"
      - "Link in profile + newsletter"
    methodologies:
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
    outputs:
      - "Pre-order page live"
      - "First receipts"
      - "Profile + newsletter link"
    decision_gate: "Advance only with >=3 paid pre-orders in 7 days."
  - name: "Waitlist + cohort plan"
    intent: "Convert the spike into a launch cohort."
    tasks:
      - "Open a free waitlist alongside paid pre-orders"
      - "Plan a small cohort launch window"
      - "Pre-write the kickoff email"
    methodologies:
      - slug: growth-indiehackers-strategy
        path: solo/marketing/gtm-strategist/growth-indiehackers-strategy
        required: true
        tier_gate: solo
    outputs:
      - "Waitlist signups"
      - "Cohort plan"
      - "Kickoff email"
    decision_gate: "Advance only when waitlist + paid pre-orders combine to a viable first cohort."
  - name: "Build OR refund decision"
    intent: "Use the pre-order data to commit."
    tasks:
      - "Read the signal honestly"
      - "Decide: build or refund"
      - "Communicate the decision"
    methodologies:
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
    outputs:
      - "Decision doc"
      - "Refund or build comms"
      - "Customer notes"
    decision_gate: "Cycle closes when decision is communicated."

token_budget_estimate: 12000

cli_invocations:
  human:  "faion get-content distribution-first-idea-validation-audience-before-product --format md"
  agent:  "faion get-content distribution-first-idea-validation-audience-before-product --format context"
  json:   "faion get-content distribution-first-idea-validation-audience-before-product --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
