slug: sunset-rebuild-from-a-failed-launch
title: "Sunset + rebuild from a failed launch"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 0b67e260a98f2320

tier_min: solo
complexity: medium
context: [solo]
persona_hints: [P2]

intent: |
  Turn a missed launch into a clean shutdown plus a sharper next-bet plan: refund/migrate users, harvest learnings publicly, recycle assets, decide on rebuild vs pivot vs walk away.

scope: |
  Turn a missed launch into a clean shutdown plus a sharper next-bet plan: refund/migrate users, harvest learnings publicly, recycle assets, decide on rebuild vs pivot vs walk away.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Honest debrief"
    intent: "Write a brutally honest post-mortem."
    tasks:
      - "Fill the indie post-mortem template"
      - "Capture what worked, what failed, what surprised"
      - "Tag the dominant cause"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: feedback-management
        path: solo/product/product-operations/feedback-management
        required: true
        tier_gate: solo
      - slug: user-interviews
        path: solo/research/researcher/user-interviews
        required: true
        tier_gate: solo
    outputs:
      - "Post-mortem doc"
      - "Tagged causes"
      - "Surprise list"
    decision_gate: "Advance only when the cause is named, not vibed."
  - name: "Customer + community comms"
    intent: "Protect trust with everyone who showed up."
    tasks:
      - "Draft a public what-happened post"
      - "Send personal emails to paying customers"
      - "Process refunds / migrations"
    methodologies:
      - slug: growth-indiehackers-strategy
        path: solo/marketing/gtm-strategist/growth-indiehackers-strategy
        required: true
        tier_gate: solo
      - slug: product-lifecycle
        path: solo/product/product-operations/product-lifecycle
        required: true
        tier_gate: solo
    outputs:
      - "Public post"
      - "Customer emails sent"
      - "Refund/migration log"
    decision_gate: "Advance only when every paying customer has a personal touch."
  - name: "Asset harvest"
    intent: "Salvage the parts worth keeping."
    tasks:
      - "Inventory code, copy, audience, learnings"
      - "Tag each: keep / archive / kill"
      - "Move keepers to a next-bet folder"
    methodologies:
      - slug: ops-customer-support
        path: solo/marketing/gtm-strategist/ops-customer-support
        required: true
        tier_gate: solo
      - slug: idea-generation
        path: solo/research/market-researcher/idea-generation
        required: true
        tier_gate: solo
    outputs:
      - "Asset inventory"
      - "Keep folder"
      - "Archive/kill log"
    decision_gate: "Advance only when every asset has a tag."
  - name: "Public learnings post"
    intent: "Turn the failure into audience compounding."
    tasks:
      - "Write a long-form learnings post"
      - "Cross-post to X / IH / newsletter"
      - "Engage with every comment"
    methodologies:
      - slug: ops-financial-planning
        path: solo/marketing/gtm-strategist/ops-financial-planning
        required: true
        tier_gate: solo
      - slug: niche-evaluation
        path: solo/research/market-researcher/niche-evaluation
        required: true
        tier_gate: solo
    outputs:
      - "Learnings post"
      - "Cross-post log"
      - "Engagement log"
    decision_gate: "Advance only when post is live AND replied to."
  - name: "Decide rebuild vs pivot vs walk"
    intent: "Apply kill criteria, not nostalgia."
    tasks:
      - "Score against the indie kill criteria"
      - "List candidate next bets"
      - "Pick: rebuild / pivot / walk"
    methodologies:
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
      - slug: jobs-to-be-done
        path: solo/research/researcher/jobs-to-be-done
        required: true
        tier_gate: solo
    outputs:
      - "Score sheet"
      - "Candidate list"
      - "Decision call"
    decision_gate: "Advance only when one path is named in writing."
  - name: "Plan the next move"
    intent: "Write a tight plan for whichever path won."
    tasks:
      - "If rebuild: spec the new v1"
      - "If pivot: open the new-bet sprint"
      - "If walk: wind down hosting, close accounts"
    methodologies:
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
      - slug: problem-validation-2026
        path: solo/research/researcher/problem-validation-2026
        required: true
        tier_gate: solo
    outputs:
      - "Next-move plan"
      - "Wind-down actions (if applicable)"
      - "First-week tasks"
    decision_gate: "Cycle closes when first week is scheduled."

token_budget_estimate: 12000

cli_invocations:
  human:  "faion get-content sunset-rebuild-from-a-failed-launch --format md"
  agent:  "faion get-content sunset-rebuild-from-a-failed-launch --format context"
  json:   "faion get-content sunset-rebuild-from-a-failed-launch --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
