# =============================================================================
# PLAYBOOK v2 — Weekly product metrics review
# Group: role-product-manager | Tier: solo | Complexity: medium
# =============================================================================

slug: weekly-product-metrics-review
title: "Weekly product metrics review"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 086061918f2b774f

tier_min: solo
complexity: medium
context: ['solo', 'team']
persona: role-product-manager
group: role-product-manager

summary: "North-star plus 3-5 leading indicators reviewed against target band; deviations have a hypothesis; one action item is filed per red metric."

intent: |
  North-star plus 3-5 leading indicators reviewed against target band; deviations have a hypothesis; one action item is filed per red metric.

scope: |
  North-star plus 3-5 leading indicators reviewed against target band; deviations have a hypothesis; one action item is filed per red metric.

methodology_refs:
  - pro/pm/pm-agile/reporting-basics
  - pro/product/product-manager/experimentation-at-scale
  - pro/product/product-manager/product-analytics
  - solo/product/product-manager/okr-setting
  - solo/product/product-manager/outcome-based-roadmaps-advanced
  - solo/product/product-operations/product-analytics

success_criteria:
  - "Every metric has a documented RAG status"
  - "Every red metric has a written deviation hypothesis"
  - "Every red metric has exactly one owned action item"
  - "A calibration note exists for the next planning cycle"

stages:
  - name: "Refresh dashboard"
    intent: "Pull a clean snapshot before reading anything."
    tasks:
      - "Confirm data freshness for every panel"
      - "Note any panel with stale or broken data"
      - "Refresh derived calculations"
    methodologies:
      - slug: product-analytics
        path: pro/product/product-manager/product-analytics
        required: true
        tier_gate: pro
      - slug: product-analytics
        path: solo/product/product-operations/product-analytics
        required: true
        tier_gate: solo
    outputs:
      - "Refreshed dashboard with freshness timestamps"
    decision_gate: "Advance when every panel is current or explicitly flagged stale."
  - name: "Read against target band"
    intent: "Compare each metric to the target band, not to last week."
    tasks:
      - "For each metric, classify against band: green / amber / red"
      - "Avoid week-over-week framing for noisy metrics"
      - "Use rolling windows for low-volume metrics"
    methodologies:
      - slug: reporting-basics
        path: pro/pm/pm-agile/reporting-basics
        required: true
        tier_gate: pro
    outputs:
      - "RAG status per metric"
    decision_gate: "Advance when every tracked metric has a documented RAG status."
  - name: "Hypothesise deviations"
    intent: "Every red gets a hypothesis before discussion."
    tasks:
      - "For each red metric, write a one-line cause hypothesis"
      - "Distinguish 'we know' from 'we suspect'"
      - "Tag external vs internal cause"
    methodologies:
      - slug: outcome-based-roadmaps-advanced
        path: solo/product/product-manager/outcome-based-roadmaps-advanced
        required: true
        tier_gate: solo
    outputs:
      - "Deviation hypothesis table"
    decision_gate: "Advance when every red metric has at least one hypothesis on paper."
  - name: "File action items"
    intent: "Convert reds into single owned action items."
    tasks:
      - "File exactly one action item per red metric"
      - "Assign an owner and a check-back date"
      - "Tag the action against the originating bet"
    methodologies:
      - slug: okr-setting
        path: solo/product/product-manager/okr-setting
        required: true
        tier_gate: solo
      - slug: experimentation-at-scale
        path: pro/product/product-manager/experimentation-at-scale
        required: true
        tier_gate: pro
    outputs:
      - "Action item list (one per red)"
    decision_gate: "Advance when each red has exactly one filed action."
  - name: "Calibration check"
    intent: "Sanity-check whether targets themselves are wrong."
    tasks:
      - "If 3+ greens hold for 4 weeks, ask if the target is too easy"
      - "If 3+ reds hold for 4 weeks, ask if the target is wrong"
      - "Log calibration findings for the next planning cycle"
    methodologies:
      - slug: okr-setting
        path: solo/product/product-manager/okr-setting
        required: true
        tier_gate: solo
      - slug: outcome-based-roadmaps-advanced
        path: solo/product/product-manager/outcome-based-roadmaps-advanced
        required: true
        tier_gate: solo
    outputs:
      - "Target calibration note"
    decision_gate: "Required: a calibration note for the next planning cycle even if no change is proposed."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content weekly-product-metrics-review --format md"
  agent:  "faion get-content weekly-product-metrics-review --format context"
  json:   "faion get-content weekly-product-metrics-review --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
