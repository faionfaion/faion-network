# =============================================================================
# PLAYBOOK v2 — Backlog grooming and prioritization session
# Group: role-product-manager | Tier: solo | Complexity: medium
# =============================================================================

slug: backlog-grooming-prioritization-session
title: "Backlog grooming and prioritization session"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: dac47667a1dd03dd

tier_min: solo
complexity: medium
context: ['solo', 'team']
persona: role-product-manager
group: role-product-manager

summary: "Backlog under 100 items, every item has an owner plus score plus tag, stale items archived; the top-20 ready-to-pull queue exists."

intent: |
  Backlog under 100 items, every item has an owner plus score plus tag, stale items archived; the top-20 ready-to-pull queue exists.

scope: |
  Backlog under 100 items, every item has an owner plus score plus tag, stale items archived; the top-20 ready-to-pull queue exists.

methodology_refs:
  - pro/pm/pm-agile/reporting-basics
  - pro/product/product-manager/stakeholder-management
  - solo/product/product-manager/backlog-management
  - solo/product/product-manager/feature-prioritization-moscow
  - solo/product/product-manager/feature-prioritization-rice
  - solo/product/product-manager/okr-setting
  - solo/product/product-operations/backlog-management

success_criteria:
  - "Backlog under 100 items"
  - "Every item has owner, tag, and score"
  - "Top-20 ready-to-pull queue exists"
  - "Graveyard has one-line rationale per item"

stages:
  - name: "Audit size"
    intent: "Refuse to groom past 100 items."
    tasks:
      - "Count current backlog items"
      - "Identify items older than 90 days with no movement"
      - "Move stale items to a graveyard"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-manager/backlog-management
        required: true
        tier_gate: solo
      - slug: backlog-management
        path: solo/product/product-operations/backlog-management
        required: true
        tier_gate: solo
    outputs:
      - "Backlog size after archive"
    decision_gate: "Advance when the backlog is under 100 items."
  - name: "Tag + own"
    intent: "Every item gets a theme tag and an owner."
    tasks:
      - "Apply theme tags (max 12)"
      - "Assign an owner per item"
      - "Reject items without an owner — close or assign"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-operations/backlog-management
        required: true
        tier_gate: solo
      - slug: stakeholder-management
        path: pro/product/product-manager/stakeholder-management
        required: true
        tier_gate: pro
    outputs:
      - "Tagged + owned backlog"
    decision_gate: "Advance when every item has a tag and an owner."
  - name: "Score"
    intent: "Run MoSCoW pass; RICE for the top quartile."
    tasks:
      - "MoSCoW the full backlog quickly"
      - "RICE the top 25 items only"
      - "Note the OKR each item ties to"
    methodologies:
      - slug: feature-prioritization-moscow
        path: solo/product/product-manager/feature-prioritization-moscow
        required: true
        tier_gate: solo
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
      - slug: okr-setting
        path: solo/product/product-manager/okr-setting
        required: true
        tier_gate: solo
    outputs:
      - "Scored backlog"
    decision_gate: "Advance when every item has a MoSCoW class."
  - name: "Top-20 queue"
    intent: "Build a ready-to-pull queue."
    tasks:
      - "Pull the top 20 by score"
      - "Confirm each has AC + dependencies surfaced"
      - "Mark each 'ready to pull'"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-manager/backlog-management
        required: true
        tier_gate: solo
      - slug: reporting-basics
        path: pro/pm/pm-agile/reporting-basics
        required: true
        tier_gate: pro
    outputs:
      - "Top-20 ready queue"
    decision_gate: "Advance when 20 items pass the ready definition."
  - name: "Graveyard rationale"
    intent: "Make 'never' loud so it does not return."
    tasks:
      - "For every archived item, write a one-line rationale"
      - "File the graveyard list separately from active backlog"
      - "Schedule a quarterly graveyard scan"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-manager/backlog-management
        required: true
        tier_gate: solo
    outputs:
      - "Graveyard log with rationale"
    decision_gate: "Required: every graveyard item has a one-line reason."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content backlog-grooming-prioritization-session --format md"
  agent:  "faion get-content backlog-grooming-prioritization-session --format context"
  json:   "faion get-content backlog-grooming-prioritization-session --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
