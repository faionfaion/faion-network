# =============================================================================
# faion playbook manifest — P1 solo SaaS builder
# Generated for F-064 from playbook-index.json entry #5
# =============================================================================

slug: sunday-roadmap-ritual
title: "Sunday roadmap and week-shaping ritual"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 66d035a5a0adeec4

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P1]

intent: |
  Friday-clear backlog → Monday-morning task primed with prompt and acceptance.

scope: |
  Solo founder runs a 60-minute Sunday ritual: top 3 outcomes for the week chosen, single-tasked file/board updated, no-go items deferred, Monday-morning first task primed with prompt + acceptance. Exit artifact is a week-plan note + Monday task ready to start.

non_goals:
  - "Multi-week roadmap rewrite — that's quarterly"
  - "Backlog grooming of >10 items — keep it tight"

prerequisites:
  - "Existing backlog file or board with current items"
  - "Friday-closeout completed (week reflection done)"

success_criteria:
  - "Top 3 outcomes written with acceptance criteria"
  - "Monday task primed with prompt + spec"
  - "No-go items explicitly deferred (not abandoned)"
  - "Ritual completed in ≤60 minutes"

stages:
  - name: "Review"
    intent: "What happened last week, what shifted in priorities."
    tasks:
      - "Read last week's outcomes vs actuals"
      - "Update mistake-memory if relevant"
      - "Pull new signals from inbox + analytics"
    methodologies:
      - slug: mistake-memory
        path: solo/sdd/sdd/mistake-memory
        required: true
        tier_gate: solo
      - slug: pattern-memory
        path: solo/sdd/sdd/pattern-memory
        required: true
        tier_gate: solo
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: solo
    outputs:
      - "Last-week review notes"
    decision_gate: |
      Advance when last week is closed. Don't start planning if last week isn't reflected on.
  - name: "Prioritise"
    intent: "Pick top 3 outcomes for the week using RICE or MoSCoW."
    tasks:
      - "List candidate outcomes"
      - "Score against revenue-relevance filter"
      - "Cut to 3"
    methodologies:
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
      - slug: feature-prioritization-moscow
        path: solo/product/product-manager/feature-prioritization-moscow
        required: true
        tier_gate: solo
      - slug: backlog-management
        path: solo/product/product-operations/backlog-management
        required: true
        tier_gate: solo
      - slug: outcome-based-roadmaps
        path: solo/product/product-planning/outcome-based-roadmaps
        required: true
        tier_gate: solo
    outputs:
      - "Top 3 outcomes list"
    decision_gate: |
      Advance when list is exactly 3. Refuse 4+ — single-operator constraint.
  - name: "Spec"
    intent: "Write acceptance criteria for the Monday task."
    tasks:
      - "Pick Monday's first task"
      - "Write 1-paragraph spec + acceptance"
      - "Prime AI prompt if applicable"
    methodologies:
      - slug: writing-specifications
        path: solo/sdd/sdd/writing-specifications
        required: true
        tier_gate: solo
    outputs:
      - "Monday spec.md"
      - "AI prompt ready"
    decision_gate: |
      Advance when Monday task is start-ready. No 'I'll figure it out Monday'.

common_pitfalls:
  - "Picking 5+ outcomes 'just in case' — guarantees at least 2 will slip"
  - "Skipping review — repeats last week's mistakes"

quality_checklist:
  - "Could I finish all 3 outcomes if half the week disappeared?"
  - "Is Monday's first task start-ready, or am I still thinking about it?"

related_playbooks:
  - friday-bug-bash-triage
  - solo-founder-operating-system

token_budget_estimate: 8000
cli_invocations:
  human:  "faion get-content sunday-roadmap-ritual --format md"
  agent:  "faion get-content sunday-roadmap-ritual --format context"
  json:   "faion get-content sunday-roadmap-ritual --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P1 solo SaaS builder persona"

gaps:
  - methodology_slug: solo-weekly-cadence-template
    expected_tier: solo
    blocks_stage: 2
    note: "Prioritise stage needs ready-to-fill weekly template"
  - methodology_slug: rice-for-one-person-cheatsheet
    expected_tier: solo
    blocks_stage: 2
    note: "Solo-scale RICE differs from team RICE — needs cheatsheet"
