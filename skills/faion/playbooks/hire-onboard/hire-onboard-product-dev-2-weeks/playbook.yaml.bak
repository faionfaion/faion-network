# =============================================================================
# faion playbook manifest — P6 product-dev team
# Generated for F-064 from playbook-index.json p6-product-dev-team entry 3
# =============================================================================

slug: hire-onboard-product-dev-2-weeks
title: "Hire + onboard a new product-team dev in 2 weeks"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 155826ef8795b144

tier_min: geek
complexity: medium
context: [team]
persona_hints: [P6]

intent: |
  Signed offer → first merged PR + first on-call shadow within 14 days.

scope: |
  A new product-dev hire walks in on day 1 and walks out of day 14 with a merged PR, an on-call shadow under their belt, a 30/60/90-day plan filed, and a buddy. Their CLAUDE.md/AGENTS.md context pyramid is set up; they have run the dev loop locally; they know the incident protocol; the team has a written retro of how week-1 went.

non_goals:
  - "Sourcing + screening — covered by hiring-screen-take-home-review and hire-to-productive-60-days-in-house"
  - "Long-term performance reviews — out of scope for 14-day window"
  - "Company-wide HR compliance training — handled by HR centrally"

prerequisites:
  - "Signed offer with start date"
  - "Laptop + accounts provisioned before day 1"
  - "Buddy assigned at offer-signature time, not day 1"
  - "Repos have CLAUDE.md + AGENTS.md context pyramid in place"

success_criteria:
  - "30/60/90-day plan filed by end of day 3"
  - "Local dev loop running by end of day 2"
  - "First PR merged by day 10"
  - "First on-call shadow completed by day 14"
  - "Day-14 retro between hire + manager + buddy"
  - "Hire has read and acknowledged incident-runbook + secrets policy"

stages:
  - name: "Pre-arrival prep"
    intent: "Accounts, repo access, buddy, 30/60/90 skeleton ready before day 1."
    tasks:
      - "Provision laptop + accounts using secrets-management protocol"
      - "Assign a buddy and a manager 1:1 cadence"
      - "Pre-fill 30/60/90 skeleton tied to a small first owned ticket"
      - "Confirm EVP messaging on day-1 welcome packet"
    methodologies:
      - slug: employee-value-proposition
        path: pro/comms/hr-recruiter/employee-value-proposition
        required: true
        tier_gate: pro
      - slug: 30-60-90-day-plan
        path: pro/comms/hr-recruiter/30-60-90-day-plan
        required: true
        tier_gate: pro
      - slug: secrets-management
        path: pro/infra/cicd-engineer/secrets-management
        required: true
        tier_gate: pro
    outputs:
      - "Provisioned environment + accounts"
      - "30/60/90 skeleton + buddy assignment"
    decision_gate: |
      Advance when laptop boots, repo clones, buddy and manager are calendared. Otherwise day 1 burns on logistics.

  - name: "Week 1: orient + first PR"
    intent: "Hire understands repo layout, runs dev loop, ships a small first PR."
    tasks:
      - "Walk the AGENTS.md context pyramid"
      - "Pair with buddy on dev loop locally"
      - "Pick a starter ticket with clear AC"
      - "Open and merge a small PR with conventional commits"
    methodologies:
      - slug: onboarding-30-day
        path: pro/comms/hr-recruiter/onboarding-30-day
        required: true
        tier_gate: pro
      - slug: onboarding
        path: pro/comms/hr-recruiter/onboarding
        required: true
        tier_gate: pro
      - slug: claude-md-creation
        path: geek/dev/code-quality/claude-md-creation
        required: true
        tier_gate: geek
      - slug: llm-friendly-architecture
        path: geek/dev/code-quality/llm-friendly-architecture
        required: true
        tier_gate: geek
      - slug: kb-agents-md-context-pyramid
        path: geek/sdlc-ai/kb-agents-md-context-pyramid
        required: true
        tier_gate: geek
      - slug: claude-code
        path: geek/ai/claude-code
        required: true
        tier_gate: geek
      - slug: gov-conventional-commits-enforced
        path: geek/sdlc-ai/gov-conventional-commits-enforced
        required: true
        tier_gate: geek
      - slug: lint-precommit-floor
        path: geek/sdlc-ai/lint-precommit-floor
        required: true
        tier_gate: geek
      - slug: task-plan-mode-locked-execution
        path: geek/sdlc-ai/task-plan-mode-locked-execution
        required: true
        tier_gate: geek
      - slug: task-spec-kit-three-step
        path: geek/sdlc-ai/task-spec-kit-three-step
        required: true
        tier_gate: geek
      - slug: task-worktree-runtime-isolation
        path: geek/sdlc-ai/task-worktree-runtime-isolation
        required: true
        tier_gate: geek
    outputs:
      - "Working local dev loop"
      - "First merged PR"
    decision_gate: |
      Advance when the hire has merged a PR they understand and can explain back to their buddy.

  - name: "Week 2: incident protocol + on-call shadow"
    intent: "Hire is incident-literate and has shadowed at least one on-call rotation slot."
    tasks:
      - "Walk the incident runbook + read-only-investigation default"
      - "Walk the tool-tier approval gate"
      - "Shadow an on-call slot with the buddy"
      - "Dry-run a postmortem auto-draft on a synthetic incident"
    methodologies:
      - slug: onboarding-60-90-day
        path: pro/comms/hr-recruiter/onboarding-60-90-day
        required: true
        tier_gate: pro
      - slug: inc-runbook-as-markdown-tagged-steps
        path: geek/sdlc-ai/inc-runbook-as-markdown-tagged-steps
        required: true
        tier_gate: geek
      - slug: inc-read-only-investigation-default
        path: geek/sdlc-ai/inc-read-only-investigation-default
        required: true
        tier_gate: geek
      - slug: inc-tool-tier-approval-gate
        path: geek/sdlc-ai/inc-tool-tier-approval-gate
        required: true
        tier_gate: geek
      - slug: inc-postmortem-auto-draft-no-publish
        path: geek/sdlc-ai/inc-postmortem-auto-draft-no-publish
        required: true
        tier_gate: geek
    outputs:
      - "On-call shadow record"
      - "Acknowledged incident protocol"
    decision_gate: |
      Advance when hire can articulate the read-only-investigation default and the approval-gate boundary unaided.

  - name: "Day-14 retro + retention loop"
    intent: "Capture what worked, what didn't, what to keep — wire to retention."
    tasks:
      - "Retro between hire + manager + buddy"
      - "Update mistake-memory / patterns-memory with onboarding lessons"
      - "Confirm 30/60/90 plan still fits or rewrite"
      - "Set retention checkpoint at day 60"
    methodologies:
      - slug: retention-compliance
        path: pro/comms/hr-recruiter/retention-compliance
        required: true
        tier_gate: pro
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
    outputs:
      - "Day-14 retro doc"
      - "Updated 30/60/90 plan"
    decision_gate: |
      Required output: written retro. If the hire stops at week 14 with no retro, the next hire repeats the same friction.

common_pitfalls:
  - "Buddy assigned on day 1, not before — wastes the first 48h"
  - "Starter ticket too ambitious — kills momentum"
  - "Skipping the incident protocol walkthrough — first page becomes the lesson"
  - "Treating onboarding as 'HR's job' — engineering owns ramp"

quality_checklist:
  - "Can the hire explain CLAUDE.md context pyramid back to me?"
  - "Did the first PR pass our normal gates with no special exceptions?"
  - "Did the hire ask at least one good repo-shaped question that surfaced a real gap?"

related_playbooks:
  - hire-to-productive-60-days-in-house
  - hiring-screen-take-home-review
  - adopt-faion-org-wide-overrides

token_budget_estimate: 18000
cli_invocations:
  human:  "faion get-content hire-onboard-product-dev-2-weeks --format md"
  agent:  "faion get-content hire-onboard-product-dev-2-weeks --format context"
  json:   "faion get-content hire-onboard-product-dev-2-weeks --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P6 product-dev team persona"

gaps:
  - methodology_slug: ai-pair-onboarding-script
    expected_tier: geek
    blocks_stage: 2
    note: "Week-1 stage needs an AI-pair script for guided first-PR sessions"
  - methodology_slug: ramp-task-difficulty-ladder
    expected_tier: geek
    blocks_stage: 2
    note: "Starter ticket selection needs a written difficulty ladder so picks aren't ad-hoc"
