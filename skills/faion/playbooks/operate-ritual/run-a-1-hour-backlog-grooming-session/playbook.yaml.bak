# =============================================================================
# PLAYBOOK v2 — Run a 1-hour backlog grooming session
# Group: role-project-manager | Tier: solo | Complexity: medium
# =============================================================================

slug: run-a-1-hour-backlog-grooming-session
title: "Run a 1-hour backlog grooming session"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 1b0b281a0cecf79e

tier_min: solo
complexity: medium
context: ['solo', 'team']
persona: role-project-manager
group: role-project-manager

summary: "Weekly grooming: top 20 backlog items are readable, sized, dependency-mapped. Exit: 2 sprints of well-formed work ready to pull."

intent: |
  Weekly grooming: top 20 backlog items are readable, sized, dependency-mapped. Exit: 2 sprints of well-formed work ready to pull.

scope: |
  Weekly grooming: top 20 backlog items are readable, sized, dependency-mapped. Exit: 2 sprints of well-formed work ready to pull.

methodology_refs:
  - pro/pm/pm-agile/scrum-ceremonies
  - pro/pm/pm-traditional/schedule-development
  - pro/pm/pm-traditional/scope-management
  - pro/pm/pm-traditional/wbs-creation
  - pro/pm/pm-traditional/work-breakdown-structure
  - pro/pm/project-manager/jira-workflow-management

success_criteria:
  - "Top 20 walked and irrelevant flagged"
  - "Every item passes DoR or is sent back"
  - "Every item has a size or a 'needs split' tag"
  - "Every dependency has an owner"
  - "Ready queue sized for 2 sprints"

stages:
  - name: "Walk top 20"
    intent: "Walk the top 20 in the order they will be pulled."
    tasks:
      - "Sort the backlog by priority"
      - "Pull the top 20 into the grooming view"
      - "Tag any that lost relevance for removal"
    methodologies:
      - slug: jira-workflow-management
        path: pro/pm/project-manager/jira-workflow-management
        required: true
        tier_gate: pro
      - slug: scope-management
        path: pro/pm/pm-traditional/scope-management
        required: true
        tier_gate: pro
    outputs:
      - "Top-20 grooming view"
    decision_gate: "Advance when 20 items are queued and irrelevant ones are flagged."
  - name: "Readable?"
    intent: "Every item passes a 'definition of ready' check."
    tasks:
      - "For each item, confirm the description tells the why + the what"
      - "Add missing context; do not assume"
      - "Reject items that still cannot be read"
    methodologies:
      - slug: scope-management
        path: pro/pm/pm-traditional/scope-management
        required: true
        tier_gate: pro
      - slug: work-breakdown-structure
        path: pro/pm/pm-traditional/work-breakdown-structure
        required: true
        tier_gate: pro
    outputs:
      - "Definition-of-ready pass results"
    decision_gate: "Advance when every item passes DoR or is sent back to refinement."
  - name: "Sized?"
    intent: "Apply story points or t-shirt sizes."
    tasks:
      - "Size with the team via planning poker or async vote"
      - "Re-size items >XL or unclear"
      - "Note items that need to be split"
    methodologies:
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
    outputs:
      - "Sized items"
    decision_gate: "Advance when every item has a size or a 'needs split' tag."
  - name: "Dependencies?"
    intent: "Map cross-item or cross-team dependencies."
    tasks:
      - "Tag dependencies per item"
      - "Confirm dependency owners are aware"
      - "Note any item blocked by a missing dependency"
    methodologies:
      - slug: wbs-creation
        path: pro/pm/pm-traditional/wbs-creation
        required: true
        tier_gate: pro
      - slug: schedule-development
        path: pro/pm/pm-traditional/schedule-development
        required: true
        tier_gate: pro
    outputs:
      - "Dependency annotations"
    decision_gate: "Advance when each dependency has an owner."
  - name: "Ready queue"
    intent: "Build the 2-sprint ready queue."
    tasks:
      - "Promote items that pass readable + sized + dependency checks"
      - "Cap the ready queue at 2 sprints of work"
      - "Move overflow back to the wider backlog"
    methodologies:
      - slug: jira-workflow-management
        path: pro/pm/project-manager/jira-workflow-management
        required: true
        tier_gate: pro
      - slug: scope-management
        path: pro/pm/pm-traditional/scope-management
        required: true
        tier_gate: pro
    outputs:
      - "2-sprint ready queue"
    decision_gate: "Required: ready queue is sized for 2 sprints of capacity."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content run-a-1-hour-backlog-grooming-session --format md"
  agent:  "faion get-content run-a-1-hour-backlog-grooming-session --format context"
  json:   "faion get-content run-a-1-hour-backlog-grooming-session --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
