    expected_tier: solo
    blocks_stage: 1
    note: "Methodology stub referenced by lifecycle-email-send-post-send-analytics-per-send; author under knowledge/solo/..."
  - methodology_slug: deliverability-incident-runbook
    expected_tier: solo
    blocks_stage: 1
    note: "Methodology stub referenced by lifecycle-email-send-post-send-analytics-per-send; author under knowledge/solo/..."
