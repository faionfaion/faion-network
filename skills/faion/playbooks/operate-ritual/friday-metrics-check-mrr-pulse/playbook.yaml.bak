slug: friday-metrics-check-mrr-pulse
title: "Friday metrics check & MRR pulse"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: d7f3564dcbf0bc65

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P1]

intent: |
  30-minute KPI scan: MRR / churn / activation / signup funnel reviewed, anomalies flagged, one experiment chosen for next week, one growth lever pushed.

scope: |
  30-minute KPI scan: MRR / churn / activation / signup funnel reviewed, anomalies flagged, one experiment chosen for next week, one growth lever pushed.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Open the dashboard"
    intent: "30-minute scan of the whole funnel."
    tasks:
      - "Open the single-screen KPI dashboard"
      - "Scan MRR / churn / activation / signup"
      - "Note any week-over-week movement >|10%|"
    methodologies:
      - slug: ab-testing-basics
        path: solo/dev/automation-tooling/ab-testing-basics
        required: true
        tier_gate: solo
      - slug: ops-subscription-models
        path: solo/marketing/gtm-strategist/ops-subscription-models
        required: true
        tier_gate: solo
    outputs:
      - "Snapshot screenshot"
      - "Week-over-week delta"
      - "Anomaly list"
    decision_gate: "Advance only with a full snapshot saved."
  - name: "Anomaly investigation"
    intent: "Probe each anomaly until it has a cause."
    tasks:
      - "Drill into the largest anomaly first"
      - "Cross-check with deploys + experiments"
      - "Tag root cause: known / unknown / noise"
    methodologies:
      - slug: ab-testing-implementation
        path: solo/dev/automation-tooling/ab-testing-implementation
        required: true
        tier_gate: solo
      - slug: okr-setting
        path: solo/product/product-manager/okr-setting
        required: true
        tier_gate: solo
    outputs:
      - "Root-cause notes"
      - "Cross-check log"
      - "Anomaly tags"
    decision_gate: "Advance only when every anomaly is tagged."
  - name: "Pick one experiment"
    intent: "One change, one metric, next week."
    tasks:
      - "List 2-3 experiment candidates from this weeks signal"
      - "Pick one with the clearest expected impact"
      - "Pre-register the hypothesis + metric"
    methodologies:
      - slug: growth-landing-page-design
        path: solo/marketing/conversion-optimizer/growth-landing-page-design
        required: true
        tier_gate: solo
      - slug: outcome-based-roadmaps
        path: solo/product/product-manager/outcome-based-roadmaps
        required: true
        tier_gate: solo
    outputs:
      - "Chosen experiment"
      - "Pre-registered hypothesis"
      - "Sample-size estimate"
    decision_gate: "Advance only with exactly one experiment selected."
  - name: "Push one growth lever"
    intent: "Ship one concrete growth action today."
    tasks:
      - "Pick a lever (cold outreach / content / referral nudge)"
      - "Execute the action right now in this slot"
      - "Log the action and the channel"
    methodologies:
      - slug: ops-dashboard-setup
        path: solo/marketing/growth-marketer/ops-dashboard-setup
        required: true
        tier_gate: solo
      - slug: product-analytics
        path: solo/product/product-operations/product-analytics
        required: true
        tier_gate: solo
    outputs:
      - "Lever pulled"
      - "Action log"
      - "Channel + KPI link"
    decision_gate: "Advance only when the action actually shipped (not just planned)."
  - name: "Close the loop"
    intent: "Write the pulse and queue Monday actions."
    tasks:
      - "Write a 5-line pulse doc"
      - "Queue Mondays first task"
      - "Set the alert tripwires"
    methodologies:
      - slug: plausible-analytics
        path: solo/marketing/growth-marketer/plausible-analytics
        required: true
        tier_gate: solo
    outputs:
      - "Friday pulse doc"
      - "Monday task pre-loaded"
      - "Tripwire rules"
    decision_gate: "Cycle closes when the pulse doc is committed."

token_budget_estimate: 6000

cli_invocations:
  human:  "faion get-content friday-metrics-check-mrr-pulse --format md"
  agent:  "faion get-content friday-metrics-check-mrr-pulse --format context"
  json:   "faion get-content friday-metrics-check-mrr-pulse --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
