# =============================================================================
# faion playbook manifest — P6 product-dev team
# Generated for F-064 from playbook-index.json p6-product-dev-team entry 20
# =============================================================================

slug: quarterly-okr-cascade-weekly-review
title: "Quarterly OKR cascade, weekly review, post-quarter retro"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: a6dc2d4cab655bdc

tier_min: geek
complexity: medium
context: [team]
persona_hints: [P6]

intent: |
  Disconnected OKRs → cascaded company → team → personal OKRs with weekly check-ins and a quarterly blameless retro.

scope: |
  Company OKR cascades to team OKR cascades to personal OKR. Weekly check-ins happen in 1:1s. A mid-quarter pivot gate decides whether to carry OKRs forward or rewrite. End-of-quarter blameless retro closes the loop. Output: every dev knows what their work ladders to, and the team has explicit carry-over rules.

non_goals:
  - "Setting the OKRs themselves — see quarter-planning-okr-reset"
  - "Performance reviews — out of scope"
  - "Daily/weekly delivery cadences — see daily-standup-ai-prebrief and backlog-grooming-pm-tech-lead"

prerequisites:
  - "Company OKRs published"
  - "Team OKRs in place (from quarter-planning-okr-reset)"
  - "1:1 cadence wired between manager and each direct"

success_criteria:
  - "Personal OKRs cascaded for every dev"
  - "Weekly check-in template used consistently"
  - "Mid-quarter pivot gate evaluated"
  - "Carry-over rules applied at quarter close"
  - "Blameless retro doc published"

stages:
  - name: "Cascade to personal"
    intent: "Team OKRs → personal OKRs in every 1:1."
    tasks:
      - "Manager + direct agree on 1-3 personal OKRs that ladder to team OKRs"
      - "Confirm each KR is measurable + has a numeric target"
      - "Tag dependencies between people"
    methodologies:
      - slug: okr-setting
        path: solo/product/product-planning/okr-setting
        required: true
        tier_gate: solo
      - slug: reporting-basics
        path: pro/pm/pm-agile/reporting-basics
        required: true
        tier_gate: pro
    outputs:
      - "Personal OKR doc per dev"
    decision_gate: |
      Advance only when each dev has 1-3 personal OKRs traceable to team OKRs.

  - name: "Weekly check-in cadence"
    intent: "OKR progress reviewed weekly in 1:1; status doesn't drift."
    tasks:
      - "Weekly status update per OKR (green / yellow / red)"
      - "Capture blockers"
      - "Reflexion-learning on misses"
    methodologies:
      - slug: reporting-basics
        path: pro/pm/pm-agile/reporting-basics
        required: true
        tier_gate: pro
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: solo
    outputs:
      - "Weekly check-in log"
    decision_gate: |
      Skip the check-in once = drift. Two skips = the cadence is dead.

  - name: "Mid-quarter pivot gate"
    intent: "At ~6 weeks: keep / revise / kill each OKR."
    tasks:
      - "Score progress vs target"
      - "Decide: keep / revise / kill per OKR"
      - "Document the decision"
    methodologies:
      - slug: okr-setting
        path: solo/product/product-planning/okr-setting
        required: true
        tier_gate: solo
    outputs:
      - "Pivot-gate decision doc"
    decision_gate: |
      Required: written keep/revise/kill verdict per OKR. Inertia = death of OKRs.

  - name: "Quarter close: retro + carry-over"
    intent: "Blameless retro + explicit carry-over rules."
    tasks:
      - "Run blameless retro"
      - "Apply carry-over rules (what carries, what dies)"
      - "Feed lessons into quarter-planning-okr-reset"
    methodologies:
      - slug: reflexion-learning
        path: solo/sdd/sdd/reflexion-learning
        required: true
        tier_gate: solo
      - slug: mistake-memory
        path: solo/sdd/sdd/mistake-memory
        required: true
        tier_gate: solo
    outputs:
      - "Quarter retro doc"
      - "Carry-over list"
    decision_gate: |
      Required: retro published before next-quarter OKRs land. Otherwise the next quarter repeats the same misses.

common_pitfalls:
  - "Personal OKRs don't ladder to team OKRs — confusion + drift"
  - "Weekly check-ins skipped 'just this week' — cadence dies fast"
  - "No mid-quarter pivot gate — bad OKRs run to quarter end"
  - "Carry-over rules implicit — last-minute disputes at quarter close"

quality_checklist:
  - "Can every dev name their personal OKRs and their lift to team OKRs?"
  - "Did we hold a mid-quarter pivot decision in writing?"
  - "Did the blameless retro happen before the next-quarter OKRs?"

related_playbooks:
  - quarter-planning-okr-reset
  - biweekly-retro-mistake-memory
  - backlog-grooming-pm-tech-lead

token_budget_estimate: 12000
cli_invocations:
  human:  "faion get-content quarterly-okr-cascade-weekly-review --format md"
  agent:  "faion get-content quarterly-okr-cascade-weekly-review --format context"
  json:   "faion get-content quarterly-okr-cascade-weekly-review --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P6 product-dev team persona"

