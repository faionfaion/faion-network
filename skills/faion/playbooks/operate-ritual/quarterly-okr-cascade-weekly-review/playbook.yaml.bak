    expected_tier: geek
    blocks_stage: 1
    note: "Cascade stage needs a multi-level template (company → team → personal) with traceability"
  - methodology_slug: personal-okr-1on1-template
    expected_tier: geek
    blocks_stage: 1
    note: "Cascade stage needs a 1:1-shaped template for personal OKRs"
  - methodology_slug: okr-weekly-check-in-template
    expected_tier: geek
