# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: quarterly-retainer-review-per-client
title: "Quarterly retainer review per client"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 1846eb4c624451b8

tier_min: pro
complexity: deep
context: [solo, team]
persona_hints: [P5]

intent: |
  Per retainer client every quarter to confirmed renewal, scope adjustment, or planned offboarding.

scope: |
  Founder runs a 45-minute structured review with each retainer client every quarter. Output: confirmed renewal, scope adjustment, or planned offboarding. Exit artifact: per-client review pack + signed renewal / scope-change / offboarding note.

non_goals:
  - "Full QBR for project-based clients - separate playbook"
  - "New-business pitch within the meeting - never mix"

prerequisites:
  - "Retainer client with 1+ quarter under contract"
  - "Health + outcome data captured monthly"

success_criteria:
  - "Per-client health score updated"
  - "Retainer renewal / scope change / offboarding decision logged"
  - "Updated scope or signed offboarding note in writing"
  - "Client commits one next-quarter outcome"

stages:
  - name: "Score health"
    intent: "Per-client signal: outcomes, friction, satisfaction."
    tasks:
      - "Pull last quarter's outcomes"
      - "Apply health scorecard"
      - "Tag retention risk + upsell signal"
    methodologies:
      - slug: ops-customer-success-metrics
        path: pro/marketing/gtm-strategist/ops-customer-success-metrics
        required: true
        tier_gate: pro
      - slug: benefits-realization
        path: pro/pm/project-manager/benefits-realization
        required: true
        tier_gate: pro
    outputs:
      - "Health score row"
    decision_gate: |
      Advance once score + tags assigned.
  - name: "Prep + run review"
    intent: "45 min: outcomes, gaps, next-quarter, ask."
    tasks:
      - "Draft review deck"
      - "Schedule meeting with sponsor"
      - "Run review with structured script"
    methodologies:
      - slug: ops-upselling-cross-selling
        path: pro/marketing/gtm-strategist/ops-upselling-cross-selling
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement-advanced
        path: pro/pm/project-manager/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
    outputs:
      - "Review deck"
      - "Meeting notes"
    decision_gate: |
      Advance after meeting held with sponsor decision direction.
  - name: "Decide + paper"
    intent: "Renew, change scope, or offboard - in writing."
    tasks:
      - "Apply renewal decision rule"
      - "Paper any scope change"
      - "Write offboarding plan if needed"
    methodologies:
      - slug: project-closure
        path: pro/pm/project-manager/project-closure
        required: true
        tier_gate: pro
      - slug: difficult-conversations
        path: solo/comms/communicator/difficult-conversations
        required: true
        tier_gate: solo
      - slug: negotiation
        path: solo/comms/communicator/negotiation
        required: true
        tier_gate: solo
    outputs:
      - "Signed renewal or scope change"
      - "Offboarding plan if applicable"
    decision_gate: |
      Required: written outcome for every retainer reviewed.

common_pitfalls:
  - "Auto-renewing without a review - kills upsell + lets churn fester"
  - "Skipping the offboarding paper trail - clients drift back resentful"
  - "Letting the review drift into 'how is it going' chat"

quality_checklist:
  - "Did the client commit a next-quarter outcome?"
  - "Is the renewal / change paper signed?"
  - "If offboarding, is the wind-down plan dated?"

related_playbooks:
  - quarter-end-retention-review
  - weekly-client-status-email-batch

token_budget_estimate: 10000
cli_invocations:
  human:  "faion get-content quarterly-retainer-review-per-client --format md"
  agent:  "faion get-content quarterly-retainer-review-per-client --format context"
  json:   "faion get-content quarterly-retainer-review-per-client --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: quarterly-retainer-review-script
    expected_tier: pro
    blocks_stage: 2
    note: "Prep-and-run-review stage needs a 45-min script"
  - methodology_slug: client-health-scorecard-agency
    expected_tier: pro
    blocks_stage: 1
    note: "Score-health stage needs a scorecard tailored to agency retainers"
  - methodology_slug: retainer-renewal-decision-rule
    expected_tier: pro
    blocks_stage: 3
    note: "Decide-and-paper stage needs an explicit decision rule"
  - methodology_slug: scope-creep-management
    expected_tier: pro
    blocks_stage: 3
    note: "Decide-and-paper stage references scope-creep-management playbook not yet ported to v2 manifest"
  - methodology_slug: statement-of-work
    expected_tier: pro
    blocks_stage: 3
    note: "Decide-and-paper stage references statement-of-work playbook not yet ported to v2 manifest"
