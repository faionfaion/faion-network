# =============================================================================
# Build-in-public weekly cadence (X + IH + newsletter, single source)
# Persona: P2 Indie Hacker — F-064
# =============================================================================

slug: build-in-public-weekly-cadence-single-source
title: "Build-in-public weekly cadence (X + IH + newsletter, single source)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: c559b69e5cff96b1

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P2]

intent: |
  One weekly source → fanout to X, IH, newsletter on a sustainable solo cadence.

scope: |
  Run a sustainable single-source content cadence — one weekly action that fans out to X, IH, and the newsletter — without burning out on a nomad schedule. The cadence stays alive on low-energy weeks.

non_goals:
  - "Adding TikTok or YouTube — text-only fanout"
  - "Multiple weekly newsletter sends"
  - "Channel-specific content scratch — single source is canonical"

prerequisites:
  - "Active accounts on X, IH, and newsletter"
  - "A clear positioning statement"

success_criteria:
  - "One canonical weekly source published"
  - "Variants fanned out to X and IH"
  - "Cadence survives 4 consecutive weeks unaided"
  - "Burnout-safe low-energy mode defined"

stages:
  - name: "Source"
    intent: "Pick the canonical weekly artefact."
    tasks:
      - "Pick the format (essay, build-log, lesson recap)"
      - "Set publish day and time"
      - "Define the artefact's narrative spine"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
      - slug: growth-newsletter-growth
        path: solo/marketing/content-marketer/growth-newsletter-growth
        required: true
        tier_gate: solo
    outputs:
      - "Canonical artefact spec"
    decision_gate: |
      Advance only after the format is locked for 4 weeks.
  - name: "Fanout"
    intent: "Variants land on X and IH within the same week."
    tasks:
      - "Distil the artefact into a 1-tweet hook"
      - "Repackage into an IH post with a personal lens"
      - "Schedule both before EOW"
    methodologies:
      - slug: growth-copywriting-fundamentals
        path: solo/marketing/content-marketer/growth-copywriting-fundamentals
        required: true
        tier_gate: solo
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
      - slug: growth-indiehackers-strategy
        path: solo/marketing/gtm-strategist/growth-indiehackers-strategy
        required: true
        tier_gate: solo
    outputs:
      - "X thread scheduled"
      - "IH post scheduled"
    decision_gate: |
      Done once both variants are live the week the source ships.
  - name: "Survive"
    intent: "Cadence has a documented low-energy escape hatch."
    tasks:
      - "Define a 30-min low-energy version"
      - "Pre-stage a backup post for travel weeks"
      - "Review cadence health monthly"
    methodologies:
      - slug: growth-community-building
        path: solo/marketing/smm-manager/growth-community-building
        required: true
        tier_gate: solo
    outputs:
      - "Documented low-energy mode"
      - "Backup post drafted"
    decision_gate: |
      Maintain only if 4-week consecutive run holds.

common_pitfalls:
  - "Treating the playbook as a checklist instead of a decision tree"
  - "Skipping decision gates when intermediate progress feels good"
  - "Letting tools or platforms replace the founder's own judgement"

quality_checklist:
  - "Did each stage produce its named output or get explicitly skipped with a note?"
  - "Were decision gates respected or quietly bypassed?"
  - "Is the evidence trail strong enough to defend the verdict externally?"

related_playbooks:
  - solo-idea-to-validated-mvp
token_budget_estimate: 16500
cli_invocations:
  human:  "faion get-content build-in-public-weekly-cadence-single-source --format md"
  agent:  "faion get-content build-in-public-weekly-cadence-single-source --format context"
  json:   "faion get-content build-in-public-weekly-cadence-single-source --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft from brainstorm-2026-05-17, persona P2 (indie hacker)"

gaps:
  - methodology_slug: build-in-public-cadence-framework
    expected_tier: solo
    blocks_stage: 1
    note: "Source stage needs a cadence framework"
  - methodology_slug: low-energy-content-mode
    expected_tier: solo
    blocks_stage: 3
    note: "Survive stage needs an explicit low-energy protocol"
  - methodology_slug: single-source-content-fanout
    expected_tier: solo
    blocks_stage: 2
    note: "Fanout stage needs a fanout template"
