# =============================================================================
# Daily build-in-public tweet
# Persona: P2 Indie Hacker — F-064
# =============================================================================

slug: daily-build-in-public-tweet
title: "Daily build-in-public tweet"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 17bbcdd2684ca199

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P2]

intent: |
  Empty page → one published build-in-public tweet thread by EOD.

scope: |
  One published tweet or short thread on the indie handle by end of day, surfacing concrete product progress, hooking a relevant audience, and feeding the weekly newsletter and audience funnel.

non_goals:
  - "Thread campaigns — single daily post"
  - "Posting on non-X channels"
  - "Promo-only tweets without build signal"

prerequisites:
  - "A handle with a defined positioning"
  - "Today's actual build artefact (commit, screenshot, metric)"

success_criteria:
  - "One published tweet or short thread"
  - "Anchored to a real build artefact"
  - "Logged in the hook bank for future remix"

stages:
  - name: "Capture"
    intent: "Pick the day's most tweetable build moment."
    tasks:
      - "Scan today's commits and screenshots"
      - "Pick the single moment a stranger would react to"
      - "Note the angle: insight, screenshot, or ask"
    methodologies:
      - slug: storytelling
        path: solo/comms/communicator/storytelling
        required: true
        tier_gate: solo
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "One build moment selected"
    decision_gate: |
      Advance once a concrete moment is picked, even if rough.
  - name: "Draft"
    intent: "A tight tweet that opens with a hook and ends with a payoff."
    tasks:
      - "Open with a hook from the swipe file"
      - "Show the artefact (image, code, metric)"
      - "Close with a single CTA or question"
    methodologies:
      - slug: growth-copywriting-fundamentals
        path: solo/marketing/content-marketer/growth-copywriting-fundamentals
        required: true
        tier_gate: solo
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
    outputs:
      - "Final tweet draft"
    decision_gate: |
      Advance once draft passes the 'would I screenshot this?' bar.
  - name: "Ship"
    intent: "Post and engage with early replies."
    tasks:
      - "Publish during the peak engagement window"
      - "Reply to every reaction in the first hour"
      - "Log final engagement metrics in hook bank"
    methodologies:
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Live tweet"
      - "Engagement log entry"
    decision_gate: |
      Done once posted and replies handled.

common_pitfalls:
  - "Treating the playbook as a checklist instead of a decision tree"
  - "Skipping decision gates when intermediate progress feels good"
  - "Letting tools or platforms replace the founder's own judgement"

quality_checklist:
  - "Did each stage produce its named output or get explicitly skipped with a note?"
  - "Were decision gates respected or quietly bypassed?"
  - "Is the evidence trail strong enough to defend the verdict externally?"

related_playbooks:
  - solo-idea-to-validated-mvp
token_budget_estimate: 16500
cli_invocations:
  human:  "faion get-content daily-build-in-public-tweet --format md"
  agent:  "faion get-content daily-build-in-public-tweet --format context"
  json:   "faion get-content daily-build-in-public-tweet --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft from brainstorm-2026-05-17, persona P2 (indie hacker)"

gaps:
  - methodology_slug: build-in-public-daily-cadence
    expected_tier: solo
    blocks_stage: 1
    note: "Capture stage needs an explicit daily cadence template"
  - methodology_slug: hook-bank-template
    expected_tier: solo
    blocks_stage: 2
    note: "Draft stage references a hook bank that has no template"
