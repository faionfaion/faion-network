# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #11
# =============================================================================

slug: story-points-estimation-poker
title: "Story-points estimation poker with client team"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: f1c3d34af57f4474

tier_min: pro
complexity: light
context: [outsource, team]
persona_hints: [P4]

intent: |
  60-90 min poker session for the next sprint → offshore team scale calibrated with client scale, preventing 'why did your 3 take a week' debates.

scope: |
  Atomic estimation ceremony with a joint offshore + client team. Output: each backlog item sized; offshore and client scales calibrated; explicit spike decisions for unknowns; estimation notes archived. Run weekly or bi-weekly per sprint cadence.

non_goals:
  - "Sprint planning — separate ceremony"
  - "Capacity planning — separate review"
  - "Cost estimation — story points are not money"

prerequisites:
  - "Backlog at Definition of Ready"
  - "Joint team agreed on scale (Fibonacci, T-shirt, etc.)"
  - "Reference stories from a previous sprint"

success_criteria:
  - "Every in-scope ticket sized"
  - "Calibration anchor stories agreed"
  - "Spike decisions captured for risky items"
  - "Notes archived for retro reference"
  - "No 'why did your 3 take a week' fight after the sprint"

stages:
  - name: "Calibrate"
    intent: "Lock the scale before estimating anything new."
    tasks:
      - "Pick 2 reference stories from previous sprint (one small, one medium)"
      - "Recall how long they actually took"
      - "Agree the scale anchor between offshore + client team"
      - "Active-listening pass for any silent disagreement"
    methodologies:
      - slug: acceptance-criteria
        path: pro/ba/business-analyst/acceptance-criteria
        required: true
        tier_gate: pro
      - slug: active-listening
        path: solo/comms/communicator/active-listening
        required: true
        tier_gate: solo
      - slug: feedback
        path: solo/comms/communicator/feedback
        required: true
        tier_gate: solo
      - slug: cross-team-points-calibration-protocol
        path: pro/_gap/cross-team-points-calibration-protocol
        required: true
        tier_gate: pro
    outputs:
      - "Anchor reference stories"
      - "Agreed scale"
    decision_gate: |
      Advance only when both teams agree the anchors. If not, recalibrate.
  - name: "Estimate"
    intent: "Run the poker; surface dissent fast."
    tasks:
      - "Run poker per ticket; reveal estimates simultaneously"
      - "Discuss outliers; do not average silently"
      - "Use scrum-ceremonies discipline on time-boxing"
      - "Apply cost-estimation patterns where points need defending"
    methodologies:
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
      - slug: cost-estimation
        path: pro/pm/pm-traditional/cost-estimation
        required: true
        tier_gate: pro
      - slug: cost-estimation
        path: pro/pm/project-manager/cost-estimation
        required: true
        tier_gate: pro
    outputs:
      - "Estimates per ticket"
      - "Outlier discussion notes"
    decision_gate: |
      Advance only when outliers are resolved by discussion, not majority vote.
  - name: "Spike or commit"
    intent: "Decide which unknowns become spikes vs estimates."
    tasks:
      - "Identify tickets with high uncertainty"
      - "Decide spike vs estimate per the spike-vs-estimate rule"
      - "Tag spike tickets with a time-box"
      - "Archive notes for retro"
    methodologies:
      - slug: spike-vs-estimate-decision-rule
        path: pro/_gap/spike-vs-estimate-decision-rule
        required: true
        tier_gate: pro
    outputs:
      - "Spike tickets created"
      - "Final estimates committed"
      - "Archived poker notes"
    decision_gate: |
      Ceremony closes only when each backlog item is either sized or spiked.

common_pitfalls:
  - "Averaging votes silently — kills the calibration signal"
  - "Estimating without an anchor — drift between teams compounds"
  - "Skipping spikes on big unknowns — sprint then misses"

quality_checklist:
  - "Did we calibrate on actual past stories, not theory?"
  - "Did we resolve outliers by discussion?"
  - "Did every risky item get a spike or an honest estimate?"

related_playbooks:
  - jira-ticket-scoping-session
  - client-demo-prep-and-run

token_budget_estimate: 7000
cli_invocations:
  human:  "faion get-content story-points-estimation-poker --format md"
  agent:  "faion get-content story-points-estimation-poker --format context"
  json:   "faion get-content story-points-estimation-poker --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, atomic angle"

gaps:
