slug: daily-figma-sync-comment-triage-30min
title: "Daily Figma sync + comment triage (30min)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 2112e36f62fbc986

tier: solo
tier_min: solo
group: role-ux-ui-designer
persona: Designer maintaining inbox-zero on Figma comments
complexity: light
context: [solo, team]

summary: |
  30-min daily ritual: inbox-zero on Figma comments, resolve open threads, escalate blockers, log unresolved decisions, snapshot the file in version history.

intent: |
  Cluttered Figma inbox -> inbox-zero + resolved threads + logged unresolved decisions.

scope: |
  Designer runs a 30-minute daily comment triage on Figma. Includes review of open threads, resolutions, escalations, decision-log entries, and a snapshot in version history. Done when the inbox is empty and decisions log is current.

success_criteria:
  - "Figma inbox at zero by end of session"
  - "Any unresolved decision logged with owner + due date"
  - "Snapshot in version history with the date"

methodology_refs:
  - faion/knowledge/pro/ux/ui-designer/design-system-success-factors
  - faion/knowledge/pro/ux/ui-designer/token-organization
  - faion/knowledge/solo/ux/ux-researcher/design-critique
  - faion/knowledge/solo/ux/ux-ui-designer/design-critique

stages:
  - name: "Scan"
    intent: "See every open thread in one pass."
    tasks:
      - "Open Figma comments inbox"
      - "Sort by file + age"
      - "Mark stale threads (>2 days) for triage"
    methodologies:
      - slug: design-critique
        path: solo/ux/ux-ui-designer/design-critique
        required: true
        tier_gate: solo
    outputs:
      - "Sorted inbox view"
    decision_gate: |
      Advance when all threads are visible in one screen.
  - name: "Resolve + reply"
    intent: "Clear the cheap wins."
    tasks:
      - "Resolve actionable comments with a reply"
      - "Apply quick fixes inline"
      - "Tag follow-ups for engineering"
    methodologies:
      - slug: design-critique
        path: solo/ux/ux-researcher/design-critique
        required: true
        tier_gate: solo
      - slug: design-critique
        path: solo/ux/ux-ui-designer/design-critique
        required: true
        tier_gate: solo
    outputs:
      - "Cleared cheap-win threads"
    decision_gate: |
      Advance only when easy threads are closed.
  - name: "Escalate blockers"
    intent: "Push what needs a decision today."
    tasks:
      - "DM stakeholders for decisions older than 24h"
      - "Surface design-system impacts to system owner"
      - "Set a 24h deadline on each escalation"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
      - slug: token-organization
        path: pro/ux/ui-designer/token-organization
        required: true
        tier_gate: pro
    outputs:
      - "Escalations sent + tracked"
    decision_gate: |
      Advance once each blocker has an owner + deadline.
  - name: "Log unresolved"
    intent: "Decisions must survive the next standup."
    tasks:
      - "Add unresolved decisions to the design decision log"
      - "Note the rationale + parked questions"
      - "Link to the Figma thread"
    methodologies:
      - slug: design-critique
        path: solo/ux/ux-ui-designer/design-critique
        required: true
        tier_gate: solo
    outputs:
      - "Updated decision log"
    decision_gate: |
      Advance only when every unresolved item is logged.
  - name: "Snapshot"
    intent: "Lock today's state for traceability."
    tasks:
      - "Create a named version snapshot in Figma"
      - "Name format: YYYY-MM-DD-short-context"
      - "Note the snapshot in the decision log"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "Named snapshot in Figma history"
    decision_gate: |
      Done when snapshot exists for the date.

common_pitfalls:
  - "Skipping the snapshot -> impossible to roll back a bad change"
  - "Treating comments as 'someday' -> threads pile up forever"
  - "No decision log entry -> same question keeps coming back"

quality_checklist:
  - "Is the comment inbox actually empty?"
  - "Are open questions in a single log, not scattered?"
  - "Does the snapshot exist with today's date?"

related_playbooks:
  - weekly-design-review-meeting-1hr

token_budget_estimate: 1800
cli_invocations:
  human:  "faion get-content daily-figma-sync-comment-triage-30min --format md"
  agent:  "faion get-content daily-figma-sync-comment-triage-30min --format context"
  json:   "faion get-content daily-figma-sync-comment-triage-30min --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
