# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: vendor-tool-consolidation-review
title: "Vendor / tool consolidation review"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 76ce9b007b51a526

tier_min: pro
complexity: light
context: [solo, team]
persona_hints: [P5]

intent: |
  Monthly SaaS audit to kill list + consolidation plan + projected savings.

scope: |
  Founder audits SaaS + tool sprawl monthly and decides what to cut, consolidate, or replace. Output: kill list, consolidation plan, projected savings. Exit artifact: tool inventory + decisions + cancellation actions taken.

non_goals:
  - "Annual financial close - separate ritual"
  - "Migration execution - separate playbook per tool"

prerequisites:
  - "Bookkeeping with tool subscriptions tagged"
  - "Last-month vendor + tool inventory"

success_criteria:
  - "Complete tool inventory with cost + usage tag"
  - "Kill list with cancellation owner + date"
  - "Consolidation plan written"
  - "Projected monthly + annual savings logged"

stages:
  - name: "Inventory"
    intent: "Single source of truth for every active subscription."
    tasks:
      - "Pull subscription list from bookkeeping"
      - "Cross-check with bank statements"
      - "Tag each with active user count + last login"
    methodologies:
      - slug: ops-financial-basics
        path: pro/marketing/gtm-strategist/ops-financial-basics
        required: true
        tier_gate: pro
      - slug: ops-tax-basics
        path: pro/marketing/gtm-strategist/ops-tax-basics
        required: true
        tier_gate: pro
    outputs:
      - "Tool inventory"
    decision_gate: |
      Advance once every line item tagged.
  - name: "Decide kill / keep / consolidate"
    intent: "Apply decision rule, no nostalgia."
    tasks:
      - "Score each tool by usage x strategic value"
      - "Tag for kill / keep / consolidate"
      - "Identify overlap candidates"
    methodologies:
      - slug: ops-partnership-strategy
        path: pro/marketing/gtm-strategist/ops-partnership-strategy
        required: true
        tier_gate: pro
      - slug: ops-pricing-strategy
        path: solo/marketing/gtm-strategist/ops-pricing-strategy
        required: true
        tier_gate: solo
    outputs:
      - "Kill list"
      - "Consolidation plan"
    decision_gate: |
      Advance once every line item has a decision.
  - name: "Execute + log"
    intent: "Cancel today, plan migrations for the month."
    tasks:
      - "Cancel kill-list items same day"
      - "Schedule migrations + comms"
      - "Log projected savings"
    methodologies:
      - slug: communications-management
        path: pro/pm/project-manager/communications-management
        required: true
        tier_gate: pro
      - slug: cross-tool-migration
        path: pro/pm/project-manager/cross-tool-migration
        required: true
        tier_gate: pro
      - slug: tool-migration-process
        path: pro/pm/pm-agile/tool-migration-process
        required: true
        tier_gate: pro
    outputs:
      - "Cancellations confirmed"
      - "Migration schedule"
      - "Savings log"
    decision_gate: |
      Required: cancellations executed same day. Migrations have owners + dates.

common_pitfalls:
  - "Keeping tools 'just in case' - sprawl grows unchecked"
  - "Skipping migration plan - kills and rage-buys later"
  - "Not logging savings - invisible win = no behavior change"

quality_checklist:
  - "Did I cancel today, or schedule a future cancellation?"
  - "Is the migration plan dated?"
  - "Did I log the saving in the books?"

related_playbooks:
  - friday-cash-flow-and-utilization-check
  - monthly-invoice-contractor-pay-batch

token_budget_estimate: 6000
cli_invocations:
  human:  "faion get-content vendor-tool-consolidation-review --format md"
  agent:  "faion get-content vendor-tool-consolidation-review --format context"
  json:   "faion get-content vendor-tool-consolidation-review --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: saas-stack-audit-micro-agency
    expected_tier: pro
    blocks_stage: 1
    note: "Inventory stage needs a tested audit template for micro-agency stacks"
  - methodology_slug: tool-consolidation-decision-rule
    expected_tier: pro
    blocks_stage: 2
    note: "Decide stage needs an explicit decision rule"
