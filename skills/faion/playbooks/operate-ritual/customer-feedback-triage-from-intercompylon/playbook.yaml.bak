# =============================================================================
# PLAYBOOK v2 — Customer feedback triage from Intercom or Pylon
# Group: role-product-manager | Tier: solo | Complexity: light
# =============================================================================

slug: customer-feedback-triage-from-intercompylon
title: "Customer feedback triage from Intercom or Pylon"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: fabb70aaed42dd5a

tier_min: solo
complexity: light
context: ['solo', 'team']
persona: role-product-manager
group: role-product-manager

summary: "All inbound feature requests and complaints from the previous week routed into the backlog with severity, theme tag, and a verdict (now / later / never); the requester is acknowledged."

intent: |
  All inbound feature requests and complaints from the previous week routed into the backlog with severity, theme tag, and a verdict (now / later / never); the requester is acknowledged.

scope: |
  All inbound feature requests and complaints from the previous week routed into the backlog with severity, theme tag, and a verdict (now / later / never); the requester is acknowledged.

methodology_refs:
  - pro/product/product-manager/feedback-management
  - pro/product/product-manager/stakeholder-management
  - solo/product/product-manager/feature-prioritization-moscow
  - solo/product/product-manager/feature-prioritization-rice
  - solo/product/product-operations/backlog-management
  - solo/product/product-operations/feedback-management

success_criteria:
  - "All last-week feedback de-duped and tagged"
  - "Every item has theme + severity + verdict"
  - "Every requester acked within 5 business days"
  - "Graveyard rationale captured for 'never' items"

stages:
  - name: "Pull"
    intent: "Pull the previous week's feedback into one place."
    tasks:
      - "Filter Intercom/Pylon for last-week tickets"
      - "Export to a triage queue"
      - "De-duplicate verbatims with the same underlying ask"
    methodologies:
      - slug: feedback-management
        path: pro/product/product-manager/feedback-management
        required: true
        tier_gate: pro
      - slug: feedback-management
        path: solo/product/product-operations/feedback-management
        required: true
        tier_gate: solo
    outputs:
      - "Triage queue with de-duped items"
    decision_gate: "Advance when the queue has no obvious duplicates."
  - name: "Tag"
    intent: "Apply theme + severity."
    tasks:
      - "Assign each item a theme tag (max 12 themes total)"
      - "Score severity (P0 broken trust → P3 nice-to-have)"
      - "Tag the requester's plan + ARR"
    methodologies:
      - slug: feedback-management
        path: solo/product/product-operations/feedback-management
        required: true
        tier_gate: solo
      - slug: feedback-management
        path: pro/product/product-manager/feedback-management
        required: true
        tier_gate: pro
    outputs:
      - "Tagged triage queue"
    decision_gate: "Advance when every item has theme + severity."
  - name: "Score"
    intent: "Run a MoSCoW or RICE pass on the new items."
    tasks:
      - "Apply MoSCoW for fast directional sort"
      - "RICE only for the top quartile"
      - "Note any items already in flight"
    methodologies:
      - slug: feature-prioritization-moscow
        path: solo/product/product-manager/feature-prioritization-moscow
        required: true
        tier_gate: solo
      - slug: feature-prioritization-rice
        path: solo/product/product-manager/feature-prioritization-rice
        required: true
        tier_gate: solo
    outputs:
      - "Scored queue"
    decision_gate: "Advance when every item has a score (Must/Should/Could/Won't, or a RICE number)."
  - name: "Verdict + route"
    intent: "Each item gets now / later / never plus a destination."
    tasks:
      - "File 'now' items to current sprint"
      - "File 'later' items to backlog with theme tag"
      - "File 'never' items to a graveyard with rationale"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-operations/backlog-management
        required: true
        tier_gate: solo
      - slug: feature-prioritization-moscow
        path: solo/product/product-manager/feature-prioritization-moscow
        required: true
        tier_gate: solo
    outputs:
      - "Backlog + graveyard with routed items"
    decision_gate: "Advance when every item has a verdict and a destination."
  - name: "Acknowledge"
    intent: "Close the loop with the requester."
    tasks:
      - "Use a templated reply per verdict (now/later/never)"
      - "Send within 5 business days of the original ticket"
      - "Log the ack on the ticket"
    methodologies:
      - slug: feedback-management
        path: pro/product/product-manager/feedback-management
        required: true
        tier_gate: pro
      - slug: stakeholder-management
        path: pro/product/product-manager/stakeholder-management
        required: true
        tier_gate: pro
    outputs:
      - "Ack record per requester"
    decision_gate: "Required: every requester is acked, even on 'never'."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content customer-feedback-triage-from-intercompylon --format md"
  agent:  "faion get-content customer-feedback-triage-from-intercompylon --format context"
  json:   "faion get-content customer-feedback-triage-from-intercompylon --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
