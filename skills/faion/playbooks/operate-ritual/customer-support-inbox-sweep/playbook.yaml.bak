# =============================================================================
# faion playbook manifest — P1 solo SaaS builder
# Generated for F-064 from playbook-index.json entry #8
# =============================================================================

slug: customer-support-inbox-sweep
title: "Customer support inbox sweep (2x weekly)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 396d6617f4333697

tier_min: solo
complexity: light
context: [solo]
persona_hints: [P1]

intent: |
  Unread customer messages → zero unread + top 3 themes promoted to product feedback.

scope: |
  2x weekly 30-minute sweep: every ticket resolved or scheduled, top 3 themes pushed into product feedback, churn signals flagged, FAQ updated where the same answer was given twice. Exit artifact is inbox-zero + updated FAQ.

non_goals:
  - "Major feature decisions from support — escalate to scoping session"
  - "Refund processing policy changes — handled in launch-operations refund playbook"

prerequisites:
  - "Support inbox routed (email, Crisp, or similar)"
  - "FAQ page exists"

success_criteria:
  - "Zero unread tickets at end of sweep"
  - "Top 3 themes added to product backlog"
  - "Churn signals tagged in CRM"
  - "FAQ updated for any repeat question"

stages:
  - name: "Read"
    intent: "Read every ticket; tag by intent + sentiment."
    tasks:
      - "Read all unread tickets"
      - "Tag: question / bug / feature / churn / refund"
      - "Note any repeat question"
    methodologies:
      - slug: active-listening
        path: solo/comms/communicator/active-listening
        required: true
        tier_gate: solo
      - slug: stakeholder-communication
        path: solo/comms/communicator/stakeholder-communication
        required: true
        tier_gate: solo
      - slug: ops-customer-support
        path: solo/marketing/gtm-strategist/ops-customer-support
        required: true
        tier_gate: solo
    outputs:
      - "Tagged ticket list"
    decision_gate: |
      Advance once all unread are tagged. Refuse to skim — sentiment shifts get missed.
  - name: "Respond"
    intent: "Resolve or schedule every ticket. No silent ignores."
    tasks:
      - "Answer with FAQ link where applicable"
      - "Schedule callbacks for >5min asks"
      - "Tag churn-risk tickets red"
    methodologies:
      - slug: mom-test
        path: solo/comms/communicator/mom-test
        required: true
        tier_gate: solo
    outputs:
      - "All tickets resolved or scheduled"
    decision_gate: |
      Advance when inbox is zero. Stay if any ticket is 'I'll get back to it'.
  - name: "Promote"
    intent: "Top 3 themes → product backlog. FAQ updated."
    tasks:
      - "Identify top 3 themes from this week"
      - "Add backlog entries with quotes"
      - "Update FAQ for repeat questions"
    methodologies:
      - slug: continuous-discovery
        path: solo/product/product-manager/continuous-discovery
        required: true
        tier_gate: solo
      - slug: feedback-management
        path: solo/product/product-operations/feedback-management
        required: true
        tier_gate: solo
      - slug: backlog-management
        path: solo/product/product-manager/backlog-management
        required: true
        tier_gate: solo
    outputs:
      - "3 backlog entries"
      - "FAQ diff"
    decision_gate: |
      Required output: 3 backlog items + FAQ diff. Without this, support stays a black hole.

common_pitfalls:
  - "Sweeping daily and burning out — 2x/week is the cadence"
  - "Treating every feature request as a roadmap input — filter by theme convergence"

quality_checklist:
  - "Did the top 3 themes actually land in the backlog, or in a 'maybe' note?"
  - "Did I answer the same question twice without updating FAQ?"

related_playbooks:
  - friday-bug-bash-triage
  - sunday-roadmap-ritual

token_budget_estimate: 7000
cli_invocations:
  human:  "faion get-content customer-support-inbox-sweep --format md"
  agent:  "faion get-content customer-support-inbox-sweep --format context"
  json:   "faion get-content customer-support-inbox-sweep --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P1 solo SaaS builder persona"

gaps:
  - methodology_slug: solo-support-sla-template
    expected_tier: solo
    blocks_stage: 2
    note: "Respond stage needs SLA template scoped to one operator"
  - methodology_slug: verbatim-to-backlog-pattern
    expected_tier: solo
    blocks_stage: 3
    note: "Promote stage needs pattern for turning customer quotes into backlog items"
