slug: run-a-30-minute-resource-allocation-review
title: "Run a 30-minute resource allocation review"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: f22750d3cfec52f4

tier: pro
tier_min: pro
group: role-project-manager
persona: PM running P4 multi-engagement or P6 multi-stream squads
complexity: medium
context: [solo, team]

summary: |
  Weekly 30-minute pass: confirm no one is >100% allocated, find idle capacity, rebalance across projects or squads.

intent: |
  Allocation snapshot -> rebalanced plan with named moves applied before the next week starts.

scope: |
  PM holds the resource picture for 3-15 people across multiple engagements (P4) or streams (P6). This playbook runs a single weekly 30-minute review: ingest current load, flag overloads + under-utilization, decide reallocations, and update the system of record. Done when next-week plan reflects the changes and affected people know.

success_criteria:
  - "Zero individuals shown >100% allocated for next week"
  - "All under-50% utilized capacity has a named pickup or a reason logged"
  - "Allocation tool reflects all moves before the meeting ends"
  - "Affected people pinged within 1 hour of the review"

methodology_refs:
  - faion/knowledge/pro/pm/pm-traditional/change-control
  - faion/knowledge/pro/pm/pm-traditional/communications-management
  - faion/knowledge/pro/pm/pm-traditional/resource-management
  - faion/knowledge/pro/pm/pm-traditional/schedule-development
  - faion/knowledge/pro/pm/pm-traditional/stakeholder-engagement
  - faion/knowledge/pro/pm/project-manager/jira-workflow-management
  - faion/knowledge/pro/pm/project-manager/raci-matrix
  - faion/playbooks/pro/delivery-ops/capacity-planning

stages:
  - name: "Snapshot"
    intent: "Get the truth before deciding."
    tasks:
      - "Pull next-week allocation from tracker (Jira / Float / sheet)"
      - "Flag anyone >100% or <50%"
      - "Note any role conflicts (one person on two crit-path tasks)"
    methodologies:
      - slug: resource-management
        path: pro/pm/pm-traditional/resource-management
        required: true
        tier_gate: pro
      - slug: jira-workflow-management
        path: pro/pm/project-manager/jira-workflow-management
        required: true
        tier_gate: pro
    outputs:
      - "Single-screen allocation view with flags"
    decision_gate: |
      Advance once flags are visible and the picture matches reality.
  - name: "Decide"
    intent: "Convert flags into reallocation moves."
    tasks:
      - "For each overload: drop / defer / reassign / accept-overtime"
      - "For each idle capacity: pull-forward / pickup billable / training"
      - "Update the RACI for anything moved"
    methodologies:
      - slug: schedule-development
        path: pro/pm/pm-traditional/schedule-development
        required: true
        tier_gate: pro
      - slug: change-control
        path: pro/pm/pm-traditional/change-control
        required: true
        tier_gate: pro
      - slug: raci-matrix
        path: pro/pm/project-manager/raci-matrix
        required: true
        tier_gate: pro
    outputs:
      - "List of moves with owners + reasons"
    decision_gate: |
      Advance when no flag remains unresolved or each remaining flag has a written reason.
  - name: "Apply"
    intent: "Make the moves stick in the system."
    tasks:
      - "Update tracker entries before leaving the meeting"
      - "Adjust project plans where dependencies shift"
      - "Log allocation deltas vs original plan"
    methodologies:
      - slug: jira-workflow-management
        path: pro/pm/project-manager/jira-workflow-management
        required: true
        tier_gate: pro
      - slug: schedule-development
        path: pro/pm/pm-traditional/schedule-development
        required: true
        tier_gate: pro
    outputs:
      - "Tracker state matching decisions"
    decision_gate: |
      Advance only when tracker is consistent; do not rely on memory.
  - name: "Communicate"
    intent: "People affected hear it from the PM, not the calendar."
    tasks:
      - "DM each person about their change with the reason"
      - "Update steerco/PMO with material reallocations"
      - "Note client-facing changes for next sync"
    methodologies:
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement
        path: pro/pm/pm-traditional/stakeholder-engagement
        required: true
        tier_gate: pro
    outputs:
      - "Personal pings sent; PMO note posted"
    decision_gate: |
      Done when each affected person has acknowledged.
  - name: "Log"
    intent: "Build the historical trend so next-quarter forecasts are calibrated."
    tasks:
      - "Append this week's metrics to the allocation log"
      - "Note recurring overload patterns"
      - "Flag structural issues for the next capacity-planning cycle"
    methodologies:
      - slug: resource-management
        path: pro/pm/pm-traditional/resource-management
        required: true
        tier_gate: pro
    outputs:
      - "Allocation-log entry"
    decision_gate: |
      Done when log shows this week's snapshot and any pattern flagged for follow-up.

common_pitfalls:
  - "Reviewing only overloads, missing idle capacity -> billable leak"
  - "Forgetting to update the tracker -> next week the same flags reappear"
  - "Skipping the per-person DM -> people feel reshuffled, not informed"

quality_checklist:
  - "Does the next-week view show zero red flags?"
  - "Did the people moved hear it from me before the calendar told them?"
  - "Was the log updated so we can spot patterns over a quarter?"

related_playbooks:
  - run-an-escalation-conversation-with-a-stakeholder
  - distressed-project-rescue-90-day-turnaround

token_budget_estimate: 4000
cli_invocations:
  human:  "faion get-content run-a-30-minute-resource-allocation-review --format md"
  agent:  "faion get-content run-a-30-minute-resource-allocation-review --format context"
  json:   "faion get-content run-a-30-minute-resource-allocation-review --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
  - methodology_slug: multi-project-allocation-tracker
    expected_tier: pro
    blocks_stage: 1
    note: "Snapshot stage needs a concrete tracker template."
  - methodology_slug: billable-vs-internal-allocation-split
    expected_tier: pro
    blocks_stage: 2
    note: "Decide stage needs a rubric for billable vs internal pickup."
