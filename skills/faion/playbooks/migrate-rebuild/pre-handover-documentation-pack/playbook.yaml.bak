# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #13
# =============================================================================

slug: pre-handover-documentation-pack
title: "Pre-handover documentation pack"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: fc9baf2a3676bc25

tier_min: pro
complexity: deep
context: [outsource, team]
persona_hints: [P4]

intent: |
  Senior rotating off a project → produces a self-contained pack that lets the next person ship within a week.

scope: |
  Doc sprint produced when a senior is rotating off (vacation, next engagement, or full handoff). Output: a self-contained pack — ADRs, design docs, onboarding plan, dark-knowledge notes, shadow-session runbook — so the next person ships within a week. Used independently of the 3-week formal client handover.

non_goals:
  - "Full project closure — that's a bigger ceremony"
  - "Code refactoring before handoff — only documentation"
  - "Hiring the replacement — handled outside"

prerequisites:
  - "Rotation date known and ≥1 week away"
  - "Existing docs accessible and editable"
  - "Successor candidate identified (even if not finalised)"

success_criteria:
  - "Self-contained pack readable by a new joiner"
  - "ADRs current and indexed"
  - "Living-documentation refreshed"
  - "Dark-knowledge notes captured"
  - "Shadow-session runbook prepped"
  - "30-day onboarding plan attached"

stages:
  - name: "Inventory"
    intent: "Audit what exists vs what's only in your head."
    tasks:
      - "List active modules, services, integrations"
      - "Walk through 30-day onboarding plan structure"
      - "Identify gaps where docs trail reality"
      - "Plan the project-closure-adjacent steps from existing methodology"
    methodologies:
      - slug: onboarding-30-day
        path: pro/comms/hr-recruiter/onboarding-30-day
        required: true
        tier_gate: pro
      - slug: project-closure
        path: pro/pm/pm-traditional/project-closure
        required: true
        tier_gate: pro
      - slug: project-closure
        path: pro/pm/project-manager/project-closure
        required: true
        tier_gate: pro
    outputs:
      - "Module inventory"
      - "Doc-gap list"
    decision_gate: |
      Advance only after every active module is listed.
  - name: "Refresh docs"
    intent: "Close the gap between docs and reality."
    tasks:
      - "Backfill ADRs for last 3 months of decisions"
      - "Apply design-docs patterns to refresh stale docs"
      - "Adopt living-documentation conventions per module"
      - "Document scope boundaries (what was NOT built)"
      - "Write design docs for any module without one"
    methodologies:
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: architecture-decision-records
        path: solo/sdd/sdd/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: design-docs-patterns
        path: solo/sdd/sdd/design-docs-patterns
        required: true
        tier_gate: solo
      - slug: living-documentation
        path: solo/sdd/sdd/living-documentation
        required: true
        tier_gate: solo
      - slug: writing-design-documents
        path: solo/sdd/sdd/writing-design-documents
        required: true
        tier_gate: solo
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
    outputs:
      - "Refreshed ADRs"
      - "Refreshed design docs"
      - "Living-documentation conventions in place"
    decision_gate: |
      Advance when a stranger can read the docs and answer top-10 questions unaided.
  - name: "Dark knowledge + shadow"
    intent: "Capture the things never written down and arrange one shadow session."
    tasks:
      - "Run dark-knowledge extraction interview with yourself (or a peer)"
      - "Document gotchas: cron quirks, vendor flakes, weird ports"
      - "Sketch shadow-session runbook for the rotation"
      - "Compile the handover pack URL"
    methodologies:
      - slug: handover-pack-template-outsource
        path: pro/_gap/handover-pack-template-outsource
        required: true
        tier_gate: pro
      - slug: dark-knowledge-extraction-protocol
        path: pro/_gap/dark-knowledge-extraction-protocol
        required: true
        tier_gate: pro
      - slug: shadow-handover-session-runbook
        path: pro/_gap/shadow-handover-session-runbook
        required: true
        tier_gate: pro
    outputs:
      - "Dark-knowledge doc"
      - "Shadow-session plan"
      - "Handover pack URL"
    decision_gate: |
      Done when the pack is single-link shareable AND a peer has spot-checked it.

common_pitfalls:
  - "Treating handover as 'I'll write up next week' — never happens"
  - "Documenting code but not the calendar quirks (vendor freezes, cron windows)"
  - "No shadow session — the successor learns the bug list the hard way"

quality_checklist:
  - "Could a new joiner ship a PR by day 5 using only this pack?"
  - "Did I write down the things I'd whisper if I were on the phone?"
  - "Did a peer spot-check the pack before I rotated?"

related_playbooks:
  - handover-to-client-in-house-team
  - engagement-handover-transition-out

token_budget_estimate: 12000
cli_invocations:
  human:  "faion get-content pre-handover-documentation-pack --format md"
  agent:  "faion get-content pre-handover-documentation-pack --format context"
  json:   "faion get-content pre-handover-documentation-pack --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, atomic angle"

gaps:
  - methodology_slug: handover-pack-template-outsource
    expected_tier: pro
    blocks_stage: 3
    note: "Referenced by stage 3; not yet materialised as a methodology."
  - methodology_slug: dark-knowledge-extraction-protocol
    expected_tier: pro
    blocks_stage: 3
    note: "Referenced by stage 3; not yet materialised as a methodology."
  - methodology_slug: shadow-handover-session-runbook
    expected_tier: pro
    blocks_stage: 3
    note: "Referenced by stage 3; not yet materialised as a methodology."
