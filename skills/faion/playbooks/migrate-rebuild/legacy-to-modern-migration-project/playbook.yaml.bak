# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #5
# =============================================================================

slug: legacy-to-modern-migration-project
title: "Legacy-to-modern migration project (~3 months)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 46ec29e2f25f98a9

tier_min: pro
complexity: deep
context: [outsource, team]
persona_hints: [P4]

intent: |
  Multi-month migration (monolith→services, on-prem→cloud, legacy stack→modern) → target system live with traffic cut over, rollback proven, legacy decom plan signed, performance + cost SLAs met, AI agent leveraged but never trusted blind.

scope: |
  End-to-end migration project led by an outsource senior. Output: target system live in production, traffic cut over with rollback proven, legacy decom plan signed, performance + cost SLAs met. AI coding agent is used heavily but every change passes human review. Reconciliation evidence retained for audit.

non_goals:
  - "Greenfield product feature work — migration only"
  - "Re-architecting the business model — technical migration"
  - "Indefinite parallel-run — decom plan is part of scope"

prerequisites:
  - "Legacy system is documented enough to extract requirements"
  - "Target architecture pattern agreed at SoW level"
  - "Production traffic profile measurable (logs, metrics)"

success_criteria:
  - "Target system live serving 100% of production traffic"
  - "Rollback drill executed at least once"
  - "Legacy decom plan signed by client sponsor"
  - "Performance + cost SLAs measured and met"
  - "Data reconciliation evidence retained"
  - "Lessons-learned + benefits-realisation captured"

stages:
  - name: "Current-state discovery"
    intent: "Inhale the legacy reality before designing the future."
    tasks:
      - "Strategy-analysis: current state of business processes"
      - "Process mining where logs exist"
      - "Business process + data analysis"
      - "Interface analysis on every integration boundary"
    methodologies:
      - slug: strategy-analysis-current-state
        path: pro/ba/business-analyst/strategy-analysis-current-state
        required: true
        tier_gate: pro
      - slug: process-mining-automation
        path: pro/ba/ba-core/process-mining-automation
        required: true
        tier_gate: pro
      - slug: business-process-analysis
        path: pro/ba/ba-modeling/business-process-analysis
        required: true
        tier_gate: pro
      - slug: data-analysis
        path: pro/ba/ba-modeling/data-analysis
        required: true
        tier_gate: pro
      - slug: interface-analysis
        path: pro/ba/ba-modeling/interface-analysis
        required: true
        tier_gate: pro
    outputs:
      - "Current-state architecture diagram"
      - "Process inventory"
      - "Interface inventory"
      - "Data dictionary v1"
    decision_gate: |
      Advance when the migration team can describe the legacy on a whiteboard from memory.
  - name: "Target design"
    intent: "Design the smallest target architecture that satisfies the SLAs."
    tasks:
      - "Future-state strategy + change strategy"
      - "Architecture choices: microservices vs strangler vs lift-shift"
      - "Apply DDD aggregates / events / repositories where useful"
      - "Cross-cutting concerns: observability, reliability, anti-corruption layer"
      - "Design event-driven boundaries where they cut coupling"
    methodologies:
      - slug: strategy-analysis-future-state
        path: pro/ba/business-analyst/strategy-analysis-future-state
        required: true
        tier_gate: pro
      - slug: strategy-analysis-change-strategy
        path: pro/ba/business-analyst/strategy-analysis-change-strategy
        required: true
        tier_gate: pro
      - slug: microservices-architecture
        path: pro/dev/software-architect/microservices-architecture
        required: true
        tier_gate: pro
      - slug: event-driven-architecture
        path: pro/dev/software-architect/event-driven-architecture
        required: true
        tier_gate: pro
      - slug: distributed-patterns
        path: pro/dev/software-architect/distributed-patterns
        required: true
        tier_gate: pro
      - slug: observability-architecture
        path: pro/dev/software-architect/observability-architecture
        required: true
        tier_gate: pro
      - slug: reliability-architecture
        path: pro/dev/software-architect/reliability-architecture
        required: true
        tier_gate: pro
      - slug: domain-driven-design
        path: pro/dev/code-quality/domain-driven-design
        required: true
        tier_gate: pro
      - slug: clean-architecture
        path: pro/dev/software-developer/clean-architecture
        required: true
        tier_gate: pro
      - slug: ddd-aggregates
        path: pro/dev/software-developer/ddd-aggregates
        required: true
        tier_gate: pro
      - slug: ddd-anti-corruption-layer
        path: pro/dev/software-developer/ddd-anti-corruption-layer
        required: true
        tier_gate: pro
      - slug: ddd-domain-events
        path: pro/dev/software-developer/ddd-domain-events
        required: true
        tier_gate: pro
      - slug: ddd-repositories
        path: pro/dev/software-developer/ddd-repositories
        required: true
        tier_gate: pro
      - slug: architecture-decision-records
        path: solo/sdd/sdd/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: strangler-fig-playbook-vendor
        path: pro/_gap/strangler-fig-playbook-vendor
        required: true
        tier_gate: pro
    outputs:
      - "Target architecture diagrams"
      - "ADR set"
      - "Migration approach memo (strangler vs other)"
    decision_gate: |
      Advance when the target arch is explainable in one diagram + 5 ADRs.
  - name: "Implementation plan"
    intent: "Sequence the work into independently shippable slices."
    tasks:
      - "Write implementation plan with parallelisable slices"
      - "Insert quality gates and code-review checkpoints"
      - "Design data-pipeline strategy where applicable"
      - "Inter-service communication contracts (saga, circuit breaker)"
      - "Plan AI-agent usage envelope per slice"
    methodologies:
      - slug: writing-implementation-plans
        path: solo/sdd/sdd-planning/writing-implementation-plans
        required: true
        tier_gate: solo
      - slug: task-creation-parallelization
        path: solo/sdd/sdd/task-creation-parallelization
        required: true
        tier_gate: solo
      - slug: code-review-cycle
        path: solo/sdd/sdd/code-review-cycle
        required: true
        tier_gate: solo
      - slug: quality-gates-confidence
        path: solo/sdd/sdd/quality-gates-confidence
        required: true
        tier_gate: solo
      - slug: data-pipeline-design
        path: pro/dev/software-architect/data-pipeline-design
        required: true
        tier_gate: pro
      - slug: microservices-inter-service-comm
        path: pro/dev/software-developer/microservices-inter-service-comm
        required: true
        tier_gate: pro
      - slug: microservices-circuit-breaker
        path: pro/dev/software-developer/microservices-circuit-breaker
        required: true
        tier_gate: pro
      - slug: microservices-saga-pattern
        path: pro/dev/software-developer/microservices-saga-pattern
        required: true
        tier_gate: pro
      - slug: ai-agent-migration-prompt-pack
        path: pro/_gap/ai-agent-migration-prompt-pack
        required: true
        tier_gate: pro
    outputs:
      - "Implementation plan with slices"
      - "Quality-gate checklist"
      - "AI-agent prompt pack"
    decision_gate: |
      Advance when slices are independently shippable AND review gates are explicit.
  - name: "Build + dual-run"
    intent: "Build slices, dual-run with the legacy, reconcile constantly."
    tasks:
      - "Implement slices in parallel where dependencies allow"
      - "Reconciliation checks between legacy and target"
      - "Backup posture for both systems during dual-run"
      - "API monitoring (metrics + alerting) on the target"
      - "Risk-management cycle each sprint"
    methodologies:
      - slug: api-monitoring-metrics
        path: pro/dev/software-developer/api-monitoring-metrics
        required: true
        tier_gate: pro
      - slug: api-monitoring-alerting
        path: pro/dev/software-developer/api-monitoring-alerting
        required: true
        tier_gate: pro
      - slug: backup-database-mysql-mongo
        path: pro/infra/cicd-engineer/backup-database-mysql-mongo
        required: true
        tier_gate: pro
      - slug: backup-database-postgres
        path: pro/infra/cicd-engineer/backup-database-postgres
        required: true
        tier_gate: pro
      - slug: backup-verification-dr
        path: pro/infra/cicd-engineer/backup-verification-dr
        required: true
        tier_gate: pro
      - slug: risk-management
        path: pro/pm/pm-traditional/risk-management
        required: true
        tier_gate: pro
      - slug: earned-value-management
        path: pro/pm/project-manager/earned-value-management
        required: true
        tier_gate: pro
      - slug: data-reconciliation-checklist
        path: pro/_gap/data-reconciliation-checklist
        required: true
        tier_gate: pro
    outputs:
      - "Reconciliation reports per slice"
      - "Production-ready target system"
      - "Backups for both systems"
    decision_gate: |
      Advance when dual-run reconciliation is green for ≥1 full business cycle.
  - name: "Cutover + decom"
    intent: "Cut traffic, prove rollback, decom the legacy."
    tasks:
      - "Blue/green or canary cutover (link to existing playbook)"
      - "Rollback drill before opening the floodgates"
      - "Benefits-realisation review against SLAs"
      - "Project-closure ceremony"
      - "Lessons-learned retro for the next migration"
    methodologies:
      - slug: benefits-realization
        path: pro/pm/pm-traditional/benefits-realization
        required: true
        tier_gate: pro
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
      - slug: project-closure
        path: pro/pm/pm-traditional/project-closure
        required: true
        tier_gate: pro
      - slug: cutover-rollback-runbook-template
        path: pro/_gap/cutover-rollback-runbook-template
        required: true
        tier_gate: pro
      - slug: deploy-blue-green-canary
        path: pro/_existing_playbook/deploy-blue-green-canary
        required: false
        tier_gate: pro
      - slug: production-cicd-pipeline
        path: pro/_existing_playbook/production-cicd-pipeline
        required: false
        tier_gate: pro
    outputs:
      - "Cutover runbook executed"
      - "Rollback drill log"
      - "Decom plan signed"
      - "Benefits-realisation report"
    decision_gate: |
      Engagement closes when 100% of traffic runs on target, rollback drill is logged, and legacy decom date is signed.

common_pitfalls:
  - "Re-architecting the business while you migrate — keeps the cutover date sliding"
  - "Trusting AI-generated migration scripts without reconciliation — silent data loss"
  - "Skipping the rollback drill because the team is exhausted — that's exactly when you need it"

quality_checklist:
  - "Can we roll back in <1 hour if the cutover breaks?"
  - "Did reconciliation prove the data, not just sample it?"
  - "Did we measure the SLAs we promised, or the SLAs we found convenient?"

related_playbooks:
  - deploy-blue-green-canary
  - production-cicd-pipeline
  - compliance-grade-feature-delivery

token_budget_estimate: 25000
cli_invocations:
  human:  "faion get-content legacy-to-modern-migration-project --format md"
  agent:  "faion get-content legacy-to-modern-migration-project --format context"
  json:   "faion get-content legacy-to-modern-migration-project --format json"

