slug: "adopt-faion-org-wide-overrides-v2"
title: "Adopt faion org-wide and override with company patterns"
tier: "geek"
group: "product-team"
persona: "p6-product-dev-team"
complexity: "deep"
version: "1.0.0"
status: "draft"
last_reviewed: 2026-05-20
maintainers:
  - "faion-network"
summary: |
  All 2-10 devs reference the same playbook set; company-specific overlays (security policy, ADR template, RFC format, internal tech-radar) cleanly shadow faion defaults without forking the corpus
content_id: "ac470b6ba488fa50"
tier_min: "geek"
context:
  - "team"
intent: |
  All 2-10 devs reference the same playbook set; company-specific overlays (security policy, ADR template, RFC format, internal tech-radar) cleanly shadow faion defaults without forking the corpus
scope: |
  All 2-10 devs reference the same playbook set; company-specific overlays (security policy, ADR template, RFC format, internal tech-radar) cleanly shadow faion defaults without forking the corpus
success_criteria:
  - "All 4 stages have written outputs in the project record"
  - "Each stage's decision gate was answered before advancing (yes / no in writing)"
  - "Final stage produced the required written decision artifact"
  - "Every methodology reference loaded cleanly via `faion get-content`"
methodology_refs:
  - "kb-agents-md-context-pyramid"
  - "kb-versioned-agent-memory-files"
  - "onboarding-30-day"
  - "team-development"
  - "design-doc-structure"
  - "architecture-decision-records"
stages:
  - name: "Pilot the Adoption"
    intent: "One squad before everyone."
    tasks:
      - "Pick a single squad to pilot Faion across SDD + playbooks"
      - "Install Faion plugin + CLI in their workflows"
      - "Pick the 3 workflows where Faion will be measured"
    methodologies:
      - slug: "kb-agents-md-context-pyramid"
        path: "geek/sdlc-ai/kb-agents-md-context-pyramid"
        required: true
        tier_gate: "geek"
    outputs:
      - "pilot squad confirmed"
      - "Faion install verified"
      - "3 pilot workflows"
    decision_gate: "Advance only when the pilot squad is using Faion daily for 1 week."
  - name: "Define Company Overrides"
    intent: "Where company standards diverge from Faion defaults."
    tasks:
      - "List company conventions that override Faion (linters, formats, naming)"
      - "Encode them as company-local skills / playbooks layered on top of Faion"
      - "Document the override registry"
    methodologies:
      - slug: "kb-versioned-agent-memory-files"
        path: "geek/sdlc-ai/kb-versioned-agent-memory-files"
        required: true
        tier_gate: "geek"
    outputs:
      - "override list"
      - "company overlay skills"
      - "override registry"
    decision_gate: "Advance when overrides are encoded and not just described."
  - name: "Roll Out Org-Wide"
    intent: "Sequence by squad; no big-bang."
    tasks:
      - "Roll out squad-by-squad with the same install runbook"
      - "Train each squad on the override registry"
      - "Surface adoption metrics weekly"
    methodologies:
      - slug: "onboarding-30-day"
        path: "pro/comms/hr-recruiter/onboarding-30-day"
        required: true
        tier_gate: "geek"
    outputs:
      - "per-squad rollout log"
      - "training records"
      - "weekly adoption metrics"
    decision_gate: "Advance only when ≥80% of squads are on the same install + overrides."
  - name: "Measure & Iterate"
    intent: "Adoption without value is theatre."
    tasks:
      - "Measure cycle-time, escape-rate, and dev-satisfaction deltas"
      - "Iterate overrides where Faion default + company default conflict"
      - "Decide: deepen / hold / unwind"
    methodologies:
      - slug: "team-development"
        path: "pro/pm/pm-agile/team-development"
        required: true
        tier_gate: "geek"
      - slug: "design-doc-structure"
        path: "solo/sdd/sdd-planning/design-doc-structure"
        required: true
        tier_gate: "geek"
      - slug: "architecture-decision-records"
        path: "solo/sdd/sdd/architecture-decision-records"
        required: true
        tier_gate: "geek"
    outputs:
      - "delta metrics"
      - "override iterations"
      - "deepen/hold/unwind memo"
    decision_gate: "Required output: a written go-forward decision with data."
token_budget_estimate: 18000
