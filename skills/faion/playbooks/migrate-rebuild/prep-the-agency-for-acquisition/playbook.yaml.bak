# =============================================================================
# faion playbook manifest -- P5 micro-agency founder
# Generated for F-064 from playbook-index.json by_persona[p5-micro-agency-founder]
# =============================================================================

slug: prep-the-agency-for-acquisition
title: "Prep the agency for acquisition (or graceful walk-away)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: eb9cb5889fb9ac5d

tier_min: pro
complexity: deep
context: [solo, team]
persona_hints: [P5]

intent: |
  2-3 person agency to sellable to strategic / acqui-hire / manager-operator within 6-12 months; same prep removes founder dependency even if not selling.

scope: |
  Get a 2-3 person agency to a state where it is sellable to a strategic buyer, an acqui-hirer, or transferable to a manager-operator within 6-12 months. Even if not selling, the same prep removes founder dependency. Exit artifact: due-diligence-ready data room + valuation rubric scorecard + handover SOP kit.

non_goals:
  - "Investment banker representation - out of scope for micro-agency"
  - "Public-market transactions - irrelevant to this size"

prerequisites:
  - "Steady revenue across 18+ months"
  - "Bookkeeping + paperwork in functional state"

success_criteria:
  - "Founder-dependency audit complete"
  - "Owner handover SOP kit produced"
  - "Valuation rubric scorecard updated"
  - "Data room with financial, legal, commercial assets"
  - "Decision: sell / hold / handover written"

stages:
  - name: "Founder-dependency audit"
    intent: "Where the agency falls apart without the founder."
    tasks:
      - "Map every recurring decision"
      - "Tag founder-only vs delegable"
      - "Score concentration risk"
    methodologies:
      - slug: product-operations
        path: pro/product/product-operations/product-operations
        required: true
        tier_gate: pro
    outputs:
      - "Dependency audit doc"
    decision_gate: |
      Advance once founder-only decisions are tagged with a plan to delegate.
  - name: "Financial + legal pack"
    intent: "Numbers and paper sellable."
    tasks:
      - "Lock 24 months trailing financials"
      - "Refresh legal + compliance pack"
      - "Audit partnership + vendor commitments"
    methodologies:
      - slug: ops-annual-planning-process
        path: pro/marketing/gtm-strategist/ops-annual-planning-process
        required: true
        tier_gate: pro
      - slug: ops-financial-basics
        path: pro/marketing/gtm-strategist/ops-financial-basics
        required: true
        tier_gate: pro
      - slug: ops-legal-basics
        path: pro/marketing/gtm-strategist/ops-legal-basics
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance-checklist
        path: pro/marketing/gtm-strategist/ops-legal-compliance-checklist
        required: true
        tier_gate: pro
      - slug: ops-partnership-strategy
        path: pro/marketing/gtm-strategist/ops-partnership-strategy
        required: true
        tier_gate: pro
    outputs:
      - "Financial pack"
      - "Legal + commercial pack"
    decision_gate: |
      Advance once a stranger could read the packs and forecast next 12 months.
  - name: "Valuation + buyer fit"
    intent: "Run valuation rubric; identify buyer archetypes."
    tasks:
      - "Score against valuation rubric"
      - "Profile 3 buyer archetypes"
      - "Test soft conversations with 2"
    methodologies: []
    outputs:
      - "Valuation scorecard"
      - "Buyer profile doc"
    decision_gate: |
      Advance with at least one buyer archetype showing live interest signal.
  - name: "Handover kit"
    intent: "Manager-operator can run agency end-to-end from kit."
    tasks:
      - "Document operating rhythm"
      - "Produce SOPs per service line"
      - "Stand up dashboard pack"
    methodologies: []
    outputs:
      - "Handover SOP kit"
      - "Dashboard pack"
    decision_gate: |
      Required: an outsider can read the kit and run the agency for 30 days.

common_pitfalls:
  - "Selling before deciding - buyers smell desperation"
  - "Skipping the dependency audit - sale collapses in due diligence"
  - "Treating handover kit as optional - it is the asset"

quality_checklist:
  - "Could a manager-operator run this for 30 days using only the kit?"
  - "Are the financials clean enough for due diligence?"
  - "Did I price honestly, not aspirationally?"

related_playbooks:
  - agency-to-recurring-revenue-transition
  - annual-planning-and-financial-close

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content prep-the-agency-for-acquisition --format md"
  agent:  "faion get-content prep-the-agency-for-acquisition --format context"
  json:   "faion get-content prep-the-agency-for-acquisition --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P5 micro-agency founder persona"

gaps:
  - methodology_slug: agency-acquisition-prep
    expected_tier: pro
    blocks_stage: 1
    note: "Founder-dependency stage needs a structured acquisition-prep canvas"
  - methodology_slug: founder-dependency-audit
    expected_tier: pro
    blocks_stage: 1
    note: "Founder-dependency stage needs a tested audit template"
  - methodology_slug: agency-valuation-rubric
    expected_tier: pro
    blocks_stage: 3
    note: "Valuation stage needs an explicit micro-agency valuation rubric"
  - methodology_slug: owner-handover-sop-kit
    expected_tier: pro
    blocks_stage: 4
    note: "Handover-kit stage needs a default SOP kit template"
