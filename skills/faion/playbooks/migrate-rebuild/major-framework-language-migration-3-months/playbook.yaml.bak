# =============================================================================
# faion playbook manifest — chunk-06 (role-software-developer)
# =============================================================================

slug: major-framework-language-migration-3-months
title: "Major framework / language migration (3 months)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 84cbda08bcdd6224

tier_min: solo
complexity: deep
context: [solo, team]
persona: "software developer"
group: role-software-developer

intent: |
  Take an software developer from the trigger condition described in this playbook to the documented outcome, with every decision gate met in writing.

scope: |
  An established service is moved across a major version boundary (e.g. Django 4 to 5, React class to hooks, Go 1.x mod restructure) without losing behaviour, with zero unplanned downtime.

summary: "An established service is moved across a major version boundary (e.g. Django 4 to 5, React class to hooks, Go 1.x mod restructure) without losing behaviour, with zero unplanned downtime."

success_criteria:
  - "Major framework / language migration (3 months) ships with written success criteria met and evidence attached"
  - "Baseline → post-change metric delta recorded against the relevant quality attribute"
  - "Rollback path rehearsed at least once and documented in the runbook"
  - "Decision doc (continue / iterate / revert) signed off by named owner"

methodology_refs:
  - free/dev/code-quality/code-decomposition-patterns
  - free/dev/code-quality/refactoring-patterns
  - free/dev/code-quality/tech-debt-basics
  - free/dev/software-developer/code-coverage
  - free/dev/software-developer/e2e-testing
  - free/dev/software-developer/integration-testing
  - free/dev/software-developer/refactoring-patterns
  - geek/sdlc-ai/mr-codemod-refactor-agent
  - geek/sdlc-ai/test-golden-master-legacy-rewrite
  - pro/dev/software-developer/api-monitoring-metrics
  - solo/dev/automation-tooling/continuous-delivery
  - solo/dev/automation-tooling/perf-test-basics
  - solo/dev/automation-tooling/perf-test-tools
  - solo/dev/automation-tooling/trunk-based-branch-by-abstraction
  - solo/dev/automation-tooling/trunk-based-feature-flags
  - solo/dev/code-quality/framework-decomposition-patterns
  - solo/dev/code-quality/tech-debt-management
  - solo/dev/software-architect/architecture-decision-records
  - solo/dev/software-architect/trade-off-technical-debt
  - solo/dev/software-developer/contract-first-development
  - solo/dev/software-developer/feature-flags
  - solo/dev/software-developer/performance-testing
  - solo/dev/software-developer/technical-debt
  - solo/dev/software-developer/trunk-based-development
  - solo/sdd/sdd/living-documentation

stages:
  - name: "Frame"
    intent: "Name the problem in writing and set explicit success criteria."
    tasks:
      - "Write a one-paragraph problem statement tied to a quality attribute or user outcome"
      - "List concrete success criteria (measurable, observable, time-bounded)"
      - "Identify the smallest credible scope that still moves the needle"
    methodologies:
      - slug: code-decomposition-patterns
        path: free/dev/code-quality/code-decomposition-patterns
        required: true
        tier_gate: free
      - slug: test-golden-master-legacy-rewrite
        path: geek/sdlc-ai/test-golden-master-legacy-rewrite
        required: true
        tier_gate: geek
      - slug: tech-debt-management
        path: solo/dev/code-quality/tech-debt-management
        required: true
        tier_gate: solo
      - slug: living-documentation
        path: solo/sdd/sdd/living-documentation
        required: true
        tier_gate: solo
    outputs:
      - "Problem brief"
      - "Success-criteria list"
      - "Scope boundary"
    decision_gate: |
      Advance only after a peer can restate the problem in their own words and agree the criteria are testable.
  - name: "Assess"
    intent: "Inventory current state vs target with evidence, not opinion."
    tasks:
      - "Run a structured assessment of the affected system (code, tests, docs, ops surface)"
      - "Capture baseline metrics that the work will need to beat"
      - "List the top 5 risks and one mitigation per risk"
    methodologies:
      - slug: refactoring-patterns
        path: free/dev/code-quality/refactoring-patterns
        required: true
        tier_gate: free
      - slug: api-monitoring-metrics
        path: pro/dev/software-developer/api-monitoring-metrics
        required: true
        tier_gate: pro
      - slug: architecture-decision-records
        path: solo/dev/software-architect/architecture-decision-records
        required: true
        tier_gate: solo
    outputs:
      - "Current-state inventory"
      - "Baseline metrics"
      - "Risk register"
    decision_gate: |
      Advance only when baselines are recorded and risks have owners.
  - name: "Plan"
    intent: "Decompose into a sequenced backlog with explicit decision points."
    tasks:
      - "Break the work into tasks of ≤1 day each, with dependencies named"
      - "Mark reversible vs irreversible (one-way-door) decisions"
      - "Define rollback / kill conditions for each major step"
    methodologies:
      - slug: tech-debt-basics
        path: free/dev/code-quality/tech-debt-basics
        required: true
        tier_gate: free
      - slug: continuous-delivery
        path: solo/dev/automation-tooling/continuous-delivery
        required: true
        tier_gate: solo
      - slug: trade-off-technical-debt
        path: solo/dev/software-architect/trade-off-technical-debt
        required: true
        tier_gate: solo
    outputs:
      - "Task plan"
      - "Decision log skeleton"
      - "Rollback playbook"
    decision_gate: |
      Advance only when every task has a definition-of-done and the plan fits on one page.
  - name: "Pilot"
    intent: "Prove the approach on a small, reversible slice before committing the full budget."
    tasks:
      - "Pick the lowest-blast-radius slice that exercises the riskiest assumption"
      - "Run the slice end-to-end, including verification and rollback rehearsal"
      - "Write up what changed vs the plan and update the rollback playbook"
    methodologies:
      - slug: code-coverage
        path: free/dev/software-developer/code-coverage
        required: true
        tier_gate: free
      - slug: perf-test-basics
        path: solo/dev/automation-tooling/perf-test-basics
        required: true
        tier_gate: solo
      - slug: contract-first-development
        path: solo/dev/software-developer/contract-first-development
        required: true
        tier_gate: solo
    outputs:
      - "Pilot result"
      - "Updated rollback playbook"
    decision_gate: |
      Advance only if the pilot meets its success criteria; otherwise re-plan or kill.
  - name: "Execute"
    intent: "Ship the change behind safe deployment controls."
    tasks:
      - "Implement the plan in small, individually shippable steps"
      - "Keep all changes behind feature flags or branch-by-abstraction where reversible"
      - "Update tests + docs in the same change set, never as a follow-up"
    methodologies:
      - slug: e2e-testing
        path: free/dev/software-developer/e2e-testing
        required: true
        tier_gate: free
      - slug: perf-test-tools
        path: solo/dev/automation-tooling/perf-test-tools
        required: true
        tier_gate: solo
      - slug: feature-flags
        path: solo/dev/software-developer/feature-flags
        required: true
        tier_gate: solo
    outputs:
      - "Shipped change set"
      - "Updated tests + docs"
    decision_gate: |
      Advance only when CI is green, the change is observable in staging, and rollback was rehearsed at least once.
  - name: "Verify"
    intent: "Prove the change cleared the success criteria with evidence."
    tasks:
      - "Run targeted tests + smoke on the most-trafficked surfaces"
      - "Compare post-change metrics against the baseline captured earlier"
      - "Capture user / operator feedback within the first 48 hours"
    methodologies:
      - slug: integration-testing
        path: free/dev/software-developer/integration-testing
        required: true
        tier_gate: free
      - slug: trunk-based-branch-by-abstraction
        path: solo/dev/automation-tooling/trunk-based-branch-by-abstraction
        required: true
        tier_gate: solo
      - slug: performance-testing
        path: solo/dev/software-developer/performance-testing
        required: true
        tier_gate: solo
    outputs:
      - "Verification report"
      - "Metric delta vs baseline"
    decision_gate: |
      Advance only when metrics meet the criteria and no regression alerts are open.
  - name: "Roll out"
    intent: "Expand the change from pilot scope to full target audience."
    tasks:
      - "Increase rollout percentage in measured steps with explicit pause points"
      - "Watch SLO / error budgets on each step; halt if any breach"
      - "Communicate progress + rollback option to all affected stakeholders"
    methodologies:
      - slug: refactoring-patterns
        path: free/dev/software-developer/refactoring-patterns
        required: true
        tier_gate: free
      - slug: trunk-based-feature-flags
        path: solo/dev/automation-tooling/trunk-based-feature-flags
        required: true
        tier_gate: solo
      - slug: technical-debt
        path: solo/dev/software-developer/technical-debt
        required: true
        tier_gate: solo
    outputs:
      - "Rollout log"
      - "Stakeholder update"
    decision_gate: |
      Advance only after 100% rollout has been stable for the agreed soak period.
  - name: "Close"
    intent: "Lock in the gain: documentation, learnings, and a single decision artifact."
    tasks:
      - "Write the decision / outcome doc (continue / iterate / revert) with evidence trail"
      - "Update ADRs, runbooks, and pattern memory with what changed"
      - "Schedule the next review checkpoint or archive the workstream"
    methodologies:
      - slug: mr-codemod-refactor-agent
        path: geek/sdlc-ai/mr-codemod-refactor-agent
        required: true
        tier_gate: geek
      - slug: framework-decomposition-patterns
        path: solo/dev/code-quality/framework-decomposition-patterns
        required: true
        tier_gate: solo
      - slug: trunk-based-development
        path: solo/dev/software-developer/trunk-based-development
        required: true
        tier_gate: solo
    outputs:
      - "Decision doc"
      - "Updated ADR / runbook / memory entry"
    decision_gate: |
      Done when the decision doc is single-link shareable and the team can name the next checkpoint.

common_pitfalls:
  - "Skipping the Frame stage and starting work without written success criteria"
  - "Treating the rollback as a doc, not a rehearsed action"
  - "Cutting the Close / decision-doc stage when the work feels obvious — that is when memory rots fastest"

quality_checklist:
  - "Can a peer restate the problem, criteria, and decision rule without me in the room?"
  - "Are the baseline metrics recorded somewhere I can grep, not just in chat?"
  - "Did we actually rehearse the rollback, or did we just talk about it?"

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content major-framework-language-migration-3-months --format md"
  agent:  "faion get-content major-framework-language-migration-3-months --format context"
  json:   "faion get-content major-framework-language-migration-3-months --format json"

