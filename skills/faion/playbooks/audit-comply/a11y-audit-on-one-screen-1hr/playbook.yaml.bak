slug: a11y-audit-on-one-screen-1hr
title: "A11y audit on one screen (1hr)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: f2d3e81cccf1ac1f

tier: pro
tier_min: pro
group: role-ux-ui-designer
persona: Designer or a11y specialist auditing a single screen
complexity: medium
context: [solo, team]

summary: |
  Single-screen a11y pass against WCAG 2.2 AA + project standards: automated + manual + AT checks; remediation tickets opened per violation.

intent: |
  Open screen with unknown a11y -> WCAG 2.2 AA-compliant + remediation tickets opened.

scope: |
  Designer or a11y specialist runs a 1-hour audit on one screen. Automated scan, manual heuristic pass, AT smoke test, ticket per violation, status tracker updated. Done when each violation has a ticket and the screen status is logged.

success_criteria:
  - "Automated + manual + AT checks completed"
  - "Each violation has a ticket with severity"
  - "Screen status updated in the a11y tracker"
  - "Pattern issues queued with design system"

methodology_refs:
  - faion/knowledge/geek/ux/accessibility-specialist/ai-accessibility-automation-2026
  - faion/knowledge/geek/ux/accessibility-specialist/ai-assisted-accessibility
  - faion/knowledge/pro/ux/accessibility-specialist/a11y-basics
  - faion/knowledge/pro/ux/accessibility-specialist/a11y-testing
  - faion/knowledge/pro/ux/accessibility-specialist/accessibility-first-design
  - faion/knowledge/pro/ux/accessibility-specialist/cognitive-inclusion-design
  - faion/knowledge/pro/ux/accessibility-specialist/testing-with-assistive-technology
  - faion/knowledge/pro/ux/accessibility-specialist/wcag-22-compliance

stages:
  - name: "Automated scan"
    intent: "Catch the easy wins."
    tasks:
      - "Run AI-assisted automated scan on the screen"
      - "Triage false positives"
      - "Note quick fixes"
    methodologies:
      - slug: ai-accessibility-automation-2026
        path: geek/ux/accessibility-specialist/ai-accessibility-automation-2026
        required: true
        tier_gate: geek
      - slug: ai-assisted-accessibility
        path: geek/ux/accessibility-specialist/ai-assisted-accessibility
        required: true
        tier_gate: geek
      - slug: a11y-testing
        path: pro/ux/accessibility-specialist/a11y-testing
        required: true
        tier_gate: pro
    outputs:
      - "Automated finding list"
    decision_gate: |
      Advance only after triage.
  - name: "Manual heuristic"
    intent: "Find what automation missed."
    tasks:
      - "Walk WCAG 2.2 AA against the screen"
      - "Check cognitive-inclusion patterns"
      - "Capture findings with severity"
    methodologies:
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
      - slug: cognitive-inclusion-design
        path: pro/ux/accessibility-specialist/cognitive-inclusion-design
        required: true
        tier_gate: pro
      - slug: a11y-basics
        path: pro/ux/accessibility-specialist/a11y-basics
        required: true
        tier_gate: pro
    outputs:
      - "Manual finding list"
    decision_gate: |
      Advance only after the heuristic walk is complete.
  - name: "AT smoke"
    intent: "Test with NVDA + VoiceOver at minimum."
    tasks:
      - "Run flagship task with NVDA"
      - "Run flagship task with VoiceOver"
      - "Capture AT-only findings"
    methodologies:
      - slug: testing-with-assistive-technology
        path: pro/ux/accessibility-specialist/testing-with-assistive-technology
        required: true
        tier_gate: pro
      - slug: a11y-testing
        path: pro/ux/accessibility-specialist/a11y-testing
        required: true
        tier_gate: pro
    outputs:
      - "AT findings + recordings"
    decision_gate: |
      Advance only when both screen-readers are tested.
  - name: "Ticket"
    intent: "Tickets, not docs."
    tasks:
      - "Open a ticket per violation with severity"
      - "Pair patterns with design-system tags"
      - "Link to evidence per finding"
    methodologies:
      - slug: accessibility-first-design
        path: pro/ux/accessibility-specialist/accessibility-first-design
        required: true
        tier_gate: pro
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
    outputs:
      - "Tickets opened with severities"
    decision_gate: |
      Advance only when every violation has a ticket.
  - name: "Update tracker"
    intent: "Make the screen's state visible."
    tasks:
      - "Update the screen-status tracker"
      - "Note the audit date + auditor"
      - "Plan re-audit after fixes"
    methodologies:
      - slug: a11y-basics
        path: pro/ux/accessibility-specialist/a11y-basics
        required: true
        tier_gate: pro
    outputs:
      - "Updated screen-status tracker entry"
    decision_gate: |
      Done when tracker reflects the audit.

common_pitfalls:
  - "Trusting automated scans alone -> missing 30-40% of issues"
  - "No AT smoke -> the real users still cannot use it"
  - "Findings without tickets -> nothing changes"

quality_checklist:
  - "Did automated + manual + AT all run?"
  - "Are violations ticketed with severity?"
  - "Is the screen-status tracker current?"

related_playbooks:
  - accessibility-audit-and-remediation-program-6-weeks
  - heuristic-evaluation-on-a-new-screen-1hr

token_budget_estimate: 2500
cli_invocations:
  human:  "faion get-content a11y-audit-on-one-screen-1hr --format md"
  agent:  "faion get-content a11y-audit-on-one-screen-1hr --format context"
  json:   "faion get-content a11y-audit-on-one-screen-1hr --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial draft from F-059-063 chunk-05."

gaps:
  - methodology_slug: a11y-screen-status-tracker
    expected_tier: pro
    blocks_stage: 5
    note: "Screen-status tracker template not yet authored."
  - methodology_slug: screen-reader-test-script-templates
    expected_tier: pro
    blocks_stage: 3
    note: "Screen-reader test script templates not yet authored."
