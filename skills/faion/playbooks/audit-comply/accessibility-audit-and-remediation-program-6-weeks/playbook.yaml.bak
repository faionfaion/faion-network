slug: accessibility-audit-and-remediation-program-6-weeks
title: "Accessibility audit and remediation program (6 weeks)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 86b15f4103f4efd4

tier: pro
tier_min: pro
group: role-ux-ui-designer
persona: Accessibility lead or product designer running an a11y program
complexity: medium
context: [solo, team]

summary: |
  Full product audited to WCAG 2.2 AA, prioritized remediation backlog shipped, regression tests with assistive tech, compliance evidence packaged.

intent: |
  Audit gap -> WCAG 2.2 AA across product + shipped remediation + compliance evidence ready for legal/ADA.

scope: |
  Accessibility lead runs a 6-week program across the product. Includes automated + manual + AT audit, prioritized remediation, regression tests, an a11y user panel, CI gates, and a compliance evidence pack. Done when all critical + major findings are remediated, AT regression tests pass, and compliance pack is filed with legal.

success_criteria:
  - "Full WCAG 2.2 AA audit complete (automated + manual + AT)"
  - "All critical + major findings remediated"
  - "Regression tests with assistive technology pass in CI"
  - "A11y compliance pack (VPAT/ACR) filed with legal"

methodology_refs:
  - faion/knowledge/geek/ux/accessibility-specialist/ai-accessibility-automation-2026
  - faion/knowledge/geek/ux/accessibility-specialist/ai-assisted-accessibility
  - faion/knowledge/pro/ux/accessibility-specialist/a11y-basics
  - faion/knowledge/pro/ux/accessibility-specialist/a11y-testing
  - faion/knowledge/pro/ux/accessibility-specialist/accessibility-first-design
  - faion/knowledge/pro/ux/accessibility-specialist/ada-title-ii-compliance-2026
  - faion/knowledge/pro/ux/accessibility-specialist/cognitive-inclusion-design
  - faion/knowledge/pro/ux/accessibility-specialist/regulatory-compliance-2026
  - faion/knowledge/pro/ux/accessibility-specialist/testing-with-assistive-technology
  - faion/knowledge/pro/ux/accessibility-specialist/wcag-22-compliance
  - faion/knowledge/pro/ux/ux-ui-designer/accessibility-evaluation

stages:
  - name: "Scope + plan"
    intent: "Define what gets audited and what good looks like."
    tasks:
      - "Inventory products + flows in scope"
      - "Pick WCAG 2.2 AA + applicable regional rules (ADA Title II 2026)"
      - "Define severity rubric + ship-blocking thresholds"
    methodologies:
      - slug: a11y-basics
        path: pro/ux/accessibility-specialist/a11y-basics
        required: true
        tier_gate: pro
      - slug: ada-title-ii-compliance-2026
        path: pro/ux/accessibility-specialist/ada-title-ii-compliance-2026
        required: true
        tier_gate: pro
      - slug: regulatory-compliance-2026
        path: pro/ux/accessibility-specialist/regulatory-compliance-2026
        required: true
        tier_gate: pro
    outputs:
      - "Audit plan + severity rubric"
    decision_gate: |
      Advance only when scope is signed by product + legal.
  - name: "Automated + AI sweep"
    intent: "Catch the easy wins fast."
    tasks:
      - "Run AI-assisted automated scan across product"
      - "Triage findings; reject false positives"
      - "Quick-fix low-effort high-impact items"
    methodologies:
      - slug: ai-accessibility-automation-2026
        path: geek/ux/accessibility-specialist/ai-accessibility-automation-2026
        required: true
        tier_gate: geek
      - slug: ai-assisted-accessibility
        path: geek/ux/accessibility-specialist/ai-assisted-accessibility
        required: true
        tier_gate: geek
      - slug: a11y-testing
        path: pro/ux/accessibility-specialist/a11y-testing
        required: true
        tier_gate: pro
    outputs:
      - "Automated findings list + quick-fix log"
    decision_gate: |
      Advance only after triage is human-reviewed.
  - name: "Manual audit"
    intent: "Find what automation cannot."
    tasks:
      - "Heuristic + manual review per WCAG 2.2 AA"
      - "Cognitive inclusion checks on flagship flows"
      - "Document each finding with severity + repro steps"
    methodologies:
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
      - slug: cognitive-inclusion-design
        path: pro/ux/accessibility-specialist/cognitive-inclusion-design
        required: true
        tier_gate: pro
      - slug: accessibility-evaluation
        path: pro/ux/ux-ui-designer/accessibility-evaluation
        required: true
        tier_gate: pro
    outputs:
      - "Manual finding list with severity"
    decision_gate: |
      Advance when severities are confirmed by a second reviewer.
  - name: "AT testing"
    intent: "Test with the tools real users use."
    tasks:
      - "Run NVDA + VoiceOver + JAWS test scripts on flagship flows"
      - "Recruit a small a11y user panel for live sessions"
      - "Capture critical issues missed by other layers"
    methodologies:
      - slug: testing-with-assistive-technology
        path: pro/ux/accessibility-specialist/testing-with-assistive-technology
        required: true
        tier_gate: pro
      - slug: a11y-testing
        path: pro/ux/accessibility-specialist/a11y-testing
        required: true
        tier_gate: pro
    outputs:
      - "AT test results + panel feedback"
    decision_gate: |
      Advance only after each flagship flow passes AT smoke test.
  - name: "Remediation"
    intent: "Ship the fixes, not just file them."
    tasks:
      - "Prioritize critical + major findings into sprint backlog"
      - "Pair with engineering on patterns; update design system"
      - "Track burndown until criticals = 0"
    methodologies:
      - slug: accessibility-first-design
        path: pro/ux/accessibility-specialist/accessibility-first-design
        required: true
        tier_gate: pro
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
    outputs:
      - "Critical + major findings remediated"
    decision_gate: |
      Advance when criticals = 0 and majors are below threshold.
  - name: "Regression in CI"
    intent: "Prevent backsliding."
    tasks:
      - "Wire a11y tests into CI pipeline"
      - "Add AT-based regression checks for flagship flows"
      - "Block merges on regression"
    methodologies:
      - slug: ai-accessibility-automation-2026
        path: geek/ux/accessibility-specialist/ai-accessibility-automation-2026
        required: true
        tier_gate: geek
      - slug: a11y-testing
        path: pro/ux/accessibility-specialist/a11y-testing
        required: true
        tier_gate: pro
    outputs:
      - "CI a11y gate live"
    decision_gate: |
      Advance only when CI has run a11y checks on >=2 release cycles.
  - name: "Compliance pack"
    intent: "Hand legal what they need to file."
    tasks:
      - "Compile VPAT/ACR evidence"
      - "Map findings + fixes to WCAG criteria"
      - "Hand off to legal with sign-off"
    methodologies:
      - slug: regulatory-compliance-2026
        path: pro/ux/accessibility-specialist/regulatory-compliance-2026
        required: true
        tier_gate: pro
      - slug: ada-title-ii-compliance-2026
        path: pro/ux/accessibility-specialist/ada-title-ii-compliance-2026
        required: true
        tier_gate: pro
    outputs:
      - "Compliance pack filed"
    decision_gate: |
      Done when legal accepts the pack.

common_pitfalls:
  - "Stopping at automated -> misses keyboard + AT issues"
  - "No CI gate -> regressions appear by next release"
  - "Compliance pack written after fact -> evidence trail incomplete"

quality_checklist:
  - "Did a screen-reader user complete a flagship flow without help?"
  - "Are criticals at zero and majors below threshold?"
  - "Did legal accept the compliance pack?"

related_playbooks:
  - a11y-audit-on-one-screen-1hr
  - design-system-v1-to-v2-migration-12-weeks

token_budget_estimate: 10000
cli_invocations:
  human:  "faion get-content accessibility-audit-and-remediation-program-6-weeks --format md"
  agent:  "faion get-content accessibility-audit-and-remediation-program-6-weeks --format context"
  json:   "faion get-content accessibility-audit-and-remediation-program-6-weeks --format json"

