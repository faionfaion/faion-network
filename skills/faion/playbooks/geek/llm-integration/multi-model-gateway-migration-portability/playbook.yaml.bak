slug: multi-model-gateway-migration-portability
title: "Multi-model gateway migration: lock-in to portability (2 months)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 101ca946a85e38ab

tier_min: geek
complexity: deep
context: [team]
persona_hints: [P7]

intent: |
  Vendor-locked agent → portable runtime where Anthropic / OpenAI / local LLM swap per-step or per-tenant with fallback, cost-aware routing, unchanged eval bar.

scope: |
  Move a single-vendor agent (e.g. Anthropic-only) to a portable runtime where Anthropic / OpenAI / local LLM can be swapped per-step or per-tenant, with fallback chain, cost-aware routing, and unchanged eval bar.

non_goals:
  - "Building a public LLM gateway product — out of scope"
  - "Custom inference infra — use Ollama / vendor APIs"

prerequisites:
  - "Working vertical agent on one vendor"
  - "Eval harness passing the playbook 1 bar"

success_criteria:
  - "All call sites go through gateway adapter"
  - "Two vendors live + one local fallback"
  - "Router policy documented + tested"
  - "Eval suite passes on each backend"
  - "Cost-aware routing reduces $/success"

stages:
  - name: "Adapter Layer"
    intent: "Centralize provider calls behind a single adapter."
    tasks:
      - "Wrap Claude API behind adapter"
      - "Add OpenAI adapter"
      - "Pick MCP-gateway composition if applicable"
    methodologies:
      - slug: claude-api-integration
        path: geek/ai/llm-integration/claude-api-integration
        required: true
        tier_gate: geek
      - slug: openai-api-integration
        path: geek/ai/llm-integration/openai-api-integration
        required: true
        tier_gate: geek
      - slug: gemini-api-integration
        path: geek/ai/llm-integration/gemini-api-integration
        required: true
        tier_gate: geek
      - slug: mcp-gateway-composition
        path: geek/ai/ai-agents/mcp-gateway-composition
        required: true
        tier_gate: geek
      - slug: function-calling-patterns
        path: geek/ai/llm-integration/function-calling-patterns
        required: true
        tier_gate: geek
      - slug: tool-use-basics
        path: geek/ai/llm-integration/tool-use-basics
        required: true
        tier_gate: geek
      - slug: structured-output-basics
        path: geek/ai/llm-integration/structured-output-basics
        required: true
        tier_gate: geek
      - slug: structured-output-patterns
        path: geek/ai/llm-integration/structured-output-patterns
        required: true
        tier_gate: geek
      - slug: structured-output-mode-picker
        path: geek/ai/ai-agents/structured-output-mode-picker
        required: true
        tier_gate: geek
      - slug: semantic-xml-content
        path: geek/ai/llm-integration/semantic-xml-content
        required: true
        tier_gate: geek
    outputs:
      - "Adapter module"
      - "Call-site sweep diff"
    decision_gate: |
      Advance only when all call sites route through adapter.
  - name: "Local Fallback"
    intent: "Ollama-backed local LLM as deterministic fallback."
    tasks:
      - "Stand up Ollama deployment"
      - "Pick + tune local model"
      - "Wire tool calling"
    methodologies:
      - slug: local-llm-ollama
        path: geek/ai/llm-integration/local-llm-ollama
        required: true
        tier_gate: geek
      - slug: ollama-setup-models
        path: geek/ai/ml-engineer/ollama-setup-models
        required: true
        tier_gate: geek
      - slug: ollama-deployment
        path: geek/ai/ml-engineer/ollama-deployment
        required: true
        tier_gate: geek
      - slug: ollama-prompt-engineering
        path: geek/ai/ml-engineer/ollama-prompt-engineering
        required: true
        tier_gate: geek
      - slug: ollama-python-client
        path: geek/ai/ml-engineer/ollama-python-client
        required: true
        tier_gate: geek
      - slug: ollama-tool-calling
        path: geek/ai/ml-engineer/ollama-tool-calling
        required: true
        tier_gate: geek
      - slug: ollama-agent-integration
        path: geek/ai/ml-engineer/ollama-agent-integration
        required: true
        tier_gate: geek
    outputs:
      - "Local LLM endpoint"
      - "Cost+latency baseline"
    decision_gate: |
      Advance when local backend passes ≥X% of eval set.
  - name: "Routing"
    intent: "Cost-aware + preference-trained routing across backends."
    tasks:
      - "Wire gateway fallback chain"
      - "Add preference-trained router"
      - "Reuse previous response ids where available"
    methodologies:
      - slug: gateway-fallback-chain
        path: geek/ai/ai-agents/gateway-fallback-chain
        required: true
        tier_gate: geek
      - slug: preference-trained-router
        path: geek/ai/ai-agents/preference-trained-router
        required: true
        tier_gate: geek
      - slug: previous-response-id-reasoning-reuse
        path: geek/ai/ai-agents/previous-response-id-reasoning-reuse
        required: true
        tier_gate: geek
      - slug: weak-model-preselection
        path: geek/ai/ai-agents/weak-model-preselection
        required: true
        tier_gate: geek
    outputs:
      - "Routing policy doc"
      - "Shadow A/B fixture"
    decision_gate: |
      Promote routing rule only after shadow A/B beats baseline.
  - name: "Eval Parity"
    intent: "Run eval suite on each backend; lock the bar."
    tasks:
      - "Run suite on each backend"
      - "Replay traces with record-replay"
      - "Pin output-mode picker per backend"
    methodologies:
      - slug: record-replay-debugging
        path: geek/ai/ai-agents/record-replay-debugging
        required: true
        tier_gate: geek
      - slug: structured-output-mode-picker
        path: geek/ai/ai-agents/structured-output-mode-picker
        required: true
        tier_gate: geek
      - slug: model-evaluation
        path: geek/ai/ml-engineer/model-evaluation
        required: true
        tier_gate: geek
      - slug: llm-observability-stack
        path: geek/ai/ml-engineer/llm-observability-stack
        required: true
        tier_gate: geek
      - slug: rag-eval-ab-testing
        path: geek/ai/rag-engineer/rag-eval-ab-testing
        required: true
        tier_gate: geek
    outputs:
      - "Cross-backend eval table"
      - "Schema pin manifest"
    decision_gate: |
      Promote only when each backend meets minimum bar.

common_pitfalls:
  - "Treating eval scores as ground truth without judge calibration"
  - "Shipping prompt or model changes without a regression gate"

quality_checklist:
  - "Can I roll back this change in one step?"
  - "Is the regression eval committed BEFORE the fix?"

related_playbooks:
  - eval-harness-continuous-benchmark-suite
  - agent-observability-drift-detection-rollout

token_budget_estimate: 18000
