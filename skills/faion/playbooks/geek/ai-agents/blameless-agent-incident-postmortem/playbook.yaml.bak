    expected_tier: geek
    blocks_stage: 1
    note: "Gap from brainstorm-2026-05-17: agent-incident-postmortem-template required by playbook chain"
  - methodology_slug: agent-failure-taxonomy
    expected_tier: geek
    blocks_stage: 1
    note: "Gap from brainstorm-2026-05-17: agent-failure-taxonomy required by playbook chain"
