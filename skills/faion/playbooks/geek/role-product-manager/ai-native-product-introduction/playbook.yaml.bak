# =============================================================================
# PLAYBOOK v2 — AI-native product introduction
# Group: role-product-manager | Tier: geek | Complexity: deep
# =============================================================================

slug: ai-native-product-introduction
title: "AI-native product introduction"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 07bc1f49a6322a6a

tier_min: geek
complexity: deep
context: ['team']
persona: role-product-manager
group: role-product-manager

summary: "Stand up an AI-native product surface (new feature or new product) end-to-end: agentic capability shape, eval framework, safety + explainability, rollout, and steady-state operating model."

intent: |
  Stand up an AI-native product surface (new feature or new product) end-to-end: agentic capability shape, eval framework, safety + explainability, rollout, and steady-state operating model. Distinct from a normal MVP because of model risk, evals, and explainability.

scope: |
  Stand up an AI-native product surface (new feature or new product) end-to-end: agentic capability shape, eval framework, safety + explainability, rollout, and steady-state operating model. Distinct from a normal MVP because of model risk, evals, and explainability.

methodology_refs:
  - geek/product/product-manager/agentic-ai-product-development
  - geek/product/product-manager/agents
  - geek/product/product-manager/ai-native-product-development
  - geek/research/market-researcher/market-sizing-with-ai
  - geek/research/market-researcher/perplexity-ai-research
  - geek/research/researcher/ai-persona-building
  - geek/research/researcher/synthetic-users
  - pro/product/product-operations/experimentation-at-scale
  - pro/product/product-operations/learning-speed-competitive-moat
  - pro/product/product-operations/product-explainability
  - pro/product/product-operations/product-operations
  - solo/product/product-operations/product-analytics
  - solo/product/product-planning/release-planning
  - solo/research/researcher/jobs-to-be-done

success_criteria:
  - "Frozen, versioned eval set with 50+ scenarios"
  - "Failure-mode matrix with refusal/escalation paths"
  - "Agent rolled out behind kill switch + flag"
  - "Steady-state ops model documented and owned"

stages:
  - name: "Capability shape"
    intent: "Decide the agentic shape before any code lands."
    tasks:
      - "Pick the agent shape: assistant, autonomous worker, or in-product copilot"
      - "Map the JTBD the agent will own end-to-end"
      - "Articulate where the agent must defer to a human"
    methodologies:
      - slug: agentic-ai-product-development
        path: geek/product/product-manager/agentic-ai-product-development
        required: true
        tier_gate: geek
      - slug: agents
        path: geek/product/product-manager/agents
        required: true
        tier_gate: geek
      - slug: ai-native-product-development
        path: geek/product/product-manager/ai-native-product-development
        required: true
        tier_gate: geek
      - slug: jobs-to-be-done
        path: solo/research/researcher/jobs-to-be-done
        required: true
        tier_gate: solo
    outputs:
      - "Capability shape doc"
      - "Human-in-loop boundaries"
    decision_gate: "Advance when the agent shape is one of 3 named patterns and the human-in-loop boundary is explicit."
  - name: "Evals first"
    intent: "Build the eval set before the agent."
    tasks:
      - "Draft 50+ frozen eval scenarios from real user JTBDs"
      - "Define passing criteria per scenario"
      - "Lock the eval set under version control"
    methodologies:
      - slug: synthetic-users
        path: geek/research/researcher/synthetic-users
        required: true
        tier_gate: geek
      - slug: ai-persona-building
        path: geek/research/researcher/ai-persona-building
        required: true
        tier_gate: geek
      - slug: learning-speed-competitive-moat
        path: pro/product/product-operations/learning-speed-competitive-moat
        required: true
        tier_gate: pro
    outputs:
      - "Frozen eval set"
      - "Passing-criteria doc"
    decision_gate: "Advance when the eval set is frozen, versioned, and has at least 50 scenarios."
  - name: "Safety + explainability"
    intent: "Decide what failure looks like and how the agent explains itself."
    tasks:
      - "Enumerate top 5 failure modes with severity"
      - "Design refusal + escalation paths per failure"
      - "Define the user-facing explanation surface (citations, source, reasoning trace)"
    methodologies:
      - slug: product-explainability
        path: pro/product/product-operations/product-explainability
        required: true
        tier_gate: pro
      - slug: agents
        path: geek/product/product-manager/agents
        required: true
        tier_gate: geek
    outputs:
      - "Failure-mode matrix"
      - "Explainability surface spec"
    decision_gate: "Advance when every top-5 failure mode has an explicit refusal or escalation path."
  - name: "Build"
    intent: "Implement the smallest agent that passes the eval set."
    tasks:
      - "Wire the agent against tools / retrieval / memory as needed"
      - "Run the eval set every commit"
      - "Gate merges on eval pass rate"
    methodologies:
      - slug: agentic-ai-product-development
        path: geek/product/product-manager/agentic-ai-product-development
        required: true
        tier_gate: geek
      - slug: experimentation-at-scale
        path: pro/product/product-operations/experimentation-at-scale
        required: true
        tier_gate: pro
      - slug: product-operations
        path: pro/product/product-operations/product-operations
        required: true
        tier_gate: pro
    outputs:
      - "Working agent passing eval set"
      - "CI-integrated eval pipeline"
    decision_gate: "Advance when the eval pass rate is above the documented threshold (no opinion-based shipping)."
  - name: "Trust testing"
    intent: "Run the agent in front of users with the brakes engaged."
    tasks:
      - "Run 10+ supervised sessions"
      - "Watch for refusal-rate, escalation-rate, and user-correction-rate"
      - "Iterate prompts/tools based on observed corrections"
    methodologies:
      - slug: jobs-to-be-done
        path: solo/research/researcher/jobs-to-be-done
        required: true
        tier_gate: solo
      - slug: product-analytics
        path: solo/product/product-operations/product-analytics
        required: true
        tier_gate: solo
    outputs:
      - "Trust-test report"
    decision_gate: "Advance when user-correction-rate is below the documented threshold across 3 consecutive sessions."
  - name: "Rollout"
    intent: "Roll the agent out behind a kill switch."
    tasks:
      - "Roll out behind a feature flag with kill switch"
      - "Ramp exposure in 1% → 10% → 50% → 100% stages"
      - "Watch eval drift weekly"
    methodologies:
      - slug: release-planning
        path: solo/product/product-planning/release-planning
        required: true
        tier_gate: solo
      - slug: experimentation-at-scale
        path: pro/product/product-operations/experimentation-at-scale
        required: true
        tier_gate: pro
      - slug: product-analytics
        path: solo/product/product-operations/product-analytics
        required: true
        tier_gate: solo
    outputs:
      - "Rollout schedule"
      - "Kill-switch wiring"
    decision_gate: "Advance when 50% exposure holds the eval pass rate for 7 days."
  - name: "Steady-state"
    intent: "Establish the operating model for the agent in production."
    tasks:
      - "Define ownership for eval set, incidents, and model upgrades"
      - "Schedule weekly drift review"
      - "Establish a model-upgrade re-eval ritual"
    methodologies:
      - slug: product-operations
        path: pro/product/product-operations/product-operations
        required: true
        tier_gate: pro
      - slug: learning-speed-competitive-moat
        path: pro/product/product-operations/learning-speed-competitive-moat
        required: true
        tier_gate: pro
      - slug: product-analytics
        path: solo/product/product-operations/product-analytics
        required: true
        tier_gate: solo
    outputs:
      - "Operating model doc"
      - "Weekly drift dashboard"
    decision_gate: "Required: a written steady-state ops model the on-call team can execute."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content ai-native-product-introduction --format md"
  agent:  "faion get-content ai-native-product-introduction --format context"
  json:   "faion get-content ai-native-product-introduction --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
