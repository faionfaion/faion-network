# =============================================================================
# PLAYBOOK v2 — Validate an AI feature before it consumes a quarter
# Group: role-product-manager | Tier: geek | Complexity: deep
# =============================================================================

slug: validate-an-ai-feature-before-it-consumes-a-quarter
title: "Validate an AI feature before it consumes a quarter"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 32bdbb03d737e4df

tier_min: geek
complexity: deep
context: ['team']
persona: role-product-manager
group: role-product-manager

summary: "Bridge the canyon between 'leadership wants AI' and 'team commits roadmap slot'."

intent: |
  Bridge the canyon between 'leadership wants AI' and 'team commits roadmap slot'. PM proves or kills an AI feature on user value (not model novelty) before it touches the roadmap. Faion has agentic-ai-product-development at geek tier but no de-risking playbook for AI feature commits specifically.

scope: |
  Bridge the canyon between 'leadership wants AI' and 'team commits roadmap slot'. PM proves or kills an AI feature on user value (not model novelty) before it touches the roadmap. Faion has agentic-ai-product-development at geek tier but no de-risking playbook for AI feature commits specifically.

methodology_refs:
  - geek/product/product-manager/agentic-ai-product-development
  - geek/product/product-manager/ai-native-product-development
  - pro/product/product-manager/experimentation-at-scale
  - solo/research/researcher/jobs-to-be-done
  - geek/product/product-manager/ai-feature-de-risking

success_criteria:
  - "De-noveltied feature statement with non-AI counterfactual"
  - "WoZ test report from 5+ sessions"
  - "20+ frozen eval scenarios"
  - "Written commit / hold / kill verdict"

stages:
  - name: "De-novelty"
    intent: "Strip the model novelty and look at user value."
    tasks:
      - "Restate the feature as a JTBD the user already has"
      - "Test if a non-AI solution would also serve the JTBD"
      - "Note the genuine reason the agent must be involved"
    methodologies:
      - slug: jobs-to-be-done
        path: solo/research/researcher/jobs-to-be-done
        required: true
        tier_gate: solo
      - slug: ai-native-product-development
        path: geek/product/product-manager/ai-native-product-development
        required: true
        tier_gate: geek
    outputs:
      - "De-noveltied feature statement"
    decision_gate: "Advance when the feature has a non-AI counterfactual that loses against the AI version on a real reason."
  - name: "Wizard-of-Oz test"
    intent: "Fake the agent with a human in the loop."
    tasks:
      - "Mock the agent response with a human responder"
      - "Run 5+ user sessions with the WoZ setup"
      - "Watch user reactions to imperfect-but-fast vs slow-but-perfect responses"
    methodologies:
      - slug: jobs-to-be-done
        path: solo/research/researcher/jobs-to-be-done
        required: true
        tier_gate: solo
      - slug: experimentation-at-scale
        path: pro/product/product-manager/experimentation-at-scale
        required: true
        tier_gate: pro
    outputs:
      - "WoZ session report"
    decision_gate: "Advance when WoZ shows clear value, not curiosity-only engagement."
  - name: "Eval-first sketch"
    intent: "Sketch the eval set before any model work."
    tasks:
      - "Draft 20+ frozen eval scenarios"
      - "Define passing criteria"
      - "Confirm eval is achievable with the candidate model"
    methodologies:
      - slug: agentic-ai-product-development
        path: geek/product/product-manager/agentic-ai-product-development
        required: true
        tier_gate: geek
      - slug: ai-native-product-development
        path: geek/product/product-manager/ai-native-product-development
        required: true
        tier_gate: geek
    outputs:
      - "Eval set sketch"
    decision_gate: "Advance when 20+ scenarios are documented and reviewable."
  - name: "Risk + trust read"
    intent: "Map the failure surface and the user trust requirement."
    tasks:
      - "Enumerate the top 5 failure modes"
      - "Score each by user-trust impact"
      - "Decide if the feature can ship behind a 'tentative answer' frame"
    methodologies:
      - slug: agentic-ai-product-development
        path: geek/product/product-manager/agentic-ai-product-development
        required: true
        tier_gate: geek
      - slug: ai-feature-de-risking
        path: geek/product/product-manager/ai-feature-de-risking
        required: true
        tier_gate: geek
    outputs:
      - "Failure-mode + trust read"
    decision_gate: "Advance when failure modes have an explicit acceptable-trust threshold."
  - name: "De-risk vote"
    intent: "Convert evidence into a roadmap-commit decision."
    tasks:
      - "Score the feature on user value, eval feasibility, and trust requirement"
      - "Decide commit / hold / kill"
      - "Document the rationale for any commit decision"
    methodologies:
      - slug: ai-feature-de-risking
        path: geek/product/product-manager/ai-feature-de-risking
        required: true
        tier_gate: geek
      - slug: experimentation-at-scale
        path: pro/product/product-manager/experimentation-at-scale
        required: true
        tier_gate: pro
    outputs:
      - "Commit / hold / kill decision with rationale"
    decision_gate: "Required: a written de-risk verdict; no 'let's see' allowed."

token_budget_estimate: 14000

cli_invocations:
  human:  "faion get-content validate-an-ai-feature-before-it-consumes-a-quarter --format md"
  agent:  "faion get-content validate-an-ai-feature-before-it-consumes-a-quarter --format context"
  json:   "faion get-content validate-an-ai-feature-before-it-consumes-a-quarter --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 playbook drafted from F-059-063 chunk-04, role-manager-manager"

gaps: []
