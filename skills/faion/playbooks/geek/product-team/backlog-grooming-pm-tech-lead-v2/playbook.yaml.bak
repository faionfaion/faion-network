stages:
  - name: "Pre-Read"
    intent: "PM + tech lead both prep before meeting."
    tasks:
      - "PM brings the candidate items with outcomes + value notes"
      - "Tech lead reads the candidates and flags feasibility risks"
      - "Both pre-agree the top 5 items to discuss"
    methodologies:
      - slug: "acceptance-criteria"
        path: "pro/ba/business-analyst/acceptance-criteria"
        required: true
        tier_gate: "geek"
      - slug: "user-story-mapping"
        path: "pro/ba/business-analyst/user-story-mapping"
        required: true
        tier_gate: "geek"
      - slug: "tech-debt-management"
        path: "solo/dev/code-quality/tech-debt-management"
        required: true
        tier_gate: "geek"
    outputs:
      - "candidate list with value"
      - "feasibility notes"
      - "top-5 agenda"
    decision_gate: "Advance only when both arrive with the pre-read done."
  - name: "Groom Live"
    intent: "Time-boxed; no rambling."
    tasks:
      - "Walk top 5; either ready / needs-info / drop"
      - "Write acceptance criteria for ready items"
      - "Estimate complexity (S/M/L) — not time"
    methodologies:
      - slug: "backlog-management"
        path: "solo/product/product-operations/backlog-management"
        required: true
        tier_gate: "geek"
      - slug: "backlog-grooming-roadmapping"
        path: "solo/sdd/sdd-planning/backlog-grooming-roadmapping"
        required: true
        tier_gate: "geek"
      - slug: "impl-plan-100k-rule"
        path: "solo/sdd/sdd-planning/impl-plan-100k-rule"
        required: true
        tier_gate: "geek"
    outputs:
      - "per-item ready/needs/drop"
      - "acceptance criteria for ready items"
      - "complexity tags"
    decision_gate: "Advance when every top-5 item has a ready/needs/drop verdict."
  - name: "Update & Communicate"
    intent: "Make the meeting count."
    tasks:
      - "Update the backlog with the changes from the meeting"
      - "Post the grooming summary to the team channel"
      - "Calendar any needs-info follow-ups"
    methodologies:
      - slug: "task-creation-principles"
        path: "solo/sdd/sdd-planning/task-creation-principles"
        required: true
        tier_gate: "geek"
      - slug: "backlog-grooming-roadmapping"
        path: "solo/sdd/sdd/backlog-grooming-roadmapping"
        required: true
        tier_gate: "geek"
      - slug: "quality-gates-confidence"
        path: "solo/sdd/sdd/quality-gates-confidence"
        required: true
        tier_gate: "geek"
      - slug: "task-creation-parallelization"
        path: "solo/sdd/sdd/task-creation-parallelization"
        required: true
        tier_gate: "geek"
    outputs:
      - "updated backlog"
      - "grooming summary post"
      - "follow-up calendar entries"
    decision_gate: "Required output: a published grooming summary."
token_budget_estimate: 18000
