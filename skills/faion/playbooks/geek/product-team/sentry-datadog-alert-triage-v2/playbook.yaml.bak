slug: "sentry-datadog-alert-triage-v2"
title: "Sentry / Datadog alert triage (in-hours)"
tier: "geek"
group: "product-team"
persona: "p6-product-dev-team"
complexity: "medium"
version: "1.0.0"
status: "draft"
last_reviewed: 2026-05-20
maintainers:
  - "faion-network"
summary: |
  An alert fires in production. On-call engineer triages within minutes using AI-classified context, decides: noise / known / new incident. New incidents enter a runbook flow; known issues get cross-linked. Outcome: every alert closes with a verdict + audit log.
content_id: "f9132f311cc4b1b8"
tier_min: "geek"
context:
  - "team"
intent: |
  An alert fires in production. On-call engineer triages within minutes using AI-classified context, decides: noise / known / new incident. New incidents enter a runbook flow; known issues get cross-linked. Outcome: every alert closes with a verdict + audit log.
scope: |
  An alert fires in production. On-call engineer triages within minutes using AI-classified context, decides: noise / known / new incident. New incidents enter a runbook flow; known issues get cross-linked. Outcome: every alert closes with a verdict + audit log.
success_criteria:
  - "All 4 stages have written outputs in the project record"
  - "Each stage's decision gate was answered before advancing (yes / no in writing)"
  - "Final stage produced the required written decision artifact"
  - "Every methodology reference loaded cleanly via `faion get-content`"
methodology_refs:
  - "inc-postmortem-auto-draft-no-publish"
  - "inc-read-only-investigation-default"
  - "inc-runbook-as-markdown-tagged-steps"
  - "inc-tool-tier-approval-gate"
  - "task-agent-fixable-triage-gate"
  - "tracker-ai-triage-classify-route"
  - "api-monitoring-alerting"
  - "api-monitoring-logging"
  - "api-monitoring-metrics"
  - "mistake-memory"
stages:
  - name: "Receive & Acknowledge"
    intent: "Acknowledge inside the SLA window."
    tasks:
      - "On-call ack within the SLA (e.g., 5 minutes)"
      - "Open an incident channel + scratchpad"
      - "Page secondary if scope is unclear"
    methodologies:
      - slug: "inc-postmortem-auto-draft-no-publish"
        path: "geek/sdlc-ai/inc-postmortem-auto-draft-no-publish"
        required: true
        tier_gate: "geek"
      - slug: "inc-read-only-investigation-default"
        path: "geek/sdlc-ai/inc-read-only-investigation-default"
        required: true
        tier_gate: "geek"
    outputs:
      - "ack timestamp"
      - "incident channel"
      - "page log if any"
    decision_gate: "Advance only when incident channel is live and ack is on the clock."
  - name: "Diagnose"
    intent: "Bound the blast radius before fixing."
    tasks:
      - "Pull dashboards (errors, latency, saturation, deploy log)"
      - "Hypothesize root cause; test cheapest hypothesis first"
      - "Decide: hotfix, rollback, or feature-flag off"
    methodologies:
      - slug: "inc-runbook-as-markdown-tagged-steps"
        path: "geek/sdlc-ai/inc-runbook-as-markdown-tagged-steps"
        required: true
        tier_gate: "geek"
      - slug: "inc-tool-tier-approval-gate"
        path: "geek/sdlc-ai/inc-tool-tier-approval-gate"
        required: true
        tier_gate: "geek"
    outputs:
      - "dashboard snapshots"
      - "hypothesis log"
      - "fix-path decision"
    decision_gate: "Advance only when the fix path is chosen with evidence."
  - name: "Mitigate"
    intent: "Stop the bleed."
    tasks:
      - "Execute the chosen mitigation (rollback / flag / hotfix)"
      - "Verify error and latency dashboards recover"
      - "Confirm user-impact has stopped"
    methodologies:
      - slug: "task-agent-fixable-triage-gate"
        path: "geek/sdlc-ai/task-agent-fixable-triage-gate"
        required: true
        tier_gate: "geek"
      - slug: "tracker-ai-triage-classify-route"
        path: "geek/sdlc-ai/tracker-ai-triage-classify-route"
        required: true
        tier_gate: "geek"
    outputs:
      - "mitigation actions log"
      - "recovery dashboard"
      - "impact-end note"
    decision_gate: "Advance only when dashboards are green for 15 consecutive minutes."
  - name: "Postmortem"
    intent: "Write the blameless postmortem within 48h."
    tasks:
      - "Document timeline, root cause, contributing factors"
      - "Define action items with owners and dates"
      - "Share postmortem to engineering at large"
    methodologies:
      - slug: "api-monitoring-alerting"
        path: "pro/dev/software-developer/api-monitoring-alerting"
        required: true
        tier_gate: "geek"
      - slug: "api-monitoring-logging"
        path: "pro/dev/software-developer/api-monitoring-logging"
        required: true
        tier_gate: "geek"
      - slug: "api-monitoring-metrics"
        path: "pro/dev/software-developer/api-monitoring-metrics"
        required: true
        tier_gate: "geek"
      - slug: "mistake-memory"
        path: "solo/sdd/sdd/mistake-memory"
        required: true
        tier_gate: "geek"
    outputs:
      - "postmortem doc"
      - "action items with owners"
      - "share log"
    decision_gate: "Required output: a published blameless postmortem."
token_budget_estimate: 18000
gaps:
  - methodology_slug: "alert-triage-decision-tree"
    expected_tier: "geek"
    blocks_stage: 1
    note: "Referenced indirectly; methodology not yet authored under skills/faion/knowledge/geek/..."
  - methodology_slug: "service-ownership-map-template"
    expected_tier: "geek"
    blocks_stage: 1
    note: "Referenced indirectly; methodology not yet authored under skills/faion/knowledge/geek/..."
