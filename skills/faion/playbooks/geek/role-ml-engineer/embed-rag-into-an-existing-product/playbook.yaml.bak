stages:
  - name: "Audit"
    intent: "Get an honest map of where things stand today for: Embed RAG into an existing product."
    tasks:
      - "Inventory current state, owners, and recent incidents"
      - "Identify the top 3 risks that block the desired outcome"
      - "Surface unknowns and missing telemetry up front"
    methodologies:
      - slug: cost-optimization
        path: geek/ai/ml-engineer/cost-optimization
        required: true
        tier_gate: geek
      - slug: embeddings-evaluation
        path: geek/ai/ml-engineer/embeddings-evaluation
        required: true
        tier_gate: geek
      - slug: guardrails-concepts
        path: geek/ai/ml-engineer/guardrails-concepts
        required: true
        tier_gate: geek
      - slug: guardrails-custom-pipeline
        path: geek/ai/ml-engineer/guardrails-custom-pipeline
        required: true
        tier_gate: geek
    outputs:
      - "Written current-state map (1 page)"
      - "Top-3 risk list with owners"
    decision_gate: |
      Advance only if all top-3 risks have a named owner; otherwise re-scope.
  - name: "Plan"
    intent: "Convert audit findings into a defensible execution plan with explicit cuts."
    tasks:
      - "Define done-state acceptance criteria"
      - "Sequence the smallest set of changes that ship the outcome"
      - "Cut everything that does not block the done state"
    methodologies:
      - slug: llm-decision-framework
        path: geek/ai/ml-engineer/llm-decision-framework
        required: true
        tier_gate: geek
      - slug: llm-observability-stack
        path: geek/ai/ml-engineer/llm-observability-stack
        required: true
        tier_gate: geek
      - slug: structured-output
        path: geek/ai/ml-engineer/structured-output
        required: true
        tier_gate: geek
      - slug: vector-db-index-tuning
        path: geek/ai/ml-engineer/vector-db-index-tuning
        required: true
        tier_gate: geek
    outputs:
      - "1-page plan with sequenced steps"
      - "Non-goals list (what we are NOT doing)"
    decision_gate: |
      Advance if every plan item maps to an acceptance criterion; rewrite the plan otherwise.
  - name: "Build"
    intent: "Land the first vertical slice end-to-end in a real environment."
    tasks:
      - "Implement the slice behind a flag or in a sandbox"
      - "Wire telemetry from day one"
      - "Get a real human (not just CI) to use it"
    methodologies:
      - slug: vector-db-setup-prod
        path: geek/ai/ml-engineer/vector-db-setup-prod
        required: true
        tier_gate: geek
      - slug: chunking-document-structure
        path: geek/ai/rag-engineer/chunking-document-structure
        required: true
        tier_gate: geek
      - slug: chunking-production-service
        path: geek/ai/rag-engineer/chunking-production-service
        required: true
        tier_gate: geek
      - slug: chunking-semantic
        path: geek/ai/rag-engineer/chunking-semantic
        required: true
        tier_gate: geek
    outputs:
      - "Working slice in a non-prod environment"
      - "Telemetry dashboard for the slice"
    decision_gate: |
      Advance when the slice runs end-to-end with one real user; loop on Build otherwise.
  - name: "Harden"
    intent: "Find the failure modes before users do."
    tasks:
      - "Run failure-mode tests against the slice (load, edge cases, abuse)"
      - "Close every must-fix; ticket every nice-to-fix"
      - "Re-run telemetry to confirm no regression"
    methodologies:
      - slug: db-comparison
        path: geek/ai/rag-engineer/db-comparison
        required: true
        tier_gate: geek
      - slug: embedding-caching
        path: geek/ai/rag-engineer/embedding-caching
        required: true
        tier_gate: geek
      - slug: embedding-model-selection
        path: geek/ai/rag-engineer/embedding-model-selection
        required: true
        tier_gate: geek
      - slug: hybrid-search-basics
        path: geek/ai/rag-engineer/hybrid-search-basics
        required: true
        tier_gate: geek
    outputs:
      - "Failure-mode report + closure log"
      - "Ticketed nice-to-fix backlog"
    decision_gate: |
      Advance only with zero open must-fixes; otherwise stay in Harden.
  - name: "Pilot"
    intent: "Run with a controlled blast radius before broad rollout."
    tasks:
      - "Roll out to a controlled subset (canary, beta team, single client)"
      - "Measure against acceptance criteria with real traffic / real work"
      - "Capture rollback signal in writing"
    methodologies:
      - slug: hybrid-search-implementation
        path: geek/ai/rag-engineer/hybrid-search-implementation
        required: true
        tier_gate: geek
      - slug: rag-architecture
        path: geek/ai/rag-engineer/rag-architecture
        required: true
        tier_gate: geek
      - slug: rag-eval-ab-testing
        path: geek/ai/rag-engineer/rag-eval-ab-testing
        required: true
        tier_gate: geek
      - slug: rag-eval-generation-metrics
        path: geek/ai/rag-engineer/rag-eval-generation-metrics
        required: true
        tier_gate: geek
    outputs:
      - "Pilot metrics vs. acceptance criteria"
      - "Rollback decision criteria in writing"
    decision_gate: |
      Advance if pilot meets all acceptance criteria; pause for fix or revert otherwise.
  - name: "Rollout"
    intent: "Move from pilot to general availability with confidence."
    tasks:
      - "Stage the rollout in defined cohorts / regions / risk bands"
      - "Hold each stage open until telemetry is clean"
      - "Communicate state to stakeholders at each step"
    methodologies:
      - slug: rag-eval-pipeline
        path: geek/ai/rag-engineer/rag-eval-pipeline
        required: true
        tier_gate: geek
      - slug: rag-eval-production-monitoring
        path: geek/ai/rag-engineer/rag-eval-production-monitoring
        required: true
        tier_gate: geek
      - slug: rag-eval-retrieval-metrics
        path: geek/ai/rag-engineer/rag-eval-retrieval-metrics
        required: true
        tier_gate: geek
      - slug: rag-eval-strategy
        path: geek/ai/rag-engineer/rag-eval-strategy
        required: true
        tier_gate: geek
    outputs:
      - "Rollout log (cohort-by-cohort)"
      - "Stakeholder update record"
    decision_gate: |
      Advance to the next cohort only after the previous is stable for the agreed window.
  - name: "Operate"
    intent: "Hand off as a steady-state operation, not a hero ticket."
    tasks:
      - "Document the runbook for on-call"
      - "Define the SLO + alert + escalation chain"
      - "Schedule the next review cycle"
    methodologies:
      - slug: rag-eval-test-set-generation
        path: geek/ai/rag-engineer/rag-eval-test-set-generation
        required: true
        tier_gate: geek
      - slug: reranking-pipeline-integration
        path: geek/ai/rag-engineer/reranking-pipeline-integration
        required: true
        tier_gate: geek
      - slug: reranking-two-stage
        path: geek/ai/rag-engineer/reranking-two-stage
        required: true
        tier_gate: geek
      - slug: vector-database-setup
        path: geek/ai/rag-engineer/vector-database-setup
        required: true
        tier_gate: geek
    outputs:
      - "Runbook + on-call notes"
      - "SLO + alert config in source control"
    decision_gate: |
      Advance when on-call can resolve the top-3 likely incidents without the original author.
  - name: "Review"
    intent: "Close the loop with a written retro and clear next-cycle bets."
    tasks:
      - "Compile evidence trail + metrics from rollout"
      - "Write retro: what worked, what didn't, what we are changing"
      - "Decide explicit continue / iterate / kill for the next cycle"
    methodologies:
      - slug: model-routing-cheap-vs-strong
        path: geek/_gaps/model-routing-cheap-vs-strong
        required: false
        tier_gate: geek
      - slug: prompt-caching-strategy
