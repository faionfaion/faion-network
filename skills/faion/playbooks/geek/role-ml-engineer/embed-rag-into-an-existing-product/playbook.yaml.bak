        path: geek/_gaps/rag-hybrid-search-bm25-vector
        required: false
        tier_gate: geek
      - slug: rag-reranking
        path: geek/_gaps/rag-reranking
        required: false
        tier_gate: geek
      - slug: retrieval-evaluation-ragas
        path: geek/_gaps/retrieval-evaluation-ragas
        required: false
        tier_gate: geek
    outputs:
      - "Retro doc with evidence"
      - "Continue / iterate / kill decision for next cycle"
    decision_gate: |
