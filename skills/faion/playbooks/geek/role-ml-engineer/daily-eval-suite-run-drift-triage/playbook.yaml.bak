    expected_tier: geek
    blocks_stage: 1
    note: "Methodology stub referenced by daily-eval-suite-run-drift-triage; author under knowledge/geek/..."
  - methodology_slug: model-eval-control-bands
    expected_tier: geek
    blocks_stage: 1
    note: "Methodology stub referenced by daily-eval-suite-run-drift-triage; author under knowledge/geek/..."
