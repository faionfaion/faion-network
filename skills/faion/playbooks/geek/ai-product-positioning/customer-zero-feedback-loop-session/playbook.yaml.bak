# =============================================================================
# faion playbook manifest — P7 llm-agent-developer
# Generated for F-064 from playbook-index.json entry #14
# =============================================================================

slug: customer-zero-feedback-loop-session
title: "Customer-zero feedback loop session"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: e7861b478b76d6f8

tier_min: geek
complexity: light
context: [team]
persona_hints: [P7]

intent: |
  30-90 min with one design partner → N failure modes captured, turned into eval rows + roadmap items before session ends.

scope: |
  30-90 min sit with one design-partner customer, capture failure modes from their last week, turn N of them into eval rows + roadmap items before the session ends.

non_goals:
  - "Generic discovery interviewing — see solo playbooks"
  - "Pricing conversations"

prerequisites:
  - "A signed design-partner customer"
  - "Eval harness reachable"

success_criteria:
  - "≥5 failure modes captured verbatim"
  - "Each turned into an eval row or roadmap item"
  - "Trust signal: customer leaves with a citation back to the source"

stages:
  - name: "Listen"
    intent: "Capture failure modes from last week."
    tasks:
      - "Walk last 5 production trajectories together"
      - "Ask 'what did you expect vs what happened'"
    methodologies:
      - slug: trajectory-eval-otel
        path: geek/ai/ai-agents/trajectory-eval-otel
        required: true
        tier_gate: geek
      - slug: llm-observability
        path: geek/ai/ml-engineer/llm-observability
        required: true
        tier_gate: geek
    outputs:
      - "Verbatim failure list"
    decision_gate: |
      Advance only when at least 3 concrete failures captured.
  - name: "Convert"
    intent: "Verbatim → eval row + roadmap entry."
    tasks:
      - "Add eval row per failure"
      - "Score with judge rubric"
      - "Add roadmap entry if needed"
    methodologies:
      - slug: llm-judge-rubric-evidence-first
        path: geek/ai/ai-agents/llm-judge-rubric-evidence-first
        required: true
        tier_gate: geek
      - slug: evaluation-framework
        path: geek/ai/ml-ops/evaluation-framework
        required: true
        tier_gate: geek
      - slug: rag-eval-production-monitoring
        path: geek/ai/rag-engineer/rag-eval-production-monitoring
        required: true
        tier_gate: geek
    outputs:
      - "New eval rows committed"
    decision_gate: |
      Advance only after each failure is mapped to an artefact.
  - name: "Close Loop"
    intent: "Show customer the eval rows landed."
    tasks:
      - "Send commit hashes"
      - "Schedule next session"
    methodologies:
      []
    outputs:
      - "Customer follow-up note"
    decision_gate: |
      Close session only when customer sees their citation back to source.

common_pitfalls:
  - "Treating eval scores as ground truth without judge calibration"
  - "Shipping prompt or model changes without a regression gate"

quality_checklist:
  - "Can I roll back this change in one step?"
  - "Is the regression eval committed BEFORE the fix?"

related_playbooks:
  - eval-harness-continuous-benchmark-suite
  - agent-observability-drift-detection-rollout

token_budget_estimate: 4000
cli_invocations:
  human:  "faion get-content customer-zero-feedback-loop-session --format md"
  agent:  "faion get-content customer-zero-feedback-loop-session --format context"
  json:   "faion get-content customer-zero-feedback-loop-session --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P7 llm-agent-developer persona"

gaps:
  - methodology_slug: design-partner-session-template
    expected_tier: geek
    blocks_stage: 1
    note: "Gap from brainstorm-2026-05-17: design-partner-session-template required by playbook chain"
  - methodology_slug: verbatim-to-eval-row-recipe
    expected_tier: geek
    blocks_stage: 1
    note: "Gap from brainstorm-2026-05-17: verbatim-to-eval-row-recipe required by playbook chain"
