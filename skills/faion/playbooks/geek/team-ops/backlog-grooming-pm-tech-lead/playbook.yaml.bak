# =============================================================================
# faion playbook manifest — P6 product-dev team
# Generated for F-064 from playbook-index.json p6-product-dev-team entry 11
# =============================================================================

slug: backlog-grooming-pm-tech-lead
title: "Backlog grooming with PM + tech lead (weekly)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: a2c48ebe4f04761c

tier_min: geek
complexity: medium
context: [team]
persona_hints: [P6]

intent: |
  Open backlog of mixed maturity → top-of-backlog spec-ready (AC + complexity tag) each week in 1 hour.

scope: |
  Weekly 1-hour grooming session: PM brings business priorities, tech lead brings tech-debt + capacity reality. Goal: only the top of the backlog is spec-ready (acceptance criteria + estimated complexity), everything else stays untouched. AI agent splits oversized items into sub-tasks. Tech-debt has a fixed slot quota per cycle. Session ends with a written grooming-decisions log.

non_goals:
  - "Sprint planning — see sprint-planning-sdd-task-expansion"
  - "Quarter-level prioritisation — see quarter-planning-okr-reset"
  - "Day-to-day triage — see daily-standup-ai-prebrief"

prerequisites:
  - "Backlog exists with at least 10 items beyond current sprint"
  - "Tech-debt register tagged in tracker"
  - "AI agent able to propose task splits from spec"

success_criteria:
  - "Top of backlog spec-ready (AC + complexity tag)"
  - "Oversized items split"
  - "Tech-debt slot quota respected"
  - "Grooming-decisions log appended"

stages:
  - name: "Walk the backlog"
    intent: "Cover top-N items; classify maturity."
    tasks:
      - "PM brings prioritised list"
      - "Tech lead overlays capacity reality"
      - "Tag each item: spec-ready / needs-AC / oversized / on-hold"
    methodologies:
      - slug: backlog-management
        path: solo/product/product-operations/backlog-management
        required: true
        tier_gate: solo
      - slug: backlog-grooming-roadmapping
        path: solo/sdd/sdd-planning/backlog-grooming-roadmapping
        required: true
        tier_gate: solo
      - slug: backlog-grooming-roadmapping-sdd
        path: solo/sdd/sdd/backlog-grooming-roadmapping
        required: true
        tier_gate: solo
    outputs:
      - "Backlog walked with maturity tags"
    decision_gate: |
      Advance once every top-N item has a maturity tag. Don't groom below the line — that's pretend-work.

  - name: "Make spec-ready"
    intent: "Top-of-backlog items become spec-ready: AC + complexity tag."
    tasks:
      - "Add acceptance criteria per item"
      - "Apply user-story-mapping where relevant"
      - "Split oversized items via task-creation-principles"
      - "Apply impl-plan-100k-rule (do not exceed)"
    methodologies:
      - slug: acceptance-criteria
        path: pro/ba/business-analyst/acceptance-criteria
        required: true
        tier_gate: pro
      - slug: user-story-mapping
        path: pro/ba/business-analyst/user-story-mapping
        required: true
        tier_gate: pro
      - slug: task-creation-principles
        path: solo/sdd/sdd-planning/task-creation-principles
        required: true
        tier_gate: solo
      - slug: impl-plan-100k-rule
        path: solo/sdd/sdd-planning/impl-plan-100k-rule
        required: true
        tier_gate: solo
      - slug: task-creation-parallelization
        path: solo/sdd/sdd/task-creation-parallelization
        required: true
        tier_gate: solo
      - slug: quality-gates-confidence
        path: solo/sdd/sdd/quality-gates-confidence
        required: true
        tier_gate: solo
    outputs:
      - "Spec-ready items at top of backlog"
      - "Split records for oversized items"
    decision_gate: |
      Advance when each spec-ready item has AC + complexity tag. Don't promote anything without both.

  - name: "Balance the slate + log decisions"
    intent: "Honour tech-debt quota; write grooming-decisions log."
    tasks:
      - "Confirm tech-debt slot quota for the coming cycle"
      - "Note any candidate that was demoted + why"
      - "Append decisions log"
    methodologies:
      - slug: tech-debt-management
        path: solo/dev/code-quality/tech-debt-management
        required: true
        tier_gate: solo
    outputs:
      - "Grooming-decisions log"
    decision_gate: |
      Required: written log. Verbal-only grooming guarantees next week's session repeats the same arguments.

common_pitfalls:
  - "Grooming below the line — wastes session on items nobody will pick up"
  - "Tech-debt quota slips — accumulates into a quarter-end crisis"
  - "Oversized items left whole — sprint planning blocks on them"
  - "Decisions stay verbal — same debates repeat weekly"

quality_checklist:
  - "Can a dev claim the top item and start without re-asking what 'done' means?"
  - "Did we close at least one tech-debt slot this week?"
  - "Did the session end in 1 hour?"

related_playbooks:
  - quarter-planning-okr-reset
  - sprint-planning-sdd-task-expansion
  - daily-standup-ai-prebrief

token_budget_estimate: 12000
cli_invocations:
  human:  "faion get-content backlog-grooming-pm-tech-lead --format md"
  agent:  "faion get-content backlog-grooming-pm-tech-lead --format context"
  json:   "faion get-content backlog-grooming-pm-tech-lead --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P6 product-dev team persona"

gaps:
  - methodology_slug: pm-tech-lead-grooming-agenda
    expected_tier: geek
    blocks_stage: 1
    note: "Walk-the-backlog stage needs a fixed weekly agenda template"
  - methodology_slug: tech-debt-slot-quota-policy
    expected_tier: geek
    blocks_stage: 3
    note: "Balance stage needs a written tech-debt slot quota policy so it's not negotiated weekly"
