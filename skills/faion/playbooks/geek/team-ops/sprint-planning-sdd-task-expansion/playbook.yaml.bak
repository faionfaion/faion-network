# =============================================================================
# faion playbook manifest — P6 product-dev team
# Generated for F-064 from playbook-index.json p6-product-dev-team entry 12
# =============================================================================

slug: sprint-planning-sdd-task-expansion
title: "Sprint planning with SDD task expansion (bi-weekly)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 0258919768570b34

tier_min: geek
complexity: deep
context: [team]
persona_hints: [P6]

intent: |
  Spec-ready stories → SDD feature folders with spec.md + design.md + implementation-plan.md broken into TASK_*.md files.

scope: |
  Bi-weekly sprint planning. Spec-ready stories that came out of grooming become SDD feature folders under `.aidocs/in-progress/<feature>/`: spec.md + design.md (where complexity demands) + implementation-plan.md broken into TASK_*.md files in `tasks/todo/`. Capacity is decided from team velocity and complexity tags — token estimates only, no time estimates. The tracker mirrors the SDD layout.

non_goals:
  - "Spec/design authoring from scratch — see rfc-to-production-feature-delivery"
  - "Daily execution — see daily-standup-ai-prebrief"
  - "Quarterly OKR setting — see quarter-planning-okr-reset"

prerequisites:
  - "Backlog grooming completed in the same week"
  - "SDD feature directory layout convention adopted (backlog → todo → in-progress → done)"
  - "Token-budget heuristic agreed by team"

success_criteria:
  - "Each selected story has spec.md + (where needed) design.md"
  - "implementation-plan.md broken into TASK_*.md files in tasks/todo/"
  - "Capacity confirmed from velocity + complexity tags"
  - "Promotion-gate checklist signed off per feature"
  - "Tracker mirrors the SDD folder layout"

stages:
  - name: "Promote spec-ready stories"
    intent: "Stories chosen from backlog get promoted into SDD feature folders."
    tasks:
      - "Pick top-N from spec-ready backlog"
      - "Initialise feature folder under backlog/ or todo/ per promotion gate"
      - "Apply task-spec-kit three-step"
      - "Confirm Definition of Ready"
    methodologies:
      - slug: task-spec-kit-three-step
        path: geek/sdlc-ai/task-spec-kit-three-step
        required: true
        tier_gate: geek
      - slug: task-agent-drafts-spec-before-coding
        path: geek/sdlc-ai/task-agent-drafts-spec-before-coding
        required: true
        tier_gate: geek
      - slug: template-spec
        path: solo/sdd/sdd-planning/template-spec
        required: true
        tier_gate: solo
      - slug: writing-specifications
        path: solo/sdd/sdd/writing-specifications
        required: true
        tier_gate: solo
    outputs:
      - "Initial feature folders with spec.md drafts"
    decision_gate: |
      Advance once each promoted story has a spec.md and passes DoR. No promotion without it.

  - name: "Design where needed"
    intent: "Features touching cross-service boundaries get a design.md."
    tasks:
      - "Identify which features need design.md"
      - "Author design.md using template-design"
      - "Reference patterns + decisions"
    methodologies:
      - slug: template-design
        path: solo/sdd/sdd-planning/template-design
        required: true
        tier_gate: solo
      - slug: writing-design-documents
        path: solo/sdd/sdd/writing-design-documents
        required: true
        tier_gate: solo
    outputs:
      - "design.md per feature that needs it"
    decision_gate: |
      Advance when every cross-service feature has a design.md AND every isolated feature has an explicit waiver in the spec.

  - name: "Expand to tasks"
    intent: "implementation-plan.md becomes TASK_*.md files in `tasks/todo/`."
    tasks:
      - "Author implementation-plan.md"
      - "Apply impl-plan-100k-rule"
      - "Materialise tasks/todo/TASK_NN.md files"
      - "Apply task-creation-parallelization where it pays off"
      - "Tracker mirror with linear-agent-as-assignee"
    methodologies:
      - slug: template-task
        path: solo/sdd/sdd-planning/template-task
        required: true
        tier_gate: solo
      - slug: writing-implementation-plans
        path: solo/sdd/sdd/writing-implementation-plans
        required: true
        tier_gate: solo
      - slug: impl-plan-100k-rule
        path: solo/sdd/sdd-planning/impl-plan-100k-rule
        required: true
        tier_gate: solo
      - slug: task-creation-parallelization
        path: solo/sdd/sdd/task-creation-parallelization
        required: true
        tier_gate: solo
      - slug: tracker-linear-agent-as-assignee
        path: geek/sdlc-ai/tracker-linear-agent-as-assignee
        required: true
        tier_gate: geek
    outputs:
      - "TASK_*.md files under tasks/todo/"
      - "Tracker mirror updated"
    decision_gate: |
      Advance once every promoted feature has a tasks/todo/ tree with self-contained task files.

  - name: "Decide capacity + commit"
    intent: "Velocity + complexity tags fit inside confirmed capacity; sprint commit posted."
    tasks:
      - "Pull last 2 sprints' velocity"
      - "Map sized tasks to confirmed capacity"
      - "Use predictive-analytics-pm to sanity-check"
      - "RACI per feature"
      - "Apply scrum-ceremonies sprint planning cadence"
      - "Apply value-stream-management lens"
      - "Post sprint commit"
    methodologies:
      - slug: predictive-analytics-pm
        path: pro/pm/pm-agile/predictive-analytics-pm
        required: true
        tier_gate: pro
      - slug: raci-matrix
        path: pro/pm/pm-agile/raci-matrix
        required: true
        tier_gate: pro
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
      - slug: value-stream-management
        path: pro/pm/pm-agile/value-stream-management
        required: true
        tier_gate: pro
    outputs:
      - "Sprint commit doc"
      - "RACI per feature"
    decision_gate: |
      Required: sprint commit signed off. Overcommitting at this gate = guaranteed mid-sprint scope cut.

common_pitfalls:
  - "Promoting stories without spec.md — task files become guesswork"
  - "Time estimates sneaking in — violates the No-Time-Estimates rule"
  - "Skipping design.md on a cross-service feature — bites at QA stage"
  - "Tracker drifts from SDD layout — devs lose source of truth"

quality_checklist:
  - "Does every task have a self-contained TASK_*.md?"
  - "Is the sprint commit reachable given last 2 sprints' velocity?"
  - "Does each spec.md pass the DoR checklist?"

related_playbooks:
  - backlog-grooming-pm-tech-lead
  - rfc-to-production-feature-delivery
  - quarter-planning-okr-reset

token_budget_estimate: 17000
cli_invocations:
  human:  "faion get-content sprint-planning-sdd-task-expansion --format md"
  agent:  "faion get-content sprint-planning-sdd-task-expansion --format context"
  json:   "faion get-content sprint-planning-sdd-task-expansion --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P6 product-dev team persona"

gaps:
  - methodology_slug: sprint-capacity-from-complexity-tags
    expected_tier: geek
    blocks_stage: 4
    note: "Capacity stage needs an explicit method to translate complexity tags into capacity without time estimates"
  - methodology_slug: sdd-promotion-gate-checklist
    expected_tier: geek
    blocks_stage: 1
    note: "Promote stage needs the canonical backlog → todo promotion checklist"
