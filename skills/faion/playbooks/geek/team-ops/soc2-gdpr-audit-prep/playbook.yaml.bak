slug: soc2-gdpr-audit-prep
title: "SOC2 / GDPR audit prep (annual)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: c5cdd9a8a62e5f70

tier_min: geek
complexity: deep
context: [team]
persona_hints: [P6]

intent: |
  Approaching audit window → control evidence current, gaps closed, walkthrough rehearsed, every exception logged with owner + date.

scope: |
  Annual SOC2 / GDPR audit deadline approaches. The team brings each required control to current state: every artifact is tagged in the repo, every secret has a verified custodian, the supply chain is provably scanned, and the auditor walkthrough is scripted and rehearsed. Exceptions are logged with remediation owners and dates. Output is an audit binder ready to ship.

non_goals:
  - "Choosing the auditor / commercial procurement — handled by Legal/Finance"
  - "EU AI Act / sector-specific compliance beyond SOC2 + GDPR — covered separately"
  - "Initial certification — assumes recurring-audit cadence; first-time audits add scope"

prerequisites:
  - "Last year's audit report + remediation list"
  - "List of in-scope systems documented"
  - "Approval-token signed-JWT in place for privileged operations"
  - "Renovate/Trivy + SBOM tooling wired"

success_criteria:
  - "Control-to-artifact map exists and resolves for every control"
  - "Secrets inventory current with named custodian per secret"
  - "Supply-chain scan green within last 30 days"
  - "Walkthrough rehearsal completed end-to-end"
  - "Open exceptions logged with owner + remediation date"
  - "Vendor risk assessment current for all in-scope vendors"

stages:
  - name: "Inventory + gap analysis"
    intent: "Map controls to repo artifacts; find gaps."
    tasks:
      - "Pull current vs gap-analysis vs target via strategy-analysis docs"
      - "Inventory systems, data flows, vendors"
      - "Run process-mining where automation gates exist"
      - "Score each control as green / yellow / red"
    methodologies:
      - slug: strategy-analysis-current-state
        path: pro/ba/business-analyst/strategy-analysis-current-state
        required: true
        tier_gate: pro
      - slug: strategy-analysis-gap-analysis
        path: pro/ba/business-analyst/strategy-analysis-gap-analysis
        required: true
        tier_gate: pro
      - slug: data-analysis
        path: pro/ba/business-analyst/data-analysis
        required: true
        tier_gate: pro
      - slug: interface-analysis
        path: pro/ba/business-analyst/interface-analysis
        required: true
        tier_gate: pro
      - slug: process-mining-automation
        path: pro/ba/business-analyst/process-mining-automation
        required: true
        tier_gate: pro
      - slug: stakeholder-register
        path: pro/pm/pm-traditional/stakeholder-register
        required: true
        tier_gate: pro
    outputs:
      - "Control-to-artifact map"
      - "Gap heatmap"
    decision_gate: |
      Advance when every control has either a green status or a documented gap with owner.

  - name: "Close gaps + supply chain"
    intent: "Trivy / CodeQL / container / IaC scans + license compliance run + remediated."
    tasks:
      - "Run sec-trivy-pinned-supply-chain-scan"
      - "Run sec-codeql-autofix-on-pr on backlog"
      - "Verify backups + DR drill"
      - "Walk container + supply-chain scans"
      - "Confirm license compliance"
    methodologies:
      - slug: sec-trivy-pinned-supply-chain-scan
        path: geek/sdlc-ai/sec-trivy-pinned-supply-chain-scan
        required: true
        tier_gate: geek
      - slug: sec-secrets-defense-in-depth
        path: geek/sdlc-ai/sec-secrets-defense-in-depth
        required: true
        tier_gate: geek
      - slug: gov-license-compliance-scan
        path: geek/sdlc-ai/gov-license-compliance-scan
        required: true
        tier_gate: geek
      - slug: secrets-management
        path: pro/infra/cicd-engineer/secrets-management
        required: true
        tier_gate: pro
      - slug: security-container-scanning
        path: pro/infra/cicd-engineer/security-container-scanning
        required: true
        tier_gate: pro
      - slug: security-supply-chain
        path: pro/infra/cicd-engineer/security-supply-chain
        required: true
        tier_gate: pro
      - slug: security-policy-as-code
        path: pro/infra/cicd-engineer/security-policy-as-code
        required: true
        tier_gate: pro
      - slug: backup-verification-dr
        path: pro/infra/cicd-engineer/backup-verification-dr
        required: true
        tier_gate: pro
    outputs:
      - "Green supply-chain scan report"
      - "Verified backup-restore evidence"
    decision_gate: |
      Advance when scan output is green within 30 days and all P0 supply-chain risks have remediation owners.

  - name: "Process + governance evidence"
    intent: "Approval-token JWT + conventional-commits + AI code gate trail = auditable engineering controls."
    tasks:
      - "Verify approval-token JWT flow on privileged ops"
      - "Confirm conventional-commits enforcement is on"
      - "Pull SonarQube AI code-gate evidence"
      - "Walk EU AI Act compliance applicability"
    methodologies:
      - slug: gov-approval-token-signed-jwt
        path: geek/sdlc-ai/gov-approval-token-signed-jwt
        required: true
        tier_gate: geek
      - slug: gov-conventional-commits-enforced
        path: geek/sdlc-ai/gov-conventional-commits-enforced
        required: true
        tier_gate: geek
      - slug: gov-sonarqube-ai-code-gate
        path: geek/sdlc-ai/gov-sonarqube-ai-code-gate
        required: true
        tier_gate: geek
      - slug: eu-ai-act-compliance
        path: geek/ai/ai-agents/eu-ai-act-compliance
        required: false
        tier_gate: geek
      - slug: quality-management
        path: pro/pm/pm-traditional/quality-management
        required: true
        tier_gate: pro
      - slug: procurement-management
        path: pro/pm/pm-traditional/procurement-management
        required: true
        tier_gate: pro
    outputs:
      - "Approval-token JWT trail"
      - "Conventional-commits + code-gate evidence"
    decision_gate: |
      Advance when every privileged action has a JWT trail and there are no untagged commits on protected branches.

  - name: "Walkthrough + exception ledger"
    intent: "Rehearse the auditor walkthrough; log exceptions with owners + dates."
    tasks:
      - "Script the walkthrough end-to-end"
      - "Rehearse with internal stakeholders"
      - "Refresh risk register"
      - "Close out outstanding lessons-learned"
      - "Project-closure-style sign-off"
    methodologies:
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
      - slug: change-control
        path: pro/pm/pm-traditional/change-control
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement-advanced
        path: pro/pm/project-manager/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
      - slug: stakeholder-register
        path: pro/pm/pm-traditional/stakeholder-register
        required: true
        tier_gate: pro
      - slug: risk-register
        path: pro/pm/pm-traditional/risk-register
        required: true
        tier_gate: pro
      - slug: lessons-learned
        path: pro/pm/pm-traditional/lessons-learned
        required: true
        tier_gate: pro
      - slug: project-closure
        path: pro/pm/pm-traditional/project-closure
        required: true
        tier_gate: pro
      - slug: benefits-realization
        path: pro/pm/pm-traditional/benefits-realization
        required: true
        tier_gate: pro
    outputs:
      - "Walkthrough script"
      - "Exception ledger"
    decision_gate: |
      Required output: rehearsed walkthrough + signed exception ledger. No 'we'll wing it'.

common_pitfalls:
  - "Discovering gaps two weeks before the audit — stress + cut corners"
  - "Exception ledger without remediation dates — auditor flags as evergreen"
  - "Walkthrough rehearsed only on slides, not against the live repo"
  - "Vendor risk assessment skipped on 'small' SaaS — auditors find them anyway"

quality_checklist:
  - "Can I point at the repo artifact for every required control in <30 seconds?"
  - "Do all secrets have named custodians who would answer a midnight page?"
  - "Did we rehearse the walkthrough against the actual repo state?"

related_playbooks:
  - incident-postmortem-preventive-backlog
  - security-review-new-dependency
  - rfc-to-production-feature-delivery

token_budget_estimate: 26000
