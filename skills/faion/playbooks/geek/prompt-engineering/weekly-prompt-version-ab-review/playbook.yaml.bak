# =============================================================================
# faion playbook manifest — P7 llm-agent-developer
# Generated for F-064 from playbook-index.json entry #7
# =============================================================================

slug: weekly-prompt-version-ab-review
title: "Weekly prompt-version A/B review"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: f93495ffa8eceaed

tier_min: geek
complexity: medium
context: [team]
persona_hints: [P7]

intent: |
  Last week's prompt-version candidates → one merged, one rolled-back, one parked.

scope: |
  Decide which of last week's prompt-version candidates graduates to default. Output: one merged PR, one rolled-back PR, one parked. Weekly cadence, ~60-90 min.

non_goals:
  - "Model-version A/Bs — covered by `bench-against-new-sota-model`"
  - "End-to-end UX A/Bs"

prerequisites:
  - "A/B fixture from eval-harness playbook"
  - "≥2 prompt candidates with at least 100 traces each"

success_criteria:
  - "Each candidate scored on judge + cost"
  - "Decision per candidate (merge/rollback/park)"
  - "Pinned prompt version manifest updated"

stages:
  - name: "Pull A/B Results"
    intent: "Collect last week's A/B traces per candidate."
    tasks:
      - "Pull traces grouped by prompt version"
      - "Confirm prompt-cache prefix order didn't change"
    methodologies:
      - slug: schema-version-pinning
        path: geek/ai/ai-agents/schema-version-pinning
        required: true
        tier_gate: geek
      - slug: prompt-cache-prefix-order
        path: geek/ai/ai-agents/prompt-cache-prefix-order
        required: true
        tier_gate: geek
      - slug: rag-eval-ab-testing
        path: geek/ai/rag-engineer/rag-eval-ab-testing
        required: true
        tier_gate: geek
    outputs:
      - "A/B trace bundle"
    decision_gate: |
      Advance when each candidate has enough traces for power.
  - name: "Judge & Compare"
    intent: "Run judges, compare against control."
    tasks:
      - "Run rubric judge"
      - "Two-pass reason-then-extract scoring"
      - "Score cost + quality delta"
    methodologies:
      - slug: llm-judge-rubric-evidence-first
        path: geek/ai/ai-agents/llm-judge-rubric-evidence-first
        required: true
        tier_gate: geek
      - slug: two-pass-reason-then-extract
        path: geek/ai/ai-agents/two-pass-reason-then-extract
        required: true
        tier_gate: geek
      - slug: prompt-engineering-evaluation
        path: geek/ai/ml-engineer/prompt-engineering-evaluation
        required: true
        tier_gate: geek
      - slug: prompt-engineering-production
        path: geek/ai/ml-engineer/prompt-engineering-production
        required: true
        tier_gate: geek
    outputs:
      - "Comparison table"
    decision_gate: |
      Advance only when delta is statistically credible.
  - name: "Land Decisions"
    intent: "Three PRs: merge, rollback, park."
    tasks:
      - "Merge the winner with version pin"
      - "Rollback the loser"
      - "Park the inconclusive with calendar reminder"
    methodologies:
      []
    outputs:
      - "Merged PR"
      - "Rollback PR"
      - "Parked tracking issue"
    decision_gate: |
      Ship only after pin manifest is updated.

common_pitfalls:
  - "Treating eval scores as ground truth without judge calibration"
  - "Shipping prompt or model changes without a regression gate"

quality_checklist:
  - "Can I roll back this change in one step?"
  - "Is the regression eval committed BEFORE the fix?"

related_playbooks:
  - eval-harness-continuous-benchmark-suite
  - agent-observability-drift-detection-rollout

token_budget_estimate: 9000
cli_invocations:
  human:  "faion get-content weekly-prompt-version-ab-review --format md"
  agent:  "faion get-content weekly-prompt-version-ab-review --format context"
  json:   "faion get-content weekly-prompt-version-ab-review --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P7 llm-agent-developer persona"

gaps:
