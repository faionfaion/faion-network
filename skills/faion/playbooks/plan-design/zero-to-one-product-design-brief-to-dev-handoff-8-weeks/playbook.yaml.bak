slug: zero-to-one-product-design-brief-to-dev-handoff-8-weeks
title: "Zero-to-one product design: brief to dev handoff (8 weeks)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 7cfcf2fa4f7b09d8

tier: pro
tier_min: pro
group: role-ux-ui-designer
persona: Product designer leading a greenfield product or major new module
complexity: deep
context: [solo, team]

summary: |
  Greenfield product taken from problem brief to validated hi-fi prototype, design tokens wired, dev handoff package shipped, first build sprint supported.

intent: |
  Brief on a blank canvas -> validated hi-fi prototype + shipped dev handoff package + first sprint supported.

scope: |
  Product designer takes a greenfield product or new module across 8 weeks. Covers discovery, IA, wireframes, hi-fi, design tokens, a11y baseline, handoff package, and first-sprint support. Done when engineering is in build, the handoff package answers their questions, and at least one design QA pass has run.

success_criteria:
  - "Validated hi-fi prototype with >=3 user-testing sessions completed"
  - "Design tokens wired to the build (W3C-compliant)"
  - "A11y baseline meets WCAG 2.2 AA on flagship flows"
  - "Dev handoff package shipped: spec, tokens, motion, edge cases"
  - "First sprint of build supported with at least one design QA pass"

methodology_refs:
  - faion/knowledge/geek/ux/ui-designer/ai-design-assistant-patterns
  - faion/knowledge/geek/ux/ui-designer/generative-ui-design
  - faion/knowledge/pro/ux/accessibility-specialist/accessibility-first-design
  - faion/knowledge/pro/ux/accessibility-specialist/wcag-22-compliance
  - faion/knowledge/pro/ux/ui-designer/cross-platform-token-distribution
  - faion/knowledge/pro/ux/ui-designer/design-system-success-factors
  - faion/knowledge/pro/ux/ui-designer/semantic-tokens-and-modes
  - faion/knowledge/pro/ux/ui-designer/w3c-design-tokens-standard
  - faion/knowledge/solo/ux/ui-designer/design-tokens-fundamentals
  - faion/knowledge/solo/ux/ui-designer/prototyping
  - faion/knowledge/solo/ux/ui-designer/wireframing
  - faion/knowledge/solo/ux/user-researcher/jobs-to-be-done
  - faion/knowledge/solo/ux/user-researcher/problem-validation-2026
  - faion/knowledge/solo/ux/user-researcher/success-metrics-definition
  - faion/knowledge/solo/ux/user-researcher/value-proposition-design
  - faion/knowledge/solo/ux/ux-ui-designer/ab-testing
  - faion/knowledge/solo/ux/ux-ui-designer/card-sorting
  - faion/knowledge/solo/ux/ux-ui-designer/design-critique
  - faion/knowledge/solo/ux/ux-ui-designer/heuristic-evaluation
  - faion/knowledge/solo/ux/ux-ui-designer/information-architecture
  - faion/knowledge/solo/ux/ux-ui-designer/journey-mapping
  - faion/knowledge/solo/ux/ux-ui-designer/usability-testing

stages:
  - name: "Problem framing"
    intent: "Convert the brief into a problem worth solving."
    tasks:
      - "Run JTBD interviews to validate the problem"
      - "Define success metrics for the product"
      - "Capture value proposition + non-goals"
    methodologies:
      - slug: jobs-to-be-done
        path: solo/ux/user-researcher/jobs-to-be-done
        required: true
        tier_gate: solo
      - slug: problem-validation-2026
        path: solo/ux/user-researcher/problem-validation-2026
        required: true
        tier_gate: solo
      - slug: value-proposition-design
        path: solo/ux/user-researcher/value-proposition-design
        required: true
        tier_gate: solo
      - slug: success-metrics-definition
        path: solo/ux/user-researcher/success-metrics-definition
        required: true
        tier_gate: solo
    outputs:
      - "Problem brief + JTBD canvas + metrics"
    decision_gate: |
      Advance only if the problem is articulated as a JTBD with measurable success.
  - name: "IA + journeys"
    intent: "Map the spine before drawing pixels."
    tasks:
      - "Card-sort to validate IA"
      - "Sketch primary user journeys"
      - "Identify flagship flows for hi-fi investment"
    methodologies:
      - slug: card-sorting
        path: solo/ux/ux-ui-designer/card-sorting
        required: true
        tier_gate: solo
      - slug: information-architecture
        path: solo/ux/ux-ui-designer/information-architecture
        required: true
        tier_gate: solo
      - slug: journey-mapping
        path: solo/ux/ux-ui-designer/journey-mapping
        required: true
        tier_gate: solo
    outputs:
      - "IA map + journey set + flagship-flow shortlist"
    decision_gate: |
      Advance when IA tests >=80% findability and flagship flows are agreed.
  - name: "Wireframes + heuristics"
    intent: "Low-fi structure before high-fi polish."
    tasks:
      - "Wireframe flagship flows"
      - "Self-run heuristic evaluation"
      - "Critique session with peers"
    methodologies:
      - slug: wireframing
        path: solo/ux/ui-designer/wireframing
        required: true
        tier_gate: solo
      - slug: heuristic-evaluation
        path: solo/ux/ux-ui-designer/heuristic-evaluation
        required: true
        tier_gate: solo
      - slug: design-critique
        path: solo/ux/ux-ui-designer/design-critique
        required: true
        tier_gate: solo
    outputs:
      - "Wireframes + heuristic issue list resolved"
    decision_gate: |
      Advance only when heuristic issues are fixed or accepted.
  - name: "Design tokens + a11y baseline"
    intent: "Wire the visual system before hi-fi sprawl."
    tasks:
      - "Pick design-token taxonomy (W3C-compliant)"
      - "Define semantic tokens + light/dark modes"
      - "Bake a11y baseline (contrast, focus, semantics) into tokens"
    methodologies:
      - slug: design-tokens-fundamentals
        path: solo/ux/ui-designer/design-tokens-fundamentals
        required: true
        tier_gate: solo
      - slug: semantic-tokens-and-modes
        path: pro/ux/ui-designer/semantic-tokens-and-modes
        required: true
        tier_gate: pro
      - slug: w3c-design-tokens-standard
        path: pro/ux/ui-designer/w3c-design-tokens-standard
        required: true
        tier_gate: pro
      - slug: cross-platform-token-distribution
        path: pro/ux/ui-designer/cross-platform-token-distribution
        required: true
        tier_gate: pro
      - slug: accessibility-first-design
        path: pro/ux/accessibility-specialist/accessibility-first-design
        required: true
        tier_gate: pro
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
    outputs:
      - "Token set distributed + a11y baseline documented"
    decision_gate: |
      Advance only when tokens build clean to code targets and a11y checklist passes.
  - name: "Hi-fi prototype"
    intent: "Pixel-true prototype on flagship flows."
    tasks:
      - "Build hi-fi screens with tokens applied"
      - "Wire interactive prototype"
      - "Use AI design-assist patterns to accelerate variants"
    methodologies:
      - slug: prototyping
        path: solo/ux/ui-designer/prototyping
        required: true
        tier_gate: solo
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
      - slug: ai-design-assistant-patterns
        path: geek/ux/ui-designer/ai-design-assistant-patterns
        required: true
        tier_gate: geek
      - slug: generative-ui-design
        path: geek/ux/ui-designer/generative-ui-design
        required: true
        tier_gate: geek
    outputs:
      - "Interactive hi-fi prototype"
    decision_gate: |
      Advance when prototype walks through flagship flows without dead ends.
  - name: "Validate"
    intent: "Real users, real tasks, real signal."
    tasks:
      - "Run >=3 usability sessions"
      - "Run quick A/B on a contested decision"
      - "Capture severity-ranked findings"
    methodologies:
      - slug: usability-testing
        path: solo/ux/ux-ui-designer/usability-testing
        required: true
        tier_gate: solo
      - slug: ab-testing
        path: solo/ux/ux-ui-designer/ab-testing
        required: true
        tier_gate: solo
    outputs:
      - "Validation report + issue list"
    decision_gate: |
      Advance only when critical issues are fixed.
  - name: "Handoff package"
    intent: "Engineering can build without re-asking."
    tasks:
      - "Compile spec: states, tokens, motion, a11y, edge cases"
      - "Annotate Figma <-> code mappings"
      - "Run a handoff review with engineering"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
      - slug: cross-platform-token-distribution
        path: pro/ux/ui-designer/cross-platform-token-distribution
        required: true
        tier_gate: pro
      - slug: accessibility-first-design
        path: pro/ux/accessibility-specialist/accessibility-first-design
        required: true
        tier_gate: pro
    outputs:
      - "Handoff package + signed-off review"
    decision_gate: |
      Advance only when engineering signs off on the package.
  - name: "First sprint support"
    intent: "Stay close during the first build sprint."
    tasks:
      - "Run a daily design-QA pass on PRs"
      - "Resolve open questions in <24h"
      - "Log learnings for next-cycle handoff template"
    methodologies:
      - slug: design-critique
        path: solo/ux/ux-ui-designer/design-critique
        required: true
        tier_gate: solo
      - slug: wcag-22-compliance
        path: pro/ux/accessibility-specialist/wcag-22-compliance
        required: true
        tier_gate: pro
    outputs:
      - "First-sprint QA log + learnings doc"
    decision_gate: |
      Done when sprint ends with >=80% design fidelity on flagship flows.

common_pitfalls:
  - "Skipping JTBD discovery -> hi-fi solves the wrong problem"
  - "Tokens added after hi-fi -> rework storm"
  - "Handoff package skips edge cases -> engineering blocked or guessing"

quality_checklist:
  - "Did engineering build without coming back to ask design questions?"
  - "Does the flagship flow pass WCAG 2.2 AA in production?"
  - "Are tokens the single source of truth for visual decisions?"

related_playbooks:
  - design-system-v1-to-v2-migration-12-weeks
  - user-research-sprint-discovery-to-recommendations-4-weeks
  - dev-handoff-doc-writing-per-feature

token_budget_estimate: 11000
cli_invocations:
  human:  "faion get-content zero-to-one-product-design-brief-to-dev-handoff-8-weeks --format md"
  agent:  "faion get-content zero-to-one-product-design-brief-to-dev-handoff-8-weeks --format context"
  json:   "faion get-content zero-to-one-product-design-brief-to-dev-handoff-8-weeks --format json"

