stages:
  - name: "Frame"
    intent: "State the outcome, constraints, and exit-condition in one paragraph."
    tasks:
      - "Read the assigned methodology references and reconcile them with this stage's goal."
      - "Produce the stage artifact named in 'outputs' and store it where the next stage can read it."
      - "Re-check the decision gate before advancing; loop within this stage if it fails."
    methodologies:
      - slug: ba-governance
        path: pro/ba/ba-core/ba-governance
        required: true
        tier_gate: pro
      - slug: requirements-traceability
        path: pro/ba/ba-core/requirements-traceability
        required: true
        tier_gate: pro
      - slug: decision-analysis
        path: pro/ba/ba-modeling/decision-analysis
        required: true
        tier_gate: pro
      - slug: strategy-analysis-change-strategy
        path: pro/ba/business-analyst/strategy-analysis-change-strategy
        required: true
        tier_gate: pro
    outputs:
      - "Written artifact for stage 1 (Frame) named per the project's docs convention"
      - "Decision-gate note (advance / iterate / kill) appended to the playbook log"
    decision_gate: "Advance when the stage 1 artifact exists in writing AND the methodology chain assigned to this stage has been applied. Iterate or escalate otherwise."
  - name: "Discover"
    intent: "Pull the evidence and prior art needed to make informed choices."
    tasks:
