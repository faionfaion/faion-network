# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #1
# =============================================================================

slug: foreign-client-project-kickoff
title: "Foreign-client project kickoff (2 weeks)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: f054b074200ba293

tier_min: pro
complexity: deep
context: [outsource, team]
persona_hints: [P4]

intent: |
  Brand-new engagement with a US/EU/UK/AU client → signed SoW, ratified architecture, RACI + cadence, dev env on client stack, first sprint groomed, and an inception report a senior promotion panel would accept.

scope: |
  Two-week onboarding sprint. By end-of-week-2 the outsource senior owns: signed SoW, validated requirements baseline, architecture skeleton fitting client conventions, RACI + comms cadence, dev environment matching client stack, first sprint backlog groomed, and an inception report sent. Output is reviewer-ready and survives a senior/lead promotion panel.

non_goals:
  - "Long-running discovery — confined to two weeks"
  - "Sales / commercial negotiation — SoW already executed"
  - "Hiring / staffing the squad — vendor PM owns"

prerequisites:
  - "Engagement contract executed (MSA + SoW skeleton)"
  - "Client primary contacts identified and reachable"
  - "Vendor security review passed (laptops, VPN access)"

success_criteria:
  - "Signed SoW with itemised scope and acceptance criteria"
  - "Architecture decision record set covering client-mandated stack"
  - "RACI + comms cadence accepted by client PM in writing"
  - "Dev environment reproducible by a new joiner inside one day"
  - "First sprint backlog groomed and committed by both sides"
  - "Inception report sent, no rework requested by client steerco"

stages:
  - name: "Engagement intake"
    intent: "Inhale every artifact the client already has and surface the gaps in 48h."
    tasks:
      - "Read MSA + SoW skeleton end-to-end, mark every undefined term"
      - "Run stakeholder mapping workshop with client PM + sponsor"
      - "Pull existing architecture diagrams, ADRs, runbooks into a shared dossier"
      - "Audit competitive context for the client product (positioning, peers)"
    methodologies:
      - slug: stakeholder-analysis
        path: pro/ba/ba-core/stakeholder-analysis
        required: true
        tier_gate: pro
      - slug: elicitation-techniques
        path: pro/ba/ba-core/elicitation-techniques
        required: true
        tier_gate: pro
      - slug: stakeholder-register
        path: pro/pm/pm-traditional/stakeholder-register
        required: true
        tier_gate: pro
      - slug: competitive-intelligence
        path: pro/research/researcher/competitive-intelligence
        required: true
        tier_gate: pro
    outputs:
      - "Stakeholder register v1"
      - "Open-questions log with named owner per item"
      - "Existing-artifacts dossier"
    decision_gate: |
      Advance only when ≥80% of client artifacts have been read AND every open question has a named owner with a target answer date. Otherwise extend intake.
  - name: "Scope & SoW lock"
    intent: "Convert SoW skeleton into a defendable scope baseline with acceptance criteria."
    tasks:
      - "Draft requirements doc tied to client business goals"
      - "Walk each requirement through an INVEST + acceptance criteria pass"
      - "Validate scope with client PM + sponsor; capture sign-off"
      - "Annotate use-cases for the top-3 customer journeys"
    methodologies:
      - slug: requirements-documentation
        path: pro/ba/ba-core/requirements-documentation
        required: true
        tier_gate: pro
      - slug: requirements-validation
        path: pro/ba/ba-core/requirements-validation
        required: true
        tier_gate: pro
      - slug: requirements-traceability
        path: pro/ba/ba-core/requirements-traceability
        required: true
        tier_gate: pro
      - slug: acceptance-criteria
        path: pro/ba/ba-modeling/acceptance-criteria
        required: true
        tier_gate: pro
      - slug: use-case-modeling
        path: pro/ba/ba-modeling/use-case-modeling
        required: true
        tier_gate: pro
      - slug: scope-management
        path: pro/pm/pm-traditional/scope-management
        required: true
        tier_gate: pro
    outputs:
      - "Requirements doc v1 with acceptance criteria"
      - "Use-case map for top journeys"
      - "Signed scope baseline (SoW Annex A)"
    decision_gate: |
      Advance when client PM countersigns scope baseline and acceptance criteria. If sponsor pushes back on >2 acceptance criteria, loop back into intake.
  - name: "Architecture & client conventions"
    intent: "Stand up an architecture skeleton that fits the client's house style, not yours."
    tasks:
      - "Reverse-engineer client conventions from existing repos (lint, CI, naming, branching)"
      - "Map quality attributes (NFRs) for performance / security / availability"
      - "Pick cloud architecture pattern aligned with client mandate"
      - "Open initial ADRs for top-5 contested decisions"
      - "Establish AI coding agent guardrails — what the agent may NOT auto-emit"
    methodologies:
      - slug: cloud-architecture
        path: pro/dev/software-architect/cloud-architecture
        required: true
        tier_gate: pro
      - slug: quality-attributes-analysis
        path: pro/dev/software-architect/quality-attributes-analysis
        required: true
        tier_gate: pro
      - slug: architecture-decision-records
        path: solo/sdd/sdd/architecture-decision-records
        required: true
        tier_gate: solo
      - slug: writing-design-documents
        path: solo/sdd/sdd/writing-design-documents
        required: true
        tier_gate: solo
      - slug: design-doc-structure
        path: solo/sdd/sdd-planning/design-doc-structure
        required: true
        tier_gate: solo
      - slug: client-conventions-reverse-engineering
        path: pro/_gap/client-conventions-reverse-engineering
        required: true
        tier_gate: pro
      - slug: ai-agent-guardrails-pack
        path: pro/_gap/ai-agent-guardrails-pack
        required: true
        tier_gate: pro
    outputs:
      - "Architecture skeleton repo (compiles, passes client lint)"
      - "ADR set #001-005"
      - "AI-agent guardrails written into AGENTS.md"
    decision_gate: |
      Advance once ADRs are merged AND a hello-world PR passes client's CI without rework. If lint/CI fails, fix conventions before sprint planning.
  - name: "RACI, cadence, dev environment"
    intent: "Make the working week predictable on both sides."
    tasks:
      - "Publish RACI for top-10 deliverables and decisions"
      - "Lock comms cadence (daily async, weekly sync, monthly steerco)"
      - "Provision dev environments matching client stack on every machine"
      - "Configure CI/CD skeleton with secrets management baseline"
      - "Document onboarding in a 30-day plan a new joiner can follow"
    methodologies:
      - slug: raci-matrix
        path: pro/pm/pm-agile/raci-matrix
        required: true
        tier_gate: pro
      - slug: communications-management
        path: pro/pm/pm-traditional/communications-management
        required: true
        tier_gate: pro
      - slug: communications-management
        path: pro/pm/project-manager/communications-management
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement
        path: pro/pm/pm-traditional/stakeholder-engagement
        required: true
        tier_gate: pro
      - slug: docker-image-optimization
        path: pro/infra/devops-engineer/docker-image-optimization
        required: true
        tier_gate: pro
      - slug: github-actions-cicd
        path: pro/infra/devops-engineer/github-actions-cicd
        required: true
        tier_gate: pro
      - slug: secrets-management
        path: pro/infra/cicd-engineer/secrets-management
        required: true
        tier_gate: pro
      - slug: foreign-client-kickoff-checklist
        path: pro/_gap/foreign-client-kickoff-checklist
        required: true
        tier_gate: pro
    outputs:
      - "RACI matrix v1"
      - "Comms cadence published"
      - "Reproducible dev environment doc"
      - "CI/CD skeleton merged"
    decision_gate: |
      Advance when a brand-new joiner can clone the repo, follow the doc, and produce a green CI run in <1 day. Loop back if not.
  - name: "Sprint zero + inception report"
    intent: "Groom the first sprint, send the inception report, get the client steerco to sign off the engagement is open for delivery."
    tasks:
      - "Run sprint zero ceremonies with the joint team"
      - "Risk register draft with top-10 risks + mitigations"
      - "Hybrid delivery plan (Scrum cadence + traditional reporting outward)"
      - "Send inception report covering 6 sections (scope, arch, RACI, risks, plan, AI usage)"
    methodologies:
      - slug: scrum-ceremonies
        path: pro/pm/pm-agile/scrum-ceremonies
        required: true
        tier_gate: pro
      - slug: six-core-principles
        path: pro/pm/pm-agile/six-core-principles
        required: true
        tier_gate: pro
      - slug: hybrid-delivery
        path: pro/pm/pm-agile/hybrid-delivery
        required: true
        tier_gate: pro
      - slug: risk-register
        path: pro/pm/pm-traditional/risk-register
        required: true
        tier_gate: pro
    outputs:
      - "First sprint backlog committed"
      - "Risk register v1"
      - "Inception report sent and acknowledged"
    decision_gate: |
      Advance to delivery only when client steerco acknowledges inception report AND first sprint is committed by both PMs. Otherwise iterate.

common_pitfalls:
  - "Copy-pasting your own conventions over the client's — every audit later flags this"
  - "Skipping AI-agent guardrails — the agent will helpfully emit unsafe defaults nobody reviews"
  - "Leaving stakeholder register as 'people I emailed once' — write down decision authority"

quality_checklist:
  - "Could a brand-new joiner read the artifacts and ship a tiny PR end-to-end in week 3?"
  - "Did the AI coding agent get an explicit perimeter, not just vibes?"
  - "Did I countersign client-side, not just verbal nods?"

related_playbooks:
  - scoping-workshop
  - statement-of-work
  - weekly-status-report
  - sprint-planning-agency
  - production-cicd-pipeline

token_budget_estimate: 22000
cli_invocations:
  human:  "faion get-content foreign-client-project-kickoff --format md"
  agent:  "faion get-content foreign-client-project-kickoff --format context"
  json:   "faion get-content foreign-client-project-kickoff --format json"

