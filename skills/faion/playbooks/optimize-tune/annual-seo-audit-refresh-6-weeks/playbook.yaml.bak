# =============================================================================
# PLAYBOOK — Annual SEO Audit & Refresh (6 weeks)
# tier=geek group=role-growth-marketing complexity=deep
# =============================================================================

slug: annual-seo-audit-refresh-6-weeks
title: "Annual SEO Audit & Refresh (6 weeks)"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 36e8f8782967c372

tier_min: geek
complexity: deep
context: [solo, team]
persona: ["solo-founder", "growth-marketer"]

intent: |
  Full technical + content SEO audit, AI-overview readiness review, refresh of top-30 pages,
  cannibalization cleanup, internal-link rewiring, and 12-month forward plan. 'Done' = audit
  report delivered, refresh sprint executed for top-30 pages, AI-overview adaptation merged
  across the priority cluster, and the next-year SEO plan is in roadmap with quarterly OKRs.

scope: |
  Full technical + content SEO audit, AI-overview readiness review, refresh of top-30 pages,
  cannibalization cleanup, internal-link rewiring, and 12-month forward plan. 'Done' = audit
  report delivered, refresh sprint executed for top-30 pages, AI-overview adaptation merged
  across the priority cluster, and the next-year SEO plan is in roadmap with quarterly OKRs.

summary: |
  Full technical + content SEO audit, AI-overview readiness review, refresh of top-30 pages,
  cannibalization cleanup, internal-link rewiring, and 12-month forward plan. 'Done' = audit
  report delivered, refresh sprint executed for top-30 pages, AI-overview adaptation merged
  across the priority cluster, and the next-year SEO plan is in roadmap with quarterly OKRs.

methodology_refs:
  - geek/marketing/seo-manager/google-ai-overviews-optimization
  - geek/marketing/seo-manager/technical-seo-for-ai
  - pro/marketing/growth-marketer/north-star-metric
  - pro/marketing/growth-marketer/ops-metrics-basics
  - pro/marketing/gtm-strategist/ops-annual-planning-process

success_criteria:
  - "Written charter (goal, owner, success metric, time-box) signed off"
  - "All planned core artifacts shipped on schedule with tracking flowing"
  - "Measurement readout produced and peer-reviewed against confounders"
  - "Continue / pivot / kill decision written, with next milestone if continue"

stages:
  - name: "Frame"
    intent: "Lock the goal, owner, success metric, and time-box."
    tasks:
      - "Draft a one-paragraph charter with goal, owner, success metric, time-box"
      - "List explicit non-goals so scope cannot creep"
      - "Identify stakeholders and their decision rights"
    methodologies:
      - slug: google-ai-overviews-optimization
        path: geek/marketing/seo-manager/google-ai-overviews-optimization
        required: true
        tier_gate: geek
      - slug: seo-techniques
        path: solo/marketing/seo-manager/seo-techniques
        required: true
        tier_gate: solo
    outputs:
      - "Charter doc (1 page)"
    decision_gate: "Advance only with a written charter that all stakeholders read and signed off."
  - name: "Discover"
    intent: "Talk to real users / stakeholders / sales — kill assumptions before they enter the plan."
    tasks:
      - "Run 5-10 short interviews tied to the charter goal"
      - "Capture verbatim quotes, not paraphrases"
      - "Update the charter if discovery contradicts an assumption"
    methodologies:
      - slug: technical-seo-for-ai
        path: geek/marketing/seo-manager/technical-seo-for-ai
        required: true
        tier_gate: geek
      - slug: topical-authority
        path: solo/marketing/seo-manager/topical-authority
        required: true
        tier_gate: solo
    outputs:
      - "Discovery notes with quotes"
    decision_gate: "Advance only when discovery either confirms the charter or forces a documented re-charter."
  - name: "Research"
    intent: "Gather the inputs needed to plan: data, prior work, competitors, constraints."
    tasks:
      - "Pull the relevant data extract / dashboards / prior decks"
      - "Scan competitors and prior internal attempts"
      - "Document constraints (legal, tech, brand) up front"
    methodologies:
      - slug: north-star-metric
        path: pro/marketing/growth-marketer/north-star-metric
        required: true
        tier_gate: pro
      - slug: zero-click-search-adaptation
        path: solo/marketing/seo-manager/zero-click-search-adaptation
        required: true
        tier_gate: solo
    outputs:
      - "Research brief with sources"
    decision_gate: "Advance once research surfaces no blocker; otherwise loop with stakeholders."
  - name: "Plan"
    intent: "Convert the charter + research into a sequenced plan with owners."
    tasks:
      - "Break the work into 3-7 phases with explicit exit-criteria"
      - "Assign an owner per phase"
      - "Wire metrics + dashboards before execution starts"
    methodologies:
      - slug: ops-metrics-basics
        path: pro/marketing/growth-marketer/ops-metrics-basics
        required: true
        tier_gate: pro
    outputs:
      - "Plan doc with Gantt or phase table"
    decision_gate: "Advance only when each phase has a named owner and exit-criterion."
  - name: "Produce"
    intent: "Create the core artifacts: assets, content, code, campaigns, configs."
    tasks:
      - "Build the core deliverables per phase plan"
      - "Hold a draft review with the named owner before publish"
      - "Track WIP visibly so blockers surface fast"
    methodologies:
      - slug: ops-annual-planning-process
        path: pro/marketing/gtm-strategist/ops-annual-planning-process
        required: true
        tier_gate: pro
    outputs:
      - "Drafts of all core artifacts"
    decision_gate: "Advance when drafts pass internal review against the charter, not personal taste."
  - name: "Ship"
    intent: "Push live: deploy, publish, launch the campaign, flip the switch."
    tasks:
      - "Run the launch checklist (dependencies, tracking, comms)"
      - "Publish on schedule; do not pre-leak"
      - "Confirm tracking is flowing in real-time on a dashboard"
    methodologies:
      - slug: ops-annual-planning-templates
        path: pro/marketing/gtm-strategist/ops-annual-planning-templates
        required: true
        tier_gate: pro
    outputs:
      - "Launch evidence (URLs / receipts)"
    decision_gate: "Advance only with tracking visibly flowing; otherwise hold launch."
  - name: "Stabilize"
    intent: "Make the new thing not collapse the moment attention moves elsewhere."
    tasks:
      - "Document the runbook for whoever inherits this"
      - "Set alarms on the success metric so silent drift surfaces"
      - "Hand off ownership formally if not staying with you"
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Runbook + ownership transfer"
    decision_gate: "Advance only after the next owner can run this from the runbook without you."
  - name: "Measure"
    intent: "Read the metrics against the plan; separate noise from signal."
    tasks:
      - "Compare actuals vs charter success metric"
      - "Split cohort/segment/channel to find what drove the result"
      - "Document confounders before drawing conclusions"
    methodologies:
      - slug: growth-seo-link-building
        path: solo/marketing/seo-manager/growth-seo-link-building
        required: true
        tier_gate: solo
    outputs:
      - "Measurement readout (1 page)"
    decision_gate: "Advance when readout passes a peer sniff-test against confounders."
  - name: "Iterate-or-close"
    intent: "Decide: continue, kill, or hand off to BAU."
    tasks:
      - "Hold the retro on what shipped vs what was planned"
      - "Decide continue / pivot / kill / hand-off in writing"
      - "If continue: define next 30-day milestone with metrics"
    methodologies:
      - slug: seo
        path: solo/marketing/seo-manager/seo
        required: true
        tier_gate: solo
    outputs:
      - "Decision doc with next steps"
    decision_gate: "Required output: a written decision; no \"let's see\"."

token_budget_estimate: 12000

cli_invocations:
  human: "faion get-content annual-seo-audit-refresh-6-weeks --format md"
  agent: "faion get-content annual-seo-audit-refresh-6-weeks --format context"
  json:  "faion get-content annual-seo-audit-refresh-6-weeks --format json"

changelog:
