# =============================================================================
# Pricing experiment toggle
# Persona: P2 Indie Hacker — F-064
# =============================================================================

slug: pricing-experiment-toggle
title: "Pricing experiment toggle"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: c783be239c2b4a62

tier_min: solo
complexity: medium
context: [solo]
persona_hints: [P2]

intent: |
  Static pricing → one variable flipped for 14 days with a measured paid-conversion delta.

scope: |
  Bi-weekly: flip one pricing variable (price, billing period, trial length, plan name) for 14 days, measure paid conversion delta vs baseline, and decide keep, rollback, or iterate.

non_goals:
  - "Full pricing rewrite"
  - "Multi-variable experiments — one knob at a time"
  - "Permanent price changes without data"

prerequisites:
  - "A live pricing page with at least 30 days of baseline data"
  - "Stripe or similar checkout with toggleable pricing"

success_criteria:
  - "Single variable changed"
  - "14-day measurement window completed"
  - "Documented keep / rollback / iterate verdict"
  - "Pricing experiment log updated"

stages:
  - name: "Hypothesis"
    intent: "One pricing variable with a directional hypothesis."
    tasks:
      - "Pick one variable (price, billing, trial, plan name)"
      - "State expected direction of conversion change"
      - "Set a minimum significance threshold"
    methodologies:
      - slug: ops-pricing-strategy
        path: solo/marketing/gtm-strategist/ops-pricing-strategy
        required: true
        tier_gate: solo
      - slug: pricing-research
        path: solo/research/researcher/pricing-research
        required: true
        tier_gate: solo
    outputs:
      - "Hypothesis brief"
    decision_gate: |
      Advance once the hypothesis fits in one sentence.
  - name: "Toggle"
    intent: "Switch flipped in Stripe or pricing page."
    tasks:
      - "Implement the change end-to-end"
      - "Confirm checkout still completes"
      - "Update marketing copy that references price"
    methodologies:
      - slug: ops-subscription-models
        path: solo/marketing/gtm-strategist/ops-subscription-models
        required: true
        tier_gate: solo
      - slug: pricing-experiment-log
        path: solo/product/pricing-experiment-log
        required: true
        tier_gate: solo
      - slug: stripe-payment-links-no-backend
        path: free/dev/stripe-payment-links-no-backend
        required: true
        tier_gate: free
      - slug: ls-gumroad-pricing-flip
        path: solo/dev/ls-gumroad-pricing-flip
        required: true
        tier_gate: solo
    outputs:
      - "Live new pricing"
      - "Updated marketing copy"
    decision_gate: |
      Advance only after stranger test passes.
  - name: "Measure"
    intent: "14 days of clean data versus baseline."
    tasks:
      - "Pull paid conversion data at day 7 and day 14"
      - "Compare to baseline cohort"
      - "Note any seasonality risk"
    methodologies:
      - slug: vanity-metrics-audit
        path: solo/product/vanity-metrics-audit
        required: true
        tier_gate: solo
    outputs:
      - "Day-7 and day-14 conversion table"
    decision_gate: |
      Advance once both checkpoints have data.
  - name: "Decide"
    intent: "Keep, rollback, or iterate with a written verdict."
    tasks:
      - "Write a one-paragraph verdict"
      - "Update pricing experiment log"
      - "Queue next variable to test"
    methodologies:
      - slug: ops-pricing-strategy
        path: solo/marketing/gtm-strategist/ops-pricing-strategy
        required: true
        tier_gate: solo
      - slug: pricing-experiment-log
        path: solo/product/pricing-experiment-log
        required: true
        tier_gate: solo
    outputs:
      - "Pricing experiment verdict"
      - "Updated log"
    decision_gate: |
      Keep only if delta exceeds threshold; otherwise rollback.

common_pitfalls:
  - "Treating the playbook as a checklist instead of a decision tree"
  - "Skipping decision gates when intermediate progress feels good"
  - "Letting tools or platforms replace the founder's own judgement"

quality_checklist:
  - "Did each stage produce its named output or get explicitly skipped with a note?"
  - "Were decision gates respected or quietly bypassed?"
  - "Is the evidence trail strong enough to defend the verdict externally?"

related_playbooks:
  - solo-idea-to-validated-mvp
token_budget_estimate: 18000
cli_invocations:
  human:  "faion get-content pricing-experiment-toggle --format md"
  agent:  "faion get-content pricing-experiment-toggle --format context"
  json:   "faion get-content pricing-experiment-toggle --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft from brainstorm-2026-05-17, persona P2 (indie hacker)"

gaps:
  []
