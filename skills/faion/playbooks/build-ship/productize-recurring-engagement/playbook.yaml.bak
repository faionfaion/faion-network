# =============================================================================
# faion playbook manifest — P3 technical freelancer
# Generated for F-064 from playbook-index.json entry #21
# =============================================================================

slug: productize-recurring-engagement
title: "Productize a recurring engagement into a fixed-scope offer"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: ce6d55181a7a95bb

tier_min: pro
complexity: deep
context: [solo]
persona_hints: [P3]

intent: |
  Take one repeatedly-sold engagement (e.g. 'Stripe integration audit', 'Next.js perf pass', 'CI pipeline setup') and convert it into a named, fixed-price productized service with a public landing page, SOP, intake form, and a delivery checklist that lets you book it without a discovery call.

scope: |
  Take one repeatedly-sold engagement (e.g. 'Stripe integration audit', 'Next.js perf pass', 'CI pipeline setup') and convert it into a named, fixed-price productized service with a public landing page, SOP, intake form, and a delivery checklist that lets you book it without a discovery call.

non_goals:
  - "Hiring employees or building a team — solo operator throughout"
  - "Enterprise procurement processes — SMB / startup buyers only"

prerequisites:
  - "Active freelance practice with at least one paying client"
  - "A bookkeeping / time-tracking baseline in place"

success_criteria:
  - "Mine the pattern stage complete: Engagement tag report"
  - "Scope + price stage complete: Scope doc"
  - "Build the surface stage complete: Landing live"
  - "Soft-launch stage complete: 3-5 paid soft-launch deliveries"

stages:
  - name: "Mine the pattern"
    intent: "Pull a candidate from past invoices."
    tasks:
      - "Tag last 12 months of engagements by type"
      - "Find the most repeated, highest-margin pattern"
      - "Validate it's still in demand by 3 prospect calls"
    methodologies:
      - slug: minimum-product-frameworks
        path: pro/product/product-manager/minimum-product-frameworks
        required: true
        tier_gate: pro
      - slug: engagement-pattern-mining-from-past-invoices
        path: pro/_gap/engagement-pattern-mining-from-past-invoices
        required: true
        tier_gate: pro
      - slug: productized-service-candidate-selection
        path: pro/_gap/productized-service-candidate-selection
        required: true
        tier_gate: pro
    outputs:
      - "Engagement tag report"
      - "Demand validation note"
    decision_gate: |
      Advance only when one pattern is dominant AND validated by external prospects.
  - name: "Scope + price"
    intent: "Fixed scope + fixed price + clear upsell ladder."
    tasks:
      - "Write 1-page scope (what's IN, what's OUT)"
      - "Set fixed price + scope-cap + upsell tier prices"
      - "Draft pre-qualifying intake form"
    methodologies:
      - slug: growth-brand-positioning
        path: pro/marketing/gtm-strategist/growth-brand-positioning
        required: true
        tier_gate: pro
      - slug: scope-cap-and-upsell-laddering
        path: pro/_gap/scope-cap-and-upsell-laddering
        required: true
        tier_gate: pro
      - slug: pre-qualifying-intake-form
        path: pro/_gap/pre-qualifying-intake-form
        required: true
        tier_gate: pro
    outputs:
      - "Scope doc"
      - "Pricing ladder"
      - "Intake form"
    decision_gate: |
      Advance only when intake form weeds out obvious bad fits.
  - name: "Build the surface"
    intent: "Landing page + booking flow + delivery checklist live."
    tasks:
      - "Build landing page from template"
      - "Wire booking flow to intake form"
      - "Write delivery SOP / checklist"
    methodologies:
      - slug: growth-conversion-optimization
        path: pro/marketing/conversion-optimizer/growth-conversion-optimization
        required: true
        tier_gate: pro
      - slug: productized-service-landing-page-template
        path: pro/_gap/productized-service-landing-page-template
        required: true
        tier_gate: pro
    outputs:
      - "Landing live"
      - "Booking flow"
      - "Delivery SOP"
    decision_gate: |
      Advance only when end-to-end booking works without your manual intervention.
  - name: "Soft-launch"
    intent: "Sell to 3-5 past clients; harvest case studies."
    tasks:
      - "Send tailored offer to past clients fitting the pattern"
      - "Deliver against SOP; refine based on friction"
      - "Publish 1-page case studies from soft-launch deliveries"
    methodologies:
      - slug: productized-service-launch
        path: pro/_gap/productized-service-launch
        required: true
        tier_gate: pro
      - slug: past-client-soft-launch-sequence
        path: pro/_gap/past-client-soft-launch-sequence
        required: true
        tier_gate: pro
      - slug: single-page-case-study-generation
        path: pro/_gap/single-page-case-study-generation
        required: true
        tier_gate: pro
    outputs:
      - "3-5 paid soft-launch deliveries"
      - "Case studies live"
    decision_gate: |
      Advance only with ≥3 paid deliveries + ≥2 published case studies.

common_pitfalls:
  - "Treating decision_gate as a suggestion — playbook collapses to a checklist if gates are not enforced"
  - "Skipping written artifacts because 'it's in my head' — kills traceability and future re-use"

quality_checklist:
  - "Did every stage produce a written artifact a stranger could read?"
  - "Did I actually advance only when the decision_gate criterion was met?"

related_playbooks:
  - scoping-workshop
  - landing-page-from-zero
  - stripe-integration-basics
  - first-10-customers

token_budget_estimate: 19000
cli_invocations:
  human:  "faion get-content productize-recurring-engagement --format md"
  agent:  "faion get-content productize-recurring-engagement --format context"
  json:   "faion get-content productize-recurring-engagement --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P3 technical-freelancer persona, synthesis angle"

