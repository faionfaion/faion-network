# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #17
# =============================================================================

slug: compliance-grade-feature-delivery
title: "Compliance-grade feature delivery (FinTech / HIPAA / PCI)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 246a87a6bc13e525

tier_min: pro
complexity: deep
context: [outsource, team]
persona_hints: [P4]

intent: |
  Ship a regulated-domain feature → merged PR + evidence pack + traceable to control catalogue + AI agent did not invent unsafe patterns.

scope: |
  Synthesis playbook: a single feature in a regulated domain (FinTech payment flow, HIPAA PHI handling, PCI cardholder data path) shipped with a defensible audit trail. 'Done' = merged PR, evidence pack attached, traceable to client control catalogue, AI agent contained.

non_goals:
  - "Full audit prep — separate playbook"
  - "Architecture migration — single feature"
  - "Net-new compliance program — uses existing regime"

prerequisites:
  - "Compliance regime active (SOC 2 / PCI / HIPAA / banking)"
  - "Client control catalogue accessible"
  - "AI guardrails active in the engagement"

success_criteria:
  - "PR merged with control IDs in description"
  - "Evidence pack attached and indexed"
  - "Threat model updated as code where relevant"
  - "AI-generated portions attested by reviewer"
  - "Audit-grade code review record archived"

stages:
  - name: "Spec to control"
    intent: "Map the feature to controls before any code."
    tasks:
      - "Validate requirements + stakeholder list"
      - "Map feature to client control IDs"
      - "Design API contract first"
      - "Identify versioning impact for any external consumer"
    methodologies:
      - slug: requirements-validation
        path: pro/ba/business-analyst/requirements-validation
        required: true
        tier_gate: pro
      - slug: stakeholder-analysis
        path: pro/ba/business-analyst/stakeholder-analysis
        required: true
        tier_gate: pro
      - slug: api-contract-first
        path: solo/dev/software-developer/api-contract-first
        required: true
        tier_gate: solo
      - slug: api-versioning
        path: solo/dev/software-developer/api-versioning
        required: true
        tier_gate: solo
      - slug: client-control-id-mapping
        path: pro/_gap/client-control-id-mapping
        required: true
        tier_gate: pro
    outputs:
      - "Control mapping"
      - "API contract"
      - "Versioning note"
    decision_gate: |
      Advance only when every AC is mapped to a control ID.
  - name: "Design for audit"
    intent: "Choose patterns that an auditor likes."
    tasks:
      - "Apply clean-architecture and DDD where boundaries matter"
      - "Apply API gateway patterns at security perimeter"
      - "Capture quality attributes impact"
      - "Threat-model the change as code"
    methodologies:
      - slug: clean-architecture
        path: pro/dev/code-quality/clean-architecture
        required: true
        tier_gate: pro
      - slug: domain-driven-design
        path: pro/dev/code-quality/domain-driven-design
        required: true
        tier_gate: pro
      - slug: quality-attributes-analysis
        path: pro/dev/software-architect/quality-attributes-analysis
        required: true
        tier_gate: pro
      - slug: api-gateway-patterns
        path: pro/dev/software-developer/api-gateway-patterns
        required: true
        tier_gate: pro
      - slug: audit-grade-api-design
        path: pro/_gap/audit-grade-api-design
        required: true
        tier_gate: pro
      - slug: hipaa-phi-data-flow-design
        path: pro/_gap/hipaa-phi-data-flow-design
        required: true
        tier_gate: pro
      - slug: pci-dss-scope-minimisation
        path: pro/_gap/pci-dss-scope-minimisation
        required: true
        tier_gate: pro
      - slug: threat-model-as-code
        path: pro/_gap/threat-model-as-code
        required: true
        tier_gate: pro
    outputs:
      - "Design doc with control mapping"
      - "Threat model as code artifact"
    decision_gate: |
      Advance only after threat model has been peer-reviewed.
  - name: "Build + audit-grade review"
    intent: "Code the change with reviewable guard rails."
    tasks:
      - "Implement with code-review process discipline"
      - "Use MR-graph vs diff reviewer where the platform supports"
      - "Run government/license compliance scan in CI"
      - "Audit-grade code review on the resulting PR"
    methodologies:
      - slug: code-review-process
        path: free/dev/code-quality/code-review-process
        required: true
        tier_gate: free
      - slug: code-review
        path: free/dev/software-developer/code-review
        required: true
        tier_gate: free
      - slug: gov-license-compliance-scan
        path: geek/sdlc-ai/gov-license-compliance-scan
        required: true
        tier_gate: geek
      - slug: mr-graph-vs-diff-reviewer
        path: geek/sdlc-ai/mr-graph-vs-diff-reviewer
        required: true
        tier_gate: geek
      - slug: compliance-aware-code-review-checklist
        path: pro/_gap/compliance-aware-code-review-checklist
        required: true
        tier_gate: pro
    outputs:
      - "Reviewed PR ready to merge"
    decision_gate: |
      Advance only when review references control IDs.
  - name: "Evidence + ship"
    intent: "Attach evidence the auditor will pull later."
    tasks:
      - "Run SOC 2 evidence generator if available"
      - "Attach evidence pack to the PR"
      - "Update living docs for the new control posture"
      - "Merge with control IDs in the squash message"
    methodologies:
      - slug: soc2-evidence-generator-cli
        path: pro/_gap/soc2-evidence-generator-cli
        required: true
        tier_gate: pro
    outputs:
      - "Evidence pack attached"
      - "Merged PR with control IDs"
      - "Living docs updated"
    decision_gate: |
      Ship only when evidence is attached AND merge message references control IDs.

common_pitfalls:
  - "Treating compliance as a post-merge concern — evidence gets reconstructed from memory"
  - "AI-generated code with no attestation — auditors disallow it implicitly"
  - "Threat models stored as ad-hoc diagrams — drift before next sprint"

quality_checklist:
  - "Could the auditor pull this PR and trace to a control in <60s?"
  - "Did we attest AI involvement explicitly?"
  - "Did the threat model survive review by someone outside the change?"

related_playbooks:
  - audit-grade-code-review-compliance
  - fintech-hipaa-compliance-audit-prep

token_budget_estimate: 21000
cli_invocations:
  human:  "faion get-content compliance-grade-feature-delivery --format md"
  agent:  "faion get-content compliance-grade-feature-delivery --format context"
  json:   "faion get-content compliance-grade-feature-delivery --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, synthesis angle"

