# =============================================================================
# faion playbook manifest — F-064 P4 outsource-specialist
# Generated from playbook-index.json entry #18
# =============================================================================

slug: foreign-client-engagement-bootstrap
title: "Foreign-client engagement bootstrap (14 days)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 010fa97d43a697d9

tier_min: pro
complexity: medium
context: [outsource, team]
persona_hints: [P4]

intent: |
  First 14 days on a new foreign-client multi-month engagement → legal posture set, comms cadence agreed, dev env provisioned, AI agent constrained → first client-visible PR merged inside client conventions with zero style/process rework.

scope: |
  Synthesis playbook covering the first 14 days of a new foreign-client engagement. Output: legal posture set, comms cadence agreed, dev env per client mandate, AI agent constrained so it stops emitting unsafe defaults. 'Done' = first client-visible PR merged inside the client conventions with zero style/process rework.

non_goals:
  - "Sales work — engagement is signed"
  - "Long discovery — capped at 14 days"
  - "Compliance audit — separate playbook"

prerequisites:
  - "MSA + SoW signed"
  - "Client primary contacts named"
  - "Vendor team allocated"

success_criteria:
  - "NDA + MSA obligation extraction complete"
  - "Client conventions captured as code (lint, CI, AGENTS.md)"
  - "AI-agent perimeter policy documented"
  - "Timezone overlap comms charter agreed"
  - "First client-visible PR merged with zero style rework"

stages:
  - name: "Legal + comms posture"
    intent: "Set the rails the engagement runs on."
    tasks:
      - "Onboarding pass per HR-recruiter onboarding methodology"
      - "Read NDA + MSA, extract obligations"
      - "Define comms cadence charter for timezone overlap"
      - "Stakeholder engagement plan (advanced)"
    methodologies:
      - slug: onboarding
        path: pro/comms/hr-recruiter/onboarding
        required: true
        tier_gate: pro
      - slug: onboarding-30-day
        path: pro/comms/hr-recruiter/onboarding-30-day
        required: true
        tier_gate: pro
      - slug: communications-management
        path: pro/pm/project-manager/communications-management
        required: true
        tier_gate: pro
      - slug: stakeholder-engagement-advanced
        path: pro/pm/project-manager/stakeholder-engagement-advanced
        required: true
        tier_gate: pro
      - slug: nda-msa-obligation-extractor
        path: pro/_gap/nda-msa-obligation-extractor
        required: true
        tier_gate: pro
      - slug: timezone-overlap-comms-charter
        path: pro/_gap/timezone-overlap-comms-charter
        required: true
        tier_gate: pro
      - slug: foreign-client-etiquette-playbook
        path: pro/_gap/foreign-client-etiquette-playbook
        required: true
        tier_gate: pro
    outputs:
      - "Obligation register"
      - "Comms charter"
      - "Stakeholder map"
    decision_gate: |
      Advance when comms charter is countersigned by client PM.
  - name: "Client conventions as code"
    intent: "Stop guessing at the house style — encode it."
    tasks:
      - "Reverse-engineer client lint rules + CI gates"
      - "Mirror them in the engagement repo"
      - "Walk the GTM-strategist legal + contractor management ops methodologies"
      - "Document for the rest of the team"
    methodologies:
      - slug: ops-contractor-management
        path: pro/marketing/gtm-strategist/ops-contractor-management
        required: true
        tier_gate: pro
      - slug: ops-legal-compliance
        path: pro/marketing/gtm-strategist/ops-legal-compliance
        required: true
        tier_gate: pro
      - slug: client-conventions-as-code
        path: pro/_gap/client-conventions-as-code
        required: true
        tier_gate: pro
    outputs:
      - "Lint + CI conventions repo"
      - "AGENTS.md per module"
    decision_gate: |
      Advance only when CI is green on a no-op PR.
  - name: "AI agent perimeter + first PR"
    intent: "Constrain the AI agent BEFORE it ships embarrassing code."
    tasks:
      - "Apply code-review process + code-review baseline"
      - "Define AI-agent perimeter policy (what it may NOT auto-emit)"
      - "Cut the first client-visible PR (a real, small change)"
      - "Run audit-grade review even on the bootstrap PR"
    methodologies:
      - slug: code-review-process
        path: free/dev/code-quality/code-review-process
        required: true
        tier_gate: free
      - slug: code-review
        path: free/dev/software-developer/code-review
        required: true
        tier_gate: free
      - slug: ai-agent-perimeter-policy
        path: pro/_gap/ai-agent-perimeter-policy
        required: true
        tier_gate: pro
    outputs:
      - "AI-agent perimeter policy"
      - "First merged PR"
    decision_gate: |
      Bootstrap closes only when the first PR merges with zero style/process rework.

common_pitfalls:
  - "Setting AI agent free without a perimeter — first PR includes unsafe defaults"
  - "Treating client conventions as 'we'll figure it out' — incurs rework debt fast"
  - "Ignoring timezone etiquette differences (subject line tone, weekend availability)"

quality_checklist:
  - "Could the team explain client conventions from a doc, not a hallway chat?"
  - "Did the first PR merge clean?"
  - "Did the AI agent know what it cannot auto-emit?"

related_playbooks:
  - foreign-client-project-kickoff
  - new-project-machine-setup
  - compliance-grade-feature-delivery

token_budget_estimate: 14000
cli_invocations:
  human:  "faion get-content foreign-client-engagement-bootstrap --format md"
  agent:  "faion get-content foreign-client-engagement-bootstrap --format context"
  json:   "faion get-content foreign-client-engagement-bootstrap --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P4 outsource-specialist persona, synthesis angle"

