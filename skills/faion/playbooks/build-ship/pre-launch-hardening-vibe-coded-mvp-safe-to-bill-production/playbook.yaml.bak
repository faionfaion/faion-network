slug: pre-launch-hardening-vibe-coded-mvp-safe-to-bill-production
title: "Pre-launch hardening: vibe-coded MVP → safe-to-bill production"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: b8cd29755249d7b1

tier_min: solo
complexity: deep
context: [solo]
persona_hints: [P1]

intent: |
  Take an MVP that works on localhost and make it survive paying customers without a co-founder/SRE.

scope: |
  Take an MVP that works on localhost and make it survive paying customers without a co-founder/SRE. End state: Stripe live, RLS audited, backups proven, legal docs live, support inbox routed.

success_criteria:
  - "Final stage decision-gate is met and committed in writing"
  - "Every stage produces its named outputs"
  - "Cycle closes only when a written commitment exists for the next step"

stages:
  - name: "Security audit"
    intent: "Find what a vibe-coded MVP missed."
    tasks:
      - "Run a security-testing checklist against the codebase"
      - "Audit RLS / authz on the database"
      - "Scan git history for leaked secrets"
    methodologies:
      - slug: security-testing
        path: solo/dev/testing-developer/security-testing
        required: true
        tier_gate: solo
    outputs:
      - "Security audit report"
      - "RLS audit notes"
      - "Secret-scan results"
    decision_gate: "Advance only when all critical security findings are fixed."
  - name: "Stripe + payment hardening"
    intent: "Make billing un-funny."
    tasks:
      - "Wire Stripe live keys with separate webhook secret"
      - "Harden webhook validation against replay + spoof"
      - "Cover subscription lifecycle edge cases"
    methodologies:
      - slug: backup-recovery
        path: solo/infra/server-craft/backup-recovery
        required: true
        tier_gate: solo
    outputs:
      - "Live Stripe config"
      - "Webhook hardening notes"
      - "Lifecycle test coverage"
    decision_gate: "Advance only when test mode + live mode behave identically."
  - name: "Backup + restore drill"
    intent: "Prove you can recover, not assume."
    tasks:
      - "Run a backup snapshot"
      - "Restore to a scratch environment"
      - "Time the restore + sanity-check data"
    methodologies:
      - slug: secrets-management
        path: solo/infra/server-craft/secrets-management
        required: true
        tier_gate: solo
    outputs:
      - "Backup snapshot"
      - "Restore log"
      - "Restore time"
    decision_gate: "Advance only when restored environment matches prod within tolerance."
  - name: "Secrets + ops cleanup"
    intent: "Get secrets out of .env clutter."
    tasks:
      - "Move secrets to a managed store"
      - "Rotate any leaked or shared keys"
      - "Document the secret rotation runbook"
    methodologies:
      - slug: ops-customer-support
        path: solo/marketing/gtm-strategist/ops-customer-support
        required: true
        tier_gate: solo
    outputs:
      - "Managed secret store"
      - "Rotation log"
      - "Runbook"
    decision_gate: "Advance only when no plaintext secret is in repo or local file."
  - name: "Support inbox + SLA"
    intent: "Route customer messages somewhere you actually read."
    tasks:
      - "Pick the support inbox tool (email-only is fine)"
      - "Define the SLA per category"
      - "Wire alerts for new tickets"
    methodologies:
      - slug: feedback-management
        path: solo/product/product-operations/feedback-management
        required: true
        tier_gate: solo
    outputs:
      - "Inbox set up"
      - "SLA doc"
      - "Alert wiring"
    decision_gate: "Advance only when a test ticket reaches you within SLA."
  - name: "Legal docs live"
    intent: "Ship Terms / Privacy / Refund pages before billing."
    tasks:
      - "Draft Terms + Privacy from a solo-saas pack"
      - "Add the refund policy + cookie banner"
      - "Link from footer + checkout"
    methodologies:
      - slug: security-testing
        path: solo/dev/testing-developer/security-testing
        required: true
        tier_gate: solo
    outputs:
      - "Legal pages live"
      - "Refund policy"
      - "Cookie banner"
    decision_gate: "Advance only when checkout shows the policy link."
  - name: "Pre-bill checklist sweep"
    intent: "Final sweep before turning on live billing."
    tasks:
      - "Walk the launch-operations checklist"
      - "Fire smoke transactions in live mode"
      - "Confirm refund + dispute flow end-to-end"
    methodologies:
      - slug: backup-recovery
        path: solo/infra/server-craft/backup-recovery
        required: true
        tier_gate: solo
    outputs:
      - "Checklist signed off"
      - "Live smoke receipts"
      - "Refund/dispute test log"
    decision_gate: "Advance only when every checklist item is green."
  - name: "Flip live + monitor"
    intent: "Flip billing live and watch the first 72 hours."
    tasks:
      - "Switch payment processor to live"
      - "Watch first transactions"
      - "Stand by for first-100-tickets"
    methodologies:
      - slug: secrets-management
        path: solo/infra/server-craft/secrets-management
        required: true
        tier_gate: solo
    outputs:
      - "Live mode active"
      - "First-transaction log"
      - "First-72h notes"
    decision_gate: "Cycle closes when the first 72 hours pass without a P0 incident."

token_budget_estimate: 22000

cli_invocations:
  human:  "faion get-content pre-launch-hardening-vibe-coded-mvp-safe-to-bill-production --format md"
  agent:  "faion get-content pre-launch-hardening-vibe-coded-mvp-safe-to-bill-production --format context"
  json:   "faion get-content pre-launch-hardening-vibe-coded-mvp-safe-to-bill-production --format json"

changelog:
  - version: "1.0.0"
    date: 2026-05-20
    note: "Initial v2 draft generated from F-059..063 backlog"
