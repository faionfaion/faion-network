slug: design-system-as-code-lifecycle-tokens-storybook-figma-library-pr-governance
title: "Design-system-as-code lifecycle: tokens, Storybook, Figma, PR, governance"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 6ed48b5d4dbe1244

tier: pro
tier_min: pro
group: role-ux-ui-designer
persona: DS lead operating a system across Figma + Storybook + code with PR governance
complexity: deep
context: [solo, team]

summary: |
  Team owns or inherits a design system; ends with a self-sustaining loop where token edits propagate to Figma + Storybook + production, with governance and breaking-change process.

intent: |
  Disconnected design system -> token edits propagate end-to-end with PR governance + drift audit.

scope: |
  DS lead establishes the lifecycle from token source -> Figma library -> Storybook -> consumer apps. Includes PR governance, visual regression, drift audit, and a breaking-change process. Done when token edits propagate cleanly, drift stays under threshold, and governance review runs monthly.

success_criteria:
  - "Token edits propagate to Figma + Storybook + apps without manual reposting"
  - "PR review checklist enforced in CI"
  - "Visual regression green for >=2 consecutive cycles"
  - "Drift audit under threshold for >=4 weeks"
  - "Governance review running monthly"

methodology_refs:
  - faion/knowledge/pro/ux/ux-ui-designer/cross-platform-token-distribution
  - faion/knowledge/pro/ux/ux-ui-designer/design-system-success-factors
  - faion/knowledge/pro/ux/ux-ui-designer/semantic-tokens-and-modes
  - faion/knowledge/pro/ux/ux-ui-designer/token-organization
  - faion/knowledge/pro/ux/ux-ui-designer/w3c-design-tokens-standard
  - faion/knowledge/solo/ux/ui-designer/design-tokens-fundamentals

stages:
  - name: "Pick source of truth"
    intent: "One repo, one taxonomy."
    tasks:
      - "Pick token source repo + format (W3C-compliant)"
      - "Define token tiers (core / alias / component)"
      - "Document ownership"
    methodologies:
      - slug: token-organization
        path: pro/ux/ux-ui-designer/token-organization
        required: true
        tier_gate: pro
      - slug: w3c-design-tokens-standard
        path: pro/ux/ux-ui-designer/w3c-design-tokens-standard
        required: true
        tier_gate: pro
      - slug: design-tokens-fundamentals
        path: solo/ux/ui-designer/design-tokens-fundamentals
        required: true
        tier_gate: solo
    outputs:
      - "Source-of-truth doc"
    decision_gate: |
      Advance only when ownership is named.
  - name: "Build pipeline"
    intent: "Tokens flow to platforms automatically."
    tasks:
      - "Wire token build to web + mobile + Figma"
      - "Add semantic + mode layers"
      - "Smoke-test propagation"
    methodologies:
      - slug: cross-platform-token-distribution
        path: pro/ux/ux-ui-designer/cross-platform-token-distribution
        required: true
        tier_gate: pro
      - slug: semantic-tokens-and-modes
        path: pro/ux/ux-ui-designer/semantic-tokens-and-modes
        required: true
        tier_gate: pro
    outputs:
      - "Pipeline green"
    decision_gate: |
      Advance only when token edit propagates end-to-end.
  - name: "Storybook as truth"
    intent: "Components live in Storybook, not Figma."
    tasks:
      - "Wire components to tokens in Storybook"
      - "Add a11y addon + visual regression suite"
      - "Make Storybook the consumer-facing reference"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ux-ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "Storybook as source of truth"
    decision_gate: |
      Advance only when Storybook is the published reference.
  - name: "Figma <-> code"
    intent: "Mappings stay current."
    tasks:
      - "Add Code Connect mappings per component"
      - "Validate mappings on PR"
      - "Alert on Figma library drift"
    methodologies:
      - slug: cross-platform-token-distribution
        path: pro/ux/ux-ui-designer/cross-platform-token-distribution
        required: true
        tier_gate: pro
      - slug: design-system-success-factors
        path: pro/ux/ux-ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "Code Connect coverage report"
    decision_gate: |
      Advance only when coverage is >=80% on base components.
  - name: "PR governance"
    intent: "Reviews catch what tooling cannot."
    tasks:
      - "Add design review checklist to PR template"
      - "Require two reviewers for breaking changes"
      - "Enforce semver in commit hooks"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ux-ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "PR template + enforced reviews"
    decision_gate: |
      Advance only when checklist runs on every PR.
  - name: "Visual regression"
    intent: "Visual bugs caught before merge."
    tasks:
      - "Wire visual regression on Storybook builds"
      - "Block merges on red regression"
      - "Triage flakes weekly"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ux-ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
    outputs:
      - "Visual regression suite running"
    decision_gate: |
      Advance only when suite has been green 2 cycles.
  - name: "Governance + drift"
    intent: "Monthly review keeps the system honest."
    tasks:
      - "Run monthly drift audit"
      - "Hold a governance review with consumers"
      - "Update deprecation policy"
    methodologies:
      - slug: design-system-success-factors
        path: pro/ux/ux-ui-designer/design-system-success-factors
        required: true
        tier_gate: pro
      - slug: token-organization
        path: pro/ux/ux-ui-designer/token-organization
        required: true
        tier_gate: pro
    outputs:
      - "Monthly governance + drift report"
    decision_gate: |
      Done when monthly cadence is sustained.

common_pitfalls:
  - "Treating Figma as the source of truth -> code drifts"
  - "No PR governance -> breaking changes ship unnoticed"
  - "No monthly review -> drift accumulates silently"

quality_checklist:
  - "Does a token edit reach apps without manual steps?"
  - "Are PRs blocked on visual regression?"
  - "Is the governance cadence sustained?"

related_playbooks:
  - design-system-v1-to-v2-migration-12-weeks
  - design-system-component-update-single-component

token_budget_estimate: 9500
cli_invocations:
  human:  "faion get-content design-system-as-code-lifecycle-tokens-storybook-figma-library-pr-governance --format md"
  agent:  "faion get-content design-system-as-code-lifecycle-tokens-storybook-figma-library-pr-governance --format context"
  json:   "faion get-content design-system-as-code-lifecycle-tokens-storybook-figma-library-pr-governance --format json"

