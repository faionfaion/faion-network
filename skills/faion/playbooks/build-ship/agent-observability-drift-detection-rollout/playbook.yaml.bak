slug: agent-observability-drift-detection-rollout
title: "Observability + drift detection rollout (3 weeks)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 05193f4f74a3a6dd

tier_min: geek
complexity: medium
context: [team]
persona_hints: [P7]

intent: |
  Blind-running agent → fully observed: per-step OTEL traces, eval-in-prod sampling, drift detection, alerting, on-call runbook.

scope: |
  Production agent goes from blind-running to fully observed: per-step OTEL traces, eval-in-prod sampling, drift detection on inputs/outputs/costs, alerting, and an on-call runbook.

non_goals:
  - "Replacing existing APM — augments, not replaces"
  - "Building a vendor observability product"

prerequisites:
  - "Existing production agent path"
  - "Logging endpoint with retention"

success_criteria:
  - "OTEL traces visible per trajectory"
  - "Eval-in-prod sampling running"
  - "Drift detection firing on planted shifts"
  - "On-call runbook signed off"
  - "Alerts route to the right channel with tier-approval gating"

stages:
  - name: "Trace Wiring"
    intent: "Per-step OTEL traces with stable trajectory ids."
    tasks:
      - "Instrument every tool call + LLM call"
      - "Stream-JSON orchestration where applicable"
      - "Pin schema versions across traces"
    methodologies:
      - slug: trajectory-eval-otel
        path: geek/ai/ai-agents/trajectory-eval-otel
        required: true
        tier_gate: geek
      - slug: stream-json-orchestration
        path: geek/ai/ai-agents/stream-json-orchestration
        required: true
        tier_gate: geek
      - slug: schema-version-pinning
        path: geek/ai/ai-agents/schema-version-pinning
        required: true
        tier_gate: geek
      - slug: llm-observability
        path: geek/ai/ml-engineer/llm-observability
        required: true
        tier_gate: geek
      - slug: llm-observability-stack
        path: geek/ai/ml-engineer/llm-observability-stack
        required: true
        tier_gate: geek
    outputs:
      - "Trace dashboard"
      - "Trajectory id contract"
    decision_gate: |
      Advance when traces resolve per-step end-to-end.
  - name: "Eval-in-Prod"
    intent: "Sample production traffic into judges."
    tasks:
      - "Stratify and sample production traffic"
      - "Run rubric judges on samples"
      - "Track scores over time"
    methodologies:
      - slug: llm-judge-rubric-evidence-first
        path: geek/ai/ai-agents/llm-judge-rubric-evidence-first
        required: true
        tier_gate: geek
      - slug: evaluation-framework
        path: geek/ai/ml-ops/evaluation-framework
        required: true
        tier_gate: geek
      - slug: rag-eval-production-monitoring
        path: geek/ai/rag-engineer/rag-eval-production-monitoring
        required: true
        tier_gate: geek
      - slug: vector-database-setup
        path: geek/ai/rag-engineer/vector-database-setup
        required: true
        tier_gate: geek
    outputs:
      - "Eval-in-prod sampler"
      - "Score timeline"
    decision_gate: |
      Advance when scores look stable on a known-good window.
  - name: "Drift Detection"
    intent: "Detect input, output, and cost drift before users do."
    tasks:
      - "Wire input-distribution monitor"
      - "Wire output-distribution monitor"
      - "Wire cost spike monitor"
    methodologies:
      - slug: guardrails-concepts
        path: geek/ai/ml-engineer/guardrails-concepts
        required: true
        tier_gate: geek
      - slug: ai-governance-compliance
        path: geek/ai/ml-engineer/ai-governance-compliance
        required: true
        tier_gate: geek
      - slug: eu-ai-act-compliance
        path: geek/ai/ml-engineer/eu-ai-act-compliance
        required: true
        tier_gate: geek
      - slug: prompt-engineering-security
        path: geek/ai/ml-engineer/prompt-engineering-security
        required: true
        tier_gate: geek
    outputs:
      - "Drift dashboard"
      - "Alert rules"
    decision_gate: |
      Advance after planted-drift test fires correctly.
  - name: "On-Call"
    intent: "Read-only investigation default + runbook + approval gates."
    tasks:
      - "Author runbook as tagged markdown steps"
      - "Default investigations to read-only"
      - "Auto-draft postmortem on incident"
    methodologies:
      - slug: inc-runbook-as-markdown-tagged-steps
        path: geek/sdlc-ai/inc-runbook-as-markdown-tagged-steps
        required: true
        tier_gate: geek
      - slug: inc-read-only-investigation-default
        path: geek/sdlc-ai/inc-read-only-investigation-default
        required: true
        tier_gate: geek
      - slug: inc-tool-tier-approval-gate
        path: geek/sdlc-ai/inc-tool-tier-approval-gate
        required: true
        tier_gate: geek
      - slug: inc-postmortem-auto-draft-no-publish
        path: geek/sdlc-ai/inc-postmortem-auto-draft-no-publish
        required: true
        tier_gate: geek
    outputs:
      - "Runbook doc"
      - "Approval gate config"
    decision_gate: |
      Ship only when an end-to-end incident drill completes.

common_pitfalls:
  - "Treating eval scores as ground truth without judge calibration"
  - "Shipping prompt or model changes without a regression gate"

quality_checklist:
  - "Can I roll back this change in one step?"
  - "Is the regression eval committed BEFORE the fix?"

related_playbooks:
  - eval-harness-continuous-benchmark-suite
  - agent-observability-drift-detection-rollout

token_budget_estimate: 9000
cli_invocations:
