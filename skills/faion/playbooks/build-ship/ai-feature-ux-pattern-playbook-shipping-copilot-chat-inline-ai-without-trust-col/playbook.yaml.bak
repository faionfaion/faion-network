slug: ai-feature-ux-pattern-playbook-shipping-copilot-chat-inline-ai-without-trust-col
title: "AI-feature UX pattern playbook: copilot / chat / inline-AI without trust collapse"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion-network"]
content_id: 04f068c7443ef91a

tier: geek
tier_min: geek
group: role-ux-ui-designer
persona: Designer shipping an AI feature (chat, copilot, inline-AI, agentic action)
complexity: deep
context: [solo, team]

summary: |
  Designer is asked to add an AI feature; ends with a vetted UX pattern + a11y + trust/disclosure framing + override path + measurable trust metrics.

intent: |
  AI feature ask -> vetted UX pattern + trust signals + override + measurable metrics.

scope: |
  Designer ships an AI feature (chat, copilot side-panel, inline autocomplete, or agentic action). Includes pattern selection, trust + disclosure framing, human-in-the-loop UI, streaming response UX, a11y, and trust metrics. Done when the feature ships with a defined trust dashboard and override paths.

success_criteria:
  - "Pattern selected and justified (chat / copilot / inline / agentic)"
  - "Trust + disclosure framing visible in UI"
  - "Override path always reachable"
  - "A11y coverage for AT users on AI surface"
  - "Trust metrics dashboard live with baseline"

methodology_refs:
  - faion/knowledge/geek/ux/user-researcher/synthetic-users
  - faion/knowledge/geek/ux/ux-ui-designer/ai-accessibility-automation-2026
  - faion/knowledge/geek/ux/ux-ui-designer/ai-design-assistant-patterns
  - faion/knowledge/geek/ux/ux-ui-designer/generative-ui-design

stages:
  - name: "Pick pattern"
    intent: "Match pattern to job."
    tasks:
      - "Map job (read / draft / decide / act) to pattern"
      - "Document trade-offs per pattern"
      - "Get sponsor sign-off on pattern choice"
    methodologies:
      - slug: ai-design-assistant-patterns
        path: geek/ux/ux-ui-designer/ai-design-assistant-patterns
        required: true
        tier_gate: geek
      - slug: generative-ui-design
        path: geek/ux/ux-ui-designer/generative-ui-design
        required: true
        tier_gate: geek
    outputs:
      - "Pattern selection doc"
    decision_gate: |
      Advance only when pattern is signed off.
  - name: "Trust + disclosure"
    intent: "Users see what is AI and what is not."
    tasks:
      - "Add provenance + confidence cues"
      - "Disclose data sources + limitations"
      - "Surface 'why' explanations on demand"
    methodologies:
      - slug: ai-design-assistant-patterns
        path: geek/ux/ux-ui-designer/ai-design-assistant-patterns
        required: true
        tier_gate: geek
    outputs:
      - "Trust + disclosure components"
    decision_gate: |
      Advance only when disclosure is visible without effort.
  - name: "Human-in-the-loop"
    intent: "User stays in control."
    tasks:
      - "Add accept / reject / edit affordances"
      - "Add undo + audit log on agentic actions"
      - "Document confirmation patterns for irreversible acts"
    methodologies:
      - slug: ai-design-assistant-patterns
        path: geek/ux/ux-ui-designer/ai-design-assistant-patterns
        required: true
        tier_gate: geek
      - slug: generative-ui-design
        path: geek/ux/ux-ui-designer/generative-ui-design
        required: true
        tier_gate: geek
    outputs:
      - "Human-in-the-loop UI"
    decision_gate: |
      Advance only when override path is always available.
  - name: "Streaming UX"
    intent: "Latency does not break trust."
    tasks:
      - "Stream tokens vs full-block responses"
      - "Add interruptible generation"
      - "Surface partial results gracefully"
    methodologies:
      - slug: generative-ui-design
        path: geek/ux/ux-ui-designer/generative-ui-design
        required: true
        tier_gate: geek
    outputs:
      - "Streaming response UX"
    decision_gate: |
      Advance only when interruption + partials work.
  - name: "A11y for AI"
    intent: "AT users get the same experience."
    tasks:
      - "Announce streamed updates politely"
      - "Make controls keyboard-reachable"
      - "Test with NVDA + VoiceOver"
    methodologies:
      - slug: ai-accessibility-automation-2026
        path: geek/ux/ux-ui-designer/ai-accessibility-automation-2026
        required: true
        tier_gate: geek
    outputs:
      - "A11y test results"
    decision_gate: |
      Advance only after AT testing passes.
  - name: "Validate with synthetic + real"
    intent: "Find failure modes before customers do."
    tasks:
      - "Run synthetic-user scenarios across edge cases"
      - "Run real-user sessions on flagship flows"
      - "Adjust patterns to address failure modes"
    methodologies:
      - slug: synthetic-users
        path: geek/ux/user-researcher/synthetic-users
        required: true
        tier_gate: geek
    outputs:
      - "Validation report"
    decision_gate: |
      Advance only when criticals are addressed.
  - name: "Trust metrics dashboard"
    intent: "Measure trust, not just usage."
    tasks:
      - "Define trust signals (accept rate, undo rate, sentiment)"
      - "Wire a dashboard with baseline"
      - "Schedule monthly review"
    methodologies:
      - slug: ai-design-assistant-patterns
        path: geek/ux/ux-ui-designer/ai-design-assistant-patterns
        required: true
        tier_gate: geek
    outputs:
      - "Trust metrics dashboard live"
    decision_gate: |
      Done when dashboard has baseline + review cadence.

common_pitfalls:
  - "Skipping disclosure -> trust collapse on first wrong answer"
  - "No undo on agentic actions -> users disengage"
  - "No streaming -> perceived latency tanks adoption"

quality_checklist:
  - "Is the AI source disclosed?"
  - "Can users override every AI act?"
  - "Are trust metrics being measured monthly?"

related_playbooks:
  - zero-to-one-product-design-brief-to-dev-handoff-8-weeks
  - design-system-as-code-lifecycle-tokens-storybook-figma-library-pr-governance

token_budget_estimate: 9500
cli_invocations:
  human:  "faion get-content ai-feature-ux-pattern-playbook-shipping-copilot-chat-inline-ai-without-trust-col --format md"
  agent:  "faion get-content ai-feature-ux-pattern-playbook-shipping-copilot-chat-inline-ai-without-trust-col --format context"
  json:   "faion get-content ai-feature-ux-pattern-playbook-shipping-copilot-chat-inline-ai-without-trust-col --format json"

changelog:
