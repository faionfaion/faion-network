slug: "productize-a-service-offering-v2"
title: "Productize a service offering (8–10 weeks idea to first paid sale)"
tier: "pro"
group: "micro-agency"
persona: "p5-micro-agency-founder"
complexity: "deep"
version: "1.0.0"
status: "draft"
last_reviewed: 2026-05-20
maintainers:
  - "faion-network"
summary: |
  Take a recurring custom engagement and convert it into a named, fixed-scope, fixed-price productized service with a public landing page, sales script, delivery SOP, and at least one paying customer.
content_id: "77ba6001aba0a501"
tier_min: "pro"
context:
  - "team"
intent: |
  Take a recurring custom engagement and convert it into a named, fixed-scope, fixed-price productized service with a public landing page, sales script, delivery SOP, and at least one paying customer.
scope: |
  Take a recurring custom engagement and convert it into a named, fixed-scope, fixed-price productized service with a public landing page, sales script, delivery SOP, and at least one paying customer.
success_criteria:
  - "All 6 stages have written outputs in the project record"
  - "Each stage's decision gate was answered before advancing (yes / no in writing)"
  - "Final stage produced the required written decision artifact"
  - "Every methodology reference loaded cleanly via `faion get-content`"
methodology_refs:
  - "business-process-analysis"
  - "use-case-modeling"
  - "growth-conversion-optimization"
  - "conversion-tracking"
  - "growth-loops"
  - "growth-brand-positioning"
  - "growth-press-coverage"
  - "ops-customer-success-metrics"
  - "continuous-discovery-habits"
  - "feedback-management"
  - "methodologies-summary"
  - "minimum-product-frameworks"
  - "mlp-planning"
  - "product-analytics"
  - "release-planning"
  - "competitive-positioning"
  - "business-model-research"
  - "competitive-intelligence"
  - "competitor-analysis"
  - "market-analysis"
  - "growth-copywriting-fundamentals"
  - "growth-customer-testimonials"
  - "growth-email-marketing"
  - "growth-newsletter-growth"
  - "growth-seo-fundamentals"
stages:
  - name: "Discover"
    intent: "Pick the recurring engagement to productize."
    tasks:
      - "Audit last 6 months of project work and tag repeated scope patterns"
      - "Pick one bundle that you've delivered ≥3 times with positive margin"
      - "Interview 5 past clients on the painful before-state"
    methodologies:
      - slug: "business-process-analysis"
        path: "pro/ba/business-analyst/business-process-analysis"
        required: true
        tier_gate: "pro"
      - slug: "use-case-modeling"
        path: "pro/ba/business-analyst/use-case-modeling"
        required: true
        tier_gate: "pro"
      - slug: "growth-conversion-optimization"
        path: "pro/marketing/conversion-optimizer/growth-conversion-optimization"
        required: true
        tier_gate: "pro"
      - slug: "conversion-tracking"
        path: "pro/marketing/growth-marketer/conversion-tracking"
        required: true
        tier_gate: "pro"
    outputs:
      - "Repeat-work audit table"
      - "Chosen productization candidate"
      - "5 client-pain notes"
    decision_gate: "Advance only if one candidate scored ≥3 repeats AND ≥3 client confirmations."
  - name: "Scope & Price"
    intent: "Lock fixed scope and fixed price."
    tasks:
      - "Draft the productized-service canvas (problem, deliverables, exclusions, timeline)"
      - "Run a cost build-up; set price at 3-4x your direct delivery cost"
      - "Define 3 explicit non-goals to protect scope"
    methodologies:
      - slug: "growth-loops"
        path: "pro/marketing/growth-marketer/growth-loops"
        required: true
        tier_gate: "pro"
      - slug: "growth-brand-positioning"
        path: "pro/marketing/gtm-strategist/growth-brand-positioning"
        required: true
        tier_gate: "pro"
      - slug: "growth-press-coverage"
        path: "pro/marketing/gtm-strategist/growth-press-coverage"
        required: true
        tier_gate: "pro"
      - slug: "ops-customer-success-metrics"
        path: "pro/marketing/gtm-strategist/ops-customer-success-metrics"
        required: true
        tier_gate: "pro"
    outputs:
      - "service canvas"
      - "pricing memo"
      - "non-goals list"
    decision_gate: "Advance if margin model clears target gross margin and scope fits on one page."
  - name: "Landing & Sales Script"
    intent: "Public landing + repeatable sales motion."
    tasks:
      - "Build single-page landing with outcome-led copy and one CTA"
      - "Write a sales-call script (problem, deliverables, price, objections, close)"
      - "Set conversion tracking on the CTA"
    methodologies:
      - slug: "continuous-discovery-habits"
        path: "pro/product/product-manager/continuous-discovery-habits"
        required: true
        tier_gate: "pro"
      - slug: "feedback-management"
        path: "pro/product/product-manager/feedback-management"
        required: true
        tier_gate: "pro"
      - slug: "methodologies-summary"
        path: "pro/product/product-manager/methodologies-summary"
        required: true
        tier_gate: "pro"
      - slug: "minimum-product-frameworks"
        path: "pro/product/product-manager/minimum-product-frameworks"
        required: true
        tier_gate: "pro"
    outputs:
      - "live landing URL"
      - "sales-call script"
      - "tracking dashboard"
    decision_gate: "Advance when landing converts at least one qualified lead per 50 visits."
  - name: "Delivery SOP"
    intent: "Make delivery repeatable, not artisanal."
    tasks:
      - "Document the delivery workflow as a numbered SOP with checkpoints"
      - "Define handover artifacts at each checkpoint"
      - "Write the case-study template the SOP outputs by default"
    methodologies:
      - slug: "mlp-planning"
        path: "pro/product/product-manager/mlp-planning"
        required: true
        tier_gate: "pro"
      - slug: "product-analytics"
        path: "pro/product/product-manager/product-analytics"
        required: true
        tier_gate: "pro"
      - slug: "release-planning"
        path: "pro/product/product-manager/release-planning"
        required: true
        tier_gate: "pro"
      - slug: "competitive-positioning"
        path: "pro/product/product-planning/competitive-positioning"
        required: true
        tier_gate: "pro"
    outputs:
      - "delivery SOP"
      - "checkpoint artifacts"
      - "case-study template"
    decision_gate: "Advance when a contractor can follow the SOP unaided to checkpoint 1."
  - name: "First Paid Sale"
    intent: "Convert one prospect end-to-end at the fixed price."
    tasks:
      - "Run outbound to 20 warm prospects with the new landing"
      - "Hold sales calls using the script; do not discount the fixed price"
      - "Sign one fixed-price contract and kick off delivery"
    methodologies:
      - slug: "business-model-research"
        path: "pro/research/market-researcher/business-model-research"
        required: true
        tier_gate: "pro"
      - slug: "competitive-intelligence"
        path: "pro/research/market-researcher/competitive-intelligence"
        required: true
        tier_gate: "pro"
      - slug: "competitor-analysis"
        path: "pro/research/market-researcher/competitor-analysis"
        required: true
        tier_gate: "pro"
      - slug: "market-analysis"
        path: "pro/research/market-researcher/market-analysis"
        required: true
        tier_gate: "pro"
    outputs:
      - "20 outbound logs"
      - "1 signed contract"
      - "kickoff packet"
    decision_gate: "Advance when 1 client has paid the first invoice."
  - name: "Learn & Iterate"
    intent: "Capture what the first sale taught."
    tasks:
      - "Compare delivered scope vs canvas — log every overage"
      - "Update SOP, landing copy, and price for the next cycle"
      - "Decide: scale this productized offering, or kill and pick another"
    methodologies:
      - slug: "growth-copywriting-fundamentals"
        path: "solo/marketing/content-marketer/growth-copywriting-fundamentals"
        required: true
        tier_gate: "pro"
      - slug: "growth-customer-testimonials"
        path: "solo/marketing/content-marketer/growth-customer-testimonials"
        required: true
        tier_gate: "pro"
      - slug: "growth-email-marketing"
        path: "solo/marketing/content-marketer/growth-email-marketing"
        required: true
        tier_gate: "pro"
      - slug: "growth-newsletter-growth"
        path: "solo/marketing/content-marketer/growth-newsletter-growth"
        required: true
        tier_gate: "pro"
      - slug: "growth-seo-fundamentals"
        path: "solo/marketing/seo-manager/growth-seo-fundamentals"
        required: true
        tier_gate: "pro"
    outputs:
      - "overage log"
      - "v2 canvas + landing diff"
      - "scale/kill memo"
    decision_gate: "Required output: a written scale-or-kill decision with evidence."
token_budget_estimate: 18000
