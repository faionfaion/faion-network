slug: "project-from-kickoff-to-client-signoff-v2"
title: "Project from kickoff to client signoff (8–12 weeks)"
tier: "pro"
group: "micro-agency"
persona: "p5-micro-agency-founder"
complexity: "deep"
version: "1.0.0"
status: "draft"
last_reviewed: 2026-05-20
maintainers:
  - "faion-network"
summary: |
  A signed SOW becomes a delivered project: kickoff, requirements baseline, delivery in waves, change-controlled scope, final acceptance, retainer-or-referral conversation. Net margin and NPS measured.
content_id: "c0e203555899fbd9"
tier_min: "pro"
context:
  - "team"
intent: |
  A signed SOW becomes a delivered project: kickoff, requirements baseline, delivery in waves, change-controlled scope, final acceptance, retainer-or-referral conversation. Net margin and NPS measured.
scope: |
  A signed SOW becomes a delivered project: kickoff, requirements baseline, delivery in waves, change-controlled scope, final acceptance, retainer-or-referral conversation. Net margin and NPS measured.
success_criteria:
  - "All 6 stages have written outputs in the project record"
  - "Each stage's decision gate was answered before advancing (yes / no in writing)"
  - "Final stage produced the required written decision artifact"
  - "Every methodology reference loaded cleanly via `faion get-content`"
methodology_refs:
  - "acceptance-criteria"
  - "elicitation-techniques"
  - "requirements-documentation"
  - "requirements-prioritization"
  - "requirements-traceability"
  - "requirements-validation"
  - "solution-assessment"
  - "ops-customer-success-metrics"
  - "ops-upselling-cross-selling"
  - "kanban-scaled-agile-ceremonies"
  - "scrum-ceremonies"
  - "benefits-realization"
  - "change-control"
  - "communications-management"
  - "earned-value-management"
  - "lessons-learned"
  - "project-closure"
  - "quality-management"
  - "raci-matrix"
  - "risk-management"
  - "risk-register"
  - "schedule-development"
  - "scope-management"
  - "stakeholder-engagement"
  - "stakeholder-engagement-advanced"
  - "team-development"
stages:
  - name: "Kickoff"
    intent: "Translate signed SOW into a baselined plan."
    tasks:
      - "Run a 60-min kickoff covering scope, RACI, success criteria, change process"
      - "Baseline schedule, scope, and acceptance criteria into the project doc"
      - "Set the weekly status cadence and channel"
    methodologies:
      - slug: "acceptance-criteria"
        path: "pro/ba/ba-modeling/acceptance-criteria"
        required: true
        tier_gate: "pro"
      - slug: "elicitation-techniques"
        path: "pro/ba/business-analyst/elicitation-techniques"
        required: true
        tier_gate: "pro"
      - slug: "requirements-documentation"
        path: "pro/ba/business-analyst/requirements-documentation"
        required: true
        tier_gate: "pro"
      - slug: "requirements-prioritization"
        path: "pro/ba/business-analyst/requirements-prioritization"
        required: true
        tier_gate: "pro"
    outputs:
      - "kickoff deck"
      - "baselined plan"
      - "status cadence calendar"
    decision_gate: "Advance only when client has signed the kickoff summary acknowledging scope."
  - name: "Requirements Baseline"
    intent: "Lock the requirements at a level of detail you can deliver against."
    tasks:
      - "Run elicitation sessions for any ambiguous spec items"
      - "Write acceptance criteria for every deliverable"
      - "Map traceability from requirements to deliverables"
    methodologies:
      - slug: "requirements-traceability"
        path: "pro/ba/business-analyst/requirements-traceability"
        required: true
        tier_gate: "pro"
      - slug: "requirements-validation"
        path: "pro/ba/business-analyst/requirements-validation"
        required: true
        tier_gate: "pro"
      - slug: "solution-assessment"
        path: "pro/ba/business-analyst/solution-assessment"
        required: true
        tier_gate: "pro"
      - slug: "ops-customer-success-metrics"
        path: "pro/marketing/gtm-strategist/ops-customer-success-metrics"
        required: true
        tier_gate: "pro"
    outputs:
      - "requirements doc"
      - "acceptance criteria table"
      - "traceability matrix"
    decision_gate: "Advance when every deliverable has acceptance criteria and a traceability row."
  - name: "Delivery Wave 1"
    intent: "First slice ships under cadence with risk register live."
    tasks:
      - "Deliver the first wave per the schedule with weekly demos"
      - "Run a risk register; review weekly with one mitigation per top-3 risk"
      - "Send the weekly client status report on a fixed day"
    methodologies:
      - slug: "ops-upselling-cross-selling"
        path: "pro/marketing/gtm-strategist/ops-upselling-cross-selling"
        required: true
        tier_gate: "pro"
      - slug: "kanban-scaled-agile-ceremonies"
        path: "pro/pm/pm-agile/kanban-scaled-agile-ceremonies"
        required: true
        tier_gate: "pro"
      - slug: "scrum-ceremonies"
        path: "pro/pm/pm-agile/scrum-ceremonies"
        required: true
        tier_gate: "pro"
      - slug: "benefits-realization"
        path: "pro/pm/project-manager/benefits-realization"
        required: true
        tier_gate: "pro"
    outputs:
      - "wave-1 demo"
      - "live risk register"
      - "weekly status reports"
    decision_gate: "Advance when wave-1 acceptance criteria are signed off by the client."
  - name: "Change-Controlled Scope"
    intent: "Any new ask flows through change control."
    tasks:
      - "Tag every new request as in-scope, change-request, or rejected"
      - "Price change requests using the rubric; no free additions"
      - "Update the baseline only when a CR is signed"
    methodologies:
      - slug: "change-control"
        path: "pro/pm/project-manager/change-control"
        required: true
        tier_gate: "pro"
      - slug: "communications-management"
        path: "pro/pm/project-manager/communications-management"
        required: true
        tier_gate: "pro"
      - slug: "earned-value-management"
        path: "pro/pm/project-manager/earned-value-management"
        required: true
        tier_gate: "pro"
      - slug: "lessons-learned"
        path: "pro/pm/project-manager/lessons-learned"
        required: true
        tier_gate: "pro"
    outputs:
      - "CR log"
      - "priced CRs"
      - "updated baselines"
    decision_gate: "Advance only when no in-flight unpriced work exists at end of stage."
  - name: "Final Acceptance"
    intent: "Pass UAT and get the signoff signature."
    tasks:
      - "Run UAT against the acceptance-criteria table"
      - "Fix UAT findings until criteria pass at the agreed bar"
      - "Get written client signoff and final invoice paid"
    methodologies:
      - slug: "project-closure"
        path: "pro/pm/project-manager/project-closure"
        required: true
        tier_gate: "pro"
      - slug: "quality-management"
        path: "pro/pm/project-manager/quality-management"
        required: true
        tier_gate: "pro"
      - slug: "raci-matrix"
        path: "pro/pm/project-manager/raci-matrix"
        required: true
        tier_gate: "pro"
      - slug: "risk-management"
        path: "pro/pm/project-manager/risk-management"
        required: true
        tier_gate: "pro"
    outputs:
      - "UAT results"
      - "fix log"
      - "signoff + paid invoice"
    decision_gate: "Advance only when signoff is in writing AND final invoice is paid."
  - name: "Retainer or Referral Conversation"
    intent: "Convert delivery into recurring or referral."
    tasks:
      - "Hold the post-delivery review with the buyer; ask for a referral"
      - "Pitch a retainer or maintenance plan with a starting number"
      - "Measure project margin and NPS; log lessons learned"
    methodologies:
      - slug: "risk-register"
        path: "pro/pm/project-manager/risk-register"
        required: true
        tier_gate: "pro"
      - slug: "schedule-development"
        path: "pro/pm/project-manager/schedule-development"
        required: true
        tier_gate: "pro"
      - slug: "scope-management"
        path: "pro/pm/project-manager/scope-management"
        required: true
        tier_gate: "pro"
      - slug: "stakeholder-engagement"
        path: "pro/pm/project-manager/stakeholder-engagement"
        required: true
        tier_gate: "pro"
      - slug: "stakeholder-engagement-advanced"
        path: "pro/pm/project-manager/stakeholder-engagement-advanced"
        required: true
        tier_gate: "pro"
      - slug: "team-development"
        path: "pro/pm/project-manager/team-development"
        required: true
        tier_gate: "pro"
    outputs:
      - "referral asks"
      - "retainer proposal"
      - "margin + NPS + lessons doc"
    decision_gate: "Required output: explicit yes/no on retainer AND a logged lessons-learned doc."
token_budget_estimate: 18000
