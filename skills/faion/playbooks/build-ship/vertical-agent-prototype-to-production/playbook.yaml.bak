slug: vertical-agent-prototype-to-production
title: "Vertical agent: prototype to production (8 weeks)"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 884e3446ae97fa78

tier_min: geek
complexity: deep
context: [team]
persona_hints: [P7]

intent: |
  Blank repo on Monday → vertical agent with paying customer-zero workload on production, eval harness, observability, drift detection, rollback button.

scope: |
  Single-vertical agent (e.g. AI SDR, code-review bot, support triage) goes from blank repo to a paying customer-zero workload on production traffic, with eval harness, observability, drift detection and rollback in place. Covers prototype, eval bootstrap, hardening, customer-zero pilot, and GA rollout.

non_goals:
  - "Horizontal multi-tenant platforms — out of scope, single vertical only"
  - "Frontier-model research — uses available models off the shelf"

prerequisites:
  - "Defined vertical use case with a buyer who will pilot"
  - "Access to one frontier model API + one open-weight fallback"

success_criteria:
  - "Working agent on production traffic for customer-zero"
  - "CI-gated eval harness with golden trajectories"
  - "OTEL trajectory traces visible per request"
  - "Drift detector firing on cost/quality/refusal anomalies"
  - "One-click rollback validated under chaos test"
  - "GA-readiness checklist signed off"

stages:
  - name: "Prototype"
    intent: "Spike a working agent loop on the vertical task with one frontier model."
    tasks:
      - "Pick agent pattern: plan-execute vs ReAct"
      - "Define tool surface and output schema"
      - "Run end-to-end on 10 golden tasks"
    methodologies:
      - slug: plan-execute-vs-react
        path: geek/ai/ai-agents/plan-execute-vs-react
        required: true
        tier_gate: geek
      - slug: reasoning-first-architectures
        path: geek/ai/ai-agents/reasoning-first-architectures
        required: true
        tier_gate: geek
      - slug: claude-code-headless-default
        path: geek/ai/ai-agents/claude-code-headless-default
        required: true
        tier_gate: geek
      - slug: agents-react-pattern
        path: geek/ai/ml-engineer/agents-react-pattern
        required: true
        tier_gate: geek
      - slug: agents-framework-selection
        path: geek/ai/ml-engineer/agents-framework-selection
        required: true
        tier_gate: geek
    outputs:
      - "Prototype repo with one-command run"
      - "10 trace recordings of golden tasks"
    decision_gate: |
      Advance if ≥7/10 golden tasks complete without manual recovery.
  - name: "Schema & Tools"
    intent: "Lock structured outputs and tool contracts before scaling traffic."
    tasks:
      - "Draft strict schema with refusal field"
      - "Name tools verb-object; describe as prompts"
      - "Decide bundle-vs-split per tool"
    methodologies:
      - slug: discriminated-union-output
        path: geek/ai/ai-agents/discriminated-union-output
        required: true
        tier_gate: geek
      - slug: refusal-field-strict-schema
        path: geek/ai/ai-agents/refusal-field-strict-schema
        required: true
        tier_gate: geek
      - slug: strict-mode-required-fields
        path: geek/ai/ai-agents/strict-mode-required-fields
        required: true
        tier_gate: geek
      - slug: field-descriptions-as-prompts
        path: geek/ai/ai-agents/field-descriptions-as-prompts
        required: true
        tier_gate: geek
      - slug: semantic-field-naming
        path: geek/ai/ai-agents/semantic-field-naming
        required: true
        tier_gate: geek
      - slug: tool-description-as-prompt
        path: geek/ai/ai-agents/tool-description-as-prompt
        required: true
        tier_gate: geek
      - slug: verb-object-tool-naming
        path: geek/ai/ai-agents/verb-object-tool-naming
        required: true
        tier_gate: geek
      - slug: bundle-vs-split-tools
        path: geek/ai/ai-agents/bundle-vs-split-tools
        required: true
        tier_gate: geek
      - slug: idempotent-write-tools
        path: geek/ai/ai-agents/idempotent-write-tools
        required: true
        tier_gate: geek
      - slug: structured-tool-errors
        path: geek/ai/ai-agents/structured-tool-errors
        required: true
        tier_gate: geek
      - slug: semantic-xml-content
        path: geek/ai/llm-integration/semantic-xml-content
        required: true
        tier_gate: geek
      - slug: two-pass-reason-then-extract
        path: geek/ai/ai-agents/two-pass-reason-then-extract
        required: true
        tier_gate: geek
    outputs:
      - "Versioned schema doc"
      - "Tool registry with descriptions"
    decision_gate: |
      Advance when schema validates 100% on golden trace replay.
  - name: "Memory & Context"
    intent: "Decide how agent carries state across turns and what gets evicted."
    tasks:
      - "Pick scratchpad vs filesystem memory"
      - "Set compaction policy preserving refs"
      - "Order prompt for cache prefix reuse"
    methodologies:
      - slug: embedded-scratchpad-field
        path: geek/ai/ai-agents/embedded-scratchpad-field
        required: true
        tier_gate: geek
      - slug: filesystem-as-working-memory
        path: geek/ai/ai-agents/filesystem-as-working-memory
        required: true
        tier_gate: geek
      - slug: compaction-preserve-refs
        path: geek/ai/ai-agents/compaction-preserve-refs
        required: true
        tier_gate: geek
      - slug: prompt-cache-prefix-order
        path: geek/ai/ai-agents/prompt-cache-prefix-order
        required: true
        tier_gate: geek
      - slug: handoff-id-payload
        path: geek/ai/ai-agents/handoff-id-payload
        required: true
        tier_gate: geek
      - slug: agents-memory-system
        path: geek/ai/ml-engineer/agents-memory-system
