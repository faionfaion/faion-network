      - slug: llm-cost-basics
        path: geek/ai/ml-ops/llm-cost-basics
        required: true
        tier_gate: geek
    outputs:
      - "Cascade policy doc"
      - "Cost-per-success baseline"
    decision_gate: |
      Advance if cost-per-success ≤ budget on golden set.
  - name: "Eval Harness"
    intent: "CI-gated eval harness with judges and chaos pack before pilot traffic."
    tasks:
      - "Author rubric-evidence judge"
      - "Add chaos-eval fault injection"
      - "Wire trajectory OTEL evals"
    methodologies:
      - slug: llm-judge-rubric-evidence-first
        path: geek/ai/ai-agents/llm-judge-rubric-evidence-first
        required: true
        tier_gate: geek
      - slug: chaos-eval-fault-injection
        path: geek/ai/ai-agents/chaos-eval-fault-injection
