  - name: "Pilot & GA"
    intent: "Customer-zero pilot, then GA with rollback wired."
    tasks:
      - "Run agent on real customer traffic shadow first"
      - "Wire incident runbook + tier-approval gate"
      - "Cut GA with rollback validated"
    methodologies:
      - slug: agents-production-deployment
        path: geek/ai/ml-engineer/agents-production-deployment
        required: true
        tier_gate: geek
      - slug: llm-observability-stack
        path: geek/ai/ml-engineer/llm-observability-stack
