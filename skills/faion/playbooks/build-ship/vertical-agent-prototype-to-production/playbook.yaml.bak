      - slug: inverted-header-content-first
        path: geek/ai/ai-agents/inverted-header-content-first
        required: true
        tier_gate: geek
    outputs:
      - "Memory architecture doc"
      - "Cache-hit baseline metric"
    decision_gate: |
      Advance when context stays under budget on the longest trace.
