# =============================================================================
# faion playbook manifest — P7 llm-agent-developer
# Generated for F-064 from playbook-index.json entry #11
# =============================================================================

slug: model-gateway-endpoint-addition
title: "Model-gateway endpoint addition"
version: "0.1.0"
status: draft
last_reviewed: 2026-05-20
maintainers: ["faion"]
content_id: 07508af4d07cf12d

tier_min: geek
complexity: medium
context: [team]
persona_hints: [P7]

intent: |
  New provider/model dropped → onboard as routable target without changing call sites.

scope: |
  Onboard a new provider/model (e.g. new Sonnet, Gemini point release, local Ollama) as a routable target without changing call sites. ~half-day per model.

non_goals:
  - "Building the gateway itself — see `multi-model-gateway-migration-portability`"
  - "Bench against the new model — separate playbook"

prerequisites:
  - "Existing gateway adapter"
  - "Eval suite green on current backends"

success_criteria:
  - "Adapter for new model wired"
  - "Routing rule + fallback updated"
  - "Eval run on the new backend"
  - "Routing pinned with rollback"

stages:
  - name: "Wrap"
    intent: "Wire adapter behind unchanged call sites."
    tasks:
      - "Add adapter for new endpoint"
      - "Confirm decision-framework signal"
    methodologies:
      - slug: llm-decision-framework
        path: geek/ai/ml-engineer/llm-decision-framework
        required: true
        tier_gate: geek
    outputs:
      - "Adapter PR"
    decision_gate: |
      Advance only when call sites are unchanged.
  - name: "Route"
    intent: "Routing + fallback policy update."
    tasks:
      - "Update gateway fallback chain"
      - "Update preference-trained router"
      - "Pick role assignment"
    methodologies:
      - slug: gateway-fallback-chain
        path: geek/ai/ai-agents/gateway-fallback-chain
        required: true
        tier_gate: geek
      - slug: preference-trained-router
        path: geek/ai/ai-agents/preference-trained-router
        required: true
        tier_gate: geek
      - slug: role-specialized-models
        path: geek/ai/ai-agents/role-specialized-models
        required: true
        tier_gate: geek
    outputs:
      - "Updated routing manifest"
    decision_gate: |
      Advance only when policy change is reviewable.
  - name: "Bench & Pin"
    intent: "Run eval; pin and ship."
    tasks:
      - "Bench on golden set"
      - "Pin model id in manifest"
    methodologies:
      - slug: model-evaluation
        path: geek/ai/ml-engineer/model-evaluation
        required: true
        tier_gate: geek
      - slug: evaluation-benchmarks
        path: geek/ai/ml-ops/evaluation-benchmarks
        required: true
        tier_gate: geek
    outputs:
      - "Bench results"
      - "Pin manifest update"
    decision_gate: |
      Ship only when bench passes and rollback is one-line.

common_pitfalls:
  - "Treating eval scores as ground truth without judge calibration"
  - "Shipping prompt or model changes without a regression gate"

quality_checklist:
  - "Can I roll back this change in one step?"
  - "Is the regression eval committed BEFORE the fix?"

related_playbooks:
  - eval-harness-continuous-benchmark-suite
  - agent-observability-drift-detection-rollout

token_budget_estimate: 9000
cli_invocations:
  human:  "faion get-content model-gateway-endpoint-addition --format md"
  agent:  "faion get-content model-gateway-endpoint-addition --format context"
  json:   "faion get-content model-gateway-endpoint-addition --format json"

changelog:
  - version: "0.1.0"
    date: 2026-05-20
    note: "Initial draft for F-064 P7 llm-agent-developer persona"

gaps:
  - methodology_slug: model-onboarding-checklist
    expected_tier: geek
    blocks_stage: 1
    note: "Gap from brainstorm-2026-05-17: model-onboarding-checklist required by playbook chain"
  - methodology_slug: gateway-adapter-template
    expected_tier: geek
    blocks_stage: 1
    note: "Gap from brainstorm-2026-05-17: gateway-adapter-template required by playbook chain"
