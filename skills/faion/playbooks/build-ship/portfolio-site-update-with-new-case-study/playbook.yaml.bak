slug: portfolio-site-update-with-new-case-study
title: "Portfolio site update with new case study"
version: "1.0.0"
status: draft
last_reviewed: 2026-05-20
maintainers:
  - faion-network
content_id: 3fad0494f5acaef9

tier_min: pro
complexity: medium
context: [solo]
persona_hints: ["P3"]

intent: |
  From the initial trigger to the closed outcome described in scope, deliver every artefact named in success_criteria without skipping the decision gates between stages.

scope: |
  A project closes successfully → add a case study to portfolio site within 2 weeks while co
  ntext is fresh. Done = published case study with metrics, client quote (if NDA permits), a
  nd shareable link queued into social rotation.

summary: "Portfolio site update with new case study — A project closes successfully → add a case study to portfolio site within 2 weeks while context is fresh. Done = published case study with metrics, clien..."

success_criteria:
  - "Every stage's decision gate is recorded as passed before the next stage starts."
  - "All artefacts named in the stage outputs are produced and signed off."
  - "A written close-out record exists for archival and post-mortem."

token_budget_estimate: 15000

stages:
  - name: "Scope"
    intent: "Define the scope, exit criteria, and the people who must agree on success."
    tasks:
      - "Restate the scope outcome for this engagement in one sentence."
      - "Identify who owns the scope output and who must approve it."
      - "Produce the scope artefact in the agreed format."
    methodologies:
      - slug: funnel-tactics-basics
        path: pro/marketing/conversion-optimizer/funnel-tactics-basics
        required: true
        tier_gate: pro
      - slug: growth-twitter-x-growth
        path: solo/marketing/smm-manager/growth-twitter-x-growth
        required: true
        tier_gate: solo
    outputs:
      - "Scope artefact (written, signed off)"
      - "Updated decision log entry for the scope step"
    decision_gate: "Advance to the next stage when the scope artefact is approved by the named owner; iterate if any blocker remains."
  - name: "Discovery"
    intent: "Gather evidence about the current state, stakeholders, constraints, and prior data."
    tasks:
      - "Restate the discovery outcome for this engagement in one sentence."
      - "Identify who owns the discovery output and who must approve it."
      - "Produce the discovery artefact in the agreed format."
    methodologies:
      - slug: ops-legal-basics
        path: pro/marketing/gtm-strategist/ops-legal-basics
        required: true
        tier_gate: pro
    outputs:
      - "Discovery artefact (written, signed off)"
      - "Updated decision log entry for the discovery step"
    decision_gate: "Advance to the next stage when the discovery artefact is approved by the named owner; iterate if any blocker remains."
  - name: "Plan"
    intent: "Turn discovery output into a written plan with owners, sequence, and risk reserves."
    tasks:
      - "Restate the plan outcome for this engagement in one sentence."
      - "Identify who owns the plan output and who must approve it."
      - "Produce the plan artefact in the agreed format."
    methodologies:
      - slug: business-storytelling
        path: solo/comms/communicator/business-storytelling
        required: true
        tier_gate: solo
    outputs:
      - "Plan artefact (written, signed off)"
      - "Updated decision log entry for the plan step"
    decision_gate: "Advance to the next stage when the plan artefact is approved by the named owner; iterate if any blocker remains."
  - name: "Execute"
    intent: "Run the plan in order of dependency; ship each output before moving on."
    tasks:
      - "Restate the execute outcome for this engagement in one sentence."
      - "Identify who owns the execute output and who must approve it."
      - "Produce the execute artefact in the agreed format."
    methodologies:
      - slug: growth-content-marketing
        path: solo/marketing/content-marketer/growth-content-marketing
        required: true
        tier_gate: solo
    outputs:
      - "Execute artefact (written, signed off)"
      - "Updated decision log entry for the execute step"
    decision_gate: "Advance to the next stage when the execute artefact is approved by the named owner; iterate if any blocker remains."
  - name: "Verify"
    intent: "Check the work against the exit criteria with the people who signed off in Scope."
    tasks:
      - "Restate the verify outcome for this engagement in one sentence."
      - "Identify who owns the verify output and who must approve it."
      - "Produce the verify artefact in the agreed format."
    methodologies:
      - slug: growth-customer-testimonials
        path: solo/marketing/content-marketer/growth-customer-testimonials
        required: true
        tier_gate: solo
    outputs:
      - "Verify artefact (written, signed off)"
      - "Updated decision log entry for the verify step"
    decision_gate: "Advance to the next stage when the verify artefact is approved by the named owner; iterate if any blocker remains."
  - name: "Communicate"
    intent: "Tell every stakeholder what changed, what's next, and what they own."
    tasks:
      - "Restate the communicate outcome for this engagement in one sentence."
      - "Identify who owns the communicate output and who must approve it."
      - "Produce the communicate artefact in the agreed format."
    methodologies:
      - slug: growth-linkedin-strategy
        path: solo/marketing/smm-manager/growth-linkedin-strategy
        required: true
        tier_gate: solo
    outputs:
      - "Communicate artefact (written, signed off)"
      - "Updated decision log entry for the communicate step"
    decision_gate: "Advance to the next stage when the communicate artefact is approved by the named owner; iterate if any blocker remains."

