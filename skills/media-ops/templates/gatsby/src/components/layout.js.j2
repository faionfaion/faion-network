import React from "react";
import { Link } from "gatsby";
import "../styles/global.css";

const Layout = ({ children }) => (
  <div className="site">
    <header className="site-header">
      <div className="container">
        <Link to="/" className="site-logo">
          {% if logo_path %}
          <img
            src="{{logo_path}}"
            alt=""
            className="logo-icon"
            width="36"
            height="36"
          />
          {% endif %}
          <span className="logo-text">{{site_title}}</span>
        </Link>
        {% if nav_links %}
        <nav className="site-nav">
          {% for link in nav_links %}
          <Link to="{{link.path}}" className="nav-link" activeClassName="active">
            {{link.label}}
          </Link>
          {% endfor %}
        </nav>
        {% endif %}
      </div>
    </header>
    <main className="container">{children}</main>
    <footer className="site-footer">
      <div className="container">
        <p className="footer-brand">{{site_title}}</p>
        <p className="footer-desc">
          {{site_description}}
        </p>
        {% if telegram_channel %}
        <a
          href="https://t.me/{{telegram_channel}}"
          target="_blank"
          rel="noopener noreferrer"
          className="footer-tg"
        >
          {{telegram_cta|default('Subscribe on Telegram')}}
        </a>
        {% endif %}
        <div className="footer-links">
          <a href="/sitemap-index.xml">Sitemap</a>
          <a href="{{rss_path|default('/feed.xml')}}">RSS</a>
        </div>
        <p className="footer-copyright">
          &copy; {new Date().getFullYear()} {{site_title}}
        </p>
      </div>
    </footer>
  </div>
);

export default Layout;
