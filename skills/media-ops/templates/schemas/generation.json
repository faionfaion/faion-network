{
  "type": "object",
  "required": ["title", "slug", "article", "description", "tags", "hashtags", "source_urls", "source_names", "image_prompt", "summary"],
  "properties": {
    "title": {"type": "string"},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "article": {"type": "string", "description": "Markdown body only, no frontmatter"},
    "description": {"type": "string", "maxLength": 120},
    "tags": {"type": "array", "items": {"type": "string"}, "minItems": 3, "maxItems": 6},
    "hashtags": {"type": "array", "items": {"type": "string"}, "minItems": 3, "maxItems": 5},
    "source_urls": {"type": "array", "items": {"type": "string"}},
    "source_names": {"type": "array", "items": {"type": "string"}},
    "image_prompt": {"type": "string", "description": "Scene description for image generation"},
    "summary": {"type": "string", "description": "1-2 paragraph summary for future editorial planning"}
  }
}
